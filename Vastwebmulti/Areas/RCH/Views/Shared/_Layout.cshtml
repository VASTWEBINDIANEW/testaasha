@using Microsoft.AspNet.Identity
@using Vastwebmulti.Models;
<!DOCTYPE html>
<html>
<head>
    @{
        var comnyname = "";
        VastwebmultiEntities DB1 = new VastwebmultiEntities();
        var companyname = DB1.Admin_details.ToList();
        if (companyname.Count > 0)
        {
            comnyname = companyname.FirstOrDefault().Companyname;
            ViewBag.companyname = comnyname;
        }
        else
        {
            comnyname = "";
        }
    }
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <title>@ViewBag.companyname</title>
    <!-- Favicon-->
    @{
        var favimage = "";
        VastwebmultiEntities db2 = new VastwebmultiEntities();
        var faviconlogo = db2.tblfavicons.Where(p => p.Role == "ADMIN").ToList();
        if (faviconlogo.Count() > 0)
        {
            if (faviconlogo.SingleOrDefault().Role == "ADMIN")
            {
                favimage = faviconlogo.SingleOrDefault().faviconimage;
            }
        }
        else
        {
            <link rel="icon" href="" type="image/x-icon" />
        }
    }
    <link rel="icon" href="@Url.Content("~/" + @favimage)" type="image/x-icon" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Roboto:400,700&subset=latin,cyrillic-ext" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" type="text/css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <!-- Wait Me Css -->
    <link href="~/AdminDesign/plugins/waitme/waitMe.css" rel="stylesheet" />
    <!-- Bootstrap Core Css -->
    <link href="~/AdminDesign/plugins/bootstrap/css/bootstrap.css" rel="stylesheet">
    <!-- Waves Effect Css -->
    <link href="~/AdminDesign/plugins/node-waves/waves.css" rel="stylesheet" />
    <!-- Animation Css -->
    <link href="~/AdminDesign/plugins/animate-css/animate.css" rel="stylesheet" />
    <!-- Morris Chart Css-->
    <link href="~/AdminDesign/plugins/morrisjs/morris.css" rel="stylesheet" />
    <!-- Custom Css -->
    <link href="~/AdminDesign/css/style.css" rel="stylesheet">

    <link href="~/AdminDesign/plugins/bootstrap-select/css/bootstrap-select.css" rel="stylesheet" />
    <!-- AdminBSB Themes. You can choose a theme from css/themes instead of get all themes -->
    <link href="~/AdminDesign/css/themes/all-themes.css" rel="stylesheet" />
    <link href="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/css/dataTables.bootstrap.css" rel="stylesheet">
    <link href="~/AdminDesign/plugins/bootstrap-material-datetimepicker/css/bootstrap-material-datetimepicker.css" rel="stylesheet" />
    <link href="~/AdminDesign/plugins/sweetalert/sweetalert.css" rel="stylesheet" />
    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
    <link href="~/fonts/icofont.css" rel="stylesheet" />
    @if (!HttpContext.Current.Request.IsLocal)
    {
        <!-- To Disable Inspect Element -->
        <script src="~/Scripts/Disable_Inspect_Element/Disable_Inspect.js"></script>
    }
    <style>
        .navbar .navbar-toggle:before {
            content: '\E8D5';
            font-family: 'Material Icons';
            font-size: 26px;
        }

        .navbar .navbar-toggle:before {
            content: '\E8D5';
            font-family: 'Material Icons';
            font-size: 26px;
        }

        .sidebar .menu .list i.material-icons {
            margin-top: 6px;
        }

        .sidebar .menu .list .ml-menu li a {
            font-size: 11px;
        }

        .material-icons {
            font-size: 20px;
        }
        .theme-pink .sidebar .menu .list li.active > :first-child i, .theme-pink .sidebar .menu .list li.active > :first-child span {
            color: #fff !important;
        }
       
    </style>
</head>
@{
    var col = "";
    VastwebmultiEntities DB = new VastwebmultiEntities();
    var color = DB.changecolors.Where(p => p.Role == "RCH").ToList();
    if (color.Count > 0)
    {
        if (color.SingleOrDefault().Role == "RCH")
        {
            col = color.Where(p => p.Role == "RCH").SingleOrDefault().adminandouterheadercolor;
        }
    }
    else
    {
        col = "pink";
    }
    string userid = User.Identity.GetUserId();
    var ch = DB.RCH_Details.FirstOrDefault(m => m.RCHId == userid);
    ViewBag.rch = ch;
    ViewBag.image = ch.Photo;

    var logoimage = "";
    var logo = DB.tblHeaderLogoes.Where(p => p.Role == "ADMIN").ToList();
    if (logo.Count > 0)
    {
        if (logo.SingleOrDefault().Role == "ADMIN")
        {
            logoimage = logo.Where(p => p.Role == "ADMIN").SingleOrDefault().LogoImage;
        }
    }
    else
    {
        logoimage = "images/Default_Logo.png";
    }
}
<body class="theme-@col">
   
    <!-- Page Loader -->
    <div class="page-loader-wrapper">
        <div class="loader">
            <center><img src="~/images/serachimg.gif" class="img-responsive" style="height:200px;width:200px;" /></center>

        </div>
    </div>

   
    <!-- #END# Page Loader -->
    <!-- Overlay For Sidebars -->
    <div class="overlay"></div>
    <!-- #END# Overlay For Sidebars -->
    <!-- Search Bar -->
    <div class="search-bar">
        <div class="search-icon">
            <i class="material-icons">search</i>
        </div>
        <input type="text" placeholder="START TYPING...">
        <div class="close-search">
            <i class="material-icons">close</i>
        </div>
    </div>
    <!-- #END# Search Bar -->
    <!-- Top Bar -->
    <nav class="navbar">
        <div class="container-fluid" style="border-bottom: 4px solid #878181;">
            <div class="navbar-header" style="padding:0px 0px;">
                @*<a href="javascript:void(0);" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar-collapse" aria-expanded="false"></a>*@
                <a href="javascript:void(0);" class="bars"></a>
                <a href="~/RCH/Home/Dashboard">
                    <center>
                        <img src="@Url.Content("~/"+@logoimage)" class="img-responsive" style="height: auto; max-width: 135px; padding: 7px;" />
                    </center>
                </a>
            </div>
            <div class="collapse navbar-collapse" id="navbar-collapse">
                <ul class="nav navbar-nav navbar-right">
                </ul>
            </div>
        </div>
    </nav>
    <!-- #Top Bar -->
    <section>
        <!-- Left Sidebar -->
        <aside id="leftsidebar" class="sidebar" style=" background: #e91e63; top:70px;">
            @{ 
            var currentuser = User.Identity.GetUserId();
            var emailid = DB.Users.Where(a => a.UserId == currentuser).SingleOrDefault().Email.ToString();
        }
          <div class="user-info navbar" style="height:157px;">
              <center>
                  @if (ViewBag.image != null)
                  {
                      <div class="image" style="margin-top:24px;">
                          <img src="@Url.Content("~/"+ ViewBag.image )" class="img-circle" alt="User" width="50" height="50" />
                      </div>
                  }
                  else
                  {
                      <div class="image" style="margin-top:24px;">
                          <img src="~/AdminDesign/images/user.png" width="100" height="100" class="img-circle" alt="User">
                      </div>
                  }
              </center>

                <center>
                    <div class="legal" style="background:none; position:relative; padding:0px;">
                        <div class="name" style="color:white;">@ViewBag.rch.RCHName</div>
                        <div class="email" style="color:white;">@emailid</div>
                        <div style="margin-top:2px;margin-right:19px;">
                            <a href="@Url.Action("Profile","Home")" class="btn btn-info">Profile</a>
                            <div style="float:right;">

                                @using (Html.BeginForm("LogOff", "Account", new { Area = "" , id = "logoutForm" }))
                                {
                                    @Html.AntiForgeryToken()
                                   <input type="submit" value="Sign out" class="btn btn-danger" />
                                }
                            </div><br />
                            <center style="margin-top:10px;"><a href="~/RCH/Home/ChangePassword" style="color:white; text-decoration:none;"><i class="material-icons" style="font-size:16px;">https</i><span>Change Password</span></a></center>
                          </div>
                    
                    </div>
               
                </center>
            </div>
            <!-- #User Info -->
            <!-- Menu -->
            <div class="menu">
                <ul class="list">
                    <li class="active">
                        <a href="~/RCH/Home/Index">
                            <i class="material-icons">home</i>
                            <span>Home</span>
                        </a>
                    </li>
                    <li>
                        <a href="~/RCH/Home/Operator_Manage">
                            <i class="material-icons">donut_large</i>
                            <span>Manage</span>
                        </a>
                      </li>
                    </ul>
            </div>
            <!-- #Menu -->
            <!-- Footer -->
            <div class="legal">
                <div class="copyright">
                    &copy; &nbsp;2019 - <span>@DateTime.Now.Year.ToString()</span>
                </div>
                <div class="copyright">
                    <a href="javascript:void(0);">@comnyname</a>.
                </div>
            </div>
            <!-- #Footer -->
        </aside>
  >
    </section>
        @RenderBody()
      
    <!-- Jquery Core Js -->
    <script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
    <script src="~/Swalalert/datatablejquery.js"></script>
    <!-- Bootstrap Core Js -->
    <script src="~/AdminDesign/plugins/bootstrap/js/bootstrap.js"></script>
    <!-- Autosize Plugin Js -->
    <script src="~/AdminDesign/plugins/autosize/autosize.js"></script>
    <!-- Select Plugin Js -->
    <!-- Slimscroll Plugin Js -->
    <script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
    <!-- Waves Effect Plugin Js -->
    <script src="~/AdminDesign/plugins/node-waves/waves.js"></script>
    <!-- Jquery CountTo Plugin Js -->
    <script src="~/AdminDesign/plugins/jquery-countto/jquery.countTo.js"></script>
    <!-- Morris Plugin Js -->
    <script src="~/AdminDesign/plugins/raphael/raphael.min.js"></script>
    <script src="~/AdminDesign/plugins/morrisjs/morris.js"></script>
    <!-- ChartJs -->

    <!-- Flot Charts Plugin Js -->
    <script src="~/AdminDesign/plugins/flot-charts/jquery.flot.js"></script>

       <!-- Sparkline Chart Plugin Js -->
    <!-- Custom Js -->
    <script src="~/AdminDesign/js/admin.js"></script>
    <script src="~/AdminDesign/js/pages/index.js"></script>
    <!-- Demo Js -->
    <script src="~/AdminDesign/js/demo.js"></script>
    <script src="~/AdminDesign/plugins/moment.min.js"></script>
    <script src="~/AdminDesign/plugins/daterangepicker.js"></script>
    <!--data table -->
    <script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
    <script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
    <script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
    <script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
    <script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
    <script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
    <script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
    <script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
    <script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
    <script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
    <script src="~/AdminDesign/plugins/bootstrap-material-datetimepicker/js/bootstrap-material-datetimepicker.js"></script>
    <script src="~/AdminDesign/plugins/sweetalert/sweetalert.min.js"></script>

    <script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
    <link href="~/Swalalert/datatable.css" rel="stylesheet" />
    <script>
    </script>
</body>
</html>
