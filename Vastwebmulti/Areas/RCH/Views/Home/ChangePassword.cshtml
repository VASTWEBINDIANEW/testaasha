@model Vastwebmulti.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "ChangePassword";
    Layout = "~/Areas/RCH/Views/Shared/_Layout.cshtml";
}
<section class="content">
    <div class="container-fluid">

        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="header navbar">
                        <h2 style="color:white;">
                            Change Password
                        </h2>
                    </div>
                    @using (Html.BeginForm("ChangePassword", "Home", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                    {
                        @Html.AntiForgeryToken()
                        <div class="body" style="margin-top:-21px;">
                            <div class="row clearfix">
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                <div class="col-sm-12">
                                    <label>Old Password</label>
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control", @required = "" })
                                            @Html.ValidationMessageFor(m => m.OldPassword, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <label>New Password</label>
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control", @required = "" })

                                        </div>
                                        @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger" })
                                    </div>
                                    <label>Confirm Password</label>
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", @required = "" })

                                        </div>
                                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
                                    </div>
                                    <button type="submit" class="btn btn-primary m-t-15 waves-effect">Change Password</button>
                                </div>
                            </div>

                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
<script src="~/Scripts/jquery-1.10.2.min.js"></script>
<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script>
        window.onload = function()
        {
            var message = '@TempData["Message"]'
            if(message !="" && message !=null)
            {
                swal("Good job!", message, "success")

            }
        }
</script>
