@model IEnumerable<Vastwebmulti.Models.PAN_CARD_IPAY_Token_report_paging_Result>
@{

    Layout = null;
}
@if (Model != null && Model.ToList().Count > 0)
{
    int sno = 0;
    foreach (var item in Model)
    {
        sno += 1;
        var sts = "";
        var color = "";
        var img = "";
        var style = "";
        var pendingColor = "";
        if (item.Particulars.Contains("Pending"))
        {
            color = "#ff9600";
            sts = "Pending";
            img = "../../ashok-images/clkk.png";
            style = "height:20px;width:20px;margin-right:3px;float:left;";
            pendingColor = "#fff8d1";

        }
        if (item.Particulars.Contains("Success"))
        {
            color = "green";
            sts = "Success";
            img = "../../ashok-images/correct.svg";
            style = "height:20px;width:20px;margin-right:3px;float:left;";
        }
        if (item.Particulars.Contains("Failed"))
        {
            color = "red";
            sts = "Failed";
            img = "../../ashok-images/closes.svg";
            style = "height:20px;width:20px;margin-right:3px;float:left;";
        }
        if (item.Particulars.Contains("Refund"))
        {
            color = "#9C27B0";
            sts = "Refund";
            img = "../../ashok-images/undo.svg";
            style = "height:20px;width:20px;margin-right:3px;float:left;";
        }
<tr style="background-color:@pendingColor">
    <td>@sno</td>
    <td class="pancardtablestatus"><p style="color:;font-size:15px;font-weight:700;"><img style="@style background-color:@color;" src=@img /><span style="font-size:0;">@sts</span><span class="addtxnid">@Html.DisplayFor(modelItem => item.MerchantTxnId)</span></p></td>
    <td style="display:none;">@Html.DisplayFor(modelItem => item.Email)</td>
    <td>@Html.DisplayFor(modelItem => item.ProcessingFees)</td>
    <td>@Html.DisplayFor(modelItem => item.PhysicalCount)</td>
    <td>@Html.DisplayFor(modelItem => item.DigitalCount)</td>
    <td style="display:none;">@Html.DisplayFor(modelItem => item.MerchantTxnId)</td>
    <td>@Html.DisplayFor(modelItem => item.UTI_TXN_ID)</td>
    <td>@Html.DisplayFor(modelItem => item.CouponStatus)</td>
    <td>@Html.DisplayFor(modelItem => item.Date)</td>
    @{
        var sd = item.ProcessingFees - item.RetailerIncome;
    }
    <td>@Html.DisplayFor(modelItem => sd)</td>
    <td style="display:none;">
        <button class="btn btn default" id="tokenStatus" onclick="tokenStatus('@item.idno')" style="margin-left:2px;  background-color:transparent; border:none;border:1px solid #c7c2c2;margin-top:4px; padding:1px 6px 1px 6px;" title="View Pancard Status">
            View
        </button>
    </td>
    <td>@Html.DisplayFor(modelItem => item.retailer_remain_pre)</td>
    <td>@Html.DisplayFor(modelItem => item.RetailerIncome)</td>
    <td>@Html.DisplayFor(modelItem => item.retailer_remain_post)</td>


    <td class="aepsprintbutton nextaepsbutton">
        <i class="material-icons" style="cursor:pointer;">print</i>
        <button class="btn btn default" id="tokenStatus" onclick="tokenStatus('@item.idno')" style="margin-left:2px;  background-color:transparent; border:none;border:1px solid #c7c2c2;margin-top:4px; padding:1px 6px 1px 6px;" title="View Pancard Status">
            View
        </button>
    </td>
</tr>
    }
}
else
{
<tr>
    @if (@ViewBag.checkdata != null)
    {
        <td colspan="13"><h3 style="text-align:center;">No Data For Current Search</h3></td>
    }
    else
    {
        <td colspan="13"><h3 style="text-align:center;">Data Not Found</h3></td>
    }
</tr>

}
