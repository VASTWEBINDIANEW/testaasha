<script>
    var txt_frm_date = $('#txt_frm_date').val();
    var txt_to_date = $('#txt_to_date').val();
    var ddl_status = $('#ddl_status').val();

        var pageindex = 2;
        var NoMoredata = false;
        var inProgress = false;
    $(window).scroll(function () {
            if ($(window).scrollTop() > Number($("#tbldata").height()) / 4 && !NoMoredata && !inProgress) {
                inProgress = true;
                $("#loadingdiv").show();
                $.post("@Url.Action("InfiniteScroll","Home")",
             { "pageindex": pageindex, "txt_frm_date":txt_frm_date,"txt_to_date":txt_to_date,"ddl_status":ddl_status},
                    function (data) {
                        pageindex = pageindex + 1;
                        NoMoredata = data.NoMoredata;
                        $("#trow").append(data.HTMLString);
                        $("#loadingdiv").hide();
                        inProgress = false;
                    });
            }
        });
</script>
<script>
    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 45 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }
</script>
<!--Calendar Javascript-->
<script>
    $(function () {

        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

    });
</script>
<script>
    function tokenStatus(id) {
        var url = '@Url.Action("GetTokenStatus", "PANCARD")'
        var jqxhr = $.post(url, {id : id}, function (data) {
            var response = JSON.parse(data);
            if (response.RESULT == "0") {
                swal("Wow!", response.ADDINFO, "success");
            }
            else if (response.RESULT == "2") {
                swal("Oops!", response.ADDINFO, "warning");
            }
            else {
                swal("Oops!!!", response.ADDINFO, "error");
            }
        })
       .fail(function (jqXHR, textStatus, errorThrown) {

           swal("Oops!!!", jqXHR.responseText, "error");

       })

    }
</script>



