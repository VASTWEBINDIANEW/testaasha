<section class="content" >

    <!--Catagory List-->
    <div class="container-fluid">
        <div class="row clearfix">
            @if (serviceerror == "NOTOK")
            {
                <div id="firstECOMM" class="col-md-12" style="text-align:center;">
                    <img src="~/ashok-images/forbidden.svg" style="width:90px;display:block;margin: 0px auto;" />
                    <span class="bodycolormy" style="margin-top: 20px;margin-bottom: 20px;font-size: 26px;">ECOMMERCE Service Expired !</span>
                    <p style="margin-bottom: 20px;text-align: justify;">Your service is currently down, if you want to keep the service running smoothly, you will have to pay the service fee, which you see below and you can purchase the service by clicking the button.</p>
                    <button class="btn btn-default fullbodydycolorbg" onclick="PurchaseECOMM('ECOMM')" style="color: #fff;">ECOMMERCE Purchase</button>
                    <button class="btn btn-default fullbodydycolorbg" onClick="window.location.href=window.location.href">Refresh Page</button>
                </div>
            }

            else if (serviceerror == "ALLNOTDONE")
            {
                <div id="ALLECOMM" class="col-md-12" style="text-align:center;">

                    <img src="~/ashok-images/forbidden.svg" style="width: 90px;display: block;margin: 0px auto;" />
                    <span class="bodycolormy" style="margin-top: 20px;margin-bottom: 20px;font-size: 26px;">ECOMMERCE Service Expired !</span>
                    <p style="margin-bottom: 20px;text-align: justify;">Your service is currently down, if you want to keep the service running smoothly, you will have to pay the service fee, which you see below and you can purchase the service by clicking the button.</p>
                    <button class="btn btn-default fullbodydycolorbg" onclick="PurchaseECOMM('ALL')" style="color: #fff;">ALL Purchase</button>
                    <button class="btn btn-default fullbodydycolorbg" onClick="window.location.href=window.location.href">Refresh Page</button>

                </div>
            }
            else if (serviceerror == "BOTHNOTDONE")
            {
                <div id="BOTHECOMM" class="col-md-12" style="text-align: center;">
                    <img src="~/ashok-images/forbidden.svg" style="width: 90px; display: block; margin: 0px auto; " />
                    <span class="bodycolormy" style="margin-top: 20px;margin-bottom: 20px;font-size: 26px;">ECOMMERCE Service Expired !</span>
                    <p style="margin-bottom: 20px;text-align: justify;">Your service is currently down, if you want to keep the service running smoothly, you will have to pay the service fee, which you see below and you can purchase the service by clicking the button.</p>
                    <button class="btn btn-default fullbodydycolorbg" onclick="PurchaseECOMM('ALL')" style="color: #fff;">ALL Purchase</button>
                    <button class="btn btn-default fullbodydycolorbg" onclick="PurchaseECOMM('ECOMM')" style="color: #fff;">ECOMMERCE Purchase</button>
                    <button class="btn btn-default fullbodydycolorbg" onClick="window.location.href=window.location.href">Refresh Page</button>

                </div>
            }




            <div id="secpurECOMM" class="col-md-12 remitter_button remitter_buttonewq" style="display:none;text-align: center;">
                <span style="margin-top:0;">Payment Details</span>
                <div class="lavbrd">
                    <label>Mode</label>
                    <label class="rightlable" id="PaymentType111"></label>
                </div>
                <div class="lavbrd">
                    <label>Amount</label>
                    <label class="rightlable" id="Price111"></label>
                </div>
                <div class="coldebuttonnew">
                    <button class="bacbuttonrrt" onClick="window.location.href=window.location.href">Back</button>
                    <button class="btn btn-default fullbodydycolorbg" onclick="FinalPurchaseECOMM()" style="color: #fff;">Pay Now</button>
                </div>
                <br />
                <label id="errmsgmicro" style="color:red;"></label>
            </div>




            @if (serviceerror == "OK")
            {

                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" id="lstProducts">
                    @Html.Action("_productlist", "ECommerce", new { ProductName = Model.ProductName, SortBy = Model.SortBy })
                </div>
            }
        </div>
    </div>
    <input type="hidden" id="HDServicesname" name="HDServicesname" value="" />

    <!--Catagory List END-->
