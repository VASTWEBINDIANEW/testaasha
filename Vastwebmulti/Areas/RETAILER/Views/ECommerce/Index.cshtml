<script type="text/javascript">

        $.noConflict();
        jQuery(document).ready(function ($) {
            var sts = '@TempData["Status"]';
            var msg = '@TempData["Message"]';
            if (sts != null && sts != '')
            {
                if (sts == "Success")
                {
                    $.notify(msg, {
                        animate: {
                            enter: 'animated fadeInRight',
                            exit: 'animated fadeOutRight'
                        },
                        type: 'success'
                    });
                }
                else {
                    $.notify(msg, {
                        animate: {
                            enter: 'animated fadeInRight',
                            exit: 'animated fadeOutRight'
                        },
                        type: 'danger'
                    });
                }
            }


            $("#txtSearch").autocomplete({
                source:'@Url.Action("FindProductByName")',
                minLength: 1
            });
            $('#txtSearch').on('autocompleteselect', function (e, ui) {
                //alert("item " + ui.item.value + " selected");
                //$("#ProductName").val(ui.item.value);
                //$("#lstProductsSubmit").click();

            });
        });
</script>


