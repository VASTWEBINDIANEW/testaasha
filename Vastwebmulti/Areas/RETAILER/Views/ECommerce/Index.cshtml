<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>
<script src="~/Scripts/PageScript/Retailer/ProductList.js"></script>

<script>

 

    function PurchaseECOMM(e) {
            $('#HDServicesname').val('');
        $.ajax({
            url: '@Url.Action("ServiceCharge", "Home")',
            data: { Service: e },
            cache: false,
            type: "POST",
            dataType: 'json',
            success: function (data) {
                
                $('#secpurECOMM').show();
                $('#PaymentType111').html(data.PaymentType);
                $('#Price111').html(data.Price);
                $('#ALLECOMM').hide();
                $('#BOTHECOMM').hide();
                $('#firstECOMM').hide();

                $('#HDServicesname').val(e);
            }
        });
    }
    function FinalPurchaseECOMM() {

         $.ajax({
            url: '@Url.Action("ServicePurchase", "Home")',
             data: { Service: $('#HDServicesname').val() },
            cache: false,
            type: "POST",
             dataType: 'json',
            beforeSend: function() {
                      $('.loader').show();
                     },
             success: function (data) {

                 if (data.Status == "Success") {
                     $('#HDServicesname').val('')
                     window.location.reload();
                 }
                 else {
                     $('#errmsgmicro').text(data.Message);
                 }

             },
             complete: function () {
                 $('.loader').hide();
                 $("#remainretailer").load(location.href + " #remainretailer");
             },
             error: function () {
                 $("#remainretailer").load(location.href + " #remainretailer");
                 $('.loader').hide();
             }
        });
    }
</script>