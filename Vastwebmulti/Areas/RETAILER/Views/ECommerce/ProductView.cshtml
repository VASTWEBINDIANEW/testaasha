        <div style="float:right;">
            <a href="@Url.Action("ProductView",new { id = Model.ProductID ,type = "Addcartitem"})" class="btn bg-grey waves-effect" style="margin-left:-119%;">
                <i class="material-icons">add_shopping_cart</i>
                <span style="top:-1px;">Add to Cart</span>
            </a>
            <a href="@Url.Action("viewCart","ECommerce")" class="btn bg-grey waves-effect" style="margin-left:-119%;">
                <i class="material-icons">shopping_cart</i>
                <span style="top:-1px;"> GO TO CART</span>
            </a>
