            </div>
             <div class="col-lg-6 col-md-6 col-sm-8 col-xs-12">
                   <div class="" style="min-height:528px;border:1px solid #0000001f;">
                                    <div id="" class="body scroll">
                                        <h3 style="color:#212121; font-size:23px;font-weight:400;">@Model.Name</h3>
                                        <p style="font-family:Roboto, Arial, sans-serif;color:#212121;">@Model.ShortDescription</p>
                                        <span style="text-decoration:line-through;color:#0000008f;">
                                            MRP : ₹&nbsp;@Model.ListPrice
                                        </span>
                                        <br />
                                        <small>
                                            <span style="color:#212121;">PRICE : ₹&nbsp;</span><span style="color:black;font-weight:700;">@Model.StandardPrice</span>
                                        </small>
                                        <br />
                                        @if (Model.stock != null && Model.stock > 0)
                                {
                                    <p style="color:greenyellow;">
                                        <small style="color:greenyellow;">
                                            <span style="color:#212121;">IN STOCK :</span><span style="color:black;font-weight:700;">@Model.stock</span>
                                        </small>
                                    </p>
                                }
                                else
                                {
                                    <small style="color:greenyellow;">
                                        <span style="color:#212121;">IN STOCK :</span><span style="color:black;font-weight:700;">@Model.stock</span>
                                    </small>
                                }
                                        <hr style="border-top:1px solid #eeeeee4d;" />
                                        <span style="color:#212121d9; font-family:Roboto, Arial, sans-serif; font-weight:500;">
                                            @Html.Raw(Model.FullDescription)
                                        </span>
                                        <br />
                                        <p style="color:#212121; font-family:Roboto, Arial, sans-serif;">
                                            Vendor: This Product is Filled And Soled By
                                            <a href="javascript:void(0);" style="color:#0035f7;">@ViewBag.Vendor.Firmname</a>
                                        </p>


                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
            </div>
        </div>
    </div>
    <!-- END-->
</section>

@Html.Partial("Loder")
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/Retailerimagezoom/imagezoom.js"></script>
<script src="~/AdminDesign/Retailerimagezoom/jquery.magnific-popup.js"></script>
<script src="~/AdminDesign/Retailerimagezoom/move-top.js"></script>
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />

