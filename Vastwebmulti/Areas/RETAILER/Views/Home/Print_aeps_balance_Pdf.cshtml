    <body>
        @*@if (ViewBag.notfound == "OK")
            {*@
        <div class="receipt">
            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                <tbody>
                    <tr>
                        <td colspan="2" align="center">
                            <img src="@Url.Content("~/" + logoimage)" class="img-responsive" alt="Logo" />
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2" align="left"><strong>Transaction: Successful</strong></td>
                    </tr>

                    <tr>
                        <td colspan="2" align="left"><strong>RRN:</strong> -@ViewData["rrnno"] </td>
                    </tr>
                    <tr>
                        <td colspan="2" align="left"><strong>Date</strong> - @DateTime.Now.ToString("d-MMM-yyyy HH:mm:ss") </td>
                    </tr>
                    <tr>
                        <td align="left"><strong>Retailer Firm:</strong>@ViewData["firmname"]</td>
                    </tr>
                    @*<tr>
                            <td colspan="2" align="left"><strong>Sender No: @ViewData["senderno"] </strong></td>
                        </tr>*@
                    <tr>
                        <td colspan="2" align="left"><strong>Bank Name:</strong> @ViewData["Bankname"]</td>
                    </tr>
                    <tr>
                        <td colspan="2" align="left"><strong>Register Aadhar</strong> @ViewData["aadhar"] </td>
                    </tr>
                    <tr>
                        <td colspan="2" align="left"><strong>Register Mobile</strong> =@ViewData["mobile"]</td> 
                    </tr>
                    <tr>
                        <td colspan="2" align="left"><strong>AEPS Mode:</strong> BALANCE</td>
                    </tr>

                    <tr>
