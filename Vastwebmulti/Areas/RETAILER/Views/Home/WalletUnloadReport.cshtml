<script>
    function otpsend(otpcount, otpfor) {
                    $.ajax({
                        url: '@Url.Action("Transactionotpsend", "Home")',
                        data: { otpcount: otpcount, otpfor: otpfor },
                        cache: false,
                        type: "POST",
                        success: function (data) {
                            var status = data.status;
                            var msg = data.Message;
                            if (status =="Success") {
                                msg = data.Message

                                setTimeout(() => {
                                    let deadline = new Date().getTime() + 60000;
                                    let x = setInterval(function () {
                                        let now = new Date().getTime();
                                        let t = deadline - now;
                                        let seconds = Math.floor((t % (1000 * 60)) / 1000);
                                        document.getElementById("demo").innerHTML = "Resend OTP after " + seconds + " seconds ";
                                        if (seconds < 0) {
                                            clearInterval(x);
                                            document.getElementById("demo").style.display = "none";
                                            document.getElementById('hideshowotpbtn').style.display = "none"
                                            document.getElementById('resendotp').style.display = "block"
                                        }
                                    }, 1000);
                                },4000)
                              

                                setTimeout(() => {
                                    document.getElementById('hideshowotpbtn').style.display = "none",
                                        document.getElementById('otpsubmithideshow').style.display = 'block'
                                        document.getElementById('dmtsuccesscodeotp').style.display = "block"
                                        $('#dmtsuccesscodeotp').text(msg);
                                     setTimeout(() => {
                                         document.getElementById('dmtsuccesscodeotp').style.display="none"
                                         },5000)
                                });
                            }
                            else {
                                $('#dmterrorcodeotp').text(msg);
                                setTimeout(() => {
                                    document.getElementById('dmterrorcodeotp').style.display = "none"
                                }, 4000)
                            }
                        }
                    })
                }
</script>

