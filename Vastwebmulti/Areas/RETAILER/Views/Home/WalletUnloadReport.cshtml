<style>
    @@keyframes ldio-zdyd6mf6t5 {
        0% {
            top: 96px;
            left: 96px;
            width: 0;
            height: 0;
            opacity: 1;
        }

        100% {
            top: 18px;
            left: 18px;
            width: 156px;
            height: 156px;
            opacity: 0;
        }
    }

    .ldio-zdyd6mf6t5 div {
        position: absolute;
        border-width: 4px;
        border-style: solid;
        opacity: 1;
        border-radius: 50%;
        animation: ldio-zdyd6mf6t5 1s cubic-bezier(0,0.2,0.8,1) infinite;
    }

        .ldio-zdyd6mf6t5 div:nth-child(1) {
            border-color: #e90c59;
        }

        .ldio-zdyd6mf6t5 div:nth-child(2) {
            border-color: #46dff0;
            animation-delay: -0.5s;
        }

    .loadingio-spinner-ripple-92ar2pfqk5j {
        width: 200px;
        height: 200px;
        display: inline-block;
        overflow: hidden;
        background: transparent;
    }

    .ldio-zdyd6mf6t5 {
        width: 100%;
        height: 100%;
        position: relative;
        transform: translateZ(0) scale(1);
        backface-visibility: hidden;
        transform-origin: 0 0;
    }

    .statusimg-winload img {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        padding: 5px;
    }

    .statusimg-winload span {
        font-size: 0px;
    }

    .unload-date .form-iconmy {
        padding: 0 6px;
        text-align: center;
        justify-content: center;
        display: flex;
        align-items: center;
        height: 32px;
    }

    .walletunhold-radio label {
        float: left;
        display: flex !important;
        align-items: center;
        justify-content: center;
    }

        .walletunhold-radio label:last-child {
            float: right;
        }

    .walletunhold-radio [type="radio"]:checked + label::after, .walletunhold-radio [type="radio"].with-gap:checked + label::after {
        background: var(--main-bg-lcolor);
        border-color: var(--main-bg-lcolor);
    }

    .walletunhold-radio {
        width: 100%;
        float: left;
        padding: 5px;
        border-bottom: 1px solid #ddd;
        margin-bottom: 15px;
    }

    .walletunhold-blance {
        font-size: 17px;
    }

    .table-scrool-wallet {
        width: 100%;
        float: left;
        overflow: auto;
        height: 250px;
    }

    .bread-same-all-page ul {
        width: 100%;
        float: left;
        margin:0px;
    }

        .bread-same-all-page ul li {
            margin-bottom: 0px;
        }

    .col-md-12.colmdwerty {
        clear: both;
    }

    .form-group {
        margin-bottom: 13px;
    }

    .datepicker-dropdown.datepicker {
        margin-top: 90px !important;
    }

    .colmdwerty-unlod-value h2 {
        width: 100%;
        float: left;
        border-bottom: 1px solid #ddd;
        padding-bottom: 4px !important;
        margin-bottom: 14px !important;
        padding-top: 0 !important;
    }

    .walletunload-header-table * {
        border-color: #555 !important;
    }

    .walletunload-header-table .col-md-2.walletsearchs button {
        background: #fff !important;
    }

    @@media only screen and (max-width:1169px) {
        .container-fluid.addnewcalsspadd {
            padding-left: 15px !important;
        }
    }

    @@media only screen and (max-width:991px) {
    }

    @@media only screen and (max-width:767px) {
    }

    @@media screen and (max-width:766px) {
        .col-md-3.buttonPdf {
            display: block;
        }
    }

    @@media only screen and (max-width:480px) {
        .walletunhold-radio label {
            padding: 8px !important;
            font-size: 11px !important;
            height: 55px !important;
        }
        .col-md-12.colmdwerty h2 {
            font-size: 18px !important;
        }

    }

</style>

