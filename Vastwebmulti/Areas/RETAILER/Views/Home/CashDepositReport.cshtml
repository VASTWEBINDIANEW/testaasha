<script>
    function mdActionBtn(Idno) {
        $('#loadredmodel').show();

        $.ajax({
            url: '@Url.Action("Microatm_View", "Home")',
            type: "POST",
            data: { Idno: Idno },
            cache: false,
            success: function (Response) {

                $("#DealerPre").val(Response[0].dealer_remain_pre);
                $("#Dlm_Comm").val(Response[0].dealer_comm);
                $("#dlmgst").val(Response[0].dealer_gst);
                $("#dlmtds").val(Response[0].dealer_tds);
                $("#DealerPost").val(Response[0].dealer_remain_post);

                $("#MasterPre").val(Response[0].master_remain_pre);
                $("#Md_Comm").val(Response[0].master_comm);
                $("#Mdgst").val(Response[0].master_gst);
                $("#Mdtds").val(Response[0].master_tds);
                $("#MasterPost").val(Response[0].master_remain_post);

                $("#Response").val(Response[0].resp);
            }
        });
    };

</script>
<script>
    $('#allwhitelabel1').select2();
    $('#allmaster2').select2();
    $('#alldealer').select2();
    $('#allretailer').select2();
</script>

<script>
    $(function()
    {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",
        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

        answers();
    });
</script>

<script type="text/javascript">
    function answers() {
        var e = document.getElementById("ddlusers");
        var answer = e.options[e.selectedIndex].value;
        if (answer == "Dealer") {
            document.getElementById("allmaster").style.display = "none";
            document.getElementById("dlm").style.display = "block";
            document.getElementById("rem").style.display = "none";
            document.getElementById("allwhitelabel").style.display = "none";
        }
        else if (answer == "Whitelabel") {
            document.getElementById("allmaster").style.display = "none";
            document.getElementById("allwhitelabel").style.display = "block";
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "none";

        }
        else if (answer == "Master") {
            document.getElementById("allmaster").style.display = "block";
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "none";
            document.getElementById("allwhitelabel").style.display = "none";
        }
        else if (answer == "Admin") {
            document.getElementById("allmaster").style.display = "none";
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "none";
            document.getElementById("allwhitelabel").style.display = "none";
        }
        else if (answer == "Retailer") {

            document.getElementById("allmaster").style.display = "none";
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "block";
            document.getElementById("allwhitelabel").style.display = "none";
        }
    }
</script>


<script>
    $("#btnExport").click(function (e) {
        e.preventDefault()
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var ddl_status = $('#ddl_status').val();
        var url = '@Url.Action("Excel_CashDeposit_Report", "Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&ddl_status=' + ddl_status;
        location.href = url
});

</script>
<script>
    $("#btnPDF").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var ddl_status = $('#ddl_status').val();
        var url = '@Url.Action("PDF_CashDepositReport", "Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&ddl_status=' + ddl_status;
        window.open(
url,
  '_blank' // <- This is what makes it open in a new window.
);
    });
</script>

