@{ int sno = 0; }

<section class="content aepsfullpage content-margin-second content-fourdesign-page allpage-four-design-section" style="overflow-x:hidden;">
    <div class="container-fluid Financial-page Financial-pagess Financial-pagess-responshive" style="height:100vh;">
        <!--Four-Design-Page-Header-Start-->

        <div class="page-title-box-fourde">
            <h3>Cash Deposit Report</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard", "Home")" style="color:var(--fullbodybg-four);background: transparent;margin: 0;padding: 0;">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);" style="background: transparent; margin: 0; padding: 0;">Report's&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);" style="background: transparent; margin: 0; padding: 0;">Cash Deposit Report</a></li>
            </ul>
        </div>

        <!--Four-Design-Page-Header-End-->
        <div class="newtabsreport newtabsreport-aepsclass newtabsreport-second" style="width:100%;">
            <div class="container container-tabsrepor money-transfer-retailer" style="padding:0;">
                @Html.Partial("_menuFinicalReport")
            </div>
        </div>
        <div class="row clearfix aeps-report-responshive aeps-report-microatm allfinancial-report-resons" style="margin:0px;width:100%;float:left;">
            @using (Html.BeginForm("CashDepositReport", "Home", FormMethod.Post))
            {
                <div class="col-md-12" style="padding:0;">
                    <div class="card class-back-tra-fourdesign" style="margin-bottom: 10px;">
                        <div class="page-header-third">
                            @*<div class="col-md-6" style="display:none;">
                                <div style="margin-left:-6px;">
                                    <p style="font-size:20px;color:#aba8a8;margin-top:2px;">Cash&nbsp;Deposit&nbsp;Report</p>
                                </div>
                            </div>*@
                            <div class="col-md-12 Financial-pagetabs" style="padding:0px;">
                                <div class="row" style="margin:0px;">
                                    <div class="col-md-2 aeps-statusclass" style="padding:0px;">
                                        <div class="form-group">
                                            <div class="" style="margin-top:5px;border:1px solid #dddddd;width:100%;padding-bottom:10px;">
                                                @Html.DropDownList("ddl_status", new List<SelectListItem>
                                           {
                                   new SelectListItem{ Text="All Status",Value="",},
                                   new SelectListItem{Text="Success",Value="Success"},
                                   new SelectListItem{Text="Failed",Value="Failed"},
                                   new SelectListItem{Text="Pending",Value="Pending"},
                                   }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;height:32px;" })

                                            </div>
                                        </div>

                                    </div>
                                    <div class="col-md-3 aeps-status finacial-selectsss" style="margin:0px !important;padding-left:3px;">
                                        <div class="form-group" style="margin-bottom:0px;margin-top:0px;">
                                            <div class="input-daterange input-group">
                                                <div class="datesate datesates">
                                                    <div class="form-iconmy" style="top: 0px;left: 1px;padding: 6px 5px;"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                                    @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;height:33px;", autocomplete = "off" })
                                                </div>
                                                <span class="input-group-addon">
                                                    <i class="fa fa-exchange" style="padding-top:10px;"></i>
                                                </span>
                                                <div class="datesate datesatese">
                                                    <div class="form-iconmy form-iconmyss" id="form-iconmyssee" style="top: 0px;left: 1px;padding: 6px 5px;left: 142px;"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                                    @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;height:33px;", autocomplete = "off" })
                                                </div>
                                            </div>
                                            <!-- /.input group -->
                                        </div>
                                    </div>
                                    <div class="col-md-1 aeps-status-search">
                                        <div class="form-group">
                                            <div class="form-line" style="border-bottom:none;">
                                                <button type="submit" class="btn" id="btntype" name="btntype" style="margin-top:5px; margin-left:2px; height:32px;border:1px solid #c7c2c2;background:#dedddd;">
                                                    <i class="fa fa-search" style="top:-1px;font-size:13px;color:black;"></i>
                                                    <span style="top:-1px;color:black;">Search</span>
                                                </button>

                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-3 buttonPdf retailer-pdf-second retailer-pdf-second-retailer" style="width:auto;float:right;">

                                        <button id="btnPDF">PDF</button>
                                        <button id="btnExport">Export</button>
                                        <button onclick="Findtotal()">Total</button>

                                    </div>

                                </div>
                            </div>


                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row clearfix rewrere rewrere-aeps-responshive">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:0px;">
                <div class="card class-back-tra-fourdesign">
                    <div class="body" style="padding:0;">
                        <div class="page-header-third">
                            <div class="table-responsive responsive-mposstatus tablethirddesign-newnew" style="position:inherit;margin-top:0px;">
                                <table class="table table-bordered table-striped table-hover third-design-table" style="width:100%; font-size:12px;">
                                    <thead style="background-color:whitesmoke;">
                                        <tr style="color: black;">
                                            <th>S.No.</th>
                                            <th>Status</th>
                                            <th>Firm Name</th>

                                            <th>Amount</th>
                                            <th>Time</th>
                                            <th>BankRRN&nbsp;No</th>
                                            <th>Ben&nbsp;Name</th>
                                            <th>Bank&nbsp;Name</th>
                                            <th>Remain&nbsp;Pre</th>
                                            <th>Comm</th>
                                            <th>GST</th>
                                            <th>TDS</th>
                                            <th>Remain&nbsp;Post</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model)
                                        {
                                            sno += 1;
                                            var img = "";
                                            var color = "";
                                            var pandingback = "";

                                            if (item.status.ToUpper() == "FAILED")
                                            {
                                                img = "../../ashok-images/closes.svg";
                                                color = "red";
                                            }
                                            if (item.status.ToUpper().Contains("REFUND"))
                                            {
                                                img = "../../ashok-images/undo.svg";
                                                color = "#9C27B0";
                                            }
                                            if (item.status.ToUpper() == "SUCCESS")
                                            {
                                                img = "../../ashok-images/correct.svg";
                                                color = "green";
                                            }
                                            if (item.status.ToUpper() == "PENDING")
                                            {
                                                img = "../../ashok-images/clkk.png";
                                                color = "#ffc107";
                                                pandingback = "#fff8d1";
                                            }
                                            <tr style="background:@pandingback;">
                                                <td>@sno</td>
                                                <td><img src="@img" style="background:@color;" />@item.status</td>
                                                <td>@item.Frm_Name</td>

                                                <td>@item.amount</td>
                                                <td>@item.req_date</td>
                                                <td>@item.bankrrn</td>
                                                <td>@item.benname</td>
                                                <td>@item.bankname</td>
                                                <td>@item.Rem_pre</td>
                                                <td>@item.rem_comm</td>
                                                <td>@item.rem_gst</td>
                                                <td>@item.rem_tds</td>
                                                <td>@item.rem_post</td>

                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>






