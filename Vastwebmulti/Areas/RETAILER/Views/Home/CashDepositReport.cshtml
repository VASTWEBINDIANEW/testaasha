    }

   

    .form-group {
        width: 100%;
    }

   
    .col-md-2.aeps-statusclass button {
        background-size: 11px !important;
    }
    .Financial-pagetabs *, .Financial-pagetabs .btn.dropdown-toggle.btn-default span, .Financial-pagetabs .aeps-status-search button i, .Financial-pagetabs .aeps-status-search button span {
        color: #555 !important;
    }

    @@media only screen and (max-width:1169px){

