@model Vastwebmulti.Models.PAN_CARD
@{
    ViewBag.Title = "View_PANCARD";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
}
<style>
  
      .text-view {
        text-transform: uppercase;
    }
    .textdesgin
    {
        
        font-family:'Times New Roman', Times, serif;
    }
    .table-bordered tbody tr td, .table-bordered tbody tr th
    {
        border:1px solid #1c1414;
    }
</style>
<section class="content" style="margin:90px 0px 0px 0px; ">
    <div class="container">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="header" style="padding:18px; padding-left:21px;">
                        <h2>
                            <span style="font-size:21px;"></span>PAN CARD RECEIPT

                            <a href="~/RETAILER/Home/Dashboard" class="btn bg-indigo  waves-effect" style="margin-top:-3px; margin-left:5px; float:right;">
                                <i class="material-icons" style="top:3px;">arrow_back</i>
                                <span style="top:-4px;">Back To Dashborad</span>
                            </a>
                        </h2>

                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
          
                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                    <div class="card" style="margin-top:-18px;">
                            <div class="body">
                                <div class="table-responsive">
                                    <table  class="table table-bordered" style="width:100%">
                                        <tr>
                                            <td class="tdtop navbar" colspan="4" style="text-align: center;position:initial;" align="center">
                                                <span style="font-size: 12pt;color:white;">Acknowledgement of PAN Application (Form 49A)</span>
                                        </td>
                                       
                                        </tr>
                                           <tr>
                                            <td class="textdesgin" style="padding:20px;">Acknowledgement Number</td>
                                               <td class="textdesgin" style="padding:20px;">
                                                   @{var ackno = !string.IsNullOrWhiteSpace(Model.Acknowledgement) ? Model.Acknowledgement : "";}
                                                   @ackno
                                               </td>
                                            <td class="textdesgin" style="padding:20px;">@Model.Date</td>
                                           <td class="textdesgin" style="padding:20px;"><span>PanCard -                                   <strong>@Model.Status</strong></span></td>
                                        </tr>
                                        <tr>
                                            <td class="textdesgin" style="padding:20px;">Category</td>
                                            <td class="textdesgin" style="padding:20px;font-size:12px;">INDIVIDUAL</td>
                                            <td style="border-right:none;padding:20px;" class="textdesgin" >
 <span>Fees&nbsp;Paid&nbsp;inclusive&nbsp;of&nbsp;Service&nbsp;Tax,&nbsp;SBC&nbsp;KKC&nbsp;as&nbsp;applicable&nbsp;(#)&nbsp;&nbsp;₹&nbsp;@Model.ProcessingFee</span></td>
                                            <td style="border-left:none;padding:20px;"></td>
                                        </tr>

                                        <tr>
                                            <td class="textdesgin" style="padding:20px;">Name on Card</td>
                                            <td class="textdesgin" style="padding:20px;">
                                            <span  style="font-size:12px;">@Model.Name_of_Card</span>
                                  <span class="text-view" style="font-size:12px;padding-left:8px;"><strong>@Model.Gender</strong></span>
                                            </td>
                                       <td class="textdesgin" style="padding:20px;">Pancard Number</td>
                                       <td class="textdesgin" style="padding:20px;"><span style="font-size:12px;">@Model.PAN_CARD_NO</span></td>
                                           
                                        </tr>

                                        <tr>
                                            <td class="textdesgin" style="padding:20px;">Father’s Name</td>
                                            <td class="textdesgin" style="padding:20px;">
                                                <span style="font-size:12px;">
                                                    @if (!string.IsNullOrWhiteSpace(Model.FFirstName))
                                                    {
                                              <span  style="font-size:12px;">@Model.FFirstName</span>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(Model.FMiddleName))
                                                    {
                                              <span  style="font-size:12px;">@Model.FMiddleName</span>
                                                    }
                                                    @Model.FLastName
                                                </span>
                                            </td>
                                            <td class="textdesgin" style="padding:20px;">State</td>
                                            <td class="textdesgin" style="padding:20px;"><span style="font-size:12px;">@ViewBag.state</span></td>

                                        </tr>
                                        <tr>
                               <td class="textdesgin" style="padding:20px;">Date&nbsp;Of&nbsp;Birth/&nbsp;Incorporation</td>
                               <td class="textdesgin" style="padding:20px;font-size:12px;border-right:none;">@Model.DOB</td>
                               <td style="border-right:none; border-left:none;padding:20px;" class="textdesgin"></td>
                               <td style="border-left:none;padding:20px;"></td>
                                        </tr>
                                        <tr>
                                            <td class="textdesgin" style="padding:20px;">AADHAAR Card Number</td>
                                            <td class="textdesgin" style="padding:20px;font-size:12px;border-right:none;">@Model.AdhaarNo</td>
                                            <td style="border-right:none; border-left:none;padding:20px;" class="textdesgin"></td>
                                            <td style="border-left:none;padding:20px;"></td>
                                        </tr>
                                        <tr>
                                            <td class="textdesgin" style="padding:20px;">Telephone/Mobile&nbsp;Number</td>
                                            <td class="textdesgin" style="padding:20px;">
                                                <span style="font-size:12px;">@Model.Mobile</span>
                                            </td>
                                            <td class="textdesgin" style="padding:20px;">E-mail ID</td>
                                            <td class="textdesgin" style="padding:20px;"><span style="font-size:12px;">@Model.Email</span></td>

                                        </tr>
                                        <tr>
                                            <td class="textdesgin" style="padding:20px;">Proof of Identity</td>
                                            <td class="textdesgin" style="padding:20px;font-size:12px;border-right:none;">@Model.ProofIdentity</td>
                                            <td style="border-right:none; border-left:none;padding:20px;" class="textdesgin"></td>
                                            <td style="border-left:none;padding:20px;"></td>
                                        </tr>
                                        <tr>
                                            <td class="textdesgin" style="padding:20px;">Proof of Address</td>
                                            <td class="textdesgin" style="padding:20px;font-size:12px;border-right:none;">@Model.ProofAddress</td>
                                            <td style="border-right:none; border-left:none;padding:20px;" class="textdesgin"></td>
                                            <td style="border-left:none;padding:20px;"></td>
                                        </tr>
                                        <tr>
                                            <td class="textdesgin" style="padding:20px;">Proof of DOB</td>
                                            <td class="textdesgin" style="padding:20px;font-size:12px;border-right:none;">@Model.ProofDOB</td>
                                            <td style="border-right:none; border-left:none;padding:20px;" class="textdesgin"></td>
                                            <td style="border-left:none;padding:20px;"></td>
                                        </tr>
                                        <tr>
                                            <td style="border-right:none;padding:20px;"></td>
                                            <td align="center" colspan="3" style="text-align: center;border-left:none;">
                                                <a href="pancard-certificate-view.php"><input id="btnClose" class="btn btn-primary" onclick="javascript:self.close()" type="button" value="Close" style="margin-right:17%;"></a>
                                            </td>
                                                                                
                                        </tr>
                                    </table>
                                    
                          
                                    
                                </div>
                                
                        </div>
                    </div>
                </div>
            
        </div>



    </div>
</section>

<!-- Jquery Core Js -->


<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-colorpicker/js/bootstrap-colorpicker.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/Scripts/PAN_CARD.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.js"></script>

<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>

<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
