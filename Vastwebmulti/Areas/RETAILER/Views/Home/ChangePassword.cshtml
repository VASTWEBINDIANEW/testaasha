            swal({
                title: "Are you sure?",
                text: "You want to reset your Transaction Pin",
                //text: kk,
                type: "warning",
                showCancelButton: true,
                confirmButtonColor: "#DD6B55",
                confirmButtonText: "Yes, Reset Transaction Pin!",
                closeOnConfirm: false
            },
     function (isConfirm) {
         if (isConfirm) {
             $("#resttarnspass").submit();
             return true;
         }
         else {
             return false;
         }
     });
        }
        else
        {
            //swal("Oops!", "Please Enter Register Email-Id", "error");
            $(".showclickerror").css("display", "block")
            return false;
        }

    }
</script>
