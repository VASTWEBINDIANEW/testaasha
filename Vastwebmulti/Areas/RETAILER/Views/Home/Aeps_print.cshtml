@using Vastwebmulti.Models;
@using Microsoft.AspNet.Identity
@{
    Layout = null;
}


@{
    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var userid = User.Identity.GetUserId();

    var Thermal = DB1.Printer_paperSize_Changes.Where(a => a.Print_Name == "Thermal_Print" && a.Userid == userid).SingleOrDefault().status;
    var A4_Size = DB1.Printer_paperSize_Changes.Where(a => a.Print_Name == "A4_Print" && a.Userid == userid).SingleOrDefault().status;


    var blockrecharge = DB1.Blocked_Recharge_Slip.Where(a => (a.Recharge_Mode == "Convence Fee" || a.Recharge_Mode == "Mobile" || a.Recharge_Mode == "Email" || a.Recharge_Mode == "Customer care" || a.Recharge_Mode == "Website Name") && a.status == "Y").ToList();
    var custfee = DB1.Blocked_Recharge_Slip.Where(a => a.Recharge_Mode == "Convence Fee").SingleOrDefault().status;
    var Mobile = DB1.Blocked_Recharge_Slip.Where(a => a.Recharge_Mode == "Mobile").SingleOrDefault().status;
    var Email = DB1.Blocked_Recharge_Slip.Where(a => a.Recharge_Mode == "Email").SingleOrDefault().status;
    var Customercare = DB1.Blocked_Recharge_Slip.Where(a => a.Recharge_Mode == "Customer care").SingleOrDefault().status;
    var WebsiteName = DB1.Blocked_Recharge_Slip.Where(a => a.Recharge_Mode == "Website Name").SingleOrDefault().status;
    var TotalAmount = DB1.Blocked_Recharge_Slip.Where(a => a.Recharge_Mode == "TotalAmount").SingleOrDefault().status;


    var logoimage = "";
    var logo = DB1.tblHeaderLogoes.Where(p => p.Role == "ADMIN").ToList();
    if (logo.Count > 0)
    {
        if (logo.SingleOrDefault().Role == "ADMIN")
        {
            logoimage = logo.Where(p => p.Role == "ADMIN").SingleOrDefault().LogoImage;
        }
    }
    else
    {
        logoimage = "images/Default_Logo.png";
    }
}


@if (Thermal != "N")
{

