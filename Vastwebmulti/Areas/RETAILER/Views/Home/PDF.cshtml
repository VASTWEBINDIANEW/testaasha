@model IEnumerable<Vastwebmulti.Models.pdf_creator_Result>
@{
    ViewBag.Title = "PDF";
}
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.2.1/jquery.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
<!DOCTYPE html>
<html lang="">
<body>
    <div style="width:100%; height:150px;">
        <div style="float:left;">
            <div><span style="font-size:25px; ">www.Vastwebmulti.in </span></div>
            <div><span style="font-size:18px;">Retailer Name : @ViewData["retailername"] </span> </div>
            <div><span style="font-size:18px;">Firm Name : @ViewData["firmname"] </span> </div>
            <div> <span style="font-size:18px; ">Retailer Mobile : @ViewData["retailermobile"] </span></div>
            <div> <span style="font-size:18px; ">Money Transfer Date : @ViewData["retailerdate"] </span></div>
        </div>
        <div style="float:right;">
            <img src="@Context.Server.MapPath("~/Images/Logo.png")" alt="PayNowRecharge" />
        </div>
    </div>
    <div style="background-color:Black;">
        <center>
            <h1 style="color:White; ">INVOICE </h1>
        </center>
    </div>
    <div style="height:40px;">
        <div style="float:left;">
            <span style="font-size:18px; ">Invoice No : @ViewData["invoiceno"]  </span>
        </div>
        <div style="float:right;">
            <span style="font-size:18px; "> Date : @ViewData["date"] </span>
        </div>
    </div>
    <table class="table">
        <tr>
            <th>Sr No.</th>
            <th>Sender Mob.</th>
            <th>Receiver</th>
            <th>A/C No.</th>
            <th>Bank Name </th>
            <th>IFSC  </th>
            <th>Amount  </th>
        </tr>
        @{int i = 1;}
        @foreach (var item in Model)
        {
            <tr>
                <td>@i</td>
                <td>@Html.DisplayFor(modelItem => item.senderno)</td>
                <td>@Html.DisplayFor(modelItem => item.recivername)</td>
                <td>@Html.DisplayFor(modelItem => item.accountno)</td>
                <td>@Html.DisplayFor(modelItem => item.bank_nm)</td>
                <td>@Html.DisplayFor(modelItem => item.ifsccode)</td>
                <td>@Html.DisplayFor(modelItem => item.amount)</td>
            </tr>
            i++;
        }
        <tr>
            <th>Total</th>
            <td></td>
            <td></td>
            <td></td>
            <td></td>
            <td></td>
            <th>@ViewData["Total"] </th>
        </tr>
    </table>
    <div>
        <center>
            <span style="font-size:22px; font-weight:bold;"> Thanks for using PayNowRecharge</span>
        </center>
    </div>
    <div>
        <div style="float:left;">
            <div style="font-size:14px; font-weight:bold;">  <span>Customer Signature</span></div>
            <div>
                <img src="@Context.Server.MapPath("~/Images/Signature.png")" alt="SIGNATURE" style="margin-top:20px;" />
            </div>
        </div>
        <div style="float:right;">
            <div style="font-size:14px; font-weight:bold;"> Retailer Signature</div>
            <div> <img src="@Context.Server.MapPath("~/Images/Signature.png")" alt="SIGNATURE" style="margin-top:20px;" /> </div>
        </div>
    </div>
</body>
</html>
