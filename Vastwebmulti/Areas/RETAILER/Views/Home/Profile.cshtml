<script type="text/javascript">
                    $(function () {
                        loadRechargeSlipBlockStatus();
                        $("#SaveAll1").click(function () {
                var optCode = []

                $("#printer123 input").each(function () {
                        if ($(this).prop('checked') == true) {
                            optCode.push($(this).val() + ",Y");
                        }
                        if ($(this).prop('checked') == false) {
                            optCode.push($(this).val() + ",N");
                        }
                    });

              /*  document.getElementById("loadermoney").style.display = "block";*/

                $.ajax({
                             type: "POST",
                             url: '@Url.Action("PrintSize_Slip_SettingSave", "Home")',
                             data: { 'ch': optCode },
                             cache: false,
                             dataType: 'json',
                             async: true,
                    success: function (data) {
                                 var pp = data.status;
                                 var mm = data.Message;

                                 if (pp) {
                                  /*   document.getElementById("loadermoney").style.display = "none";*/
                                     toastr.success('Print size Mode ON Successfully ', 'Print size Mode ON');
                                 }
                                 else {
                                     toastr.error(mm, 'Print size Mode ON Error');
                                 }

                             }
                         });

            });

                        function loadRechargeSlipBlockStatus() {
                 $.ajax({
                    type: "GET",
                    url: '@Url.Action("Check_Unchek_PrintSize_Setting", "Home")',
                    cache: false,
                    dataType: 'json',
                    async: true,
                    success: function (data) {
                        var obj = data;

                        for (var item in obj) {
                            var sts = obj[item].status;
                            var name = obj[item].Print_Name;
                            if (sts == "Y") {
                                $("#" + name + "").prop("checked", true);
                            }
                        }
                    }
                });
            }
            });
    </script>



