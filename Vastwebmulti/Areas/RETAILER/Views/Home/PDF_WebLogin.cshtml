@model IEnumerable<Vastwebmulti.Models.Login_info>
@{
    ViewBag.Title = "PDF_WebLogin";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>PDF_WebLogin</title>
    <style>
        table {
            border-collapse: collapse;
        }

        table, td, th {
            border: 1px solid black;
        }

        thead {
            display: table-header-group
        }

        tfoot {
            display: table-row-group
        }

        tr {
            page-break-inside: avoid
        }
    </style>
</head>
<body>
    <table id="example" class="table table-bordered third-design-table fourdesign-data-table" style="width:100%;">
        <thead style="background-color:whitesmoke;">
            <tr>
                @*<th>Sr.&nbsp;No.</th>*@

                <th>Login&nbsp;Status</th>
                <th>Login&nbsp;Id&nbsp;Details</th>
                <th>IP&nbsp;Address</th>
                <th>Browser</th>
                <th>Lattitude</th>
                <th>Longitude</th>
                <th>Login&nbsp;Date&nbsp;Time&nbsp;Details</th>
            </tr>
        </thead>
        <tbody>
            @{ var i = 1;}
            @foreach (var item in Model)
            {
                <tr role="row" class="odd">
                    @*<td>@i</td>*@

                    <td class="activeinactive">
                        <p class="" style="font-size:15px;"><span class="activeopertor">Success</span></p>

                        <p class="" style="display:none;font-size:15px;"><span class="inactiveopertor">Failed</span></p>
                    </td>
                    <td>@item.UserId</td>
                    <td>@item.IP_Address</td>
                    <td>@item.browser</td>
                    <td>@item.Latitude</td>
                    <td>@item.Logitude</td>
                    <td>@item.CurrentLoginTime</td>
                </tr>
                i++;
            }
        </tbody>
    </table>
    </body>
</html>
