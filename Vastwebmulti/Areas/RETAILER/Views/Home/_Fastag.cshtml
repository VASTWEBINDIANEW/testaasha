<script>

     var isPinOn = @Model.Ispin.ToString().ToLower();

    function fasttagprocessToPay() {

     if (isPinOn) {

         var pin = $('#fasttagRechargepin').val();


         if (!pin) {
             alert('Please enter transaction PIN');
             $('#fasttagRechargepin').focus();
             return;
         }

         fasttagrechargeconfirm(pin);
     }
     else {
         fasttagrechargeconfirm('');
     }
 }

</script>



