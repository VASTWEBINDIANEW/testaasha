<script>
    function fasttagrechargeconfirm(pinValue) {

       var e = document.getElementById("fasttagddltype");
        var eleddl = e.options[e.selectedIndex].text;
        var eleddlvalue = e.options[e.selectedIndex].value;
        var txtval = $("#txtvehicle").val();
        var Amount = $("#FastTagAmount").val();
        var duedate = $("#fasttagduedate").val();
        var fasttagRefId = $("#fasttagRefId").val();
        var servicefeefasttag = $("#servicefeefasttag").val();
        if (servicefeefasttag != "") {
            /* call function*/
            var sts = continuebtnvalidation(eleddl, txtval, "", "", Amount, "");
            if (sts == true) {
                  $("#servicefeefasttag").css("border-color", "#000000");
                var optional1 = "";
                //$("#txtvehicle").val("");
                //$("#FastTagAmount").val("");
            //    if (txtval != "" && Amount != "") {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("Recharge","Home")",
                        data: { OperatorName: eleddl, OptCode: eleddlvalue, mobileno: txtval, Amount: Amount, optional1: "", optional2: "", optional3: "", optional4: "", comm: "", BillRefId: fasttagRefId, servicefee: servicefeefasttag, billduedate: duedate, Rechargepin: pinValue },
                        cache: false,
                        dataType: 'json',
                        beforeSend: function () {
                            $('.loader').show();
                        },
                        success: function (result) {




                            // 🔴 Clear old PIN error every time
                            $('#fasttagpinError').hide().text("");

                            /* 🔴 PIN ERROR — SAME PAGE */
                            if (result.status && (
                                result.status === "PIN_REQUIRED" ||
                                result.status === "INVALID_PIN" ||
                                result.status === "PIN_NOT_SET")) {

                                $('#fasttagpinError').text(result.message).show();
                                $('.loader').hide();
                                return; // 🚫 STOP ONLY FOR PIN ERROR
                            }


                            var status = result.Response;
                            var message = result.Message;
                            if (status == "GATEWAY") {
                                window.open(message, "_self");
                                $('#rchstatuschkfasttag').text("Pending");
                                $('#rchmsgelec').text("Please Wait While Redirect The Gateway");
                            }
                            else {
                                $('#rchstatuschkfasttag').text(status);
                                $('#rchmsgelec').text(message);

                                $("#txtvehicle").val("");
                                $("#FastTagAmount").val("");
                            }

                            $('#confirmfasttag').hide();
                            $('#rechargeconfirmfasttag').show();
                        },
                        complete: function () {
                            $("#remainretailer").load(location.href + " #remainretailer");
                            $('.loader').hide();
                            $.ajax({
                                url: '@Url.Action("showrecentrecharge", "Home")',
                                type: 'GET',
                                dataType: "html",
                                data: { type: "Fastag" },
                                success: function (data) {
                                    $('#reportchk').html(data);
                                },
                                error: function (data) {

                                }
                            });
                        },
                        error: function () {
                            $("#remainretailer").load(location.href + " #remainretailer");
                            $('.loader').hide();
                        }
                    })

              //  }
            }
        }
        else {
              $("#servicefeefasttag").css("border-color", "#FF0000");
        }
    }
</script>