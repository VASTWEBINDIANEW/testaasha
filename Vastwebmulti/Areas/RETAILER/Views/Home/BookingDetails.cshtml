<script type="text/javascript">
    $(function () {
        $('.slimScrollDiv').slimScroll({
            height: '250px',
            wheelStep: 10,
        });
    });
</script>
<script>
    function getTicketStatus(TraceId,refNo,pnr)
    {
        var requestObject = {};
        requestObject.BookingId = refNo;
        requestObject.PNR = pnr;
        requestObject.TraceId = TraceId;
        //alert(JSON.stringify(requestObject));
        $.ajax({
            url: '@Url.Action("GetFlightStatus", "Home")',
            type: 'POST',
            data: JSON.stringify(requestObject),
            dataType: 'json',
            contentType: "application/json; charset=utf-8",
            success: function (data) {
                //alert("Success");
                var respo = JSON.parse(data);
                if(respo.Status == "Success")
                {
                    if(respo.StatusCode == 5)
                    {
                        swal("Wow!!", "Ticketed successfully", "success");
                    }
                    else if (respo.StatusCode == 1) {
                        swal("Wow!!", "Ticket is on Hold", "warning");
                    }
                    else if (respo.StatusCode == 2) {
                        swal("Wow!!", "Ticket is ready", "success");
                    }
                    else if (respo.StatusCode == 3) {
                        swal("Wow!!", "Ticket is cancelled", "warning");
                    }
                    else if (respo.StatusCode == 4) {
                        swal("Wow!!", "Ticket is in InProgress", "warning");
                    }
                    else {
                        swal("Oh!", "Ticket not confirmed yet", "warning");
                    }
                } else {
                    swal("Oops!!", respo.Message, "error");
                }
                // alert('Data: '+data);
                //$("#topSection").html(data);
                //$('#radio_'+DstnRadionValue).click();
                //$('#radio_' + DstnRadionValue).attr("checked", true);
            },
            error: function (request, error) {
                 alert("Error");
                // alert("Request: "+JSON.stringify(request));
            }
        });
    }
</script>
<script>
    function changerequest(bookingId,orgn,dstn,TicketId)
    {
        //alert(bookingId);
        //alert(orgn);
        //alert(dstn);
        //alert(TicketId);
        // call CancelTicket action
        var url = '@Url.Action("CancelTicket", "Home")';
        $.post(url, { bookingid: bookingId, origin: orgn, destination: dstn, ticketIds: TicketId }, function (data) {
            alert(data);
            var respo = JSON.parse(data);
            if(respo.Status == "Success")
            {
                swal("Wow!!", "Your cancel request has been accepted.", "success");
            } else {
                swal("Oops!!", respo.Message, "error");
            }
        }).fail(function () {
            swal("Oops!!", "Unknow error.", "error");
        })
    }
</script>