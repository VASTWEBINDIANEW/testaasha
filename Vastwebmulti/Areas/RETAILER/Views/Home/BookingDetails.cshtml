@model List<Vastwebmulti.Areas.RETAILER.Models.TickeBookingDetailsVM>
@{
    ViewBag.Title = "BookingDetails";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="http://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
<link rel="stylesheet" href="http://netdna.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
<link href="~/AdminDesign/Retailer_Slider/Slieder.css" rel="stylesheet" />

<section class="content" style="margin-left: 10px;margin-right: 10px;">
    <div class="container-fluid">
        <div class="row">
            <div class="panel-group">
                @foreach (var item in Model)
                {
                    if (item.ResponseJson != null && item.ResponseJson.Content != null)
                    {
                        var response = item.ResponseJson.Content.Addinfo.Response;
                        if (response != null)
                        {
                            var FlightItinerary = response.FlightItinerary;
                            if (FlightItinerary != null)
                            {
                                <div class="panel panel-primary">
                                    <div class="panel-heading" style="height: 30px;padding: 4px;">@FlightItinerary.Passenger[0].FirstName &nbsp; @FlightItinerary.Passenger[0].LastName</div>
                                    <div class="panel-body">
                                        <div class="col-md-12">
                                            <div class="col-md-4">
                                                <ol>
                                                    @foreach (var Pax in FlightItinerary.Passenger)
                                                    {
                                                        <li><a>@Pax.FirstName @Pax.LastName</a></li>
                                                    }
                                                </ol>
                                            </div>
                                            <div class="col-md-4" style="text-align:center;">
                                                @FlightItinerary.AirlineCode | @FlightItinerary.Origin - @FlightItinerary.Destination | <span title="Ticket Date">@FlightItinerary.LastTicketDate.Date</span>
                                                @*</br>*@
                                                <p> @FlightItinerary.Passenger.Count(a => a.PaxType == "1") <span>ADULT |</span> @FlightItinerary.Passenger.Count(a => a.PaxType == "2") <span>CHILD |</span> @FlightItinerary.Passenger.Count(a => a.PaxType == "3") <span>INFANT</span></p>
                                            </div>
                                            <div class="col-md-4" style="text-align:right;">
                                                <p> <strong>PNR : @FlightItinerary.Pnr</strong></p>
                                                <p> Ref No : @FlightItinerary.BookingId</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="panel-footer" style="padding-bottom: 15px;padding-top: 10px;">
                                        <span>
                                            <span><a>Fare Rule</a></span>&nbsp;&nbsp;
                                            <span><a>View Ticket</a></span>&nbsp;&nbsp;
                                            @{ var ids = FlightItinerary.Passenger.Select(a => a.Ticket.TicketId).ToList();
                                                var str = string.Join(",", ids);
                                            }
                                            <span onclick="changerequest('@FlightItinerary.BookingId','@FlightItinerary.Origin','@FlightItinerary.Destination','@str')"><a>Change Request</a></span>&nbsp;&nbsp;
                                            <span id="statusLink" onclick="getTicketStatus('@item.ResponseJson.Content.Addinfo.TraceId','@response.BookingId','@response.Pnr')"><a>Current Status</a></span>
                                        </span>
                                        <span style="float:right">
                                            <span> <a class="btn btn-primary">View Invoice</a></span>&nbsp;&nbsp;
                                            <span>  <a class="btn btn-primary">Open</a></span>
                                        </span>
                                    </div>
                                </div>
                                                            }
                                                        }
                                                    }
                                                }
            </div>
        </div>
    </div>
    <!--Slider div-->
    <br />
</section>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
