    <body>

        <div class="col-md-4 new-prent-page">
            <div class="col-md-12 Confirm-Payment">
                <div class="container-fluid">
                    <div class="col-md-7 successful" style="">
                        <div style="text-align:center; margin-top:10px;">
                            <p style="position:absolute;top:15px;left:45%; text-transform:uppercase;border-bottom:2px solid #3a3a3a;">@ViewData["msg"]</p>
                         </div>
                            @*<div>@logoimage  123123</div>*@

                            <strong>
                                @*<img src="~/ashok-images/india(2).svg" alt="india(2)" class="center" />
                <span class="transform-re"> @ViewData["Totalamount"]</span>*@

                            @*@if (ViewData["msg"].ToString() == "Transaction Successful")
                                {
                                    <i class="fa fa-check fullbodydycolorbg" style="background:green;width:50px "> </i>
                                }
                                else
                                {
                                    <i class="fa fa-times fullbodydycolorbg" style="background:red;"></i>
                                }*@
                            @if (ViewData["msg"].ToString() == "Successful")
                            {
                                <div style="width: 50px; background: green; border-radius: 50px; text-align: center; margin-left: 4%;">
                                    <i class="fa fa-check fullbodydycolorbg" style="top: -2px; text-align: center; "> </i>
                                </div>
                            }
                            else if (ViewData["msg"].ToString() == "Transaction In Process" || ViewData["msg"].ToString()== "Transaction pending")
                            {
                                <div style="  margin-left:4%;">
                                    <i class="fa fa-clock-o " style="font-size:48px;color:orange"></i>
                                </div>
                            }
                        </strong>
                    </div>
                    <div class="col-md-6 successful-logo" style="float: right; margin-top: -50px; width: 116px !important; height: 49px; margin-top: 13px;">
                        <img src="@Url.Content("~/" +logoimage)" class="img-responsive" alt="Logo" />
                    </div>
                </div>
                <div class="container-fluid transaction">
                    <p style="color:white;">IMPS/NEFT Transaction </p>
                    <ul class="transaction-detail">
                        @*<li class="transaction-left"><span>retailer firm</span></li>
        <li class="transaction-right"><span>@ViewData["FirmName"]</span></li>*@

                        @*<li class="transaction-left"><span>Account Holder Name</span></li>
        <li class="transaction-right"><span>@ViewData["name"]</span></li>*@
                        @*<li class="transaction-left"><span>Net amount</span></li>
        <li class="transaction-right"><span>@ViewData["total"]</span></li>*@
                        <ul style="width: 49%; float: left; background: #e3e3e3; padding: 6px;">
                            <li class="transaction-left"><span>Receiver</span></li>
                            <li class="transaction-right"><span>@ViewData["Reciver"]</span></li>
                            <li class="transaction-left"><span>Sender No</span></li>
                            <li class="transaction-right"><span>@ViewData["senderno"]</span></li>
                            <li class="transaction-left"><span>Bank Name</span></li>
                            <li class="transaction-right"><span>@ViewData["BankName"]</span></li>
                            <li class="transaction-left"><span>A/C No.</span></li>
                            <li class="transaction-right"><span>@ViewData["accountno"]</span></li>
                            <li class="transaction-left"><span>IFSC Code</span></li>
                            <li class="transaction-right"><span>@ViewData["ifsccode"]</span></li>
                            <li class="transaction-left"><span>Bank RRN</span></li>
                            <li class="transaction-right"><span>@ViewData["rrn"]</span></li>
                        </ul>
                        <ul style="width: 49%; float: right; background: #e3e3e3; padding: 6px;">
                            <li class="transaction-left"><span>Trans Mode</span></li>
                            <li class="transaction-right"><span>@ViewData["mode"]</span></li>
                            <li class="transaction-left"><span>Trans amount</span></li>
                            <li class="transaction-right"><span>@ViewData["amount"]</span></li>
                            <li class="transaction-left"><span>Tran Date</span></li>
                            <li class="transaction-right"><span>@ViewData["TransDate"] </span></li>
                            <li class="transaction-left"><span>Orderid</span></li>
                            <li class="transaction-right"><span>@ViewData["orderid"]</span></li>

                            @if (custfee != "Y")
                            {
                                <li class="transaction-left"><span>Service charge</span></li>
                                <li class="transaction-right"><span>@ViewData["servicefee"]</span></li>
                            }

                            @if (TotalAmount != "Y")
                            {
                                <li class="transaction-left"><span>Total Amount</span></li>
                                <li class="transaction-right"><span>@ViewData["total"]</span></li>

                            }
                         </ul>
                        </ul>
                        <div class="container-fluid transaction">
                            <p style="color: white; text-align: center;">Partner Info </p>
                            <ul style="width: 100%; background: #e3e3e3; padding: 4px; " class="transaction-detail">
                                <li class="transaction-left"><span>Business Name</span></li>
                                <li class="transaction-right"><span>@ViewData["firmname"]</span></li>
                                <li class="transaction-left"><span>Address</span></li>
                                <li class="transaction-right"><span>@ViewData["retaileraddress"]</span></li>
                                @if (Mobile != "Y")
                                {
                                    <li class="transaction-left"><span>Mobile</span></li>
                                    <li class="transaction-right"><span>@ViewData["retailermobile"]</span></li>
                                }
                                @if (Email != "Y")
                                {
                                    <li class="transaction-left"><span>Email</span></li>
                                    <li class="transaction-right"><span>@ViewData["retaileremail"]</span></li>
                                }
                            </ul>
                        </div>
                        <div class="container-fluid transaction">
                            <p style="color: #000; background: none; font-size: 8px; font-family: inherit; line-height: 1.5; color: #3a3a3a; ">NOTE:   Thanks for visiting @ViewData["firmname"]. We are always ready for customer service, You can contact us for (M ATM) Payment Withdrawal, Mobile Recharge, Bill Payment, (AEPS) Aadhaar Withdrawal, Travel Booking and Related Services in future. Have a nice day. </p>

                            <ul style="width: 100%; background: #e3e3e3; padding: 4px; " class="transaction-detail">
                                @if (Customercare != "Y")
                                {
                                    <li class="transaction-left"><span>customer care No.</span></li>
                                    <li class="transaction-right"><span>@ViewData["customercare"]</span></li>
                                }
                                @if (WebsiteName != "Y")
                                {
                                    <li class="transaction-left"><span>Website Name</span></li>
                                    <li class="transaction-right"><span>@ViewData["Websitename"]</span></li>
                                }
                            </ul>
                        </div>

</div>
            </div>
        </div>
    </body>
</html>
}

