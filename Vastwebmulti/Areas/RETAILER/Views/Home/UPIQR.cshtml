<script type="text/javascript">
var timeoutHandle;
function countdown(minutes, seconds,txnid) {
    function tick() {

        var counter = document.getElementById("timer");
        counter.innerHTML =
            minutes.toString() + ":" + (seconds < 10 ? "0" : "") + String(seconds);
        seconds--;
        $.ajax({
                url: '@Url.Action("Paytmqrresponse","Home")',
                type: 'GET',
            data: { txnid: txnid },
            success: function (response) {


                if (response.res == "Yes") {

                    document.getElementById('successgenrate').style.display = 'block';
                    document.getElementById('qrregenrate').style.display = 'none';
                    document.getElementById('paytmshowgenrateform').style.display = 'none';
                    document.getElementById('paytmqrcodeshow').style.display = 'none';

                    setTimeout(function () {
                        location.reload();
                    }, 5000);

                }


                },

            });

        if (seconds == 0 && minutes == 0) {
            document.getElementById('qrregenrate').style.display = 'block';
            document.getElementById('successgenrate').style.display = 'none';
            document.getElementById('paytmshowgenrateform').style.display = 'none';
            document.getElementById('paytmqrcodeshow').style.display = 'none';
        }
        else {


            if (seconds >= 0) {
                timeoutHandle = setTimeout(tick, 1000);
            } else {
                if (minutes >= 1) {
                    // countdown(mins-1);   never reach “00″ issue solved:Contributed by Victor Streithorst
                    setTimeout(function () {
                        countdown(minutes - 1, 59, txnid);
                    }, 1000);
                }
            }
        }


    }
    tick();
}

