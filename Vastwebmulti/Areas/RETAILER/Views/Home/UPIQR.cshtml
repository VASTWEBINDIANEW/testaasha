    function countdown11(minutes, seconds,txnid) {
        debugger;
    function tick11() {

        var counter = document.getElementById("timerssss");
        counter.innerHTML =
            minutes.toString() + ":" + (seconds < 10 ? "0" : "") + String(seconds);
        seconds--;
       

        if (seconds == 0 && minutes == 0) {
            bharatpayutr(txnid);
            document.getElementById('qrregenrate').style.display = 'block';
            document.getElementById('successgenrate').style.display = 'none';
            document.getElementById('bharatpeshowgenrateform').style.display = 'none';
            document.getElementById('bharatpeqrcodeshow').style.display = 'none';
        }
        else {


            if (seconds >= 0) {
                timeoutHandle11 = setTimeout(tick11, 1000);
            } else {
                if (minutes >= 1) {
                    // countdown(mins-1);   never reach “00″ issue solved:Contributed by Victor Streithorst
                    setTimeout(function () {
                        countdown11(minutes - 1, 59, txnid);
                    }, 1000);
                }
            }
        }


    }
    tick11();
    }

