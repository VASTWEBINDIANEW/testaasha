@model IEnumerable<Vastwebmulti.Models.show_dispute_list_Result>
@{
    ViewBag.Title = "PDF_DisputeReport";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>PDF_DisputeReport</title>
    <style>
        table {
            border-collapse: collapse;
        }

        table, td, th {
            border: 1px solid black;
        }

        thead {
            display: table-header-group
        }

        tfoot {
            display: table-row-group
        }

        tr {
            page-break-inside: avoid
        }
    </style>
</head>
<body>
     <table class="table table-bordered table-striped table-hover third-design-table" style="width:100%; font-size:12px;">
        <thead style="background-color:whitesmoke;">
                <tr>
                    <th>Sr</th>
                    <th>Status&nbsp;&&nbsp;Description</th>
                    <th>Number</th>
                    <th>Operator&nbsp;Name</th>
                    <th>₹&nbsp;Amount</th>
                    <th>Transition&nbsp;Date</th>
                    <th>Dispute&nbsp;Reason</th>
                    <th>Response</th>
                    <th>Dispute&nbsp;Date</th>

                </tr>
            </thead>
        <tbody id="myTable">
            @if (Model.Count() > 0)
            {

                int i = 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>@Html.DisplayFor(modelItem => item.sts)</td>
                        <td>@Html.DisplayFor(modelItem => item.rch_number)</td>
                        <td>@Html.DisplayFor(modelItem => item.operator_Name)</td>
                        <td>@Html.DisplayFor(modelItem => item.rch_amount)</td>
                        <td>@Html.DisplayFor(modelItem => item.rch_time)</td>
                        <td>@Html.DisplayFor(modelItem => item.dispute_region)</td>
                        <td>@Html.DisplayFor(modelItem => item.comment)</td>
                        <td>@Html.DisplayFor(modelItem => item.dis_time)</td>

                    </tr>
                    i++;
                }
            }
            else
            {
                <tr>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td><p style="font-size:22px;margin-top:0px;margin-bottom:0;text-align:center;color:#555;font-weight:700;">No Data Found !</p></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                </tr>
            }
        </tbody>

        </table>
</body>
</html>