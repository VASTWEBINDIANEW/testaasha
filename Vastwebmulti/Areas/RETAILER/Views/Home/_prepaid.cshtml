<script>
    var isPinOn = @Model.Ispin.ToString().ToLower();

    function processToPay() {

        if (isPinOn) {

            var pin = $('#Rechargepin').val();
        

            if (!pin) {
                alert('Please enter transaction PIN');
                $('#Rechargepin').focus();
                return;
            }

            mobilerechargeconfirm(pin);
        }
        else {
            mobilerechargeconfirm('');
        }
    }
</script>

<script>
    function showMsg(msg, type) {

        var color = (type === "success") ? "green" : "red";

        $('#msgBox').html(
            '<div style="color:' + color + '; font-weight:bold;">' + msg + '</div>'
        );

        setTimeout(function () {
            $('#msgBox').html('');
        }, 5000);
    }
</script>





