            var e = document.getElementById("mobileoperatorPostpaid");
            optname = e.options[e.selectedIndex].text;
            optvalue = e.options[e.selectedIndex].value;
        }
        var e = document.getElementById("ddlcircle");
        var circle = e.options[e.selectedIndex].text;
        var mobileno = $("#txtmobile").val();
        var radiovalue = document.querySelector('input[name="radiogroup"]:checked').value;
        var amout = $("#txtmobileamount").val();
        var comm = $("#commvalue").val();
        //$("#txtmobile").val("");
        //$("#txtmobileamount").val("");
        //if (mobileno != "" && amout != "")
        //{
            $.ajax({
                type: "POST",
                url: "@Url.Action("Recharge","Home")",
                data: { OperatorName: optname, OptCode: optvalue, mobileno: mobileno, Amount: amout, optional1: "", optional2: "", optional3: "", optional4: "", comm: comm, BillRefId: "", circle: circle, Rechargepin: pinValue },
                cache: false,
                dataType: 'json',
                beforeSend: function () {
                    $('.loader').show();
                },
                success: function (result)
                {

                    // 🔴 Clear old PIN error every time
                    $('#pinError').hide().text("");

                    /* 🔴 PIN ERROR — SAME PAGE */
                    if (result.status && (
                        result.status === "PIN_REQUIRED" ||
                        result.status === "INVALID_PIN" ||
                        result.status === "PIN_NOT_SET")) {

                        $('#pinError').text(result.message).show();
                        $('.loader').hide();
                        return; // 🚫 STOP ONLY FOR PIN ERROR
                    }

                   // window.location.reload();
                    var status = result.Response;
                    var message = result.Message;


                    if (status == "GATEWAY") {
                        window.open(message, "_self");
                        $('#rchstatuschkpre').text("Pending");
                        $('#rchmsgprepaid').text("Please Wait While Redirect The Gateway");
                    }
                    else {
                        $('#rchstatuschkpre').text(status);
                        $('#rchmsgprepaid').text(message);


                        // ✅ CLEAR FIELDS ONLY AFTER SUCCESS

                        $("#txtmobile").val("");
                        $("#txtmobileamount").val("");

                    }

                        $('#confirmprepaid').hide();
                        $('#rechargeconfirm').show();
                },
                complete: function () {
                    $("#remainretailer").load(location.href + " #remainretailer");
                    $('.loader').hide();
                          $.ajax({
            url: '@Url.Action("showrecentrecharge", "Home")',
            type: 'GET',
            dataType: "html",
            data: { type: "Prepaid" },
                   success: function (data) {
                    $('#reportchk').html(data);

            },
            error: function (data) {

            }
        });
                },
                error: function () {
                    $("#remainretailer").load(location.href + " #remainretailer");
                    $('.loader').hide();
                }
            })
       // }

    }
</script>

