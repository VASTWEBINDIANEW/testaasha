                                    document.getElementById("viewplan").style.display = "block";
                                     $('#droppostpaid').hide();
                                         $('#dropprepaid').show();
                                         $("#radio_1"). prop("checked", true);
                                    operator = $.trim(operator).toUpperCase();
                                    $("#mobileoperatorPrepaid option").each(function () {
                                        var opt = $(this).text().toUpperCase();
                                        if (opt == "BSNL TOPUP") {
                                            if (operator == "BSNL") {
                                                operator = "BSNL TOPUP";
                                            }
                                        }
                                        else if (opt == "MTNL TOPUP") {
                                            if (operator == "MTNL") {
                                                operator = "MTNL TOPUP";
                                            }
                                        }
                                        if (operator == opt) {

                                            var optcode = $(this).val();

                                            $('#mobileoperatorPrepaid').val(optcode);
                                             j('#mobileoperatorPrepaid').select2().trigger('change');
                                            return;
                                         }
                                       });
                                    $('#viewplan').show();
                                    getbestofferplan();
                                }
                                //postpaid
                                else {
                                                document.getElementById("viewplan").style.display = "none";
                                           $('#droppostpaid').show();
                                         $('#dropprepaid').hide();
                                    $("#radio_2"). prop("checked", true);
                                    operator = $.trim(operator).toUpperCase();

                                    $("#mobileoperatorPostpaid option").each(function () {
                                        var opt = $(this).text().toUpperCase();

                                          if (opt == "AIRTEL POSTPAID") {
                                            if (operator == "AIRTEL") {
                                                operator = "AIRTEL POSTPAID";
                                            }
                                        }
                                        else if (opt == "IDEA POSTPAID") {
                                            if (operator == "IDEA") {
                                                operator = "IDEA POSTPAID";
                                            }
                                        }
                                          else if (opt == "VODAFONE POSTPAID") {
                                            if (operator == "VODAFONE") {
                                                operator = "VODAFONE POSTPAID";
                                            }
                                        }
                                        else if (opt == "RELIANCE POSTPAID") {
                                            if (operator == "JIO") {
                                                operator = "RELIANCE POSTPAID";
                                            }
                                        }
                                         else if (opt == "BSNL POSTPAID") {
                                            if (operator == "BSNL") {
                                                operator = "BSNL POSTPAID";
                                            }
                                        }
                                         else if (opt == "TATA DOCOMO POSTPAID") {
                                            if (operator == "TATA") {
                                                operator = "TATA DOCOMO POSTPAID";
                                            }
                                        }
                                        if (operator == opt) {
                                            var optcode = $(this).val();

                                            $('#mobileoperatorPostpaid').val(optcode);
                                             j('#mobileoperatorPostpaid').select2().trigger('change');
                                            return;
                                         }
                                       });
                                }
                            }
                        },
                        error: function (response) {
                            document.getElementById("rchspinner").style.display = "none";

                        }
                    });
                    return true;
    }
</script>

