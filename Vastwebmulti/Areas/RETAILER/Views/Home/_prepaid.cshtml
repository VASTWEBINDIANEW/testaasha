                   $('#mobileoperatorPrepaid').val("");
                    j('#mobileoperatorPrepaid').select2().trigger('change');
                    var mobileno = $("#txtmobile").val();
                    document.getElementById("rchspinner").style.display = "block";
             // check circle code and fill operator throw mobile number
                   $.ajax({
                        url: '@Url.Action("Checkcircle", "Home")',
                        type: 'GET',
                        dataType: "json",
                        data: { mobileno: mobileno },
                       success: function (response) {

                                     document.getElementById("rchspinner").style.display = "none";
                            var sts = response.status;
                            var circle = response.Response.Circle;
                            var operator = response.Response.Operator;
                           var optype = response.Response.postpaid;

                            if (sts == "SUCCESS") {

                                j("#ddlcircle").val(circle);
