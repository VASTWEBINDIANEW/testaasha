<!--Get Recharge Best Offer's -->

<script>
    function getbestofferplan()
    {
        document.getElementById("PrePaidbestplan").style.display = "none";
        $('#BestOfferTbl').empty();
        var e = document.getElementById("mobileoperatorPrepaid");
        optname = e.options[e.selectedIndex].text;
        optvalue = e.options[e.selectedIndex].value;
        var mobileno = $("#txtmobile").val();
       if(mobileno == "" || mobileno==null || optname == "" || optname==null  )
        {
            document.getElementById("mobileoptddl").innerHTML = "Please Select Operator";
            document.getElementById("txtmobilemessage").innerHTML = "Enter valid Mobile Number";
            event.preventDefault();
            return false;
       }
       var mobilenolenght = document.getElementById("txtmobile").value.length;
       var pattern = "^[6-9]{1}[0-9]{9}$";
       if (mobilenolenght != 10 && mobilenolenght != null && mobilenolenght != "") {

           document.getElementById("txtmobilemessage").innerHTML = "Number should be [10] digits";
           document.getElementById("txtmobilemessage").style.display = "block";
           event.preventDefault();
           return false;
       }
       else if (!mobileno.match(pattern)) {

           document.getElementById("txtmobilemessage").innerHTML = "Your Mobile Number is not Valid.";
           document.getElementById("txtmobilemessage").style.display = "block";
           event.preventDefault();
           return false;

       }
       else {
           $('#offertable').html('');
           $.ajax({
               url: '@Url.Action("RechargeBestofferplan", "Home")',
               type: 'GET',
               dataType: "json",
               data: { optname: optname, mobileno: mobileno },
               success: function (response) {
                   var sts = response.status;
                   if (sts == "SUCCESS") {
                       var jsonObj = response.Response;
                       if (jsonObj.length > 0) {
                        document.getElementById("PrePaidbestplan").style.display = "block";
                       $('#BestOfferTbl').empty();
                           for (var i = 0; i < jsonObj.length; i++) {
                               var newRow =
                                   "<div class='col-sm-4' style='text-align: left;'>" +
                                   "<button type='button' style='color:white;' onclick='offerval(this)' class='btn bg-blue-grey waves-effect' value='" + jsonObj[i]['price'] + "||" + jsonObj[i]['commAmount'] + "'>₹  " + jsonObj[i]['price'] + "</button>" +
                                   "<div>" + jsonObj[i]['offer'] + "</div>" +
                                   "</div>"
                               $('#BestOfferTbl').append(newRow);
                           }
                      }
                   }
                   else {
                           document.getElementById("PrePaidbestplan").style.display = "none";
                       $('#BestOfferTbl').empty();

                   }
               }
           });
           return true;
       }

    }
</script>

