@using Vastwebmulti.Models;
@model IEnumerable<Vastwebmulti.Models.select_retailer_credit_report_by_admin_Result>
@{
    ViewBag.Title = "Show_Credit_report_by_admin";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Dealer").ToList();
    if (usernname.Count() > 0)
    {
        if (usernname.SingleOrDefault().Role == "Dealer")
        {
          var  favimage = usernname.SingleOrDefault().NickName;
            ViewBag.nickname = favimage;
        }
    }

}
<link href="~/MainFrontDesign/css/Dashcustom.css" rel="stylesheet" />
<style>
    /* new css  */
    .distributor-class {
        padding-right: 0px;
    }
    .cpmpany-class {
        padding-left: 0px;
    }

    .layoutt-retailer section.content {
        margin-top: 95px;
        padding-top: 5px;
    }

    .bread-same-all-page li {
        margin: 6px 0;
    }

    .table {
        margin-bottom: 0px;
    }

    .bread-same-all-page {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    @@media only screen and (max-width:1169px) {
        .container-fluid.show-creditby {
            padding-left: 15px !important;
        }
    }

    @@media only screen and (max-width:991px) {
        .cpmpany-class {
            padding-left: 0px;
            padding-right: 0;
        }
        .distributor-class {
            padding-left: 0px;
        }

    }
    @@media only screen and (max-width:990px) {
        .container-fluid.show-creditby {
            padding-right: 15px !important;
        }


    }

    @@media only screen and (max-width:767px) {
        .table-responsive > .table-bordered {
            border: 1px solid var(--border-color);
        }
    }

    @@media only screen and (max-width:480px) {
    }

    /* new css  */
</style>

