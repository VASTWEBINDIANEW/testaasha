                                    </li>
                                    <li>
                                        <strong>Company&nbsp;Mobile&nbsp;No</strong>
                                        <span>@item.Name</span>
                                    </li>
                                    <li>
                                        <strong>Current &nbsp;Blance</strong>
                                        <span>@item.remain_amount</span>
                                    </li>
                                    <li>
