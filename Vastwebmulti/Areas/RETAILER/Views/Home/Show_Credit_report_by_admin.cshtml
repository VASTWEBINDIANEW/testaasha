                                    <span>@item.remain_amount</span>
                                </li>
                                <li>
                                    <strong>Current&nbsp;Credit<sup>*</sup></strong>
                                    <span>@item.cr</span>
                                </li>
                            }
                        </ul>

                    </div>
                    <div class="bank-full-four">
