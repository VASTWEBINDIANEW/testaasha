            <div class="col-md-6 cpmpany-class distributor-responshiveclass brachcashreport-noneclass">
                <div class="page-header-third">
                    <div class="creditcompany changeback-four-design">
                        <div class="creditimg">
                            <img src="~/ashok-images/value.svg" />

                            <h2 class="fullbodydycolorbg black-back-fordesign">Credit From Company</h2>
                        </div>
                        <div class="companydataall">
                            <table border="1">
                                @foreach (var item in ViewBag.admin)
                                {
                                    <tr>
                                        <th>Company&nbsp;Name</th>
                                        <td>@item.AdminEmail</td>
                                    </tr>
                                    <tr>
                                        <th>Company&nbsp;Mobile&nbsp;No</th>
                                        <td>@item.Name</td>
                                    </tr>
                                    <tr>
                                        <th>Current &nbsp;Blance</th>
                                        <td>@item.remain_amount</td>
                                    </tr>
                                    <tr class="current-credit">
                                        <th>Current&nbsp;Credit<sup>*</sup></th>
                                        <td>@item.cr</td>
                                    </tr>
                                }
                            </table>
                        </div>

                    </div>
                </div>
            </div>

            <!---------------Distributor Start---------------->

            <div class="col-md-6 distributor-class distributor-responshiveclass brachcashreport-noneclass">
                <div class="page-header-third">
                    <div class="creditcompany changeback-four-design">
                        <div class="creditimg">
                            <img src="~/ashok-images/value.svg" />
                            <h2 class="fullbodydycolorbg black-back-fordesign">Credit From @ViewBag.nickname</h2>
                        </div>
                        <div class="companydataall">
                            <table border="1">
                                @foreach (var item in ViewBag.dealer)
                                {
                                    <tr>
                                        <th>@ViewBag.nickname&nbsp;Name</th>
                                        <td>@item.DLMEmail</td>
                                    </tr>
                                    <tr>
