                                    </tr>
                                    <tr>
                                        <th>Current &nbsp;Blance</th>
                                        <td>@item.remain_amount</td>
                                    </tr>
                                    <tr class="current-credit">
                                        <th>Current&nbsp;Credit<sup>*</sup></th>
                                        <td>@item.cr</td>
                                    </tr>
                                }
