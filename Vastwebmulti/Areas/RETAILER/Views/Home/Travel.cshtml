                        $('#secpur2').hide();
                    }
                    else if (data == "ALLNOTDONE") {
                        $('#flightservice').hide();
                        $('#firstpur2').hide();
                        $('#ALLpur2').show();
                        $('#BOTHpur2').hide();
                        $('#secpur2').hide();
                    }
                    else if (data == "NOTOK") {

                        $('#flightservice').hide();
                        $('#firstpur2').show();
                        $('#ALLpur2').hide();
                        $('#BOTHpur2').hide();
                        $('#secpur2').hide();

                    }
                    else if (data == "BOTHNOTDONE") {

                        $('#flightservice').hide();
                        $('#firstpur2').hide();
                        $('#ALLpur2').hide();
                        $('#BOTHpur2').show();
                        $('#secpur2').hide();

                    }
                    else {
                        $('#flightservice').hide();
                        $('#firstpur2').show();
                        $('#secpur2').hide();
                    }
            }
        });
    });
</script>

