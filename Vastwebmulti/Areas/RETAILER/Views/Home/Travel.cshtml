<style>

    .loaderssee {
        position: fixed;
        top: -90px;
        left: 0;
        background-color: rgba(255,255,255,0.7);
        z-index: 999999999999;
        display: none;
        height: 100vw;
        width: 100vw;
    }

    @@-webkit-keyframes spin {
        from {
            -webkit-transform: rotate(0deg);
        }

        to {
            -webkit-transform: rotate(360deg);
        }
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .loaderssee::after {
        content: '';
        display: block;
        position: absolute;
        left: 48%;
        top: 25%;
        width: 100px;
        height: 100px;
        border-style: solid;
        border-color: black;
        border-top-color: transparent;
        border-width: 4px;
        border-radius: 50%;
        -webkit-animation: spin .8s linear infinite;
        animation: spin .8s linear infinite;
    }

    .satepackeheform {
        margin: 0;
    }
        .satepackeheform .row {
            margin: 0 !important;
        }
            .satepackeheform .row .hotel-htmlfirst {
                border: 1px solid #ddd;
                display: flex;
                align-items: center;
                width:100% !important;
                padding:0px !important;
            }
                .satepackeheform .row .hotel-htmlfirst span {
                    background: #f5f5f5;
                    font-size: 14px !important;
                    padding: 8px 10px;
                    min-width: 141px !important;
                    text-align: left;
                }
                .satepackeheform .row .hotel-htmlfirst strong {
                    padding-left: 10px;
                }
    .packegeclassaw-scroll {
        height: 547px;
        overflow-y: auto;
        overflow-x: hidden;
    }
    .satepackeheform .row .hotel-htmlfirst.hotel-htmlfirstimgadd img {
        margin: 0;
        width: 70px;
        float: right;
        height: 36px;
    }
    .satepackeheform .row .hotel-htmlfirst.hotel-htmlfirstimgadd {
        display: block;
    }
    .satepackeheform .hotel-html-responshive-end .row .hotel-htmlfirst span {
        min-width: 170px !important;
        margin: 0;
    }
    .satepackeheform .hotel-html-responshive-end .row .hotel-htmlfirst input {
        border: 0;
        margin: 0 !important;
        height: 36px;
        border-left: 1px solid #ddd;
        box-shadow:none !important;
    }
    .satepackeheform .hotel-html-responshive-end .form-group {
        margin: 0;
        width: 100%;
        float: left;
    }
        .satepackeheform .hotel-html-responshive-end .form-group input {
            float: right;
            padding: 8px 20px;
            background: #a4a0a0;
            border: #a4a0a0;
            color: #333;
            text-transform: uppercase;
            transition: all .4s linear;
        }
    .satepackeheform .row .hotel-htmlfirst span {
        text-transform: capitalize;
    }
    .travel-page-report {
        background: #eae9e9;
        height: 634px;
    }
        .travel-page-report table tr td {
            padding-right: 5px;
            padding-left: 5px !important;
        }


@@media only screen and (max-width:767px){
