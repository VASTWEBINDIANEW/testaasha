@model IEnumerable<Vastwebmulti.Models.Selling_Recharge_info>
@using Vastwebmulti.Models;
@{
    Layout = null;  
    VastwebmultiEntities DB1 = new VastwebmultiEntities();
}

    @if (Model != null && Model.Count() > 0)
    {
        foreach (var item in Model)
        {
           <tr>
               <td>@item.Rstaus</td>
               <td>@item.Mobile</td>
               <td>@item.optcode</td>
               <td>@item.amount</td>
               <td>@item.income</td>
               <td>@item.dlmpre</td>
               <td>@item.dlmpost</td>
               <td>@item.Rch_time</td>
               <td>@item.Resp_time</td>
               <td>

                       <td id="succ">
                           <button onclick="updaterecharge(@item.idno , 'Success', @item.trans_id)">Success</button>
                       </td>
                       <td id="fail">
                           <button onclick="updaterecharge(@item.idno , 'Failed' , @item.trans_id)">Failed</button>
                       </td>
                   

               </td>
              
           </tr>



           
        }
    }

    else
    {
        <tr>
            @if (@ViewBag.checkdata != null)
            {
                <td colspan="13"><h3 style="text-align:center;">No Data For Current Search</h3></td>
            }
            else
            {
                <td colspan="13"><h3 style="text-align:center;">Data Not Found</h3></td>
            }
        </tr>

    }

<div class="sbutton_m" style="display:none;">

    <div class="bt_sumbit">

        <div class="bt_sumbit2"> on  </div>
        <div class="bt_sumbit2"> off </div>

        <div id="sucfai1">

        </div>
    </div>
    
</div>

<style>
    .sbutton_m {
        background: #00000040;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 9999;
    }

    .bt_sumbit {
        background: #f1f1f1;
        width: 349px;
        text-align: center;
        position: absolute;
        left: 41%;
        top: 37%;
        border: 5px solid #ccc;
        color: #000;
        height: 137px;
        padding: 15px;
    }
    #sucfai1 {
        width: 100%;
        float: left;
        display: flex;
        align-items: center;
        justify-content: center;
    }
        #sucfai1 a {
            color: #fff;
            border: 1px solid #2a771a;
            background: #358b23;
            border-radius: 3px;
            padding: 6px 12px;
            display: inline;
        }
    .bt_sumbit2 {
        width: 50%;
        float: left;
        margin: 16px 0;
    }



</style>

<script>

    function updaterecharge(id, sts, txnid) {

      document.getElementById('sucfai1').innerHTML = "";
        var doc = '<a href="' + '@Url.Action("Rechargesellupd", "Home", new { id = "idnis", status = "stsnds" , txnid = "txnids" })' + '">Are you Sure</a>';
        var doc1 = doc.replace("idnis", id);
        doc1 = doc1.replace("stsnds", sts);
        doc1 = doc1.replace("txnids", txnid);

     document.getElementById('sucfai1').innerHTML = doc1;

    }

    $("#succ").on("click", function () {
        $(".sbutton_m").show("slow");
    });


</script>

