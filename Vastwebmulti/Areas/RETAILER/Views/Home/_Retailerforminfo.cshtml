
@model Vastwebmulti.Areas.RETAILER.Models.Servicefee

<style>
    .wallet-bank-input input[readonly="readonly"] {
        background: transparent;
        border: 0px;
    }
    
</style>


<!-- Modal -->
<div class="col-md-12" id="axy" style="padding:0;">
    <div class="table-responsive" style="position:inherit;">
        <div class="" style="width: 100%; height: auto; overflow-y: auto;" id="retailermanualformadd">
            <table class="table table-bordered " style="width:100%;">
                <thead style="background-color:whitesmoke;">
                    <tr>

                        <th>Name</th>
                        <th>Value</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="Outerother_links">
                 
                    @foreach (var item in Model.AddForm_information)
                    {
                        <tr class="hidelink">
                            <td>
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
           
                            <td>
                                @Html.DisplayFor(modelItem => item.Value)
                            </td>

                            <td>
                                <button type="button" onclick="retailerform('@item.id')" id="retailerform1" class="btn waves-effect shownextrow switch-edit-button swichedit-second" value="Edit">
                                    <p>Edit</p>
                                </button>
                               
                            </td>
                        </tr>

                    }



                </tbody>
            </table>
        </div>
    </div>
</div>