<script>
    var isPinOn = @Model.Ispin.ToString().ToLower();

    function gasprocessToPay() {

        if (isPinOn) {

            var pin = $('#gasRechargepin').val();


            if (!pin) {
                alert('Please enter transaction PIN');
                $('#gasRechargepin').focus();
                return;
            }

            gasrechargeconfirm(pin);
        }
        else {
            gasrechargeconfirm('');
        }
    }
</script>

