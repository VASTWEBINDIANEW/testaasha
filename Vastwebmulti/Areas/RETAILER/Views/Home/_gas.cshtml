            $('#gasinfo').hide();
            $('#confirmgas').show();

            //  Recharge(gasddl, eleddlvalue, txtgasno, gasamount, billgroup, "", "", "", "0", BillRefId);
            event.preventDefault();
            return false;
        }
    }
</script>


<script>
    function gasrechargeconfirm(pinValue) {

                var e = document.getElementById("gasddltype");
        var gasddl = e.options[e.selectedIndex].text;
        var eleddlvalue = e.options[e.selectedIndex].value;
        var txtgasno = $("#txtgasno").val();
        var billgroup = $("#billgroup").val();
        var registermobile = $("#registermogroup").val();
        var gasamount = $("#gasamount").val();
        var duedate = $("#gasduedate").val();
        var BillRefId = $("#BillRefId").val();
        var servicefeegas = $("#servicefeegas").val();
        if (servicefeegas != "") {
            /*call function */
            var sts = getgascontiunebtn(gasddl, txtgasno, gasamount, billgroup, registermobile);
            if (sts == true) {
                           $("#servicefeegas").css("border-color", "#000000");
                //$("#txtgasno").val("");
                //$("#gasamount").val("");
                //if (txtgasno != "" && gasamount != "") {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("Recharge","Home")",
                        data: { OperatorName: gasddl, OptCode: eleddlvalue, mobileno: txtgasno, Amount: gasamount, optional1: billgroup, optional2: registermobile, optional3: "", optional4: "", comm: "", BillRefId: BillRefId, servicefee: servicefeegas, billduedate: duedate, Rechargepin: pinValue },
                        cache: false,
                        dataType: 'json',
                        beforeSend: function () {
                            $('.loader').show();
                        },
                        success: function (result) {


                            // 🔴 Clear old PIN error every time
                            $('#gaspinError').hide().text("");

                            /* 🔴 PIN ERROR — SAME PAGE */
                            if (result.status && (
                                result.status === "PIN_REQUIRED" ||
                                result.status === "INVALID_PIN" ||
                                result.status === "PIN_NOT_SET")) {

                                $('#gaspinError').text(result.message).show();
                                $('.loader').hide();
                                return; // 🚫 STOP ONLY FOR PIN ERROR
                            }

                            var status = result.Response;
                            var message = result.Message;
                            if (status == "GATEWAY") {
                                window.open(message, "_self");
                                $('#rchstatuschkgas').text("Pending");
                                $('#rchmsggas').text("Please Wait While Redirect The Gateway");
                            }
                            else {
                                $('#rchstatuschkgas').text(status);
                                $('#rchmsggas').text(message);

                                $("#txtgasno").val("");
                                $("#gasamount").val("");
                            }

                            $('#confirmgas').hide();
                            $('#rechargeconfirmgas').show();
                        },
                        complete: function () {
                            $("#remainretailer").load(location.href + " #remainretailer");
                            $('.loader').hide();
                            $.ajax({
                                url: '@Url.Action("showrecentrecharge", "Home")',
