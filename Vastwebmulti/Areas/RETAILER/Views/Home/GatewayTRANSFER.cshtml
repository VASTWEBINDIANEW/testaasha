    ViewBag.Title = "GatewayTRANSFER";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
    var totalsuccess = ViewBag.totalsuccess ?? 0;
    var totalfailamnt = ViewBag.totalfailedamount ?? 0;
    var penamount = ViewBag.totalpendingamount ?? 0;
    var totalcharges = ViewBag.totalchargesamount ?? 0;
    var CheckActiveGetway = ViewBag.CREDITCARDSTATUS;
    @functions {
        public string MaskLastSixDigits(string input)
        {
            input = new string(input.Where(char.IsDigit).ToArray());
            if (input.Length > 6)
            {
                string visiblePart = input.Substring(0, input.Length - 6);
                return visiblePart + new string('*', 6);
            }
            return input;
        }
    }
}
