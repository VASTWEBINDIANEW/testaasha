                span.style.marginLeft = '3px';
                td.appendChild(img);
                td.appendChild(span);
            }
        }
        tbl.style.margin = "30px 0";
        return tbl;
    }

    function ucFirst(string) {
        return string.charAt(0).toUpperCase() + string.slice(1);
    }
