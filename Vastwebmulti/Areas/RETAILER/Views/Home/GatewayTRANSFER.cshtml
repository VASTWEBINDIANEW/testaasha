<script>
    function HideShowGetWay(CheckActive) {
        if (CheckActive === 'Gateway') {
            document.getElementById('GetWayMode').style.display = 'none';
            document.getElementById('CreditCardMode').style.display = 'block';

            document.getElementById('creditCardPayment').checked = true;
            document.getElementById('gatewayTransfer').checked = false;

            $.ajax({
                url: '@Url.Action("GetDiscountedAmount", "Home")',
                type: 'POST',
                success: function (response) {
                    if (response.Status) {
                        var addinfoArray = JSON.parse(response.Addinfo);
                        var IHTML = `<option value="">Select Amount</option>`;
                        for (var i = 0; i < addinfoArray.length; i++) {
                            var billInfo = addinfoArray[i];
                            IHTML += `<option value="${billInfo.Idno}">${billInfo.Amount}</option>`;
                        }
                        document.getElementById('BillInfo').innerHTML = IHTML;
                    } else {
                    }
                },
                error: function (error) {
                }
            });
        } else {
            document.getElementById('GetWayMode').style.display = 'block';
            document.getElementById('CreditCardMode').style.display = 'none';
            document.getElementById('creditCardPayment').checked = false;
            document.getElementById('gatewayTransfer').checked = true;
        }
    }
    function SelectAmount(dropdown) {
        var selectedValue = dropdown.value;
        $.ajax({
            url: '@Url.Action("GetHoldAmount", "Home")',
            type: 'POST',
            data: { Id: selectedValue },
            success: function (response) {
                if (response.Status) {
                    var addinfoArray = JSON.parse(response.Addinfo);
                    document.getElementById("BillDropdown").style.display = 'none';
                    document.getElementById("BillInputBox").style.display = 'block';
                    document.getElementById("Amount").value = addinfoArray.Amount;
                    document.getElementById("hideidno").value = selectedValue;

                } else {
                }
            },
            error: function (error) {
            }
        });
    }
    function validateInput(input, type) {
        let value = input.value.replace(/\D/g, '');
        let message = '';
        switch (type) {
            case 'amount':
                input.value = value;
                if (value < 100) {
                    message = 'The Amount must be 100 or more';
                }
                break;
            case 'cardNumber':
                const minLength = 13;
                const maxLength = 19;
                if (value.length > maxLength) value = value.slice(0, maxLength);
                input.value = value;
                if (value.length < minLength || value.length > maxLength) {
                    message = 'Please enter a valid credit card number with 13 to 19 digits.';
                    input.setCustomValidity("Card number must be between 13 and 19 digits long.");
                } else {
                    input.setCustomValidity("");
                }
                break;
            case 'month':
                if (value.length > 2) value = value.slice(0, 2);
                const month = parseInt(value, 10);
                if (value.length === 2 && (month < 1 || month > 12)) {
                    message = 'Select month between 1 to 12 only.';
                }
                if (value.length === 2) {
                    const month = parseInt(value, 10);
                    if (month < 1 || month > 12) {
                        value = value.slice(0, 1);
                    }
                }
                input.value = value;
                break;
            case 'year':
                if (value.length > 2) value = value.slice(0, 2);
                if (value.length < 2) {
                    message = 'Please enter last 2-digit year (e.g., 24).';
                }
                input.value = value;
                break;
            case 'cvv':
                if (value.length > 3) value = value.slice(0, 3);
                input.value = value;
                if (value.length !== 3) {
                    message = 'Please enter a valid 3-digit CVV.';
                }
                break;
            case 'otp':
                input.value = value;
                break;
            default:
                break;
        }
        document.getElementById("VlidateionsMessage").innerHTML = message;
    }
    function CreditCardProceed() {
        let Amount = $('#Amount').val(); 
        let Name = $('#NameInput').val();
        let Cardnumber = $('#CardNumberInput').val(); 
        let Month = $('#MonthInput').val(); 
        let Year = $('#YearInput').val(); 
        let CVV = $('#CVVInput').val(); 
        let Otp = $('#OtpInput').val();
        let Idno = $('#hideidno').val();
        let reqid = $('#RequestId').val();
        if (Idno != "") {
            if (Amount >= 100) {
                if (Cardnumber.length > 12 && Cardnumber.length < 20) {
                    if (Month.length > 0 && Month.length < 3) {
                        Month = Month.length === 1 ? 0 + Month : Month;
                        if (Year.length > 0 && Year.length < 3) {
                            if (CVV.length > 2 && CVV.length < 5) {
                                let Exp = Month + "/" + Year;

                                $.ajax({
                                    url: '@Url.Action("CreditCardTransfer", "Home")',
                                    type: 'POST',
                                    data: { Amount, Cardnumber, Name, CVV, Exp, Otp, Idno, reqid },
                                    beforeSend: function () {
                                        document.getElementsByClassName('Loader-set')[0].style.display = 'block';
                                    },
                                    success: function (response) {
                                        document.getElementsByClassName('Loader-set')[0].style.display = 'none';
                                        if (response.Issendotp) {
                                            document.getElementById('RequestId').value = response.RequestId
                                            document.getElementById('OtpBox').style.display = 'block';
                                           // document.getElementById('ButtonProceed').style.display = 'none';
                                           // document.getElementById('ButtonSubmit').style.display = 'block';
                                        }
                                        else {
                                            document.getElementById('VlidateionsMessage').innerHTML = response.Message;
                                        }
                                    },
                                    error: function (error) {
                                        document.getElementsByClassName('Loader-set')[0].style.display = 'none';
                                    },
                                    complete: function (xhr, status) {
                                        document.getElementsByClassName('Loader-set')[0].style.display = 'none';
                                    }
                                });
                            }
                            else {
                                document.getElementById('VlidateionsMessage').innerHTML = 'Please enter a valid 3 or 4-digit CVV.';
                            }
                        }
                        else {
                            document.getElementById('VlidateionsMessage').innerHTML = 'Please enter last 2-digit year (e.g., 24).'
                        }
                    }
                    else {
                        document.getElementById('VlidateionsMessage').innerHTML = 'Select month between 1 to 12 only.'
                    }
                }
                else {
                    document.getElementById("VlidateionsMessage").innerHTML = 'Please enter a valid credit card number with 13 to 19 digits.';
                }
            }
            else {
                document.getElementById("VlidateionsMessage").innerHTML = 'The Amount must be 100 or more';
            }
        }
        else {
            document.getElementById("VlidateionsMessage").innerHTML = 'ID is miss';
        }
    }

