<!--Buy Now Giftcard-->
<script>
    function Buynow()
    {
        latss = $('#latss').val();
        longloc = $('#longloc').val();
        var minval = $("#minval").val();
        var maxval = $("#maxval").val();
        var amount = $("#Amount").val();
        var recivername = $("#ReceiverName").val();
        var reciveremail = $("#ReceiverEmail").val();
        var recivermobile = $("#ReceiverMobile").val();
        var message = $("#Message").val();
        var optcode = $("#optcode").val();

        if (amount == "" || recivername == "" || reciveremail == "" || recivermobile == "")
         {
        if (amount == "")
        {
          document.getElementById("amount_validate").innerHTML = "Please enter amount";
            event.preventDefault();
            return false;
        }
        else {
            document.getElementById("amount_validate").innerHTML = "";
        }
        if (amount < parseInt(minval) || amount > parseInt(maxval)) {
                  document.getElementById("amount_validate").innerHTML = "Enter a valid amount";
            event.preventDefault();
            return false;

          }
          else {
              document.getElementById("amount_validate").innerHTML = "";
          }

          if (recivername == "")
           {
           document.getElementById("recivername_validate").innerHTML = "Please enter receiver name";
                event.preventDefault();
                return false;

          }
          else {
              document.getElementById("recivername_validate").innerHTML = "";
          }
          if (reciveremail == "") {
              document.getElementById("reciveremail_validate").innerHTML = "Please enter receiver email-id";
              event.preventDefault();
              return false;
          }
          else {
              document.getElementById("reciveremail_validate").innerHTML = "";
          }
          if (recivermobile == "") {
              document.getElementById("recivermobile_validate").innerHTML = "Please enter receiver mobile no";
              event.preventDefault();
              return false;
          }
          else {
              document.getElementById("recivermobile_validate").innerHTML = "";
          }
        }
          else {

              document.getElementById("amount_validate").innerHTML = "";
              document.getElementById("recivername_validate").innerHTML = "";
              document.getElementById("reciveremail_validate").innerHTML = "";
              document.getElementById("recivermobile_validate").innerHTML = "";

            ///Ajax Call


            $("#textshowcontentnone").html("Are you sure !");

                    $.ajax({
                    type: "POST",
                     url: "@Url.Action("Buygitfcard", "Home")",
                        data: { optcode: optcode, amount: amount, receiver_name: recivername, receiver_email: reciveremail, receiver_mobile: recivermobile, gift_message: message, latss: latss, longloc: longloc  },
                    cache: false,
                    dataType: 'json',
                    closeOnConfirm: true,
                        success: function (data) {

                        var sts = "";
                        sts = data.status;
                            var msg = data.message;
                            if (sts == "success") {
                                $('#fail').hide();
                                $('#suc').show();
                                $('#sts').text(sts);
                            }
                            else {
                                $('#fail').show();
                                $('#suc').hide();
                                $('#sts1').text(sts);
                            }


                            $("#showwwww").hide();
                            $('#messageshow').show();

                            $('#msg').text(msg);
                            $('#amt').text(amount);
                            $('#recname').text(recivername);
                            $('#recemail').text(reciveremail);
                            $('#recmob').text(recivermobile);
                            $('#recemsg').text(message);

                    }
                });



          }

    }
</script>

