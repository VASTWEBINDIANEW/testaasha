<!--Check Bal Gift card Voucher script-->
<script>
    function CheckBalVoucher()
    {
        var giftcardno = $("#Giftcardno").val();
        var Pin = $("#Pin").val();
        if (giftcardno == "" || Pin == "")
        {
            if (giftcardno == "") {
                document.getElementById("giftcardno_validate").innerHTML = "Please gift card number";
                event.preventDefault();
                return false;
             }
            else {
                document.getElementById("giftcardno_validate").innerHTML = "";
             }
            if (Pin == "") {
                document.getElementById("pin_validate").innerHTML = "Please enter pin";
                event.preventDefault();
                return false;
            }
            else {
                document.getElementById("pin_validate").innerHTML = "";
            }
        }
        else {
            document.getElementById("giftcardno_validate").innerHTML = "";
            document.getElementById("pin_validate").innerHTML = "";

            $.ajax({
                type: 'Post',
                url: "@Url.Action("CheckGiftVoucherBal", "Home")",
                data: { cardnumber: giftcardno, pin: Pin },
            dataType: 'json',
            cache: false,
            async: true,
            success: function (data) {
                var sts = "";

                sts = data.status;
                   var cardnumberno = data.cardnumberno;
                var cardbalance = data.cardbalance;
                var expiry = data.expiry;
                if (sts == "SUCCESS")
                {
                $("#CheckbalModal").modal('hide');
                    swal({
                        title: "CHECK VOUCHER BALANCE",
                        html: true,
                        text: "<p>Cardnumber :  " + cardnumberno + "</p> <br/><p style='margin-top:-17px;margin-left:-97px;'>Cardbalance :  " + cardbalance + "</p> <br/>  <p style='margin-top:-17px;margin-left:-61px;'>Expiry Date   :  " + expiry + "</p><br/> <p style='margin-top:-17px;margin-left:-32px;'>Status   :  " + sts + "</p>",
                        confirmButtonText: "Close",
                        allowOutsideClick: "true"
                    });
                }
                else {
                $("#CheckbalModal").modal('hide');
                    swal("Oops !", data.message, "error");
                }
            }
        });

        }
    }
</script>





<script>
    function countChar(val) {
