<script>
    function isNumber(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            return false;
        }
        return true;
    }
</script>
<!--Brand Details Function-->
<script>
    function brand_details(optcode)
    {
        $('#secpurGiftCard').hide();
        $('#ALLGiftCard123').hide();
        $('#BOTHGiftCard123').hide();
        $('#firstGiftCard123').hide();
        $('#HDServicesname').val('')
        $('#showwwww').hide();
        document.getElementById("amount_validate").innerHTML = "";
        document.getElementById("recivername_validate").innerHTML = "";
        document.getElementById("reciveremail_validate").innerHTML = "";
        document.getElementById("recivermobile_validate").innerHTML = "";
        $.ajax({
            type: 'Post',
            url: "@Url.Action("GiftCard_details", "Home")",
            data: { optcode: optcode, opttype: "ALL", isfirsttime: 'NO' },
            dataType: 'json',
             cache: false,
             async: true,
            success: function (data) {
                
                var resp = JSON.parse(data);

                if (resp == "ALLNOTDONE") {

                    $('#ALLGiftCard123').show();


                   $("#defaultModal").modal();
                }
                else if (resp == "BOTHNOTDONE") {

                    $('#BOTHGiftCard123').show();


                    $("#defaultModal").modal();
                }
                else if (resp == "NOTOK") {
                    $("#firstGiftCard123").show()

                    $("#defaultModal").modal();



                  }


                else if (resp.StatusCode == "200") {

                    $('#showwwww').show();
                   var addinfo = resp.Content.ADDINFO[0];

                    var img = "https://www.vastbazaar.com/" + addinfo.image.replace("../../", "");

                    document.getElementById("myImg").src = img;
                    $("#optname").html(addinfo.OptName);

                     var description = addinfo.DESCRIPTION;
                     var product_type = addinfo.opttype;
                     var price_type = addinfo.amounttype;
                     var min_custom_price="";
                     var max_custom_price="";
                     var showpricerange="";
                     var custom_denominations="";
                     var termcondition = addinfo.Terms;
                     var array = termcondition.split("<br/>");
                     var str = "";
                     array.forEach(function (entry) {
                         str = str + "<li style='padding-bottom:7px;font-size:12px;'>" + entry + "</li>";
                     });
                     if(price_type=="Range")
                     {
                         document.getElementById("slabamt").style.display = "block";

                         min_custom_price = addinfo.min;
                         max_custom_price = addinfo.max;
                         $("#Amount").html("");
                         $("#Amount")
                      .replaceWith('<input type="text"  id="Amount" class="form-control" onkeypress="return isNumber(event)"/ >');

                         showpricerange =  "Min: ₹" + min_custom_price + " - Max: ₹" + max_custom_price + "";
                         $("#cardtype").html(product_type);
                         $("#shortdesc").html(description);
                          $("#termsdesc").html(str);
                         $("#showprice").html(showpricerange);
                         $("#minval").val(min_custom_price);
                         $("#maxval").val(max_custom_price);
                         $("#optcode").val(optcode);
                         $("#defaultModal").modal();
                     }
                     else {
                         $("#minval").val("");
                         $("#maxval").val("");
                         document.getElementById("slabamt").style.display = "block";
                          custom_denominations = addinfo.fixedvalues;
                          showpricerange = "(Choose from ₹:" + custom_denominations + ")";
                          var array = custom_denominations.split(",");
                        $("#cardtype").html(product_type);
                         $("#shortdesc").html(description);
                         $("#showprice").html(showpricerange);
                         $("#optcode").val(optcode);
                         $("#termsdesc").html(str);

                     $("#Amount")
                  .replaceWith('<select name="Amount" id="Amount" class="form-control">' +
                    '</select>');
                   var div_data = "";
                   array.forEach(function (entry) {
                       div_data = div_data + "<option value=" + entry + ">" + entry + "</option>";
                   });
                   $(div_data).appendTo('#Amount');
                    $("#defaultModal").modal();
                     }
                }
        }
    });
        //$("#defaultModal").modal();
    }
</script>

