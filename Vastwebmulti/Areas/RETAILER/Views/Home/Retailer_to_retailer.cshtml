                                                            <th>Transfer&nbsp;Amt</th>
                                                            <th>Retailer&nbsp;Old&nbsp;Bal</th>
                                                            <th>Retailer&nbsp;New&nbsp;Bal</th>
                                                            <th>Your&nbsp;Old&nbsp;Bal</th>
                                                            <th>Your&nbsp;New&nbsp;Bal</th>
                                                            <th>Comment</th>
                                                            <th>Date</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var item in Model)
                                                        {

                                                            <tr style="background:no-repeat;">
                                                                <td>@Html.DisplayFor(modelItem => item.rem_to)</td>
                                                                <td> @Html.DisplayFor(modelItem => item.value)</td>
                                                                <td>@Html.DisplayFor(modelItem => item.rem_to_old_bal)</td>
                                                                <td>@Html.DisplayFor(modelItem => item.rem_to_new)</td>
                                                                <td>@Html.DisplayFor(modelItem => item.rem_from_old_bal)</td>
                                                                <td>@Html.DisplayFor(modelItem => item.rem_from_new)</td>
                                                                <td>@Html.DisplayFor(modelItem => item.comment)</td>
