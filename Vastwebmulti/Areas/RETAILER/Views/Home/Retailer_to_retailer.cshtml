<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script>
    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 45 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }
    $("#RetailerId").blur(function (event) {
        //  var character = String.fromCharCode(event.keyCode);
        var mobemail = $("#RetailerId").val()
        
       
           
            //   alert(mobemail.val())
            $.ajax({
                url: "@Url.Action("CheckRetailerEmailMobile")",
                data: { emailmobile:mobemail},
                success: function (data) {
                    if (data != '') {
                        $('#retailerinform').show();
                        $('#lblfrmname').text(data.Frm_Name);
                          $('#lblreatilername').text(data.RetailerName);
                        $('#lblemail').text(data.Email);
                        $('#lblmobile').text(data.Mobile)
                         $('#submit').removeAttr('disabled');
                    }
                    else {
                        $('#retailerinform').hide();
                         $('#submit').attr('disabled', 'disabled');
                    }
                  
                    
                }



            })
       
       
});
</script>
