                                                            <td style="font-size:17px;">@Model.Sum(m => m.value)</td>
                                                            <td></td>
                                                            <td></td>
                                                            <td></td>
                                                            <td></td>
                                                            <td></td>
                                                            <td></td>

                                                        </tr>
                                                    </tfoot>
                                                </table>
                                            </div>
                                        </div>
                                    </div>


                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                    
                    
            </div>

        </div>      
        
        
    </div> 

</section>

