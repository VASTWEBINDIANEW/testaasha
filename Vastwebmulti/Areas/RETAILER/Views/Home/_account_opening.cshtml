<style>
    .listtryp {
        width: 11.1% !important;
        margin-top: -2px;
    }
    @@-webkit-keyframes blinker {
  from { opacity: 5.0; }
  to { opacity: 0.0; }
}

.waitingForConnection {
  -webkit-animation-name: blinker;
  -webkit-animation-iteration-count: infinite;
  -webkit-animation-timing-function: cubic-bezier(.5, 0, 1, 1);
  -webkit-animation-duration: 1.7s;
}
    .loader {
        position: fixed;
        top: -90px;
        left: 0;
        background-color: rgba(255,255,255,0.7);
        z-index: 999999999999;
        display: none;
        height: 100vw;
        width: 100vw;
        -webkit-animation: spin .8s linear infinite;
        animation: spin .8s linear infinite;
    }

    @@-webkit-keyframes spin {
        from {
            -webkit-transform: rotate(0deg);
        }

        to {
            -webkit-transform: rotate(360deg);
        }
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .loader::after {
        content: '';
        display: block;
        position: absolute;
        left: 48%;
        top: 25%;
        width: 100px;
        height: 100px;
        border-style: solid;
        border-color: black;
        border-top-color: transparent;
        border-width: 4px;
        border-radius: 50%;
        -webkit-animation: spin .8s linear infinite;
        animation: spin .8s linear infinite;
    }

    .aeps-start .fdgfgfgfga {
        width: 60% !important;
    }

    .my-trans {
        width: 100%;
        float: left;
        border: 5px solid #fff;
        padding: 10px;
        margin-top: 15px;
    }

    .update-page .container-fluid.transaction-button .update-page5, .update-page .container-fluid.transaction-button .update-page3 {
        background-image: linear-gradient(to right, var(--main-bg-lcolor), var(--main-bg-rcolor)) !important;
        color: #fff !important;
    }

    .update-page .container-fluid.transaction-button {
        margin-top: 0px;
    }

    .my-trans.introoo .custome-none-class1 {
        display: none;
    }

    .my-trans.introoo .custome-none-class {
        display: block !important;
    }
</style>
<style>
    .form-set_1 {
        width: 100%;
        float: left;
        
    }
    form#account_form {
        width: 100%;
        float: left;
    }
        form#account_form label {
            padding: 0px;
            margin: 0px;
            margin-top: 5px;
        }
    span.whight_line {
        background: linear-gradient(to right, var(--main-bg-lcolor), var(--main-bg-rcolor)) !important;
