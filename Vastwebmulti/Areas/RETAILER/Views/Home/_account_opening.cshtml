<div class="loader loaderpancard"></div>
<div style="display: grid; align-items: center; height: 50vh">
    <div id="not_active" style="display: none;">
        <div style="margin: auto; display: grid;">
            <p style="font-size: 20px; text-align: center">Your Account is not activated.</p>
            <p style="text-align: center">Activate your Account first</p>
            <span class="text-danger" style="text-align: center; font-size: 11px;" id="customer_acc_error"></span>
            <button class="btn" style="background: var(--main-bg-lcolor); color: white; margin: auto; font-size: 18px;margin-top: 20px" id="account_opening_customer_btn">Activate</button>
        </div>
    </div>
    <div id="account_opening" style="display: none;">
        <h3 style="  margin-top: -10px; ">Axis bank Saving Account Opening</h3>
        <h4 style="font-weight: 400; font-size: 11px; letter-spacing: 0.1px; line-height: 3; animation: blink 1s step-start 0s infinite; display: initial; ">Please enter correct information as per customer/consumer KYC documents below.</h4>
       <span class="whight_line" style="padding:2px 0px;"></span>
        <div class="form-set_1">
            <form id="account_form">
                <div class="input">
                    <label>First Name</label>
                    <input class="form-control" type="text" name="fname" value="" style="width: 100%; height: 34px;" required placeholder="Customer First Name" />
                </div>
                <div class="input">
                    <label>Last Name</label>
                    <input class="form-control" type="text" name="lname" value=""style="width: 100%; height: 34px;" required placeholder="Customer Last Name"/>
                </div>
                <div class="input">
                    <label>Email</label>
                    <input class="form-control" type="text" name="email" value=""style="width: 100%; height: 34px;" required placeholder="Customer Email I'd"/>
                </div>
                <div class="input">
                    <label>Mobile</label>
                    <input class="form-control" type="text" name="mobile" value=""style="width: 100%; height: 34px;" required placeholder="Customer Mobile Number" maxlength="10" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" />
                </div>
                <div class="input">
                    <label>DOB (DD,MM,YYYY)</label>
                    <input class="form-control" type="date" name="dob" value=""style="width: 100%; height: 34px;" required />
                </div>
                <div class="input">
                    <label> Area Pincode</label>
                    <input class="form-control" type="text"placeholder="Customer Area Pincode" name="pincode" value=""style="width: 100%; height: 34px;"  required maxlength="6" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*)\./g, '$1');" />
                </div>
                <div style="width: 50%; float: left; padding-top: 16px;">
                    <input class="btn" type="button" value="Submit" id="account_submit" style="width: 98%; height: 34px; background: var(--main-bg-lcolor) !important;" />
                </div>
                <div style="width: 50%; float: right; padding-top: 16px;">                   
                    <input class="btn" type="reset" value="Reset" style="width: 98%; height: 34px;  " id="account_reset" />
                </div>
                <div>
                    <span style="font-size: 11px; position: absolute; left: 13px; margin-top: 55px;font-weight:600;" class="text-danger" id="account_submit_error"></span>
                </div>
            </form>
        </div>
    </div>
    <div>

    </div>
</div>