<style>

    /* new css  */



    .layoutt-retailer section.content {
        margin-top: 95px;
        padding-top: 5px;
    }

    .bread-same-all-page li {
        margin: 6px 0;
    }

    .bread-same-all-page {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }


       
    /* new css  */

    .table tbody tr td, .table tbody tr th {
        border-top: 0px;
        border-bottom: 0px;
    }

    .table-responsive {
        border: 0px;
        margin-right: 10px;
        margin-left: 10px;
    }

    .dsdtb tr {
        border-bottom: 1px dashed;
    }

        .dsdtb tr td:nth-child(2) {
            text-align: right;
        }

    .pki img {
        width: 57%;
        padding: 20px;
    }

    .dsdtb tr:last-child {
        border-bottom: 0px;
    }

    @@media only screen and (max-width:767px){

        .bread-same-all-page li {
            margin: 6px 0 !important;
        }
        .allpage-responshivenew {
            padding: 0px 0;
        }


    }

   
</style>
