<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.1/css/toastr.css" rel="stylesheet" />
<style>
    /* New Css */
    .aeps_id .amount {
        display: flex;
        align-items: center;
    }
    #Corrections input {
        width: 100%;
    }

    .aeps_id .amount span {
        padding-top: 0;
    }

    .aeps_id .col-md-12.amount strong {
        padding: 6px 5px;
    }

    .tabspage .tab-content input {
        border: 1px solid #919191;
        border-radius: 4px;
    }

    .select2-container--default .select2-selection--single {
        border: 1px solid #919191 !important;
    }
    /* New Css */
    .loader {
        position: fixed;
        top: -90px;
        left: 0;
        background-color: rgba(255,255,255,0.7);
        z-index: 999999999999;
        display: none;
        height: 100vw;
        width: 100vw;
    }

    @@-webkit-keyframes spin {
        from {
            -webkit-transform: rotate(0deg);
        }

        to {
            -webkit-transform: rotate(360deg);
        }
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .loader::after {
        content: '';
        display: block;
        position: absolute;
        left: 48%;
        top: 25%;
        width: 100px;
        height: 100px;
        border-style: solid;
        border-color: black;
        border-top-color: transparent;
        border-width: 4px;
        border-radius: 50%;
        -webkit-animation: spin .8s linear infinite;
        animation: spin .8s linear infinite;
    }

    .aeps-start .fdgfgfgfga {
        width: 70% !important;
    }

    .my-trans {
        width: 100%;
        float: left;
        border: 5px solid #fff;
        padding: 10px;
        margin-top: 15px;
    }

    .update-page .container-fluid.transaction-button .update-page5, .update-page .container-fluid.transaction-button .update-page3 {
        background-image: linear-gradient(to right, var(--main-bg-lcolor), var(--main-bg-rcolor)) !important;
        color: #fff !important;
    }

    .update-page .container-fluid.transaction-button {
        margin-top: 0px;
    }

    .my-trans.introoo .custome-none-class1 {
        display: none;
    }

    .my-trans.introoo .custome-none-class {
        display: block !important;
    }

    .Physical-Token {
        display: flex;
        align-items: center;
        width: 100%;
    }

        .Physical-Token img {
            width: 15px;
            float: left;
            margin-right: 2px;
        }

    .myDiv123 {
        margin: 0px 2px;
    }

    #psaidregister {
        font-size: 12px;
    }

    .manual_form {
        width: 100%;
        float: left;
    }

    .manual_form1 {
        padding: 4px;
        width: 33.33%;
        float: left;
    }

        .manual_form1 button {
            width: 100%;
            padding: 6px 0;
        }

    .manual_form_m label {
        width: 100%;
        float: left;
        padding-top: 5px;
    }

    .manual_form_m input {
        width: 100% !important;
        float: left;
        padding-top: 5px;
    }

    .manual_w {
        width: 50%;
        float: left;
        padding: 5px;
    }

    #full .manual_w span.select2 {
        width: 100% !important;
        height: 32px !important;
    }

    #full .manual_w .selection {
        width: 100% !important;
        height: 32px !important;
        padding: 0;
    }

    .manual_w .select2-container .select2-selection--single {
        height: 32px;
    }

    #full .manual_w .select2-selection__arrow b {
        position: relative;
        top: -12px;
        margin-right: 9px;
        float: right;
    }
    /* Chrome, Safari, Edge, Opera */
    .manual_w input::-webkit-outer-spin-button,
    .manual_w input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Firefox */
    .manual_w input[type=number] {
        -moz-appearance: textfield;
    }

    .sub_b {
        width: 100%;
        float: left;
        padding: 10px 0;
        text-align: center;
    }

        .sub_b button {
            padding: 6px 30px;
        }

    .manual_w [type="radio"]:not(:checked), .manual_w [type="radio"]:checked {
        position: sticky;
        left: initial;
        opacity: 1;
        float: initial;
        margin-right: 4px;
    }

    .manual_w.Gender input {
        width: auto !important;
        height: auto;
        position: sticky;
    }

    .backgroundss {
        background: var(--main-bg-lcolor);
        border: 1px solid #aaa;
        border-radius: 4px;
        color: #fff;
    }

    .btmd {
        height: 34px;
    }

    @@media only screen and (max-width:991px) {
        .col-md-4.tabspage {
            float: left;
        }
    }
    /* New css */

    @@media only screen and (max-width:480px) {
        .manual_form1 {
            width: 100%;
        }

        .aeps-start .fdgfgfgfga {
            width: 100% !important;
        }

            .aeps-start .fdgfgfgfga .amount_strong span {
                font-size: 14px;
                padding-top: 0px;
            }

        .col-md-2.aeps_button {
            width: 30%;
        }

        .manual_w {
            width: 100%;
        }
    }
</style>

<script>
    function colorchanges(t) {
        var s = document.getElementsByClassName('btmd');
        var s1 = document.getElementsByClassName('manual');
        for (var i = 0; i < s.length; i++) {
            s[i].classList.remove('backgroundss');
            s1[i].style.display = 'none';
        }
        s[t].classList.add('backgroundss');
        s1[t].style.display = 'block';

    }
</script>

