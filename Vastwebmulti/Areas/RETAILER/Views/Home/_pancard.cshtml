            else {
                if (isBlank(panadharno)) {
                    document.getElementById('mess').innerHTML = 'Please Enter Aadhaar Card No.';
                }
                else {
                    if (isBlank(panname)) {
                        document.getElementById('mess').innerHTML = 'Please Enter Name';
                    }
                    else {
                        if (isBlank(pandob)) {
                            document.getElementById('mess').innerHTML = 'Please Enter Dob';
                        }
                        else {
                            if (isBlank(panmobno)) {
                                document.getElementById('mess').innerHTML = 'Please Enter Mobile No.';
                            }
                            else {
                                if (isBlank(panfathername)) {
                                    document.getElementById('mess').innerHTML = 'Please Enter Father Name';
                                }
                                else {
                                    if (isBlank(panemail)) {
                                        document.getElementById('mess').innerHTML = 'Please Enter Email id';
                                    }
                                    else {
                                        if (isBlank(pancustmno)) {
                                            document.getElementById('mess').innerHTML = 'Please Enter Customer Mobile No.';
                                        }
                                        else {
                                            if (isBlank(userstate)) {
                                                document.getElementById('mess').innerHTML = 'Please Select State.'
                                            }
                                            else {
                                                $.ajax({
                                                    url: '@Url.Action("pancardmanual", "Home")',
                                                    data: { msts: panmarrigests, adharno: panadharno, name: panname, dob: pandob, mobile: panmobno, father: panfathername, Email: panemail, cmobile: pancustmno, gender: panradio, state: userstate },
                                                    cache: false,
                                                    type: "POST",
                                                    dataType: 'json',

                                                    success: function (data) {
                                                    document.getElementById('mess').innerHTML = data.message;
                                                       if (data.status = "Pending") {
                                                           PANCARD_manual();
                                                       }
                                                    }
                                                });
                                            }

                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

        }
        function isBlank(str) {
            return (!str || /^\s*$/.test(str));
        }
</script>
