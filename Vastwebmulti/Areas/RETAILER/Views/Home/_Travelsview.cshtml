<style>
    #ul {
        list-style-type: none;
        margin: 0;
        padding: 0;
        overflow: hidden;
        /*background-color: #e91e63;*/
    }

        #ul li {
            float: left;
            margin-left: 4px;
        }

            #ul li a {
                color: black;
                padding: 7px 12px;
                text-align: center;
                text-decoration: none;
                display: block;
                
                border-radius: 2px;
                border: 1px solid #d2d1d1;
                text-align: center;
                text-decoration: none;
                display: block;
                margin-top:0px;
            }

                #ul li a:hover:not(.activee) {
                    background-color: #111;
                    color: white;
                    border-radius: 2px;
                }

    .activee {
        background-color: #dddddd;
        color: white;
    }
    #tabsrepor-navs li {
        margin-right: 4px;
    }
</style>

<ul class="nav nav-tabs tabsrepor-nav" id="tabsrepor-navs">
    <li>
        <a href="@Url.Action("TicketReport", "Air") ">
            <img class="reportnone" src="~/images/airplane.png" /> <img class="reportblock" style="" src="~/images/airplane.svg" /><span>Flight</span>
        </a>
        
    </li>
    <li><a href="@Url.Action("BusBookingReport","Bus")"><img class="reportnone" src="~/ashok-images/bus.svg" /> <img class="reportblock" style="" src="~/ashok-images/bus (1).svg" /><span>Bus</span></a></li>
    <li><a href="@Url.Action("HotelReport","Hotel")"><img class="reportnone" src="~/ashok-images/hotel.svg" /> <img class="reportblock" style="" src="~/ashok-images/hotel(1).svg" /><span></span>Hotel</a></li>


</ul>
<script src="~/Scripts/jquery-1.10.2.min.js"></script>
<script>
    $(document).ready(function () {
        var current = location.pathname;
        $('.nav.nav-tabs.tabsrepor-nav li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('active');
                $this.addClass('navbar');

            }
        })
    });
</script>


