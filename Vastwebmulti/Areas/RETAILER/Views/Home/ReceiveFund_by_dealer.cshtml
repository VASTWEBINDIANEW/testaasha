@model IEnumerable<Vastwebmulti.Models.Retailer_total_fund_recive_by_dealer_Result>
@{
    ViewBag.Title = "ReceiveFund_by_master";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
}
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }

    .btn-group, .btn-group-vertical {
        box-shadow: none;
    }

    .ppp {
        margin-top: -20px !important;
    }

    .form-inline .bootstrap-select.btn-group, .form-horizontal .bootstrap-select.btn-group, .form-group .bootstrap-select.btn-group {
        height: 29px;
    }
</style>
<section class="content" style="margin:90px 0px 0px 0px; overflow-x:hidden;">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    @using (Html.BeginForm("ReceiveFund_by_dealer", "Home", FormMethod.Post))
                    {
                        <div class="">
                            <div class="col-md-7">
                                <div class="form-group" style="margin-top: 2px;">
                                    <ol class="breadcrumb breadcrumb-col-blue-grey" style="margin-left:-12px;">
                                        <li class="active" style="color:#a79f9f; font-size:15px;font-weight:700;">Fund Receive From Distributor History</li>
                                    </ol>
                                </div>

                            </div>
                            <div class="col-md-3">
                                <div class="form-group" style="margin-bottom:0px;margin-left:-10px;width:108%;">
                                    <div class="input-daterange input-group">
                                        @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;", autocomplete = "off" })
                                        <span class="input-group-addon">
                                            <i class="fa fa-exchange"></i>
                                        </span>
                                        @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;", autocomplete = "off" })
                                    </div>
                                    <!-- /.input group -->
                                </div>
                            </div>
                            <div class="col-md-2">
                                <center>
                                    <button type="submit" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left:-20px; height:34px;">
                                        <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                        <span style="top:-2px;color:black;">Search</span>
                                    </button>
                                </center>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-39px;">
                <div class="card">
                    <div class="">
                        <h2 style="color:black; font-size:16px;padding-top:9px; padding-left:22px;"></h2>
                    </div>
                    <div class="body" style="padding:7px;">
                        <div class="table-responsive" style="position:inherit;margin-top:-24px;">
                            <table id="example" class="table table-bordered " style="width:100%;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Distributro&nbsp;Info</th>
                                        <th>Total&nbsp;Transfer</th>
                                        <th>Type</th>
                                        <th>Remain&nbsp;Pre</th>
                                        <th>Remain&nbsp;Post</th>
                                        <th>Current&nbsp;Credit</th>
                                        <th>Old&nbsp;Credit</th>
                                        <th>Net&nbsp;Amt</th>
                                        <th>Date</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr style="background:no-repeat;">
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <div class="btn-group" role="group">
                                                        <button type="button" class="btn btn-default waves-effect dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="true" title="Click to All information">
                                                            @item.Email
                                                        </button>
                                                        <ul class="dropdown-menu ppp">
                                                            <li>
                                                                <a href="javascript:void(0);" class="waves-effect waves-block" style="border-bottom:1px solid #f1efef;line-height:11px;">
                                                                    @item.DealerName
                                                                    <p style="font-size: 11px;margin-left: 0px;margin-top: 6px;">Name</p>
                                                                </a>
                                                            </li>
                                                            <li>
                                                                <a href="javascript:void(0);" class="waves-effect waves-block" style="border-bottom:1px solid #f1efef;line-height:11px;">
                                                                    @item.FarmName
                                                                    <p style="font-size: 11px;margin-left: 0px;margin-top: 6px;">Frim Name</p>
                                                                </a>
                                                            </li>
                                                            <li>
                                                                <a href="javascript:void(0);" class="waves-effect waves-block" style="border-bottom:1px solid #f1efef;line-height:11px;">
                                                                    @item.comment
                                                                    <p style="font-size: 11px;margin-left: 0px;margin-top: 6px;">Comment</p>
                                                                </a>
                                                            </li>

                                                        </ul>

                                                    </div>
                                                </div>

                                            </td>
                                            <td><p style="margin-top:6px;">@item.Balance</p></td>
                                            <td><p style="margin-top:6px;">@item.bal_type</p></td>
                                            <td><p style="margin-top:6px;">@item.remain_pre_amount</p></td>
                                            <td><p style="margin-top:6px;">@item.remain_amount</p></td>
                                            <td><p style="margin-top:6px;">@item.cr</p></td>
                                            <td><p style="margin-top:6px;">@item.oldcrbalance</p></td>
                                            <td><p style="margin-top:6px;">@item.TotalBal</p></td>
                                            <td><p style="margin-top:6px;">@item.RechargeDate</p></td>

                                        </tr>
                                    }
                                </tbody>
                                <tfoot style="background-color:whitesmoke;">
                                    <tr>
                                        <td>Total</td>
                                        <td>@Model.Sum(m => m.Balance)</td>
                                        <td></td>
                                        <td>@Model.Sum(m => m.remain_pre_amount)</td>
                                        <td>@Model.Sum(m => m.remain_amount)</td>
                                        <td>@Model.Sum(m => m.cr)</td>
                                        <td>@Model.Sum(m => m.oldcrbalance)</td>
                                        <td>@Model.Sum(m => m.TotalBal)</td>
                                        <td></td>

                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />

<script>

    $(document).ready(function()
    {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
    });
</script>

<script>
    $(document).ready(function () {
        $('#example').DataTable({
            dom: 'Bfrtip',
            buttons: [
                'copyHtml5',
                'excelHtml5',
                'csvHtml5',
                'pdfHtml5',
                'print'
            ]
        });
    });
</script>
