@model Vastwebmulti.Areas.RETAILER.Models.BankInfo


@*@Model Vastwebmulti.Areas.Retailer.Model.BankInfo*@
@{
    ViewBag.Title = "Bank_info";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
}
<style>
    /* new css  */

    .layoutt-retailer section.content {
        margin-top: 95px;
        padding-top: 5px;
    }

    .bread-same-all-page li {
        margin: 6px 0;
    }

    .table {
        margin-bottom: 0px;
    }

    .bread-same-all-page {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    @@media only screen and (max-width:1169px) {
        .bank-info-fullclass {
            padding-left: 15px !important;
        }
    }

    @@media only screen and (max-width:991px) {

        .col-md-6.brachcashreport, .col-md-6.atmcashreport {
            padding-right: 0px;
        }

    }

    @@media only screen and (max-width:767px) {
        .col-md-12.responsive-scroll th, .col-md-12.responsive-scroll td {
            font-size: 14px !important;
        }
    }

    @@media only screen and (max-width:480px) {
        
    }

    /* new css  */
</style>

<section class="content content-responshiveclass content-fourdesign-page allpage-four-design-section" style="overflow-x:hidden;">
