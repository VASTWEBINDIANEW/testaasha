@model Vastwebmulti.Models.Retailer_Details
@{
    ViewBag.Title = "Ekyc_Verification";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
}
<style>
    input#aadharno {
        width: 42%;
        border: 1px solid #ccc;
        color: #000;
        margin-top: 10px;
        margin-left: 14.7rem;
        background-color: #ddd;
    }

    input#sendOtp {
        border: 1px solid #ccc;
        background-color: #fff !important;
        height: 34px;
        margin-left: 30rem;
        margin-top: -3.4rem;
        width: 105px;
        background-color: #ddd;
    }

    small#aadhar_error {
        position: absolute;
        left: 13.5rem;
        padding-top: 35px;
    }

    input#aadharOtp {
        width: 57.4%;
        border: 1px solid #674522;
        color: #000;
        margin-top: 10px;
        margin-left: 14.9rem;
        margin-bottom: 10px;
        background-color: #ddd;
        border-radius: 5px;
    }

    input#verifyOtp {
        background: green !important;
        border: 0.5px solid #674522;
        width: 24%;
    }

    input#back {
        border: 1px solid #ccc;
        height: 34px;
        margin-left: 9px;
        background-color: #ddd !important;
        width: 70px;
        margin-right: 5px;
    }

    input#resendOtp {
        border: 1px solid #ccc;
        background-color: #ddd;
        height: 34px;
        width: 20%;
        background-color: #ddd;
    }

    input#panno {
        width: 29%;
        border: 1px solid #ccc;
        /* background-color: #fff !important; */
        height: 34px;
        margin-top: 1.5rem;
        margin-left: 19.2rem;
        background-color: #ddd !important;
    }

    input#pan_verification {
        border: 1px solid #4f3214;
        background-color: #fff !important;
        height: 34px;
        margin-left: 20.5rem;
        margin-top: -3.4rem;
        width: 112px;
        background-color: green !important;
    }

    small#pan_error {
        position: absolute;
        left: 17.8rem;
    }

    .aadhar_center {
        width: 100%;
        float: left;
        max-width: 50%;
        position: relative;
        border: 2px solid #ddd;
        text-align: center;
        height: 300px;
        margin: auto;
        top: 50%;
        left: 50%;
        transform: translate(-50%, 50%);
        background: var(--main-bg-lcolor) !important;
    }

        .aadhar_center:hover {
            box-shadow: rgba(0, 0, 0, 0.50) 0px 3px 8px;
            cursor: pointer;
            border-radius: 0px 50px 0px 50px;
        }

    .border_1 {
        width: 100%;
        text-align: center;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    hr.aadhar_ver {
        width: 409px;
        border: solid #ccc 1px;
        margin: auto;
        margin-bottom: 18px;
    }

    .pan_ver {
        width: 326px;
        border: solid #ccc 1px;
        margin: auto;
        margin-bottom: 18px;
    }
</style>



<section class="content" style="margin:90px 0px 0px 0px;">
    <div class="aadhar_center" id="aadhar_container">
        <div class="border_1">
            <div class="">
                <div class="row">
                    <h3 style="word-spacing: 5px; letter-spacing: 1px; font-size: 36px; text-transform: uppercase;">Aadhar Verification</h3>
                    <hr class="aadhar_ver" />
                    <small style="font-size: 20px; text-transform: capitalize; word-spacing: 3px;">Your aadhar is not verified. Please verifiy it.</small>

                    <div class="for-border-effect">
                        <input type="text" name="Aadhar" id="aadharno" value="@ViewBag.aadhar" class="form-control" placeholder="Aadhar" maxlength="12" />
                        <input type="text" name="OTP" id="aadharOtp" value="" class="form-control hidden" placeholder="Otp" />
                        <small id="aadhar_error" style="color: rgb(255, 0, 0);"></small>
                    </div>

                    <div class="for-border-effect" style="display: flex; align-items: center; justify-content: center;" id="sendOtpContainer">
                        <input id="sendOtp" type="button" value="Send OTP" class="" style="padding: 4px 6px; font-size:14px; background: #ccc;">
                        @if (ViewBag.pan_status == false && ViewBag.type == "pan")
                        {
                            <input id="skip_aadhar" type="button" value="Skip" class="" style="padding: 4px 6px; font-size:14px; background: #ccc;">
                        }
                    </div>
                    <div class="hidden" id="verifyOtpContainer">
                        <input id="verifyOtp" type="button" value="Verify Otp" class="" style="padding: 4px 6px; font-size:16px; background: #ccc;">
                        <input id="back" type="button" value="Back" class="" style="padding: 4px 6px; font-size:16px; background: #ccc;">
                        <input id="resendOtp" type="button" value="Resend" class="" style="padding: 4px 6px; font-size:16px; background: #ccc; margin-left: 3px;">
                    </div>
                </div>
            </div>

        </div>
    </div>
    <div class="aadhar_center" id="pan_container" style="display: none;">
        <div class="border_1">
            <div class="">
                <div class="row">
                    <h3 style="letter-spacing: 1px; font-size: 36px; text-transform: uppercase;">Pan Verification</h3>
                    <hr class="pan_ver" />
                    <small style="font-size: 18px; text-transform: capitalize; ">Your pan is not verified. Please verifiy it.</small>
                    <div class="for-border-effect">
                        <input type="text" name="Pan" id="panno" value="@ViewBag.pan" class="form-control" placeholder="Pan" maxlength="10" />
                        <small id="pan_error" style="color: rgb(255, 0, 0);"></small>
                    </div>
                    <div class="for-border-effect" style="display: flex; align-items: center; justify-content: center;">
                        <input id="pan_verification" type="button" value="Verify" class="" style="padding: 4px 6px; font-size:16px; background: #ccc;">
                    </div>
                    @if (ViewBag.aadhar_status == false && ViewBag.type == "pan")
                    {
                        <input id="backto_aadhar" type="button" value="Back To Aadhar" class="" style="padding: 4px 6px; font-size:14px; background: #ccc;">
                    }
                    @if (ViewBag.type == "aadhar")
                    {
                        <input id="skip_pan" type="button" value="Skip" class="" style="padding: 4px 6px; font-size:14px; background: #ccc;">
                    }
                </div>
            </div>
        </div>
    </div>
</section>


<script>
    $(function () {
        var clientId;
        var txnid;
        var aadhar;
        var loading = false;

        var v_type = '@ViewBag.aadhar_status';

        if (v_type == 'True') {
            $('#aadhar_container').hide();
            $('#pan_container').show();
        }

        if (document.getElementById('aadharno'))
            '@ViewBag.aadhar' && document.getElementById('aadharno').setAttribute('disabled', 'disabled');
        else if (document.getElementById('panno'))
            '@ViewBag.pan' && document.getElementById('panno').setAttribute('disabled', 'disabled');

        $('#back').click(() => {
            $('#aadhar_error').text('');
            clientId = null;
            txnid = null;
            aadhar = null;
            toggleHidden_aadhar();
        });

        $('#sendOtp').click(() => {
            debugger
            if (loading) return;
            $('#aadhar_error').text('');

            var aadhar_val = '@Model.AadharCard';
            var query = '?aadhar=';

            if (aadhar_val) {
                query = query + aadhar_val;
            }
            else {
                if ($('#aadharno').val().length != 12) {
                    return $('#aadhar_error').text('Invalid Aadhar Number');
                }
                query = query + $('#aadharno').val();
            }

            loading = true;
            $.ajax({
                url: '@Url.Action("AadharVerificationOtpSent")' + query,
                method: 'GET',
                success: (data) => {
                    data = JSON.parse(data);
                    const { Status, Message } = data;
                    loading = false;
                    if (Status) {
                        clientId = data.clientId;
                        txnid = data.txnid;
                        aadhar = data.aadhar;

                        toggleHidden_aadhar();
                    }
                    else {
                        $('#aadhar_error').text(Message);
                    }
                }
            })
        })

        $('#resendOtp').click(() => {
            if (loading) return;
            debugger;

            $('#aadhar_error').text('');

            var aadhar_val = '@Model.AadharCard';
            var query = '?aadhar=';

            if (aadhar_val) {
                query = query + aadhar_val;
            }
            else {
                if ($('#aadharno').val().length != 12) {
                    return $('#aadhar_error').text('Invalid Aadhar Number');
                }
                query = query + $('#aadharno').val();
            }

            loading = true;
            $.ajax({
                url: '@Url.Action("AadharVerificationOtpSent")' + query,
                method: 'GET',
                success: (data) => {
                    data = JSON.parse(data);
                    const { Status, Message } = data;
                    loading = false;
                    if (Status) {
                        clientId = data.clientId;
                        txnid = data.txnid;
                        aadhar = data.aadhar;
                    }
                    else {
                        $('#aadhar_error').text(Message);
                    }
                }
            })
        })


        $('#verifyOtp').click(() => {
            if (loading) return;

            $('#aadhar_error').text('');
            var otp = $('#aadharOtp').val();
            if (!otp) {
                $('#aadhar_error').text('Please Enter otp');
                return;
            }
            loading = true;
            $.ajax({
                url: '@Url.Action("AadharVerificationOtpVerify")?client_id=' + clientId + '&otp=' + otp + '&txnid=' + txnid + '&aadhar=' + aadhar,
                method: 'GET',
                success: (data) => {
                    data = JSON.parse(data);
                    const { Status, Message } = data;
                    loading = false;
                    if (Status) {
                        clientId = null;
                        txnid = null;
                        //window.location.href = '@Url.Action("/")';
                        toggleHidden_aadhar();
                        $('#aadhar_container').hide();
                        $('#pan_container').show();
                    }
                    else {
                        $('#aadhar_error').text(Message);
                    }
                }
            })

        })

        $('#pan_verification').click(() => {
            if (loading) return;
            debugger

            $('#pan_error').text('');

            var pan_val = '@Model.PanCard';
            //var query = '?pan=';
            var query = {};

            if (pan_val) {
                //query = query + pan_val;
                query.pan = pan_val;

            }
            else {
                if ($('#panno').val().length != 10) {
                    return $('#pan_error').text('Invalid Pan Number');
                }
                //query = query + $('#panno').val();
                query.pan = $('#panno').val();
            }
            query.userid = '@Model.RetailerId'
            loading = true;

            fetch('@Url.Action("PanVerification")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(query)
            })
                .then(res => res.text())
                .then(data => {
                    debugger
                    data = JSON.parse(data);
                    const { Status, Message } = data;
                    loading = false;
                    if (Status) {
                        alert('pan verification success');
                        window.location.href = '@Url.Action("/")';
                    }
                    else {
                        $('#pan_error').text(Message);
                    }
                })
                .catch(err => {
                    debugger;
                })
            @*$.ajax({
                url: '@Url.Action("PanVerification")' + query,
                method: 'POST',
                contentType: 'application/json',
                //data: query,
                success: (data) => {
                    debugger
                    data = JSON.parse(data);
                    const { Status, Message } = data;
                    loading = false;
                    if (Status) {
                        alert('pan verification success');
                        window.location.href = '@Url.Action("/")';
                    }
                    else {
                        $('#pan_error').text(Message);
                    }
                }
            })*@
        })

        function toggleHidden_aadhar() {
            $('#aadharOtp').toggleClass('hidden');
            $('#aadharno').toggleClass('hidden');

            $('#sendOtpContainer').toggleClass('hidden');
            $('#verifyOtpContainer').toggleClass('hidden');
        }

        $('#skip_aadhar').click(() => {
            $('#aadhar_container').hide();
            $('#pan_container').show();
        })

        $('#backto_aadhar').click(() => {
            $('#aadhar_container').show();
            $('#pan_container').hide();
        })

        $('#skip_pan').click(() => {
            window.location.href = '@Url.Action("/")';
        })

    })

</script>

