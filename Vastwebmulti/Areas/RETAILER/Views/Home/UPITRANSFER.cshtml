<script>
    $(function () {
        var cchhh = '@ViewData["upi_msg"]';
        if (cchhh != null) {
            $('#msgg').text(cchhh);
            setTimeout(() => {
                document.getElementById('msgg').style.display = "none";
            }, 4000)
        }

         var cchhhcollect = '@TempData["UPICollect"]';
        if (cchhhcollect != '') {


            if (`@TempData["GetUniqueid"]` != '') {
                let xx = setInterval(() => {
                    document.getElementById('upispinner22').style.display='block'
                })
                setTimeout(() => {
                    clearInterval(xx);
                    document.getElementById('upispinner22').style.display = 'none'
                },4000)


                let deadline = new Date().getTime() + 482000;
                let x = setInterval(() => {


                    let requestUrlResp = '@TempData["GetUniqueid"]'
                    $.ajax({
                        url: '@Url.Action("UPIAUTOSERVICE", "Home")',
                        data: { generatedid: requestUrlResp },
                        cache: false,
                        type: "POST",
                        success: function (data) {
                            var status = data.status;
                            var upists = data.upists;
                            var refid = data.refid;
                            var amount = data.amount;


                            let y = setInterval(() => {
                                let now = new Date().getTime();
                                let t = deadline - now;
                                let seconds = Math.floor((t % (1000 * 482)) / 1000);
                                document.getElementById("contentshowhide").style.display = "none";
                                document.getElementById("gobackshow").style.display = "block";
                                document.getElementById("msggcollect").innerHTML = "Please wait for " + seconds + " seconds to get the payment request response";
                                if ((status == "SUCCESS")) {
                                    clearInterval(y);
                                    clearInterval(x);

                                    document.getElementById("msggcollect").style.display = "none";
                                    document.getElementById('hidemsg1212').style.display = 'none'
                                    if (upists == "FAILED" || upists == "Failed") {

                                        document.getElementById('MessageShoHidecollect').style.cssText = `display: block; color: red;`;
                                    }
                                    else {
                                        document.getElementById('MessageShoHidecollect').style.cssText = `display: block; color: green;`;

                                    }
                                    document.getElementById('MessageShoHidecollect').innerHTML = `STATUS: ${upists} <br> BANKRR NO : ${refid} <br> AMOUNT : ${amount} `;
                                    setTimeout(() => {
                                        document.getElementById('MessageShoHidecollect').innerHTML = 'Plese go back your trangection has complete successfully.';
                                    }, 20000)
                                }
                                else if (status == "FAILED") {

                                    if (seconds <= 0) {
                                        clearInterval(y);
                                        clearInterval(x);
                                        document.getElementById("msggcollect").style.display = "none";
                                        document.getElementById('hidemsg1212').style.display = 'none'
                                        document.getElementById('MessageShoHidecollect').style.cssText = `display: block; color: red;`;
                                        document.getElementById('MessageShoHidecollect').innerHTML = "No Response Found Please Go Back";
                                    }
                                }
                            }, 1000)
                            function oncliktoremovetext() {
                                document.getElementById("countDownShow").style.display = "none";
                            }

                        }
                    })

                }, 3000)
            }
        }

        var current = location.pathname;
        $('.report-list-change li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('active');


            }
        })
    });
</script>

