<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.8/js/select2.min.js" defer></script>
<script>
    $(document).ready(function () {
        var month = '@ViewBag.chkmonth';
         var val = '@ViewBag.chk';
        if (val != "post") {
            $('#Month').val(month);
            $('#Month').select2().trigger('change');
            $('#Year').select2();
        }
    });
</script>

<script>
    function Download(apiid) {
        var Month = $('#Month').val();
        var Year = $('#Year').val();
            var url = '@Url.Action("Print_Sell_Gst_retailer", "Home")?Month=' + Month + '&Year=' + Year + '';
            window.open(url, '_blank');
    }
</script>
