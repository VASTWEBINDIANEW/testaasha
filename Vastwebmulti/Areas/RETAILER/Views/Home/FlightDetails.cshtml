<script>

    function onPluseMinus(check, v) {
        var adltCount = parseInt($('#txtAdultCount').val());
        var childCount = parseInt($('#txtChildCount').val());
        var infCount = parseInt($('#txtInfantCount').val());
        var allCount = parseInt($('#txtPassengerCount').val());
        if (check == 'Adult') {

            $('#txtAdultCount').val(adltCount + v);
            $('#txtPassengerCount').val(allCount + v);
            $('#showPassengerCount').html(allCount + v);
            $('#showAdultCount').html(adltCount + v);
            if (parseInt($('#txtAdultCount').val()) > 1) {
                $('#btnAdultMinus').prop('disabled', false);
            } else {
                $('#btnAdultMinus').prop('disabled', true);
            }
        }
        else if (check == 'child') {

            $('#txtChildCount').val(childCount + v);
            $('#txtPassengerCount').val(allCount + v);
            $('#showPassengerCount').html(allCount + v);
            alert(parseInt($('#txtChildCount').val()));
            $('#showChildCount').html(childCount + v);
            if (parseInt($('#txtChildCount').val()) > 0) {
                $('#btnChildMinus').prop('disabled', false);
            } else {
                $('#btnChildMinus').prop('disabled', true);
            }
        }
        if (check == 'infant') {

            $('#txtInfantCount').val(infCount + v);
            $('#txtPassengerCount').val(allCount + v);
            $('#showPassengerCount').html(allCount + v);
            $('#showInfantCount').html(infCount + v);
            if (parseInt($('#txtInfantCount').val()) > 0) {
                $('#btnInfantMinus').prop('disabled', false);
            } else {
                $('#btnInfantMinus').prop('disabled', true);
            }
        }
    }

