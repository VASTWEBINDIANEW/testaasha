                                                            </div>
                                                            <div class="col-md-3" style="text-align:right;padding-right:0px;">

                                                                <div class="demo-google-material-icon" style="text-align:center;">
                                                                    ------------<i class="material-icons">flight_takeoff</i>------------
                                                                </div>
                                                                Baggage(@item.Baggage + @item.CabinBaggage) KG

                                                            </div>
                                                            <div class="col-md-3" style="padding-right:0px;">
                                                                <strong>@Convert.ToDateTime(item.Destination.ArrTime).ToString("HH:mm")</strong> <br />
                                                                <Bold>@Convert.ToDateTime(item.Destination.ArrTime).ToString("ddd, dd MMM yyyy")</Bold> <br />
                                                                @item.Destination.Airport.CityName (@item.Destination.Airport.AirportCode)<br />
                                                                @item.Destination.Airport.AirportName (Terminal : @item.Destination.Airport.Terminal)
                                                            </div>
                                                            <div class="col-md-2">
                                                                @{
                                                                    TimeSpan spWorkMin = TimeSpan.FromMinutes(item.Duration);
                                                                }
                                                                @string.Format("{0:00}:{1:00}", (int)spWorkMin.TotalHours, spWorkMin.Minutes) approax
                                                            </div>

                                                            @*<div class="col-md-2">
                                                                    <button class="btn btn-primary bg-dark-green">Book Now</button>
                                                                </div>*@
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }
                <!-- #END# Flight Details start -->
