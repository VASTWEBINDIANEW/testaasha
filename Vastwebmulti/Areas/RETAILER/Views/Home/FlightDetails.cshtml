@model Vastwebmulti.Areas.RETAILER.ViewModels.FlightDetailsVM
@{
    ViewBag.Title = "Travel";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
    decimal markup = ViewBag.RetailerMarkup;
}
<style>
    .scrollypy {
        overflow-y: auto !important;
        height: 250px;
    }

    .btmPlusMinus {
        padding: 3px 6px;
        margin-right: 4px;
        padding-bottom: 6px;
        border-radius: 5px;
    }

        .btmPlusMinus i {
            font-size: 10px;
        }

    .table {
        display: table; /* Allow the centering to work */
        margin: 0 auto;
    }

    ul#horizontal-list {
        min-width: 696px;
        list-style: none;
        padding-top: 20px;
    }

        ul#horizontal-list li {
            display: inline;
            text-align: center;
            padding: 20px;
        }

    span.field-validation-error {
        font-size: 12px;
        display: block;
        margin-top: 5px;
        font-weight: normal;
        color: #F44336;
    }

    .vertical-text {
        /*transform: rotate(90deg);
    transform-origin: left top 0;
    float:left;
    position:absolute;*/
        transform: rotate(-90deg);
        -ms-transform: rotate(-90deg);
        -webkit-transform: rotate(-90deg);
        bottom: 0%;
        top: 125%;
        right: 93%;
        position: absolute;
        color: #ed217c;
    }
</style>
<link rel="stylesheet" href="http://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
<link rel="stylesheet" href="http://netdna.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
<link href="~/AdminDesign/Retailer_Slider/Slieder.css" rel="stylesheet" />
@*@Html.Partial("_FareQuote",Model.FareQuoteVM)*@
<section class="content" style="margin-left: 10px;margin-right: 10px;">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-9">
                <!-- Flight Details start -->
                <div class="block-header" style="padding: 12px 0 22px 1px;margin-bottom: 20px;">
                    @*<h2>NO HEADER CARDS</h2>*@
                    <div class="col-md-6 pull-left">
                        <h2>Review Flight</h2>
                    </div>
                    <div class="col-md-6" style="text-align:right;">
                        @*<button type="button" class="btn bg-purple waves-effect pull-right">
                                <i class="material-icons">search</i>
                                <span>Modify Search</span>
                            </button>*@
                        <a src="javascript:void(0)">change Flight</a>
                    </div>
                </div>

                <div class="row">

                    @if (Model.Onward.FareQuoteVM != null)
                    {
                        int SegmentsIndex = 0;
                        foreach (var item in Model.Onward.FareQuoteVM.Content.Addinfo.Results.Segments)
                        {

                            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                <div class="card">

                                    <div class="body bg-white">
                                        <div class="table">
                                            @foreach (var sgmtItem in item)
                                            {
                                                <div class="row clearfix">
                                                    <div class="col-md-3" style="padding-right:0px;padding-left:0px;">
                                                        @if (SegmentsIndex == 0)
                                                        {
                                                            <strong class="vertical-text">DEPARTURE</strong>
                                                        }
                                                        else
                                                        {
                                                            <strong class="vertical-text">RETURN&nbsp;&nbsp;</strong>
                                                        }

                                                        <div class="media" style="margin:0px;">
                                                            <div class="media-left">
                                                                <a href="javascript:void(0);">
                                                                    @if (sgmtItem.Airline.AirlineCode == "AI")
                                                                    {
                                                                        <img class="media-object" src="https://logo.clearbit.com/www.airindia.com?size=64" width="64" height="64">
                                                                    }
                                                                    else if (sgmtItem.Airline.AirlineCode == "6E")
                                                                    {
                                                                        <img class="media-object" src="https://logo.clearbit.com/www.goindigo.in?size=32" width="32" height="32">
                                                                    }
                                                                    else if (sgmtItem.Airline.AirlineCode == "SG")
                                                                    {
                                                                        <img class="media-object" src="https://logo.clearbit.com/www.spicejet.com/?size=32" width="32" height="32">
                                                                    }
                                                                    else if (sgmtItem.Airline.AirlineCode == "9W")
                                                                    {
                                                                        <img class="media-object" src="https://logo.clearbit.com/www.jetairways.com?size=32" width="32" height="32">
                                                                    }
                                                                    else if (sgmtItem.Airline.AirlineCode == "9W")
                                                                    {
                                                                        <img class="media-object" src="https://logo.clearbit.com/www.jetairways.com?size=32" width="32" height="32">
                                                                    }
                                                                    else if (sgmtItem.Airline.AirlineCode == "UK")
                                                                    {
                                                                        <img class="media-object" src="https://logo.clearbit.com/www.airvistara.com?size=32" width="32" height="32">
                                                                    }
                                                                    else
                                                                    {
                                                                        <img class="media-object" src="http://placehold.it/32x32" width="32" height="32">
                                                                    }

                                                                </a><br />
                                                            </div>
                                                            <div class="media-body" style="text-align:left;">
                                                                <h4 class="media-heading">@sgmtItem.Airline.AirlineName</h4>
                                                                @sgmtItem.Airline.AirlineCode - @sgmtItem.Airline.FlightNumber
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="timeDiv col-md-9" style="padding-right:0px;padding-left:0px;">
                                                        <div class="row">
                                                            <div class="col-md-3" style="padding-left:0px;padding-right:0px;">
                                                                <strong>@sgmtItem.StopPointDepartureTime.ToString("HH:mm")</strong> <br />
                                                                <Bold>@sgmtItem.StopPointDepartureTime.ToString("ddd, dd MMM yyyy")</Bold> <br />
                                                                @sgmtItem.Origin.Airport.CityName (@sgmtItem.Origin.Airport.AirportCode) <br />
                                                                @sgmtItem.Origin.Airport.AirportName (Terminal : @sgmtItem.Origin.Airport.Terminal)
                                                            </div>
                                                            <div class="col-md-3" style="text-align:right;padding-right:0px;">

                                                                <div class="demo-google-material-icon" style="text-align:center;">
                                                                    ------------<i class="material-icons">flight_takeoff</i>------------
                                                                </div>
                                                                Baggage(@sgmtItem.Baggage + @sgmtItem.CabinBaggage) KG

                                                            </div>
                                                            <div class="col-md-3" style="padding-right:0px;">
                                                                <strong>@Convert.ToDateTime(sgmtItem.Destination.ArrTime).ToString("HH:mm")</strong> <br />
                                                                <Bold>@Convert.ToDateTime(sgmtItem.Destination.ArrTime).ToString("ddd, dd MMM yyyy")</Bold> <br />
                                                                @sgmtItem.Destination.Airport.CityName (@sgmtItem.Destination.Airport.AirportCode)<br />
                                                                @sgmtItem.Destination.Airport.AirportName (Terminal : @sgmtItem.Destination.Airport.Terminal)
                                                            </div>
                                                            <div class="col-md-2">
                                                                @{
                                                                    TimeSpan spWorkMin = TimeSpan.FromMinutes(sgmtItem.Duration);
                                                                }
                                                                @string.Format("{0:00}:{1:00}", (int)spWorkMin.TotalHours, spWorkMin.Minutes) approax
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                </div>
                            </div>

                            SegmentsIndex++;
                        }
                    }
                </div>
