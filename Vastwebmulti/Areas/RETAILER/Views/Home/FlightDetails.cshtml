                <!-- Passanger Details End-->
                <!-- Fare rule -->
                <div class="block-header" style="padding: 12px 0 22px 1px;margin-bottom: 20px;">
                    @*<h2>NO HEADER CARDS</h2>*@
                    <div class="col-md-6 pull-left">
                        <h2>Fare Rule</h2>
                    </div>

                </div>
                <div class="row">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                        <div class="card">
                            <div class="body bg-white slimScrollDiv">

                                @*@foreach (var item in Model.Onward.FareRuleVM.Content.Addinfo.FareRules)*@
                                @if (ViewBag.FareRuleOB != null)
                                {
                                    var OBFareRule = (Vastwebmulti.Areas.RETAILER.ViewModels.FareRuleVM)ViewBag.FareRuleOB;
                                    foreach (var item in OBFareRule.Content.Addinfo.FareRules)
                                    {

                                        <strong>@item.Origin - @item.Destination</strong><br />
                                        string[] stringSeparators = new string[] { "\r\n" };
                                        string[] lines = item.FareRuleDetail.Split(stringSeparators, StringSplitOptions.None);
                                        //Console.WriteLine("Nr. Of items in list: " + lines.Length); // 2 lines
                                        foreach (string s in lines)
                                        {
                                            //Console.WriteLine(s); //But will print 3 lines in total.
                                            @Html.Raw(s)<br />
                                        }

                                    }
                                }


                            </div>
                        </div>
                    </div>
                </div>

                @if (Model.isDomastic && Model.JourneyType == 2)
                {
                    <div class="row">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                            <div class="card">
                                <div class="body bg-white slimScrollDiv">

                                    @*@foreach (var item in Model.Inward.FareRuleVM.Content.Addinfo.FareRules)*@
                                    @if (ViewBag.FareRuleIB != null)
                                    {
                                        var IBFareRule = (Vastwebmulti.Areas.RETAILER.ViewModels.FareRuleVM)ViewBag.FareRuleIB;
                                        foreach (var item in IBFareRule.Content.Addinfo.FareRules)
                                        {
                                            <strong>@item.Origin - @item.Destination</strong><br />
                                            string[] stringSeparators = new string[] { "\r\n" };
                                            string[] lines = item.FareRuleDetail.Split(stringSeparators, StringSplitOptions.None);
                                            //Console.WriteLine("Nr. Of items in list: " + lines.Length); // 2 lines
                                            foreach (string s in lines)
                                            {
                                                //Console.WriteLine(s); //But will print 3 lines in total.
                                                @Html.Raw(s)<br />
                                            }

                                        }
                                    }

                                </div>
                            </div>
                        </div>
                    </div>
                }
                <!-- #END# Fare rule -->
            </div>
            <!-- Fare Details -->
            <div class="col-md-3">
                <div class="row">
                    <div class="block-header" style="padding: 12px 0 22px 1px;margin-bottom: 4px;">
                        <h2>Fare Details</h2>
                    </div>
                    <div class="row">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                            <div class="card">
                                <div class="body bg-white">
                                    @{
                                        var of = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.OfferedFare;
                                        var pf = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.PublishedFare;
                                        var bf = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.BaseFare;
                                        var tax = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.Tax;
                                        var TxnFee = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.AdditionalTxnFeeOfrd;
                                        if (Model.isDomastic && Model.JourneyType == 2)
                                        {
                                            of = of + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.OfferedFare;
                                            pf = of + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.PublishedFare;
                                            bf = bf + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.BaseFare;
                                            tax = tax + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.Tax;
                                            TxnFee = TxnFee + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.AdditionalTxnFeeOfrd;
                                        }

                                        var otherCharge = pf - (bf + tax + TxnFee);
                                        TxnFee = TxnFee + markup;
                                        pf = pf + markup;
                                    }
                                    <div>
                                        Base Fare <span class="pull-right">@bf</span><br>
                                        Fuel & Tax <span class="pull-right">@tax</span><br>
                                        Other Charges <span class="pull-right">@otherCharge</span><br>
                                        Txn Fee <span class="pull-right">@TxnFee</span><br>
                                        <strong>Total Fare <span class="pull-right" id="totalPubFare">@pf</span></strong>
                                        <br>
                                        @*<span>
                                                <i class="fa fa-eye fa-2x" onclick="getOfferFare('@of')"></i>
                                            </span>*@
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>


            </div>
            <!-- #END# Fare Details -->

        </div>

    </div>
    <!--Slider div-->
    <br />
</section>

