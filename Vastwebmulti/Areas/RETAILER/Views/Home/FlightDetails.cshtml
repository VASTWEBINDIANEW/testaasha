                                                                <div class="media-body" style="text-align:left;">
                                                                    <h4 class="media-heading">@item.Airline.AirlineName</h4>
                                                                    @item.Airline.AirlineCode - @item.Airline.FlightNumber
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="timeDiv col-md-9" style="padding-right:0px;padding-left:0px;">
                                                            <div class="col-md-3" style="padding-left:0px;padding-right:0px;">
                                                                <strong>@item.StopPointDepartureTime.ToString("HH:mm")</strong> <br />
                                                                <Bold>@item.StopPointDepartureTime.ToString("ddd, dd MMM yyyy")</Bold> <br />
