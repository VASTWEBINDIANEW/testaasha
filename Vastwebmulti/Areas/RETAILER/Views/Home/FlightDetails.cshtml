                                                                        {
                                                                            <img class="media-object" src="https://logo.clearbit.com/www.goindigo.in?size=64" width="64" height="64">
                                                                        }
                                                                        else if (item.Airline.AirlineCode == "SG")
                                                                        {
                                                                            <img class="media-object" src="https://logo.clearbit.com/www.spicejet.com/?size=64" width="64" height="64">
                                                                        }
                                                                        else if (item.Airline.AirlineCode == "9W")
                                                                        {
                                                                            <img class="media-object" src="https://logo.clearbit.com/www.jetairways.com?size=64" width="64" height="64">
                                                                        }
                                                                        else if (item.Airline.AirlineCode == "9W")
                                                                        {
                                                                            <img class="media-object" src="https://logo.clearbit.com/www.jetairways.com?size=64" width="64" height="64">
                                                                        }
                                                                        else if (item.Airline.AirlineCode == "UK")
                                                                        {
                                                                            <img class="media-object" src="https://logo.clearbit.com/www.airvistara.com?size=64" width="64" height="64">
                                                                        }
                                                                        else
