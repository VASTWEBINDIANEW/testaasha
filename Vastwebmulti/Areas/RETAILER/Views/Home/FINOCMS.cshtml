    </div>
    <!--Change-New-->
    <div class="col-md-8 money-transform-content money-transform-responshive oveflow-four-css">

        <div class="page-header-third" style="float: left; width: 100%; margin-top: 2px;">
            <div style="margin-bottom: 5px; float: left; width: 100%;">
                <form>
                    <div style="display: flex; justify-content: center; align-items: center;padding:0;" class="col-md-12">
                        @*@Html.TextBox("status", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;height:32px;", autocomplete = "off", @placeholder = "Enter Status" })*@
                        <select name="status" class="form-control" id="status">
                            <option value="">Status</option>
                            <option value="Success">Success</option>
                            <option value="Failed">Failed</option>
                            <option value="Pending">Pending</option>
                        </select>
                        @Html.TextBox("number", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;", autocomplete = "off", @placeholder = "Enter Mobile" })
                        <div class="input-daterange input-group" style="display: flex;">
                            <div class="datesate datesates focused">
                                <div class="form-iconmy" style="top: 0px;left: 1px;padding: 6px 5px;"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                @Html.TextBox("from_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; display: block", autocomplete = "off" })
                            </div>
                            @*<span class="input-group-addon" style="display:none;">
                                    <i class="fa fa-exchange" style="padding-top:8px;"></i>
                                </span>*@
                            <div class="datesate datesatese">
                                <div class="form-iconmy form-iconmyss" id="iconmyssee" style="top: 0px;left: 1px;padding: 6px 5px;"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                @Html.TextBox("to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; display: block", autocomplete = "off" })
                            </div>
                        </div>
                        <input type="button" name="submit" value="Search" id="search_report" class="btn" />
                    </div>
                </form>
            </div>
            <div id="reportallinone">
                @Html.Partial("_FinoCMSReport")
            </div>
        </div>

    </div>
</section>
<script>
    $('ul.tabsmy li').click(function () {
        var tab_id = $(this).attr('data-tab');

        $('ul.tabsmy li').removeClass('current');
        $('.tab-content').removeClass('current');

        $(this).addClass('current');
        $("#" + tab_id).addClass('current');
    });
</script>

<script>
    $(document).ready(() => {
    })


</script>

<script>

    function isNumeric(str) {
        if (typeof str != "string") return false // we only process strings!
        return !isNaN(str) && // use type coercion to parse the _entirety_ of the string (`parseFloat` alone does not do this)...
            !isNaN(parseFloat(str)) // ...and ensure strings of whitespace fail
    }
</script>

<script>
    $('#generate_url_btn').click(() => {
        $('#fino_error').text('')
        $.ajax({
            url: '@Url.Action("fino_generate_url", "Home")',
            cache: false,
            type: "GET",
            cache: false,
            dataType: "html",
            success: function (data) {
                data = JSON.parse(data);
                if (data.status) {
                    window.open(data.url, "_blank")
                    return;
                }
                $('#fino_error').text(data.message);
            }
        })
    });

    $('#search_report').click(() => {
        var status = $('#status').val() || '';
        var number = $('#number').val() || '';
        var from = $('#from_date').val();
        var to = $('#to_date').val();
        $.ajax({
            url: '@Url.Action("fino_cms_report", "Home")?status=' + status + '&number=' + number + '&from=' + from + '&to=' + to,
            cache: false,
            type: "GET",
            cache: false,
            dataType: "html",
            success: function (data) {
                $('#reportallinone').html(data);
            }
        })
    });
</script>

<script type="text/javascript">
    $(document).ready(function () {

        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",
        });

        $("#from_date").datepicker("setDate", new Date());
        $("#to_date").datepicker("setDate", new Date());

    });


</script>



