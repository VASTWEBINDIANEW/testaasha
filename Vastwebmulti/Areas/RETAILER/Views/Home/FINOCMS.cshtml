@{
    ViewBag.Title = "FINOCMS";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
}
<link href="~/CSS/bootstrap-combobox.css" rel="stylesheet" />
<link href="~/AdminDesign/css/sp.css" rel="stylesheet" />
<link href="~/AdminDesign/plugins/bootstrap-colorpicker/css/bootstrap-colorpicker.css" rel="stylesheet" />
<link href="~/MainFrontDesign/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/MainFrontDesign/select2/dist/js/select2.full.min.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/webcamjs/1.0.25/webcam.js"></script>
<style>
    /* new css */

    #reportallinone {
        overflow-y: auto;
    }

    .newpagecustomertyui .money-transform-content {
        overflow: inherit;
    }
    #fino_cms_table {
        padding: 0;
    }
        #fino_cms_table thead, #fino_cms_table tbody {
            display: table;
            width: 100%;
        }
    .tabspage {
        background: #fff;
    }
    #status {
        width: 25%;
        margin-right: 5px;
    }
    #number {
        width: 260px;
    }
    .input-daterange {
        width: 35%;
        margin: 0px 5px;
    }
    #search_report {
        height: 34px;
        padding: 6px 15px;
    }
    #reload h1 {
        position: relative !important;
        text-align: center;
    }


    /* new css  */

    .transaction ul li.transaction-left, .transaction ul li.transaction-right {
        height: 20px;
    }

    .loader::after {
        border-color: var(--main-bg-lcolor) !important;
        border-top-color: transparent !important;
    }

    .aadharpaysup {
        animation: blinks 2s linear infinite;
        font-size: 8px;
        top: -10px;
        left: -12px;
    }

    @@keyframes blinks {
        0% {
            color: yellow;
        }

        50% {
            color: red;
        }

        100% {
            color: orange;
        }
    }

    @@media screen and (max-width:1366px) {
        .newpagecustom.newpagecustomertyui ul li span.aeps-aadharclassdiv {
            left: 0px !important;
        }
    }
    @@media only screen and (max-width:1024px){

        .money-transform-content .col-md-12 {
            display: block !important;
        }
        #status {
            width: 49%;
            float: left;
            margin-bottom: 5px;
        }
        #number {
            width: 50%;
            float: left;
            margin-bottom: 5px;
        }
        .input-daterange {
            width: 100%;
            margin: 0;
        }

            .input-daterange .datesate {
                float: left;
                width: 50%;
                position: relative;
                margin-bottom: 5px;
            }
                .input-daterange .datesate #iconmyssee {
                    left: 0 !important;
                }

    }

    @@media only screen and (max-width:767px){

        #reload h1 {
            position: relative !important;
            margin-top: 0;
            text-align: center;
            font-size: 25px;
        }
        .navbar-header .bars {
            top: 6px !important;
        }
        .responcive {
            padding:0;
        }

    }


    @@media only screen and (max-width:600px){
        #status {
            width: 50%;
            margin-right: 0px;
        }
        
    }
    @@media only screen and (max-width:480px){
        #status{
            width:100%; 
        }
        #number {
            width: 100%;
        }
        .newpagecustom.newpagecustomertyui{
            padding-right:13px;
        }


    }



</style>
<section class="newpagecustom newpagecustomertyui newpagecustomertyui-second content-fourdesign-page allpage-four-design-section widthinherit-four">
