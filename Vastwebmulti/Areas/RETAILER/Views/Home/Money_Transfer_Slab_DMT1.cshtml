<script>
    $(window).load(function () {

        var viewportWidth = $(window).width();
        if (viewportWidth < 420) {
            $(".second-design .giftcardcategory-second-design").removeClass("giftcardcategory-second-design");

        }

        $(window).resize(function () {

            if (viewportWidth < 420) {
                $(".second-design .giftcardcategory-second-design").removeClass("giftcardcategory-second-design");
            }
        });

    });
</script>

<script>

