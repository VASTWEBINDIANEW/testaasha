<link href="~/MainFrontDesign/css/Dashcustom.css" rel="stylesheet" />
<style>


    /* new css  */
    .wallet_transfer #ul {
        display: flex;
        align-items: center;
        justify-content: space-around;
        padding: 14px 0;
    }

        .wallet_transfer #ul a {
            padding: 10px 14px;
            background: #ccc;
            color: #000;
            border-radius: 2px;
        }

    .layoutt-retailer section.content {
        margin-top: 95px;
        padding-top: 5px;
    }

    .bread-same-all-page li {
        margin: 6px 0 !important;
    }

    .table {
        margin-bottom: 0px;
    }

    .bread-same-all-page {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }



    /* new css  */

    .giftcardcategory ul li a span {
        font-size: 12px;
    }

    .giftcardcategory ul li a span, .giftcardcategory ul li.active a span {
        color: #fff !important;
    }

    .operator-clearfix table tr td span {
        color: #555;
    }

    .second-design .giftcardcategory ul li a span, .second-design .giftcardcategory ul li.active a span {
        color: #000 !important;
    }

    @@media only screen and (max-width:1169px) {
        .body.Gift_Carddbody {
            padding: 0;
        }

            .body.Gift_Carddbody .row {
                margin-left: 0;
                margin-right: 0;
            }
    }

    @@media screen and (max-width:992px) {
        .third-design .giftcardtab-thirddesign .giftul-third-block {
            display: block !important;
        }

        .third-design .giftcardtab-thirddesign .giftul-third {
            display: none !important;
        }
    }

    @@media only screen and (max-width:991px) {
    }

    @@media only screen and (max-width:767px) {
        #leftulbar li {
            width: 20% !important;
        }

        .operator-clearfix .giftcardcategory ul li.active a {
            margin-top: 0px;
        }

        .Gift_Carddbody .giftcardcategory ul li.active a {
            padding: 10px 2px;
        }

        .giftcardcategory-second ul {
            display: inline-block !important;
        }
    }

    @@media screen and (max-width:766px) {
    }


    @@media only screen and (max-width:480px) {
        #leftulbar li {
            width: 50% !important;
        }

        .bread-same-all-page {
            display: block;
        }

            .bread-same-all-page .col-md-6 {
                width: 100% !important;
            }
        /* lastest css  */

        .wallet_transfer #ul {
            display: block;
        }

            .wallet_transfer #ul li {
                width: 50%;
                float: left;
                padding: 5px;
            }

            .wallet_transfer #ul a {
                width: 100%;
                float: left;
                text-align: center;
            }

        .wallet_transfer {
            width: 100%;
            float: left;
        }

    }
</style>
