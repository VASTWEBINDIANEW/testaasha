@using Vastwebmulti.Models;
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>VeryFY_Profiles_users</title>
    <style>
        h2.pagetitle {
            text-align: center;
            width: 100%;
            float: left;
            color: #fff;
            text-transform: uppercase;
            font-weight: 500;
        }

        .formfullclsass input {
            width: 100%;
            border: 1px solid #555;
            height: 38px;
            padding: 0 10px;
            font-size: 14px;
        }

        .formfullclsass button {
            float: none;
            height: 40px;
            border: 1px solid #555;
            background:;
            background: var(--main-bg-lcolor);
            color: #fff;
            padding: 0 20px;
            font-weight: 400;
            margin-right: 2%;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 16px;
        }

        .formfullclsass {
            width: 100%;
            float: left;
            padding: 15px 0;
        }

        .allservice ul li {
            list-style: none;
            display: inline-block;
        }

        .allservice ul {
            width: 100%;
            float: left;
            display: flex;
        }

            .allservice ul li {
                color: #fff;
                font-weight: bold;
                background: var(--main-bg-rcolor);
                padding: 10px 0;
                width: 18%;
                margin-right: 6px;
                text-align: center;
            }

                .allservice ul li:last-child {
                    margin-right: 0px;
                }

                .allservice ul li.active span::before {
                    content: "";
                    display: inline-block;
                    width: 15px;
                    height: 15px;
                    background: #fff;
                    border-radius: 50%;
                    background: url(../../AdminDesign/images/checkprofile.svg) no-repeat;
                    background-color: #fff;
                    background-size: 12px;
                    background-position: center;
                    position: relative;
                    left: -5px;
                    top: 3px;
                }

        .digit-groupverfy {
            text-align: center;
            border: 2px solid #fff;
            padding: 7px 0px;
            display: flex;
        }

            .digit-groupverfy input {
                width: 24%;
                height: 50px;
                background-color: #fff;
                border: none;
                line-height: 50px;
                text-align: center;
                font-size: 30px;
                font-family: 'Raleway', sans-serif;
                font-weight: 600;
                color: #555;
                margin: 0 2px;
            }

        .formfullclsass span.otpoption {
            font-size: 18px;
            color: #fff;
            margin-bottom: 10px;
            display: block;
            text-transform: uppercase;
        }

        .formfullclsass {
            width: 100%;
            float: left;
            padding: 15px 0;
            background: #aca9a9;
            min-height: 400px;
            display: grid;
            justify-content: center;
            align-items: center;
        }

        .submitebutton {
            text-align: center;
            width: 100%;
            float: left;
            display: flex;
            justify-content: center;
        }

        h2.pagetitle {
            margin-top: 50px;
            margin-bottom: 70px;
        }

        input, .button {
            outline: none !important;
        }

        .submitebutton form {
            display: flex;
        }

        @@media screen and (max-width:480px) {
            .formfullclsass {
                display: inherit;
            }

                .formfullclsass .col-md-12 {
                    padding: 0;
                    width: 100%;
                    float: left;
                }

                    .formfullclsass .col-md-12 .col-md-6 {
                        margin-bottom: 15px;
                    }

            .submitebutton {
                display: inherit;
            }

                .submitebutton form {
                    display: inherit;
                }

                .submitebutton button {
                    margin-bottom: 10px;
                    width: 100%;
                    padding: 0;
                    margin-right: 0;
                }

            .submitebutton {
                padding: 0 15px;
            }

            h2.pagetitle {
                font-size: 22px;
                margin-bottom: 25px;
            }
        }
    </style>
    @{
        VastwebmultiEntities DB = new VastwebmultiEntities();
        var logoimage = "";
        var logo = DB.tblHeaderLogoes.Where(p => p.Role == "ADMIN").ToList();
        if (logo.Count > 0)
        {
            if (logo.SingleOrDefault().Role == "ADMIN")
            {
                logoimage = logo.Where(p => p.Role == "ADMIN").SingleOrDefault().LogoImage;
            }
        }
        else
        {
            logoimage = "images / Default_Logo.png";
        }
    }


</head>
<body>
    <div class="cintainer-fliud" style="background:linear-gradient(to right, var(--main-bg-lcolor), var(--main-bg-rcolor));height:100vh;">

        <div class="navbar-header asd-asd logoheight-second logoheight-third" style="padding:0px 0px;">
            <a href="javascript:void(0);" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar-collapse" aria-expanded="false"></a>
            <a href="javascript:void(0);" class="bars" style="display: none;"></a>
            <a href="@Url.Action("Dashboard", "Home")" class="logo-second-design">
                <center>
                        <img src="@Url.Content("~/" + @logoimage)" class="img-responsive" style="width:148px;padding:2px;">
                </center>
            </a>




        </div>

        @using (Html.BeginForm("LogOff", "Account", new { Area = "", id = "logoutForm" }))
        {
            @Html.AntiForgeryToken()
            <button type="submit" class="pull-right">
                <input type="submit" id="subHere" class="btn btn-default" value="LOGOUT" style="padding:0px; height:35px;color:#fff;border-color:#fff; margin-right:5px;position:absolute;top:0;right:20px;background: transparent;
                border-radius: 0;margin-top: 10px;padding: 4px 20px;border: 2px solid #fff;" />
            </button>
        }
        <h2 class="pagetitle">Verify User's Profile</h2>
        <div class="container">

            <div class="formfullclsass">
                <div class="col-md-12">
                    @if (ViewBag.mobilests == false)
                    {
                        <div class="col-md-6">
                            <span class="otpoption">Enter Your Mobile OTP</span>
                            <div class="digit-groupverfy">
                                <input type="text" id="digit-1" name="digit-1" data-next="digit-2" autocomplete="off" maxlength="1"><input type="text" id="digit-2" name="digit-2" data-next="digit-3" data-previous="digit-1" autocomplete="off" maxlength="1"><input type="text" id="digit-3" name="digit-3" data-next="digit-4" data-previous="digit-2" autocomplete="off" maxlength="1"><input type="text" id="digit-4" name="digit-4" data-next="digit-5" data-previous="digit-3" autocomplete="off" maxlength="1">
                            </div>
                        </div>
                    }

                    @if (ViewBag.emailsts == false)
                    {
                        <div class="col-md-6">
                            <span class="otpoption">Enter Your Email OTP</span>
                            <div class="digit-groupverfy">
                                <input type="text" id="email-1" name="email-1" data-next="email-2" autocomplete="off" maxlength="1"><input type="text" id="email-2" name="email-2" data-next="email-3" data-previous="email-1" autocomplete="off" maxlength="1"><input type="text" id="email-3" name="email-3" data-next="email-4" data-previous="email-2" autocomplete="off" maxlength="1"><input type="text" id="email-4" name="email-4" data-next="email-5" data-previous="email-3" autocomplete="off" maxlength="1">

                            </div>
                        </div>
                    }


                </div>

                <div class="submitebutton">
                    @using (Html.BeginForm("VeryfyUserEmailOTP", "Home", FormMethod.Post))
                    {
                        if (ViewBag.mobilests == false && ViewBag.emailsts == false)
                        {
                            <input type="hidden" id="btnveryfyotp" name="btnveryfyotp" value="MobileEmail" />
                        }
                        else
                        {
                            if (ViewBag.mobilests == false)
                            {
                                <input type="hidden" id="btnveryfyotp" name="btnveryfyotp" value="Mobile" />
                            }
                            if (ViewBag.emailsts == false)
                            {
                                <input type="hidden" id="btnveryfyotp" name="btnveryfyotp" value="Email" />
                            }
                        }

                        <input type="hidden" id="hdmobileotp" name="hdmobileotp" value="0" />
                        <input type="hidden" id="hdemailotp" name="hdemailotp" value="0" />
                        <button type="submit" style=" margin-right: 7px;" value="Submit OTP" id="btnsubmitotp" name="btnsubmitotp">Submit</button>
                    }
                    @using (Html.BeginForm("SendingEmailOTP", "Home", FormMethod.Post))
                    {

                        if (ViewBag.mobilests == false)
                        {
                            <button type="submit" value="mobile" name="btnsendotp" id="mobileotp">Resend&nbsp;Mobile</button>
                        }
                        if (ViewBag.emailsts == false)
                        {
                            <button type="submit" value="email" name="btnsendotp" id="emailotp">Resend&nbsp;Email</button>
                        }
                    }

                </div>

            </div>

        </div>
    </div>
</body>
</html>
<link href="~/Content/bootstrap.min.css" rel="stylesheet" />

<link href="~/MainFrontDesign/css/Custom-style.css" rel="stylesheet" />
<link href="~/MainFrontDesign/css/globalallcss.css" rel="stylesheet" />
<link href="~/Content/bootstrap-theme.min.css" rel="stylesheet" />
<script src="~/MainFrontDesign/js/vendor/bootstrap.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/1.7.1/jquery.min.js" type="text/javascript"></script>
<script src="/MainFrontDesign/js/vendor/jquery-1.11.2.min.js"></script>
<script>
    $('.allservice ul li').click(function () {
        $(this).toggleClass('active');
    });
</script>

<script>
    $("#digit-1, #digit-2, #digit-3, #digit-4").on("keyup", function () {

        var OtpDigit = $("#digit-1").val() + $("#digit-2").val() + $("#digit-3").val() + $("#digit-4").val();


        if (OtpDigit.length == 4) {
            $('#hdmobileotp').val(OtpDigit)
        }
    });
</script>
<script>
    $("#email-1, #email-2, #email-3, #email-4").on("keyup", function () {

        var OtpDigit = $("#email-1").val() + $("#email-2").val() + $("#email-3").val() + $("#email-4").val();


        if (OtpDigit.length == 4) {
            $('#hdemailotp').val(OtpDigit);

        }
    });
</script>

<script>
    $('.digit-groupverfy').find('input').each(function () {
        $(this).attr('maxlength', 1);
        $(this).on('keyup', function (e) {
            var parent = $($(this).parent());

            if (e.keyCode === 8 || e.keyCode === 37) {
                var prev = parent.find('input#' + $(this).data('previous'));

                if (prev.length) {
                    $(prev).select();
                }
            } else if ((e.keyCode >= 48 && e.keyCode <= 57) || (e.keyCode >= 65 && e.keyCode <= 90) || (e.keyCode >= 96 && e.keyCode <= 105) || e.keyCode === 39) {
                var next = parent.find('input#' + $(this).data('next'));

                if (next.length) {
                    $(next).select();
                } else {
                    if (parent.data('autosubmit')) {
                        parent.submit();
                    }
                }
            }
        });
    });
</script>