                    </div>
                    <div class="row">
                        <div class="body rwertfdaaa">
                            <div class="table-responsive fundtran-responsive" style="position:inherit;margin-top:-10px;">
                                <table id="tbldata" class="table table-bordered table-striped table-hover dataTable" cellspacing="0" style="width:100%;margin-top:0;">
                                    <thead style="background-color:whitesmoke;">
                                        <tr>
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">Transfer By</th>
                                            @*<th style="padding-left:2px; padding-right:2px;text-align:center;">Name</th>*@
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">Head</th>
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">P_ Mode</th>
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">TotalBal</th>
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">Charge</th>
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">Old Balance</th>
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">Net Transfer</th>
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">New Balance</th>
                                            @*<th style="padding-left:2px; padding-right:2px;text-align:center;">Dealer New Balance</th>
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">Dealer Old Balance</th>*@
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">New Credit </th>
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">old Credit</th>
                                            <th style="padding-left:2px; padding-right:2px;text-align:center;">RechargeDate</th>


                                        </tr>
                                    </thead>
                                    <tbody id="trow">
                                        @{
                                            Html.RenderAction("_FundTransferReports", "Home", new { Model = Model });
                                        }
                                    </tbody>
                                </table>
                                <div id="loadingdiv" style="text-align:center;display:none;margin-bottom:20px;">
                                    <div class="loadertablecssnew">Loading...</div>
                                </div>
                            </div>
                        </div>
                    </div>


                </div>
            </div>
        </div>

    </div>

</section>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
