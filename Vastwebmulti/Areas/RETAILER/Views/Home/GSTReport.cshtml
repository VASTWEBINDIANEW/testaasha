@model Vastwebmulti.Areas.ADMIN.Models.GSTReportModel
@{
    ViewBag.Title = "GSTReport";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
}
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }

    .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {
        height: 20px;
    }
</style>
<section class="content" style="margin:90px 0px 0px 0px; overflow-x:hidden;">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:0px;">
                <div class="card">
                    <div class="row">
                        <div class="col-md-6">
                            <p style="font-size:20px;margin-top:5px;color:#9e9e9e;font-weight:700;margin-left:5px;">GST&nbsp;Report&nbsp;For&nbsp;Month&nbsp;:-&nbsp;@ViewBag.Crmonth</p>
                        </div>
                        <div class="col-md-4">
                            @using (Html.BeginForm("GSTReport", "Home", FormMethod.Post))
                            {
                                <div class="row">
                                    <div class="col-xs-4">
                                        <center>
                                            <button id="submit" type="submit" class="btn  waves-effect" style="margin-top: 6px; margin-left: 3px; height:32px;border:1px solid #c7c2c2;background:#dedddd;" name="submit" value='@ViewBag.CurrentMonthName'>
                                                <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                                <span style="top:-2px;color:black;">@ViewBag.CurrentMonthName</span>
                                            </button>
                                        </center>
                                    </div>
                                    <div class="col-xs-4">
                                        <center>
                                            <button id="submit" type="submit" class="btn  waves-effect" style="margin-top: 6px; margin-left: -10px; height:32px;border:1px solid #c7c2c2;background:#dedddd;" name="submit" value='@ViewBag.OldMonth1'>
                                                <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                                <span style="top:-2px;color:black;">@ViewBag.OldMonth1</span>
                                            </button>
                                        </center>
                                    </div>
                                    <div class="col-xs-4">
                                        <center>
                                            <button id="submit" type="submit" class="btn  waves-effect" style="margin-top: 6px; margin-left: -30px; height:32px;border:1px solid #c7c2c2;background:#dedddd;" name="submit" value='@ViewBag.OldMonth2'>
                                                <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                                <span style="top:-2px;color:black;">@ViewBag.OldMonth2</span>
                                            </button>
                                        </center>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="col-md-2">
                            <center>
                                <a  href="@Url.Action("TDSReport","Home")" class="btn  waves-effect" style="margin-top: 6px; margin-left: 3px; height:32px;border:1px solid #c7c2c2;" >
                                    <i class="fa fa-long-arrow-right" style="top:-1px;font-size:16px;color:black;"></i>
                                    <span style="top:-2px;color:black;">Go to TDS Report</span>
                                </a>
                            </center>
                        </div>
                    </div>

                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-18px;">
                <div class="card">

                    <div class="body" style="padding:7px;">
                        <div class="table-responsive" style="position:inherit;margin-top:-3px;">
                            <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%; font-size:12px;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Sr.</th>
                                        <th>Role</th>
                                        <th>FarmName</th>
                                        <th>Name</th>
                                        <th>Account Transfer&nbsp;GST</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var i = 1;
                                    }
                                    @if (Model.GSTRetailer != null)
                                    {
                                        foreach (var item in Model.GSTRetailer)
                                        {
                                            <tr>
                                                <td>@i</td>
                                                <td>@item.Role</td>
                                                <td>@item.FarmName</td>
                                                <td>@item.Name</td>
                                                <td>@item.gst</td>
                                            </tr>
                                            i++;
                                        }
                                    }
                                </tbody>
                                <tfoot style="background-color:whitesmoke;">
                                    @if (Model.GSTRetailer != null)
                                    {
                                        <tr>
                                            <td style="font-size:18px;">Total</td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td><p style="font-size:18px;margin-left:-10px;">@Model.GSTRetailer.Sum(a => a.gst)</p></td>
                                        </tr>
                                    }
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
            </div>
</section>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->

<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />


