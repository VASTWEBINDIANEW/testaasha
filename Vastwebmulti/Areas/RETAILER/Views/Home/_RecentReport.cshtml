                                <button class="btn status" style="background: #a4a0a0 !important; word-break: break-all " onclick="RegisterAccount('@item.senderno', '@item.accountno', '@item.ifsccode', '@item.bank_nm', '@item.recivername')">Add <small>Beneficiary</small></button>
