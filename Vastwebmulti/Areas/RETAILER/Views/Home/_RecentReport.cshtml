@model Vastwebmulti.Areas.RETAILER.Models.Recent_report

<FontAwesomeIcon icon="fa-solid fa-rotate" />
<style>

    div#trans_id {
        margin: 20px 0px;
        border: 1px solid;
        background: #f3f3f3;
        width: 100%;
        float: left;
    }

        div#trans_id li {
            color: #262525;
            width: 81%;
        }

    .modal-dialog {
        float: right;
        margin-top: 11%;
        text-align: center;
        width: 64%;
        margin-right: 13%;
    }

    #example tbody tr td {
        padding: 0px 5px 0px 0px 5px !important;
    }

    .status {
        background: #ff9e00;
        width: 83px;
        height: 28px;
        color: #fff;
        font-size: 10px !important;
    }

        .status:hover, .status:focus {
            color: #fff;
        }

    #reportallinone {
        background: #eae9e9;
        float: left;
        padding-bottom: 13px;
        width: 100%;
        overflow-y: hidden;
    }

    .aadharpaysup-1 {
        animation: blinks 2s linear infinite;
        font-size: 8px;
        top: -10px;
        left: -12px;
    }

    @@keyframes blinks {
        0% {
            color: yellow;
        }

        50% {
            color: red;
        }

        100% {
            color: orange;
        }
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    @@media screen and (max-width: 1024px) {
        .fund-tr-history .modal-dialog {
            width: 100%;
            float: left !important;
            top: 38%;
            right:0px;
        }
    }
    @@media only screen and (max-width:992px){

    }
      @@media screen and (max-width: 580px){
.fund-tr-history .modal-dialog {
  width: 100%;
  float: left !important;
  top: 38%;
  right: 10px;
}
}


</style>
