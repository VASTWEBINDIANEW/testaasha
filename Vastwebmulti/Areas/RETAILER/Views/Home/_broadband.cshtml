<!--broadband Continue Button script-->
<script>
    function getbroadbandcontinuebtn(b) {
        var e = document.getElementById(b);
        var broadbandddltext = e.options[e.selectedIndex].text;
        var broadbandddlvalue = e.options[e.selectedIndex].value;
        var broadbandno = $("#txtbroadbandno").val();
        var broadbandamount = $("#broadbandamount").val();
        var duedate = $("#broadbandduedate").val();
        /* call function */
        var sts = getbroadbandcontiunebtn(broadbandddltext, broadbandno, broadbandamount);

        if (sts == true) {
            $('#showoptbroad').text(broadbandddltext);
            $('#shownumberbroad').text(broadbandno);
            $('#showamountbroad').text(broadbandamount);
            $('#broadbandduedate').text(duedate);
            $('#broadshow').hide();
            $('#confirmbroad').show();
            //    Recharge(broadbandddltext, broadbandddlvalue, broadbandno, broadbandamount, "", "", "", "", "0");
            event.preventDefault();
            return false;
        }
        else {
            event.preventDefault();
            return false;
        }
    }
</script>

<!--Broadband View Bill -->
<script>
    function Getbroadbandviewbill(b) {
        var e = document.getElementById(b);
        var broadbandddltext = e.options[e.selectedIndex].text;
        var eleddlvalue = e.options[e.selectedIndex].value;
        var broadbandno = $("#txtbroadbandno").val();
        /* call function */
        var sts = getbroadbandcontiunebtn(broadbandddltext, broadbandno, "10");
        if (sts == true) {
            viewbillbroad(broadbandddltext, eleddlvalue, broadbandno, "10", "", "", "", "");
            event.preventDefault();
            return false
        }
        else {
            event.preventDefault();
            return false
        }
    }
</script>
<script>
    function viewbillbroad(optname, optvalue, mobileno, amount, optional1, optional2, optional3, optional4) {
           $.ajax({
            type: "POST",
            url: "@Url.Action("viewbill", "Home")",
            data: { OperatorName: optname, OptCode: optvalue, mobileno: mobileno, Amount: amount, optional1: optional1, optional2: optional2, optional3: optional3, optional4: optional4 },
            cache: false,
            dataType: 'json',
            closeOnConfirm: true,
               success: function (result) {
                   if (result.Response == 'SUCCESS') {
                       var displayValues = "";
                       var price = result.Price;
                       var BIllduedate = result.billduedate;
                       const displayValuesArray = JSON.parse(result.DisplayValues);

                       // Access the value associated with the "label" "Customer Name"
                       const customerNameValue = displayValuesArray[0].value;
                       var newrow = "<table class='col-sm-4 table-responsive table-bordered'><tr>";
                       newrow += "<td>" + displayValues + "</td></tr>";
                       newrow += "<tr><td> Bill Amount &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; ::  " + result.Price + "</td></tr>";
                       newrow += "<tr><td> Due Date &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;   ::  " + result.billduedate + "</td></tr>";
                       newrow += "<tr><td> Costomer Name &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;   ::  " + customerNameValue + "</td></tr>";
                       newrow += "</table>";
                       $('#broadband1').append(newrow);
                       $('#broadbandinfo').css('display', 'block');
                       displayValues = price;
                       if (price != "") {
                           //price = parseInt(price);
                           $('#broadbandamount').val(price);
                           $('#broadbandduedate').val(BIllduedate);
                           //swal("Success!", displayValues, "success")
                       }
                   }
                   if (result.Response == 'ERROR') {
                       $('.loader').hide();
                       var newRow = "<div class='col-sm-4' style='text-align: left;color:red'>" +
                           "" + result.Message + ""
                       "</div>";

                       $('#broadbandamount').val('');
                       $('#broadbandduedate').val('');
                       $('#broadband1').append(newRow);
                       $('#broadbandinfo').css('display', 'block');
                   }
            }
        })
    }
</script>

<script>
    function backbroad() {

        $('#broadshow').show();
        $('#confirmbroad').hide();
        $('#rechargeconfirmbroad').hide();
    }
</script>
<script>
    function broadrechargeconfirm(pinValue) {

        var e = document.getElementById("broadbandddltype");
        var broadbandddltext = e.options[e.selectedIndex].text;
        var broadbandddlvalue = e.options[e.selectedIndex].value;
        var broadbandno = $("#txtbroadbandno").val();
        var broadbandamount = $("#broadbandamount").val();
        var servicefeebroad = $("#servicefeebroad").val();
        var duedate = $("#broadbandduedate").val();
        if (servicefeebroad != "") {
            /* call function */
            var sts = getbroadbandcontiunebtn(broadbandddltext, broadbandno, broadbandamount);
            if (sts == true) {
                $("#servicefeebroad").css("border-color", "#000000");
                //$("#txtbroadbandno").val("");
                //$("#broadbandamount").val("");
              //  if (broadbandno != "" && broadbandamount != "") {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("Recharge","Home")",
                        data: { OperatorName: broadbandddltext, OptCode: broadbandddlvalue, mobileno: broadbandno, Amount: broadbandamount, optional1: "", optional2: "", optional3: "", optional4: "", comm: "", BillRefId: "", servicefee: servicefeebroad, billduedate: duedate, Rechargepin: pinValue },
                        cache: false,
                        dataType: 'json',
                        beforeSend: function () {
                            $('.loader').show();
                        },
                        success: function (result) {



                            // 🔴 Clear old PIN error every time
                            $('#broadpinError').hide().text("");

                            /* 🔴 PIN ERROR — SAME PAGE */
                            if (result.status && (
                                result.status === "PIN_REQUIRED" ||
                                result.status === "INVALID_PIN" ||
                                result.status === "PIN_NOT_SET")) {

                                $('#broadpinError').text(result.message).show();
                                $('.loader').hide();
                                return; // 🚫 STOP ONLY FOR PIN ERROR
                            }

                            var status = result.Response;
                            var message = result.Message;
                            if (status == "GATEWAY") {
                                window.open(message, "_self");
                                $('#rchstatuschkbroad').text("Pending");
                                $('#rchmsgbroad').text("Please Wait While Redirect The Gateway");
                            }
                            else {
                                $('#rchstatuschkbroad').text(status);
                                $('#rchmsgbroad').text(message);

                                $("#txtbroadbandno").val("");
                                $("#broadbandamount").val("");

                            }

                            $('#confirmbroad').hide();
                            $('#rechargeconfirmbroad').show();
                        },
                        complete: function () {
                            $('.loader').hide();
                            $.ajax({
                                url: '@Url.Action("showrecentrecharge", "Home")',
                                type: 'GET',
                                dataType: "html",
                                data: { type: "broadband" },
                                success: function (data) {
                                    $('#reportchk').html(data);
                                },
                                error: function (data) {

                                }
                            });
                        },
                        error: function () {
                            $('.loader').hide();
                        }
                    })
                //}
            }
        }
        else {
              $("#servicefeebroad").css("border-color", "#FF0000");
        }
    }
</script>
<script>
    function Rechargeagainbroad() {
        $('#numbershowmobile').text();
        j('#broadbandddltype').val("");
        j('#broadbandddltype').select2().trigger('change');
        $('#txtbroadbandno').val("");
        $('#broadbandamount').val("");
        $('#broadshow').show();
        $('#confirmbroad').hide();
        $('#rechargeconfirmbroad').hide();
    }
</script>