<script>

     var isPinOn = @Model.Ispin.ToString().ToLower();

    function broadprocessToPay() {

     if (isPinOn) {

         var pin = $('#broadRechargepin').val();


         if (!pin) {
             alert('Please enter transaction PIN');
             $('#broadRechargepin').focus();
             return;
         }

         broadrechargeconfirm(pin);
     }
     else {
         broadrechargeconfirm('');
     }
 }

</script>



<script>
    function showMsg(msg, type) {

        var color = (type === "success") ? "green" : "red";

        $('#broadmsgBox').html(
            '<div style="color:' + color + '; font-weight:bold;">' + msg + '</div>'
        );

        setTimeout(function () {
            $('#broadmsgBox').html('');
        }, 5000);
    }
</script>


