<script type="text/jscript">
        $(function () {
            $('#Paymode').change(function () {

                var amount = $('#balanceDiv').find('input[name="balance"]').val();//$("#balance").text();
                //alert('amount'+amount);
                var disCharge = 20;
                $(".formElement").hide();
                var name = $("#Paymode option:selected").val();
                if (name == "Third Party Transfer") {
                    $('#divpartyAcc').show();
                    $('#divAccHolderName').show();
                }
                if (name == "ATM Machine Deposit") {
                    $('#divbranch').show();
                    $('#divPancard').show();
                    $('#dopistChargeDiv').show();
                    //alert('@ViewBag.ATMMinCharge');
                    //alert('@ViewBag.ATMChargePercant');
                    disCharge = (amount * '@ViewBag.ATMChargePercant') / 100;
                    // alert(disCharge);
                    if (disCharge <= '@ViewBag.ATMMinCharge') {
                        disCharge = '@ViewBag.ATMMinCharge';
                    }
                }
                if (name == "Branch Cash Deposit") {
                    $('#divbranch').show();
                    $('#divPancard').show();
                    $('#dopistChargeDiv').show();
                    disCharge = (amount * '@ViewBag.CashChargePercant') / 100;
                    //alert(disCharge);
                    if (disCharge <= '@ViewBag.CashMinCharge') {
                        disCharge = '@ViewBag.CashMinCharge';
                    }
                }
                $('#dipositCharge').val(disCharge);
            });

            $(document).on("focusout", "#balance", function () {
               // alert();
                var disCharge = 20;
                // alert();
                var amount = $(this).val();
               // alert("amount " +amount);

                //var dipCharge = $("#dipositCharge").val();
                var name = $("#Paymode option:selected").val();
                //alert("name " + name);
                if (name == "ATM Machine Deposit") {
                    disCharge = (amount * '@ViewBag.ATMChargePercant') / 100;
                    //alert(disCharge);
                    if (disCharge <= '@ViewBag.ATMMinCharge') {
                        disCharge = '@ViewBag.ATMMinCharge';
                    }

                } else if (name == "Branch Cash Deposit") {
                    disCharge = (amount * '@ViewBag.CashChargePercant') / 100;
                    if (disCharge <= '@ViewBag.CashMinCharge') {
                        disCharge = '@ViewBag.CashMinCharge';
                    }
                }
               // alert(disCharge);
                $("#dipositCharge").attr("disabled", false);
                $("#dipositCharge").val(disCharge);
                $("#dipositCharge").attr("disabled", true);
            });
        });

</script>
<script type="text/javascript">
    $(document).ready(function () {
        $("#balance").keydown(function (e) {
            // Allow: backspace, delete, tab, escape, enter and .
            if ($.inArray(e.keyCode, [46, 8, 9, 27, 13, 110, 190]) !== -1 ||
                // Allow: Ctrl+A, Command+A
                (e.keyCode === 65 && (e.ctrlKey === true || e.metaKey === true)) ||
                // Allow: home, end, left, right, down, up
                (e.keyCode >= 35 && e.keyCode <= 40)) {
                // let it happen, don't do anything
                return;
            }
            // Ensure that it is a number and stop the keypress
            if ((e.shiftKey || (e.keyCode < 48 || e.keyCode > 57)) && (e.keyCode < 96 || e.keyCode > 105)) {
                e.preventDefault();
            }
        });

    });

</script>

