<!--View Bill-->
<script type="text/javascript">
    function Getviewbill(el) {
        $('#ElectricityCustomerTbl').empty();

        var e = document.getElementById(el);
        var eleddl = e.options[e.selectedIndex].text;
        var eleddlvalue = e.options[e.selectedIndex].value;
        var txtval = $("#txtelectricity").val();
        var cycleno = $("#ProcessingCycle").val();
        var billunit = $("#billunit").val();
        var Amount = $("#electricityAmount").val();
        var ddlcity = $("#ddlcity").val();
        var ddlcitytamil = $("#ddlcitytamilnadu").val();


        /* call function*/
        if (eleddl == "TNEB-Tamil Nadu") {
            var sts = continuebtnvalidation(eleddl, txtval, cycleno, billunit, "10", ddlcitytamil);
        }
        else {
            var sts = continuebtnvalidation(eleddl, txtval, cycleno, billunit, "10", ddlcity);
        }
        if (sts == true) {
            if (ddlcity != "" && ddlcity != null) {

                viewbille(eleddl, eleddlvalue, txtval, "10", ddlcity, cycleno, "", "");
            }
            else if (ddlcitytamil != "" && ddlcitytamil != null) {
                viewbille(eleddl, eleddlvalue, txtval, "10", ddlcitytamil, cycleno, "", "");
            }
            else {

                viewbille(eleddl, eleddlvalue, txtval, "10", billunit, cycleno, "", "");
            }
            //viewbill(eleddl, eleddlvalue, txtval, "10", billunit, cycleno, "", "");
            event.preventDefault();
            return false;
        }
        else {
            event.preventDefault();
            return false;
        }
    }

</script>

<script>
    function viewbille(optname, optvalue, mobileno, amount, optional1, optional2, optional3, optional4) {
         $('.loader').show();
       $.ajax({
           type: "POST",
           url: "@Url.Action("viewbill", "Home")",
           data: { OperatorName: optname, OptCode: optvalue, mobileno: mobileno, Amount: amount, optional1: optional1, optional2: optional2, optional3: optional3, optional4: optional4 },
           cache: false,
           dataType: 'json',
           closeOnConfirm: true,
           success: function (result) {
               console.log(result)
               $('.loader').hide();
               if (result.Response == 'SUCCESS') {
                   var displayValues = "";
                   $.each(JSON.parse(result.DisplayValues), function (key, val) {
                       if (!val.label.includes('Incentive')) {

                           displayValues = displayValues + val.label + ' : ' + val.value + "</br>";
                       }
                   });

                   var newrow = "<table class='col-sm-4 table-responsive table-bordered'><tr>";
                   newrow += "<td>" + displayValues +"</td></tr>";
                   newrow += "<tr><td> Bill Amount &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;;&nbsp; ::  " + result.Price + "</td></tr>";
                   newrow += "<tr><td> Due Date &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;   ::  " + result.billduedate + "</td></tr>";
                    newrow += "</table>";
                   $('#ElectricityCustomerTbl').append(newrow);
                   $('#ElectricityCustomerInfo').css('display', 'block');
                   var price = result.Price;
                   var BillRefId = result.reference_id;
                   var BIllduedate = result.billduedate;
                   if (BillRefId == "undefined" || BillRefId == "") {
                       if (price != "") {
                           //price = parseInt(price);
                           $('#electricityAmount').val(price);
                           $('#BillRefId').val(BillRefId);
                           $('#electricityduedate').val(BIllduedate);
                           // displayValues
                       }
                   }
                   else {
                       if (price != "") {
                           //price = parseInt(price);
                           $('#electricityAmount').val(price);
                           $('#BillRefId').val(BillRefId);
                           $('#electricityduedate').val(BIllduedate);
                           // displayValues
                       }
                       else {
                           var message = result.Message;
                           $('#electricityAmount').val('');
                           $('#BillRefId').val(message);
                           $('#electricityduedate').val(BIllduedate);
                       }
                   }
               }
               if (result.Response == 'ERROR') {
                   $('.loader').hide();
                                  var newRow ="<div class='col-sm-4' style='text-align: left;color:red'>" +
                                  ""+result.Message+""
                   "</div>";
                   $('#electricityAmount').val('');
                   $('#electricityduedate').val('');
                   $('#ElectricityCustomerTbl').append(newRow);
                   $('#ElectricityCustomerInfo').css('display', 'block');
               }
           }
       })
    }
</script>
