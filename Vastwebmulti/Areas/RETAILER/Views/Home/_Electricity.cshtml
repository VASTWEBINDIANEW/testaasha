<script>
    function elecrechargeconfirm(pinValue) {

            var e = document.getElementById("eddltype");
        var eleddl = e.options[e.selectedIndex].text;
        var eleddlvalue = e.options[e.selectedIndex].value;
        var txtval = $("#txtelectricity").val();
        var cycleno = $("#ProcessingCycle").val();
        var billunit = $("#billunit").val();
        var Amount = $("#electricityAmount").val();
        var duedate = $("#electricityduedate").val();
        var ddlcity = "";
        if (eleddl === "TNEB-Tamil Nadu") {
            ddlcity = $("#ddlcitytamilnadu").val();
        }
        else {
            ddlcity = $("#ddlcity").val();
        }
        var BillRefId = $("#BillRefId").val();
        var servicefeelectricty = $("#servicefeelectricty").val();
        if (servicefeelectricty != "") {
            /* call function*/
            var sts = continuebtnvalidation(eleddl, txtval, cycleno, billunit, Amount, ddlcity);
            if (sts == true) {
                  $("#servicefeelectricty").css("border-color", "#000000");
                var optional1 = billunit;
                if (ddlcity != "" && ddlcity != null) {
                    optional1 = ddlcity;
                }

                //$("#txtelectricity").val("");
                //$("#electricityAmount").val("");
                //if (txtval != "" && Amount != "") {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("Recharge","Home")",
                        data: { OperatorName: eleddl, OptCode: eleddlvalue, mobileno: txtval, Amount: Amount, optional1: optional1, optional2: cycleno, optional3: "", optional4: "", comm: "", BillRefId: BillRefId, servicefee: servicefeelectricty, billduedate: duedate, Rechargepin: pinValue },
                        cache: false,
                        dataType: 'json',
                        beforeSend: function () {
                            $('.loader').show();
                        },
                        success: function (result) {
                            console.log(result);

                            // 🔴 Clear old PIN error every time
                            $('#elecpinError').hide().text("");

                            /* 🔴 PIN ERROR — SAME PAGE */
                            if (result.status && (
                                result.status === "PIN_REQUIRED" ||
                                result.status === "INVALID_PIN" ||
                                result.status === "PIN_NOT_SET")) {

                                $('#elecpinError').text(result.message).show();
                                $('.loader').hide();
                                return; // 🚫 STOP ONLY FOR PIN ERROR
                            }


                            var status = result.Response;
                            var message = result.Message;

                            console.log(status);
                            console.log(message);

                            if (status == "GATEWAY") {
                                window.open(message, "_self");
                                $('#rchstatuschkelec').text("Pending");
                                $('#rchmsgelec').text("Please Wait While Redirect The Gateway");
                            }
                            else {
                                $('#rchstatuschkelec').text(status);
                                $('#rchmsgelec').text(message);

                                $("#txtelectricity").val("");
                                $("#electricityAmount").val("");

                                if (status === "SUCCESS") {
                                    // ✅ Fill popup form fields
                                    document.querySelector("input[name='biller']").value = eleddl || "Not Available";
                                    document.querySelector("input[name='billNumber']").value = txtval || "N/A";
                                   /* document.querySelector("input[name='billDate']").value = new Date().toISOString().split("T")[0];*/
                                    /*document.querySelector("input[name='dueDate']").value = duedate || new Date().toISOString().split("T")[0];*/
                                    document.querySelector("input[name='txnId']").value = "TXN" + Date.now();
                                    document.querySelector("input[name='amount']").value = Amount || 0;
                                    document.querySelector("input[name='total']").value = Amount || 0;
                                    document.querySelector("input[name='txnTime']").value = new Date().toISOString().split("T")[0];
                                    document.querySelector("input[name='status']").value = status;

                                    // ✅ Show popup
                                    const popup = document.getElementById("payConfirmationPopup");
                                    popup.style.display = "block";
                                    popup.scrollIntoView({ behavior: "smooth" });
                                }
                            }

                            // ✅ Always toggle sections
                            $('#confirmelec').hide();
                            $('#rechargeconfirmelec').show();
                        },

                        /*success: function (result) {
                            console.log(result)

                            var status = result.Response;
                            var message = result.Message;
                            console.log(status)
                            console.log(message)
                            if (status == "GATEWAY") {
                                window.open(message, "_self");
                                $('#rchstatuschkelec').text("Pending");
                                $('#rchmsgelec').text("Please Wait While Redirect The Gateway");
                            }
                            else {
                                $('#rchstatuschkelec').text(status);
                                $('#rchmsgelec').text(message);
                            }
                            $('#confirmelec').hide();
                            $('#rechargeconfirmelec').show();

                        },*/
                        complete: function () {
                            $("#remainretailer").load(location.href + " #remainretailer");
                            $('.loader').hide();
                            $.ajax({
                                url: '@Url.Action("showrecentrecharge", "Home")',
                                type: 'GET',
                                dataType: "html",
                                data: { type: "Electricity" },
                                success: function (data) {
                                    $('#reportchk').html(data);
                                },
                                error: function (data) {

                                }
                            });
                        },
                        error: function () {
                            $("#remainretailer").load(location.href + " #remainretailer");
                            $('.loader').hide();
                        }
                    })

               // }
            }
        }
        else {
              $("#servicefeelectricty").css("border-color", "#FF0000");
        }
    }
</script>