<script>
    var isPinOn = @Model.Ispin.ToString().ToLower();

    function elecprocessToPay() {

        if (isPinOn) {

            var pin = $('#elecRechargepin').val();

            if (!pin) {
                alert('Please enter transaction PIN');
                $('#elecRechargepin').focus();
                return;
            }

            elecrechargeconfirm(pin);
        }
        else {
            elecrechargeconfirm('');
        }
    }
</script>



<script>
