<script>
    function OnSuccessunload() {
        var chk = $('input[name="group1"]:checked').val();
        if (chk == "bywalletunload") {
            $('#WalletUnload').show();
            $('#tabsmyss1').hide();
            $('#posunload').hide();
            $('#datashowPOS').hide();
            $('#datashowPOS1').hide();
            $('#datashow').show();
        }
        else if (chk == "byposunload") {
            $('#posunload').show();
            $('#WalletUnload').hide();
            $('#tabsmyss1').hide();
            $('#datashowPOS1').hide();
            $('#datashowPOS').show();
            $('#datashow').hide();
        }

        else if (chk == "byposDis") {
            $('#tabsmyss1').show();
            $('#WalletUnload').hide();
            $('#posunload').hide();
            $('#datashowPOS').hide();
            $('#datashowPOS1').show();
            $('#datashow').hide();
        }
    }
</script>