<script>
    function PurchaseMICROATM(e) {
            $('#HDServicesname').val('');
        $.ajax({
            url: '@Url.Action("ServiceCharge","Home")',
            data: { Service: e },
            cache: false,
            type: "POST",
            dataType: 'json',
            success: function (data) {

                $('#secpur111').show();
                $('#PaymentType111').html(data.PaymentType);
                $('#Price111').html(data.Price);
                $('#firstRegister').hide();
                $('#firstMICRO').hide();
                $('#ALLMICRO').hide();
                $('#BOTHMICRO').hide();

                $('#HDServicesname').val(e);
            }
        });
    }
    function FinalPurchaseMICROATM() {

         $.ajax({
            url: '@Url.Action("ServicePurchase","Home")',
             data: { Service: $('#HDServicesname').val() },
            cache: false,
            type: "POST",
             dataType: 'json',
            beforeSend: function() {
                      $('.loader').show();
                     },
             success: function (data) {

                 if (data.Status == "Success") {
                     GotoATMActive();
                 }
                 else {
                     $('#errmsgmicro').text(data.Message);
                 }

             },
             complete: function () {
                 $('.loader').hide();
                 $("#remainretailer").load(location.href + " #remainretailer");
             },
             error: function () {
                 $("#remainretailer").load(location.href + " #remainretailer");
                 $('.loader').hide();
             }
        });
    }
</script>
<script>
    function GotoATMActive() {
        $('#errormposid3').text("");
        $('#firstRegister').hide();
        $('#firstMICRO').hide();
        $('#ALLMICRO').hide();
        $('#BOTHMICRO').hide();
        $('#secpur111').hide();
        $('#ATMReg').hide();
        $('#HDServicesname').val('');
        $('#errormposid123').text("");
        $.ajax({
            url: '@Url.Action("MicroATM", "Home")',
            cache: false,
            type: "GET",
             beforeSend: function() {
                  $('.loader').show();
             },
            success: function (data) {

                $('.loader').hide();
                var output = JSON.parse(data);
                  if(output.status == "ALLNOTDONE") {
                      $('#ALLMICRO').show();
                     }
                  else if (output.status == "BOTHNOTDONE") {
                     $('#BOTHMICRO').show();
                 }
                else if (output.status == "NOTOK") {
               $('#firstMICRO').show();
             }
               else if (output.status == "StatusCheck") {
                    //buttonDisable
                    $('#alredyexist').text(output.msg);
                      $('#merchantidd').text(output.MerchantId);
                      $('#serialno').val(output.devicesr);
                    $('#errormposid123').text('');
                    $('#ATMReg').hide();
                      $('#statuschk').show();
                }
                else if (output.status == "Device") {
                    //buttonDisable
                    //$('#alredyexist').text(output.msg);

                    $('#Deviceidd').text("NOt Register");
                    $('#merchantidd').text(output.MerchantId);
                      $('#serialno').val(output.devicesr);
                    $('#errormposid123').text('');
                    $('#statuschk').hide();
                    $('#ATMReg').hide();
                    $('#SecondSerialNoSubmit').show();
                }
                else if (output.status == "Success") {
                    //buttonDisable
                    $('#Deviceidd').text(output.devicesr);

                    $('#alredyexist').text(output.msg);
                      $('#merchantidd').text(output.MerchantId);
                      $('#serialno').val(output.devicesr);
                    $('#errormposid123').text('');
                    $('#statuschk').hide();
                    $('#ATMReg').show();
                }
                else if (output.status == "Failed") {
                    //buttonEnable
                    $('#errormposid123').text(output.msg);
                      $('#firstRegister').show();
                      $('#statuschk').hide();
                }
                else if (output.status == "ERROR") {
                    alert(output.msg);

                    //buttonEnable
                    $('#errormposid123').text(output.msg);
                //    $('#firstRegister').show();
                }

                else {
                    //buttonEnable
                    $('#errormposid123').text(output.msg);
                    $('#firstRegister').show();
                }
            },
             complete: function () {

                   $('.loader').hide();
                    $.ajax({
            url: '@Url.Action("MIcroAtmReportnew", "Home")',
            cache: false,
                 type: "GET",
                 cache: false,
               dataType:"html",
            success: function (data) {
                 $('#reportallinone').html(data);
            }
        })
            }
        })
    }
    // Merchant Status Check
    function microATM_StatusCheck() {
        $('#Updateprofiledetails').hide();
             $('#firstRegister').hide();

        $('#ATMReg').hide();
        $('#errormposid123').text("");
        $('#alredyexist').text("");
        $.ajax({
            url: '@Url.Action("StatusCheck", "Home")',
            cache: false,
            type: "GET",
             beforeSend: function() {
                  $('.loader').show();
             },
            success: function (data) {
                $('.loader').hide();
                var output = JSON.parse(data);

                if (output.status == "Success") {
                    //buttonDisable
                    $('#alredyexist').text(output.msg);
                    $('#merchantidd').text(output.MerchantId);
                    $('#errormposid123').text('');
                    $('#statuschk').hide();
                    $('#ATMReg').show();
                    $('#SecondSerialNoSubmit').show();
                }
                else if (output.status == "REFER_BACK") {
                  $.ajax({
                         url: '@Url.Action("FillRetailerInformation", "Home")',
                        type: "POST",
                        success: function (data) {

                          $('#remusrname').val(data.name);
                          $('#rempanname').val(data.pancardname);
                          $('#errormicrrefer2').text(output.msg)
                          $('#errormposid').text('');
                          $('#statuschk').hide();
                          $('#ATMReg').hide();
                          $('#SecondSerialNoSubmit').hide();
                          $('#Updateprofiledetails').show();


            }
        })

              }
                      else if (output.status == "Failed") {
                    //buttonEnable
                    $('#alredyexist').text(output.msg);
                    $('#statuschkkk').text(output.msg);
                    $('#statuschkkk').show();
                    $('#ATMReg').hide();
                    $('#statuschk').show();
                    $('#firstRegister').hide();
                }

                else {
                    //buttonEnable
                    $('#errormposid123').text(output.msg);
                    $('#firstRegister').show();
                }
            }
        })
    }
// Merchant Submit
        function microATMActive() {
            $('#SecondSerialNoSubmit').hide();

            $('#ATMReg').hide();
            $('#errormposid2').text('');
        $.ajax({
            url: '@Url.Action("Active_microATM", "Home")',
            cache: false,
            type: "POST",
            beforeSend: function () {
                $('.loader').show();
            },
            success: function (data) {
                $('.loader').hide();
                var output = JSON.parse(data);

                if (output.status == "Success") {
                    $('#MerchantId').val(output.MerchantId);
                    $('#errormposid2').text('');
                    $('#firstRegister').hide();
                }
                else if (output.status == "Failed") {
                    //buttonEnable
                    $('#errormposid2').text(output.msg);
                    $('#firstRegister').show();
                }
                else {
                    //buttonEnable
                    $('#errormposid2').text(output.msg);
                    $('#firstRegister').show();
                }
            }
        })
    }

    // Device Serialno Active
        function microATMActiveSerialno() {
            $('#SecondSerialNoSubmit').hide();

        $('#ATMReg').hide();
        $('#errormposid3').text('');
        $.ajax({
            url: '@Url.Action("microATMSnNo", "Home")',
            cache: false,
            type: "POST",
            data: { DeviceSnNo: $('#serialno').val() },
            beforeSend: function () {
                $('.loader').show();
            },
            success: function (data) {
                $('.loader').hide();
                var output = JSON.parse(data);

                if (output.status == "Success") {
                    //$('#MerchantId').val(output.MerchantId);
                    $('#errormposid3').text('');
                    $('#SecondSerialNoSubmit').hide();
                    GotoATMActive();
                }
                else if (output.status == "Failed") {
                    //buttonEnable
                    $('#MerchantId').val('');
                    $('#serialno').val('');
                    $('#errormposid3').text(output.msg);
                    $('#SecondSerialNoSubmit').show();
                }
                else {
                    //buttonEnable
                    $('#errormposid3').text(output.msg);
                    $('#SecondSerialNoSubmit').show();
                }
            }
        })
    }
</script>