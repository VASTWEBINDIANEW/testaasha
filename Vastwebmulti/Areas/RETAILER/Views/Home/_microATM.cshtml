    /* New css  */
    .loader {
        position: fixed;
        top: -90px;
        left: 0;
        background-color: rgba(255,255,255,0.7);
        z-index: 999999999999;
        display: none;
        height: 100vw;
        width: 100vw;
    }

    @@-webkit-keyframes spin {
        from {
            -webkit-transform: rotate(0deg);
        }

        to {
            -webkit-transform: rotate(360deg);
        }
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .loader::after {
        content: '';
        display: block;
        position: absolute;
        left: 48%;
        top: 25%;
        width: 100px;
        height: 100px;
        border-style: solid;
        border-color: black;
        border-top-color: transparent;
        border-width: 4px;
        border-radius: 50%;
        -webkit-animation: spin .8s linear infinite;
        animation: spin .8s linear infinite;
    }

    .deviceactivemicroatm img {
        width: 122px;
        height: 122px;
        border-radius: 50%;
        padding: 22px;
        display: block;
    }

    .deviceactivemicroatm {
        width: 100%;
        float: left;
        text-align: center;
        display: grid;
        justify-items: center;
        margin-top: 15px;
    }

        .deviceactivemicroatm strong {
            margin: 10px 0;
            text-transform: uppercase;
            font-size: 16px;
            border-bottom: 1px solid green;
        }

        .deviceactivemicroatm p {
            font-size: 14px;
            text-transform: capitalize;
        }
</style>
