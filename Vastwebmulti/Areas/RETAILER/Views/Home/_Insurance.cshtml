<!--Insurance View Bill-->
<script>
    function GetInsuranceviewbill(ins) {
        var e = document.getElementById(ins);
        var insuranceddl = e.options[e.selectedIndex].text;
        var eleddlvalue = e.options[e.selectedIndex].value;
        var txtpolicyno = $("#txtpolicyno").val();
        var insuranceamount = $("#insuranceamount").val();
        var dob = $("#txtDOB").val();
        /*call function */
        var sts = getinsurancecontiunebtn(insuranceddl, txtpolicyno, dob, "10");
        console.log('sts', sts);
        if (sts == true) {
            viewbillinsur(insuranceddl, eleddlvalue, txtpolicyno, "10", dob, "", "", "");
            event.preventDefault();
            return false
        }
        else {
            event.preventDefault();
            return false
        }
    }
</script>
<script>
    function viewbillinsur(optname, optvalue, mobileno, amount, optional1, optional2, optional3, optional4) {
        $.ajax({
            type: "POST",
            url: "@Url.Action("viewbill", "Home")",
            data: { OperatorName: optname, OptCode: optvalue, mobileno: mobileno, Amount: amount, optional1: optional1, optional2: optional2, optional3: optional3, optional4: optional4 },
            cache: false,
            dataType: 'json',
            closeOnConfirm: true,
            beforeSend: function () {
                $('.loader').show();
            },
            success: function (result) {
                $('.loader').hide();
                $('#insurCustomerTbl').html('');
                var message = result.Message;
                if (message == "Operator Code MissMatch") {
                    $('#insuranceamount').val(0);
                    $('#insuranceduedate').val('');

                    var newRow =
                        "<div class='col-sm-4 text-danger' style='text-align: left;'>" +
                        "" + message + ""
                    "</div>"
                    $('#insurCustomerTbl').append(newRow);
                    $('#insurCustomerInfo').css('display', 'block');
                    return;
                }
                if (result.Response == 'SUCCESS') {
                    var price = result.Price;
                    var BIllduedate = result.billduedate;
                    var name = JSON.parse(result.DisplayValues);
                    name = name[0].value;

                    if (price != "") {
                        $('#insuranceamount').val(price);
                        $('#insuranceduedate').val(BIllduedate);

                        var newRow = "<li style='list-style-type: none;'>Name: " + name + "</li>";
                        newRow += "<li style='list-style-type: none;'>Amount: " + price + "</li>";
                        newRow += "<li style='list-style-type: none;'>Due Date: " + result.billduedate + "</li>";

                        $('#insurCustomerTbl').append(newRow);
                        $('#insurCustomerInfo').css('display', 'block');
                    }
                    else {
                        $('#insuranceamount').val(0);
                        $('#insuranceduedate').val('');

                        var newRow =
                            "<div class='col-sm-4' style='text-align: left;'>" +
                            "" + message + ""
                        "</div>"
                        $('#insurCustomerTbl').append(newRow);
                        $('#insurCustomerInfo').css('display', 'block');
                    }

                }
                else {
                    $('#insuranceamount').val(0);
                    $('#insuranceduedate').val('');

                    var newRow =
                        "<div class='col-sm-4 text-danger' style='text-align: left;'>" +
                        "" + message + ""
                    "</div>"
                    $('#insurCustomerTbl').append(newRow);
                    $('#insurCustomerInfo').css('display', 'block');
                }
            }
        })
    }
</script>
<script>
    function backinsur() {
        $('#insurCustomerInfo').show();
        $('#insureinfo').show();
        $('#confirminsur').hide();
    }
</script>
<!--Insurance continue button function-->
<script>
    function getinsurancecontinuebtn(ins) {
        var e = document.getElementById(ins);
        var insuranceddl = e.options[e.selectedIndex].text;
        var insurancevalue = e.options[e.selectedIndex].value;
        var txtpolicyno = $("#txtpolicyno").val();
        var insuranceamount = $("#insuranceamount").val();
        var duedate = $("#insuranceduedate").val();
        var dob = $("#txtDOB").val();
        var email = $("#txtemail").val();

        /*call function */
        var sts = getinsurancecontiunebtn(insuranceddl, txtpolicyno, dob, insuranceamount);
        if (sts == true) {
            $('#showoptinsur').text(insuranceddl);
            $('#shownumberinsur').text(txtpolicyno);
            $('#showamountinsur').text(insuranceamount);
            $('#insuranceduedate').text(duedate);
            $('#insurCustomerInfo').hide();
            $('#insurinfo').hide();
            $('#confirminsur').show();

            //  Recharge(insuranceddl, insurancevalue, txtpolicyno, insuranceamount, dob, "", "", "", "0");
            event.preventDefault();
            return false;
        }
        else {
            event.preventDefault();
            return false;
        }
    }
</script>

<script>
    function insurrechargeconfirm(pinValue) {

        var e = document.getElementById("insuranceddltype");
        var insuranceddl = e.options[e.selectedIndex].text;
        var insurancevalue = e.options[e.selectedIndex].value;
        var txtpolicyno = $("#txtpolicyno").val();
        var insuranceamount = $("#insuranceamount").val();
        var duedate = $("#insuranceduedate").val();
        var dob = $("#txtDOB").val();
        var email = $("#txtemail").val();
        var servicefeeinsurance = $("#servicefeeinsurance").val();
        if (servicefeeinsurance != "") {
            /*call function */
            var sts = getinsurancecontiunebtn(insuranceddl, txtpolicyno, dob, insuranceamount);
            if (sts == true) {
                  $("#servicefeeinsurance").css("border-color", "#00000");
                //$("#txtpolicyno").val("");
                //$("#insuranceamount").val("");
               // if (txtpolicyno != "" && insuranceamount != "") {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("Recharge","Home")",
                        data: { OperatorName: insuranceddl, OptCode: insurancevalue, mobileno: txtpolicyno, Amount: insuranceamount, optional1: dob, optional2: email, optional3: "", optional4: "", comm: "", BillRefId: "", servicefee: servicefeeinsurance, billduedate: duedate, Rechargepin: pinValue },
                        cache: false,
                        dataType: 'json',
                        beforeSend: function () {
                            $('.loader').show();
                        },
                        success: function (result) {


                            // 🔴 Clear old PIN error every time
                            $('#insurpinError').hide().text("");

                            /* 🔴 PIN ERROR — SAME PAGE */
                            if (result.status && (
                                result.status === "PIN_REQUIRED" ||
                                result.status === "INVALID_PIN" ||
                                result.status === "PIN_NOT_SET")) {

                                $('#insurpinError').text(result.message).show();
                                $('.loader').hide();
                                return; // 🚫 STOP ONLY FOR PIN ERROR
                            }


                            var status = result.Response;
                            var message = result.Message;
                            if (status == "GATEWAY") {
                                window.open(message, "_self");
                                $('#rchstatuschkinsur').text("Pending");
                                $('#rchmsginsur').text("Please Wait While Redirect The Gateway");
                            }
                            else {
                                $('#rchstatuschkinsur').text(status);
                                $('#rchmsginsur').text(message);

                                $("#txtpolicyno").val("");
                                $("#insuranceamount").val("");
                            }

                            $('#confirminsur').hide();
                            $('#rechargeconfirminsur').show();
                        },
                        complete: function () {
                            $("#remainretailer").load(location.href + " #remainretailer");
                            $('.loader').hide();
                            $.ajax({
                                url: '@Url.Action("showrecentrecharge", "Home")',
                                type: 'GET',
                                dataType: "html",
                                data: { type: "Insurance" },
                                success: function (data) {
                                    $('#reportchk').html(data);
                                },
                                error: function (data) {

                                }
                            });
                        },
                        error: function () {
                            $("#remainretailer").load(location.href + " #remainretailer");
                            $('.loader').hide();
                        }
                    })
               // }
            }
        }
        else {
              $("#servicefeeinsurance").css("border-color", "#FF0000");
        }
    }
</script>

<script>
    function Rechargeagaininsur() {
        $('#insurinfo').show();
        $('#confirminsur').hide();
        $('#rechargeconfirminsur').hide();
        j('#insuranceddltype').val("");
        j('#insuranceddltype').select2().trigger('change');
        $('#txtpolicyno').val("");
        $('#insuranceamount').val("");
        $('#txtDOB').val("");
        $('#txtemail').val("");
    }
</script>