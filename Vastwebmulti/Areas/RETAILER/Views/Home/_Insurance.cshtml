<script>
    var isPinOn = @Model.Ispin.ToString().ToLower();

    function insurprocessToPay() {

        if (isPinOn) {

            var pin = $('#InsurRechargepin').val();


            if (!pin) {
                alert('Please enter transaction PIN');
                $('#InsurRechargepin').focus();
                return;
            }

            insurrechargeconfirm(pin);
        }
        else {
            insurrechargeconfirm('');
        }
    }
</script>

<script>
    function showMsg(msg, type) {

        var color = (type === "success") ? "green" : "red";

        $('#insurmsgBox').html(
            '<div style="color:' + color + '; font-weight:bold;">' + msg + '</div>'
        );

        setTimeout(function () {
            $('#insurmsgBox').html('');
        }, 5000);
    }
</script>


