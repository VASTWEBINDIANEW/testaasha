<script src="~/Scripts/CheckValidation/valideatelocations.js"></script>
<script>
    function confirm(sspcode) {
        $('.errmsg').text("");
        var mobilecode = "#" + sspcode + "txtmobile";
        var emailcode = "#" + sspcode + "txtemail";
        var txtmobile1 = $('' + mobilecode + '').val();
        var email = $('' + emailcode + '').val();
        intRegex = /[0-9 -()+]+$/;
        var expr = /^([\w-\.]+)@@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([\w-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$/;
        if ((!intRegex.test(txtmobile1))) {
            $('.errmsg').text("Please enter a valid phone number.");
        }
        else if (txtmobile1.length == 10) {
            if (!expr.test(email)) {
                $('.errmsg').text("Please enter a valid email address");
            }
            else {
                $('.c_mobile').text(txtmobile1);
                $('.h_email').text(email);

                $('.purchaseconfirmcheck').show();
                $('.confirm-purch').hide();
            }
        }
        else {
            $('.errmsg').text("Please enter a valid phone number");
        }
    }
</script>

<script>
    function pay(sspcode, offerprice, planname, month, device) {
        
        latss = $('#latss').val();
        longloc = $('#longloc').val();
        $('#loadredmodel').show();
        $('.purchaseconfirmcheck').hide();
       
        var mobilecode = "#"+sspcode + "txtmobile";
        var emailcode = "#"+sspcode + "txtemail";
        var txtmobile = $(''+mobilecode+'').val();
        var email = $('' + emailcode + '').val();
      
   
          $.ajax({
              type: "POST", url: '@Url.Action("AddPurchase", "Home")',
              data: { 'sspcode': sspcode, 'offerprice': offerprice, 'planname': planname, 'month': month, 'txtmobile': txtmobile, 'email': email, 'device': device, latss: latss, longloc: longloc },
              dataType: 'json',
              cache: false,
              success: function (result) {
                  
                  $('#loadredmodel').hide();
                  $('.purchasesucces').show();
                
                  if (result == "DONE") {
                      $('.koibhe').text("Successfully Purchased");
                      $('.ghgh').show();
                      
                  }
                  else if (result == "PENDING") {
                      $('.koibhe1').text("Order Pending");
                        $('.ghgh1').show();
                  }
                  else {
                      
                      
                      $('.koibhe2').text(result);
                        $('.ghgh2').show();
                  }
                 
        }
    });
    }
</script>

