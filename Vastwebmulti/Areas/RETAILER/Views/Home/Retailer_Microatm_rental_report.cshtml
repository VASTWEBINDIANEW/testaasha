@using Vastwebmulti.Models;
@model IEnumerable<Vastwebmulti.Models.microatm_rental_report_Result>
@{
    ViewBag.Title = "Retailer_Microatm_rental_report";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Retailer").ToList();
    var favimage = "";
    if (usernname.Count() > 0)
    {
        if (usernname.SingleOrDefault().Role == "Retailer")
        {
            favimage = usernname.SingleOrDefault().NickName;

        }
    }
}


<link href="~/MainFrontDesign/css/Dashcustom.css" rel="stylesheet" />
<style>

    /* new css  */



    .layoutt-retailer section.content {
        margin-top: 95px;
        padding-top: 5px;
    }

    .bread-same-all-page li {
        margin: 6px 0;
    }

    .card .body {
        padding: 0px;
    }

    .table {
        margin-bottom: 0px;
    }

    .cardretailerlager {
        margin-bottom: 0;
    }

    .cl_set {
        width: 70%;
    }

    .col-md-2.despute-search {
        float: left;
        padding-left: 4px;
    }

    /* new css  */

    .dropdown-menu {
        margin-top: 97px !important;
    }

    .form-iconmy.form-iconmyss {
        z-index: 9;
    }

    @@media only screen and (max-width:990px) {
        .dispute-date {
            width: 45%;
        }

        .card.class-back-tra-fourdesign table {
            margin-top: 4px;
        }
    }

    @@media screen and (max-width:767px) {
        .cardaddclass-res .bread-same-all-page {
            width: 100% !important;
            padding-top: 0px !important;
        }

        .col-md-4.dispute-date.dispute-datelager.datelager-class {
            margin-bottom: 10px;
        }

        .table-responsive.table-responsive-responshive.tablethirddesign-new table {
            border: 1px solid var(--border-color);
        }
    }

    @@media only screen and (max-width:480px) {

        .cl_set {
            width: 100%;
            margin-bottom: 4px;
        }

        .dispute-date {
            width: 70%;
        }

            .dispute-date.dispute-datelager.datelager-class input {
                padding-right: 4px;
                text-align: right;
            }
    }
</style>
<section class="content content-margin-second content-fourdesign-page allpage-four-design-section" style="overflow-x:hidden;">
    <div class="container-fluid retailerledger-container" style="height:100vh;">

        <!--Four-Design-Page-Header-Start-->

        <div class="page-title-box-fourde">
            <h3>Microatm Rental Report</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard", "Home")" style="color:var(--fullbodybg-four);background: transparent;margin: 0;padding: 0;">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);" style="background: transparent; margin: 0; padding: 0;">My Account 1&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);" style="background: transparent; margin: 0; padding: 0;">MicroAtm Rental Report</a></li>
            </ul>
        </div>

        <!--Four-Design-Page-Header-End-->

        <div class="page-header-third">

            <div class="bread-same-all-page" style="width:auto;float:left;">
                <div class="col-md-6" style="width: auto; float: left; padding: 0;">
                    <ul style="margin:0;">
                        <li class="smli">
                            <a href="@Url.Action("Dashboard", "Home")" class="fullbodydycolorbg tmw-total-color-one">
                                Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width: 12px;margin-top: -2px;">
                            </a>
                        </li>

                        <li class="fullbodydycolorbg tmw-total-color-one">
                            MicroAtm Rental Report
                        </li>
                    </ul>
                </div>

            </div>

        </div>

        <div class="row clearfix" style="margin:0;">

            <div class="page-header-third">

                <div class="col-md-12" style="padding: 0; margin-bottom: 4px;">
                    <div class="card cardretailerlager legar-responshivewidth cardaddclass-res class-back-tra-fourdesign fix-bootmmarg-fourdesign">



                        @using (Html.BeginForm("Retailer_Microatm_rental_report", "Home", FormMethod.Post))
                        {

                            <div class="cl_set" style="float:left;">
                                <div class="col-md-6 dispute-date dispute-datelager datelager-class" style="float:left;position: relative;padding:0;">
                                    <div class="input-daterange input-group">
                                        <div class="datesate datesates">
                                            <div class="form-iconmy" style="top: 0px;left: 1px;padding: 6px 5px;"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                            @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;height:32px;", autocomplete = "off" })
                                        </div>
                                        <span class="input-group-addon" style="display:none;">
                                            <i class="fa fa-exchange" style="padding-top:8px;"></i>
                                        </span>
                                        <div class="datesate datesatese">
                                            <div class="form-iconmy form-iconmyss" style="top: 0px;left: 1px;padding: 6px 5px;"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                            @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;height:32px;", autocomplete = "off" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2 despute-search">
                                    <center>
                                        <button type="submit" class="btn bg-grey waves-effect retailer-search-second" style="margin-top: 4px; margin-left:-74px; height:36px;">
                                            <i class="fa fa-search" style="top:1px;font-size:16px;color:black;"></i>
                                            <span style="top:0px;color:black;">Search</span>
                                        </button>
                                    </center>
                                </div>
                            </div>

                            <div class="dispute-right dispute-new">
                                <div class="col-md-3 buttonPdf buttonPdfdispute retailer-pdf-second" style="text-align:right;">

                                    <button style="color:#555;" id="btnPDF">PDF</button>
                                    <button style="color:#555;" id="btnExport">Export</button>

                                </div>


                            </div>




                        }
                    </div>
                </div>

                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="padding:0;">
                    <div class="card class-back-tra-fourdesign">
                        <div class="body" style="">
                            <div class="table-responsive table-responsive-responshive tablethirddesign-new" style="position: inherit;">
                                <table class="table table-bordered table-striped table-hover example-second third-design-table" style="width:100%;background:#eae9e9;">
                                    <thead style="background-color:whitesmoke;">
                                        <tr>
                                            <th>S.N</th>
                                            <th>Frm&nbsp;Name</th>
                                            <th>DeviceId</th>
                                            <th>Plan&nbsp;Name</th>
                                            <th>Num.of&nbsp;Trans</th>
                                            <th>Trans&nbsp;Date</th>
                                            <th>Curr&nbsp;Date</th>
                                            <th>@favimage&nbsp;Pre</th>
                                            <th>@favimage&nbsp;Charge</th>
                                            <th>@favimage&nbsp;GST</th>
                                            <th>@favimage&nbsp;TDS</th>
                                            <th>@favimage&nbsp;Post</th>

                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{int i = 1;}
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@i</td>
                                                <td>@Html.DisplayFor(modelItem => item.Frm_Name)</td>
                                                <td>@Html.DisplayFor(modelItem => item.deviceid)</td>
                                                <td>@Html.DisplayFor(modelItem => item.planname)</td>
                                                <td>@Html.DisplayFor(modelItem => item.nooftrans)</td>
                                                <td>@Html.DisplayFor(modelItem => item.transdate)</td>
                                                <td>@Html.DisplayFor(modelItem => item.currdate)</td>
                                                <td>@Html.DisplayFor(modelItem => item.rempre)</td>
                                                <td>@Html.DisplayFor(modelItem => item.remcomm)</td>
                                                <td>@Html.DisplayFor(modelItem => item.remgst)</td>
                                                <td>@Html.DisplayFor(modelItem => item.remtds)</td>
                                                <td>@Html.DisplayFor(modelItem => item.rempost)</td>

                                            </tr>
                                            i++;
                                        }
                                    </tbody>
                                </table>


                                <div id="loadingdiv" style="text-align:center;display:none;margin-bottom:20px;">

                                    <div class="loadertablecssnew">Loading...</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

        </div>


    </div>
</section>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>

<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script type="text/javascript">
    $(function () {

               $('.input-daterange').datepicker({
                format: "yyyy-mm-dd",
                todayHighlight: true,
                autoclose: true

            });
            var val = '@ViewBag.chk';
            if (val != "post") {
                $("#txt_frm_date").datepicker("setDate", new Date());
                $("#txt_to_date").datepicker("setDate", new Date());
            }


        });
</script>