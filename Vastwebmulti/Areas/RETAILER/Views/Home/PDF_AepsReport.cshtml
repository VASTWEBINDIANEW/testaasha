@model IEnumerable<Vastwebmulti.Models.Aeps_Report_New_Result>
@{
    ViewBag.Title = "PDF_AepsReport";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>PDF_M_PossReport</title>
    <style>
        table {
            border-collapse: collapse;
        }

        table, td, th {
            border: 1px solid black;
        }

        thead {
            display: table-header-group
        }

        tfoot {
            display: table-row-group
        }

        tr {
            page-break-inside: avoid
        }
    </style>
</head>
<body>
    <table class="table table-bordered table-striped table-hover third-design-table" style="width:100%; font-size:12px;">
        <thead style="background-color:whitesmoke;">
            <tr>
                <th>S. No.</th>
                <th>Transaction&nbsp;Status</th>

                <th style="display:none;">From</th>
                <th>User&nbsp;Bank&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</th>
                @*<th>User&nbsp;Name</th>*@
                <th>User&nbsp;A/C</th>
                <th>User&nbsp;Aadhaar</th>
                <th>User&nbsp;Mobile</th>
                <th>User&nbsp;Name</th>

                <th>Net&nbsp;Amount</th>
                <th>User&nbsp;Fee</th>
                <th>Earn</th>
                <th>GST&nbsp;IN</th>
                <th>TDS</th>

                <th style="display:none;">View&nbsp;Status</th>
                <th style="display:none;">Merchant&nbsp;ID</th>
                <th style="display:none;">Req&nbsp;Date</th>
                <th style="display:none;">Transfer&nbsp;</th>
                <th style="display:none;">Mobile&nbsp;No</th>
                <th style="display:none;">User&nbsp;Credit&nbsp;</th>

                <th>Pre&nbsp;₹</th>
                <th>Cr&nbsp;/&nbsp;Dr</th>
                <th>Post&nbsp;₹</th>


                <th>Bank&nbsp;RRN&nbsp;&amp;&nbsp;Error&nbsp;Info..</th>
                <th>Request&nbsp;Time</th>

                <th style="display:none;">Terminal&nbsp;ID</th>
                <th style="display:none;">Remark</th>



            </tr>
        </thead>
        @if (Model != null && Model.Count() > 0)
        {
            int sno = 0;
            foreach (var item in Model)
            {
                sno += 1;
                <tr>
                    <td>@sno</td>
                    <td>@item.Status</td>
                    <td>
                        <p style="font-size:12px;">@item.BankName&nbsp;</p>
                    </td>
                    <td>@item.customerremain</td>
                    <td>
                        @if (item.AccountHolderAadhaar != null)
                        {
                            var resultID = "******" + System.Text.RegularExpressions.Regex.Match(item.AccountHolderAadhaar, @"(.{6})\s*$");
                            <p style="font-size:13px;">@resultID&nbsp;</p>
                        }
                    </td>

                    <td>@item.Mobile</td>
                    <td>@item.username</td>
                    <td>@String.Format("{0:0.00#}", item.Amount)</td>
                    <td>@item.charge</td>
                    <td>@item.RemIncome</td>
                    <td>@item.RemGST</td>
                    <td>0</td>
                    <td style="display:none;">
                        <p style="font-size:12px;">&nbsp;@item.MerchantTxnId&nbsp;</p>
                    </td>

                    <td style="display:none;"><p style="font-size:11px;">@String.Format("{0:dd-MMM HH:mm:ss}", item.Txn_Date)&nbsp;&nbsp;<span style="color:green;font-weight:700;"></span></p></td>
                    <td style="display:none;">
                        <p style="font-size:12px;">&nbsp;@String.Format("{0:0.00#}", item.Amount)&nbsp;</p>
                    </td>
                    <td style="display:none;"><p style="font-size:12px;">&nbsp;@item.Mobile&nbsp;</p></td>
                    <td style="display:none;">
                        @{
                            decimal amount = 0;
                            decimal remincome = 0;
                            decimal usercredit = 0;
                            if (item.Role == "Retailer")
                            {
                                amount = Convert.ToDecimal(item.Amount);
                                remincome = Convert.ToDecimal(item.RemIncome);
                                usercredit = (amount + remincome);
                            }
                        }
                        <p style="font-size:12px;">@String.Format("{0:0.00#}", usercredit)&nbsp;</p>
                    </td>



                    <td>
                        @{
                            decimal usercredit1 = 0;
                            if (item.Role == "Retailer")
                            {

                                usercredit1 = (Convert.ToDecimal(item.Amount) + Convert.ToDecimal(item.RemIncome));
                            }

                        }
                        <p style="font-size:13px;">@String.Format("{0:0.00#}", item.RemPre)</p>
                    </td>
                    <td><p style="font-size:13px;">@String.Format("{0:0.00#}", usercredit1)</p></td>
                    <td><p style="font-size:13px;">@String.Format("{0:0.00#}", item.RemPost)</p></td>

                    <td>
                        @if (item.Status.ToUpper() == "SUCCESS")
                        {
                            <p style="font-size:12px;">@item.BankRRN&nbsp;</p>
                        }
                        else
                        {
                            <p style="font-size:12px;">@item.Remark&nbsp;</p>
                        }
                    </td>
                    <td><p style="font-size:11px;">@String.Format("{0:dd-MMM HH:mm:ss}", item.Txn_Date)&nbsp;&nbsp;<span style="color:green;font-weight:700;"></span></p></td>


                    <td style="display:none;">
                        <p style="font-size:13px;">@item.TerminalId</p>
                    </td>
                    <td style="display:none;">
                        <p style="font-size:13px;">@item.Remark</p>
                    </td>

                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="18"><h2 style="text-align:center;">Data Not Found</h2></td>

            </tr>

        }

    </table>
</body>
</html>
