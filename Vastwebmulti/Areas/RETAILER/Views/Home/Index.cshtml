<!--start mobile number 6-9 javascript-->
<script>
    $(".pp").on('keypress blur', function (e) {

        var k = e.keyCode || e.which;
        var id = $(this)[0].id;
        var str = $(this)[0].value;
        var length = str.length;

        if (e.type == 'keypress') {
            if (k != 8 && k != 9) {
                k = String.fromCharCode(k);
                var regex = /[0-9]/;
                if (!regex.test(k)) {
                    return false;
                }

                var regexs = /[6-9]/;
                if (length == 0 && !regexs.test(k)) {
                    return false;
                }
            }
            return true;
        }
    });
</script>
