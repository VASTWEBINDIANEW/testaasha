                    }
                    else if (frm == "Nifi")
                    {
                        var list = JSON.parse(output.banklist);
                        var count = list.Content.ADDINFO.length;
                            var i;
                            var ddlCustomers = $("#banklistshow");
                            ddlCustomers.append(
                                $('<option></option>').val("").html("Select Bank")
                            );
                            for (i = 1; i < count; i++) {
                                ddlCustomers.append(
                                    $('<option></option>').val(list.Content.ADDINFO[i].BankIIN).html(list.Content.ADDINFO[i].BankName)
                                );

                            }

