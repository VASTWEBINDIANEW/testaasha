<script>

    function nextclick() {


        var txtphone = $('#txtphone').val();
        var amount = $('#txtamt').val();
        var myRadio = $("input[name=radio]");
        var checkedValue = myRadio.filter(":checked").val();
        if (checkedValue == "aadharpay") {
            type = "M";
            $('#txtphone').attr('readonly', true);
            $('#txtaadhar').attr('readonly', true);
            $('#txtusernm').attr('readonly', true);
            $('#txtamt').attr('readonly', true);
            $('#txtfee').attr('readonly', true);
            if (amount >= 5000) {
                $.ajax({
                    url: "@Url.Action("GenerateOTPFOR_AEPS_AADHARPAY", "Home")",
                    cache: false,
                    type: "POST",
                    data: { usermobile: txtphone, typess: type, amount: amount },
                    success: function (data) {

                        var stscode = data.status;
                        var msg = data.Details;
                        if (stscode == "OTP") {

                            $('#otpfortransfer').show();
                            $('#nextfund').show();
                            $('#nextclick').hide();

                        }
                        else {
                            //swal("Oops!!", msg, "error");
                            $('#OTPMSG').text(msg);
                        }
                    }
                })
            }
            else {
                $('#nextfund').show();
                $('#nextclick').hide();
            }
        }

    }


    function Nextransfer() {
        $('#showspinneraeps').show();
        setTimeout(() => {
        scanfing();
        var _isAeps2 = $('#tabs .tab-link.active').text() == 'Aeps 2';

        var otpss = "";
        var txtamt = $('#txtamt').val();
        var myRadio = $("input[name=radio]");
        var checkedValue = myRadio.filter(":checked").val();
        var type = "CW";
        if (checkedValue == "aadharpay") {
            type = "M";
            if (txtamt > 5000) {
                otpss = $('#txtotptransfer').val();
            }
        }
        if (checkedValue == "depositwithotp") {
            type = "CDO";
        }
        if (checkedValue == "deposit") {
            type = "CD";
        }
        $("#txterrortransfer").text("");
        var txtaadhar = $('#txtaadhar').val();
        var txtphone=$('#txtphone').val();
        var bankname = $("#banklistshow").find("option:selected").text();
        var iin = $('#banklistshow').val();
        var cap = $('#capAEPS').val();

            var capxml = $('#capxml').val();
            console.log(capxml)
        var remark = "";

        var servicefee =  $('#txtfee').val();
        var devicesrno = $('#devicesrno').val();
        var usernm = $('#txtusernm').val();
        var devicenm = $('#txtdevice').val();
        var pidata = $('#pidata_doc').val();
            pidata = escape(pidata);

            var requestData = {
                mobile: txtphone,
                uid: txtaadhar,
                bank: bankname,
                iin: iin,
                cap: cap,
                type: type,
                amount: txtamt,
                remark: remark,
                DeviceSrNo: devicesrno,
                servicefee: servicefee,
                usernm: usernm,
                devicenm: devicenm,
                userotp: otpss,
                pidata: pidata,
                _isAeps2,
                capxml
            };
            var jsonData = JSON.stringify(requestData);


        if (txtaadhar != "" && txtphone != ""  && devicesrno != "" && txtamt != "" && bankname!="Select Bank") {
            var chk = validate(txtaadhar);
            if (chk == true) {
                $.ajax({
                    url: '@Url.Action("AEPS_1","Home")',
                    cache: false,
                    data: jsonData,
                    type: "POST",
                    contentType: "application/json", // Set content type to JSON
                    beforeSend: function () {
                        $('.loader').show();
                    },
                    success: function (data) {

                        var sts = data.Status;

                        if (sts == "Failed") {
                            var msg = data.Message;


                            $('#capAEPS').val("");
                            $('#capxml').val("");
                            $('#devicesrno').val("");
                            $("#txterrortransfer").text(msg);
                            $('#capAEPS').val("");
                            $('#devicesrno').val("");
                            $('#nextfund').html('Confirm & Withdraw')
                        }
                        else {

                            var userinfo = data.userinfo;
                            var taxenable = userinfo.taxenable;
                            var paid = 0; var tax = 0;
                            if (taxenable == "N") {
                                paid = parseFloat(txtamt) - parseFloat(servicefee);
                            }
                            else {
                                tax = (parseFloat(servicefee) * 18) / 100;
                                paid = parseFloat(txtamt) - parseFloat(servicefee) - parseFloat(tax);
                            }

                            $('#aeps-Confirm-Payment').show();
                            $('#AEPSFOUND').hide();
                            $('#capAEPS').val("");
                            $('#capxml').val("");
                            $('#devicesrno').val("");
                            $('#amountaepssuccess').text(txtamt);
                            var rrnno = "RRN - " + data.Message.BankRrn;
                            $('#rrnaepssuccess').text(rrnno);
                            $("#logochkaepssuccess").attr("src", "../.." + userinfo.logo);
                            $('#aepssuccessfirm').text(userinfo.firmname);
                            $('#aepssuccessBankname').text(bankname);
                            $('#aepssuucessaadhar').text(txtaadhar);
                            $('#aepssuccessmobile').text(txtphone);
                            $('#aepssuccessremain').text(data.Message.BalanceAmount);
                            $('#aepssuccessamt').text(txtamt);
                            $('#aepssuccessfee').text(servicefee);
                            $('#aepssuccesstax').text(tax);
                            $('#paidamt').text(paid);
                        }
                    },
                    complete: function () {

                        $('.loader').hide();
                           onloaddata();
                    },
                    error: function () {

                        $('.loader').hide();
                    }
                })

            }
            else {
                $('#txterrortransfer').text("⚠ Enter Valid AADHAR");
            }
        }
        else {
            if (cap == "") {
                $('#txterrortransfer').text("⚠ Try Again");
            }
            else {
                $('#txterrortransfer').text("⚠ All Field Are Mandatory");
            }
            }
        }, 10)
    }
</script>
