<script>
    function SendOTP() {
        $('.loader').show();
        var url = '@Url.Action("RetailerOutletRegister", "Home")'
        $.ajax({
            url: url,
            cache: false,
            type: "POST",
            success: function (data) {
                $('.loader').hide();
                var stscode = data.Status;
                var msg = data.Message;
                if (stscode == "TXN") {

                    $('#otpShow').css('display', 'block');
                    $('#otpSubmit').css('display', 'block');
                    $('#OTPMSG').text(msg);
                }
                else {
                    //swal("Oops!!", msg, "error");
                    $('#OTPMSG').text(msg);
                }
            }
        })
    }
