<script>
        function Genrateotp() {
            $.ajax({
                url: '@Url.Action("GenrateOtp", "Home")',
                cache: false,
                type: "POST",
                beforeSend: function () {
                    $(".loader").show();
                },
                success: function (data) {

                    var output = data; //JSON.parse(data);

                    var status = output.Status;
                    var msg = output.Message;

                    if (status == "Success") {
                        var primarykey = output.primarykey;
                        var encodetxnid = output.encodetxnid;
                        $('#primaryhide').val(primarykey);
                        $('#encodehide').val(encodetxnid);
                        $('#divotpsend').hide();
                        $('#verifyotp').show();
                    }
                    else {
                        $('#otperror123').text(msg);
                    }
                },
                complete: function () {
                    $(".loader").hide();
                },
                error: function () {
                    $(".loader").hide();
                }
            })
        }
</script>
<script>
        function Verifyotp() {
            var otp = $('#txtotp').val();
            var primaryhide = $('#primaryhide').val();
            var encodehide = $('#encodehide').val();
            var apinm = $('#checkapi').val()
            if (otp == "") {
                $('#verifyotperr').text("Please Enter The OTP");
            }
            else {
                $.ajax({
                    url: '@Url.Action("VerifyotpEkyc", "Home")',
                    cache: false,
                    type: "POST",
                    data: { otp: otp, primaryhide: primaryhide, encodehide: encodehide, apinameinfo: apinm },
                    beforeSend: function () {
                        $(".loader").show();
                    },
                    success: function (data) {
                        var output = data;//JSON.parse(data);
                        var status = output.Status;
                        var msg = output.Message;
                        if (status == "Success") {
                            $('#divotpsend').hide();
                            $('#verifyotp').hide();
                            $('#scancheck').show();
                        }
                        else {
                            $('#verifyotperr').text(msg);
                        }
                    },
                    complete: function () {
                        $(".loader").hide();
                    },
                    error: function () {
                        $(".loader").hide();
                    }
                })
            }
        }
</script>
