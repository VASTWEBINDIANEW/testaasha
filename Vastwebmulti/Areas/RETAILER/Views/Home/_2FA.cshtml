<script>
        function ValidateDevice() {
            var cap = $('#cap').val();
            var capxml = $('#capxml').val();
            var devicesrno = $('#device_srno').val();
            var devicenm = $('#txtdevice').val();
            $('#namechnage').hide();
            $('#EditName').show();
            $('#updatename').hide();
            var apinm = $('#checkapi').val()

            var requestData =  {
                cap,
                capxml,
                devicesrno,
                devicenm,
                apinm
            };
            var jsonData = JSON.stringify(requestData);
    
                $.ajax({
                    url: '@Url.Action("Validate2FA", "Home")',
                    cache: false,
                    type: "POST",

                    contentType: "application/json", // Set content type to JSON
                    data: jsonData,
                    beforeSend: function () {
                        $(".loader").show();
                    },
                    success: function (data) {
                        $('#cap').val("");
                        $('#capxml').val("");
                        $('#device_srno').val("");
                        $('#txtdevice').val("");
                        var output = data; //JSON.parse(data);
                        var status = output.Status;

                        var msg = output.Message;
                        if (status == "Success") {
                            var url = '@Url.Action("Money_transfer2", "Home", new {id="AEPS"})';
                            window.location.href = url;
                        }
                        else {
                            $('#errdevicefind').text(msg);
                        }
                    },
                    complete: function () {
                        $(".loader").hide();
                    },
                    error: function () {
                        $(".loader").hide();
                    }
                })
           
    }
</script>
