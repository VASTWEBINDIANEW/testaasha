            function fundtransfercreadit(e, b, i) {
                $('#benidss').val(i);
                $('#paymentmodetransfer').text('');
                $('modf').text('CREDIT CARD');
                //$('#creadittransfer').show();
                //$('#ccbanknametransfer').html(bank);
                //$('#ccbencodetransfer').html(id);
                //$('#ccifsccodetransfer').html(ifsc);
                //$('#ccnotransfer').html(account);

                var type = $('input[name=bendetails]:checked', '#myForm').val();
                var str = $(e).closest('td').prev('td').html();
                var bencode = str.substring(str.lastIndexOf("<span style='display:none;'>") + 29, str.lastIndexOf("</span><p"));
                var bankname = str.substring(str.lastIndexOf(">BANK:") + 6, str.lastIndexOf("</p><strong>"));

                var Name = str.substring(str.lastIndexOf("<strong>") + 8, str.lastIndexOf("</strong>"));
                var Account = b;
                var ifsccode = str.substring(str.lastIndexOf("IFSC:") + 5, str.lastIndexOf("</span>"));
                $('#ccdivbankifsc').show();

                $('#ccifsccodetransfer').text(ifsccode);
                $('#ccnotransfer').text(Account);
                $('#ccNametransfer').text(Name);
                $('#ccbanknametransfer').text(bankname);
                $('#ccbencodetransfer').text(bencode);
                $('#creadittransfer').show();
                $('#dmttransfer').hide();
                $('#remlist').hide();
            }
        </script>
        <script>
            function Registerbencreditcard() {
                debugger;
                var name = $('#benname11').val();
                var mobile = $('#senderno').val();
                var ifsc = $('#ifsccodecreaditcard').val();
                var ifscoriginal = $('#hidebankifsc').val();
                var bank = $('#Cardbanknm111').val();
                var cardno = $('#cardsno').val();
                if (isBlank(name) || isBlank(ifsc) || isBlank(bank) || isBlank(cardno)) {
                    document.getElementById('verifycreditcard').innerHTML = 'All Values are Required';
                }
                else {
                    if (cardno.length != 16)
                    {
                        document.getElementById('verifycreditcard').innerHTML = 'Invalid Card no.';
                    }
                    else {

                        $.ajax({
                            type: "POST",
                            url: '@Url.Action("savebencreaditcard", "Home")',
                            data: { name: name, Mobile: mobile, Ifsc: ifsc, OriginalIfsc: ifscoriginal, Account:cardno},
                            success: function (result) {
                                console.log(result);
                                if (result.sts == "TXN") {
                                    back();
                                    $('#creaditcardnew').hide();
                                }
                                else {
                                    document.getElementById('verifycreditcard').innerHTML = result.mess;
                                }
                            }
                        });
                    }
                }

            }
            function isBlank(str) {
                return (!str || /^\s*$/.test(str));
            }
            function bankifdd() {
                debugger;

                var selectv = $('#Cardbanknm111').val();
                var vall = "";
                if (selectv != "") {

                    for (var i = 0; i < banskks.length; i++) {
                        var chk = banskks[i];
                        if (chk.includes(selectv)) {
                            vall = chk;
                        }

                    }
                    var chk = vall.split('!');



                    $('#ifsccodecreaditcard').val(chk[1]);
                    $('#hidebankifsc').val(chk[1]);
                }



            }
            function credicardshow() {
                var cal = document.getElementsByClassName('holddder');
                cal[0].style.display = 'none';
                document.getElementById('upiaddnew').style.display = 'none';
                document.getElementById('walletaddnew').style.display = 'none';
                document.getElementById('creaditcardnew').style.display = 'block';

            }
        </script>
        <script>
                    var banskks = [];

                       $.ajax({
