                               var bankid = document.getElementById('Cardbanknm111');

                               for (var i = 0; i < result.length; i++){
                                   banskks[i] = result[i].bankname + "!" + result[i].ifsccode;

                               }
                               var option = document.createElement('option');
                               option.value = '';
                               option.text = 'Select Bank';
                               bankid.appendChild(option);


                               for (var j = 0; j < result.length; j++) {
                                   var option1 = document.createElement('option');
                                   option1.value = result[j].bankname
                                   option1.text = result[j].bankname
                                   bankid.appendChild(option1);
                               }

                           }
  });
