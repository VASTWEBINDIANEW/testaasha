@using Microsoft.AspNet.Identity
@using Vastwebmulti.Models;
@{
    VastwebmultiEntities DB = new VastwebmultiEntities();
    var stsotp = "N";
    var dmtotpsts = DB.dmtpin_otp_status.SingleOrDefault();
    if (dmtotpsts != null)
    {
        if (dmtotpsts.status == true)
        {
            stsotp = "Y";
        }
    }
}
<style>
    /* New css */
    /*.tabspage .tab-content {
     height: auto;
 }*/
    @@keyframes blink {
        0% {
            color: #fff;
        }

        50% {
            color: Yellow;
        }

        100% {
            color: black;
        }
    }

    .col-md-12.remitter_button {
        padding: 9px;
    }
    /* New css */
    .loader {
        position: fixed;
        top: -90px;
        left: 0;
        background-color: rgba(255,255,255,0.7);
        z-index: 999999999999;
        display: none;
        height: 100vw;
        width: 100vw;
    }

    .col-md-2.add_account a {
        margin-top: 5px;
    }

    @@-webkit-keyframes spin {
        from {
            -webkit-transform: rotate(0deg);
        }

        to {
            -webkit-transform: rotate(360deg);
        }
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .loader::after {
        content: '';
        display: block;
        position: absolute;
        left: 48%;
        top: 25%;
        width: 100px;
        height: 100px;
        border-style: solid;
        border-color: black;
        border-top-color: transparent;
        border-width: 4px;
        border-radius: 50%;
        -webkit-animation: spin .8s linear infinite;
        animation: spin .8s linear infinite;
    }

    #addaccount-add123_again {
        float: right;
        font-size: 9px;
        color: var(--main-bg-lcolor);
        font-weight: 600;
        padding: 0px 11px;
        margin-top: 4px;
        border: 1px solid #ddd;
        margin-right: 8px;
    }

        #addaccount-add123_again label {
            font-weight: 400;
            margin: 0px;
        }

    .amount-image {
        position: absolute;
        right: 0;
    }

        .amount-image button {
            height: 34px;
            display: flex;
            align-items: center;
        }

    .selfiphoto div#camera, .selfiphoto div#camera video {
        width: 100% !important;
    }

    .selfiphoto input#btPic {
        margin-right: 0;
        width: auto;
        margin-top: 0px;
        width: 100%;
        background: #ddd;
        color: #000;
        height: auto;
        text-transform: uppercase;
        font-size: 18px;
        text-align: center;
        margin: 0px auto;
        display: block;
    }

    .selfiphoto .modal-dialog {
        margin-top: 105px;
    }

        .selfiphoto .modal-dialog .modal-header {
            background: transparent;
            border: 0 !important;
            padding: 0 15px;
            position: relative;
        }

            .selfiphoto .modal-dialog .modal-header button span {
                font-size: 14px;
                color: #000;
                position: relative;
                left: -13px;
            }

    .selfiphoto .modal-dialog {
        width: 420px;
        padding: 0 !important;
    }

        .selfiphoto .modal-dialog .modal-body {
            padding: 30px 0px !important;
        }

        .selfiphoto .modal-dialog .modal-header button {
            border: 0;
            background: #ddd;
            width: 28px;
            height: 26px;
            position: absolute;
            top: 0px;
            right: 0;
            z-index: 99;
        }

    i.fa.fa-camera.cameraiconadd {
        position: absolute;
        top: 12px;
        left: 29%;
        font-size: 18px;
    }

    .imgselfishow {
        width: 43px;
        height: 34px;
        position: relative;
        top: 0px;
        margin: 0;
    }

        .imgselfishow img {
            width: 100%;
            height: 100%;
        }

    .selfiphoto input#btPic {
        width: 363px;
    }

    .addpaymentwallet {
        display: flex;
        justify-content: space-between;
    }

    .radiobuttonimps .addpaymentwallet label.container {
        width: auto;
        margin-right: 3px;
        margin-left: 0;
    }

    .upiaddnewclass input {
        margin-right: 0px;
    }

    .vpaverifyclass {
        float: left;
        background: transparent !important;
        border: 1px solid #ddd;
        padding: 2px 8px;
        margin-top: 4px;
        color: #545454;
        position: absolute;
        right: 4px;
    }

    .col-md-12.next-page .button-classadd.body-border-bottom {
        min-height: 94px;
    }

    @@media screen and (max-width:1366px) {
        .radiobuttonimps label.container {
            font-size: 13px;
        }
    }

    @@media screen and (max-width:766px) {
        .selfiphoto .modal-dialog {
            width: 95%;
            padding: 0 !important;
        }

            .selfiphoto .modal-dialog .modal-body {
                padding: 0px 0px !important;
            }

        i.fa.fa-camera.cameraiconadd {
            left: 26%;
        }

        .selfiphoto input#btPic {
            width: 100%;
        }

        .dmttransfer-responshivee .amount.radiobuttonimps label {
            font-size: 9px;
            font-weight: 400;
        }

        .upiaddnewclass .amount.amount_strong strong, .upiaddnewclass .amount.amount_strong input {
            width: 100% !important;
        }

        .radiobuttonimps label p {
            font-weight: 400;
            font-size: 11px;
        }
    }
</style>
<style>
    .button-container {
        display: flex; /* Use flexbox to align the buttons side by side */
        justify-content: space-between; /* Center the buttons horizontally */
        gap: 10px; /* Add space between the buttons */
        padding-bottom: 12px;
    }

        .button-container .btn {
            padding: 8px 18px;
            border: none;
            background-color: var(--main-bg-lcolor); /* Primary color */
            color: #fff;
            cursor: pointer;
            font-size: 16px;
            border-radius: 4px !important;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
        }

            .button-container .btn i {
                top: 0 !important;
                margin-right: 6px;
                font-size: 16px !important;
            }

            .button-container .btn:hover {
                background-color: var(--main-bg-lcolor); /* Darker shade on hover */
            }

        .button-container .btn-secondary {
            background-color: #c4c4c4; /* Secondary color */
            color: #000;
        }

            .button-container .btn-secondary:hover {
                background-color: var(--main-bg-lcolor); /* Darker shade on hover */
                color: #fff;
            }
    @@media only screen and (max-width:480px) {
        .button-container {
            display: block;
            text-align: center;
        }
            .button-container .btn {
                margin-bottom: 8px;
                text-align: center;
                display: block;
            }
    }


</style>
