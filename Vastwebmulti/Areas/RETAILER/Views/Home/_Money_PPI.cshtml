<script>

    sendotp = () => {
        var aadhar = $('#aadharnumber_sender').val();
        var senderno = $('#changesender').val();
        if (aadhar != "") {
            var check = validate(aadhar);
            if (check == false) {
                $('#errmsgaadhar').text("Enter Valid aadhar");
            }
            else {
                var url = "@Url.Action("AadharVerificationOtpSent_Money", "Home")"
                var data = { aadhar: aadhar, senderno: senderno }
                var req = JSON.stringify(data)
                fetch(url, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: req
                }).then(Response => Response.json()).then(data =>
                {
                    if (data.Status == true) {
                        $('#errmsgaadhar').text("");
                        $('#Clientid').val(data.clientId);
                        $('#txnid').val(data.txnid);
                        $('#sendotpaadhar').hide();
                        $('#validateaadhar').show();
                    }
                    else {
                        $('#errmsgaadhar').text(data.Message);
                    }
                }).catch(err => $('#errmsgaadhar').text(err));

            }
        }
        else {
            $('#errmsgaadhar').text("Enter Aadhar Number");
        }

    }
    validotp = ()=>{
        var otp = $('#aadharnumber_OTP').val();
        if (otp != "") {
            var sendernm = $('#changesender').val();
            var clientid = $('#Clientid').val();
            var txnid = $('#txnid').val();
            var aadhar = $('#aadharnumber_sender').val();
               var url = "@Url.Action("AadharVerificationOtpVerify_money", "Home")"
            var data = { client_id: clientid, otp: otp, aadhar: aadhar, senderno: sendernm, txnid: txnid }
                var req = JSON.stringify(data)
                fetch(url, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: req
                }).then(Response => Response.json()).then(data =>
                {
                    if (data.Status == true) {
                        $('#errmsgaadharotp').text("");
                        senderdetails(sendernm);
                    }
                    else {
                        $('#errmsgaadharotp').text(data.Message);
                    }
                }).catch(err => $('#errmsgaadharotp').text(err));


        } else {
            $('#errmsgaadharotp').text("Enter Otp");
        }
    }


    validkyc = () => {
        $('#transfer_fund').hide()
        $('#kycverifyed').show()
    }

</script>
