<script>
    upibenlist = (senderno, cb) => {
        var url = '@Url.Action("UPI_Senderdetails", "Home")';
        var data = { senderno: senderno };
        var requ = JSON.stringify(data);
        $("#upibenlistttable tr").remove();
         fetch(url, {
             method: "POST",
             headers: {
                 "Content-Type": "application/json"
             },
             body: requ
         }).then(Response => Response.json())
             .then(resp => {
                 var statuscode = resp.statuscode;
                 if (statuscode == "TXN") {
                     typeof cb == 'function' && cb(null, resp.Response);
                     for (let i = 0; i < resp.Response.length; i++) {
                         var output = JSON.parse(resp.Response)[i];
                         var id = output.idno;
                         var senderno = output.senderno;
                         var UPIID = output.UPIID;
                         var name = output.BenName;
                         var isverified = output.isverified;
                         $('#upibenlistttable').append('<tr id=' + id + '><td><span style="display:none;">' + id + '</span><strong>' + name + '</strong><br /><span>VPA ID: ' + UPIID + '</span><br /></td><td><div style="display:none;"><span>"' + isverified + '"</span></div><div class="Transferdata"><a href="#" class="addtabledata" onclick=fundtransferUPI(this)></a><button id="btn' + id + '"  class="addtabledatade click-displays" onclick=deleteshow("' + id + '")><i class="fa fa-trash"></i></button><a href="javascript:void(0);" id="aa' + id + '" class="addtabledatade click-delete" onclick=upideleteben("'+id+'")>sure <Strong>?</Strong></a> </div></td></tr>');

                     }
                 }
                 else {
                     typeof cb == 'function' && cb('Something Went Wrong!');
                 }
             }).catch(err => {
                 console.log(err)
                 typeof cb == 'function' && cb(err.message);
             });

    }
</script>
