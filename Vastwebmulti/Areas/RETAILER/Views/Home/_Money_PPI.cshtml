<script>
    walletRegisterben = () => {
        $('#walletaddaccount-add123').show();
        $('#walletaddaccount-addasssss').html("<i class='fa fa-circle-o-notch fa-spin'></i>");
        $('#benerror').text("");
        $('#sendererror').text("");
        const senderno = $('#changesender').val();
        const account = $('#walletid').val();
        if (account.length == 10) {
            const benname = $('#walletbenname').val();
            if (senderno != "" && account != "" && benname != "") {
                const url = "@Url.Action("Register_ben_WALLET","Home")";
                const data = { senderno: senderno, account: account, benname: benname };
                const reqdata = JSON.stringify(data);
                fetch(url, {
                    method: "POST",
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: reqdata
                }).then(Response => Response.json()).
                    then(data => {
                        $('#walletid').val("");
                        $('#walletbenname').val("");
                        $('#walletaddaccount-addasssss').html('Add Account')
                        var sts = data.status;
                        var msg = data.message;
                        if (sts == true) {
                            senderdetails("change");
                        }
                        else {
                            $('#benerror').text(msg);
                        }
                    }).catch(err => alert(err));
            }
        }
        else {
            $('#benerror').text("Paytm Number must be 10 Digit");
            $('#walletaddaccount-addasssss').html("<span>Add Account</span>");
        }
    }
</script>
<script>
    upiRegisterben = () => {
        $('#upiaddaccount-add123').show();
        $('#upiaddaccount-addasssss').html("<i class='fa fa-circle-o-notch fa-spin'></i>");
        $('#benerror').text("");
        $('#sendererror').text("");
        const senderno = $('#changesender').val();
        const account = $('#vpaid').val();
        const benname = $('#upibenname').val();

        if (senderno != "" && account != "" && benname != "") {
            const url = "@Url.Action("Register_ben_UPI","Home")";
            const data = { senderno: senderno, account: account, benname: benname };
            const reqdata = JSON.stringify(data);
            fetch(url, {
                method: "POST",
                headers: {
                    'Content-Type': 'application/json',
                },
                body: reqdata
            }).then(Response => Response.json()).
                then(data => {
                    $('#vpaid').val("");
                    $('#upibenname').val("");
                    $('#upiaddaccount-addasssss').html('Add Account')
                    var sts = data.status;
                    var msg = data.message;
                    if (sts == true) {
                        senderdetails("change");
                    }
