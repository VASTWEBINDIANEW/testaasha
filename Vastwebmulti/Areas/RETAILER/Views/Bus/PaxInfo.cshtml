@model Vastwebmulti.Areas.RETAILER.ViewModels.BusPaxInfoVM
@{
    ViewBag.Title = "Travel";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
    var markup = ViewBag.RetailerMarkup;
}
<style>
    .scrollypy {
        overflow-y: auto !important;
        height: 250px;
    }

    .table {
        display: table; /* Allow the centering to work */
        margin: 0 auto;
    }

    ul#horizontal-list {min-width: 696px;list-style: none;padding-top: 20px;}

        ul#horizontal-list li {display: inline;text-align: center;padding: 20px;}

    span.field-validation-error {font-size: 12px;display: block;margin-top: 5px;font-weight: normal;color: #F44336;}
    .buspax-infoclass .block-header {width: 100%;float: left;background:#a4a0a0;margin-top:15px;}
    .buspax-infoclass .block-header h2 {color: #000 !important;}
    .buspax-infoclass .bus-detailesshowtable .bus-bookingdetailesclass{background: #f5f5f5 !important;border: 1px solid #e7e7e7;}
    .buspax-infoclass .bus-detailesshowtable .bus-bookingdetailesclass .header {padding: 15px 20px;}
    .buspax-infoclass .bus-detailesshowtable .bus-bookingdetailesclass .header h2 {font-weight: bold;color: #555;}
    .buspax-infoclass .bus-detailesshowtable .form-group select, .buspax-infoclass .bus-detailesshowtable .form-group input {
    border: 1px solid #c4bfbf;
}
    .buspax-infoclass .bus-detailesshowtable .form-group .help-info {
    float: left;margin: 0;margin-bottom: 0px;float: left;width: 100%;
    color: #555;margin-bottom: 3px;text-transform: capitalize;text-align: left;
}
    .buspax-infoclass .bus-detailesshowtable .bus-titleclass {width: 12%;float: left;}
    .buspax-infoclass .bus-detailesshowtable .bus-nameclass {width: 30%;float: left;padding-right: 0;}
    .buspax-infoclass .bus-detailesshowtable .age-busclass {width: 12%;float: left;}
    .buspax-infoclass .bus-detailesshowtable .gender-menclass {width: 16%;float: left;}
    .buspax-infoclass .bus-detailesshowtable .age-busclass input {-webkit-appearance: none;-moz-appearance: textfield;}
    .buspax-infoclass .bus-detailesshowtable .busmobilenimber, .buspax-infoclass .bus-detailesshowtable .busemailid, .buspax-infoclass .bus-detailesshowtable .busidnumber, .buspax-infoclass .bus-detailesshowtable .busidproof {
    width: 25%;float: left;padding-right: 0;
}
    .buspax-infoclass .bus-detailesshowtable .busidnumber{padding-right:15px;}
    .buspax-infoclass .bus-detailesshowtable .form-group select:focus, .buspax-infoclass .bus-detailesshowtable .form-group input:focus{border-color:#000;}
    .buspax-infoclass .bus-detailesshowtable .form-group select {-webkit-appearance: none;
    background: url('../../ashok-images/down-arrow11.svg')no-repeat right;
    background-position-x: right 5px !important;background-position-y: center;
    background-size: auto;background-size: 12px;background-color: #fff;
}
    .buspax-infoclass .block-header h2 {color: #fff !important;font-weight: bold;}
    .buspax-infoclass .block-header {margin-bottom: 0px !important;}
    .buspax-infoclass .bus-detailesshowtable button.bussbookingsucces {
    background: transparent !important;color: #555;float: right;
    font-size: 18px;border: 2px solid #555;padding: 6px 35px;transition:.4s linear;
}
    .buspax-infoclass .bus-detailesshowtable button.bussbookingsucces:hover{background:var(--main-bg-lcolor) !important;transition:.4s linear;border-color:var(--main-bg-lcolor);color:#fff;}
    .full-fare-detailsclass {width: 100%;float: left;background: #f5f5f5;border: 1px solid #e7e7e7;margin-top: 15px;} 
    .full-fare-detailsclass .block-header {border-bottom: 1px solid #c4bfbf;padding: 10px 8px !important;}
    .full-fare-detailsclass .block-header h2 {font-size: 18px;}
    .full-fare-detailsclass .card .body.bg-white {background: transparent !important;padding: 10px 8px;}
    .full-fare-detailsclass .card {margin-bottom: 0;}
    .full-fare-detailsclass .card {background: transparent;}
    .card.card-rulesbusclass {background: #f5f5f5;border: 1px solid #e7e7e7;margin-top: 15px;padding: 0 0px;}
    .card.card-rulesbusclass .header {padding: 10px 8px;border-bottom: 1px solid #c4bfbf;}
    .card.card-rulesbusclass .header h2 {color: #555 !important;font-size: 18px;}
    .card.card-rulesbusclass .body.bg-white {background: transparent !important;padding: 10px 8px !important;}
    .card.card-rulesbusclass .body.bg-white strong {padding: 2px;width: 100%;float: left;margin-bottom: 5px;}
    .card.card-rulesbusclass .table-busdetailsclass table tr th, .card.card-rulesbusclass .table-busdetailsclass table tr td, .card.card-rulesbusclass .table-busdetailsclass table, .card.card-rulesbusclass .table-busdetailsclass table tr {
    border-color: #c4bfbf;
}
    .card.card-rulesbusclass .table-busdetailsclass table tr th, .card.card-rulesbusclass .table-busdetailsclass table tr td {
    padding: 10px 10px;
}
    .table-busdetailsclass {overflow: auto;padding-bottom: 10px;}
    .buspax-infoclass{width:70%;float:left;}
    .pax-info-second{width:30%;float:left;}
    .col-md-9.buspax-infoclass {padding-right: 6px;}
  .buspax-infoclass .bus-detailesshowtable button.bussbookingsucces:nth-child(2) {margin-right: 1%;}

  @@media screen and (max-width:768px){
      .pax-info-second {width: 100%;float: left;margin-top: 40px;}
      .buspax-infoclass {width: 100%;float: left;padding: 0 !important;}
      .row.rowclassresponsive {margin-left: 0;}
      .full-fare-detailsclass {margin-top: 0;}
      .card.card-rulesbusclass .table-busdetailsclass table tr th, .card.card-rulesbusclass .table-busdetailsclass table tr td {white-space: nowrap;}

  }
  @@media screen and (max-width:580px) {
        .buspax-infoclass .bus-detailesshowtable .bus-titleclass, .buspax-infoclass .bus-detailesshowtable .bus-nameclass, .buspax-infoclass .bus-detailesshowtable .age-busclass, .buspax-infoclass .bus-detailesshowtable .gender-menclass, .buspax-infoclass .bus-detailesshowtable .busmobilenimber, .buspax-infoclass .bus-detailesshowtable .busemailid, .buspax-infoclass .bus-detailesshowtable .busidnumber, .buspax-infoclass .bus-detailesshowtable .busidproof {
            width: 100%;float: left;padding-right: 15px !important;padding-left: 15px;
        }

        .bus-bookingdetailesclass .body .row.clearfix > div {margin-bottom: 0;} 
    } 

</style>
<link rel="stylesheet" href="http://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
<link rel="stylesheet" href="http://netdna.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
<link href="~/AdminDesign/Retailer_Slider/Slieder.css" rel="stylesheet" />
@*@Html.Partial("_FareQuote",Model.FareQuoteVM)*@
<section class="content" style="margin-left: 10px;margin-right: 10px;">
    <div class="container-fluid">
        <div class="row rowclassresponsive">
            <div class="col-md-3 pax-info-second">
                <div class="row">
                    <div class="full-fare-detailsclass">
                        <div class="block-header" style="padding: 12px 0 12px 1px; margin-bottom: 0px;">
                            <h2>Fare Details</h2>
                        </div>
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="padding:0;">
                            <div class="card">
                                <div class="body bg-white">
                                    @{
                                        var priceToShow = markup + Model.bookInfo.Passenger.Sum(a => a.Seat.Price.PublishedPriceRoundedOff);
                                    }
                                    <div>
                                        Base Fare <span class="pull-right">@Model.bookInfo.Passenger.Sum(a => a.Seat.Price.BasePrice)</span><br>
                                        GST <span class="pull-right"></span><br>
                                        Other Tax/Charges <span class="pull-right">@Model.bookInfo.Passenger.Sum(a => a.Seat.Price.Tax + a.Seat.Price.OtherCharges)</span><br>
                                        <strong>Total Fare <span class="pull-right" id="totalPubFare">@priceToShow</span></strong>
                                        <br>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row" style="margin:0;width:100%;float:left;">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="padding:0;width:100%;float:left;">

                            <div class="card card-rulesbusclass" style="width:100%;float:left;">
                                <div class="header" style="width:100%;float:left;">
                                    <h2>
                                        Onward Journey Details
                                    </h2>

                                </div>
                                <div class="body bg-white" style="background:transparent;padding:0;width:100%;float:left;">
                                    @{

                                    }
                                    <div class="table-busdetailsclass" style="width:100%;float:left;">
                                        <table border="1" style="width:100%;float:left;">
                                            <thead>
                                                <tr>
                                                    <th colspan="2">@Model.bookInfo.sourceCity TO @Model.bookInfo.destinationCity</th>
                                                </tr>
                                                <tr>
                                                    <td colspan="2">on @Model.bookInfo.doj at @Model.bookInfo.boardingPoint.CityPointTime</td>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <th>Boarding&nbsp;Point</th>
                                                    <td>@Model.bookInfo.boardingPoint.CityPointLocation</td>
                                                </tr>
                                                <tr><th colspan="2">@Model.busOperatorName</th></tr>
                                                <tr>
                                                    <th>Seats</th>
                                                    <td>@Model.selectedSeatsName</td>
                                                </tr>
                                            </tbody>

                                        </table>
                                        
                                    </div>
                                </div>
                            </div>
                        </div>


                    </div>
                </div>
            </div>

            <div class="col-md-9 buspax-infoclass">
                <!-- Flight Details start -->
                <div class="block-header" style="padding: 12px 0 12px 1px; margin-bottom: 20px; ">
                    @*<h2>NO HEADER CARDS</h2>*@
                    <div class="col-md-12 pull-left">
                        <h2>Bus & Payment Preview</h2>
                    </div>
                    <div class="col-md-6" style="text-align:right;display:none;">
                        @*<button type="button" class="btn bg-purple waves-effect pull-right">
                        <i class="material-icons">search</i>
                        <span>Modify Search</span>
                    </button>*@
                        @*<a src="javascript:void(0)">change Flight</a>*@
                    </div>
                </div>
                <div class="row" style="margin:0;">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 bus-detailesshowtable" style="padding:0;">
                        <div class="card">
                            <div class="body bg-white" style="padding-left:0;padding-right:0;">
                                <div class="table">
                                    <div class="row clearfix" style="margin:0;">
                                        <div class="timeDiv col-md-12" style="padding-right:0px;padding-left:0px;">
                                            @using (Html.BeginForm("SeatBooking", "Bus", FormMethod.Post))
                                            {
                                                @Html.ValidationSummary(true)
                                                @Html.ValidationMessage("CustomError")
                                                List<SelectListItem> Title = new List<SelectListItem>()
                                                                                                    {
                                                                      new SelectListItem {Text="MR",Value="Mr",Selected=false },
                                                                      new SelectListItem {Text="Ms",Value="Ms" },
                                                                      new SelectListItem {Text="Mrs",Value="Mrs"},
                                                                      new SelectListItem {Text="Miss",Value="Miss"},
                                                                      new SelectListItem {Text="Mstr",Value="Mstr" },
                                                                    };
                                                @Html.HiddenFor(m => m.bookInfo.sourceCity)
                                                @Html.HiddenFor(m => m.bookInfo.destinationCity)
                                                @Html.HiddenFor(m => m.bookInfo.doj)
                                                @Html.HiddenFor(m => m.bookInfo.boardingPoint.CityPointIndex)
                                                @Html.HiddenFor(m => m.bookInfo.boardingPoint.CityPointLocation)
                                                @Html.HiddenFor(m => m.bookInfo.boardingPoint.CityPointTime)
                                                @Html.HiddenFor(m => m.bookInfo.droppingPoint.CityPointIndex)
                                                @Html.HiddenFor(m => m.bookInfo.droppingPoint.CityPointLocation)
                                                @Html.HiddenFor(m => m.bookInfo.droppingPoint.CityPointTime)
                                                @Html.HiddenFor(m => m.busOperatorName)
                                                @Html.HiddenFor(m => m.selectedSeats)
                                                @Html.HiddenFor(m => m.bookInfo.ResultIndex)
                                                int PaxCounter = 1;
                                                foreach (var item in Model.bookInfo.Passenger)
                                                {
                                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 bus-bookingdetailesclass" style="padding-left: 0px;padding-right: 0px;">
                                                        <div class="">
                                                            <div class="header">
                                                                <h2>Passanger @PaxCounter  </h2>
                                                            </div>
                                                            <div class="body">
                                                                <div class="row clearfix">
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.ColumnNo)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Height)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.IsLadiesSeat)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.IsMalesSeat)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.IsUpper)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.RowNo)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.SeatFare)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.SeatIndex)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.SeatName)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.SeatStatus)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.SeatType)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Width)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.AgentCommission)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.AgentMarkUp)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.BasePrice)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.CurrencyCode)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.Discount)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.GST)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.OfferedPrice)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.OfferedPriceRoundedOff)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.OtherCharges)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.PublishedPrice)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.PublishedPriceRoundedOff)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.Tax)
                                                                    @Html.HiddenFor(m => m.bookInfo.Passenger[PaxCounter - 1].Seat.Price.TDS)
                                                                    @Html.HiddenFor(m => m.bookInfo.BoardingPointId)
                                                                    @Html.HiddenFor(m => m.bookInfo.DropingPointId)
                                                                    @Html.HiddenFor(m => m.bookInfo.TraceId)

                                                                    <div class="col-md-1 m-r-0 p-r-0 bus-titleclass">
                                                                        <div class="form-group form-float">
                                                                            <div class="help-info">Title</div>
                                                                            <div class="form-line focused">
                                                                                @Html.DropDownListFor(m => m.bookInfo.Passenger[PaxCounter - 1].Title, Title, "Title", new { @class = "form-control" })
                                                                            </div>

                                                                            @Html.ValidationMessageFor(m => m.bookInfo.Passenger[PaxCounter - 1].Title, "")
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-3 bus-nameclass">
                                                                        <div class="form-group form-float">
                                                                            <div class="help-info">First Name</div>
                                                                            <div class="form-line ">
                                                                                @Html.TextBoxFor(m => m.bookInfo.Passenger[PaxCounter - 1].FirstName, new { @class = "form-control" })
                                                                            </div>

                                                                            @Html.ValidationMessageFor(m => m.bookInfo.Passenger[PaxCounter - 1].FirstName, "")
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-3 bus-nameclass">
                                                                        <div class="form-group form-float">
                                                                            <div class="help-info">Last Name</div>
                                                                            <div class="form-line ">
                                                                                @Html.TextBoxFor(m => m.bookInfo.Passenger[PaxCounter - 1].LastName, new { @class = "form-control" })
                                                                            </div>

                                                                            @Html.ValidationMessageFor(m => m.bookInfo.Passenger[PaxCounter - 1].LastName, "")
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-1 m-r-0 p-r-0 age-busclass">
                                                                        <div class="form-group form-float">
                                                                            <div class="help-info">Age</div>
                                                                            <div class="form-line">
                                                                                @Html.TextBoxFor(m => m.bookInfo.Passenger[PaxCounter - 1].Age, new { @type = "number", min = "1", max = "70", @class = "form-control" })
                                                                            </div>

                                                                            @Html.ValidationMessageFor(m => m.bookInfo.Passenger[PaxCounter - 1].Age, "")
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-2 gender-menclass">
                                                                        <div class="form-group form-float">
                                                                            <div class="help-info">Gender</div>
                                                                            <div class="form-line">
                                                                                @Html.EnumDropDownListFor(m => m.bookInfo.Passenger[PaxCounter - 1].Gender, new { @class = "form-control" })
                                                                            </div>

                                                                            @Html.ValidationMessageFor(m => m.bookInfo.Passenger[PaxCounter - 1].Gender, "")
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-2 busmobilenimber">
                                                                        <div class="form-group form-float">
                                                                            <div class="help-info">Mobile Number</div>
                                                                            <div class="form-line">
                                                                                @Html.TextBoxFor(m => m.bookInfo.Passenger[PaxCounter - 1].Phoneno, new { @class = "form-control" })
                                                                            </div>

                                                                            @Html.ValidationMessageFor(m => m.bookInfo.Passenger[PaxCounter - 1].Phoneno, "")
                                                                        </div>
                                                                    </div>


                                                                    @if (PaxCounter == 1)
                                                                    {
                                                                        <div class="col-md-2 busemailid">
                                                                            <div class="form-group form-float">
                                                                                <div class="help-info">Email Id</div>
                                                                                <div class="form-line">
                                                                                    @Html.TextBoxFor(m => m.bookInfo.Passenger[PaxCounter - 1].Email, new { @class = "form-control" })
                                                                                </div>

                                                                                @Html.ValidationMessageFor(m => m.bookInfo.Passenger[PaxCounter - 1].Email, "")
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                    @if (Model.IdProofRequired)
                                                                    {
                                                                        <div class="col-md-2 busidproof">
                                                                            <div class="form-group form-float">
                                                                                <div class="help-info">Id Proof</div>
                                                                                <div class="form-line">
                                                                                    @Html.EnumDropDownListFor(m => m.bookInfo.Passenger[PaxCounter - 1].IdType, new { @class = "form-control" })
                                                                                </div>

                                                                                @Html.ValidationMessageFor(m => m.bookInfo.Passenger[PaxCounter - 1].IdType, "")
                                                                            </div>
                                                                        </div>
                                                                        <div class="col-md-2 busidnumber">
                                                                            <div class="form-group form-float">
                                                                                <div class="help-info">Id Number</div>
                                                                                <div class="form-line">
                                                                                    @Html.TextBoxFor(m => m.bookInfo.Passenger[PaxCounter - 1].IdNumber, new { @class = "form-control" })
                                                                                </div>

                                                                                @Html.ValidationMessageFor(m => m.bookInfo.Passenger[PaxCounter - 1].IdNumber, "")
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>

                                                            </div>
                                                        </div>
                                                    </div>
                                                    PaxCounter++;
                                                }
                                        <div class="submitandcancelclass">
                                            <button class="btn btn-primary waves-effect bussbookingsucces" type="submit">SUBMIT</button><button id="gobackpage" class="btn btn-primary waves-effect bussbookingsucces">Cancel</button>
                                        </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- #END# Flight Details start -->
                <!-- Passanger Details-->
                <!-- Passanger Details End-->
                <!-- #END# Fare rule -->
            </div>
            <!-- Fare Details -->
            <!-- #END# Fare Details -->
        </div>
    </div>
    <!--Slider div-->
    <br />
</section>

