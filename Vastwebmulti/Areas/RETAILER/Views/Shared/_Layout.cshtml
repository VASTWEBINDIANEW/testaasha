@using Microsoft.AspNet.Identity
@using Vastwebmulti.Models;
<!DOCTYPE html>
<html>
<head>
    @{
        var comnyname = "";
        var favimage = "";
        var Link = "";
        VastwebmultiEntities DB1 = new VastwebmultiEntities();
        var Userid = User.Identity.GetUserId();
        var companyname = DB1.Admin_details.SingleOrDefault();
        ViewBag.companyname = companyname.Companyname;

        var faviconlogo = DB1.tblfavicons.Where(p => p.Role == "ADMIN").ToList();
        if (faviconlogo.Count() > 0)
        {
            if (faviconlogo.SingleOrDefault().Role == "ADMIN")
            {
                favimage = faviconlogo.SingleOrDefault().faviconimage;
            }
        }
        else
        {
            <link rel="icon" href="" type="image/x-icon" />
        }
        var color = DB1.changecolors.Where(a => a.Role == "ADMIN").ToList();
        var col = color.Count == 0 ? "pink" : color.SingleOrDefault().multipaloutercolor;

        var remain = (from nm in DB1.Remain_reteller_balance where nm.RetellerId == Userid select nm).Single().Remainamount;
        var chkmsg = DB1.lowbalancemsgs.Where(a => a.userid == Userid).SingleOrDefault();
        var userfor = DB1.lowbalances.Where(a => a.Role == "Retailer").FirstOrDefault();
        if (userfor != null && userfor.amount < remain)
        {
            if (chkmsg == null)
            {
                lowbalancemsg lb = new lowbalancemsg();
                lb.userid = Userid;
                lb.message = "Message Sent";
                lb.status = false;
                DB1.lowbalancemsgs.Add(lb);
                DB1.SaveChanges();
            }
            else
            {
                chkmsg.status = false;
                DB1.SaveChanges();
            }
        }

        var remainpos = (from nm in DB1.Pos_remain where nm.userid == Userid select nm).Single().Remain;
        var RetailerName = (from nm in DB1.Retailer_Details where nm.RetailerId == Userid select nm).Single().RetailerName;
        var retailerimg1 = (from nm in DB1.Retailer_Details where nm.RetailerId == Userid select nm).SingleOrDefault();
        var retailerimg = "NODATA";
        if (!string.IsNullOrWhiteSpace(retailerimg1.Photo))
        {
            retailerimg = retailerimg1.Photo;
        }
        var remainAeps = (from nm in DB1.AEPS_TXN_Details where nm.UserId == Userid && nm.IsSettled == false && nm.Status == "Success" select nm).ToList().Sum(a => a.Amount + a.RemIncome + a.RemGST);
        var logoimage = "";
        var logo = DB1.tblHeaderLogoes.Where(p => p.Role == "ADMIN").ToList();
        if (logo.Count > 0)
        {
            if (logo.SingleOrDefault().Role == "ADMIN")
            {
                logoimage = logo.Where(p => p.Role == "ADMIN").SingleOrDefault().LogoImage;
            }
        }
        else
        {
            logoimage = "images/Default_Logo.png";
        }
        //complaint request
        ViewBag.complaint = DB1.complaint_request.Count(a => a.userid == Userid && a.sts == "Open");
        //total cart count
        var countval = DB1.Carts.Where(a => a.BuyerId == Userid).Count();
        ViewBag.cartcount = countval;

        JSONReadWrite readWrite = new JSONReadWrite();
        dynamic people = Newtonsoft.Json.JsonConvert.DeserializeObject(readWrite.Read("LogoBackgroundColor.json", "~/Areas/ADMIN/Models/JsonData/"));
        string logoBgColor = people.ColorCode;


        var dlm = DB1.Retailer_Details.Where(aa => aa.RetailerId == Userid).SingleOrDefault();

        decimal? admincr = 0;


        try
        {

            var admininfochk = DB1.Dealer_To_Retailer_Balance.Where(aa => aa.RetailerId == Userid && aa.DealerId == companyname.userid).OrderByDescending(aa => aa.RechargeDate).Take(1).SingleOrDefault();
            if (admininfochk != null)
            {
                admincr = admininfochk.cr;
            }
        }
        catch (Exception)
        {
            admincr = 0;
        }


        decimal? dlmcr = 0;

        try
        {
            var dlmcrinfo = DB1.Dealer_To_Retailer_Balance.Where(aa => aa.RetailerId == Userid && aa.DealerId == dlm.DealerId).OrderByDescending(aa => aa.RechargeDate).Take(1).SingleOrDefault();
            if (dlmcrinfo != null)
            {
                dlmcr = dlmcrinfo.cr;
            }

        }
        catch (Exception)
        {
            dlmcr = 0;
        }
        var total = Convert.ToDecimal(admincr) + Convert.ToDecimal(dlmcr);

        var servicechk = "NOTSHOW";




        var resukt = DB1.Service_BlockUserwise.Where(x => x.remid == Userid).ToList();
        //var sevienamehh = DB1.Show_Service_name.Where(x => resukt.Contains(x.idno));



        var travelstatus = "NOTchk";
        var finiancialstatus = "NOTchk";
        var otherstatus = "NOTchk";
        var b2csts = false;
        foreach (var itesmm in resukt)
        {
            var sevienamehh = DB1.Show_Service_name.Where(x => x.idno == itesmm.Show_Service_name_id).FirstOrDefault();
            if (sevienamehh != null)
            {

                if (sevienamehh.servicename == "Finiance" && itesmm.status == true)
                {
                    finiancialstatus = "CHKOK";
                }
                else if (sevienamehh.servicename == "Travel" && itesmm.status == true)
                {
                    travelstatus = "CHKOK";
                }
                else if (sevienamehh.servicename == "Other" && itesmm.status == true)
                {
                    otherstatus = "CHKOK";
                }
            }

        }
        var b2cststus = DB1.RechargeB2CStatus.Where(aa => aa.userid == Userid).SingleOrDefault();
        if (b2cststus.Sts == true)
        {
            travelstatus = "NOTchk";
            otherstatus = "NOTchk";
            finiancialstatus = "NOTchk";
            b2csts = true;
        }

        var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Retailer").ToList();
        if (usernname.Count() > 0)
        {
            if (usernname.SingleOrDefault().Role == "Retailer")
            {
                favimage = usernname.SingleOrDefault().NickName;
                ViewBag.nickname = favimage;
            }
        }


        var linkurl = DB1.Upload_Link.ToList();

        var upiandgatewaychk = DB1.UPIandGatewayStatus.ToList();
        ViewBag.UPIQR = upiandgatewaychk.Where(aa => aa.Name == "UPI_QR").SingleOrDefault().Status;
        ViewBag.UPICOLLECTION = upiandgatewaychk.Where(aa => aa.Name == "UPI_Collection").SingleOrDefault().Status;
        ViewBag.GATEWAY = upiandgatewaychk.Where(aa => aa.Name == "Payment_GateWay_page").SingleOrDefault().Status;

    }



