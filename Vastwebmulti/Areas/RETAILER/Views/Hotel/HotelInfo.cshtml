<script>
    function gotoRoomsTab(event) {
        // alert('Hey i am calling');
        event.preventDefault();
        $("#roomsLiTab").click();
        // alert();
    }
    $(".roomRadio").click(function () {
        $("#RTypeCode").val($(this).attr('id'));
        //$("#roomPriceSpan").html($(this).attr("data-room-price"));
        $("#roomTypeNameHeadding").html($(this).attr("data-room-typename"));
    });
</script>

<script>

    $(".twohrd span").hover(function () {
        $('.scrol.scrl').css("display", "block");
    }, function () {
        $('.scrol.scrl').css("display", "none");
    });

</script>




<script>



    $('#showofferfare').click(function () {
        if ($('.showofferchk:visible').length == 0) {
            $('.showofferchk').show();
        }
        else {
            $('.showofferchk').hide();
        }
    });



</script>
