@model List<Vastwebmulti.Models.HotelPassenger>
<div class="row clearfix">
    @if (Model != null && Model.Count > 0)
    {
        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
            @*<div class="card">*@
            @*<div class="header">
                    <h2>
                        Guest Details
                    </h2>
                </div>*@
            <div class="body table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Title</th>
                            <th>FIRST NAME</th>
                            <th>MIDDLE NAME</th>
                            <th>LAST NAME</th>
                            <th>AGE</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1;}
                        @foreach (var item in Model)
                        {
                        <tr>
                            <th scope="row">@i</th>
                            <td>@item.Title</td>
                            <td>@item.FirstName</td>
                            <td>@item.MiddleName</td>
                            <td>@item.LastName</td>
                            <td>@item.Age</td>
                        </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
            @*</div>*@
        </div>
    }
    else
    {
     <div class="col-lg-12 col-md-12 col-sm-12">
         No Data found
     </div>
    }

</div>