                                                        @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].PassportExpDate, "")
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            if (i == 0 && a == 0)
                            {
                                <div class="col-md-4">
                                    <div class="card">
                                        <div class="header">
                                            <h2>
                                                Room Details
                                                @*<small>Add the badges component to any list group item and it will automatically be positioned on the right.</small>*@
                                            </h2>
                                        </div>
                                        <div class="body">
                                            @{
                                                var roomNode = Model.Content.Addinfo.HotelRoomsDetails.FirstOrDefault();
                                            }
                                            <ul class="list-group">
                                                <li class="list-group-item">
                                                    Room Type : <span class="badge" style="background:none;color:black;">@roomNode.RoomTypeName</span>
