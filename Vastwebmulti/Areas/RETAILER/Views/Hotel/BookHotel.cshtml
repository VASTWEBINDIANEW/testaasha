                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group form-float">
                                                        <div class="help-info">Passport Expiry</div>
                                                        <div class="form-line">
                                                            @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].PassportExpDate, new { @class = "form-control", @type = "date" })
