                                                        <div class="form-line">
                                                            @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].PassportNo, new { @class = "form-control" })
                                                        </div>

                                                        @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].PassportNo, "")
