                                                    Check-Out : <span class="badge" style="background:none;color:black;">@HotelDetailedVM.CheckOutDate</span>
                                                </li>
                                            </ul>
                                            @*<input type="submit" class="btn btn-block btn-lg btn-primary waves-effect" name="BokingType" value="HOLD">
                                            <input type="submit" class="btn btn-block btn-lg btn-primary waves-effect" name="BokingType" value="PAY NOW">*@
                                        </div>
                                    </div>
                                </div>
                            }
                            PaxCounter++;
                            adultCounter++;
                            @Html.HiddenFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].PaxType, new { @Value = 1 })

                            @Html.HiddenFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].LeadPassenger, new { @Value = true })
                            <div class="col-lg-8 col-md-8 col-sm-8 col-xs-8 bookhotel-adult" style="">
