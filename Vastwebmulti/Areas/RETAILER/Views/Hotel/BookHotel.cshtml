@using Vastwebmulti.Areas.RETAILER.ViewModels
@model Vastwebmulti.Areas.RETAILER.ViewModels.HotelBlockRoomResponseModel
@{
    ViewBag.Title = "Travel";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
    var HotelDetailedVM = (HotelDetailedVM)TempData.Peek("HotelDetailedVM");
    var AdultCount = TempData.Peek("AdultCount");
    var ChildCount = TempData.Peek("ChildCount");
    List<RoomGuestMapping> guestInfo = (List<RoomGuestMapping>)TempData.Peek("guestsInfo");
    if (HotelDetailedVM == null || guestInfo == null)
    {
        TempData["Status"] = "Failed";
        TempData["Message"] = "Session expired,try again.";
        Response.Redirect("~/RETAILER/Home/Travel");
    }
    var hotel = HotelDetailedVM.hotelInfo.Content.Addinfo.HotelDetails;
    var markup = ViewBag.RetailerMarkup;
}
<style>
    .scrollypy {
        overflow-y: auto !important;
        height: 250px;
    }
    /*======================================
    =            NO GUTTER CODE            =
    ======================================*/
    .no-gutter > [class*='col-'] {
        padding-right: 0;
        padding-left: 0;
    }

    .loader_innner {
        position: fixed;
        z-index: 999999;
        height: 100%;
        margin: auto;
        top: 0;
        left: 0;
        bottom: 0;
        right: 0;
        background: rgba(255, 255, 255, 0.8) none repeat scroll 0 0;
    }

    .checked {
        color: orange;
    }

    .price {
        font-size: xx-large;
        font-weight: bold;
        color: black;
        margin-top: 50px;
        margin-left: 130px;
    }
</style>
<link rel="stylesheet" href="http://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
<link rel="stylesheet" href="http://netdna.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
<link href="~/AdminDesign/Retailer_Slider/Slieder.css" rel="stylesheet" />
<link href="~/CSS/PageCss/AirSearch.css" rel="stylesheet" />
<section class="content content-book-htelclass content-fourdesign-page allpage-four-design-section" style="margin-left:10px;">
    <div class="container-fluid">

        <!--Four-Design-Page-Header-Start-->

        <div class="page-title-box-fourde">
            <h3>Hotels</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard", "Home")" style="color:var(--fullbodybg-four);background: transparent;margin: 0;padding: 0;">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="@Url.Action("Travel", "Home")" style="color: var(--fullbodybg-four);background: transparent; margin: 0; padding: 0;">Hotels&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);" style="background: transparent; margin: 0; padding: 0;">Hotel Book</a></li>
            </ul>
        </div>

        <!--Four-Design-Page-Header-End-->

        <div class="row clearfix">
            <div id="BusLoader" style="display:none;">
                <div class="loader_innner">
                    <img src="~/images/Busloader.gif" style="margin-top:15%;margin-left:46%;" />
                </div>
            </div>
            <!-- FirstBox -->
            <div class="col-lg-4 col-md-4 col-sm-4 col-xs-4">

                <div class="card changeback-four-design">
                    <div class="header">
                        <h2>
                            Price Details
                            @*<small>Add the badges component to any list group item and it will automatically be positioned on the right.</small>*@
                        </h2>

                    </div>
                    <div class="body">
                        @{
                            var basePrice = Model.Content.Addinfo.HotelRoomsDetails.Sum(a => a.Price.RoomPrice);
                            var TotalAmountPayable = Model.Content.Addinfo.HotelRoomsDetails.Sum(a => a.Price.PublishedPriceRoundedOff) + markup;
                            var taxAndCharges = TotalAmountPayable - basePrice;
                        }
                        <ul class="list-group">
                            <li class="list-group-item">
                                Base Price : <span class="badge" style="background:none;color:black;">@basePrice</span>
                            </li>
                            <li class="list-group-item">
                                Tax & Charges :<span class="badge" style="background:none;color:black;">@taxAndCharges</span>
                            </li>
                            <li class="list-group-item">
                                Total Price : <span class="badge" style="background:none;color:black;">@TotalAmountPayable</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-8 col-md-8 col-sm-8 col-xs-8">
                <div class="card changeback-four-design">
                    <div class="header">
                        <h2>
                            Hotel Details
                            @*<small>Add the badges component to any list group item and it will automatically be positioned on the right.</small>*@
                        </h2>
                    </div>
                    <div class="body">
                        <div class="media">
                            <div class="media-left">
                                @if (!string.IsNullOrWhiteSpace(HotelDetailedVM.hotelInfo.Content.Addinfo.HotelDetails.HotelPicture))
                                {
                                    <a href="javascript:void(0);">
                                        <img class="media-object" src="@HotelDetailedVM.hotelInfo.Content.Addinfo.HotelDetails.HotelPicture" width="150" height="150">
                                    </a>
                                }
                                else
                                {
                                    <a href="javascript:void(0);">
                                        <img class="media-object" src="http://placehold.it/32x32" width="32" height="32">
                                    </a>
                                }
                                <br />
                            </div>
                            <div class="media-body" style="text-align:left;">
                                <h4 class="media-heading">
                                    <a href="#" style="color:#052258;"> @hotel.HotelName</a>
                                </h4>
                                <br />
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var isChecked = "";
                                    if (i <= hotel.StarRating)
                                    {
                                        isChecked = "checked";
                                    }
                                    <span class="fa fa-star @isChecked" style="font-size: 22px;"></span>
                                }
                                <br /><span><i class="fa fa-map-marker" aria-hidden="true" style="color: orangered;"></i></span>
                                @hotel.Address<br />

                                <details>
                                    <summary>Show Hotel Description</summary>
                                    <br />
                                    <p>@Html.Raw(hotel.Description)</p>
                                </details>
                                <details>
                                    <summary>Show Cancallation Policy</summary>
                                    <br />
                                    <p>@Html.Raw(Model.Content.Addinfo.HotelRoomsDetails.First().CancellationPolicy)</p>
                                </details>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- #END#  -->
        </div>
        <div class="row clearfix">
            <!-- Passanger Details-->
            @using (Html.BeginForm("BookHotel", "Hotel", FormMethod.Post))
            {
                @Html.ValidationSummary(true)
