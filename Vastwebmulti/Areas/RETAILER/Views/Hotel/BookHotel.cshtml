                                                        @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].MiddleName, new { @class = "form-control" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].MiddleName, "")
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group form-float">
                                                    <div class="help-info">Adult Last Name</div>
                                                    <div class="form-line ">
                                                        @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].LastName, new { @class = "form-control nospace" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].LastName, "")
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row clearfix">
                                            @if (a == 0)
                                            {

                                                <div class="col-md-4">
                                                    <div class="form-group form-float">
                                                        <div class="help-info">Email Address</div>
                                                        <div class="form-line">
                                                            @*<input type="text" class="form-control" name="minmaxlength" maxlength="10" minlength="3" required="" aria-required="true" aria-invalid="false">*@
                                                            @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].Email, new { @class = "form-control" })
                                                            @*<label class="form-label">Email</label>*@
                                                        </div>

                                                        @*<label id="minmaxlength-error" class="error" for="minmaxlength" style="display: none;"></label>*@
                                                        @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].Email, "")
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group form-float">
                                                        <div class="help-info">Contact No</div>
                                                        <div class="form-line">
                                                            @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].phoneno, new { @class = "form-control" })
                                                        </div>

                                                        @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].phoneno, "")
                                                    </div>
                                                </div>

                                            }
                                            <div class="col-md-4">
                                                <div class="form-group form-float">
                                                    <div class="help-info">Age</div>
                                                    <div class="form-line">
                                                        @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].Age, new { @class = "form-control" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].Age, "")
                                                </div>
                                            </div>
                                            @if (!Model.IsDomestic)
                                            {
                                                <div class="col-md-4">
                                                    <div class="form-group form-float">
                                                        <div class="help-info">Passport Number</div>
                                                        <div class="form-line">
                                                            @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].PassportNo, new { @class = "form-control" })
                                                        </div>

                                                        @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].PassportNo, "")
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group form-float">
                                                        <div class="help-info">Passport Expiry</div>
                                                        <div class="form-line">
                                                            @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].PassportExpDate, new { @class = "form-control", @type = "date" })
                                                        </div>

                                                        @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].PassportExpDate, "")
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Adult Details-->

                        }
                        adultCounter = 1;
                        for (int c = 0 + guestInfo[i].NoOfAdults; c < guestInfo[i].NoOfChild + guestInfo[i].NoOfAdults; c++)
                        {
                            @Html.HiddenFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].PaxType, new { @Value = 2 })
                            @*@Html.HiddenFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].PaxType, "2")*@

                            <!-- Child Details-->
                            <div class="col-lg-8 col-md-8 col-sm-8 col-xs-8 bookhotel-adult" style="">
                                <div class="card changeback-four-design">
                                    <div class="header">
                                        <h2> @childCounter Child (Room @Roomcount)  </h2>
                                    </div>
                                    <div class="body">
                                        <div class="row clearfix">
                                            <div class="col-md-3">
                                                <div class="form-group form-float">
                                                    <div class="help-info">Title</div>
                                                    <div class="form-line focused">
                                                        @Html.DropDownListFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].Title, Title, "Title", new { @class = "form-control" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].Title, "")
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group form-float">
                                                    <div class="help-info">Adult Pax First Name</div>
                                                    <div class="form-line ">
                                                        @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].FirstName, new { @class = "form-control" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].FirstName, "")
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group form-float">
                                                    <div class="help-info">Adult Pax Middle Name</div>
                                                    <div class="form-line ">
                                                        @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].MiddleName, new { @class = "form-control" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].MiddleName, "")
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group form-float">
                                                    <div class="help-info">Adult Last Name</div>
                                                    <div class="form-line ">
                                                        @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].LastName, new { @class = "form-control nospace" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].LastName, "")
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row clearfix">
                                            <div class="col-md-4">
                                                <div class="form-group form-float">
                                                    <div class="help-info">Age</div>
                                                    <div class="form-line">
                                                        @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].Age, new { @class = "form-control" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].Age, "")
                                                </div>
                                            </div>
                                            @if (!Model.IsDomestic)
                                            {
                                                <div class="col-md-4">
                                                    <div class="form-group form-float">
                                                        <div class="help-info">Passport Number</div>
                                                        <div class="form-line">
                                                            @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].PassportNo, new { @class = "form-control" })
                                                        </div>

                                                        @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].PassportNo, "")
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group form-float">
                                                        <div class="help-info">Passport Expiry</div>
                                                        <div class="form-line">
                                                            @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].PassportExpDate, new { @class = "form-control", @type = "date" })
                                                        </div>

                                                        @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].PassportExpDate, "")
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            PaxCounter++;
                            childCounter++;
                        }
                        Roomcount++;
                    }
                }
                <div class="hotel-booking-buttonlast">
                    @*<input type="submit" class="btn btn-block btn-lg btn-primary waves-effect" name="BokingType" value="HOLD">*@
                    <input type="submit" class="btn btn-block btn-lg btn-primary waves-effect" name="BokingType" value="PAY NOW">
                </div>

            }
            <!-- Passanger Details End-->
        </div>


    </div>
</section>
