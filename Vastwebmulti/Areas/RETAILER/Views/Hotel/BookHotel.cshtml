                                                        @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].FirstName, new { @class = "form-control" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].FirstName, "")
