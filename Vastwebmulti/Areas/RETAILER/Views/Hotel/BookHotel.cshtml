                                                    <div class="form-line">
                                                        @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].Age, new { @class = "form-control" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].Age, "")
                                                </div>
                                            </div>
                                            @if (!Model.IsDomestic)
                                            {
                                                <div class="col-md-4">
                                                    <div class="form-group form-float">
                                                        <div class="help-info">Passport Number</div>
                                                        <div class="form-line">
                                                            @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].PassportNo, new { @class = "form-control" })
                                                        </div>

                                                        @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].PassportNo, "")
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group form-float">
                                                        <div class="help-info">Passport Expiry</div>
                                                        <div class="form-line">
                                                            @Html.TextBoxFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].PassportExpDate, new { @class = "form-control", @type = "date" })
                                                        </div>

                                                        @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].PassportExpDate, "")
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                            PaxCounter++;
                            childCounter++;
                        }
                    }
                }
                else
                {
                    for (var i = 0; i < guestInfo.Count; i++)
                    {
                        for (int a = 0; a < guestInfo[i].NoOfAdults; a++)
                        {
                            @*@Html.HiddenFor(m => m.BookHotelRoomDetails[i].HotelPassenger[a].PaxType, "1")*@
                            if (i == 0 && a == 0)
                            {
                                <div class="col-md-4">
                                    <div class="card changeback-four-design">
                                        <div class="header">
                                            <h2>
                                                Room Details
                                                @*<small>Add the badges component to any list group item and it will automatically be positioned on the right.</small>*@
                                            </h2>
                                        </div>
                                        <div class="body">
                                            @{
                                                var roomNode = Model.Content.Addinfo.HotelRoomsDetails.FirstOrDefault();
                                            }
                                            <ul class="list-group">
                                                <li class="list-group-item">
                                                    Room Type : <span class="badge" style="background:none;color:black;">@roomNode.RoomTypeName</span>
                                                </li>
