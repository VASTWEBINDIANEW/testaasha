                                                    <div class="help-info">Title</div>
                                                    <div class="form-line focused">
                                                        @Html.DropDownListFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].Title, Title, "Title", new { @class = "form-control" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.BookHotelRoomDetails[i].HotelPassenger[c].Title, "")
