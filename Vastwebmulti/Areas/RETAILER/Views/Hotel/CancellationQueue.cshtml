<script>
    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 45 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }
</script>
<!--Calendar Javascript-->
<script>
   
  
    function OnSuccessStatus(data)
    {
        var respo = JSON.parse(data);
        if (respo.Status == "Pending")
        {
            swal("Keep calm!", respo.Message, "warning");
        }
        else if (respo.Status == "Success") {
            swal("Wow!", respo.Message, "success");

        }
        else {
            swal("Oops!", respo.Message, "error");
        }
    }
    function OnFailedStatus(data) {
        swal("Oops!", "Failed to fatch data.", "error");
    }
    $(function () {

            var sts = '@TempData["Status"]';
        var msg = '@TempData["Message"]';
        if (sts != null && sts != '')
        {
            if(sts == "Success")
            {
                swal("Wow!", msg, "success");
            } else {
                swal("Oops!", msg, "error");
            }
        }
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

    });
</script>
<script>
    function reloadPage()
    {
        window.setTimeout(function () {
            location.reload();
        }, 3000);
    }
</script>

<script>
    $(function () {
        var loc = window.location.href; // returns the full URL
        if ('/~/RETAILER/Hotel/CancellationQueue') {
            $('#flightaddclass ul li:last-child a, .list.report-list-change li#rewertyd a').addClass('active');
        }
    });
</script>

<script>
    $(".input-daterange").click(function () {
        $(".datepicker").addClass('qdatepickersecondcancelreport');
    });


</script>
<script>
    $("#btnExport").click(function (e) {
        e.preventDefault()
        var ddl_status = $('#ddl_status').val();
        var ddl_top = $('#ddl_top').val();
        var bookingid = $('#TXNID').val();
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var url = '@Url.Action("ExcelCancellationQueue", "Hotel")?ddl_status=' + ddl_status + '&ddl_top=' + ddl_top + '&bookingid=' + bookingid + '&txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date;
        location.href = url;
});
</script>
<script>
    $("#btnPDF").click(function () {
        var ddl_status = $('#ddl_status').val();
        var ddl_top = $('#ddl_top').val();
        var bookingid = $('#TXNID').val();
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var url = '@Url.Action("PDFCancellationQueue", "Hotel")?ddl_status=' + ddl_status + '&ddl_top=' + ddl_top + '&bookingid=' + bookingid + '&txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date;
        window.open(
url,
  '_blank' // <- This is what makes it open in a new window.
);
    });
</script>
