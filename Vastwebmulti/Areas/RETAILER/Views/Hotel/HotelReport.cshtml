<script>
    $(function () {
        var loc = window.location.href; // returns the full URL
        if ('/~/RETAILER/Hotel/HotelReport') {
            $('.list.report-list-change li#rewertyd a').addClass('active');
        }
    });
</script>
<script>
    $("#btnExport").click(function (e) {
        e.preventDefault()
        var ddl_status = $('#ddl_status').val();
        var ddl_status_ticket = $('#ddl_status_ticket').val();
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var url = '@Url.Action("ExcelHotelReport", "Hotel")?ddl_status=' + ddl_status + '&ddl_status_ticket=' + ddl_status_ticket + '&txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date;
        location.href = url
});
</script>
<script>
    $("#btnPDF").click(function () {
        var ddl_status = $('#ddl_status').val();
        var ddl_status_ticket = $('#ddl_status_ticket').val();
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var url = '@Url.Action("PDF_HotelReport", "Hotel")?ddl_status=' + ddl_status + '&ddl_status_ticket=' + ddl_status_ticket + '&txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date;
        window.open(
url,
  '_blank' // <- This is what makes it open in a new window.
);
    });
</script>