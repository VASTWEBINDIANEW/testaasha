<script>


  function onPluseMinusHotel(check, v) {
      event.stopPropagation();
      var adltCount = parseInt($('#txtAdultCountHotel').val());
      var childCount = parseInt($('#txtChildCountHotel').val());

      var allCount = parseInt($('#txtPassengerCountHotel').val());
      if (check == 'Adult') {

          $('#txtAdultCountHotel').val(adltCount + v);
          $('#txtPassengerCountHotel').val(allCount + v);
          $('#showPassengerCountHotel').html(allCount + v);
          $('#showAdultCountHotel').html(adltCount + v);
          document.getElementById("showChildCountHotel").textContent = "0";
          document.getElementById("txtChildCountHotel").value = "0";

          if (parseInt($('#txtAdultCountHotel').val()) > 1) {
              $('#btnAdultMinusHotel').prop('disabled', false);
          }
          var vv = document.getElementById("showPassengerCountHotel").textContent;
          if (vv == 9) {
              $('#btnAdlutPlusHotel').prop('disabled', true);
              $('#btnChildPlusHotel').prop('disabled', true);
          }
          var adspan = document.getElementById("showAdultCountHotel").textContent;
          if (adspan == 9) {
              $('#btnAdlutPlusHotel').prop('disabled', true);
              $('#btnChildPlusHotel').prop('disabled', true);
              $('#btnAdultMinusHotel').prop('disabled', false);
              $('#btnChildMinusHotel').prop('disabled', true);
              document.getElementById("showChildCountHotel").textContent = "0";
              document.getElementById("txtChildCountHotel").value = "0";
          }
          else if (vv != 1) {
              $('#btnAdlutPlusHotel').prop('disabled', false);
              $('#btnChildPlusHotel').prop('disabled', false);
          }
          else {
              $('#btnAdultMinusHotel').prop('disabled', true);
          }
      }
      else if (check == 'child') {

          $('#txtChildCountHotel').val(childCount + v);
          $('#txtPassengerCountHotel').val(allCount + v);
          $('#showPassengerCountHotel').html(allCount + v);
          //alert(parseInt($('#txtChildCount').val()));
          $('#showChildCountHotel').html(childCount + v);
          if (parseInt($('#txtChildCountHotel').val()) > 0) {
              $('#btnChildMinusHotel').prop('disabled', false);
          }
          var vv = document.getElementById("showPassengerCountHotel").textContent;

          if (vv == 9) {
              $('#btnAdlutPlusHotel').prop('disabled', false);
              $('#btnChildPlusHotel').prop('disabled', true);
          }
          var gg = document.getElementById("showChildCountHotel").textContent;
          if (gg == 0) {
              $('#btnChildMinusHotel').prop('disabled', true);
              $('#btnChildPlusHotel').prop('disabled', false);
              $('#btnAdlutPlusHotel').prop('disabled', false);

          }
      }
  }

