            $(".fourthdesign-retailer-allnone #defaultnonehotel").addClass("hotelfilter-fixed-four");
        }
        else {
            $(".fourthdesign-retailer-allnone #defaultnonehotel").removeClass("hotelfilter-fixed-four");
