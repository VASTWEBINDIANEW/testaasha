<script>
    function OnSeatClick(fare, seatid, isAvailable, isladiesSeat, dom) {
        //alert(isAvailable);
        // alert(isladiesSeat);
        isAvailable = JSON.parse(isAvailable);
        isladiesSeat = JSON.parse(isladiesSeat);
        if (isAvailable) {
            if (isladiesSeat) {
                $(dom).css("background-color", "#c396a6");
                $(dom).css("border", "#ed719e");
            } else {
                $(dom).css("background-color", "#CCE8B5");
            }
            // $(dom).setAttribute('onclick', 'writeLED(1,1)')
            var str = "OnSeatDeSelect('" + fare + "','" + seatid + "','" + isAvailable + "','" + isladiesSeat + "',this)" + "";
            //alert(str);
            //ADD FARE
            var totalFare = parseInt($('#TotalFare').val()) == NaN ? 0 : $('#TotalFare').val();
            if (totalFare == "NaN" || totalFare == NaN || totalFare == "") {
                totalFare = parseInt(0);
            }
            //alert(totalFare);
            totalFare = parseInt(totalFare) + parseInt(fare);
            $('#TotalFare').val(totalFare);
            //ADD seats
            var selectedSeats = $('#selectedSeats').val();
            selectedSeats += ',' + seatid;
            selectedSeats = selectedSeats.replace(/(^,)|(,$)/g, "");
            selectedSeats = selectedSeats.replace(',,', ",");
            $('#selectedSeats').val(selectedSeats);
            $(dom).attr("onclick", str);

        }
        //$(this).css("background-color", "red");
    }
    function OnSeatDeSelect(fare, seatid, isAvailable, isladiesSeat, dom) {
        //alert("deselect");
        $(dom).css("background-color", "white");
        $(dom).css("border", "1px solid gray");
        var str = "OnSeatClick('" + fare + "','" + seatid + "','" + isAvailable + "','" + isladiesSeat + "',this)" + "";
        $(dom).attr('onclick', str);
        //remove seats
        var selectedSeats = $('#selectedSeats').val();
        selectedSeats = selectedSeats.replace(seatid, "");
        selectedSeats = selectedSeats.replace(',,', ",");
        selectedSeats = selectedSeats.replace(/(^,)|(,$)/g, "");
        $('#selectedSeats').val(selectedSeats);
        //recalculate FARE
        var totalFare = parseInt($('#TotalFare').val()) == NaN ? 0 : $('#TotalFare').val();
        if (totalFare == "NaN" || totalFare == NaN || totalFare == "") {
            totalFare = parseInt(0);
        }
        //alert(totalFare);
        totalFare = parseInt(totalFare) - parseInt(fare);
        $('#TotalFare').val(totalFare);
    }
    function ShowLayoutClick(id) {
        //alert();
        $(".selectSeatRightCol").html('');
        $(".selectSeatRightCol").hide();
        //$("#" + id).show();
        $("#" + id).fadeIn(3000).animate({ opacity: 1 }, { queue: false, duration: '4000' });
    }
</script>
