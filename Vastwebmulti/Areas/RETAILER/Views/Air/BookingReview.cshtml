                                                            <div class="demo-google-material-icon flight-after flight-afterbefore" style="text-align:center;">

                                                            </div>
                                                            Baggage(@item.Baggage + @item.CabinBaggage) KG

                                                        </div>
                                                        <div class="col-md-3 changename" style="padding-right:0px;">
                                                            <span class="channame">@item.Destination.Airport.CityName (@item.Destination.Airport.AirportCode)</span>
                                                            <strong>@Convert.ToDateTime(item.Destination.ArrTime).ToString("HH:mm")</strong> <br />
