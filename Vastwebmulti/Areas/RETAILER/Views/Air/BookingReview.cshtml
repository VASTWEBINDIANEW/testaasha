                        }
                        else {
                            //alert("else 1");
                            if (respo.length = 1 && respo[0].IsSuccess == true) {
                                alert("Booking Success");
                                window.location = '@Url.Action("TicketReport","Air")';
                            }
                            else {
                                //alert("else 2");
                                //alert(respo.length);
                                //alert(respo[0].IsSuccess);
                                if (Message1 == "Low Balance") {
                                    Message1 = "⚠ You do not have enough wallet left";
                                }
                                $("#lowblan").text(Message1);
                            }
                        }
                    }
                    else {
                        alert("ErrorMessage: \nInternal error!!!");
                    }
                }
                else {
                    alert("Something went wrong");
                    
                }
            },
                failure: function (response) {
                    document.getElementById("loadermoney").style.display = "none";
                    alert(response.responseText);
            },
                error: function (response) {
                    document.getElementById("loadermoney").style.display = "none";
                    alert(response.responseText);
            }
        });
        } else {
        //alert('You Un-Checked it');
                $("#basic_checkbox_2-error").show();
        }
    });
</script>



