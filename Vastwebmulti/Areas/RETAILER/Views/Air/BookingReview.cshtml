                                                            <p>@item.Origin.DepTime.ToString("ddd, dd MMM yyyy")</p>
                                                            <span class="flightcity">@item.Origin.Airport.AirportName (Terminal : @item.Origin.Airport.Terminal)</span>
                                                        </div>
