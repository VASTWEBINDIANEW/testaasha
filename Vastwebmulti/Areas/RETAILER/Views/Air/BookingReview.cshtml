@model Vastwebmulti.Areas.RETAILER.ViewModels.FlightDetailsVM
@{
    ViewBag.Title = "Booking review";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
    decimal margin = ViewBag.RetailerMarkup;
}
<style>
    .scrollypy {
        overflow-y: auto !important;
        height: 250px;
    }

    .btmPlusMinus {
        padding: 3px 6px;
        margin-right: 4px;
        padding-bottom: 6px;
        border-radius: 5px;
    }

        .btmPlusMinus i {
            font-size: 10px;
        }

    .table {
        display: table; /* Allow the centering to work */
        margin: 0 auto;
    }

    ul#horizontal-list {
        min-width: 696px;
        list-style: none;
        padding-top: 20px;
    }

        ul#horizontal-list li {
            display: inline;
            text-align: center;
            padding: 20px;
        }

    span.field-validation-error {
        font-size: 12px;
        display: block;
        margin-top: 5px;
        font-weight: normal;
        color: #F44336;
    }

    .vertical-text {
        transform: rotate(-90deg);
        -ms-transform: rotate(-90deg);
        -webkit-transform: rotate(-90deg);
        bottom: 5%;
        top: 0%;
        position: absolute;
        color: var(--main-bg-lcolor);
    }
</style>
<style type="text/css">
    .loadermoney {
        position: fixed;
        left: 0px;
        top: 0px;
        width: 100%;
        height: 100%;
        z-index: 199999;
        background: url('../../images/TRAVEL.svg') 50% 50% no-repeat rgba(249, 249, 249, 0.9);
    }
</style>
<link rel="stylesheet" href="http://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
<link rel="stylesheet" href="http://netdna.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
<link href="~/AdminDesign/Retailer_Slider/Slieder.css" rel="stylesheet" />
@*@Html.Partial("_FareQuote",Model.FareQuoteVM)*@

<div id="loadermoney" class="loadermoney" style="display:none;"></div>
<section class="content" style="margin-left: 10px;margin-right: 10px;">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-9 col-md-9 col-sm-9 col-xs-9" id="PNR_BookingDetails" style="display:none;">
                <div class="card" style="min-height:70px;">
                    <div class="body bg-white">
                        <div class="col-md-6" id="leftCol">

                        </div>
                        <div class="col-md-6" id="rightCol">

                        </div>
                    </div>
                </div>
                @Html.Hidden("PNRNO")
                @Html.Hidden("BookingID")
                @Html.Hidden("OfferedFare")
                @Html.Hidden("ItinerarySource")
                @Html.Hidden("PublishedFare")
            </div>


            <!-- Fare Details -->
            <div class="col-md-3 flight-rules">
                <div class="col-md-3 flightbook-fare">
                    <div class="block-header" style="padding: 12px 0 22px 1px;margin-bottom: 4px;">
                        <h2>Fare Details</h2>
                    </div>
                    <div class="row">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 bookfare">
                            <div class="card bookfared">
                                <div class="body bg-white bookfaredc">
                                    @{
                                        var of = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.OfferedFare;
                                        var pf = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.PublishedFare;
                                        var bf = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.BaseFare;
                                        var tax = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.Tax;
                                        var TxnFee = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.AdditionalTxnFeeOfrd;
                                        if (Model.isDomastic && Model.JourneyType == 2)
                                        {
                                            of = of + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.OfferedFare;
                                            pf = pf + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.PublishedFare;
                                            bf = bf + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.BaseFare;
                                            tax = tax + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.Tax;
                                            TxnFee = TxnFee + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.AdditionalTxnFeeOfrd;
                                        }
                                        var otherCharge = pf - (bf + tax + TxnFee);
                                        TxnFee = TxnFee + margin;
                                        pf = pf + margin;
                                    }
                                    <div>
                                        Base Fare <span class="pull-right">@bf</span><br>
                                        Fuel & Tax <span class="pull-right">@tax</span><br>
                                        Other Charges <span class="pull-right">@otherCharge</span><br>
                                        Txn Fee <span class="pull-right">@TxnFee</span><br>
                                        <strong>Total Fare <span class="pull-right">@pf</span></strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Fare rule -->
                <div class="farerules-full" style="overflow-y: inherit;overflow-x: initial;height:auto;">

                    @*<h2>NO HEADER CARDS</h2>*@

                    <h2 style="margin-bottom: 10px;">
                        Fare Rule <span class="from-to-class" style="float:right;">
                            @{
                                var source = ""; var desti = "";
                                var count = @Model.Onward.FareQuoteVM.Content.Addinfo.Results.Segments[0].Count;
                                count = count - 1;
                                source = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Segments[0][0].Origin.Airport.CityName;
                                desti = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Segments[0][count].Destination.Airport.CityName;
                            }

                            @source-@desti
                        </span>
                    </h2>




                    <div class="row">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                            <div class="card" style="background:#f5f5f5;height: 490px !important;overflow-y: scroll !important;">
                                <div class="body bg-white slimScrollDiv slimScrollDivs">



                                    @*@foreach (var item in Model.Onward.FareRuleVM.Content.Addinfo.FareRules)*@
                                    @if (ViewBag.FareRuleOB != null)
                                    {
                                        var OBFareRule = (Vastwebmulti.Areas.RETAILER.ViewModels.FareRuleVM)ViewBag.FareRuleOB;
                                        foreach (var item in OBFareRule.Content.Addinfo.FareRules)
                                        {
                                            <!-- <strong>@item.Origin - @item.Destination</strong>-->
                                            string[] stringSeparators = new string[] { "\r\n" };
                                            string[] lines = item.FareRuleDetail.Split(stringSeparators, StringSplitOptions.None);
                                            //Console.WriteLine("Nr. Of items in list: " + lines.Length); // 2 lines
                                            foreach (string s in lines)
                                            {
                                                //Console.WriteLine(s); //But will print 3 lines in total.
                                                @Html.Raw(s)
                                            }

                                        }
                                    }

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- #END# Fare rule -->
                @if (Model.JourneyType == 2)
                {
                    <div class="farerules-full">
                        <h2>
                            Fare Rules <span class="from-to-class" style="float:right;">
                                @{
                                    source = ""; desti = "";
                                    count = @Model.Inward.FareQuoteVM.Content.Addinfo.Results.Segments[0].Count;
                                    count = count - 1;
                                    source = Model.Inward.FareQuoteVM.Content.Addinfo.Results.Segments[0][0].Origin.Airport.CityName;
                                    desti = Model.Inward.FareQuoteVM.Content.Addinfo.Results.Segments[0][count].Destination.Airport.CityName;
                                }
                                @source-@desti
                            </span>
                        </h2>
                        <div class="cancellation" style="padding-top: 21px;">
                            <h3>Cancellation Fee <span>(Per Guest/Sector)</span></h3>
                            <span>Prior to the date/time of departure</span>
                        </div>
                        @if (Model.isDomastic && Model.JourneyType == 2)
                        {
                            <div class="row">
                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                    <div class="card" style="min-height:auto;height:auto;margin-bottom:0;">
                                        <div class="body bg-white slimScrollDiv" style="height:auto;">

                                            @*@foreach (var item in Model.Inward.FareRuleVM.Content.Addinfo.FareRules)*@
                                            @if (ViewBag.FareRuleIB != null)
                                            {
                                                var IBFareRule = (Vastwebmulti.Areas.RETAILER.ViewModels.FareRuleVM)ViewBag.FareRuleIB;
                                                foreach (var item in IBFareRule.Content.Addinfo.FareRules)
                                                {
                                                    <strong>@item.Origin - @item.Destination</strong><br />
                                                    string[] stringSeparators = new string[] { "\r\n" };
                                                    string[] lines = item.FareRuleDetail.Split(stringSeparators, StringSplitOptions.None);
                                                    //Console.WriteLine("Nr. Of items in list: " + lines.Length); // 2 lines
                                                    foreach (string s in lines)
                                                    {
                                                        //Console.WriteLine(s); //But will print 3 lines in total.
                                                        @Html.Raw(s)<br />
                                                    }

                                                }
                                            }

                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

            </div>
                    <!-- #END# Fare Details -->


                    <div class="col-md-9 flight-book flight-book-start">
