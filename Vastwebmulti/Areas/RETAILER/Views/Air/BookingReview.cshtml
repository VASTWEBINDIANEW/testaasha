<script>
    $(function () {
        $(document).ajaxStart(function () {
            document.getElementById("loadermoney").style.display = "block";
        });
        $(document).ajaxComplete(function () {
            document.getElementById("loadermoney").style.display = "none";
        });
    });
</script>
<script type="text/javascript">
    $(function () {
        //uncomment to enable loader on submit button
        //$('.btn').on('click', function () {
        //    var $this = $(this);
        //    $this.button('loading');
        //    setTimeout(function () {
        //        $this.button('reset');
        //    }, 6000);
        //});
        $('.slimScrollDiv').slimScroll({
            height: '250px',
            wheelStep: 10,
        });
    });

    $("#btnBook").on('click', function () {
        //alert("Book");
        var vm = '@Html.Raw(Json.Encode(@Model))';

        var ckbox = $('#basic_checkbox_2');
        document.getElementById("loadermoney").style.display = "block";
        if (ckbox.is(':checked')) {
            $.ajax({
                type: "POST",
                url: "@Url.Action("Book", "Air")",
                data:  vm ,
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (response) {
                document.getElementById("loadermoney").style.display = "none";
                if (response != null) {
                    var respo = JSON.parse(response);

                    if(respo.Content.ADDINFO.Error.ErrorCode == 0)
                    {
                        //alert("booking success");
                        var ADDINFOResponse = respo.Content.ADDINFO.Response;
                        var FlightItinerary = respo.Content.ADDINFO.Response.FlightItinerary;
                        var Email = FlightItinerary.Passenger[0].Email;
                        var mobile = FlightItinerary.Passenger[0].ContactNo;
                        $("#PNR_BookingDetails").show();

                        var leftcol = $("#PNR_BookingDetails").find("div#leftCol");
                        var rightCol = $("#PNR_BookingDetails").find("div#rightCol");
                        rightCol.css("text-align", "right");
                        var leftColText = "Email : " + Email;
                        leftColText = leftColText +"<br/>Contact : " + mobile;
                        var rightColText = "PNR: " + ADDINFOResponse.PNR;
                        if (ADDINFOResponse.IsTimeChanged) {
                            alert("time changed");
                            rightColText = rightColText + "<br/>New Time : " + FlightItinerary.Segments[0].StopPointDepartureTime;
                        }
                        if (ADDINFOResponse.IsPriceChanged) {
                            var IsContinue = confirm("Oops! \n Search fare has been changed!\n Do you want to continue with new price: " + FlightItinerary.Fare.OfferedFare + "?");
                            if (IsContinue == true) {
                                var Fare = FlightItinerary.Fare;
                                alert("TODO\n Work in progress");
                            } else {
                                //TODO
                            }
                        }
                        else {
                            $("#btnReleasePNR").show();
                            $("#btnBook").hide();
                            $("#TandParentDiv").hide();
                        }
                        $("#PNRNO").val(ADDINFOResponse.PNR);
                        $("#BookingID").val(ADDINFOResponse.BookingId);
                        $("#OfferedFare").val(FlightItinerary.Fare.OfferedFare);
                        $("#PublishedFare").val(FlightItinerary.Fare.PublishedFare)
                        $("#ItinerarySource").val(FlightItinerary.Source)
                        leftcol.html(leftColText);
                        rightCol.html(rightColText);
                    }
                    else {
                        alert("ErrorMessage: " + respo.Content.ADDINFO.Error.ErrorMessage);
                    }
                } else {
                    alert("Something went wrong");
                }
            },
            failure: function (response) {
                document.getElementById("loadermoney").style.display = "none";
                alert(response.responseText);
            },
            error: function (response) {
                document.getElementById("loadermoney").style.display = "none";
                alert(response.responseText);
            }
        });

    } else {
        //alert('You Un-Checked it');
            $("#basic_checkbox_2-error").show();
        }
    })

    $("#btnTicket").on('click', function () {
        var traceid1 = '@Model.TraceId'.toString();
        var pnr = $("#PNRNO").val();
        var bookingid = $("#BookingID").val();
        var offeredFare = $("#OfferedFare").val();
        var PubFare = $("#PublishedFare").val();
        //alert(traceid1);
        var jsonRequestObj = { TraceId: traceid1.toString(), PNR: pnr, BookingId: bookingid, OfferedFare: offeredFare, PublishedFare: PubFare }
        var jjj = JSON.stringify(jsonRequestObj);
        if(traceid1 != null && traceid1!= '')
        {
            //alert("traceid1  " +traceid1);
            if (pnr != null && pnr != '') {
                if (bookingid != null && bookingid != '') {
                    //////////////////  ticket ////////////
                    document.getElementById("loadermoney").style.display = "block";
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("TicketNonLCC", "Air")",
                        data: jjj,
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function (response) {
                        document.getElementById("loadermoney").style.display = "none";
                        if (response != null) {
                            var respo = JSON.parse(response);
                            var respoString = JSON.stringify(respo);
                            if (respo.Content.ADDINFO.ResponseStatus != null ) {
                                if (respo.Content.ADDINFO.Response.TicketStatus == 1)
                                {
                                    alert("Ticket Success")
                                    var bookingDetailsURL = '@Url.Action("TicketReport","Air")';
                                    window.location = bookingDetailsURL;
                                }
                                else {
                                    alert(respo.Content.ADDINFO.Response.Message);
                                }
                                if (respoString.includes("ErrorCode") && respo.Content.ADDINFO.Error.ErrorCode == 0) {
                                    //alert("ticket success");
                                    var ADDINFOResponse = respo.Content.ADDINFO.Response;
                                    //alert(ADDINFOResponse);
                                }
                                else {
                                    alert("ErrorMessage: " + respo.Content.ADDINFO.Error.ErrorMessage);
                                }
                            } else {
                                alert("Something went wrong");
                            }
                        } else {
                            alert("Something went wrong");
                        }
                    },
                        failure: function (response) {
                            document.getElementById("loadermoney").style.display = "none";
                        alert(response.responseText);
                    },
                        error: function (response) {
                            document.getElementById("loadermoney").style.display = "none";
                        alert(response.responseText);
                    }
                });
                /////////////////////////////////////////
            }
            else {
                alert("Unable to proccess request!");
            }
        }
        else {
            alert("Unable to proccess request!");
        }
    }
    else
    {
            alert("Unable to proccess request!");
    }
    });
</script>
