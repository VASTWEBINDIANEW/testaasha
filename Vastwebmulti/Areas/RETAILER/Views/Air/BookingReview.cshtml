                                                                TimeSpan spWorkMin = TimeSpan.FromMinutes(item.Duration);
                                                            }
                                                            @string.Format("{0:00}:{1:00}", (int)spWorkMin.TotalHours, spWorkMin.Minutes) approax
                                                        </div>

                                                        @*<div class="col-md-2">
                                                    <button class="btn btn-primary bg-dark-green">Book Now</button>
                                                </div>*@
                                                    </div>

                                                    <div class="Important-content">
                                                        <strong><img src="~/ashok-images/info.svg" style="width:15px;margin-right: 5px;">Important Note</strong>
                                                        <p><span></span>The Fare Rules for your flight selection have changed. Please review them before proceeding.</p>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
