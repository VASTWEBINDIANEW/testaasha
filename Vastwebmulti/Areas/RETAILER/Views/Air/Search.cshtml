<script>
    function getvalue() {
        var value = document.querySelector('input[name="JourneyType"]:checked').value;
        if (value == "1") {
            $("#divForSpacialReturn").hide();
            document.getElementById("txt_to_date").disabled = true;
            document.getElementById("txt_to_date").style.color = "white";
            document.getElementById('txt_to_date').style.backgroundColor = "white";
            document.getElementById("txt_to_date").style.paddingLeft = "10px";
            document.getElementById("txt_to_date").style.fontSize = "16px";
            $("#multicityDynamic").empty();
        }
        if (value == "2" || value == "5") {

            if (value == "5") {
                $("#divForSpacialReturn").show();
            } else {
                $("#divForSpacialReturn").hide();
            }
            document.getElementById("txt_to_date").disabled = false;
            document.getElementById("txt_to_date").style = backgroundColor = "white";
            document.getElementById("txt_to_date").style.paddingLeft = "10px";
            document.getElementById("txt_to_date").style.border = "1px solid #dddddd";
            document.getElementById("txt_to_date").style.height = "37px";
            document.getElementById("txt_to_date").style.marginTop = "6px";
            $("#multicityDynamic").empty();
        }
        if (value == "4") {
            $("#divAdvanceSearch").show();
            $("#multicityDynamic").empty();
        }
        else {
            $("#divAdvanceSearch").hide();
        }
    }
</script>

<script>
                function GetSourceByIndex(src)
                {
                    
                    var chk = $('#destispan').text();
                    var data = @Html.Raw(Json.Encode(Model));
                    var results = data.Content.Addinfo.Results;
                    var srcItem = results[0];
                    var DstnItem = results[1];
                    $('#radio_'+src).attr("checked",true);
                    var DstnRadionValue = $('[name=DestinationRadio]:checked').val();
                   // var SourceRadioValue = $('[name=SourceRadio]:checked').val();
                    //alert('SourceRadioValue : '+SourceRadioValue);

                    // $('#radio_'+SourceRadioValue).attr("checked",false);
                    var ResultItem1 = new Object();
                    var ResultItem2 = new Object();
                    var arrItem = [];
                    ///
                    var destichange = "NOT";
                    for(var i =0 ;i<srcItem.length;i++)
                    {

                        var selectedItem = srcItem[i];
                        var apinm = selectedItem.Apinm;
                        var fixapinm = "";
                       
                        if(selectedItem.ResultIndex == src)
                        {
                            if (apinm == null) {
                                apinm = "TBO";
                            }
                            if (apinm != chk) {
                                destichange = "OK";
                            }
              
                            fixapinm = selectedItem.Apinm;
                            ResultItem1 = selectedItem;
                            var size = ResultItem1.Segments[0].length;
                            for (var aa = 0; aa < size; aa++) {
                                var date = ResultItem1.Segments[0][aa].Origin.DepTime;
  
                                var d = new Date(parseInt(date.replace(/(^.*\()|([+-].*$)/g, '')));
                                var dformat = d.getFullYear() + '-' + d.getMonth() + '-' + d.getDate() + ' ' + d.getHours() + ':' + d.getMinutes() + ':' + d.getSeconds();
                                ResultItem1.Segments[0][aa].Origin.DepTime = dformat;
