<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script>
    var txt_frm_date = $('#txt_frm_date').val();
    var txt_to_date = $('#txt_to_date').val();
    var ddl_status = $('#ddl_status').val();
    var PNR = $('#PNR').val();
        var pageindex = 2;
        var NoMoredata = false;
        var inProgress = false;
    $(window).scroll(function () {
            if ($(window).scrollTop() > Number($("#tbldata").height()) / 4 && !NoMoredata && !inProgress) {
                inProgress = true;
                $("#loadingdiv").show();
                $.post("@Url.Action("InfiniteScroll_cancelticket","Home")",
                    { "pageindex": pageindex, "PNR": PNR,"ddl_status":ddl_status, "frm_date": txt_frm_date, "to_date": txt_to_date },
                    function (data) {
                        pageindex = pageindex + 1;
                        NoMoredata = data.NoMoredata;
                        $("#trow").append(data.HTMLString);
                        $("#loadingdiv").hide();
                        inProgress = false;
                    });
            }
        });
</script>
<script>
    function OnSuccess(data) {
        //alert("s");
        var respo = JSON.parse(data);
        if (respo.Status == "Success") {
            swal("Wow!", respo.Message, "success");
            setTimeout(function () {
                location.reload();
            }, 3000);
        } else {
            swal("Oops!", respo.Message, "error");
        }
    }
    function OnFailure() {
        swal("Oops!", "Unable to fatch data", "error");
    }
</script>

<script>
    $(document).ready(function () {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

    });
</script>


<script>
    $(document).ready(function () {
        var current = location.pathname;
        $('#custnav li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('activee');
                $this.addClass('navbar');

            }
        })
    });
</script>


<script>
    $(function() {
  var loc = window.location.href; // returns the full URL
  if('/RETAILER/Air/CancellationReport') {
    $('#flightaddclass ul li:first-child a, .list.report-list-change li#rewertyd a').addClass('active');
  }
});
</script>
<script>
    $("#btnExport").click(function (e) {
        e.preventDefault()
        
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var ddl_status = $('#ddl_status').val();
        var PNR = $('#PNR').val();
        var bookingid = $('#bookingid').val();
        var cancelreqid = $('#cancelreqid').val();
        var tracid = $('#tracid').val();
        var url = '@Url.Action("Excel_Cancellation_Report", "Air")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&ddl_status=' + ddl_status + '&PNR=' + PNR + '&bookingid=' + bookingid + '&cancelreqid=' + cancelreqid + '&tracid=' + tracid;
        location.href = url;
});
</script>
<script>
    $("#btnPDF").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var ddl_status = $('#ddl_status').val();
        var PNR = $('#PNR').val();
        var bookingid = $('#bookingid').val();
        var cancelreqid = $('#cancelreqid').val();
        var tracid = $('#tracid').val();
        var url = '@Url.Action("PDF_CancellationReport", "Air")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&ddl_status=' + ddl_status + '&PNR=' + PNR + '&bookingid=' + bookingid + '&cancelreqid=' + cancelreqid + '&tracid=' + tracid;
        window.open(
url,
  '_blank' // <- This is what makes it open in a new window.
);
    });
</script>

