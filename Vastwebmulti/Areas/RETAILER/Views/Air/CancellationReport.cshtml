                            <div class="page-header-third">
                                <div class="table-responsive flightcancel-responsive" style="position:inherit;">
                                    <table id="example" class="table table-bordered table-striped table-hover" cellspacing="0" style="width:100%;font-size:12px;">
                                        <thead style="color:black;position:inherit;background-color:whitesmoke;">
