@model Vastwebmulti.Areas.RETAILER.ViewModels.FlightDetailsVM
@{
    ViewBag.Title = "Travel";
    Layout = "~/Areas/RETAILER/Views/Shared/_Layout.cshtml";
    decimal markup = ViewBag.RetailerMarkup;
}
<style>
    .scrollypy {
        overflow-y: auto !important;
        height: 250px;
    }

    .btmPlusMinus {
        padding: 3px 6px;
        margin-right: 4px;
        padding-bottom: 6px;
        border-radius: 5px;
    }

        .btmPlusMinus i {
            font-size: 10px;
        }

    .table {
        display: table; /* Allow the centering to work */
        margin: 0 auto;
    }

    ul#horizontal-list {
        min-width: 696px;
        list-style: none;
        padding-top: 20px;
    }

        ul#horizontal-list li {
            display: inline;
            text-align: center;
            padding: 20px;
        }

    span.field-validation-error {
        font-size: 12px;
        display: block;
        margin-top: 5px;
        font-weight: normal;
        color: #F44336;
    }

    .vertical-text {
        /*transform: rotate(90deg);
    transform-origin: left top 0;
    float:left;
    position:absolute;*/
        transform: rotate(-90deg);
        -ms-transform: rotate(-90deg);
        -webkit-transform: rotate(-90deg);
        bottom: 0%;
        top: 125%;
        right: 93%;
        position: absolute;
        color: var(--main-bg-lcolor);
    }
</style>
<link rel="stylesheet" href="http://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
<link rel="stylesheet" href="http://netdna.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
<link href="~/AdminDesign/Retailer_Slider/Slieder.css" rel="stylesheet" />
@*@Html.Partial("_FareQuote",Model.FareQuoteVM)*@
<section class="content contentgfdjkgfdifgjg contentgfdjkg-responshive" style="margin-left: 10px;margin-right: 10px;">
    <div class="container-fluid">
        <div class="row">



            <!--Flight Rules-->
            <div class="col-md-3 flight-rules">


                <!-- Fare Details -->
                <div class="col-md-3 flightbook-fare">
                    <div class="row">
                        <div class="block-header" style="padding: 12px 0 22px 1px;margin-bottom: 4px;">
                            <h2>Fare Details</h2>
                        </div>
                        <div class="row">
                            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 bookfare">
                                <div class="card bookfared">
                                    <div class="body bg-white bookfaredc">
                                        @{
                                            var of = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.OfferedFare;
                                            var pf = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.PublishedFare;
                                            var bf = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.BaseFare;
                                            var tax = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.Tax;
                                            var TxnFee = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Fare.AdditionalTxnFeeOfrd;
                                            if (Model.isDomastic && Model.JourneyType == 2)
                                            {
                                                of = of + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.OfferedFare;
                                                pf = pf + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.PublishedFare;
                                                bf = bf + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.BaseFare;
                                                tax = tax + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.Tax;
                                                TxnFee = TxnFee + Model.Inward.FareQuoteVM.Content.Addinfo.Results.Fare.AdditionalTxnFeeOfrd;
                                            }

                                            var otherCharge = pf - (bf + tax + TxnFee);
                                            TxnFee = TxnFee + markup;
                                            pf = pf + markup;
                                        }
                                        <div>
                                            Base Fare <span class="pull-right">@bf</span><br>
                                            Fuel & Tax <span class="pull-right">@tax</span><br>
                                            Other Charges <span class="pull-right">@otherCharge</span><br>
                                            Txn Fee <span class="pull-right">@TxnFee</span><br>
                                            <strong>Total Fare <span class="pull-right" id="totalPubFare">@pf</span></strong>
                                            <br>
                                            @*<span>
                                                    <i class="fa fa-eye fa-2x" onclick="getOfferFare('@of')"></i>
                                                </span>*@
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>


                </div>
                <!-- #END# Fare Details -->



                <div class="farerules-full">
                    <h2>
                        Fare Rules <span class="from-to-class" style="float:right;">
                            @{
                                var source = ""; var desti = "";
                                var count = @Model.Onward.FareQuoteVM.Content.Addinfo.Results.Segments[0].Count;
                                count = count - 1;
                                source = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Segments[0][0].Origin.Airport.CityName;
                                desti = Model.Onward.FareQuoteVM.Content.Addinfo.Results.Segments[0][count].Destination.Airport.CityName;
                            }
                            @source-@desti
                        </span>
                    </h2>
                    <div class="cancellation" style="padding-top: 21px;">
                        <h3>Cancellation Fee <span>(Per Guest/Sector)</span></h3>
                        <span>Prior to the date/time of departure</span>
                    </div>
                    @if (ViewBag.FareRuleOB != null)
                    {
                        var OBFareRule = (Vastwebmulti.Areas.RETAILER.ViewModels.FareRuleVM)ViewBag.FareRuleOB;
                        foreach (var item in OBFareRule.Content.Addinfo.FareRules)
                        {

                            <!--    <strong>@item.Origin - @item.Destination</strong><br />-->
                            string[] stringSeparators = new string[] { "\r\n" };
                            string[] lines = item.FareRuleDetail.Split(stringSeparators, StringSplitOptions.None);
                            //Console.WriteLine("Nr. Of items in list: " + lines.Length); // 2 lines
                            foreach (string s in lines)
                            {
                                //Console.WriteLine(s); //But will print 3 lines in total.
                                <span class="economy11">@Html.Raw(s)</span>
                            }

                        }
                    }
                </div>
                @if (Model.JourneyType == 2)
                {
                    <div class="farerules-full">
                        <h2>
                            Fare Rules <span class="from-to-class" style="float:right;">
                                @{
                                    source = ""; desti = "";
                                    if (@Model.Inward != null)
                                    {
                                        count = @Model.Inward.FareQuoteVM.Content.Addinfo.Results.Segments[0].Count;
                                        count = count - 1;
                                        source = Model.Inward.FareQuoteVM.Content.Addinfo.Results.Segments[0][0].Origin.Airport.CityName;
                                        desti = Model.Inward.FareQuoteVM.Content.Addinfo.Results.Segments[0][count].Destination.Airport.CityName;
                                    }
                                }
                                @source-@desti
                            </span>
                        </h2>
                        <div class="cancellation" style="padding-top: 21px;">
                            <h3>Cancellation Fee <span>(Per Guest/Sector)</span></h3>
                            <span>Prior to the date/time of departure</span>
                        </div>
                        @if (Model.isDomastic && Model.JourneyType == 2)
                        {
                            <div class="row">
                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                    <div class="card" style="min-height:auto;height:auto;margin-bottom:0;">
                                        <div class="body bg-white slimScrollDiv" style="height:auto;">

                                            @*@foreach (var item in Model.Inward.FareRuleVM.Content.Addinfo.FareRules)*@
                                            @if (ViewBag.FareRuleIB != null)
                                            {
                                                var IBFareRule = (Vastwebmulti.Areas.RETAILER.ViewModels.FareRuleVM)ViewBag.FareRuleIB;
                                                foreach (var item in IBFareRule.Content.Addinfo.FareRules)
                                                {
                                                    <strong>@item.Origin - @item.Destination</strong><br />
                                                    string[] stringSeparators = new string[] { "\r\n" };
                                                    string[] lines = item.FareRuleDetail.Split(stringSeparators, StringSplitOptions.None);
                                                    //Console.WriteLine("Nr. Of items in list: " + lines.Length); // 2 lines
                                                    foreach (string s in lines)
                                                    {
                                                        //Console.WriteLine(s); //But will print 3 lines in total.
                                                        @Html.Raw(s)<br />
                                                    }

                                                }
                                            }

                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <!--Flight Rules-->
            <div class="col-md-9 flight-book flight-book-responshive">
                <!-- Flight Details start -->
                <div class="block-header book-block-header" style="padding: 12px 0 22px 1px;background: #a4a0a0 !important;">
                    @*<h2>NO HEADER CARDS</h2>*@
                    <div class="col-md-6 pull-left bookfight-Review">
                        <h2>Review Your Booking</h2>
                    </div>
                    <div class="col-md-6 flight-back" style="text-align:right;">
                        @*<button type="button" class="btn bg-purple waves-effect pull-right">
                                <i class="material-icons">search</i>
                                <span>Modify Search</span>
                            </button>*@
                        <a src="javascript:void(0)" onclick="goBack()">change Flight</a>
                    </div>
                </div>

                <div class="row">

                    @if (Model.Onward.FareQuoteVM != null)
                    {
                        int SegmentsIndex = 0;
                        foreach (var item in Model.Onward.FareQuoteVM.Content.Addinfo.Results.Segments)
                        {

                            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                <div class="card">
                                    <div class="body bg-white class-changebg">
                                        <div class="table">
                                            @foreach (var sgmtItem in item)
                                            {
                                                <div class="row clearfix">
                                                    <div class="col-md-3" style="padding-right:0px;padding-left:0px;width: 16%;">
                                                        @if (SegmentsIndex == 0)
                                                        {
                                                            <strong class="vertical-text">DEPARTURE</strong>
                                                        }
                                                        else
                                                        {
                                                            <strong class="vertical-text vertical-text11">RETURN&nbsp;&nbsp;</strong>
                                                        }
                                                        <div class="media" style="margin:0px;">
                                                            <div class="media-left">
                                                                <a href="javascript:void(0);">
                                                                    @{
                                                                        var AirlineCode = sgmtItem.Airline.AirlineCode;
                                                                        var dir = Server.MapPath("~/images/AirlineLogo");
                                                                        var myFiles = Directory.GetFiles(dir, "" + AirlineCode + ".*", SearchOption.AllDirectories);
                                                                    }

                                                                    @if (myFiles != null && myFiles.Length > 0)
                                                                    {
                                                                        string pPath = myFiles[0];
                                                                        int endIndex = pPath.LastIndexOf(@"\");
                                                                        string vPath = "~/images/AirlineLogo/" + pPath.Remove(0, endIndex);
                                                                        <img class="media-object" src="@Url.Content(vPath)" width="32" height="32">
                                                                    }
                                                                    else
                                                                    {
                                                                        <img class="media-object" src="http://placehold.it/32x32" width="32" height="32">
                                                                    }
                                                                </a><br />
                                                            </div>
                                                            <div class="media-body" style="text-align:left;">
                                                                <h4 class="media-heading">@sgmtItem.Airline.AirlineName</h4>
                                                                @sgmtItem.Airline.AirlineCode - @sgmtItem.Airline.FlightNumber
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="timeDiv col-md-9 timeDiv-book" style="padding-right:0px;padding-left:0px;width: 84% !important;margin-bottom:0 !important;">
                                                        <div class="row" style="margin:0;">
                                                            <div class="col-md-3 changename" style="padding-left:0px;padding-right:0px;">
                                                                <span class="channame">  @sgmtItem.Origin.Airport.CityName (@sgmtItem.Origin.Airport.AirportCode)  </span>
                                                                <strong>@string.Format("{0}", sgmtItem.Origin.DepTime != null ? Convert.ToDateTime(sgmtItem.Origin.DepTime).ToString("HH:mm") : "")</strong>
                                                                <Bold>@string.Format("{0}", sgmtItem.Origin.DepTime != null ? Convert.ToDateTime(sgmtItem.Origin.DepTime).ToString("ddd, dd MMM yyyy") : "")</Bold>

                                                                <span class="flightcity"> @sgmtItem.Origin.Airport.AirportName (Terminal : @sgmtItem.Origin.Airport.Terminal) </span>
                                                            </div>
                                                            <div class="col-md-3 flight-afterpadding" style="text-align:right;padding-right:0px;">

                                                                <div class="demo-google-material-icon flight-after" style="text-align:center;">


                                                                    Baggage(@sgmtItem.Baggage + @sgmtItem.CabinBaggage) KG

                                                                </div>

                                                            </div>
                                                            <div class="col-md-3 changename" style="padding-right:0px;">
                                                                <span class="channame">  @sgmtItem.Destination.Airport.CityName (@sgmtItem.Destination.Airport.AirportCode) </span>
                                                                <strong>@Convert.ToDateTime(sgmtItem.Destination.ArrTime).ToString("HH:mm")</strong>
                                                                <Bold>@Convert.ToDateTime(sgmtItem.Destination.ArrTime).ToString("ddd, dd MMM yyyy")</Bold>

                                                                <span class="flightcity"> @sgmtItem.Destination.Airport.AirportName&nbsp;(Terminal : @sgmtItem.Destination.Airport.Terminal)</span>
                                                            </div>

                                                            <div class="col-md-2">
                                                                @{
                                                                    TimeSpan spWorkMin = TimeSpan.FromMinutes(sgmtItem.Duration);
                                                                }
                                                                @string.Format("{0:00}:{1:00}", (int)spWorkMin.TotalHours, spWorkMin.Minutes) approax
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="Important-content">
                                                        <strong><img src="~/ashok-images/info.svg" style="width:15px;margin-right: 5px;" />Important Note</strong>
                                                        <p><span></span>The Fare Rules for your flight selection have changed. Please review them before proceeding.</p>
                                                    </div>

                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            SegmentsIndex++;
                        }
                    }
                </div>
                @if (Model.isDomastic && Model.JourneyType == 2)
                {
                    <div class="row">
                        @if (Model.Inward != null && Model.Inward.FareQuoteVM != null)
                        {
                            foreach (var sgmt in Model.Inward.FareQuoteVM.Content.Addinfo.Results.Segments)
                            {
                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                    <div class="card">
                                        <div class="body bg-white class-changebg">
                                            <div class="table">
                                                @foreach (var item in sgmt)
                                                {
                                                    <div class="row clearfix">
                                                        <div class="col-md-3 class-autow" style="padding-right:0px;padding-left:0px;">
                                                            <strong class="vertical-text" style="padding-right: 25px;top: 0;right:73%;">RETURN</strong>
                                                            <div class="media media-leftdiv">
                                                                <div class="media-left">
                                                                    <a href="javascript:void(0);">
                                                                        @{
                                                                            var AirlineCode = item.Airline.AirlineCode;
                                                                            var dir = Server.MapPath("~/images/AirlineLogo");
                                                                            var myFiles = Directory.GetFiles(dir, "" + AirlineCode + ".*", SearchOption.AllDirectories);
                                                                        }
                                                                        @if (myFiles != null && myFiles.Length > 0)
                                                                        {
                                                                            string pPath = myFiles[0];
                                                                            int endIndex = pPath.LastIndexOf(@"\");
                                                                            string vPath = "~/images/AirlineLogo/" + pPath.Remove(0, endIndex);
                                                                            <img class="media-object" src="@Url.Content(vPath)" width="32" height="32">
                                                                        }
                                                                        else
                                                                        {
                                                                            <img class="media-object" src="http://placehold.it/32x32" width="32" height="32">
                                                                        }
                                                                    </a><br />
                                                                </div>
                                                                <div class="media-body" style="text-align:left;">
                                                                    <h4 class="media-heading">@item.Airline.AirlineName</h4>
                                                                    @item.Airline.AirlineCode - @item.Airline.FlightNumber
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="timeDiv col-md-9 timeDiv-book" style="padding-right:0px;padding-left:0px;width: 84% !important;margin: 0 !important;">
                                                            <div class="col-md-3 changename" style="padding-left:0px;padding-right:0px;">
                                                                <span class="channame">@item.Origin.Airport.CityName (@item.Origin.Airport.AirportCode)</span><br />
                                                                <strong>@string.Format("{0}", item.Origin.DepTime != null ? Convert.ToDateTime(item.Origin.DepTime).ToString("HH:mm") : "")</strong> <br />
                                                                <Bold>@string.Format("{0}", item.Origin.DepTime != null ? Convert.ToDateTime(item.Origin.DepTime).ToString("ddd, dd MMM yyyy") : "")</Bold> <br />

                                                                <span class="flightcity">@item.Origin.Airport.AirportName (Terminal :&nbsp;@item.Origin.Airport.Terminal)</span>
                                                            </div>
                                                            <div class="col-md-3 flight-afterpadding" style="text-align:right;padding-right:0px;">

                                                                <div class="demo-google-material-icon flight-after" style="text-align:center;">
                                                                    Baggage(@item.Baggage + @item.CabinBaggage) KG
                                                                </div>


                                                            </div>
                                                            <div class="col-md-3 changename" style="padding-right:0px;">
                                                                <span class="channame">@item.Destination.Airport.CityName (@item.Destination.Airport.AirportCode)</span><br />
                                                                <strong>@Convert.ToDateTime(item.Destination.ArrTime).ToString("HH:mm")</strong> <br />
                                                                <Bold>@Convert.ToDateTime(item.Destination.ArrTime).ToString("ddd, dd MMM yyyy")</Bold> <br />

                                                                <span class="flightcity">@item.Destination.Airport.AirportName (Terminal : @item.Destination.Airport.Terminal)</span>
                                                            </div>
                                                            <div class="col-md-2" style="padding-right: 0;">
                                                                @{
                                                                    TimeSpan spWorkMin = TimeSpan.FromMinutes(item.Duration);
                                                                }
                                                                @string.Format("{0:00}:{1:00}", (int)spWorkMin.TotalHours, spWorkMin.Minutes) approax
                                                            </div>

                                                            @*<div class="col-md-2">
                                                                    <button class="btn btn-primary bg-dark-green">Book Now</button>
                                                                </div>*@
                                                        </div>

                                                        <div class="Important-content">
                                                            <strong><img src="~/ashok-images/info.svg" style="width:15px;margin-right: 5px;" />Important Note</strong>
                                                            <p><span></span>The Fare Rules for your flight selection have changed. Please review them before proceeding.</p>
                                                        </div>

                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }
                <!-- #END# Flight Details start -->
                <!-- Passanger Details-->
                @*<form id="form_advanced_validation" method="POST" novalidate="novalidate">*@
                @using (Html.BeginForm("BookingReview", "Air", FormMethod.Post))
                {
                    @Html.ValidationSummary(true)
                    @Html.ValidationMessage("CustomError")
                    List<SelectListItem> Title = new List<SelectListItem>()
                                            {
                              new SelectListItem {Text="Mr",Value="Mr",Selected=false },
                              new SelectListItem {Text="Ms",Value="Ms" },
                              new SelectListItem {Text="Mrs",Value="Mrs"},
                              new SelectListItem {Text="Miss",Value="Miss"}
                                };
                    @Html.HiddenFor(m => m.JourneyType)
                    @Html.HiddenFor(m => m.InBoundResultIndexForSpacailReturn)
                    int PaxCounter = 1;
                    int adultCounter = 1;

                    foreach (var item in Model.AdultPax)
                    {
                        @Html.HiddenFor(m => m.AdultPax[adultCounter - 1].PaxType)
                        <!-- Adult Details-->
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 passanger-header-cardpage" style="padding-left: 0px;padding-right: 0px;">
                            <div class="card passanger-header-card">
                                <div class="header passanger-header" style="background: #a4a0a0;">
                                    <h2>Passanger @PaxCounter (Adult @adultCounter)  </h2>


                                    @if (!Model.isDomastic)
                                    {
                                        <div class="passport-full">
                                            <div class="passport-fullright">
                                                <div class="col-md-3 Passport-css">
                                                    <div class="form-group form-float">
                                                        <div class="help-info">Passport Number</div>
                                                        <div class="form-line">
                                                            @Html.TextBoxFor(m => m.AdultPax[adultCounter - 1].PassportNo, new { @class = "form-control" })
                                                        </div>

                                                        @Html.ValidationMessageFor(m => m.AdultPax[adultCounter - 1].PassportNo, "")
                                                    </div>
                                                </div>
                                                <div class="col-md-3 passport-exp-css">
                                                    <div class="form-group form-float">
                                                        <div class="help-info">Passport Exp Date</div>
                                                        <div class="form-line">
                                                            <div class="form-iconmy flight-exp" style="top:20px;left:11px;"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                                            @Html.TextBoxFor(m => m.AdultPax[adultCounter - 1].PassportExpiry, new { @class = "form-control", @type = "date" })
                                                        </div>

                                                        @Html.ValidationMessageFor(m => m.AdultPax[adultCounter - 1].PassportExpiry, "")
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                    }



                                </div>
                                <div class="body passanger-body" style="background: #f5f5f5;">
                                    <div class="row clearfix">
                                        <div class="border-top1" style="height:1px;"></div>
                                        <div class="col-md-2 title-css">
                                            <div class="form-group form-float">
                                                <div class="help-info">Title</div>
                                                <div class="form-line focused">
                                                    @Html.DropDownListFor(m => m.AdultPax[adultCounter - 1].Title, Title, "Title", new { @class = "form-control" })
                                                </div>

                                                @Html.ValidationMessageFor(m => m.AdultPax[adultCounter - 1].Title, "")
                                            </div>
                                        </div>
                                        <div class="col-md-2 Adult-css">
                                            <div class="form-group form-float">
                                                <div class="help-info">First Name</div>
                                                <div class="form-line ">
                                                    @Html.TextBoxFor(m => m.AdultPax[adultCounter - 1].FirstName, new { @class = "form-control" })
                                                </div>

                                                @Html.ValidationMessageFor(m => m.AdultPax[adultCounter - 1].FirstName, "")
                                            </div>
                                        </div>
                                        <div class="col-md-2 Adult-css">
                                            <div class="form-group form-float">
                                                <div class="help-info">Last Name</div>
                                                <div class="form-line ">
                                                    @Html.TextBoxFor(m => m.AdultPax[adultCounter - 1].LastName, new { @class = "form-control" })
                                                </div>

                                                @Html.ValidationMessageFor(m => m.AdultPax[adultCounter - 1].LastName, "")
                                            </div>
                                        </div>
                                        <div class="col-md-3 Adult-css Adult-css1">
                                            <div class="form-group form-float">
                                                <div class="help-info">Date od Birth</div>
                                                <div class="form-line">
                                                    <div class="form-iconmy flight-exp" style="top:20px;left:11px;"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                                    @Html.TextBoxFor(m => m.AdultPax[adultCounter - 1].DateOfBirth, new { @type = "date", @class = "form-control" })
                                                </div>

                                                @Html.ValidationMessageFor(m => m.AdultPax[adultCounter - 1].DateOfBirth, "")
                                            </div>
                                        </div>

                                    </div>
                                    <div class="row clearfix">
                                        @if (PaxCounter == 1)
                                        {
                                            <div class="col-md-3 email-css">
                                                <div class="form-group form-float">
                                                    <div class="help-info">Email Address</div>
                                                    <div class="form-line">
                                                        @Html.TextBoxFor(m => m.AdultPax[adultCounter - 1].Email, new { @class = "form-control" })
                                                    </div>

                                                    @Html.ValidationMessageFor(m => m.AdultPax[adultCounter - 1].Email, "")
                                                </div>
                                            </div>
                                        }

                                        @if (PaxCounter == 1)
