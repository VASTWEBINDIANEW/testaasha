@model IEnumerable<Vastwebmulti.Models.proc_Complaint_request_Result>
@{
    ViewBag.Title = "Complaint";
    Layout = "~/Areas/API/Views/Shared/_Layout.cshtml";
}
<link href="~/Swalalert/chatting.css" rel="stylesheet" />
<style>
    .api-admin-chat .header, .api-admin-massege .panel-heading {
        background-color: rgb(222 221 221) !important;
        width: 100%;
        float: left;
        padding: 10px 15px !important;
        padding-bottom: 9px;
        border-top-left-radius: 3px;
        border-top-right-radius: 3px;
    }
    .api-admin-chat .header h2 span, .api-admin-chat .header h2 i ,.api-admin-massege .panel-heading ,.api-admin-massege .panel-heading span{
    font-size: 14px !important;
    color: #555 !important;
    position: static;
    line-height: normal;
}
    .api-admin-chat .form-group {
        margin-top: 0 !important;
    }
    .api-admin-massege .panel-heading {
    padding: 12px 15px !important;
}
    .chat.apiadminchatmassege li .chat-img img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
}
    .chat.apiadminchatmassege ,.chat.apiadminchatmassege li{
    width: 100%;
    float: left;
}
    .full-chatbackground .chat-body.clearfix {
    float: left;
    background: var(--main-bg-lcolor);
    
    
}
    .chat.apiadminchatmassege li .chat-body.clearfix p, .chat.apiadminchatmassege li .chat-body.clearfix span {
    color: #fff;
    margin: 0 !important;
    padding: 0 !important;
}
    .chat.apiadminchatmassege li .header {
    width: auto !important;
    padding: 0 !important;
    float: right;
}
    .chat.apiadminchatmassege li .chat-body.clearfix {
        padding: 6px 15px;
        min-width:40%;position:relative;border-radius:8px;box-shadow: 0px 3px 5px 0px #555;
    }
        .chat.apiadminchatmassege li .chat-body.clearfix::after {
            content: "";
            width: 27px;
            right: 0px;
            top: 0;
            position: absolute;
            border-style: solid;
            border-width: 0 20px 15px 0;
            border-color: rgb(0 0 0 / 0%) var(--main-bg-lcolor) rgb(0 0 0 / 0%) rgb(0 0 0 / 0%);
        }

    .full-chatbackground .chat-body.clearfix::after {
        left: -21px;
    }

    .full-chatbackground-right {
        width: auto !important;
        float: right !important;
    }

        .full-chatbackground-right .chat-body.clearfix {
            float: left;
            margin: 0 !important;
            margin-right: 0px;
            background: var(--main-bg-rcolor);
            min-width: 347px !important;
            margin-right:25px !important;
        }
    .full-chatbackground-right .chat-img.pull-left {
    float: right !important;
}
    .full-chatbackground-right .chat-img.pull-left p {
    margin-left: -2px !important;
    text-align: center;
}
    .full-chatbackground-right .chat-body.clearfix::after {
    border-width: 0 20px 15px 0 !important;
    border-color: rgb(0 0 0 / 0%) rgb(0 0 0 / 0%) var(--main-bg-rcolor) rgb(0 0 0 / 0%) !important;
    right: -18px !important;
}
    .chat.apiadminchatmassege li .chat-body.clearfix p {
    float: left;
    width: 100%;
    white-space: normal;
}
    .chat.apiadminchatmassege li .chat-body.clearfix {
    width: 500px;
}
    .chat.apiadminchatmassege li .chat-body.clearfix {
    width: 50%;
    min-width: inherit !important;
}
    .master-four-design .admin-sendmassege .chat-img p {
        color: var(--fullbodybg-four) !important;
    }
    .master-four-design .api-sendmassege .chat-img p {
        color: var(--four-design-bg-first) !important;
    }
    .master-four-design .full-chatbackground-right .chat-body.clearfix {
        background: var(--four-design-bg-first);
    }
        .master-four-design .full-chatbackground-right .chat-body.clearfix::after {
            border-color: rgb(0 0 0 / 0%) rgb(0 0 0 / 0%) var(--four-design-bg-first) rgb(0 0 0 / 0%) !important;
        }

    @@media screen and (max-width:990px) {
        .col-md-8.api-admin-massege {
            width: 100%;
            float: left;
        }
    }

    @@media screen and (max-width:766px) {
        .api-admin-chat .body {
            min-height: inherit !important;
        }
        .complaint-chat-api {
            padding-left: 0px;
        }
    }
    @@media screen and (max-width:580px){
        .chat.apiadminchatmassege li .chat-body.clearfix {
    width: 70%;
    min-width: inherit !important;
}

    }


</style>
<section class="content">
    <div class="container-fluid complaint-chat-api">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Complaint</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                @*<li><a href="javascript:void(0);">Basic Setting&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>*@
                <li><a href="javascript:void(0);">Chat's</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-4 api-admin-chat">
                <div class="card" style="width:100%;float:left;background:#f5f5f5;">

                    <div class="header" style="background-color: #dedddd; border: none;">
                        <h2 style="line-height:normal;">
                            <i class="fa fa-keyboard-o" aria-hidden="true" style="color:black; font-size:21px;"></i>&nbsp;&nbsp;<span style="color:black;">Insert Complaint</span>
                        </h2>

                    </div>
                    @using (Html.BeginForm("Complaint_insert", "Home", FormMethod.Post))
                    {
                        <div class="body" style="min-height:630px;width:100%;float:left;">
                            <div class="form-group" style="margin-top:22px;">
                                <div class="">
                                    <textarea id="message" name="message" class="form-control" style="height:189px; border:1px solid #1b171714;" required="" placeholder="Enter Message"></textarea>

                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <button type="submit" class="btn  waves-effect" style="border:1px solid #c7c2c2;background:#dedddd;width:100%;">
                                        <i class="fa fa-send-o" style="font-size: 18px;top:2px;left: -13px;padding: 8px 8px 8px 8px;background: whitesmoke;border-radius: 35px;"></i>
                                        <span style="top: 3px;font-weight: 600;font-size: 19px;text-transform: uppercase;">Insert Message</span>
                                    </button>
                                </div>
                                <div class="col-xs-6">
                                    <button type="reset" class="btn  waves-effect" style="border:1px solid #c7c2c2;background:#dedddd;width:100%;">
                                        <i class="fa fa-eraser" style="top: 1px;"></i>
                                        <span style="top:-2px;font-size: 14px;">Reset</span>
                                    </button>
                                </div>
                                <div class="col-xs-6">
                                    <a href="@Url.Action("Dashboard","Home")" class="btn  waves-effect" style="float:right;border:1px solid #c7c2c2;background:#dedddd;width:100%;">
                                        <i class="fa fa-arrow-left" style="top:0px;color: #525050;"></i>
                                        <span style="top:-2px;font-size: 14px;color:black;">Back</span>
                                    </a>
                                </div>
                            </div>




                        </div>
                    }
                </div>
            </div>
            <div class="col-md-8 api-admin-massege">

                <div class="card" style="">
                    <div class="panel-heading" style="border:0px solid #dddddd;background:#dedddd;">
                        <span class="fa fa-comments-o"></span> Chatting Details

                    </div>
                    <div class="panel-collapse collapse" style="display:block;">
                        <div class="panel-body" style="height:424px;">

                            <ul class="chat apiadminchatmassege" style="border:none !important;">

                                @foreach (var item in Model)
                                {

                                    if (item.resdate != null)
                                    {
                                        <li class="admin-sendmassege" style="">
                                            <div class="full-chatbackground" style="width:100%;float:left;">
                                                <span class="chat-img" style="float:left;">
                                                    <img src="../../images/reportimage/chatuserimage.png" />
                                                    <p style="color:var(--main-bg-lcolor) ;font-weight:700;margin-right:22px;margin-top:5px;">Admin</p>
                                                </span>
                                                <div class="chat-body clearfix">

                                                    <p style="margin-left:38px;">
                                                        @item.response
                                                    </p>
                                                    <div class="header" style="border-bottom:none;">
                                                        <p class="text-muted" style="margin-top:-14px;"><span class="fa fa-clock-o"></span>&nbsp;@item.resdate</p>
                                                        <strong class="pull-right primary-font"></strong>
                                                    </div>
                                                </div>
                                            </div>
                                        </li>

                                    }
                                    if (item.rdate != null)
                                    {

                                        <li class="left clearfix api-sendmassege" style="border:none !important;">
                                            <div class="full-chatbackground-right" style="width:100% !important;float:left !important;">

                                                <span class="chat-img pull-left">
                                                    <img src="../../images/reportimage/chatuserimage.png" />
                                                    <p style="color:var(--main-bg-rcolor);font-weight:700;margin-top:5px;margin-left:16px;">You</p>
                                                </span>
                                                <div class="chat-body clearfix" style="float:right;">

                                                    @if (item.sts == "Open")
                                                    {
                                                        <p style="margin-left:-19px; font-weight:700;">@item.complant </p>
                                                    }
                                                    else
                                                    {
                                                        <p style="margin-left:-19px;">@item.complant </p>
                                                    }
                                                    <div class="header" style="border-bottom:none;">
                                                        <strong class="primary-font"></strong> <p class="pull-right text-muted" style="margin-top:-14px;">
                                                            <span class="fa fa-clock-o"></span>&nbsp;@item.rdate
                                                        </p>
                                                    </div>

                                                </div>

                                            </div>
                                        </li>

                                    }

                                }


                            </ul>
                        </div>

                    </div>

                </div>
            </div>

        </div>

    </div>
</section>



<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>



