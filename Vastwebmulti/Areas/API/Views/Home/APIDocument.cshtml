                                    <h5 style="color:black; padding-left:22px;">
                                        SECURITY STATUS &nbsp;&nbsp;[ IP ADDRESS / MAC ADDRESS ]
                                    </h5>
                                </div>
                                <div class="col-md-6">
                                    <p style="color:red; font-size:16px; margin-top: 8px; padding-left:22px;">
                                        Note :- Please Select One At a Time.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        @{VastwebmultiEntities db = new VastwebmultiEntities();
                            var loginid = User.Identity.GetUserId();
                            var STATUS = db.Security_ip_macaddreess.Where(aa => aa.userid == loginid).SingleOrDefault();
                        }
                        <div class="col-md-3">
                            <p style="font-size:25px; margin-top:12px; padding-left:22px;">IP ADDRESS</p>
                        </div>
                        <div class="col-md-1">
                            @if (STATUS.ipsts == "Y")
                            {
                                <a href="@Url.Action("Securitysts","Home",new { idno = STATUS.idno,type="ip",sts="N" })" style="text-decoration:none;"><i class="icofont icofont-toggle-on " style="color:green;font-size:61px; padding-left:22px;"></i></a>
                            }
                            else
                            {
                                <a href="@Url.Action("Securitysts","Home",new { idno = STATUS.idno,type="ip",sts="Y" })" style="text-decoration:none;"><i class="icofont icofont-toggle-off " style="color:red;font-size:61px; padding-left:22px;"></i></a>
                            }
                        </div>
                        <div class="col-md-2">
                        </div>
                        <div class="col-md-3">
