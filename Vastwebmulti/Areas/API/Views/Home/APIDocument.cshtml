        $.ajax(
            {
            url: '@Url.Action("verifyOTP","Home")',
            type: 'POST',
            dataType: "html",
            data: {otp:otp, ipaddress: ipaddress },
            success: function (data) {
                var response = JSON.parse(data);
                if (response.Status) {
                    alert(response.Message);
                    $('#verifyOTP').css("display", "none");
                    $('#Otp').css("display", "none");
                    $('#btn').css("display", "block");
                    var url = '@Url.Action("APIDocument","Home")'
                    window.location.href = url;
               }
                else
                {
                   alert(response.Message);

                }
              },
            error: function (data) {

            }
        });
    }
</script>
