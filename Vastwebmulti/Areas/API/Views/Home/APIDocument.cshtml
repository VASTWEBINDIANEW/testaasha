                            <input type="text" name="otp" id="otp" class="form-control" placeholder="Enter OTP" required="" />
                        </div>
                        <div class="col-md-4">
                            <input type="submit" id="btn" value="Submit" class="btn btn-primary" onclick="insertip()" />
                            <button type="submit" class="btn btn-primary" onclick="VerifyOtp()" style="display:none;" id="Otp">Insert</button>
                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <div class="col-md-12">
                            <h2 style="color:black; font-size:16px; padding-left:22px;">
                                Your IP Address and Token No:-
                            </h2>
                        </div>
                    </div>
                    <div class="body" style="margin-top:-20px;">
                            <div class="table-responsive " style="position:inherit;">
                                <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%;">
                                    <thead class="navbar" style="color:white;position:inherit;">
                                        <tr>
                                            <th>Your&nbsp;Ip&nbsp;Address</th>
                                            <th>Token&nbsp;No</th>
                                            <th>Status</th>
                                            <th>Update&nbsp;Date</th>
                                            <th>Delete</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ var i = 1;}
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@item.userip</td>
                                                <td align="center"><input type="text" value="@item.token" id="@i" name="myInput" style="height:34px;background-color:#00000038; border:1px dashed #f30850;" readonly=""><button onclick="myFunction('@i')" class="btn btn-primary" style="border-top-left-radius:0px;border-bottom-left-radius:0px;background:#f30850;border-color:#f30850; height: 35px; color: white;">Copy</button></td>
                                                @{ var sts = item.status;}
                                                @if (sts)
                                                {
                                                    <td style="padding-top:0px;">
                                                        <button class="icofont icofont-toggle-on  BtnTransparent" style="font-size:46px; color:green;"></button>
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td style="padding-top:0px;">
                                                        <button class="icofont icofont-toggle-off  BtnTransparent" style="font-size:46px; color:red;"></button>
                                                    </td>
                                                }
                                                <td>@item.udate</td>
                                                <td><span id="btn1" data-toggle="modal" onclick="deleteipaddress('@item.idno')"><i class="fa fa-trash-o" aria-hidden="true" style="font-size:31px; color:#ed174c;"></i></span></td>
                                            </tr>
                                         i = i + 1;
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    <hr />
