                            {
                                <a href="@Url.Action("Securitysts","Home",new { idno = STATUS.idno,type="mac",sts="Y" })" style="text-decoration:none;"><i class="icofont icofont-toggle-off " style="color:red;font-size:61px; padding-left:22px;"></i></a>
                            }
                        </div>
                        <div class="col-md-2">
                        </div>
                    </div>
