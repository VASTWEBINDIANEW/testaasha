@model IEnumerable<Vastwebmulti.Models.bank_info>
@{
    ViewBag.Title = "Bank_Information";
    Layout = "~/Areas/API/Views/Shared/_Layout.cshtml";
}

<style>

    @@media screen and (max-width:766px){
        .content {
            margin-left: 0px !important;
        }
        .col-md-6.bankinformation-third {
            width: 100%;
            float: left;
        }
    }

    @@media screen and (max-width:580px){
        .baninformation-api table tr th {
            width: 100% !important;
            float: left;
            height: auto !important;
            text-align: left !important;
            padding: 15px 10px;
            border: 0 !important;
        }
    }

</style>

<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>All Bank Information</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Basic Setting&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">All Bank Information</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card" style="margin-bottom: 0px;">
                    <div class="bread-same-all-page breadsameall-second">
                        <ul class="">
                            <li class="smli">
                                <a href="/ADMIN/Home" class="fullbodydycolorbg tmw-total-color-one">
                                    Dashboard&nbsp;<img src="../../ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;">
                                </a>
                            </li>
                            <li class="fullbodydycolorbg tmw-total-color-one">
                                All Bank Information
                            </li>
                        </ul>
                    </div>
                    


                </div>
            </div>
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 baninformation-api-second baninformation-api">
                <div class="card">
                    <div>
                        <div class="row">
                            @foreach (var item in Model)
                            {
                                <div class="col-md-6 bankinformation-third" style="margin-bottom:20px;">
                                    <table class="dealer-box-back-four" border="1" style=" margin-bottom:5px; float:left;border:10px solid #e4e1e1;width:100%;float:left;">
                                        <tr>
                                            <th style="width:220px; height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black; position:initial;border:1px solid #dddddd;background-color:whitesmoke;">
                                                Bank Name
                                            </th>
                                            <th style="width:320px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.banknm)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px;background-color:whitesmoke;   height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                Branch Name
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.branch_nm)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px;background-color:whitesmoke;  height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                IFSC CODE
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.ifsccode)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px;background-color:whitesmoke; height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                Account Number
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.acno)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px; height: 42px;background-color:whitesmoke; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                Account Type
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.actype)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px; height: 42px;background-color:whitesmoke; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black; position:initial;border:1px solid #dddddd;">
                                                Account Holder Name
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.holdername)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px; background-color:whitesmoke; height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                Branch Address
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.address)
                                            </th>
                                        </tr>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>




        </div>
    </div>


</section>


