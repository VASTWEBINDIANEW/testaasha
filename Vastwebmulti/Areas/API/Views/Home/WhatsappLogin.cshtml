<script>
    submit = () => {
        var mobile = $('#txtmobile').val();
        if (mobile != "") {
            var len = mobile.length;
            if (len == 10) {
                var url = '@Url.Action("whatsapp_login_insert", "Home")';
                var datachk = { "mobile": mobile };
                var inputchk = JSON.stringify(datachk);
                fetch(url, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: inputchk
                }).then(Response => Response.json())
                    .then(resp => {
                        if (resp == "OK") {
                            window.location.reload(true)
                        }
                        else {
                            $('#err').text(resp);
                        }
                    }).catch(err => alert(err))
            }
            else {
                $('#err').text("Enter Valid Mobile Number");
            }
        }
        else {
            $('#err').text("Enter Mobile Number");
        }
    }
</script>
