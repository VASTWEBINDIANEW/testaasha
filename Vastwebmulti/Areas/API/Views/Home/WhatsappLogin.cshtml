<script>
    Login = (idno) => {
        var url = '@Url.Action("whatsapp_login", "Home")';
        var datachk = { "id": idno };
        var inputchk = JSON.stringify(datachk);
        $("#overlay").fadeIn(300);
        fetch(url, {
            method: "post",
            headers: { "content-type": "application/json" },
            body: inputchk
        }).then(response => response.json())
            .then(resp => {
                $("#overlay").fadeOut(300);
                if (resp == "OK") {
                   window.location.reload(true)
                }
                else {
                    alert(resp);
                }
            }).catch(err => alert(err))
    }

</script>
