@model List<Vastwebmulti.Models.money_transfer_report_paging_Result>
@{
    ViewBag.Title = "DMT_Report";
    Layout = "~/Areas/API/Views/Shared/_Layout.cshtml";
}
<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 75px !important;
    }

    .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {
        height: 20px;
    }

    .rechargepdfexal {
        width: 100%;
    }

        .rechargepdfexal button span {
            height: 20px !important;
        }

    #pdfblock .pdfblocks {
        position: static;
        border: 0px;
        padding: 0px 9px;
        height: 32px;
    }

    #successtotal, #Failedtotal, #Pendingtotal {
        float: right;
    }

    .form-iconmy {
        padding: 6px 7px;
        top: 0px;
    }

    @@media only screen and (max-width:991px) {
        .dmt_report .col-md-2 {
            padding: 0px;
            width: 50%;
            float: left;
            padding-right: 0px !important;
        }

            .dmt_report .col-md-2 .select2 {
                width: 100% !important;
            }

        .ls-closed section.content {
            margin-left: 5px;
            margin-right: 5px;
        }

        .dmt_report .col-md-5 {
            width: 100%;
            float: left;
        }

        .dmt_report .col-md-2 .form-group {
            margin-bottom: 5px;
        }

        .col-md-2.api-dmt-search {
            padding: 0px !important;
            margin-top: 5px;
        }

            .col-md-2.api-dmt-search button {
                width: 98%;
            }

        .dmt-pdf {
            padding: 0px;
        }

        .rechargepdfexal {
            width: 100%;
        }

        .col-md-12.dmt-table {
            padding: 0px;
            margin-top: 10px;
        }

        .dmt_report .col-md-5 {
            margin-top: 5px;
        }

        .col-md-2.api-dmt-search {
            width: auto;
            float: left;
        }

        .col-lg-4.col-md-4.col-sm-4.col-xs-4.rechargepdfexal {
            position: absolute;
            right: 0;
            bottom: 5px;
            padding-right: 0px !important;
        }
    }
</style>
<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Financial Services</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                @*<li><a href="javascript:void(0);">Developer's&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>*@
                <li><a href="javascript:void(0);">Financial Services</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="">
                    <div class="row">
                        <div class="col-md-8">
                            <div class="row">
                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 selecttwo-full">
                                    @using (Html.BeginForm("DMT_Report", "Home", FormMethod.Post))
                                    {
                                        <div class="">
                                            <div class="row dmt_report">


                                                <div class="col-md-2" style="padding-right:0px;">
                                                    <div class="form-group">
                                                        <div class="">
                                                            @Html.DropDownList("ddl_status", new List<SelectListItem>
                                                    {
                                                    new SelectListItem{ Text="Status",Value="ALL",},
                                                    new SelectListItem{Text="SUCCESS",Value="SUCCESS"},
                                                    new SelectListItem{Text="Pending",Value="PENDING"},
                                                    new SelectListItem{Text="FAILED",Value="FAILED"}
                                                    }, new { @class = "for-select2 form-control", data_live_search = "true" })

                                                        </div>
                                                    </div>
                                               </div>
                                                <div class="col-md-2" style="padding:0px 5px;">
                                                    <div class="form-group">
                                                        <div class="">
                                                            @Html.DropDownList("ddl_Type", new List<SelectListItem>
                                                    {
                                                     new SelectListItem{ Text="Type",Value="ALL",},
                                                     new SelectListItem{Text="Transfer",Value="IMPS"},
                                                     new SelectListItem{Text="Verify",Value="IMPS_VERIFY"}
                                                    }, new { @class = "for-select2 form-control", data_live_search = "true" })

                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col-md-5" style="padding:0px;">
                                                    <div class="form-group" style="margin-bottom:0px;margin-top:0px;">
                                                        <div class="input-daterange input-group">
                                                            <div class="form-iconmy"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                                            @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; height:32px;", autocomplete = "off" })
                                                            <span class="input-group-addon" style="min-width:5px;padding:0px;">

                                                            </span>
                                                            <div style="position:relative;width:100%;float:left;">
                                                                <div class="form-iconmy"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                                                @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; height:32px;", autocomplete = "off" })
                                                            </div>
                                                        </div>
                                                        <!-- /.input group -->
                                                    </div>
                                                </div>


                                                <div class="col-md-2 api-dmt-search" style="padding:0px 5px;">
                                                    <div class="form-group">
                                                        <div class="form-line" style="border-bottom:none;">

                                                            <button type="submit" class="btn" style=" height:32px;border:1px solid #c7c2c2;background:transparent;">
                                                                <i class="fa fa-search" style="top:-1px;font-size:13px;color:black;"></i>
                                                                <span style="top:-1px;color:black;">Search</span>
                                                            </button>

                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                    }

                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-4 col-sm-4 col-xs-4 rechargepdfexal" style="width:auto;float:right;padding-right:15px;">
                            <div style="float:right;">
                                @*<span><img src="~/ashok-images/pdf.png"><input type="button" id="btnPDF" value="PDF" style="margin-left:2px; "></span>*@
                                <span>
                                    <img src="~/ashok-images/xls.png"><input type="button" id="btnExport" value="Export" style="margin-left:2px;">
                                </span>

                                @*<button onclick="findtotal()" class="btn" id="pdfblock" style=" margin-left:2px; height:32px;border:1px solid #c7c2c2;background:#dedddd;margin-top:-3px;">
                                    <span class="displaypdf" style="top:-1px;color:black;">TOTAL</span>
                                    <strong class="pdfblocks" style="display:none;float:right; width:80% !important">
                                        <span id="successtotal" style="background-color:green !important;height: 25px !important;font-size: 18px !important"></span>
                                        <span id="Failedtotal" style="background-color:red !important;height: 25px !important;font-size: 18px !important"></span>
                                        <span id="Pendingtotal" style="background-color:orange !important;height: 25px !important;font-size: 18px !important"></span>
                                    </strong>
                                </button>*@
                            </div>

                        </div>

                    </div>

                    <div>

                    </div>
                </div>
            </div>



        </div>
        <div class="row clearfix">
            <div class="col-md-12 dmt-table">
                <div class="card">
                    <div>
                        <div class="table-responsive" style="position:inherit;">
                            <table id="example1" class="table table-bordered table-striped table-hover tableseconddes-master" style="width:100%; font-size:12px;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th style="width:100px;">Status</th>
                                        <th>Sender&nbsp;No</th>
                                        <th>Beneficiary&nbsp;A/C</th>
                                        <th>Amount</th>
                                        <th>Charge</th>
                                        <th>Debit ₹</th>
                                        <th>Pre ₹</th>
                                        <th>Post ₹</th>
                                        <th>Request&nbsp;Date</th>
                                        <th>Response&nbsp;Date</th>
                                        <th>Print</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null)
                                    {
                                        foreach (var item in Model)
                                        {
                                            DateTime Req_time = Convert.ToDateTime(item.trans_time);
                                            DateTime resp_time = Convert.ToDateTime(item.response_time);
                                            var color = "";
                                            var fontsize = "";

                                            if (item.status.Contains("REFUND") || item.status.Contains("REFUND AGAINST"))
                                            {
                                                color = "#673AB7";
                                                fontsize = "9px;";
                                            }
                                            if (item.status.ToUpper().Contains("PENDING"))
                                            {
                                                color = "#FF9800";
                                            }
                                            if (item.status.ToUpper().Contains("SUCCESS"))
                                            {
                                                color = "green";
                                            }
                                            if (item.status.ToUpper().Contains("FAILED"))
                                            {
                                                color = "red";
                                            }

                                            <tr>
                                                @{
                                                    decimal debit1 = 0;
                                                    decimal amount1 = 0;
                                                    decimal usercomm = 0;
                                                    if (item.Roles == "API")
                                                    {
                                                        if (item.Trans_type.Contains("IMPS_VERIFY"))
                                                        {
                                                            debit1 = Convert.ToDecimal(item.rem_comm);
                                                        }
                                                        else
                                                        {
                                                            amount1 = Convert.ToDecimal(item.amount);
                                                            usercomm = Convert.ToDecimal(item.rem_comm);
                                                            debit1 = amount1 + usercomm;
                                                        }
                                                    }
                                                }

                                                <td style="color:@color;font-weight:700;font-size:@fontsize;">@item.status&nbsp;</td>
                                                <td>@item.senderno</td>
                                                <td><span style="color:@color;">@item.Trans_type</span>&nbsp;⇒&nbsp;@item.accountno&nbsp;@item.recivername</td>
                                                <td>@item.amount</td>
                                                <td>@item.charge</td>
                                                <td>@debit1</td>
                                                <td>@item.user_remain_pre</td>
                                                <td>@item.user_remain</td>
                                                <td>@Req_time.ToString("d-MMM-yyyy HH:mm:ss")</td>
                                                @if (item.response_time != null)
                                                {
                                                    <td>@resp_time.ToString("d-MMM-yyyy HH:mm:ss")</td>
                                                }
                                                else
                                                {
                                                    <td>@item.response_time</td>
                                                }
                                                <td>
                                                    @if (item.status.ToUpper().Contains("SUCCESS"))
                                                    {
                                                        <button id="but" onclick="GotoPDF('@item.trans_common_id')" href="#" style="border:none;background:none;" data-toggle="tooltip" data-placement="bottom" title="Click To Print Generate Invoice"><i class="material-icons">print</i></button>
                                                    }
                                                    else if (item.status.ToUpper().Contains("PENDING"))
                                                    {
                                                        <button id="but" onclick="GotoPDF('@item.trans_common_id')" href="#" style="border:none;background:none;" data-toggle="tooltip" data-placement="bottom" title="Click To Print Generate Invoice"><i class="material-icons">print</i></button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>


</section>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-colorpicker/js/bootstrap-colorpicker.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>

<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>

<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<link href="~/MainFrontDesign/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/MainFrontDesign/select2/dist/js/select2.full.min.js"></script>
<script>
    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 45 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }
</script>
<!--Calendar Javascript-->
<script>
    $(document).ready(function()
    {

        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

    })
</script>

<script type="text/javascript">
                   function GotoPDF(e) {
                       // alert(e)
                       var idno = e.toString();
                       var url = '@Url.Action("IMPSPDF", "Home")?Idno=' + idno + '';
                       //window.location.href = url,;
                       window.open(url, '_blank');
                   }
</script>
<script>
    var jq = $.noConflict();
    jq('.for-select2').select2();
</script>

<script>
    $("#btnExport").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var ddl_status = $('#ddl_status').val();
        var ddl_Type = $('#ddl_Type').val();
        var url = '@Url.Action("ExcelDMT_Report", "Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&ddl_status=' + ddl_status + '&ddl_Type=' + ddl_Type ;
        location.href = url;
});
</script>
