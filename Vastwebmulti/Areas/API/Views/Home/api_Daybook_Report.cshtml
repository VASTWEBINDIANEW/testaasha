@model Vastwebmulti.Areas.API.Models.Daybookapireport
@{
    ViewBag.Title = "api_Daybook_Report";
    Layout = "~/Areas/API/Views/Shared/_Layout.cshtml";
}
<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 81px !important;
    }

    table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px;
    }
</style>
<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 81px !important;
    }

    table.dataTable tbody th, table.dataTable tbody td {
        padding: 4px 5px;
    }

    .form-iconmy {
        top: -1px;width:auto !important;
    }


    @@media screen and (max-width:766px) {
        .col-md-12 div {
            width: 100%;
            float: left;
            margin-bottom: 5px;
        }

        .content {
            margin-left: 0px !important;
        }

        .rowaddnew-dayapi {
            width: 100%;
            float: left;
            margin: 0px;
        }

            .rowaddnew-dayapi .col-md-7 {
                width: 100%;
                float: left;
                padding: 0px;
                margin: 0px;
            }

            .rowaddnew-dayapi .col-md-1 {
                width: auto;
                float: left;
                padding: 0px !important;
                margin: 0px;
            }

            .rowaddnew-dayapi .col-md-2 {
                padding: 0px;
                margin: 0px;
            }
        .col-md-7 {
            width: 100% !important;
            float: left;
        }
    }

</style>
<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Day Book Report</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Basic Setting&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Day Book</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card" style="margin-bottom:10px;">
                    <div class="row rowaddnew-dayapi">
                        <div class="col-md-7" style="width:auto;float:left;">
                            <div class="bread-same-all-page breadsameall-second">
                                <ul class="">
                                    <li class="smli">
                                        <a href="@Url.Action("Dashboard","Home")" class="fullbodydycolorbg tmw-total-color-one">
                                            Dashboard&nbsp;<img src="../../ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;">
                                        </a>
                                    </li>
                                    <li class="fullbodydycolorbg tmw-total-color-one">
                                        DayBook&nbsp;Report
                                    </li>
                                </ul>
                            </div>

                        </div>

                        <div class="col-md-2" style="float:right;width:auto;padding-left:15px !important;">
                            <div class="rechargepdfexal" style="float:right;width:100%;">
                                <span><img src="~/ashok-images/pdf.png"><input type="button" id="btnPDF" value="PDF" style="border:0px;background:transparent"></span>
                                <span>
                                    <img src="~/ashok-images/xls.png"><input type="button" id="btnExport" value="Export" style="border:0px;background:transparent;">
                                </span>
                            </div>
                        </div>

                        @using (Html.BeginForm("api_Daybook_Report", "Home", FormMethod.Post))
                        {
                            <div class="col-md-1" style="padding:0px 5px;width:auto;float:right;">

                                <button type="submit" class="btn  waves-effect" style=" height:32px;border:1px solid #dddddd;background:transparent;">
                                    <i class="fa fa-search" style="top:1px;font-size:16px;color:black;"></i>
                                    <span style="top:0px;color:black;">Search</span>
                                </button>

                            </div>

                            <div class="col-md-3 rechargethrees api-allpage-date" style="float:right;">
                                <div class="form-group" style="margin-bottom:0px;margin-top:1px;">
                                    <div class="input-daterange input-group">
                                        <div class="datesate datesates focused">
                                            <div class="form-iconmy" style="top: 0px;left: 1px;padding: 6px 5px;"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                            <input autocomplete="off" class="form-control" id="txt_frm_date" name="txt_frm_date" required="required" style="border:1px solid #dddddd; margin-top:4px;height:32px;" type="text" value="">
                                        </div>
                                        <span class="input-group-addon" style="display:none;">
                                            <i class="fa fa-exchange" style="padding-top:8px;"></i>
                                        </span>
                                        <div class="datesate datesatese">
                                            <div class="form-iconmy form-iconmyss" id="iconmyssee" style="top: 0px;left: 4px;padding: 6px 5px;"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i></div>
                                            <input autocomplete="off" class="form-control" id="txt_to_date" name="txt_to_date" required="required" style="border:1px solid #dddddd; margin-top:4px;height:32px;" type="text" value="">
                                        </div>
                                    </div>
                                    <!-- /.input group -->
                                </div>
                            </div>

                        }

                    </div>

                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">

                    <div>
                        <div class="table-responsive tableseconddes-master" style="position:inherit;">
                            <table class="table table-bordered table-striped table-hover  " style="width:100%;font-size:12px;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Firm&nbsp;Name</th>
                                        <th>Recharge&nbsp;&&nbsp;Bill</th>
                                        <th>IMPS</th>
                                        <th>AEPS</th>
                                        <th>M&nbsp;-&nbsp;POS</th>
                                        <th>Pancard</th>
                                        <th>Travel</th>
                                        <th>Purchase</th>
                                        <th>Opening&nbsp;Bal</th>
                                        <th>Closing&nbsp;Bal</th>
                                        <th>Old&nbsp;Day&nbsp;Refund</th>
                                        <th>Old&nbsp;Day&nbsp;Failed</th>
                                        <th>Diff</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.DaybookLive != null)
                                    {
                                        foreach (var item in Model.DaybookLive)
                                        {
                                            <tr>
                                                <td>
                                                    @if (item.farmname == null)
                                                    {
                                                        @item.username
                                                    }
                                                    else
                                                    {
                                                        @item.farmname
                                                    }
                                                </td>
                                                <td>@item.RCH</td>
                                                <td>@item.IMPS</td>
                                                <td>@item.AEPS</td>
                                                <td>0.00</td>
                                                <td>@item.PAN</td>
                                                <td>0.00</td>
                                                <td>@item.PURCHASE</td>
                                                <td>@item.openbal</td>
                                                <td>@item.closebal</td>
                                                <td>@item.OLDDAYREFUND</td>
                                                <td>@item.OLDDAYFAILED</td>
                                                <td>@item.DIFF</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        foreach (var item in Model.Daybook_Old)
                                        {
                                            <tr>
                                                <td>
                                                    @if (item.farmname == null)
                                                    {
                                                        @item.username
                                                    }
                                                    else
                                                    {
                                                        @item.farmname
                                                    }
                                                </td>
                                                <td>@item.RCH</td>
                                                <td>@item.IMPS</td>
                                                <td>@item.AEPS</td>
                                                <td>0.00</td>
                                                <td>@item.PAN</td>
                                                <td>0.00</td>
                                                <td>@item.PURCHASE</td>
                                                <td>@item.openbal</td>
                                                <td>@item.closebal</td>
                                                <td>@item.OLDDAYREFUND</td>
                                                <td>@item.OLDDAYFAILED</td>
                                                <td>@item.DIFF</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script type="text/javascript">
    $(function () {

               $('.input-daterange').datepicker({
                format: "yyyy-mm-dd",
                todayHighlight: true,
                autoclose: true

            });
            var val = '@ViewBag.chk';
            if (val != "post") {
                $("#txt_frm_date").datepicker("setDate", new Date());
                $("#txt_to_date").datepicker("setDate", new Date());
            }


        });
</script>




<script>
    $("#btnExport").click(function(){
        var txt_frm_date = $('#txt_frm_date').val();
        var url = '@Url.Action("Excelapi_Daybook_Report", "Home")?txt_frm_date=' + txt_frm_date;

        location.href = url;
});
</script>



<script>
    $("#btnPDF").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();


        var url = '@Url.Action("PDFapi_Daybook_Report", "Home")?txt_frm_date=' + txt_frm_date;
        window.open(
url,
  '_blank' // <- This is what makes it open in a new window.
);
    });
</script>



<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
