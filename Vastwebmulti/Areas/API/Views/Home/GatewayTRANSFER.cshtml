<script>

    function tableCreate(amount, columns, row, type = null) {
        const body = document.body,
            tbl = document.createElement('table');
        tbl.style.width = '100%';
        //tbl.style.border = '1px solid black';
        const tr = tbl.insertRow();
        const tr1 = tbl.insertRow();
        const tr2 = tbl.insertRow();

        for (let i = 0; i < columns.length; i++) {
            const td1 = tr.insertCell();

            td1.style.border = '1px solid black';
            td1.style.backgroundColor = '#dca167';
            //td1.style.padding = '2px 5px';
            //td1.style.fontWeight = 'bold';
            td1.style.textAlign = 'center';
            var col_name = typeof columns[i] == 'string' ? columns[i] : columns[i].text;
            td1.appendChild(document.createTextNode(col_name));

            if (columns[i].cols) {
                if (Array.isArray(columns[i].cols)) {
                    td1.setAttribute('colSpan', columns[i].cols.length.toString());

                    for (let j = 0; j < columns[i].cols.length; j++) {
                        var td = tr1.insertCell();
                        var tdr;

                        if (typeof columns[i].cols[j] == 'string') {
                            if (type == "DC" && col_name == 'RUPAY') {
                                td.setAttribute('rowSpan', 2);
                            }
                            else if (type == "NB") {

                            }
                            else {
                                tr2.insertCell();
                            }
                            td.appendChild(document.createTextNode(ucFirst(columns[i].cols[j])));
                            td.style.border = '1px solid black';
                            //td.style.fontWeight = 'bold';
                            td.style.backgroundColor = '#dca167';
                            td.style.textAlign = 'center';
                            td.style.fontSize = '11px';
                        }
                        else {
                            var cols3 = columns[i].cols[j].cols;

                            td.setAttribute('colSpan', cols3.length.toString());
                            td1.setAttribute('colSpan', (2 * cols3.length).toString());
                            td.appendChild(document.createTextNode(ucFirst(columns[i].cols[j].text)));
                            td.style.border = '1px solid black';
                            td.style.backgroundColor = '#dca167';
                            //td.style.fontWeight = 'bold';
                            td.style.textAlign = 'center';
                            td.style.fontSize = '11px';


                            for (let k = 0; k < cols3.length; k++) {
                                var td3 = tr2.insertCell();

                                var text3 = cols3[k];

                                td3.appendChild(document.createTextNode(ucFirst(text3)));
                                td3.style.border = '1px solid black';
                                td3.style.backgroundColor = '#dca167';
                                //td3.style.fontWeight = 'bold';
                                td3.style.textAlign = 'center';
                                td3.style.fontSize = '10px';
                            }

                        }

                    }

                }

            } else {

                if (type == "DC" && col_name == 'Status') {
                    td1.setAttribute('rowSpan', 3);
                }
                else if (type == "NB" && col_name == 'Status') {
                    td1.setAttribute('rowSpan', 2);
                }
                else {
                    //tr1.insertCell();
                    //tr2.insertCell();
                }
            }

        }
        var merged_array = [].concat.apply([], [].concat.apply([], row));
        var tr_val = tbl.insertRow();
        console.log(merged_array[0])

        for (let i = 0; i < merged_array.length; i++) {
            var td = tr_val.insertCell();

            if (i > 0) {
                td.appendChild(document.createTextNode(parseFloat(merged_array[i]).toFixed(2)));
                td.style.border = '1px solid black';
                td.style.textAlign = 'center';
                td.style.fontSize = '10px';
            }
            else {
                var img = document.createElement('img');
                img.src = merged_array[i] ? "../../ashok-images/correct.svg" : "../../ashok-images/closes.svg";
                img.style.width = "12px";
                img.style.borderRadius = "99px";
                img.style.backgroundColor = merged_array[i] ? 'green' : 'red'
                td.style.border = '1px solid black';
                td.style.textAlign = 'center';

                var span = document.createElement('small')
                span.textContent = amount;
                span.style.fontSize = '11px';
                span.style.marginLeft = '3px';

                td.appendChild(img);
                td.appendChild(span);
            }
        }

        tbl.style.margin = "30px 0";
        return tbl;
    }

    function ucFirst(string) {
        return string.charAt(0).toUpperCase() + string.slice(1);
    }

</script>
