<script>
    $('.pay-mode-process').click(function () {
        $(this).hide();
        $('.pay-mode-second').show();
        $('.pay-mode-edit').show();
        $('.pay-mode-first input').attr('readonly', 'readonly')

    });
    $('.pay-mode-edit').click(function () {
        $(this).hide();
        $('.pay-mode-second').hide();
        $('.pay-mode-process').show();
        $('.pay-mode-first input').removeAttr('readonly', 'readonly')
    });
    (function () {
        $('.pay-mode-first input').keyup(function () {
            var empty = false;
            $('.pay-mode-first input').each(function () {
                if ($(this).val() == '') {
                    empty = true;
                }
            });
            if (empty) {
                $('.pay-mode-process').attr('disabled', 'disabled');
            }
            else {
                $('.pay-mode-process').removeAttr('disabled');
            }
        });
    })()

    function isNumberKey(evt) {
        var charCode = (evt.which) ? evt.which : event.keyCode
        if (charCode > 31 && (charCode < 48 || charCode > 57))
            return false;

        return true;
    }
</script>


