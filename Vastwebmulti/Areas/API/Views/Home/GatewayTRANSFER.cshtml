</script>
<script>
    function proceed() {
        //$this.button('loading');
        if ($('#txtamt').val() == "") {
           $('#txtmsgerror').text("Amount Not Blank");
        }
        else if ($('#ddl_type').val() == "")
        {
            $('#txtmsgerror').text("Select Any Type");
        }
        else {
            $('#txtmsgerror').text("");
        $.ajax({
              url: '@Url.Action("calculatecharge_gateway", "Home")',
              type: 'GET',
              dataType: "json",
            data: { amount: $('#txtamt').val(), type: $('#ddl_type').val() },
            success: function (response) {

                if (response.status) {
                    $('#showdata').show();
                    $('#showdata').find('table').empty();

                    document.getElementById('showdata').querySelector('table').appendChild(tableCreate($('#txtamt').val(), response.cols, response.values, $('#ddl_type').val()));

                }
                else {
                    $('#showdata').hide();
                    $('#txtmsgerror').text("Charge Not Set");
                }


            }
        });
            }

        //setTimeout(function () {
        //    $this.button('reset');
        //}, 500);
    }
</script>


