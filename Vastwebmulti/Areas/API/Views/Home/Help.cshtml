@{
    ViewBag.Title = "Help";
    Layout = "~/Areas/API/Views/Shared/_Layout.cshtml";
}
<style>
    .table tbody tr td, .table tbody tr th
    {
        border-top:0px;
        border-bottom:0px;
    }
    .table-responsive{
        border:0px;
    }
    .my-table td p{text-align:right;margin:0px;}
    .my-table tr{border-bottom:1px dotted;}
    .my-table tr:last-child{border-bottom:none;}

    .master-four-design .api-help-class {
        border-radius: 25px !important;
        box-shadow: 0 0 2px 1px #555;
        background: #fff !important;
        border: 0 !important;
    }
    .master-four-design .api-four-radius {
        border-radius: 25px !important;
        background: #ccc !important;
    }

    @@media screen and (max-width:766px) {
        .content {
            margin-left: 0px !important;
        }
    }

    @@media screen and (max-width:580px){
        .table-responsive-help-api table tr td {
            width: 100%;
            float: left;
            text-align: left !important;
            padding: 5px 5px;
        }
            .table-responsive-help-api table tr td p {
                text-align: left;
            }
    }

    @@media screen and (max-width:420px){
        .api-four-radius {
            font-size: 16px !important;
        }
        
    }

</style>
<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Help</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Basic Setting&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Help</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-6">
                <div class="card">
                    <p class="api-four-radius" style="font-size:21px;padding-top:2px;padding-bottom:7px;padding-left:15px;background-color:#bbb;font-weight:700;"><img src="~/images/reportimage/Help.svg" style="height:24px;">&nbsp;Customer&nbsp;Care&nbsp;Support&nbsp;Time</p>
                    <div class="row">
                        <div class="col-md-12" style="margin-top:15px;">
                            <div>
                                <div style="padding-top:13px;border:1px solid #dddddd;background: #f5f5f5;">
                                    <center><p class="api-help-class" style="margin-top:-24px;font-weight:bold;padding:0px 16px 1px 16px;background:linear-gradient(#ffffff 0%, #ffffff 100%);position:absolute;right:44%;border: 1px solid #bbb;">Day&nbsp;and&nbsp;Time</p></center>
                                    <div class="row">
                                        <div class="col-md-12" style="margin-bottom:-25px;">
                                            <div class="table-responsive">
                                                <table class="table my-table">
                                                    <thead>

                                                    </thead>
                                                    <tbody>
                                                        <tr>
                                                            <td>MONDAY</td>

                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>



                                                        </tr>
                                                        <tr>
                                                            <td>TUESDAY</td>

                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>

                                                        </tr>
                                                        <tr>
                                                            <td>WEDNESDAY</td>

                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>

                                                        </tr>

                                                        <tr>
                                                            <td>THURSDAY</td>

                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>

                                                        </tr>
                                                        <tr>
                                                            <td>FRIDAY</td>

                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>

                                                        </tr>
                                                        <tr>
                                                            <td>SATURDAY</td>

                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>

                                                        </tr>
                                                        <tr>
                                                            <td>SUNDAY</td>

                                                            <td><p style="font-weight:700;">9.00 AM  to  02.00 PM</p></td>

                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <p class="api-four-radius" style="font-size:21px;padding-top:2px;padding-bottom:7px;padding-left:15px;background-color:#bbb;font-weight:700;"><img src="~/images/reportimage/Help.svg" style="height:24px;">&nbsp;Contact&nbsp;Information</p>
                    <div class="row">
                        <div class="col-md-12" style="margin-top:15px;">
                            <div>
                                <div style="padding-top:13px;border:1px solid #dddddd;background: #f5f5f5;padding-bottom: 50px;padding-top: 40px;">
                                    <center><p class="api-help-class" style="margin-top:-52px;font-weight:bold;padding:0px 16px 1px 16px;background:linear-gradient(#ffffff 0%, #ffffff 100%);position:absolute;right:45%;border: 1px solid #bbb;">Company&nbsp;Info</p></center>
                                    <div class="row">
                                        <div class="col-md-12" style="margin-bottom:-19px;">
                                            <div class="table-responsive table-responsive-help-api">
                                                <table class="table my-table">
                                                    <thead>

                                                    </thead>
                                                    <tbody>
                                                        <tr>
                                                            <td>Company Name</td>

                                                            <td>
                                                                @if (ViewBag.admin.Companyname != null && ViewBag.admin.Companyname != "")
                                                                {
                                                                    <p>@ViewBag.admin.Companyname</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>


                                                        </tr>
                                                        <tr>
                                                            <td>Name</td>

                                                            <td>
                                                                @if (ViewBag.admin.Name != null && ViewBag.admin.Name != "")
                                                                {
                                                                    <p>@ViewBag.admin.Name</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>

                                                        </tr>
                                                        <tr>
                                                            <td>Email-ID</td>

                                                            <td>
                                                                @if (ViewBag.admin.email != null && ViewBag.admin.email != "")
                                                                {
                                                                    <p>@ViewBag.admin.email</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>

                                                        </tr>

                                                        <tr>
                                                            <td>Mobile No</td>

                                                            <td>
                                                                @if (ViewBag.admin.mobile != null && ViewBag.admin.mobile != "")
                                                                {
                                                                    <p>@ViewBag.admin.mobile</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>

                                                        </tr>
                                                        <tr>
                                                            <td>Address</td>

                                                            <td>
                                                                @if (ViewBag.admin.Address != null && ViewBag.admin.Address != "")
                                                                {
                                                                    <p>@ViewBag.admin.Address</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>

                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

