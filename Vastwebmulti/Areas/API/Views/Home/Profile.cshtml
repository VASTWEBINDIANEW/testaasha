@model Vastwebmulti.Models.User
@using Vastwebmulti.Models;
@{
    ViewBag.Title = "Profile";
    Layout = "~/Areas/API/Views/Shared/_Layout.cshtml";
    var passcodeset = ViewBag.passcodesetings;
    var offpasscode = passcodeset == "OFF" ? "activeupto" : "";
    var perpasscode = passcodeset == "PERDAY" ? "activeupto" : "";
    var Weakpasscode = passcodeset == "WEAKS" ? "activeupto" : "";
    var monthpasscode = passcodeset == "MONTHS" ? "activeupto" : "";

    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Api").ToList();
    var favimage = "";
    if (usernname.Count() > 0)
    {
        if (usernname.SingleOrDefault().Role == "Api")
        {
            favimage = usernname.SingleOrDefault().NickName;


        }
    }
}

<style>
    .ribbon {
        position: absolute;
        right: -2px;
        top: -2px;
        z-index: 1;
        overflow: hidden;
        width: 75px;
        height: 75px;
    }

        .ribbon span {
            font-size: 11px;
            color: #fff;
            text-align: center;
            font-weight: bold;
            line-height: 20px;
            transform: rotate(45deg);
            -webkit-transform: rotate(45deg);
            width: 100px;
            box-shadow: 0 3px 10px -5px rgba(0, 0, 0, 1);
            position: absolute;
            top: 19px;
            right: -21px;
            background: linear-gradient(#c5c5c5 0%, #868686 100%);
        }

    .list-group-item {
        border: none;
    }

    .field-validation-error {
        color: red;
    }

    .required:after {
        color: red;
        content: " *";
    }

    #EditnameandpancardModal .form-group, #EditaddressModal .form-group {
        margin-bottom: 0px;
    }

    #EditnameandpancardModal .form-control-label, #EditaddressModal .form-control-label {
        text-align: left;
        margin-bottom: 10px;
    }

    .card .body #EditnameandpancardModal .col-xs-8, .card .body #EditnameandpancardModal .col-sm-8, .card .body #EditnameandpancardModal .col-md-8, .card #EditnameandpancardModal .body .col-lg-8,
    .card .body #EditnameandpancardModal .col-xs-9, .card .body #EditnameandpancardModal .col-sm-9, .card .body #EditnameandpancardModal .col-md-9, .card #EditnameandpancardModal .body .col-lg-9 {
        margin-bottom: 10px;
    }

    #EditaddressModal .form-control {
        height: 28px;
    }

    .profile-dealeronchange button p {
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .profile-dealeronchange button p.activeupto {
            background: green;
            color: #fff;
        }

        .profile-dealeronchange button p::after {
            display: none;
        }

        .profile-dealeronchange button p.activeupto span::before {
            content: "";
            float: left;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            color: #555;
            font-size: 12px;
            position: relative;
            left: -5px;
            background: url('../../AdminDesign/images/checkprofile.svg') no-repeat;
            background-color: #fff;
            background-size: 11px;
            background-position: center;
        }

    .profile-dealeronchange button strong {
        display: flex;
    }

        .profile-dealeronchange button strong p {
            width: 33%;
            background: #f9f9cb;
            text-transform: capitalize;
            margin-right: 5px;
        }

    .profile-borders table th, .profile-borders table td, .profile-borders table tr, .profile-borders table {
        border-color: #ddd;
        color: #555 !important;
    }

    @@media screen and (max-width:1366px) {
        .api-profile {
            padding-left: 15px;
        }
    }

    @@media screen and (max-width:990px) {
        .col-md-8, .col-md-4 {
            width: 100%;
            float: left;
            padding-left: 0;
        }

        .modal-body .col-md-4, .modal-body .col-md-8 {
            padding-left: 15px;
        }

        .modal-body .col-md-3, .modal-body .col-md-9 {
            width: 100%;
            float: left;
            margin-bottom: 5px !important;
        }
    }

    @@media screen and (max-width:766px) {
        .col-md-4, .col-md-8 {
            float: left;
            width: 100%;
            margin-bottom: 10px;
        }

        .profile-dealeronchange button strong {
            display: inherit;
        }

            .profile-dealeronchange button strong p {
                width: 100%;
                float: left;
                margin: 0px !important;
                margin-bottom: 15px !important;
            }
    }
</style>
