<script type="text/javascript">
    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 46 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }
</script>

<script>
    function FillDistict() {
        var State_id = $('#State').val();
    $.ajax({
        url: '@Url.Action("FillDistict", "Home")',
        type: "GET",
        dataType: "JSON",

        data: { State: State_id },
        success: function (cities) {
            $("#District").html("");
            $.each(cities, function (i, District) {
                $("#District").append(
                    $('<option></option>').val(District.Dist_id).html(District.Dist_Desc));
            });
        }
    });
  }
</script>

<!--edit address and prifile image -->
<script>
    function editeaddress(apiid) {


        var url = '@Url.Action("Showapiprofile", "Home")'
        $.ajax({
            url: url,
            data: { apiid: apiid },
            cache: false,
            type: "POST",
            success: function (data) {

                $("#txtid1").val(data[0].apiid);
                $("#txtfrimname").val(data[0].farmname)
                $("#txtcity").val(data[0].city);
                $("#txtaddress").val(data[0].address);
                $("#txtzipcode").val(data[0].pincode);
                $("#State").val(data[0].state);
                $("#District").val(data[0].district);


                $('#EditaddressModal').show();
                $('.modal-backdrop').hide();
                $('.adrres-up').hide();


            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });

    }

</script>
<script>
    $('.show-ele1').click(function () {
        $('.adrres-up').show();
        $('#EditaddressModal').hide();
    })
</script>
<!--edit Name and Pancrad and Gst Number  image -->
<script>
    function editemobileandpancard(apiid) {

        document.getElementById("txtpancard").readOnly = false;
        document.getElementById("txtaadhaarcard").readOnly = false;
        document.getElementById("txtname").readOnly = false;
        document.getElementById("txtgst").readOnly = false;



        var url = '@Url.Action("Showmobileandpancardprofile", "Home")'
        $.ajax({
            url: url,
            data: { apiid: apiid },
            cache: false,
            type: "POST",
            success: function (data) {
                $("#txtid2").val(data[0].apiid);
                $("#txtname").val(data[0].username);
                 $("#txtaadhaarcard").val(data[0].adharcard);
                $("#txtpancard").val(data[0].pancard);
                $("#txtgst").val(data[0].gst);
                 $("#ddlPosition").val(data[0].Position);
                $("#ddlBusinessType").val(data[0].BusinessType);

                if (data[0].aadharcardPath != null && data[0].AadhaarStatus == "Y" && data[0].pancardPath != null && data[0].PSAStatus=="Y") {
                  document.getElementById("txtaadhaarcard").readOnly = true;
                }
                if (data[0].pancardPath != null && data[0].PSAStatus == "Y" && data[0].aadharcardPath != null && data[0].AadhaarStatus == "Y") {
                    document.getElementById("txtpancard").readOnly = true;
                      document.getElementById("txtaadhaarcard").readOnly = true;
                      document.getElementById("txtname").readOnly = true;
                    document.getElementById("txtgst").readOnly = true;



                }

                $('#EditnameandpancardModal').show();
                $('.modal-backdrop').hide();
                 $('.api-first-pro').hide();
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });

    }

</script>

<script>
    $('.show-ele').click(function () {
        $('.api-first-pro').show();
        $('#EditnameandpancardModal').hide();
    })
</script>



