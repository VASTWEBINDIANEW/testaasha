@model IEnumerable<Vastwebmulti.Models.Retailer_Cr_Dr_Report_Result>
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>PDF Security Report</title>
    <style>
        table {
            border-collapse: collapse;
        }

        table, td, th {
            border: 1px solid black;
        }

        thead {
            display: table-header-group
        }

        tfoot {
            display: table-row-group
        }

        tr {
            page-break-inside: avoid
        }

        th, td {
            padding: 5px;
        }
    </style>
</head>
<body>
    <table cellspacing="0">
        <thead style="background-color: whitesmoke; display:table-header-group;">
            <tr>

                <th>Sr.No</th>
                <th>Request&nbsp;Id</th>
                <th>Particular</th>
                <th>₹&nbsp;Amount</th>
                <th>Credit</th>
                <th>Debit</th>
                <th>Balance</th>
                <th>Date</th>
            </tr>

</thead>

        <tbody>
            @{int i = 1;}
            @foreach (var item in Model)
            {

                <tr>
                    <td>@i</td>
                    <td>@Html.DisplayFor(modelItem => item.RequestId)</td>
                    <td>@Html.DisplayFor(modelItem => item.Particulars)</td>
                    <td>@Html.DisplayFor(modelItem => item.Amount)</td>
                    <td>@Html.DisplayFor(modelItem => item.credit)</td>
                    <td>@Html.DisplayFor(modelItem => item.debit)</td>
                    <td>@Html.DisplayFor(modelItem => item.Balance)</td>
                    <td>@Html.DisplayFor(modelItem => item.Date)</td>
                </tr>
                i++;
            }


        </tbody>
    </table>
</body>
</html>
