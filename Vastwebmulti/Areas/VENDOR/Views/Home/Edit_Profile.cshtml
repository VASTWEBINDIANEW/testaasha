@model Vastwebmulti.Models.Vendor_details
@{
    ViewBag.Title = "Edit_Profile";
    Layout = "~/Areas/VENDOR/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                @using (Html.BeginForm("Edit_Profile", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
            {
                    <div class="card">
                        <div class="header" style="padding:10px;">
                            <h2>
                                <span style="font-size:21px;"></span> Update Profile Information
                            </h2>
                        </div>
                        <div class="row">
                            <div class="body">
                                <div class="row">
                                    <div class="col-md-6">
                                        @Html.HiddenFor(model => model.idno)
                                        <label for="email_address">Email-Id</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.emailid, new { @class = "form-control", @readonly = "readonly" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="setbox">Name</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.Name, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <label for="setbox">Frim Name</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.Firmname, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="amount">Mobile Number</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.mobile, new { @class = "form-control", @readonly = "readonly" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <label for="mobileno">State </label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.DropDownListFor(m => m.state, (IEnumerable<SelectListItem>)ViewBag.Sate, "-- Select State--", new { @class = "selectpicker form-control", data_live_search = "true", @required = "required", @onchange = "FillDistict()" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="pincode">District</label>
                                        <div class="form-group">
                                            <div class="">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.DropDownListFor(m => m.district, (IEnumerable<SelectListItem>)ViewBag.District, "-- Select District--", new { @class = "form-control", @required = "" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                             
                               <div class="row">
                                   <div class="col-md-6">
                                       <label for="fullname">Full Address</label>
                                       <div class="form-group">
                                           <div class="" style="border:1px solid #dddddd;">
                                               @Html.TextBoxFor(m => m.address, new { @class = "form-control" })
                                           </div>
                                       </div>
                                   </div>
                                   <div class="col-md-6">
                                       <label for="address">Pincode Number</label>
                                       <div class="form-group">
                                           <div class="" style="border:1px solid #dddddd;">
                                               @Html.TextBoxFor(m => m.pin, new { @class = "form-control", onkeypress = "return isNumber(event)", maxlength = "6" })
                                           </div>
                                       </div>
                                   </div>
                               </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <label for="address">Aadharcard Number</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(m => m.aadharnumber, new { @class = "form-control", onkeypress = "return isNumber(event)", maxlength = "12" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="address">Pancard Number</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(m => m.pancardnumber, new { @class = "form-control", maxlength = 10, @style = "text-transform:uppercase" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                          <div class="row">
                              <div class="col-md-6">
                                  <label for="address">GST Number</label>
                                  <div class="form-group">
                                      <div class="" style="border:1px solid #dddddd;">
                                          @Html.TextBoxFor(m => m.gstnumber, new { @class = "form-control", maxlength = "15", @style = "text-transform:uppercase" })
                                      </div>
                                  </div>
                              </div>
                              <div class="col-md-6">
                                  <label for="address">Upload Image</label>
                                  <div class="form-group">
                                      <div class="" style="border:1px solid #dddddd;">
                                          <input type="file" id="file" name="file" class="form-control" />
                                      </div>
                                  </div>
                              </div>
                          </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <label for="setbox">Acc Holder Name</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.accountholder, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="amount">Bank Account No</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.Bankaccountno, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <label for="setbox">IFSC Code</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.Ifsccode, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="amount">Bank Name</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.bankname, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <div class="row">
                                <div class="col-md-6">

                                </div>
                                <div class="col-md-6">
                                    <button type="submit" class="btn bg-blue-grey waves-effect">Update</button>
                                    <a href="@Url.Action("Index","Home")" class="btn btn-info">Back</a>
                                </div>
                            </div>
                         
                           
                            </div>
                        </div>

                    </div>
                }
            </div>

        </div>
    </div>
</section>


<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script language="javascript" type="text/javascript">
                    $(function () {
                        $('#state').change(function () {
                            // alert('Value:' + ' ' + $('#State1').val())
                            var stid = $('#state').val()
                                GetDistrict1(stid)
                        });
                    })

                    function GetDistrict1(_stateId) {
                        var procemessage = "<option value='0'> Please wait...</option>";
                        $("#district").html(procemessage).show();
                        var url = '@Url.Action("DistrictList","Home")'
                        $.ajax({
                            url: url,
                            data: { Id: _stateId },
                            cache: false,
                            type: "POST",
                            success: function (data) {
                                $("#district").html("");
                                for (var x = 0; x < data.length; x++) {
                                    //alert(markup)
                                    $("#district").append($('<option></option>').val(data[x].Value).html(data[x].Text));
                                }

                            },
                            error: function (reponse) {
                                alert("error : " + reponse);
                            }
                        });
                    }
</script>


<script>
    $(document).ready(function () {

        $('#state').val(@Model.state);
        $('#district').val(@Model.district);

    })
</script>

<script type="text/javascript">
        function isNumber(evt) {
            var iKeyCode = (evt.which) ? evt.which : evt.keyCode
            if (iKeyCode != 46 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
                return false;
            return true;
        }
</script>

