@using System.Net.Mime
@using Vastwebmulti.Models
@{
    ViewBag.Title = "CatagoryList";
    Layout = "~/Areas/VENDOR/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">
      <div class="row">
          <div class="col-md-12">
              <div class="card">
                  <div class="col-md-10">
                      <p style="font-size:22px;margin-top:4px;font-weight:500;">Add New Product</p>
                  </div>
                  <div class="col-md-2">
                      <a href="@Url.Action("AddProduct","Home")" class="btn waves-effect" style="margin-left:15%; margin-top:5px;border:1px solid #c7c2c2;background:#dedddd;" >
                          <i class="fa fa-plus" style="top:-1px;font-size:16px;color:black;"></i>
                          <span style="top:-2px;color:black;">Add&nbsp;New&nbsp;Product</span>
                      </a>
                  </div>
              </div>
          </div>
      </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-24px;">
                <div class="card" style="margin-top:7px;">
                 
                    <div class="body" id="lstProduct">
                        <div class="row">
                            @Html.Action("_productListPartial")
                        </div>
                      
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
@using (Ajax.BeginForm("_productListPartial", "Home", new AjaxOptions { UpdateTargetId = "lstProduct", InsertionMode = InsertionMode.Replace }))
{
    <input type="hidden" name="searchBy" />
    <input type="hidden" name="sortBy" />
    <input type="hidden" name="filterBy" />
    <input type="submit" id="submitBtnlstProduct" />
}
<!--Add New   modal-->
<div class="modal fade" id="ImgUpload" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header navbar" style="position:initial;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:white;">Add New Attribute</h4>
            </div>
            @using (Html.BeginForm("ImgUpload", "Home", FormMethod.Post, new { @enctype = "multipart/form-data" }))
            {
                <div class="modal-body" style="margin-top:-26px;">
                    <div class="body">
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                        @Html.Hidden("ProductID")
                        <form>
                            <div class="row clearfix" style="margin-top:30px;">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="ProductId">Image</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBox("Image", "", new { @type = "file", @class = "form-control", required = "required" })
                                            @Html.ValidationMessage("Image", "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="modal-footer">
                                <button type="submit" class="btn bg-blue-grey waves-effect">Save</button>
                                <button type="button" class="btn btn-info waves-effect" data-dismiss="modal">CLOSE</button>
                            </div>
                        </form>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>
<script src="~/Scripts/PageScript/Vendor/ProductList.js"></script>

<script>
    function FillID(id) {
        $("#ProductID").val(id);
    }
</script>

<script>
    window.onload = function () {
        var succ = '@ViewData["success"]';
        var exists = '@ViewData["exists"]';
        if (succ != "" && succ != null) {
            swal("Good job!", succ, "success");

        }
        if (exists != "" && exists != null) {
            swal("Oops...", exists, "error");

        }
    }
</script>


