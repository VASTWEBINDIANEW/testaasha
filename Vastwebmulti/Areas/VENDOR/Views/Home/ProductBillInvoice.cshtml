@using Vastwebmulti.Models;
@{
    ViewBag.Title = "DMT FUND TRANSFER GST";
    Layout = null;
}

@{
    var logoimage = "";
    var com = "";
    VastwebmultiEntities db = new VastwebmultiEntities();
    var logo = db.tblHeaderLogoes.Where(p => p.Role == "ADMIN").ToList();
    if (logo.Count > 0)
    {
        logoimage = logo.SingleOrDefault().LogoImage;
    }
    else
    {
        logoimage = "";
    }
    var websiteurl = db.Admin_details.SingleOrDefault().WebsiteUrl;
    var companyname = db.tblContects.ToList();
    if (companyname.Count > 0)
    {
        com = companyname.SingleOrDefault().CompnayName;
    }
    else
    {
        com = "";
    }

}

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <!--[if IE]>
        <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
        <![endif]-->
    <title>@com</title>
    <!-- BOOTSTRAP CORE STYLE  -->
    <link href="~/Invoicebillcss/bootstrap.css" rel="stylesheet" />
    <link href="~/Invoicebillcss/custom-style.css" rel="stylesheet" />

    <!-- GOOGLE FONTS -->
    <link href='http://fonts.googleapis.com/css?family=Open+Sans:400,700,300' rel='stylesheet' type='text/css' />
    <style>
        table, th, td {
            border: 1px solid black;
            padding-left: 20px;
        }
    </style>
</head>
<body>
    <div class="container" style="border:1px solid #0000000d;">

        <div class="row text-center contact-info" style="margin-top:7%;">
            <div class="col-lg-12 col-md-12 col-sm-12">
                <hr />
                <span style="font-size:22px;">
                    <strong>TAX INVOICE</strong>
                </span>

                <hr />
            </div>
        </div>
        <div class="row pad-top-botm " style="padding-top:12px;padding-bottom:1px;">
            <div class="col-xs-2">
                <img src="@Url.Content("~/" +logoimage)" class="img-responsive" />
            </div>
            <div class="col-xs-10">
                <p style="margin-top:-10px;">Contact us&nbsp;:&nbsp;@ViewBag.VendorMobile II @ViewBag.VendorEmail</p>
                <p style="line-height:24px;margin-top:-12px;font-size:14px;">
                    <span style="font-size:22px;font-weight:600;">@ViewBag.Vendorfrmname</span>, WarehouseAddress&nbsp;:&nbsp;@ViewBag.VendorAddress  - @ViewBag.VendorPincode
                </p>
            </div>
        </div>
        <div class="row pad-top-botm client-info" style="border-top:2px solid black;border-bottom:2px solid black;padding-bottom:10px;">
            <div class="col-xs-4" style="margin-top:-52px;">
                <strong>Order ID: @ViewBag.OrderID</strong>
                <br />
                <b>Order Date :</b> @ViewBag.OrderDate
                <br />
                <b>Invoice Date :</b> @DateTime.Now.ToString();

            </div>
            <div class="col-xs-4" style="margin-top:-52px;">
                <b>Billing Address  </b>
                <br />
                <p style="line-height:22px;">
                    @ViewBag.RetailerName&nbsp;,&nbsp;
                    @ViewBag.RetailerAddress &nbsp;,&nbsp; @ViewBag.RetailerPincode &nbsp;,&nbsp;@ViewBag.RetailerState
                </p>
                <p style="margin-top:-18px;"><b>Phone No :</b> @ViewBag.RetailerMobile</p>
            </div>
            <div class="col-xs-4" style="margin-top:-52px;">
                <b>Shipping Address </b>
                <br />
                <p style="line-height:22px;">
                    @ViewBag.VendorName&nbsp;,&nbsp;
                    @ViewBag.VendorAddress &nbsp;,&nbsp; @ViewBag.VendorPincode &nbsp;,&nbsp;@ViewBag.VendorState
                </p>
                <p style="margin-top:-18px;"><b>Phone No :</b> @ViewBag.VendorMobile</p>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="row" style="border-bottom:1px solid black;border-right:1px solid black;border-left:1px solid black;">
                    <table style="width:100%;">
                        <thead>
                            <tr>
                                <th rowspan="2">Sr No.</th>
                                <th rowspan="2">Product</th>
                                <th rowspan="2">Title</th>
                                <th rowspan="2">HSN/SAC</th>
                                <th rowspan="2">Price</th>
                                <th rowspan="2">Qty</th>
                                <th rowspan="2">Total&nbsp;Qty&nbsp;Price</th>
                                <th colspan="2">CGST</th>
                                <th colspan="2">SGST</th>
                                <th colspan="2">IGST</th>
                                <th rowspan="2">Total</th>
                            </tr>
                            <tr>
                                <th>Amount</th>
                                <th>%</th>
                                <th>Amount</th>
                                <th>%</th>
                                <th>Amount</th>
                                <th>%</th>
                            </tr>
                        </thead>
                        <tbody>

                            <tr>
                                <td rowspan="2">1.</td>
                                <td rowspan="2">@ViewBag.ProductName</td>
                                <td rowspan="2">@ViewBag.ProductTitle</td>
                                <td rowspan="2">@ViewBag.HSN</td>
                                <td rowspan="2">@ViewBag.StandardPrice</td>
                                <td rowspan="2">@ViewBag.Qty</td>
                                <td rowspan="2">@ViewBag.Amount</td>
                                <td colspan="2" style="border: 1px solid white;"></td>
                                <td colspan="2" style="border: 1px solid white;"></td>
                                <td colspan="2" style="border: 1px solid white;"></td>
                                <td rowspan="2">@ViewBag.Totalamount</td>
                            </tr>
                            <tr>
                                <td>@ViewBag.TotalCgstamt</td>
                                <td>@ViewBag.cgst</td>
                                <td>@ViewBag.TotalSgstamt</td>
                                <td>@ViewBag.sgst</td>

                                <td>@ViewBag.totaligst</td>
                                <td>@ViewBag.igsttax</td>
                            </tr>

                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3">Total</td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td>@ViewBag.Amount</td>
                                <td>@ViewBag.cgst</td>
                                <td></td>
                                <td>@ViewBag.sgst</td>
                                <td></td>
                                <td>@ViewBag.totaligst</td>
                                <td></td>
                                <td>@ViewBag.Totalamount</td>
                            </tr>
                            <tr>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td colspan="10" style="text-align:right; padding-right:20px;">Taxable Amount</td>
                                <td>@ViewBag.Amount</td>
                            </tr>
                            <tr>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td colspan="10" style="text-align:right; padding-right:20px;">Total Tax</td>
                                <td>@ViewBag.TotalProductGatval</td>
                            </tr>
                            <tr>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td colspan="10" style="text-align:right; padding-right:20px;">Total Amount</td>
                                <td>@ViewBag.Totalamount</td>

                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="row">

                    <div class="col-xs-12">
                        <p style="padding-top:5px;font-weight:700;">Total Amount (in Words)</p>
                    </div>
                    <div class="col-xs-12" style="margin-top:-18px;">
                        <p style="padding-top:5px;font-weight:700;">@ViewBag.finalword</p>
                    </div>
                </div>
            </div>
        </div>
        <br /><br />
        <div class="row">
            <div class="col-md-12">
                <div class="row">

                    <div class="col-xs-12" style="margin-top:-68px;">
                        <p style="padding-top:5px;font-weight:700;">For @ViewBag.Vendorfrmname</p>
                        <p style="padding-top:10px;font-weight:700;margin-top:-20px;">Authorised Signatory</p>
                    </div>

                </div>
            </div>
        </div>
    </div>

</body>
</html>


