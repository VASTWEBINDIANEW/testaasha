@model IEnumerable<Vastwebmulti.Models.deleteproductlist_Result>
@{
    ViewBag.Title = "DeleteproductList";
    Layout = "~/Areas/VENDOR/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="header">
                        <h2>
                          All Deleted Product's List
                        </h2>
                       
                    </div>
                    <div class="body">
                        <div class="table-responsive" style="position:inherit;margin-top:-20px;">
                            <table class="table table-bordered table-striped table-hover dataTable js-exportable ">
                                <thead  style="color:black;background-color:whitesmoke;">
                                    <tr>
                                        <th style="padding-left:2px;">Product Name</th>
                                        <th style="padding-left:2px;">Sub&nbsp;Catagory</th>
                                        <th style="padding-left:2px;">Actual&nbsp;Price</th>
                                        <th style="padding-left:2px;">List&nbsp;Price</th>
                                        <th style="padding-left:2px;">Stoke</th>
                                         <th style="padding-left:2px;">HSN</th>
                                        <th style="padding-left:2px;">GST(%)</th>
                                         <th style="padding-left:2px;">Photo</th>
                                         <th style="padding-left:2px;">Action</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
            {
                                        <tr>
                                            <td style="padding:3px;">@item.Name</td>
                                            <td style="padding:3px;">@item.SubCatName</td>
                                            <td style="padding:3px;">₹&nbsp;@String.Format("{0:0.00#}", item.StandardPrice)</td>
                                            <td style="padding:3px;">₹&nbsp;@String.Format("{0:0.00#}", item.ListPrice)</td>
                                            <td style="padding:3px;">@item.stock</td>
                                            <td style="padding:3px;">@item.HSN</td>
                                            <td style="padding:3px;">@item.GST</td>
                                          
                                            @if (!string.IsNullOrWhiteSpace(item.Photo))
                                            {
                                                <td style="padding: 3px;">

                        <img src="@Url.Content("~"+item.Photo)" height="60px" width="60px" />
                                                </td>
                                            }
                                            else
                                            {
                                                <td style="padding: 3px;">
                                                    

                                                </td>
                                            }

                                      <td>
                                            @using (Html.BeginForm("UpdateDeleteStatus", "Home", FormMethod.Post))
                                            { 
                                               <input type="text" id="idno" name="idno" value="@item.ProductID" style="display:none;" />
                                            <button type="submit" class="btn btn default" id="but" onclick="return confirm('Are you sure you want to restore this product?');" style="background-color:transparent; border:none;border:1px solid #c7c2c2;margin-top:4px; padding:5px 13px 5px 13px;" title="Restore Product">
                                                Restore
                                            </button>
                                         
                                            }
                                      </td>

                                        </tr>


                                    }

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</section>

