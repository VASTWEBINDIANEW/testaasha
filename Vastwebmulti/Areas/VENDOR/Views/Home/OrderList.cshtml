@model IEnumerable<Vastwebmulti.Areas.VENDOR.ViewModel.OrderListVM>
@{
    ViewBag.Title = "OrderList";
    Layout = "~/Areas/VENDOR/Views/Shared/_Layout.cshtml";
}
<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 81px !important;
    }

    table.dataTable tbody th, table.dataTable tbody td {
        padding: 4px 5px;
    }

    .form-inline .bootstrap-select.btn-group, .form-horizontal .bootstrap-select.btn-group, .form-group .bootstrap-select.btn-group {
        height: 26px;
    }
</style>
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    <div class="col-md-3">
                        <p style="font-size:20px;margin-top:6px;">All Order's Details</p>
                    </div>
                    <div class="col-md-9">
                        @using (Html.BeginForm("OrderList", "Home", FormMethod.Post))
                        {
                            <div class="row">
                                <div class="col-md-2">
                                    <div class="form-group" style="margin-bottom:0px;margin-left:-14px;width:108%;">
                                        <div class="" style="border:1px solid #bfbebe; margin-top:6px;padding-bottom:4px;">
                                            @Html.DropDownList("Cateid", (IEnumerable<SelectListItem>) ViewBag.category as SelectList, "Select Category", new { id = "Cateid", @class = "selectpicker form-control", data_live_search = "true" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group" style="margin-left:-14px;width:108%;">
                                        <div class="" style="border:1px solid #bfbebe; margin-top:6px;padding-bottom:4px;">
                                            @Html.DropDownList("ddl_status", new List<SelectListItem>
               {
               new SelectListItem{ Text="ALL STATUS",Value=""},
                     new SelectListItem{Text="Pending",Value="1"},
               new SelectListItem{Text="Delivered",Value="2"},
                new SelectListItem{Text="Cencelled",Value="3"}
                }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "height:32px;padding:0px;" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #bfbebe;margin-top:6px;margin-left:-13px;width:108%;padding-bottom:4px;">
                                            @Html.DropDownList("ddl_top", new List<SelectListItem>
               {
               new SelectListItem{ Text="TOP 50",Value="50",},
               new SelectListItem{Text="TOP 100",Value="100"},
                new SelectListItem{Text="TOP 200",Value="200"},
               new SelectListItem{Text="TOP 500",Value="500"},
               new SelectListItem{Text="TOP 1000",Value="1000"},
               new SelectListItem{Text="TOP 1500",Value="1500"},
               new SelectListItem{Text="ALL ENTRY",Value="1000000"}
                }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "height:32px;padding:0px;" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="input-daterange input-group" style="margin-left:-13px;width:108%;">
                                        @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:6px;height:32px;" })
                                        <span class="input-group-addon">
                                            <i class="fa fa-exchange" style="padding-top:11px;"></i>
                                        </span>
                                        @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:6px;height:32px;" })
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <center>
                                        <button type="submit" class="btn bg-grey waves-effect" style="margin-top:6px; margin-left:-25px; height:32px;">
                                            <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                            <span style="top:-2px;color:black;">Search</span>
                                        </button>
                                    </center>
                                </div>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-38px;">
                <div class="card">
                    <div class="">
                        <h2 style="color:black; font-size:20px;padding-top:9px; padding-left:22px;color:#44404070;">
                       
                        </h2>

                    </div>
                    <div class="" id="lstProduct">
                        @Html.Partial("_orderListPartail", Model)
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>
<script src="~/Scripts/PageScript/Vendor/ProductList.js"></script>

<script>
    function FillID(id) {
        $("#ProductID").val(id);
    }
</script>
<script>
    window.onload = function () {
        var approve = '@ViewBag.success';
        var failed = '@ViewBag.failed';
        if (approve != "") {
            swal("Wow..", approve, "success");
        }
        if (failed != "") {
            swal("Ooops..", failed, "error");
        }

        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
    }
</script>

<!--Approved Product -->
<script>
    function Approvedandreject(idno, OrderId, status, retailerid, role)
    {
        var answer = confirm('Are you sure ?');
        if(answer)
        {
            $.ajax({
                url: '@Url.Action("UpdateOrderStatus", "Home")',
                type: 'POST',
                dataType: "html",
                data: { idno: idno, OrderId: OrderId, status: status, retailerid: retailerid, role: role },
                success: function (data) {

                    var response = JSON.parse(data);
                    var type = response.Type;
                    var Message = response.Message;
                    if (response.Status) {
                        window.location.reload();
                            $.ajax({
                            url: '@Url.Action("OrderList1", "Home")',
                            type: 'GET',
                            dataType: "html",
                            data: { type: type, Message: Message },
                            success: function (data) {
                                
                               $('#lstProduct').html(data);
                              }

                        });
                    }
                    else {
                        swal("Wow..", response.Message, "success");
                        window.location.reload();
                                     }


                },
                error: function (data) {

                }
            });

            return true;
        }
        else {
            return false;
        }
    }
</script>

<script>
    function OnSuccess(data)
    {
        //alert("OnSuccess");
        $("#otpModal").modal('hide');
        if(data.Status == "Success")
        {
            swal("Wow!!", data.Message, "success");
            setTimeout(function () {
                location.reload();
            }, 5000);
        }else
        {
            swal("Oops!!", data.Message, "error");
        }
    }
    function OnFailure(data)
    {
        //alert("OnFailure");
        $("#otpModal").modal('hide');
        swal("Oops!!", "some error ocured", "error");

    }
    function SetHiddenFieldVal(id)
    {
        //alert(id);
        $("#orderId").val(id);
    }
</script>