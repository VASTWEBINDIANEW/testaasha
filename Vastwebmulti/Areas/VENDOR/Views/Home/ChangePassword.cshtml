@model Vastwebmulti.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "ChangePassword";
    Layout = "~/Areas/VENDOR/Views/Shared/_Layout.cshtml";
}
<section class="content">
    <div class="container-fluid">

        <div class="row clearfix">
            <div class="col-md-4">
                <div class="card">
                    <div class="header">
                        <h2 style="color:red; font-size:16PX; font-weight:700;"><i class="fa fa-lock" aria-hidden="true"></i>&nbsp;&nbsp;Required Password Strength:-</h2>
                    </div>
                    <div style="padding-top:13px;">
                        <p style="line-height:32px;padding-left:10px;">1.Password must be Required one Special character</p>
                        <p style="line-height:32px;padding-left:10px;">2.Password must be Required one Digit Number</p>
                        <p style="line-height:32px;padding-left:10px;">3.Password must be Required one Lowercase character</p>
                        <p style="line-height:32px;padding-left:10px;">4.Password must be Required one Uppercase character</p>
                        <p style="line-height:32px;padding-left:10px;">4.Password must be Required one alphabet character</p>
                        <p style="line-height:32px;padding-left:10px;">5.Password must be Required Minimum Length Six character</p>
                    </div>

                </div>
            </div>
            <div class="col-md-8">
                <div class="card">
                    <div class="header">
                        <h2 style="color:red;">
                            <i class="fa fa-keyboard-o" aria-hidden="true"></i>&nbsp;&nbsp; Change Password
                        </h2>
                    </div>
                    @using (Html.BeginForm("ChangePassword", "Home", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                    {
                        @Html.AntiForgeryToken()
                        <div class="body">
                            <div class="row clearfix">
                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                <div class="col-sm-12">
                                    <label>Enter Old Password</label>
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control", @required = "" })
                                            @Html.ValidationMessageFor(m => m.OldPassword, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                    <label>Enter New Password</label>
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control", @required = "" })

                                        </div>
                                        @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger" })
                                    </div>
                                    <label>Enter Confirm Password</label>
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", @required = "" })

                                        </div>
                                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
                                    </div>
                                    <div style="float:right;">
                                        <button type="submit" class="btn bg-blue-grey m-t-15 waves-effect">Change Password</button>
                                        <a href="@Url.Action("Index","Home")" class="btn bg-teal waves-effect" style="margin-top:15px;">Back</a>
                                    </div>
                                </div>
                            </div>

                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
<script src="~/Scripts/jquery-1.10.2.min.js"></script>
<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script>
        window.onload = function()
        {
            var message = '@TempData["Message"]'
            if(message !="" && message !=null)
            {
                swal("Good job!", message, "success")

            }
        }
</script>

