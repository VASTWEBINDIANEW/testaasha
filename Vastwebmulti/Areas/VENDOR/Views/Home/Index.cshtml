
@{
    Layout = "~/Areas/VENDOR/Views/Shared/_Layout.cshtml";
}

<section class="content">
        <div class="container-fluid">
            <div class="row clearfix">
            <!-- Task Info -->
            <div class="col-md-5">
                <div class="card">
                    <div class="header">
                        <center><h2><i class="fa fa-user-circle-o" style="color:green;font-weight:700;"></i>&nbsp;&nbsp;&nbsp;<span style="color:green; font-weight:700;">" VENDOR "</span>&nbsp;<span>Profile</span></h2></center> 
                    </div>
                    <div class="body">
                        <center>
                            <div class="image" style="margin-top:-6px;">
                                @if (ViewBag.image != null && ViewBag.image != "")
                                {
                                    <img src="@Url.Content("~/" + ViewBag.image)" width="100" height="100" class="img-circle" alt="User">

                                }
                                else
                                {

                                    <img src="~/AdminDesign/images/user.png" width="100" height="100" class="img-circle" alt="User">
                                }

                            </div>
                            <div class="msg" style="padding-top:6px;">@ViewBag.email</div>
                        </center>
                        <center>
                            <div class="row" style="margin-top:4%;">

                                <div class="col-xs-4" style="margin-bottom:0px;">
                                    <a href="~/VENDOR/Home/Profile" class="btn btn-default waves-effect" type="button" style="text-decoration:none;box-shadow:none; border:1px solid #dddddd;"><i class="fa fa-user-circle-o" style="top:1px;font-size:14px;"></i>&nbsp;Profile</a>
                                </div>
                                <div class="col-xs-3" style="margin-bottom:0px;">
                                    @using (Html.BeginForm("LogOff", "Account", new { Area = "", id = "logoutForm" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-default waves-effect" type="submit" style="text-decoration:none;box-shadow:none; border:1px solid #dddddd;margin-left:-17px;"><i class="fa fa-sign-out" style="top:0px; color:red;font-size:14px;"></i><span style="top:-2px; color:red; font-size:13px;">Logout</span></button>
                                    }
                                </div>
                                <div class="col-xs-3" style="margin-bottom:0px;">
                                    <a href="@Url.Action("ChangePassword","Home")" style="text-decoration:none;box-shadow:none; border:1px solid #dddddd; margin-left:-8px;" class="btn btn-default waves-effect"><span style="font-size:13px;top:-2px;"><i class="material-icons" style="font-size:14px;top:2px;">lock_outline</i>&nbsp;Change Pass</span></a>
                                </div>

                            </div>
                        </center>


                    </div>
                </div>
               </div>

            <div class="col-md-7">
                <div class="card">
                    <div class="header">
                        <h2><i class="fa fa-bar-chart"></i>&nbsp;<span>TODAY BUSINESS</span></h2>
               </div>
                    <div class="body" style="height:212px;">
                        
                    </div>
                </div>
            </div>
         
        </div>
            <div class="row clearfix">
                <div class="col-md-5">
                    <div class="card" style="margin-top:-6px;">
                        <div class="" style="padding-top:29px;">
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="body" style="margin-top:-31px;">
                                        <div class="icon-button-demo">
                                            @*<div class="col-xs-4">
                                                <a href="~/RETAILER/Home/Purchase_ORDER">
                                                    <button type="button" class="btn btn-grey btn-circle-lg waves-effect waves-circle waves-float">
                                                        <img src="~/images/reportimage/purchase.svg">
                                                    </button>
                                                </a>
                                                <a href="~/RETAILER/Home/Purchase_ORDER" style="margin-left:-14px;cursor:pointer;font-size:11px;font-weight:700;">Purchase&nbsp;Req</a>
                                            </div>*@

                                            @*<div class="col-xs-4">
                                                <a href="~/RETAILER/Home/Retailer_to_retailer">
                                                    <button type="button" class="btn btn-grey btn-circle-lg waves-effect waves-circle waves-float">
                                                        <center>
                                                            <i class="fa fa-exchange" style="margin-left:0px;color:black;font-weight:700;"></i>
                                                        </center>
                                                    </button>
                                                </a>
                                                <a href="~/RETAILER/Home/Retailer_to_retailer" style="margin-left:-9px;cursor:pointer;font-size:11px;font-weight:700;">R&nbsp;to&nbsp;R&nbsp;Transfer</a>
                                            </div>*@
                                            <div class="col-xs-4">
                                                <a href="@Url.Action("WalletUnloadReport","Home")">
                                                    <button type="button" class="btn btn-grey btn-circle-lg waves-effect waves-circle waves-float" style="margin-left:7px;">
                                                        <center>
                                                            <i class="fa fa-credit-card" style="font-size:20px;font-weight:700;color:black;"></i>

                                                        </center>
                                                    </button>
                                                </a>
                                                <a href="@Url.Action("WalletUnloadReport","Home")" style="margin-left:-2px;cursor:pointer;font-size:11px;font-weight:700;">Unload&nbsp;Wallet</a>
                                            </div>


                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                </div>


    </div>
</section>
