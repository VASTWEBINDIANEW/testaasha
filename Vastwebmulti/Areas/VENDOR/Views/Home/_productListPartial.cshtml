@model List<Vastwebmulti.Models.proc_ProductList_Result>
<div class="table-responsive" style="position:inherit;margin-top:-15px;">
    <table class="table table-bordered table-striped table-hover dataTable js-exportable ">
        <thead  style="color:black;background-color:whitesmoke;">
            <tr>
                <th style="padding-left:2px;">Product Name</th>
                <th style="padding-left:2px;">Sub&nbsp;Catagory</th>
                <th style="padding-left:2px;">Actual&nbsp;Price</th>
                <th style="padding-left:2px;">List&nbsp;Price</th>
                <th style="padding-left:2px;">Stoke</th>
               
                <th style="padding-left:2px;">HSN</th>
                <th style="padding-left:2px;">GST(%)</th>
                <th style="padding-left:2px;">Status</th>
                <th style="padding-left:2px;">Show&nbsp;on&nbsp;Home</th>
                <th style="padding-left:2px;">Photo</th>
                @*<th style="padding-left:2px;">MIN&nbsp;Order&nbsp;QTY</th>
                    <th style="padding-left:2px;">MAX&nbsp;Order&nbsp;QTY</th>*@

                <th style="padding-left:2px;">Action</th>

            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="padding:3px;">@item.Name</td>
                    <td style="padding:3px;">@item.SubCatName</td>
                    <td style="padding:3px;">₹&nbsp;@item.StandardPrice</td>
                    <td style="padding:3px;">₹&nbsp;@item.ListPrice</td>
                    <td style="padding:3px;">@item.stock</td>
                     <td style="padding:3px;">@item.HSN</td>
                    <td style="padding:3px;">@item.GST</td>
                    @if (item.IsActive)
                    {
                       
                   <td style="padding:3px;">
                       <center>
                           <a href="#" style="text-decoration:none;">
                               <img src="~/images/reportimage/switch_on.png" style="margin-top:2px;height:20px;" />
                           </a>
                       </center>

                </td>
                    }
                    else
                    {
                    <td style="padding:3px;">
                        <center>
                            <a href="#" style="text-decoration:none;">
                                <img src="~/images/reportimage/switchoff.png" style="margin-top:2px;height:20px;" />
                            </a>
                        </center>
                    </td>
                    }
                    @if (@item.ShowOnHome==true)
                    {

                        <td style="padding:3px;">
                            <center>
                                <a href="#" style="text-decoration:none;">
                                    <img src="~/images/reportimage/switch_on.png" style="margin-top:2px;height:20px;" />
                                </a>
                            </center>
                       
                        </td>
                    }
                    else
                    {
                        <td style="padding:3px;">
                            <center>
                                <a href="#" style="text-decoration:none;">
                                    <img src="~/images/reportimage/switchoff.png" style="margin-top:2px;height:20px;" />
                                </a>
                            </center>>
                        </td>
                    }
                    
                    @if (!string.IsNullOrWhiteSpace(item.Photo))
                    {
                        <td style="padding: 3px;">

                            <img src="@Url.Content("~"+item.Photo)" height="60px" width="60px" />
                        </td>
                    }
                    else
                    {
                        <td style="padding: 3px;">
                            <button class="btn bg-blue-grey waves-effect" onclick="FillID('@item.ProductID')" data-toggle="modal" data-target="#ImgUpload">
                                <span>
                                    Upload Image
                                </span>
                            </button>

                        </td>
                    }

                    @*<td style="padding:3px;">@item.MinOrderQty</td>
                        <td style="padding:3px;">@item.MaxOrderQty</td>*@
                    <td style="padding:3px;">
                        @*<a href="@Url.Action("RemoveProduct",new { id = item.ProductID  })" style="text-decoration:none;"><span class="" style=""></span><i class="fa fa-trash fa-2x" style="color:red;"></i></a>*@
                        <div class="header" style="border:none;position:absolute;">
                            <ul class="header-dropdown m-r--5" style="margin-top:-11px;">
                                <li class="dropdown" style="margin-right:-38px;">
                                    <a href="javascript:void(0);" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="true" title="Click to link" style="color:blue;">
                                      Click&nbsp;Now
                                        @*<i class="material-icons">more_vert</i>*@
                                    </a>
                                    <ul class="dropdown-menu pull-right">
                                        <li><a href="@Url.Action("EditProduct",new { id = item.ProductID  })" class="waves-effect waves-block">Edit</a></li>
                                        <li><a href="@Url.Action("RemoveProduct",new { id = item.ProductID  })" class="waves-effect waves-block">Delete</a></li>
                                        <li><a onclick="ReplicateProduct('@item.ProductID')" href="javascript:void(0);" class="waves-effect waves-block">Replicate</a></li>
                                    </ul>
                                </li>
                            </ul>
                        </div>
                    </td>

                </tr>


            }

        </tbody>
    </table>
</div>

