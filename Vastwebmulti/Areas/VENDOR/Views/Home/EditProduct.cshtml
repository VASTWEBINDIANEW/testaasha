@using System.Net.Mime
@using Vastwebmulti.Models
@model Vastwebmulti.Areas.VENDOR.Models.ProductModel
@{
    ViewBag.Title = "CatagoryList";
    Layout = "~/Areas/VENDOR/Views/Shared/_Layout.cshtml";
}

  <style>
    .dropdown-menu {
        margin-top: 81px !important;
    }
</style>
<section class="content">
    <div class="container-fluid">
        <div class="row">
        <div class="col-md-12">
            <div class="card">
                <p style="font-size:20px;padding-top:3px;padding-left:8px;">Edit Product Details</p>
            </div>
        </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card" style="margin-top:-17px;">
                    <div class="body">
                        <div class="demo-button">
                            <div class="row">
                                @using (Html.BeginForm("EditProduct", "Home", FormMethod.Post))
                                {
                                    <div class="modal-body" style="margin-top:-26px;">
                                        <div class="body">
                                            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                            @Html.HiddenFor(a=>a.ProductID)
                                            
                                            <form>
                                                <div class="row clearfix">

                                                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-2 form-control-label">
                                                        <label for="Name">Name</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Product Name", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-2 form-control-label">
                                                        <label for="ShortDescription">Description</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.ShortDescription, "", new { @class = "form-control", placeholder = "Short Description", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.ShortDescription, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-2 form-control-label">
                                                        <label for="SubCatID">Catagory</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.DropDownListFor(m => m.SubCatID, (IEnumerable<SelectListItem>)ViewBag.Catagories, "Select Catagory", new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.SubCatID, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>


                                                </div>
                                                <div class="row clearfix">

                                                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-2 form-control-label">
                                                        <label for="stock">Quantity</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.stock, new { @class = "form-control", placeholder = "Stoke Quantity", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.stock, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-2 form-control-label">
                                                        <label for="MinOrderQty">Min QTY</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.MinOrderQty, "", new { @class = "form-control", placeholder = "Min Order QTY", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.MinOrderQty, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-2 form-control-label">
                                                        <label for="MaxOrderQty">Max QTY</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.MaxOrderQty, "", new { @class = "form-control", placeholder = "Max Order QTY", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.MaxOrderQty, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>




                                                </div>
                                                <div class="row clearfix">

                                                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-2 form-control-label">
                                                        <label for="ListPrice">List&nbsp;Price</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.ListPrice, new { @class = "form-control", placeholder = "List Price", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.ListPrice, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-2 form-control-label">
                                                        <label for="MinQtyFlag">Qty Alert</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.MinQtyFlag, "", new { @class = "form-control", placeholder = "Min Stoke QTY Alert", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.MinQtyFlag, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-2 form-control-label">
                                                        <label for="StandardPrice">Actual&nbsp;Price</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.StandardPrice, "", new { @class = "form-control", placeholder = "Actual Price", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.StandardPrice, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row clearfix">
                                                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-3 form-control-label">
                                                        <label for="ShowOnHome">HSN</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.HSN, new { @class = "form-control", placeholder = "Product HSN", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.HSN, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-3 form-control-label">
                                                        <label for="GST">GST</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.GST, "", new { @class = "form-control", placeholder = "Product GST %", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.GST, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-4 col-md-4 col-sm-5 col-xs-5">
                                                        <div class="form-group">
                                                            <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                                @Html.LabelFor(m => m.Published)
                                                                @Html.CheckBoxFor(m => m.Published, new {@style = "left:0px; opacity:inherit;position:initial;"})
                                                            </div>
                                                            <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                                
                                                                @Html.LabelFor(m => m.ShowOnHome)
                                                                @Html.CheckBoxFor(m => m.ShowOnHome, new {@style = "left:0px; opacity:inherit;position:initial;"})
                                                            </div>



                                                        </div>
                                                    </div>

                                                </div>
                                                <div class="row clearfix">
                                                    <div class="col-md-2">
                                                        <label for="ShowOnHome">Admin Comm.</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group" style="margin-left:-91px; margin-top:-8px;">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.AdminComm, new { @class = "form-control", placeholder = "Admin Comm.", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.AdminComm, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>

                                                    @*<div class="col-lg-1 col-md-1 col-sm-2 col-xs-3 form-control-label">
                                                        <label for="GST">GST</label>
                                                    </div>
                                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-4">
                                                        <div class="form-group">
                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextBoxFor(m => m.GST, "", new { @class = "form-control", placeholder = "Product GST %", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.GST, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>*@
                                                    @*<div class="col-lg-4 col-md-4 col-sm-5 col-xs-5">
                                                        <div class="form-group">
                                                            <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                                                @Html.LabelFor(m => m.Published)
                                                                @Html.CheckBoxFor(m => m.Published, new { @style = "left:0px; opacity:inherit;position:initial;" })
                                                            </div>
                                                            <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">

                                                                @Html.LabelFor(m => m.ShowOnHome)
                                                                @Html.CheckBoxFor(m => m.ShowOnHome, new { @style = "left:0px; opacity:inherit;position:initial;" })
                                                            </div>



                                                        </div>
                                                    </div>*@

                                                </div>
                                                <div class="row clearfix">
                                                    <div class="col-lg-12 col-md-12 col-sm-10 col-xs-9">
                                                        <div class="form-group">

                                                            <label for="FullDescription">Product Full Description</label>

                                                            <div class="" style="border:1px solid #ddd;">
                                                                @Html.TextAreaFor(m => m.FullDescription, 5, 5, new { @class = "form-control ckeditor", placeholder = "Product full description", required = "required" })
                                                                @Html.ValidationMessageFor(m => m.FullDescription, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="modal-footer">
                                                    <button type="submit" class="btn btn-primary waves-effect">Save Change</button>
                                                    <button type="button" class="btn btn-info waves-effect" data-dismiss="modal" onclick="javascript: history.go(-1);">Back</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script src="~/Ckeditor/ckeditor.js"></script>
<script src="~/Ckeditor/adapters/jquery.js"></script>
<script type="text/javascript"> CKEDITOR.replace('txtedit'); </script>
<script src="@Url.Content("~/Scripts/jquery.validate.min.js")"></script>
<script src="@Url.Content("~/Scripts/jquery.validate.unobtrusive.min.js")"></script>


