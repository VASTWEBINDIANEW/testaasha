@model IEnumerable<Vastwebmulti.Models.VendorWalletToBankAmountTransferRequest>
@{
    ViewBag.Title = "Wallet Unload";
    Layout = "~/Areas/VENDOR/Views/Shared/_Layout.cshtml";
}
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }

    .btn-group, .btn-group-vertical {
        box-shadow: none;
    }

    .ppp {
        margin-top: -20px !important;
    }

    .form-inline .bootstrap-select.btn-group, .form-horizontal .bootstrap-select.btn-group, .form-group .bootstrap-select.btn-group {
        height: 29px;
    }
</style>
<section class="content" >
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    <div class="col-md-7" style="border-right:4px solid #dddddd;">
                        @using (Ajax.BeginForm("AddWalletToBankRequest", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "OnSuccess", OnFailure = "OnFailed" }))
                        {
                            <div class="">
                                <div class="col-md-4">
                                    <div class="form-group" style="margin-top:4px;margin-left:10px;">
                                        <div class="" style="padding-bottom:3px;border:1px solid #dddddd;margin-left:-36px;">
                                            <input class="form-control" id="Amount" name="Amount" onkeypress="return isNumber(event)" placeholder="Enter Value" required="required" style="padding-top:4px;height:30px;" type="text">

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group" style="margin-top:4px;margin-left:10px;">
                                        <div class="" style="padding-bottom:3px;border:1px solid #dddddd;margin-left:-23px;">
                                            <select id="Type" name="Type" class="form-control" required="" style="height:29px;">
                                                <option value="General">General</option>
                                                <option value="Tatkal">Tatkal</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group">
                                        <button type="submit" id="submit" class="btn  waves-effect" style="margin-top:4px; margin-left:-12px; height:34px;border:1px solid #c7c2c2;background:#dedddd;" onclick="return confirm('Are you sure to unload this amount from wallet into your bank account?');">
                                            <i class="fa fa-exchange" style="top:1px;font-size:18px;"></i>
                                            <span style="top:-1px;color:black;">Transfer</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="col-md-5">
                        @using (Html.BeginForm("WalletUnloadReport", "Home", FormMethod.Post))
                        {
                            <div class="">
                                <div class="col-md-12">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group" style="margin-bottom:0px;margin-left:-10px;width:108%;">
                                                <div class="input-daterange input-group">
                                                    @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;", autocomplete = "off" })
                                                    <span class="input-group-addon">
                                                        <i class="fa fa-exchange"></i>
                                                    </span>
                                                    @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;", autocomplete = "off" })
                                                </div>
                                                <!-- /.input group -->
                                            </div>
                                        </div>
                                        <div class="col-md-2">
                                            <center>
                                                <button type="submit" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left:-20px; height:34px;">
                                                    <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                                    <span style="top:-2px;color:black;">Search</span>
                                                </button>
                                            </center>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    <div class="body" style="margin-top:-18px;">
                        <div class="table-responsive " style="position:inherit;padding:0px;margin-top:-17px;">
                            <table id="example" class="table table-bordered table-striped   ">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Status</th>
                                        <th>Bank&nbsp;Name</th>
                                        <th>Bank&nbsp;Account</th>
                                        <th>Ifsc&nbsp;Code</th>
                                        <th>₹&nbsp;Value</th>
                                        <th>₹&nbsp;Charge</th>
                                        <th>Type</th>
                                        <th>Remain&nbsp;Pre</th>
                                        <th>Remain&nbsp;Post</th>
                                        <th>Request&nbsp;Id</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                @foreach (var item in Model)
                                {
                                    var color = "";
                                    if (item.Status.Contains("Success"))
                                    {
                                        color = "green";
                                    }
                                    if (item.Status.Contains("Pending"))
                                    {
                                        color = "#FF9800";
                                    }
                                    if (item.Status.Contains("Rejected"))
                                    {
                                        color = "red";
                                    }
                                    if (item.Status.Contains("Refund"))
                                    {
                                        color = "#3F51B5";
                                    }
                                    <tbody>

                                        <tr>
                                            <td style="color:@color;font-weight:700;">@Html.DisplayFor(modelItem => item.Status)</td>
                                            <td>@Html.DisplayFor(modelItem => item.BankName)</td>
                                            <td>@Html.DisplayFor(modelItem => item.BankAccount)</td>
                                            <td>@Html.DisplayFor(modelItem => item.IfscCode)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Amount)</td>
                                            <td>@Html.DisplayFor(modelItem => item.ProcessingCharge)</td>
                                            <td>@Html.DisplayFor(modelItem => item.TransferType)</td>
                                            <td>@Html.DisplayFor(modelItem => item.VenderPre)</td>
                                            <td>@Html.DisplayFor(modelItem => item.VenderPost)</td>
                                            <td>@Html.DisplayFor(modelItem => item.RequestId)</td>
                                            <td>@Html.DisplayFor(modelItem => item.RequestDate)</td>
                                        </tr>
                                    </tbody>
                                }

                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>

</section>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-colorpicker/js/bootstrap-colorpicker.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>


<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>

<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>>
<script>
    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 45 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }
</script>
<!--Calendar Javascript-->
<script>
    $(function()
    {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
    });
</script>
<script>
    $(function () {

        var succ = '@ViewData["success"]';
        var error = '@ViewData["error"]';
        if (succ != null && succ != "")
        {
            swal("Good job!", succ,"success");
        }
        if (error != null && error != "")
        {
            swal("Oops!", error, "error");
        }

    });
    function OnSuccess(data)
    {
        //alert("Success");
        var respose = JSON.parse(data);

        if (respose.status == "Success")
        {
            swal({ title: "Good job!", text: respose.Message, type: "success" },
              function () {
                  location.reload();
              }
           );
        } else if (respose.status == "Failed") {

            swal({ title: "Oops!", text: respose.Message, type: "error" },
                        function () {
                            location.reload();
                        }
                     );
        }
    }
    function OnFailed()
    {
        swal("Oops!", "Internal Error,contact to admin", "error");
    }
</script>
<script>
    $(function () {
        $('#example').DataTable({
            dom: 'Bfrtip',
            buttons: [
                'copyHtml5',
                'excelHtml5',
                'csvHtml5',
                'pdfHtml5',
                'print'
            ]
        });
    });
</script>
