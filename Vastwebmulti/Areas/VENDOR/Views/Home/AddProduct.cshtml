@using System.Net.Mime
@using Vastwebmulti.Models
@model Vastwebmulti.Areas.VENDOR.Models.ProductModel
@{
    ViewBag.Title = "CatagoryList";
    Layout = "~/Areas/VENDOR/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="header">
                        <h2><span>Add New Product</span></h2>
                    </div>
                @using (Html.BeginForm("AddProduct", "Home", FormMethod.Post))
                {
                    <div class="body">
                        <div class="row clearfix">
                            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                            <div class="col-md-4">
                                <b>Product Name</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                        <div class="">
                                            @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Product Name", required = "required", @maxlength = "50",@style="padding-left:5px;" })
                                  </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-4">
                                <b>Short Description</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.TextBoxFor(m => m.ShortDescription, "", new { @class = "form-control", placeholder = "Short Description", required = "required" , @style = "padding-left:5px;" })
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.ShortDescription, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-4">
                                <b>Category</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.DropDownList("Cateid",  (IEnumerable<SelectListItem>)ViewBag.category, "Select Category", new { @class = "form-control", @style = "padding-left:5px;" })
                           
                                    </div>
                                </div>
                            </div>
                            </div>
                        <div class="row">
                            <div class="col-md-4">
                                <b>Sub Category</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.DropDownListFor(m => m.SubCatID,
                        new SelectList(Enumerable.Empty<SelectListItem>(), "SubCatID", "SubCatName"),
                             "Select Sub Category",
                        new { @class = "form-control", required = "required", @style = "padding-left:5px;" })
                                        @*@Html.DropDownListFor(m => m.SubCatID, (IEnumerable<SelectListItem>)ViewBag.Catagories, "Select Sub Category", new { @class = "form-control", required = "required", @style = "padding-left:5px;" })*@
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.SubCatID, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-4">
                                <b>Quantity in Stoke</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.TextBoxFor(m => m.stock, new { @class = "form-control", placeholder = "Stoke Quantity", required = "required", @style = "padding-left:5px;" })
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.stock, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-4">
                                <b>Minimum Order Quantity</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.TextBoxFor(m => m.MinOrderQty, "", new { @class = "form-control", placeholder = "Min Order QTY", required = "required", @style = "padding-left:5px;" })
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.MinOrderQty, "", new { @class = "text-danger" })
                            </div>
                            </div>
                            
                        <div class="row">
                            <div class="col-md-3">
                                <b>Maximum Order Quantity</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.TextBoxFor(m => m.MaxOrderQty, "", new { @class = "form-control", placeholder = "Max Order QTY", required = "required", @style = "padding-left:5px;" })
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.MaxOrderQty, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-3">
                                <b>MRP Price</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.TextBoxFor(m => m.ListPrice, new { @class = "form-control", placeholder = "List Price", required = "required", @style = "padding-left:5px;" })
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.ListPrice, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-3">
                                <b>Actual Product Price</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.TextBoxFor(m => m.StandardPrice, "", new { @class = "form-control", placeholder = "Actual Price", required = "required", @style = "padding-left:5px;" })
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.StandardPrice, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-3">
                                <b>Minimum Stoke "Alert" Quantity  </b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.TextBoxFor(m => m.MinQtyFlag, "", new { @class = "form-control", placeholder = "Min Stoke QTY Alert", required = "required", @style = "padding-left:5px;" })
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.MinQtyFlag, "", new { @class = "text-danger" })
                            </div>
                            </div>
                    
                        <div class="row">
                            <div class="col-md-3">
                                <b>Admin Commission (Rs)</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.TextBoxFor(m => m.AdminComm, "", new { @class = "form-control", placeholder = "Admin Commission", required = "required", @style = "padding-left:5px;" })
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.AdminComm, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-3">
                                <b>Product HSN Code</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.TextBoxFor(m => m.HSN, new { @class = "form-control", placeholder = "Product HSN", required = "required", @style = "padding-left:5px;" })
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.HSN, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-2">
                                <b>Product&nbsp;Applicable&nbsp;GST&nbsp;%</b>
                                <div class="input-group" style="border:1px solid #dddddd;">
                                    <div class="">
                                        @Html.TextBoxFor(m => m.GST, "", new { @class = "form-control", placeholder = "Product GST %", required = "required", @style = "padding-left:5px;" })
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.GST, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-4">
                                <div class="form-group" style="margin-top:25px;">
                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                                        @Html.LabelFor(m => m.Published)
                                        @Html.CheckBoxFor(m => m.Published, new { @style = "left:0px; opacity:inherit;position:initial;" })
                                    </div>
                                    <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">

                                        @Html.LabelFor(m => m.ShowOnHome)
                                        @Html.CheckBoxFor(m => m.ShowOnHome, new { @style = "left:0px; opacity:inherit;position:initial;" })
                                    </div>
                                </div>
                            </div>
                            </div>

                       <div class="row">
                            <div class="col-md-12">
                                <b>Product Full Description</b>
                                <div class="input-group">
                                    <div class="form-line">
                                        @Html.TextAreaFor(m => m.FullDescription, 5, 5, new { @class = "form-control ckeditor", placeholder = "Product full description", required = "required" })
                                     
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(m => m.FullDescription, "", new { @class = "text-danger" })
                            </div>
                            <div class="col-md-12">
                                <div class="modal-footer">
                                    <button type="submit" class="btn bg-blue-grey waves-effectt">Save Product</button>
                                    <button type="reset" class="btn bg-grey waves-effect" data-dismiss="modal">Reset</button>
                                </div>
                            </div>
                        </div>
                        
                    </div>
                }

                    

                </div>
            </div>
        </div>

    </div>
</section>
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script src="~/Ckeditor/ckeditor.js"></script>
<script src="~/Ckeditor/adapters/jquery.js"></script>
<script type="text/javascript"> CKEDITOR.replace('txtedit'); </script>
<script src="@Url.Content("~/Scripts/jquery.validate.min.js")"></script>
<script src="@Url.Content("~/Scripts/jquery.validate.unobtrusive.min.js")"></script>
<!--Add fill dropdown list-->
<script language="javascript" type="text/javascript">
                    $(function () {
                        $('#Cateid').change(function () {
                            // alert('Value:' + ' ' + $('#State1').val())
                            var stid = $('#Cateid').val()

                            GetDistrict(stid)
                
                        });
                    })

                    function GetDistrict(_stateId) {
                        var procemessage = "<option value='0'> Please wait...</option>";
                        $("#SubCatID").html(procemessage).show();
                        var url = '@Url.Action("SubcategoryList","Home")'
                        $.ajax({
                            url: url,
                            data: { Id: _stateId },
                            cache: false,
                            type: "POST",
                            success: function (data) {

                                $("#SubCatID").html("");
                                for (var x = 0; x < data.length; x++) {

                                    $("#SubCatID").append($('<option></option>').val(data[x].Value).html(data[x].Text));
                                }

                            },
                            error: function (reponse) {
                                alert("error : " + reponse);
                            }
                        });
                    }

 


</script>

