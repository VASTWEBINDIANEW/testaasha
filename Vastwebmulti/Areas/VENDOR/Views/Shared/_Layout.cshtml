    <link href="~/AdminDesign/css/themes/all-themes.css" rel="stylesheet" />
    <link href="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/css/dataTables.bootstrap.css" rel="stylesheet">
    <link href="~/AdminDesign/plugins/bootstrap-material-datetimepicker/css/bootstrap-material-datetimepicker.css" rel="stylesheet" />
    <link href="~/AdminDesign/plugins/sweetalert/sweetalert.css" rel="stylesheet" />
    <link href="~/ClanderCss/bootstrap-datepicker3.min.css" rel="stylesheet" />
    <link href="~/ClanderCss/bootstrap-datetimepicker.min.css" rel="stylesheet" />
    <link href="~/ClanderCss/daterangepicker.min.css" rel="stylesheet" />
    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
    @if (!HttpContext.Current.Request.IsLocal)
    {
        <!-- To Disable Inspect Element -->
        <script src="~/Scripts/Disable_Inspect_Element/Disable_Inspect.js"></script>
    }
    <style>
        .sidebar .menu .list a span {
            color: white;
        }

        .sidebar .menu .list a {
            color: white;
        }

        .navbar .navbar-toggle:before {
            content: '\E8D5';
            font-family: 'Material Icons';
            font-size: 26px;
        }

        .navbar .navbar-toggle:before {
            content: '\E8D5';
            font-family: 'Material Icons';
            font-size: 26px;
        }

        .sidebar .menu .list i.material-icons {
            margin-top: 6px;
        }

        .sidebar .menu .list .ml-menu li a {
            font-size: 11px;
        }

        .material-icons {
            font-size: 20px;
        }
    </style>
</head>
@{
    VastwebmultiEntities DB = new VastwebmultiEntities();
    var color = DB.changecolors.AsNoTracking().Where(a => a.Role == "ADMIN").ToList();
    var col = "";
    if (color.Count >0)
    {
        col = color.SingleOrDefault().adminandouterheadercolor;
    }
    else
    {
        col = "pink";
    }

    var image = "";
    var backimage = DB.tblWhiteLabelLoginBackImages.AsNoTracking().FirstOrDefault(p => p.Role == "ADMIN");
    if (backimage != null)
    {
        image = backimage.ImageUrl;
    }
    else
    {
        image = "img24.png";
    }
    <!--Current Login Time-->
    var userid = User.Identity.GetUserId();
    var emailid = DB.Users.AsNoTracking().Where(a => a.UserId == userid).FirstOrDefault().Email;
    var currentlogintime = DB.Login_info.AsNoTracking().Where(a => a.UserId == emailid).OrderByDescending(a => a.Idno).ToList();
    var logintime = currentlogintime.FirstOrDefault().CurrentLoginTime;
    var remain = (from nm in DB1.vendor_remainbal where nm.userid == userid select nm).Single().remain;
    var logoimage = "";
    var logo = DB.tblHeaderLogoes.AsNoTracking().Where(p => p.Role == "ADMIN").ToList();
    if (logo.Count > 0)
    {
        if (logo.SingleOrDefault().Role == "ADMIN")
        {
            logoimage = logo.Where(p => p.Role == "ADMIN").SingleOrDefault().LogoImage;
        }
    }
    else
    {
        logoimage = "images/Default_Logo.png";
    }
       <!--count retailer pending product-->
    var show = DB.Total_Retailer_pending_product(userid).SingleOrDefault();
    ViewBag.pending = show.Totalcount ;
}
<body class="theme-@col">

    <!-- Page Loader -->
    <div class="page-loader-wrapper">
        <div class="loader">
            <center><img src="~/images/serachimg.gif" class="img-responsive" style="height:200px;width:200px;" /></center>

        </div>
    </div>
    <!-- #END# Search Bar -->
    <!-- Top Bar -->
    <nav class="navbar">
        <div class="container-fluid">
            <div class="navbar-header" style="padding:0px 0px;">
                <a href="javascript:void(0);" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar-collapse" aria-expanded="false"></a>
                <a href="javascript:void(0);" class="bars"></a>
                <a href="~/VENDOR/Home/Index">
                    <center>
                        <img src="@Url.Content("~/"+@logoimage)" class="img-responsive" style="width:148px;" />
                    </center>
                </a>
            </div>

            <div class="collapse navbar-collapse" id="navbar-collapse">
                <ul class="nav navbar-nav navbar-right">
                 
                    
                     <li class="dropdown">
                        <a href="javascript:void(0);" class="dropdown-toggle" data-toggle="dropdown" role="button">
                            <span class="label-count" style="background:none; font-size:13px;margin-right:4px; padding-top:2px;">Current Login Time</span>
                            <p style="padding-top:11px; padding-left:15px; color:white;">@logintime</p>
                        </a>                      
                    </li>
                    <li class="list-group" style="margin-top:-11px;padding-left:26px; margin-bottom:-18px;padding-right:25px;">
                        <a href="@Url.Action("OrderList","Home")" class="btn btn-default btn-circle waves-effect waves-circle waves-float pull-right" title="Total Pending Product">
                            @if (ViewBag.pending != null)
                            {
                                <i class="" style="color:black;font-size:20px;left:-1px;top:3px; font-weight:500; font-style:normal;">@ViewBag.pending</i>
                            }
                            else
                            {
                                <i class="" style="color:black;font-size:20px;left:-1px;top:3px; font-weight:500; font-style:normal;">0</i>

                            }

                        </a>

                        <center><p style="color:white;font-size:11px;margin-right:-16px;">Product&nbsp;Req.</p></center>

                    </li>
                    <!--Retailer Live  Balance-->
                    <li class="list-group" style="margin-top:-11px;padding-left:14px; margin-bottom:-10px;">
                        <a href="javascript:void(0);" class="btn btn-default btn-circle waves-effect waves-circle waves-float pull-right dropdown-toggle" data-toggle="dropdown" role="button" aria-expanded="true" title="Wallet Balance" style="margin-right:6px;">
                            <img src="~/images/reportimage/purse.svg" class="img-responsive" style="height:20px;margin-top:3px;margin-left:4px;" />
                        </a>
                        <center><p style="color:white;font-size:11px;">@remain</p></center>


                    </li>
                    <li class="list-group" style="padding-top:6px;padding-left:14px; margin-bottom:-10px;">
                        @using (Html.BeginForm("LogOff", "Account", new { Area = "", id = "logoutForm" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-default btn-circle waves-effect waves-circle waves-float pull-right" title="Logout">
                                <i class="material-icons" style="color:red;font-size:22px;left:-3px;top:3px; font-weight:700;">power_settings_new</i>
                            </button>
                        }
                        <p style="color:white;font-size:11px;">Logout</p>
                    </li>
                   
                </ul>
            </div>
        </div>
    </nav>
    <!-- #Top Bar -->
    <section>
        <!-- Left Sidebar -->
        <aside id="leftsidebar" class="sidebar navbar" style="margin-top:-4px;">
            <!-- #User Info -->
            <!-- Menu -->
            <div class="menu">
                <ul class="list">
                    <li class="active">
                        <a href="~/VENDOR/Home/Index">
                            <i class="material-icons" style="color:white;">home</i>
                            <span style="color:white;">Home</span>
                        </a>
                    </li>
                    <li class="">
                        <a href="~/VENDOR/Home/ProductList">
                            <i class="material-icons" style="color:white;">assignment</i>
                            <span style="color:white;">Add&nbsp;New&nbsp;Product</span>
                        </a>
                    </li>
                    <li class="">
                        <a href="~/VENDOR/Home/Attributes">
                            <i class="material-icons" style="color:white;">assignment</i>
                            <span style="color:white;">Add&nbsp;New&nbsp;Attributes</span>
                        </a>
                    </li>
                    <li class="">
                        <a href="~/VENDOR/Home/OrderList">
                            <i class="material-icons" style="color:white;">payment</i>
                            <span style="color:white;">Order List</span>
                        </a>
                    </li>
                    <li class="">
                        <a href="~/VENDOR/Home/DeleteproductList">
                            <i class="material-icons" style="color:white;">delete_forever</i>
                            <span style="color:white;">Delete Product List</span>
                        </a>
                    </li>
            
                    <li>
                        <a href="javascript:void(0);" class="menu-toggle">
                            <i class="material-icons">library_books</i>
                            <span>Report </span>
                        </a>
                        <ul class="ml-menu">
                           <li>
                                <a href="~/VENDOR/Home/Ecommerce_Report">E-commerce Report</a>
                            </li>
                            <li>
                                <a href="~/VENDOR/Home/Product_details">Product&nbsp;Details&nbsp;Report</a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
            <!-- #Menu -->
            <!-- Footer -->
            <div class="legal">
                <div class="copyright" style="margin-top:-4px;">
                    Copyright&nbsp;&nbsp;2019 - <span>@DateTime.Now.Year.ToString()</span>
                </div>
                <div class="copyright">
                    <a href="javascript:void(0);">@comnyname</a>.
                </div>
                <div class="navbar" style="position:inherit;margin-top:52px; height:33px;">

                </div>
            </div>
            <!-- #Footer -->
        </aside>

    </section>
    @RenderBody()

