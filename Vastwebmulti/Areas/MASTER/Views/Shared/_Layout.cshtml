@{
    var activetheme = "";
    try
    {
        List<Vastwebmulti.JsonData.Hlp_TC_Privacy> thems = new List<Vastwebmulti.JsonData.Hlp_TC_Privacy>();
        JSONReadWrite readWrite1 = new JSONReadWrite();
        thems = Newtonsoft.Json.JsonConvert.DeserializeObject<List<Vastwebmulti.JsonData.Hlp_TC_Privacy>>(readWrite.Read("master_theme.json", "~/JsonData/"));
        var themlist = thems.ToList();
        var them = themlist.Where(aa => aa.Id == 1).SingleOrDefault();

        if (them != null)
        {
            activetheme = them.Name;
        }
    }
    catch
    {
        activetheme = "";
    }

}

