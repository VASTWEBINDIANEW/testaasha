<head>
    @{
        var comnyname = "";
        var favimage = "";
        var col = "";
        var backgroundcol = "";
        var logoimage = "";
        VastwebmultiEntities DB1 = new VastwebmultiEntities();
        var companyname = DB1.Admin_details.AsNoTracking().ToList();
        var masteruser = User.Identity.GetUserId();
        VastwebmultiEntities db2 = new VastwebmultiEntities();
        var email = db2.Superstokist_details.SingleOrDefault(a => a.SSId == masteruser).Email;
        if (companyname.Count > 0)
        {
            comnyname = companyname.FirstOrDefault().Companyname;
            ViewBag.companyname = comnyname;
        }
        else
        {
            comnyname = "";
        }
        var faviconlogo = DB1.tblfavicons.AsNoTracking().Where(p => p.Role == "ADMIN").ToList();
        if (faviconlogo.Count() > 0)
        {
            if (faviconlogo.SingleOrDefault().Role == "ADMIN")
            {
                favimage = faviconlogo.SingleOrDefault().faviconimage;
            }
        }
        else
        {
            <link rel="icon" href="" type="image/x-icon" />
        }

        var color = DB1.changecolors.FirstOrDefault(a => a.Role == "ADMIN");

        if (color != null && color.ToString() != "")
        {
            col = color.multipaloutercolor;
        }
        else
        {
            col = "pink";
        }

        <!--Current Login Time-->
        var userid = User.Identity.GetUserId();
        var emailid = DB1.Users.AsNoTracking().Where(a => a.UserId == userid).FirstOrDefault().Email;
        var logo = DB1.tblHeaderLogoes.AsNoTracking().Where(p => p.Role == "ADMIN").ToList();
        if (logo.Count > 0)
        {
            if (logo.SingleOrDefault().Role == "ADMIN")
            {
                logoimage = logo.Where(p => p.Role == "ADMIN").SingleOrDefault().LogoImage;
            }
        }
        else
        {
            logoimage = "images/Default_Logo.png";
        }
        //Remain Master Balance
        var masterlivebal = DB1.Remain_superstokist_balance.Where(p => p.SuperStokistID == userid).SingleOrDefault().Remainamount;
        var chkmsg = DB1.lowbalancemsgs.Where(a => a.userid == userid).SingleOrDefault();
        var userfor = DB1.lowbalances.Where(a => a.Role == "master").FirstOrDefault();
        if (userfor != null && userfor.amount < masterlivebal)
        {
            if (chkmsg == null)
            {
                lowbalancemsg lb = new lowbalancemsg();
                lb.userid = userid;
                lb.message = "Message Sent";
                lb.status = false;
                DB1.lowbalancemsgs.Add(lb);
                DB1.SaveChanges();
            }
            else
            {
                chkmsg.status = false;
                DB1.SaveChanges();
            }

        }

        //purchase order request
        var ch = DB1.dlm_purchage.Count(a => a.frm == emailid && a.sts == "Pending");
        ViewBag.purchasereq = ch;
        //Notification message
        ViewBag.notificount = DB1.complaint_request.Count(a => a.userid == userid && a.sts == "Open");

        JSONReadWrite readWrite = new JSONReadWrite();
        dynamic people = Newtonsoft.Json.JsonConvert.DeserializeObject(readWrite.Read("LogoBackgroundColor.json", "~/Areas/ADMIN/Models/JsonData/"));
        string logoBgColor = people.ColorCode;


        var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Dealer").ToList();

        if (usernname.Count() > 0)
        {
            if (usernname.SingleOrDefault().Role == "Dealer")
            {
                favimage = usernname.SingleOrDefault().NickName;

            }
        }

    }
