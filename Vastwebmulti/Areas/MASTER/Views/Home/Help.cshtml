@{
    ViewBag.Title = "Help";
    Layout = "~/Areas/MASTER/Views/Shared/_Layout.cshtml";
}
<style>
    .table tbody tr td, .table tbody tr th
    {
        border-top:0px;
        border-bottom:0px;
    }
    .table-responsive{
        border:0px;
    }
    .second-design-master .bankinfo-master-second .col-md-6 table {
        border: 0px !important;
    }
    .table-responsive table tr {
        border-bottom: 1px solid #fff;
    }

    .master-four-design .second-bank-masterani table {
        margin: 0;
        width: 100%;
    }
        .master-four-design .second-bank-masterani table, .master-four-design .second-bank-masterani table tr, .master-four-design .second-bank-masterani table thead, .master-four-design .second-bank-masterani table tbody, .master-four-design .second-bank-masterani table td, .master-four-design .second-bank-masterani table th {
            background: transparent !important;
        }
    .master-four-design .second-bank-masterani .dealer-box-back-four {
        border-radius: 0px !important;
    }
    .master-four-design .second-bank-masterani .dealer-box-back-four table {
    border: 1px solid #aaa4a4;
}
    .master-four-design .second-bank-masterani .dealer-box-back-four {
        margin-top: 25px;
    }
    .master-four-design .second-bank-masterani:first-child {
        padding-left:0px;
    }
    .master-four-design .second-bank-masterani:last-child {
        padding-right: 0px;
    }

    @@media screen and (max-width:766px) {
        .padding-master {
            padding-left: 0px;
        }
        .bankinfo-master-second {
            padding-top: 15px;
        }
        .table-responsive table tr {
            width:100%;
            float:left;
            display: block;
        }

    }

</style>
<section class="content">
    <div class="container-fluid padding-master">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Help</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right" aria-hidden="true"></i></a></li>
                <li><a href="javascript:void(0);">Basic Setting 3&nbsp;&nbsp;<i class="fa fa-angle-right" aria-hidden="true"></i></a></li>
                <li><a href="javascript:void(0);">Help</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="bankinfo-master-second">
            <div class="row clearfix" style="margin:0px;">
                <div class="col-md-6 second-bank-masterani">
                    <div class="card">
                        <p class="dealer-box-back-four" style="font-size:21px;padding-top:2px;padding-bottom:7px;padding-left:15px;background-color:whitesmoke;font-weight:700;">
                            <img src="~/AdminDesign/images/headphone.svg" style="width:28px;" />&nbsp;Customer&nbsp;Care&nbsp;Support&nbsp;Timing
                        </p>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="">
                                    <div class="dealer-box-back-four" style="border:1px solid #dddddd;border-radius:5px;">
                                        @*<center><p style="margin-top:-24px;font-weight:bold;padding:0px 16px 1px 16px;background:linear-gradient(#ffffff 0%, #ffffff 100%);position:absolute;right:44%;border-radius:1px;border: 1px solid #ccc;">Day&nbsp;and&nbsp;Time</p></center>*@
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="table-responsive">
                                                    <table class="table for-table-border">
                                                        <thead>

                                                        </thead>
                                                        <tbody>
                                                            <tr>
                                                                <td>MONDAY</td>

                                                                <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>



                                                            </tr>
                                                            <tr>
                                                                <td>TUESDAY</td>

                                                                <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>

                                                            </tr>
                                                            <tr>
                                                                <td>WEDNESDAY</td>

                                                                <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>

                                                            </tr>

                                                            <tr>
                                                                <td>THURSDAY</td>

                                                                <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>

                                                            </tr>
                                                            <tr>
                                                                <td>FRIDAY</td>

                                                                <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>

                                                            </tr>
                                                            <tr>
                                                                <td>SATURDAY</td>

                                                                <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>

                                                            </tr>
                                                            <tr>
                                                                <td>SUNDAY</td>

                                                                <td><p style="font-weight:700;">9.00 AM  to  02.00 PM</p></td>

                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="col-md-6 second-bank-masterani">
                    <div class="card" style="margin-top:0px;">
                        <p class="dealer-box-back-four" style="font-size:21px;padding-top:5px;padding-bottom:7px;padding-left:15px;background-color:whitesmoke;font-weight:700;"><img src="~/AdminDesign/images/company.svg" style="height:24px;">&nbsp;Contact&nbsp;Information</p>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="">
                                    <div class="dealer-box-back-four" style="border:1px solid #dddddd;border-radius:5px;">
                                        @*<center><p style="margin-top:-24px;border: 1px solid #ccc;font-weight:bold;padding:0px 16px 1px 16px;background:linear-gradient(#ffffff 0%, #ffffff 100%);position:absolute;right:45%;border-radius:1px;">Company&nbsp;Info</p></center>*@
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="table-responsive">
                                                    <table class="table for-table-border">
                                                        <thead>

                                                        </thead>

                                                        <tbody>
                                                            <tr>
                                                                <td>Company Name</td>

                                                                <td>
                                                                    @if (ViewBag.admin.Companyname != null && ViewBag.admin.Companyname != "")
                                                                    {
                                                                        <p>@ViewBag.admin.Companyname</p>
                                                                    }
                                                                    else
                                                                    {
                                                                        <p>No Data Found !</p>
                                                                    }
                                                                </td>


                                                            </tr>
                                                            <tr>
                                                                <td>Otheride Person</td>

                                                                <td>
                                                                    @if (ViewBag.admin.Name != null && ViewBag.admin.Name != "")
                                                                    {
                                                                        <p>@ViewBag.admin.Name</p>
                                                                    }
                                                                    else
                                                                    {
                                                                        <p>No Data Found !</p>
                                                                    }
                                                                </td>

                                                            </tr>
                                                            <tr>
                                                                <td>Support Email-Id</td>

                                                                <td>
                                                                    @if (ViewBag.admin.email != null && ViewBag.admin.email != "")
                                                                    {
                                                                        <p>@ViewBag.admin.email</p>
                                                                    }
                                                                    else
                                                                    {
                                                                        <p>No Data Found !</p>
                                                                    }
                                                                </td>

                                                            </tr>

                                                            <tr>
                                                                <td>Custmor Care No</td>

                                                                <td>
                                                                    @if (ViewBag.admin.mobile != null && ViewBag.admin.mobile != "")
                                                                    {
                                                                        <p>@ViewBag.admin.mobile</p>
                                                                    }
                                                                    else
                                                                    {
                                                                        <p>No Data Found !</p>
                                                                    }
                                                                </td>

                                                            </tr>
                                                            <tr>
                                                                <td>Company Address</td>

                                                                <td>
                                                                    @if (ViewBag.admin.Address != null && ViewBag.admin.Address != "")
                                                                    {
                                                                        <p>@ViewBag.admin.Address</p>
                                                                    }
                                                                    else
                                                                    {
                                                                        <p>No Data Found !</p>
                                                                    }
                                                                </td>

                                                            </tr>
                                                            <tr>
                                                                <td>GST IN</td>

                                                                <td>
                                                                    @if (ViewBag.admin.Address != null && ViewBag.admin.Address != "")
                                                                    {
                                                                        <p>@ViewBag.admin.Address</p>
                                                                    }
                                                                    else
                                                                    {
                                                                        <p>No Data Found !</p>
                                                                    }
                                                                </td>

                                                            </tr>
                                                            <tr>
                                                                <td>Pancard</td>

                                                                <td>
                                                                    @if (ViewBag.admin.Address != null && ViewBag.admin.Address != "")
                                                                    {
                                                                        <p>@ViewBag.admin.Address</p>
                                                                    }
                                                                    else
                                                                    {
                                                                        <p>No Data Found !</p>
                                                                    }
                                                                </td>

                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</section>

<script>
    $(document).ready(function () {
        $(".second-design-master .second-bank-masterani").addClass("second-bank-masteranisow")
    });
</script>