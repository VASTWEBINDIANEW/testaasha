<script type="text/javascript">
        var val1 = "";
        function animation(userid) {
                     document.getElementById("Pan1").readOnly = false;
                      document.getElementById("Adhaar1").readOnly = false;
                      document.getElementById("Name1").readOnly = false;
                      document.getElementById("Firm1").readOnly = false;
                      document.getElementById("Address1").readOnly = false;
            var url = '@Url.Action("DealerSearch","Home")';
            $.ajax({
                url: url,
                data: { userid: userid },
                cache: false,
                type: "POST",
                success: function (data) {

                    $("#Name1").val(data[0].DealerName);
                    $("#Dealerid").val(userid);
                    $("#Firm1").val(data[0].FarmName);
                    $("#Address1").val(data[0].Address);
                    $("#Pincode1").val(data[0].Pincode);
                    $("#Pan1").val(data[0].pancard);
                    $("#Adhaar1").val(data[0].adharcard);
                    $("#Gst1").val(data[0].gst);
                    //$("#Slab1").val(data[0].slab_name);
                    $("#State1").val(data[0].State);

               if (data[0].pancardPath != null && data[0].PSAStatus=="Y")
                {
                 document.getElementById("Pan1").readOnly = true;

                }
                if (data[0].aadharcardPath != null && data[0].AadhaarStatus == "Y") {
                  document.getElementById("Adhaar1").readOnly = true;
                }
                if (data[0].pancardPath != null && data[0].PSAStatus == "Y" && data[0].aadharcardPath != null && data[0].AadhaarStatus == "Y") {
                    document.getElementById("Pan1").readOnly = true;
                      document.getElementById("Adhaar1").readOnly = true;
                      document.getElementById("Name1").readOnly = true;
                      document.getElementById("Firm1").readOnly = true;
                      document.getElementById("Address1").readOnly = true;
                   

                }

                    GetDistrict1(data[0].State);
                    var objSelect1 = document.getElementById("District1");
                    binddist(data[0].State, data[0].District, objSelect1);
                      $('#lblberror').text('');
                    $('#defaultModal1').modal('show');
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                }
            });

        }
      function binddist(staid, dist, objSelect1) {
          var url = '@Url.Action("DistrictList","Home")';
            $.ajax({
                url: url,
                data: { Id: staid },
                cache: false,
                type: "POST",
                success: function (data) {
                    var markup = "<option value='0'>Select District</option>";
                    for (var x = 0; x < data.length; x++) {
                        markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                    }
                    $("#District").html(markup).show();
                    setSelectedValue(objSelect1, dist);
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                }
            });
        }
    function setSelectedValue(selectObj, valueToSet) {

            for (var i = 0; i < selectObj.options.length; i++) {
                if (selectObj.options[i].value == valueToSet) {
                    //alert(selectObj.options[i].value);
                    selectObj.options[i].selected = true;
                    return;
                }
            }
        }
    function GetDistrict1(_stateId) {
        var procemessage = "<option value='0'> Please wait...</option>";
        $("#District1").html(procemessage).show();
        var url = '@Url.Action("DistrictList","Home")'
        $.ajax({
            url: url,
            data: { Id: _stateId },
            cache: false,
            type: "POST",
            success: function (data) {
                $("#District1").html("");
                for (var x = 0; x < data.length; x++) {
                    //alert(markup)
                    $("#District1").append($('<option></option>').val(data[x].Value).html(data[x].Text));
                }

            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
    }
</script>
