@using System.Net.Mime
@using Vastwebmulti.Models
@model Vastwebmulti.Areas.MASTER.Models.DealerModel
@{
    ViewBag.Title = "Attributes";
    Layout = "~/Areas/MASTER/Views/Shared/_Layout.cshtml";

    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Dealer").ToList();
    var favimage = "";
    if (usernname.Count() > 0)
    {
        if (usernname.SingleOrDefault().Role == "Dealer")
        {
            favimage = usernname.SingleOrDefault().NickName;


        }
    }
}
<style>
    .btn-group, .btn-group-vertical {
        box-shadow: none;
    }

    .table-responsivehide #example_wrapper .dt-buttons, .table-responsivehide #example_wrapper #example_filter {
        display: none;
    }

    .tbmtr p {
        margin-bottom: 0px;
    }

    .ttyu .btn-group.bootstrap-select.form-control {
        padding-left: 0px;
    }

    .ttyu .btn.dropdown-toggle.btn-default {
        padding-left: 9px;
    }

    .jkiop .text-danger.field-validation-error {
        position: absolute;
        bottom: 8px;
        left: 17px;
        display: block;
        font-size: 11px;
    }

    .form-control-label {
        text-align: left;
    }

    @@media screen and (max-width:766px) {
        .masterindex-pagefull .card {
            width: 100%;
            float: left;
            margin-bottom: 15px !important;
        }

        .masterindex-pagefull {
            width: 100%;
            float: left;
            padding-left: 0;
        }

            .masterindex-pagefull .table-responsive table {
                border-left: 1px solid #aaa4a4;
            }
    }
</style>
<section class="content">
    <div class="container-fluid masterindex-pagefull full-master-secondanimation">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Manage Password</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right" aria-hidden="true"></i></a></li>

                <li><a href="javascript:void(0);">Manage Password</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card" style="margin-bottom: 0px;">
                    <div class="">
                        <div class="col-md-7 dealer-none-fourclass" style="padding: 0px;">
                            <div class="form-group">
                                <ol class="breadcrumb breadcrumb-col-blue-grey" style="padding: 0px;">
                                    <li class="active" style="color:#555; font-size:21px;font-weight:700;">All&nbsp;@favimage&nbsp;Details&nbsp;</li>

                                </ol>
                            </div>
                        </div>
                        <div class="col-md-4" style="float: right;text-align: right;padding: 0px;">
                            <button type="button" class="btn bg-grey waves-effect adduser-master-second" style=" margin-right: 2px;background: transparent;border: 1px solid #b1a6a638 !important;" data-toggle="modal" data-target="#defaultModal">
                                <i class="fa fa-plus" style="top:-1px;font-size:16px;color:black;"></i>
                                <span style="top:-2px;color:black;">Add&nbsp;New&nbsp;@favimage</span>
                            </button>
                            <input type="button" id="btnExportA" value="Export" style="margin-left:0px;font-size: 11px;padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background-color:#b1a6a638;background-image: url(../../images/reportimage/xls.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">
                            <input type="button" id="btnPDFA" value="PDF" style="margin-left:2px;font-size: 11px;padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background-color:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">
                        </div>

                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">


                    <div class="body" style="padding:0px;">
                        <div class="table-responsive table-responsivehide table-second-master-scroll" style="position:inherit;overflow: hidden;">
                            <table id="example" class="table table-bordered example-second third-design-table" style="background: #f5f5f5;">
                                <thead style="background-color:whitesmoke;">
                                    <tr style="color: black;">
                                        <th>@favimage&nbsp;Firm</th>
                                        <th>@favimage&nbsp;Name</th>
                                        <th>Contact&nbsp;Information</th>
                                        <th>Remaining&nbsp;Blance</th>

                                        <th>Full&nbsp;Address</th>
                                        <th>Pan&nbsp;/&nbsp;GST&nbsp;Info</th>
                                        <th style="width: 140px;">Email&nbsp;/&nbsp;Action</th>

                                    </tr>
                                </thead>
                                <tbody class="tbmtr">
                                    @if (Model.Select_Dealer_total_Result != null)
                                    {
                                        foreach (var item in Model.Select_Dealer_total_Result)
                                        {
                                            <tr style="background:no-repeat;">
                                                <td>
                                                    <p>
                                                        @if (item.Status == "Y")
                                                        {

                                                            <a href="#" style="margin-right: 4px;">
                                                                <img style="border-radius:50%;background-color:green;width: 18px;height: 18px;padding: 3px;" src="../../ashok-images/correct.svg">
                                                            </a>

                                                        }
                                                        else
                                                        {

                                                            <a href="#" style="margin-right: 4px;">
                                                                <img style="border-radius:50%;background-color:red;width: 18px;height: 18px;border-radius: 50%;padding: 2px;" src="../../ashok-images/closes.svg">
                                                            </a>


                                                        }<span>@item.FarmName</span>
                                                    </p>
                                                    <p style="font-size: 10px;">@item.JoinDate</p>
                                                </td>
                                                <td><span>@item.DealerName</span><p style="font-size: 10px;">@item.adharcard</p></td>
                                                <td>
                                                    <p><span>@item.Mobile</span></p>
                                                    <p style="font-size: 10px;">@item.Email</p>
                                                </td>
                                                <td>
                                                    <p><span style="margin-right: 6px;"><span style="border: 1px solid;border-radius: 50%;padding: 2px 3px;font-size: 12px;line-height: 10px;text-align: center;display: inline-block;">D</span>&nbsp;@item.remaindlm</span><span><span style="border: 1px solid;border-radius: 50%;padding: 2px 3px;font-size: 12px;line-height: 10px;text-align: center;display: inline-block;">R</span>&nbsp;@item.remainrem</span></p>

                                                </td>

                                                <td>
                                                    <p><span>@item.Dist_Desc</span>,&nbsp;<span>@item.State_name</span>&nbsp;-&nbsp;<span>@item.Pincode</span></p>
                                                    <p style="font-size: 10px;">@item.Address</p>
                                                </td>
                                                <td>
                                                    <p><span>@item.pancard</span></p>
                                                    <p style="font-size: 10px;">@item.gst</p>

                                                </td>

                                                <td>
                                                    <p style="float: left;margin-right: 4px;">
                                                        @if (item.Emailconfirmed == true)
                                                        {
                                                            <a href="#" style="border: 1px solid #b1a6a638;float: left;padding: 2px;background: transparent;">
                                                                <span style="padding: 0px 3px;">Verified</span>
                                                            </a>

                                                        }
                                                        else
                                                        {
                                                            <a href="#" style="border: 1px solid #b1a6a638;float: left;padding: 2px;background:#ff9e00;">
                                                                <span style="color: #fff;">Pending</span>
                                                            </a>

                                                        }
                                                </p>
                                                <p style="float: left;">
                                                    <button class="btn btn default" id="but" onclick="animation('@item.DealerId')" style="background-color:transparent;height: auto;padding: 3px 10px; border:none;border: 1px solid #b1a6a638;padding:" title="Edit Information">
                                                        Edit
                                                    </button>
                                                </p>

                                            </td>

                                            @*<td>
                                                <div class="row">

                                                    <div class="col-xs-4">
                                                    @if (item.Emailconfirmed == false)
                                                    {
                                                        <button class="btn btn default" id="but" onclick="sendotpDealer('@item.DealerId')" style="background-color:transparent; border:none;border:1px solid #c7c2c2;margin-top:4px; padding:1px 6px 1px 6px;margin-left:-16px;" title="Delete Information">
                                                            Delete
                                                        </button>
                                                         }

                                                    </div>
                                                    <div class="col-xs-4">
                                                        @if (item.Emailconfirmed == false)
                                                        {
                                                            <a class="btn btn default" href="@Url.Action("ResendDealerEmail", "Home", new { email = item.Email })" title="Resend Email " style="border:1px solid #c7c2c2; padding:1px 4px 1px 4px;margin-top:4px;margin-left:-17px;">
                                                                Resend
                                                            </a>
                                                        }
                                                    </div>
                                                </div>
                                            </td>*@

                                        </tr>
                                    }
                                }

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
<!--Add New   modal-->
