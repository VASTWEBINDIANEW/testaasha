                                    <td>@i.Amount</td>
                                    <td>@i.Rem_pre</td>
                                    <td>@i.Rem_tds</td>
                                    <td>@i.Rem_comm</td>
                                    <td>@i.rem_post</td>
                                    <td>@i.Rem_final</td>
                                    <td>@i.master_pre</td>
                                    <td>@i.master_comm</td>
                                    <td>@i.master_tds</td>
                                    <td>@i.master_post</td>
