@using Vastwebmulti.Models;
@model IEnumerable<Vastwebmulti.Areas.ADMIN.Models.RetailerCreationTokenVM>
@{
    ViewBag.Title = "SignupTokens";
    Layout = "~/Areas/MASTER/Views/Shared/_Layout.cshtml";
    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Dealer").ToList();
    var favimage = "";
    if (usernname.Count() > 0)
    {
        if (usernname.SingleOrDefault().Role == "Dealer")
        {
            favimage = usernname.SingleOrDefault().NickName;


        }
    }
    var usernname1 = DB1.Usernicknames.Where(aa => aa.Role == "master").ToList();
    var favimage1 = "";
    if (usernname1.Count() > 0)
    {
        if (usernname1.SingleOrDefault().Role == "master")
        {
            favimage1 = usernname1.SingleOrDefault().NickName;


        }
    }

}
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }

    .form-inline .bootstrap-select.btn-group, .form-horizontal .bootstrap-select.btn-group, .form-group .bootstrap-select.btn-group {
        height: 20px;
    }

    .select-drop-up button {
        height: 30px !important;
    }

    .tmw-joing-tokens ul.jo-to-po-ul li {
        width: 33%;
        text-align: center;
        height: 30px;
    }

        .tmw-joing-tokens ul.jo-to-po-ul li span {
            padding: 5px 0px;
            display: block;
        }

        .tmw-joing-tokens ul.jo-to-po-ul li button {
            background: transparent;
        }

    .tmw-joing-tokens ul.jo-to-po-ul {
        width: 100%;
        float: left;
        border: 1px solid #ccc;
    }

    .small-s-change-newclass button {
        padding: 0 !important;
        height: 29px !important;
    }

    @@media screen and (max-width:992px) {
        .small-s-change span, .small-s-change button, .small-s-change a {
            display: inline-block;
            width: 49%;
            margin: 0px !important;
            margin-bottom: 15px !important;
            text-align: left;
            float: left;
            margin-right: 7px !important;
        }

            .small-s-change button span {
                width: auto;
            }

        .small-s-change {
            padding: 0px !important;
            margin: 0px !important;
        }

        .select-dropdown-up-down form {
            width: 100%;
            float: left;
            margin-bottom: 20px;
        }
    }

    @@media screen and (max-width:767px) {
        .small-s-change span, .small-s-change button, .small-s-change a {
            display: inline-block;
            width: 100%;
            margin: 0px !important;
            margin-bottom: 15px !important;
            text-align: left;
        }

        .small-s-change {
            padding: 0px !important;
            margin: 0px !important;
        }

            .small-s-change a span, .small-s-change button span {
                width: auto;
                margin-right: 5px !important;
            }
    }
</style>

