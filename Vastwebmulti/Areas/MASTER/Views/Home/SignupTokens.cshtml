<script>
    $(function () {
        $("button.shownextrow").click(function () {
            $(this).closest("tr").next().show();
            $(this).closest("tr").hide();
        });
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",
        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }


        var message = '@ViewData["success"]';
        var error = '@ViewData["error"]';
        if (message != "") {
                swal("Good job!", message, "success");
        }
        if (error != "") {
            swal("Ooops!", error, "error");
        }
    });


</script>


<script>
    function onPluseMinus(v) {
        //alert(v);
        event.stopPropagation();
        var digiCount = parseInt($('#tokenCount').val());
        if (v >= 0) {
            $('#tokenCount').val(digiCount + v);
            $('#showPhysicalCount').html(digiCount + v);
        } else {
            $('#tokenCount').val(digiCount - 1);
            $('#showPhysicalCount').html(digiCount - 1);
        }
        if (parseInt($('#tokenCount').val()) >= 1) {
            $('#btnChildMinus').prop('disabled', false);
        }
        if (parseInt($('#tokenCount').val()) == 0) {
            $('#btnChildMinus').prop('disabled', true);
        }
    }
</script>



<script>

    $(function () {
        $.ajax({
            url: '@Url.Action("Remain_dealer_token_report", "Home")',
            method: "Post",
            cache: false,
            dataType: 'json',
            async: false,
            success: function (data) {
                var mdtblHtml = "";
                var i = 0;
                $.each(data, function (a, b) {

                    mdtblHtml += "<tr><td style='font-size:12px;'>" + b.FarmName + "</td>";

                    mdtblHtml += "<td style='font-size:12px;'>" + b.DealerName + "</td>";

                    mdtblHtml += "<td style='font-size:12px;'>" + b.RemainTokenPost + "</td></tr >";


                    i++;
                });
                $('#kkkk > tbody').html(mdtblHtml);
            }
        });
    });

</script>

<script>
    function converttoDate(str) {
        var date = new Date(str),
            mnth = ("0" + (date.getMonth() + 1)).slice(-2),
            day = ("0" + date.getDate()).slice(-2),
            Hrs = (date.getHours()),
            mnts = (date.getMinutes()),
            sec = (date.getSeconds());
        return dd = [day, mnth, date.getFullYear()].join("-") + " " + [Hrs + ":" + mnts + ":" + sec];
    }

    $('#MdbtnSubmit').click(function () {


        $.ajax({
            url: '@Url.Action("addJoiningToken_dlm", "Home")',
            type: 'POST',
            data: { ddlDealer: $("#ddlDealer").val(),tokenCount: $("#tokenCount2").val() },
            cache: false,
            success: function (response) {
                if (response == "Insufficient balance." || response == "Set the Dealer token Value." || response == "Token Can Not Be Negative") {
                    $("#Lblmsg2").css("color", 'red').text(response);
                    //$("#defaultModal").delay(1500).hide(0, function () {
                    //    $("#Lblmsg2").text('');
                    //    $("#defaultModal").modal('hide');
                    //});
                }
                else {
                    $("#Lblmsg2").css("color", 'green').text("Credited Successfully.");
                    $("#defaultModal").delay(1000).hide(0, function () {
                        $("#Lblmsg2").text('');
                        $("#defaultModal").modal('hide');
                    });
                }
                location.reload();

            }
        });



    })
</script>

