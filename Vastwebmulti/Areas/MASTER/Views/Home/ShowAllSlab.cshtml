        if (chh == "INDO NEPAL")
        {
            chh = "NEPAL";
        }
        $('#' + chh+'').show();
    });
   
    function funedit() {
        var chh1 = '@ViewData["type"]';
        if (chh1 == "INDO NEPAL") {
            chh1 = "NEPAL";
        }
        $('#' + chh1 + '_show').hide();
        $('#' + chh1 + '_edit').show();
        $('#' + chh1 + '_Save').show();
    }

    var succ = '@ViewData["Defaultslab"]';
    if (succ != null && succ != "")
    {
        swal("Oops!", succ, "error");
    }
