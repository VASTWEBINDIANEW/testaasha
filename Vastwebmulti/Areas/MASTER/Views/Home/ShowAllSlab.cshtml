                        <div id="PrePaid" class="table-responsive " style="position:inherit; display:none; margin-top: -40px;">
                            @using (Html.BeginForm("EditAllSlab", "Home", FormMethod.Post, new { id = "EditForm" }))
                            {
                                <div id="PrePaid_Save" style="padding-bottom: 10px; display:none;">
                                    <input type="submit" value="Save" class="btn bg-grey waves-effect" style="margin-top:6px;" />
                                </div>

                                <table class="table table-bordered table-striped table-hover dataTable js-exportable" style="width:100%;">
                                    <thead class="navbar" style="color:white;position:inherit;">
                                        <tr>
                                            <th style="padding-left:0px; text-align:center">Operator&nbsp;Name</th>
                                            <th style="padding-left:0px; text-align:center">Default&nbsp;Commission</th>
                                            <th style="padding-left:0px;text-align:center">Commission</th>
                                        </tr>
                                    </thead>
                                    <tbody id="PrePaid_show">
                                        @foreach (var item in Model.Slab_prepaid)
                                        {
                                            <tr>
                                                <td>@Html.DisplayFor(modelItem => item.OperatorName)</td>
                                                <td>@Html.DisplayFor(modelItem => item.DefaultComm)</td>
                                                <td> @Html.DisplayFor(modelItem => item.commission)</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tbody id="PrePaid_edit" style="display:none;">
                                        @{
                                            int i = 0;
                                            foreach (var item in Model.Slab_prepaid)
                                            {
                                                @Html.HiddenFor(o => o.Slab_prepaid[i].idno)
                                                @Html.HiddenFor(o => o.Slab_prepaid[i].slabfor)
                                                @Html.HiddenFor(o => o.Slab_prepaid[i].slabname)
                                                @Html.HiddenFor(o => o.Slab_prepaid[i].DefaultComm)
                                                @Html.Hidden("ID", "SLABPrePaid")
                                                <tr>
                                                    <td>@Html.DisplayFor(o => o.Slab_prepaid[i].OperatorName)  </td>
                                                    <td>@Html.DisplayFor(o => o.Slab_prepaid[i].DefaultComm)</td>
                                                    <td>
                                                        @Html.EditorFor(o => o.Slab_prepaid[i].commission)
                                                        @Html.ValidationMessageFor(o => o.Slab_prepaid[i].commission)
                                                    </td>
                                                </tr>
                                                i++;
                                            }
                                        }
                                    </tbody>
                                </table>

                                            }
