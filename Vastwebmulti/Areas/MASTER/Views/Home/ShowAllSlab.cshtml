@model  Vastwebmulti.Areas.ADMIN.Models.Show_all_slab

@{
    ViewBag.Title = "ShowAllSlab";
    Layout = "~/Areas/MASTER/Views/Shared/_Layout.cshtml";
}
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card" style="margin-top:2px;">
                    @using (Html.BeginForm("ShowAllSlab", "Home", FormMethod.Post, new { id = "CreateForm" }))
                    {
                        <div class="">
                            <div class="col-md-4">
                                <div class="form-group" style="margin-top: 2px;">
                                    <ol class="breadcrumb breadcrumb-col-blue-grey" style="margin-left:6px;">
                                        <li><a href="javascript:void(0);" style="font-weight:100; font-size:15px;">Slab Setting</a></li>
                                        <li class="active" style="color:#607d8b; font-size:15px;font-weight:700;">Show All Slab List</li>
                                    </ol>
                                </div>
                         
                            </div>
                       
                            <div class="col-md-3">
                                <div class="form-group">
                                    <div class="" style="padding-top:3px;border:1px solid #dddddd;margin-top:3px;">
                                        @Html.DropDownList("Operatortype", ViewBag.Operatortype as SelectList, "Select Operator Type", new { id = "Operatortype", @class = "selectpicker form-control", data_live_search = "true", @required = "required", @style = "padding-left:0px;" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <div class="" style="padding-top:3px;border:1px solid #dddddd;margin-top:3px;">
                                        @Html.DropDownList("slabname", ViewData["distributorslab"] as SelectList, "Select Slab Name", new { id = "slabname", @class = "form-control", data_live_search = "true", @style = "padding-left:0px;" })
                                    </div>
                             
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group" style="margin-top:3px;">
                                    <button type="submit" class="btn bg-blue-grey waves-effect" style="height:37px;">
                                        <i class="material-icons" style="top:2px;">search</i>
                                        <span style="top:-4px;">Search</span>
                                    </button>
                                    <button type="button" value="EDIT" class="btn bg-blue-grey waves-effect" onclick="funedit()" style="height:37px; margin-top:1px;">
                                        <i class="fa fa-pencil-square-o" style="top:2px;"></i>
                                        <span style="top:-3px;">Edit</span>
                                    </button>
                                </div>
                            </div>

                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-41px;">
                <div class="card">
                    <div class="">
                        <h2 style="color:black; font-size:16px;padding-top:9px; padding-left:22px;">
                
                        </h2>
                    </div>
