@using Vastwebmulti.Models;
@model Vastwebmulti.Models.User
@{
    ViewBag.Title = "Profile";
    Layout = "~/Areas/MASTER/Views/Shared/_Layout.cshtml";
    var passcodeset = ViewBag.passcodesetings;
    var offpasscode = passcodeset == "OFF" ? "activeupto" : "";
    var perpasscode = passcodeset == "PERDAY" ? "activeupto" : "";
    var Weakpasscode = passcodeset == "WEAKS" ? "activeupto" : "";
    var monthpasscode = passcodeset == "MONTHS" ? "activeupto" : "";

    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var usernname = DB1.Usernicknames.Where(aa => aa.Role == "master").ToList();
    var favimage = "";
    if (usernname.Count() > 0)
    {
        if (usernname.SingleOrDefault().Role == "master")
        {
            favimage = usernname.SingleOrDefault().NickName;

        }
    }
}


<style>
    .ribbon {
        position: absolute;
        right: 16px;
        top: 0px;
        z-index: 1;
        overflow: hidden;
        width: 75px;
        height: 75px;
    }

        .ribbon span {
            font-size: 11px;
            color: #fff;
            text-align: center;
            font-weight: bold;
            line-height: 20px;
            transform: rotate(45deg);
            -webkit-transform: rotate(45deg);
            width: 100px;
            box-shadow: 0 3px 10px -5px rgba(0, 0, 0, 1);
            position: absolute;
            top: 19px;
            right: -21px;
            background: linear-gradient(#c5c5c5 0%, #868686 100%);
        }

    .list-group-item {
        border: none;
    }

    .field-validation-error {
        color: red;
    }

    .required:after {
        color: red;
        content: " *";
    }

    .ltgl .list-group-item {
        background: transparent;
    }

    .ltgl {
        border: 1px solid #ddd;
        border-bottom: 0px;
    }

        .ltgl li {
            border-bottom: 1px solid #ddd;
        }

    .edtbdy .col-md-3 {
        text-align: left !important;
    }

    .edtbdy .col-md-3, .edtbdy .col-md-9 {
        margin-bottom: 0px !important;
    }

    .edtbdy .form-group {
        margin-bottom: 0px;
    }

    .edtbdy .modal-footer {
        border: 0px;
        padding: 0px;
    }

    .edtbdy .row {
        margin-bottom: 10px;
    }

    .edtbdy .col-md-9 .form-control {
        width: 100% !important;
    }

    .edtbdy .col-md-9 select {
        -webkit-appearance: none;
        background: url('~/AdminDesign/images/multimedia.svg')no-repeat;
        background-position-y: 50%;
        background-color: #fff;
    }
</style>
<style>



    p.uptotransction.activeupto::after {
        content: "";
        float: left;
        width: 10px;
        height: 10px;
        background: url('../../ashok-images/correct.svg')no-repeat;
        background-color: green;
        background-size: 83%;
        background-position: center;
        position: relative;
        left: 1px;
        top: 3.4px;
    }

    .retailer-profile-secondclass button p {
        font-size: 9px;
        left: 22px;
        bottom: -9px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .retailer-profile-secondclass p.uptotransction {
        float: left;
        background: #f9f9cb;
        color: #555;
        padding: 0 1px;
        margin-left: 8px;
        margin-top: 3px;
        margin-bottom: 0;
        width: 33%;
    }

    .retailer-profile-secondclass span {
        text-transform: uppercase;
    }

    .retailer-profile-secondclass strong {
        text-align: center;
        display: flex;
        width: 100%;
        justify-content: center;
    }

        .retailer-profile-secondclass strong span {
            font-size: 12px;
        }

    .master-four-design .card.dealer-box-back-four .body.jonbdy {
        background: transparent !important;
    }

    .master-four-design #EditaddressModal .modal-body {
        background: #fafbfe !important;
    }

    .retailer-profile-secondclass button strong p {
        padding: 8px 6px !important;
    }

        .retailer-profile-secondclass button strong p.uptotransction.activeupto span::before {
            content: "";
            float: left;
            width: 20px;
            height: 20px;
            background: url('../../ashok-images/correct.svg')no-repeat;
            background-color: green;
            background-size: 60%;
            background-position: center;
            position: relative;
            left: -5px;
            top: 0px;
            border-radius: 50%;
            float: none;
            display: inline-block;
            vertical-align: middle;
        }

    p.uptotransction.activeupto::after {
        display: none;
    }

    .master-four-design #EditnameandpancardModal .modal-content .tftg .row.clearfix {
        display: flex;
    }

    .master-four-design #EditnameandpancardModal .modal-content {
        background: #fafbfe !important;
    }

    @@media screen and (max-width:991px) {
        .col-md-8, .col-md-4 {
            width: 100%;
            float: left;
        }
    }

    @@media screen and (max-width:766px) {
        .joining-master p {
            width: 100% !important;
            text-align: left !important;
            margin-bottom: 0;
            border-left: 1px solid #ddd !important;
            border-bottom: 0 !important;
        }

        .joining-master p {
            border-bottom: 1px solid #ddd !important;
        }

        .retailer-profile-secondclass strong {
            display: block;
        }

        .retailer-profile-secondclass button strong p {
            width: 100% !important;
            margin: 0 !important;
            margin-bottom: 15px !important;
        }
    }
</style>


<section class="content" style="">
