                            Joining Date
                            <a style="float:right;cursor:pointer;" onclick="editemobileandpancard('@ViewBag.MD_Details.SSId')"><i class="fa fa-pencil-square-o" style="font-size: 22px;margin-top: 0px;border: 1px solid #bdbdbd;background: #fff;padding: 3px 6px;text-transform: capitalize;">Edit</i></a>
                        </h1>
                        <p style="text-transform:uppercase;margin-top:-9px;font-size: 11px;">@ViewBag.MD_Details.JoinDate</p>

                    </div>
                    <div class="body jonbdy" style="margin-top:0px;background: #f5f5f5;float: left;">
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Name</p>
                        <p style="text-transform:uppercase;">@ViewBag.MD_Details.SuperstokistName</p>
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Email-ID</p>
                        <p style="text-transform:uppercase;">@ViewBag.MD_Details.Email</p>
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Mobile</p>
                        <p style="text-transform:uppercase;">@ViewBag.MD_Details.Mobile</p>
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Aadharcard</p>
                        @if (ViewBag.MD_Details.adharcard != null && ViewBag.MD_Details.adharcard != "")
                        {
                            var input = ViewBag.MD_Details.adharcard;
                            string firstPart = input.Substring(0, 8);
                            int len = input.Length;
                            string middlePart = new String('X', 8);
                            string lastPart = input.Substring(len - 4, 4);
                            var aadharcard = middlePart + lastPart;
                            <p style="text-transform:uppercase;">@aadharcard</p>
                        }
                        else
                        {
                            <p style="text-transform:uppercase;">Data Not Found !</p>
                        }
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Pancard</p>
                        @if (ViewBag.MD_Details.pancard != null && ViewBag.MD_Details.pancard != "")
                        {
                            <p style="text-transform:uppercase;">@ViewBag.MD_Details.pancard</p>
                        }
                        else
                        {
                            <p style="text-transform:uppercase;">Data Not Found !</p>
                        }
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">GST No</p>
                        @if (ViewBag.MD_Details.gst != null && ViewBag.MD_Details.gst != "")
                        {
                            <p style="text-transform:uppercase;">@ViewBag.MD_Details.gst</p>
                        }
                        else
                        {
                            <p style="text-transform:uppercase;">Data Not Found !</p>
                        }
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Position</p>
                        @if (ViewBag.MD_Details.Position != null && ViewBag.MD_Details.Position != "")
                        {
                            <p style="text-transform:uppercase;">@ViewBag.MD_Details.Position</p>
                        }
                        else
                        {
                            <p style="text-transform:uppercase;">Data Not Found !</p>
                        }

                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Businees Type</p>
                        @if (ViewBag.MD_Details.BusinessType != null && ViewBag.MD_Details.BusinessType != "")
                        {
                            <p style="text-transform:uppercase;">@ViewBag.MD_Details.BusinessType</p>
                        }
                        else
                        {
                            <p style="text-transform:uppercase;">Data Not Found !</p>
                        }
                    </div>

