@model List<Vastwebmulti.Models.money_transfer_report_paging_Result>
@{
    Layout = null;
}

@if (Model != null)
{
    foreach (var item in Model)
    {
        var color = "";
        var fontsize = "";
        var rchtype = "";
        var rchtypeicon = "";
        var dmtytpe = "";
        var icon = "";
        var backgraound = "";

        if (item.status.Contains("REFUND") || item.status.Contains("REFUND AGAINST"))
        {
            color = "#673AB7";
            fontsize = "12px;";
            icon = "../../ashok-images/undo.svg";
        }
        if (item.status.ToUpper().Contains("PENDING"))
        {
            double difftime = DateTime.Now.Subtract(item.trans_time.Value).TotalMinutes;
            if (difftime < 2)
            {
                backgraound = "#ffbf00";
            }
            else
            {
                backgraound = "#fff8d1";
            }
            color = "#FF9800";
            icon = "../../ashok-images/clkk.png";
        }
        if (item.status.ToUpper().Contains("SUCCESS"))
        {
            color = "green";
            icon = "../../ashok-images/correct.svg";
        }
        if (item.status == "FAILED")
        {
            color = "red";
            icon = "../../ashok-images/closes.svg";
        }
        if (item.trans_from == "ONLINE")
        {
            rchtype = "WEB";
            rchtypeicon = "../../images/wwwBlack.svg";
        }
        if (item.trans_from == "API")
        {
            rchtype = "WEB";
            rchtypeicon = "../../images/wwwBlack.svg";

        }
        if (item.trans_from == "Apps")
        {
            rchtype = "APP";
            rchtypeicon = "../../images/android-logo.svg";
        }
        if (item.status.ToLower().Contains("Success To Failed"))
        {
            color = "green";
            fontsize = "12px;";
        }
        if (item.status.ToLower().Contains("Failed To Success"))
        {
            color = "red";
            fontsize = "12px;";
        }
        if (item.DmtType == "DMT1")
        {
            dmtytpe = "➊";
        }
        if (item.DmtType == "DMT2")
        {
            dmtytpe = "➋";
        }
    <tr style="font-size: 12px;text-transform: capitalize;background-color:@backgraound;">
        <td style="color:@color;font-size:@fontsize;">
            <img style="height: 20px;width: 18px;margin:5px;max-width: 100%;padding: 0; border-radius:50%; background-color:@color" src="@icon" />

            <span style="color:black;font-weight;">@item.frm_name</span>

        </td>
        <td>
            @if (item.Trans_type == "IMPS")
            {
                <i><img style="height: 20px;width: 18px;margin-right:3px;max-width: 100%;padding: 0; border-radius:50%;" src="@rchtypeicon" /></i>
                <span>IMPS</span>

            }
            else if (item.Trans_type == "NEFT")
            {
                <i><img style="height: 20px;width: 18px;margin-right:3px;max-width: 100%;padding: 0; border-radius:50%;" src="@rchtypeicon" /></i>
                <span>NEFT</span>

            }
            else
            {
                <i><img style="height: 20px;width: 18px;margin-right:3px;max-width: 100%;padding: 0; border-radius:50%;" src="@rchtypeicon" /></i>
                <span>Verify</span>

            }
        </td>
        <td>@item.accountno</td>
        <td>@item.senderno</td>

        <td>@item.totalamount</td>

        <td>
            @{
                decimal amount = 0;
                decimal customerfee = 0;
                decimal total = 0;
                decimal debit = 0;
                decimal remcomm = 0;
                if (item.Trans_type.Contains("IMPS_VERIFY"))
                {
                    amount = Convert.ToDecimal(item.amount);
                    customerfee = Convert.ToDecimal(item.rem_comm);
                    customerfee = customerfee - amount;
                    total = amount + customerfee;
                    debit = Convert.ToDecimal(item.rem_comm);
                }
                else
                {
                    amount = Convert.ToDecimal(item.amount);
                    customerfee = Convert.ToDecimal(item.customer_fee);
                    total = amount + customerfee;
                    remcomm = Convert.ToDecimal(item.rem_comm);
                    debit = amount + remcomm;

                }
            }
            @debit
        </td>


        <td>@item.md_income</td>
        <td>@item.md_remain</td>
        <td>@item.bank_trans_id</td>
        <td>
            <span style="font-size:11px;">@String.Format("{0:dd-MMM HH:mm:ss}", item.trans_time)</span>

            
        </td>
        <td class="nrch"><span class="fftt" data-toggle="modal" data-target="#defaultModal222" onclick="mdActionBtn('@item.idno')" style="padding-left:15px;"><i class="fa fa-angle-double-right" aria-hidden="true"></i></span></td>

        @*<td>
            @if ((item.status.Contains("REFUND") || item.status.Contains("REFUND AGAINST")) && item.Trans_type.Contains("IMPS_VERIFY"))
            {

                <p></p>
            }
            else
            {
                <p>@item.md_gst&nbsp;│&nbsp;@item.md_comm_tds</p>
            }

        </td>
        <td>@item.md_income</td>
        <td>

            <p>@item.md_remain_pre&nbsp;│&nbsp;@item.md_remain</p>
        </td>
        <td>@item.trans_id</td>
        <td>@item.trans_common_id</td>

        <td>@item.bank_nm</td>
        <td>@item.ifsccode</td>
        <td>@item.DealerEmail</td>
        <td>@item.Dealername</td>
        <td>@item.DealerFrmname</td>
        <td>@item.dlm_remain</td>
        <td>@item.dlm_income</td>
        <td>@item.dlm_remain_pre</td>
        <td>@item.email</td>
        <td>@item.retailername</td>
        <td>@item.frm_name</td>
        <td>
            <p>
                <span>@item.user_remain_pre</span><span style="padding-left:28px;">&nbsp;│&nbsp;</span>@debit<span style="padding-left:28px;">&nbsp;│&nbsp;</span><span>@item.user_remain</span>

            </p>

        </td>
        <td>@item.response_time</td>*@
    </tr>
    }
}