@model IEnumerable<Vastwebmulti.Models.Retailer_Cr_Dr_Report_Result>
@{
    ViewBag.Title = "RetailerLedger";
    Layout = "~/Areas/MASTER/Views/Shared/_Layout.cshtml";
}
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }
    @@media screen and (max-width:520px) {
        .container-fluid.full-master-secondanimation.classmaster-padding-second {
            padding-left: 0px;
        }

        .masterladgerclass {
            width: 100% !important;
            float: left !important;
            margin: 10px 0px;
        }

            .masterladgerclass .col-md-7 {
                width: 70% !important;
                float: left;
            }

            .masterladgerclass .col-md-5 {
                width: 30% !important;
            }

            .masterladgerclass .col-md-7 input {
                width: 100% !important;
                text-align: center !important;
            }
    }

</style>
<section class="content">
    <div class="container-fluid full-master-secondanimation classmaster-padding-second">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>User Management</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right" aria-hidden="true"></i></a></li>
                <li><a href="javascript:void(0);">Basic Setting&nbsp;&nbsp;<i class="fa fa-angle-right" aria-hidden="true"></i></a></li>
                <li><a href="javascript:void(0);">Ledger</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card" style="margin-bottom: 0px;">
                    <div class="col-md-4 dealer-none-fourclass" style="padding: 0px;width:auto;float:left;">
                        <p style="font-size:19px;margin-top:3px;color:#555;">Ledger Report</p>
                    </div>
                    <div class="col-md-2" style="padding: 0px;float:right; width: auto;padding-left:5px;">
                        <div class="form-group">
                            <div style="float:right">

                                <input type="button" id="btnExport" value="Excel" style="margin-left:0px;font-size: 14px;float: left; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">
                                <input type="button" id="btnPDF" value="PDF" style="margin-left:2px;font-size: 14px;float: left; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">
                                <button class="white-success-button" style="height:32px;font-size: 14px;padding: 0px 4px;height: 32px;border: 1px solid #b1a6a638;float: left;margin-left: 2px;background: #b1a6a638;" onclick="findtotal()">Total</button>
                            </div>





                        </div>
                    </div>
                    <div class="col-md-2 masterladgerclass" style="padding: 0px;float: right;width:auto;">
                        @using (Html.BeginForm("MasterLedger", "Home", FormMethod.Post))
                        {
                            <div class="col-md-7" style="padding: 0px;width:auto;float:left;">
                                <div class="input-daterange input-group" style="">
                                    <div class="custom-date-icon ner" style="border-color:#dddddd !important;">
                                        <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                    </div>
                                    @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; width: 119px;margin-top:0px;height:36px;text-align:right;text-align:right;" })
                                </div>
                            </div>
                            <div class="col-md-5" style="padding: 0px;padding-left:5px;width:auto;float:left;">
                                <center>
                                    <button type="submit" class="btn bg-grey waves-effect" style=" background: transparent !important;border: 1px solid #ddd !important;width:100%;float:left;width:100%;">
                                        <i class="fa fa-search" style="top:1px;font-size:16px;color:black;"></i>
                                        <span style="top:0px;color:black;">Search</span>
                                    </button>
                                </center>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="body" style="margin-top: 0px;padding: 0;">
                        <div class="table-responsive tableseconddes-master" style="position: inherit;margin-top:0px;">
                            <table id="example" class="table table-bordered mastermargin-second-table third-design-table" style="width:100%;">
                                <thead style="background-color:var(--second-bg-color);">
                                    <tr>
                                        <th>Sr.No</th>
                                        <th>Request&nbsp;Id</th>
                                        <th>Particular</th>
                                        <th>₹&nbsp;Amount</th>
                                        <th>Credit</th>
                                        <th>Debit</th>
                                        <th>Balance</th>
                                        <th>Date&nbsp;&&nbsp;Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{int i = 1;}
                                    @foreach (var item in Model)
                                    {

                                        <tr>
                                            <td>@i</td>
                                            <td>@Html.DisplayFor(modelItem => item.RequestId)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Particulars)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Amount)</td>
                                            <td>@Html.DisplayFor(modelItem => item.credit)</td>
                                            <td>@Html.DisplayFor(modelItem => item.debit)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Balance)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Date)</td>
                                        </tr>
                                        i++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>

<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script type="text/javascript">
    $(function () {

               $('.input-daterange').datepicker({
                format: "yyyy-mm-dd",
                todayHighlight: true,
                autoclose: true

            });
            var val = '@ViewBag.chk';
            if (val != "post") {
                $("#txt_frm_date").datepicker("setDate", new Date());
                $("#txt_to_date").datepicker("setDate", new Date());
            }


        });
</script>

