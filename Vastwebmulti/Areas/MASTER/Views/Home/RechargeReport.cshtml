<script>

    function mdActionBtn(Idno) {
        $('#loadredmodel').show();
        $.ajax({
            url: '@Url.Action("Recharge_report_View", "Home")',
            type: 'POST',
            data: { Idno: Idno },
            cache: false,
            success: function (Response) {
                
                if (Response[0].rstatus == "SUCCESS" )
                {
                    rstatus = "../../ashok-images/correct.svg";
                    var color = "green";
                }

                if (Response[0].rstatus == "FAILED") {
                    rstatus = "../../ashok-images/closes.svg";
                    color = "red";
                }
                if (Response[0].rstatus == "Resend") {
                    rstatus = "";
                    color = "blue"
                }
                if (Response[0].rstatus == "REFUND") {
                    rstatus = "";
                    color = "brown"
                }
                if (Response[0].rstatus == "Success To Failed") {
                    rstatus = "";
                    color = "red"
                }
                if (Response[0].rstatus == "Refund") {
                    rstatus = "";
                    color = "#673AB7"
                }
                document.getElementById("img12").src = rstatus
                document.getElementById("img12").style.backgroundColor = color

                //$('#frm_name').val(Response[0].frm_name)
                $('#mobile').val(Response[0].mobile)
                $('#dealerincome').val(Response[0].dealerincome)
                $('#dealerremain').val(Response[0].dealerremain)
                $('#income').val(Response[0].income)
                $('#remain').val(Response[0].remain)
                $('#Response').val(Response[0].api_response_output)
            }
        });
    }

</script>

