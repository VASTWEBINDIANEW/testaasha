    var txtmob = $('#txtmob').val();
    var allretailer = $('#allretailer').val();
    var alldealer = $('#alldealer').val();
        var pageindex = 2;
        var NoMoredata = false;
        var inProgress = false;
    $(window).scroll(function () {

        if ($(window).scrollTop() > Number($("#example").height()) / 4 && !NoMoredata && !inProgress) {
                inProgress = true;
                $("#loadingdiv").show();
                $.post("@Url.Action("InfiniteScroll","Home")",
                    { "pageindex": pageindex, txt_frm_date: $('#txt_frm_date').val(),txt_to_date: $('#txt_to_date').val(), "ddlusers": ddlusers, "Operator": Operator, "ddl_status": ddl_status, "txtmob": txtmob, "allretailer": allretailer, "alldealer": alldealer},
                    function (data) {
                        pageindex = pageindex + 1;
                        NoMoredata = data.NoMoredata;
                        $("#trow").append(data.HTMLString);
                        $("#loadingdiv").hide();
                        inProgress = false;
                    });
            }
        });
</script>
