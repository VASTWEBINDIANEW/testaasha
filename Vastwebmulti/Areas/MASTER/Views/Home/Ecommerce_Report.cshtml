@model IEnumerable<Vastwebmulti.Models.show_ecomm_report_Result>
@{
    ViewBag.Title = "Ecommerce_Report";
    Layout = "~/Areas/MASTER/Views/Shared/_Layout.cshtml";
}
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }
    .padding-left-right{padding-left: 2px;padding-right: 2px;z-index:999;}
    .padding-left-right button, .padding-left-right .btn-group.bootstrap-select.form-control{height: 32px !important;padding-left: 5px;text-align: left;}
    .padding-left-right .input-group input[type="text"], .padding-left-right .input-group .form-control{height: 34px !important;}
    .padding-left-right-right{padding:0px;}
    .card .body{padding: 0px;}
    .padding-left-right .ner{height: 34px;}
    @@media screen and (max-width:767px) {
        .padding-left-right{width: 50%;float: left;margin-top: 15px;z-index: 999;}
        .form-group{margin-bottom: 0px;}
        .padding-left-right-right{z-index: 999;margin: 15px 0px;}
    }
    @@media screen and (max-width:420px) {
        .padding-left-right, .padding-left-right-right{width:50%;float: left;}
        .padding-left-right.padding-left-right-full{width: 100%;float: left;padding: 0px;}
    }
</style>
<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Master-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Ecommerce Report</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right" aria-hidden="true"></i></a></li>
                <li><a href="javascript:void(0);">Report's&nbsp;&nbsp;<i class="fa fa-angle-right" aria-hidden="true"></i></a></li>
                <li><a href="javascript:void(0);">Ecommerce Report</a></li>
            </ul>
        </div>
        <!--Four-Design-Master-page-Header-Section-End-->

        @*        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
