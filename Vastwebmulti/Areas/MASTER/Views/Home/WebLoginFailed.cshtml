@model IEnumerable<Vastwebmulti.Models.Failed_Login_info>
@{
    ViewBag.Title = "WebFailedLogin";
    Layout = "~/Areas/MASTER/Views/Shared/_Layout.cshtml";
}
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }

    @@media screen and (max-width:766px) {
        .padding-master {padding-left: 0px;}
        .table-responsive table {border: 1px solid #aaa4a4 !important;}
        .col-md-6 {width: 100% !important;float: left !important;margin-bottom: 15px;}
        .weblogin-master .col-md-4 {width: 100% !important;float: left;margin-bottom: 10px !important;}
        .weblogin-master .col-md-4 input, .weblogin-master .col-md-4 input ~ div {width: 49% !important;text-align: center;}
        .weblogin-master .col-md-4 input ~ div input {width: 100% !important;float: left;}
        .weblogin-master .col-md-2 {position: static !important;}
    }

</style>
<section class="content">
    <div class="container-fluid padding-master">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>App Login History</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right" aria-hidden="true"></i></a></li>
                <li><a href="javascript:void(0);">Basic Setting 3&nbsp;&nbsp;<i class="fa fa-angle-right" aria-hidden="true"></i></a></li>
                <li><a href="javascript:void(0);">App Login History</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    <div class="col-md-6" style="width:auto;float:left;">

                        <a href="@Url.Action("WebLogin","Home")" id="btn" class="btn" style="margin-top:6px; margin-left:-13px; height:31px;border:1px solid #c7c2c2;">
                            <span style="top:-1px;color:#000;">Web Login History</span>
                        </a>
                        <a href="@Url.Action("WebLoginFailed","Home")" id="btn" class="btn fullbodydycolorbg " style="margin-top:6px; margin-left:12px; height:31px;border:1px solid #c7c2c2;" title="Go to Web Failed Login History">
                            <span style="top:-1px;color:#fff;">App Login History</span>
                        </a>
                    </div>
                    <div class="col-md-6 weblogin-master" style="width:auto;float:right;">
                        @using (Html.BeginForm("WebLoginFailed", "Home", FormMethod.Post))
                        {
                            <div class="row">

                                <div class="col-md-4 mrj" style="margin: 0px;width:auto;float:left;">
                                    <div class="form-group jjp" style="margin-bottom:0px;">
                                        <div class="input-daterange input-group">
                                            <div class="custom-date-icon ner">
                                                <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                            </div>
                                            @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:0px;", autocomplete = "off" })

                                            <div class="nrr3">
                                                <div class="custom-date-icon ner">
                                                    <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                                </div>
                                                @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:0px;", autocomplete = "off" })
                                            </div>
                                        </div>
                                        <!-- /.input group -->
                                    </div>
                                </div>
                                <div class="col-md-2" style="padding: 0px;width:auto;float:left;">

                                    <button type="submit" class="btn bg-grey waves-effect" style="border: 1px solid #ddd !important;background: transparent !important;">
                                        <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                        <span style="top:-2px;color:black;">Search</span>
                                    </button>

                                </div>
                                <div class="col-md-2 fin3 pploh" style="padding: 0px;float: right;width:auto;padding-left:5px;">

                                    <div class="form-group">
                                        <div style="padding-top: 0px; float:right">

                                            <input type="button" id="btnExport" value="Excel" style="margin-left:0px;font-size: 11px;float: left; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;" />
                                            <input type="button" id="btnPDF" value="PDF" style="margin-left:2px;font-size: 11px;float: left; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;" />

                                        </div>

                                    </div>

                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:0px;">
                <div class="card">


                    <div class="body" style="margin-top:0px;padding:0px;">
                        <div class="table-responsive tableseconddes-master" style="position:inherit;margin-top:0px;">
                            <table id="example" class="table table-bordered third-design-table" style="width:100%;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>

                                        <th>Login&nbsp;From</th>

                                        <th>IP&nbsp;Address</th>
                                        <th>Browser</th>

                                        <th>Login&nbsp;Date&nbsp;Time&nbsp;Details</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var i = 1;}
                                    @foreach (var item in Model)
                                    {
                                        <tr role="row" class="odd">
                                            <td><span style="background: red;color: white;padding: 3px 5px;border: 1px solid #f5f5f5;">@item.LoginFrom</span></td>

                                            <td>@item.IP_Address</td>
                                            <td>@item.browser</td>
                                            <td>@item.LoginTime</td>


                                        </tr>
                                        i++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>


<script>
    $(function () {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
    });
</script>

