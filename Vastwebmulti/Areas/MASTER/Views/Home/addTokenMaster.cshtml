<script>
    function onPluseMinuss(v) {
        //alert(v);
        event.stopPropagation();
        var digiCount = parseInt($('#tokenCount2').val());
        if (v >= 0) {
            $('#tokenCount2').val(digiCount + v);
            $('#showPhysicalCount2').html(digiCount + v);
        } else {
            $('#tokenCount2').val(digiCount - 1);
            $('#showPhysicalCount2').html(digiCount - 1);
        }
        if (parseInt($('#tokenCount2').val()) >= 1) {
            $('#btnChildMinus2').prop('disabled', false);
        }
        if (parseInt($('#tokenCount2').val()) == 0) {
            $('#btnChildMinus2').prop('disabled', true);
        }
    }
</script>

<script>
    function converttoDate(str) {
        var date = new Date(str),
            mnth = ("0" + (date.getMonth() + 1)).slice(-2),
            day = ("0" + date.getDate()).slice(-2),
            Hrs = (date.getHours()),
            mnts = (date.getMinutes()),
            sec = (date.getSeconds());
        return dd = [day, mnth, date.getFullYear()].join("-") + " " + [Hrs + ":" + mnts + ":" + sec];
    }

    $('#MdbtnSubmit').click(function () {
        

        $.ajax({
            url: '@Url.Action("addTokenMaster1", "Home")',
            type: 'POST',
            data: {tokenCount: $("#tokenCount2").val() },
            cache: false,
            success: function (response) {
                if (response == "Insufficient balance." || response == "Set the Dealer token Value." || response == "Token Can Not Be Negative") {
                    $("#Lblmsg2").css("color", 'red').text(response);
                    //$("#defaultModal2").delay(1500).hide(0, function () {
                    //    $("#Lblmsg2").text('');
                    //    $("#defaultModal2").modal('hide');
                    //});
                }
                else {
                    $("#Lblmsg2").css("color", 'green').text("Credited Successfully.");
                    $("#defaultModal2").delay(1000).hide(0, function () {
                        $("#Lblmsg2").text('');
                        $("#defaultModal2").modal('hide');
                    });
                }
                location.reload();
        
            }
        });



    })
</script>