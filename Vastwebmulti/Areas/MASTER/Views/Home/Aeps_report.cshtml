<script>
    function mdActionBtn(Idno) {
        $.ajax({
            url: '@Url.Action("AepsReport_View", "Home")',
            type: 'POST',
            data: { Idno: Idno },
            cache: false,
            success: function (Response) {
                
                if (Response[0].Status == "Success") {
                    status = "../../ashok-images/correct.svg";
                    var color = "green";
                }

                if (Response[0].Status == "Failed") {
                    status = "../../ashok-images/closes.svg";
                    color = "red";
                }
                if (Response[0].Status == "Pending") {
                    status = "../../ashok-images/clock.svg";
                }
                if (Response[0].Status == "Refund") {
                    status = "";
                    color = "blue";
                }
                document.getElementById("img12").src = status
                document.getElementById("img12").style.backgroundColor = color
                $('#Idno').val(Response[0].idno)
                $('#Amount').val(Response[0].Amount)
                $('#Rempre').val(Response[0].RemPre)
                $('#RemIncome').val(Response[0].RemIncome)
                $('#RemPost').val(Response[0].RemPost)
                $('#Mdpre').val(Response[0].MdPre)
                $('#MdIncome').val(Response[0].MdIncome)
                $('#MdPost').val(Response[0].MdPost)
                $('#DlmPre').val(Response[0].DlmPre)

                $('#DlmIncome').val(Response[0].DlmIncome)
                $('#DlmPost').val(Response[0].DlmPost)
                $('#Remark').val(Response[0].Remark)
                $('#Response').val(Response[0].response_output)
            }
        });
    }

</script>

<script>
    $(function () {

       $('.input-daterange').datepicker({
                format: "yyyy-mm-dd",
                todayHighlight: true,
                autoclose: true,
                orientation: "bottom auto",

            });
            var val = '@ViewBag.chk';
            if (val != "post") {
                $("#txt_frm_date").datepicker("setDate", new Date());
                $("#txt_to_date").datepicker("setDate", new Date());
            }
            answers();
    });
</script>

<script type="text/javascript">
    function answers() {
        var e = document.getElementById("ddlusers");
        var answer = e.options[e.selectedIndex].value;
        if (answer == "Dealer") {
            document.getElementById("dlm").style.display = "block";
            document.getElementById("rem").style.display = "none";
        }

        else if (answer == "Master") {
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "none";

        }

        else if (answer == "Retailer") {
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "block";

        }
    }
</script>

<script>
    var pageindex = 2;
        var NoMoredata = false;
    var inProgress = false;
    $(window).scroll(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var ddlusers = $('#ddlusers').val();
        var ddl_status = $('#ddl_status').val();
        var alldealer = $('#alldealer').val();
        var allretailer = $('#allretailer').val();

            if ($(window).scrollTop() > Number($("#apes").height()) / 4 && !NoMoredata && !inProgress) {
                inProgress = true;
                $("#loadingdiv").show();
                $.post("@Url.Action("InfiniteScrollAeps", "Home")",
                    { "pageindex": pageindex, "txt_frm_date": txt_frm_date, "txt_to_date": txt_to_date, "ddlusers": ddlusers, "alldealer": alldealer, "allretailer": allretailer, "ddl_status": ddl_status},
                    function (data) {
                        pageindex = pageindex + 1;
                        NoMoredata = data.NoMoredata;
                        $("#trow").append(data.HTMLString);
                        $("#loadingdiv").hide();
                        inProgress = false;
                    });
            }
        });
</script>
<script>
    function findtotal() {
        
        var ddlusers = $('#ddlusers').val();
        var ddl_status = $('#ddl_status').val();
        var allretailer = $('#allretailer').val();
        var alldealer = $('#alldealer').val();
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
             $.post("@Url.Action("TotalAepsreport", "Home")",
                 { "ddlusers": ddlusers,"ddl_status": ddl_status, "allretailer": allretailer, "alldealer": alldealer, "txt_frm_date": txt_frm_date, "txt_to_date": txt_to_date },
                 function (data) {
                     $('#successtotal').text("₹. " + data.success);
                     $('#Failedtotal').text("₹. " + data.failed);
                     $('#Pendingtotal').text("₹. " + data.pending);

                 });
    }
</script>
