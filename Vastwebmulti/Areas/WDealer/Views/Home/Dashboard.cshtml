
@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Areas/WDealer/Views/Shared/_Layout.cshtml";
}
<style>
    .img-responsive, .thumbnail > img, .thumbnail a > img, .carousel-inner > .item > img, .carousel-inner > .item > a > img {
        max-width: 49%;
    }
</style>
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card" style="margin-top:-5px;">
                    <div class="list-group">
                        @if (ViewBag.news != null && ViewBag.newimg != null)
                        {
                            <marquee scrollamount="2" onmouseover="this.stop();" onmouseout="this.start();">
                                <p style="font-size:19px;margin-top:13px;margin-bottom:2px;color:#ed174c;"><img src="@Url.Content("~/" + ViewBag.newimg)" style="height:21px;" />&nbsp;@ViewBag.news</p>
                            </marquee>
                        }
                        else
                        {
                            <p style="font-size:22px;padding-top:5px;text-align:center;color:#e0dddd;font-weight:700;">No Data Found !</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- CPU Usage -->
        <div class="row clearfix">
            <div>
                <!-- Task Info -->
                <div class="col-md-5">
                    <div class="card" style="margin-top:-13px;">
                        <div class="header">
                            <h2><i class="fa fa-user-circle-o"></i>&nbsp;<span>Distributor Profile</span></h2>
                        </div>
                        <div class="body">
                            <center>
                                <div class="image" style="margin-top:-6px;">
                                    @if (ViewBag.image != null && ViewBag.image != "")
                                    {
                                        <img src="@Url.Content("~/" + ViewBag.image)" width="100" height="100" class="img-circle" alt="User">

                                    }
                                    else
                                    {

                                        <img src="~/AdminDesign/images/user.png" width="100" height="100" class="img-circle" alt="User">
                                    }

                                </div>
                                <div class="msg" style="padding-top:20px;">@ViewBag.email</div>
                            </center>
                            <center>
                                <div class="row" style="margin-top:9%;">

                                    <div class="col-xs-4" style="margin-bottom:0px;">
                                        <a href="@Url.Action("Profile","Home")" class="btn btn-default waves-effect" type="button" style="text-decoration:none;box-shadow:none; border:1px solid #dddddd70;"><i class="fa fa-user-circle-o" style="top:1px;font-size:14px;"></i>&nbsp;Profile</a>
                                    </div>
                                    <div class="col-xs-3" style="margin-bottom:0px;">
                                        @using (Html.BeginForm("LogOff", "Account", new { Area = "", id = "logoutForm" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-default waves-effect" type="submit" style="text-decoration:none;box-shadow:none; border:1px solid #dddddd70;margin-left:-12px;"><i class="fa fa-sign-out" style="top:0px; color:red;font-size:14px;"></i><span style="top:-2px; color:red; font-size:13px;">Logout</span></button>
                                        }
                                    </div>
                                    <div class="col-xs-3" style="margin-bottom:0px;">
                                        <a href="@Url.Action("ChangePassword","Home")" style="text-decoration:none;box-shadow:none; border:1px solid #dddddd70;" class="btn btn-default waves-effect"><span style="font-size:13px;top:-2px;"><i class="material-icons" style="font-size:14px;top:2px;">lock_outline</i>&nbsp;Change Pass</span></a>
                                    </div>

                                </div>
                            </center>


                        </div>
                    </div>
                    <div class="card" style="margin-top:-3%;">
                        <div class="header">
                            <h2><i class="material-icons col-pink">group</i>&nbsp;<span>ACTIVE / INACTIVE USERS</span></h2>
                        </div>
                        <div class="body">
                            <div class="table-responsive">
                                <table class="table table-hover dashboard-task-infos">
                                    <thead>
                                        <tr>
                                            <th>USER</th>
                                            <th>ACTIVE</th>
                                            <th>INACTIVE</th>
                                            <th>TOTAL</th>
                                            <th>PROGRESS</th>
                                        </tr>
                                    </thead>
                                    <tbody>

                                        <tr>
                                            <td>Retailer</td>
                                            <td><a href="#" style="text-decoration:none;color:#867b7b;">@ViewData["actRtl"]</a></td>
                                            <td><a href="#" style="text-decoration:none;color:#867b7b;">@ViewData["inRtl"]</a></td>
                                            <td><a href="#" style="text-decoration:none;color:#867b7b;">@ViewData["TotalRetailrs"]</a></td>
                                            <td>
                                                <div class="progress">
                                                    <div class="progress-bar bg-green" role="progressbar" aria-valuenow="62" aria-valuemin="0" aria-valuemax="100" style="width: @ViewData["Act_Rtl_Perc"]%"></div>
                                                </div>

                                            </td>
                                        </tr>

                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="col-xs-12 col-sm-12 col-md-7 col-lg-7">
                    <div class="card" style="margin-top:-13px;">
                        <div class="" style="padding-top:1px;">
                            <!-- Nav tabs -->

                            <ul class="nav nav-tabs" role="tablist" style="padding-bottom:13px;border-bottom:1px solid #e6e6e6;background:#dddddd70;border:5px solid white;">
                                <li role="presentation" class="active" style="background:#dddddd70; margin-left:4px;">
                                    <a href="#History" data-toggle="tab" aria-expanded="false" class="btn bg-grey waves-effect" onclick="Alltab()">
                                        <i class="fa fa-newspaper-o" style="top:3px;color:black;font-size:16px;"></i><span style="color:black;top:2px;">All Transaction Tab</span>
                                    </a>
                                </li>
                                <li role="presentation" style="background:#dddddd70;">
                                    <a href="#Todaybusiness" id="Today" data-toggle="tab" aria-expanded="false" class="btn bg-grey waves-effect" onclick="today(this)">
                                        <i class="fa fa-calendar-check-o" style="top:3px;color:black;font-size:16px;"></i><span style="color:black;top:2px;">Today Business Chart</span>
                                    </a>
                                </li>
                                <li role="presentation" style="background:#dddddd70;">
                                    <a href="#Todaybusiness" data-toggle="tab" id="Yesterday" aria-expanded="false" class="btn bg-grey waves-effect" onclick="today(this)">
                                        <i class="fa fa-calendar-check-o" style="top:3px;color:black;font-size:16px;"></i><span style="color:black;top:2px;">Yesterday Business Chart</span>
                                    </a>
                                </li>

                            </ul>

                            <!-- Tab panes -->
                            <div class="tab-content">
                                <div role="tabpanel" class="tab-pane fade in active" id="History">
                                    <div class="" style="margin-bottom:-142px;" id="rch">
                                        <div style="margin-top:21px;">
                                            <div class="row clearfix">
                                                <div class="col-md-12">
                                                    <div class="table-responsive" style="margin-top:-3px;">
                                                        <table class="table" style="margin-left:1%;width:98%;">
                                                            <tr style="border-bottom:1px solid #eeeeee;">
                                                                <td>
                                                                    <a href="@Url.Action("Recharge_Report","Home")" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/recharge.svg" />
                                                                            <p>Recharge&nbsp;&&nbsp;Bill</p>
                                                                        </center>
                                                                    </a>
                                                                </td>
                                                                <td>
                                                                    <a href="@Url.Action("Money_transfer_Report","Home")" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/dmt.svg" />
                                                                            <p>Money&nbsp;Transfer</p>
                                                                        </center>
                                                                    </a>
                                                                </td>
                                                                <td>
                                                                    <a href="#" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/airplane.svg" />
                                                                            <p>Flight&nbsp;Booking</p>
                                                                        </center>
                                                                    </a>
                                                                </td>

                                                                <td>
                                                                    <a href="#" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/bus.svg" />
                                                                            <p>Bus&nbsp;Booking</p>
                                                                        </center>
                                                                    </a>
                                                                </td>

                                                            </tr>
                                                        </table>
                                                        <table class="table" style="margin-top:-17px;margin-left:1%;width:98%;">
                                                            <tr style="border-bottom:1px solid #eeeeee;">
                                                                <td>
                                                                    <a href="@Url.Action("Aeps_Report","Home")" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/fingerprint.svg" />
                                                                            <p>Aadhaar&nbsp;Pay</p>
                                                                        </center>
                                                                    </a>
                                                                </td>

                                                                <td>
                                                                    <a href="#" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/shopping-cart.svg" />
                                                                            <p>E-commerce&nbsp;&nbsp;&nbsp;</p>
                                                                        </center>
                                                                    </a>
                                                                </td>
                                                                <td>
                                                                    <a href="#" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/mposs.svg" />
                                                                            <p>&nbsp;&nbsp;&nbsp;&nbsp;M-Poss&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</p>
                                                                        </center>
                                                                    </a>
                                                                </td>

                                                                <td>
                                                                    <a href="@Url.Action("Pancard_Report","Home")" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/pan.svg" />
                                                                            <p>Pancard</p>
                                                                        </center>
                                                                    </a>
                                                                </td>

                                                            </tr>
                                                        </table>
                                                        <table class="table" style="margin-top:-17px;margin-left:1%;width:98%;">
                                                            <tr style="border-bottom:1px solid #eeeeee;">
                                                                <td>
                                                                    <a href="#" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/indo nepal.svg" />
                                                                            <p>&nbsp;Indo&nbsp;Nepal&nbsp;</p>
                                                                        </center>
                                                                    </a>
                                                                </td>
                                                                <td>
                                                                    <a href="#" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/hotel.svg" />
                                                                            <p>Hotel&nbsp;Bokking</p>
                                                                        </center>
                                                                    </a>
                                                                </td>


                                                                <td>
                                                                    <a href="#" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/satellite-dish.svg" />
                                                                            <p>Dth&nbsp;Booking</p>
                                                                        </center>
                                                                    </a>
                                                                </td>
                                                                <td>
                                                                    <a href="#" style="text-decoration:none;">
                                                                        <center>
                                                                            <img class="img-responsive" src="~/images/reportimage/greeting-card.svg" />
                                                                            <p>Gift&nbsp;Card</p>
                                                                        </center>
                                                                    </a>
                                                                </td>

                                                            </tr>
                                                        </table>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div role="tabpanel" class="tab-pane1 fade" id="Todaybusiness" style="margin-top:-12px;">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div id="donut_chart" class="graph" style="margin-top:-28px;"></div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="body" style="margin-top:-37px;">
                                                <div class="table-responsive">
                                                    <table class="table table-hover dashboard-task-infos" style="border-left:1px solid #eeeeee;border-right:1px solid #eeeeee;">
                                                        <thead>
                                                            <tr>
                                                                <th>SIGN</th>
                                                                <th>OPERATORS</th>
                                                                <th>TOTAL</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody id="tabletoday"></tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>


                <!-- #END# Browser Usage -->
            </div>
        </div>
    </div>
</section>
<script>
    window.onload=function()
    {
               initDonutChart();
    }
</script>
<script>
    $(function () {
        var succ = '@ViewData["sucess"]';
        var error = '@ViewData["error"]';
        if (succ != "" && succ != null) {
            swal("Good job!", succ, "success");
        }
        if (error != "" && error != null) {
            swal("Ooops!", error, "error");
        }
        document.getElementById("Todaybusiness").style.display = "none";
        document.getElementById("rch").style.marginBottom = "22px";
        //initDonutChart();
    });
</script>
<script>
    function Alltab()
        {
        document.getElementById("Todaybusiness").style.display = "none";
        document.getElementById("rch").style.marginBottom = "22px";
        }
</script>
<script>
    function today(a)
    {
        document.getElementById("Todaybusiness").style.display = "block";
        $("#tabletoday").empty();

        var x = a.id;
        //call ajax
        $.ajax({
            url: '@Url.Action("Show_All_Recharge", "Home")',
            type: 'POST',
            dataType: "html",
            data: { yesterday: x },
            success: function (data) {
                var  x = JSON.parse(data);

                    var newRow =
                "<tr>" +
               " <td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='fa fa-desktop' style='color:#E91E63;'></i></p></td>" +
               "<td><p style='padding-top:3px;'>Recharge & bill</p></td>" +
               "<td><p style='padding-top:3px;'> " + x.Recharge + "</p></td>" + "</tr>" +
               "<tr>" +
                "<td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='fa fa-university' style='color:#2196F3;'></i></p></td>" +
               "<td><p style='padding-top:3px;'>Financial Services</p> </td>" +
               "<td><p style='padding-top:3px;'>" + x.Moneytransfer + "</p></td>" + "</tr>" +
                 "<tr>" +
                "<td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='material-icons' style='color:#FF9800;'>fingerprint</i></p></td>" +
               "<td><p style='padding-top:3px;'>Aeps Services</p> </td>" +
               "<td><p style='padding-top:3px;'>" + x.Aeps + "</p></td>" + "</tr>" +
                "<tr>" +
                "<td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='fa fa-id-card' aria-hidden='true' style='color:#000000;'></i></p></td>" +
               "<td><p style='padding-top:3px;'>Pancard</p> </td>" +
               "<td><p style='padding-top:3px;'>" + x.Pancard + "</p></td>" + "</tr>" +
                "<tr>" +
                "<td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='fa fa-plane' style='color:#4CAF50;'></i></p></td>" +
               "<td><p style='padding-top:3px;'>Travel</p> </td>" +
               "<td><p style='padding-top:3px;'>" + 0.00+ "</p></td>" + "</tr>" +
                "<tr>" +
                "<td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='fa fa-gift' style='color:#F44336;'></i></p></td>" +
               "<td><p style='padding-top:3px;'>Gift Cards </p></td>" +
               "<td><p style='padding-top:3px;'>" + 0.00 + "</p></td>"
                 + "</tr>" +
                "<tr>" +
                "<td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='fa fa-cart-plus' style='color:#555;'></i></p></td>" +
               "<td><p style='padding-top:3px;'>E-Commerce</p> </td>" +
                 "<td><p style='padding-top:3px;'>" + 0.00 + "</p></td>"
                 + "</tr>";
                    $('#tabletoday').append(newRow);
                    $("#donut_chart").empty();
                    var rechargebillamt = x.Recharge;
                    var moneytransferamt = x.Moneytransfer;
                    var Aepsamt = x.Aeps;
                    var pancardamount = x.Pancard;
                    initDonutChart(rechargebillamt, moneytransferamt, Aepsamt, pancardamount);


            },
            error: function (data) {

            }
        });
        return true;

     }
</script>
<!-- Doughnut Chart -->
<script type="text/javascript">
    function initDonutChart(rechargebill, moneytrasfer, Aepsamt, pancardamount) {

         var rechargeandbill = rechargebill;
         var Financial = moneytrasfer;
         var aeps = Aepsamt;
         var Pancard = pancardamount;
         var Travel = 0.00
         var GiftCards = 0.00
         var ECommerce = 0.00

          Morris.Donut({
            element: 'donut_chart',

            data: [
                {
                    label: 'Recharge & bill',
                    value: rechargeandbill,
                },
            {
                label: 'Financial',
                value: Financial
            },
            {
                label: 'Aeps',
                value: aeps
            },
              {
                  label: 'Pancard',
                  value: Pancard
              },
            {
                label: 'Travels',
                value: Travel
            },
            {
                label: 'Gift Cards',
                value: GiftCards,
                },
             {
                 label: 'E-Commerce',
                 value: ECommerce
             }
            ],

            colors: [
                'rgb(233, 30, 99)',
                'rgb(0, 128, 255)',
                'rgb(255, 152, 0)',
                'rgb(0, 0, 0)',
                'rgb(76, 175, 80)',
                'rgb(255, 0, 0)',
                'rgb(128, 128, 128)'],

            formatter: function (y) {
             return y
            }
         });

    }
</script>

