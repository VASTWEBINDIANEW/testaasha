<script type="text/javascript">
    function GenerateInvoice(DistOldBal, Value, DistNewBal, Date) {
        //alert(ReciveFrom + '' + OldRemain + '' + Value + '' + Commission + '' + FinalValue + '' + NewRemain + '' + Date)
        var url = '@Url.Action("GotoInvoicePDF", "Home")?Value=' + Value + '&DistOldBal=' + DistOldBal + '&DistNewBal=' + DistNewBal + '&Date=' + Date + '';
        window.open(url, "_blank");
    }
</script>
<script>
    $(function()
    {
            $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

    })
</script>

<script type="text/jscript">
    $(function () {
        var error = '@ViewData["show"]';
        var success = '@ViewData["success"]';
        if (error != "") {
            sweetAlert("Oops...", error, "error");
        }
        if(success !="" && success !=null)
        {
            swal("Good job!", success, "success");
        }
        })

    $('#radio_6').on('click', function () {
        if ((this.value) == "3rdParty") {
            $("#accountno2").replaceWith($('<input/>', { 'type': 'text', 'name': 'accountno', 'required': "", 'placeholder': 'Enter Account Number', 'class': 'form-control' }));
        }
    });
    $('#radio_3').on('click', function () {
        if ((this.value) == "3rdParty") {
            $("#accountno1").replaceWith($('<input/>', { 'type': 'text', 'name': 'accountno', 'required': "",'placeholder' :'Enter Account Number', 'class': 'form-control' }));
        }
    });


</script>
<script type="text/javascript">
    $(function () {
        $("#balance").keydown(function (e) {
            // Allow: backspace, delete, tab, escape, enter and .
            if ($.inArray(e.keyCode, [46, 8, 9, 27, 13, 110, 190]) !== -1 ||
                // Allow: Ctrl+A, Command+A
                (e.keyCode === 65 && (e.ctrlKey === true || e.metaKey === true)) ||
                // Allow: home, end, left, right, down, up
                (e.keyCode >= 35 && e.keyCode <= 40)) {
                // let it happen, don't do anything
                return;
            }
            // Ensure that it is a number and stop the keypress
            if ((e.shiftKey || (e.keyCode < 48 || e.keyCode > 57)) && (e.keyCode < 96 || e.keyCode > 105)) {
                e.preventDefault();
            }
        });

    });

</script>


