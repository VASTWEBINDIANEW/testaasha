@model IEnumerable<Vastwebmulti.Models.GST_Report_Dealer_Result>
@{
    ViewBag.Title = "GST_Report";
    Layout = "~/Areas/WDealer/Views/Shared/_Layout.cshtml";
}
<link href="~/Areas/RETAILER/Blinking text/Blinking.css" rel="stylesheet" />
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card" style="margin-top:2px;">
                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-group" style="margin-top:10px;">
                                <p style="font-size:20px;padding-left:10px;">GST Information</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <div class="input-group" style="padding-top:4px;">
                                    @if (ViewBag.IsFormSubmmited != null && ViewBag.IsFormSubmmited.Status == "Rejected")
                                    {
                                        <input class="form-control flash" id="balance" name="balance" style="border:1px solid #dddddd; background-color:white;" type="text" readonly="" value="GST  NOT ACCEPTED YET!">
                                        <div class="input-group-addon" style="background:#607d8b; color:white;border:1px solid #dddddd;border-right:1px solid ; padding-left:5px;">
                                            <span onclick="Download_diclarationform()" title="Click To Download Form">
                                                <i class="fa fa-download  flash" style="padding-left:3px; font-size:20px;"></i>Download
                                            </span>
                                        </div>
                                        <div class="input-group-addon" style="background:#607d8b; color:white;border:1px solid #607d8b;">
                                            <button type="submit" style="margin-top:-3px; margin-left:11px; background:none;border:none; " title="Upload GST Form" data-toggle="modal" data-target="#defaultModal">
                                                <i class="material-icons" style="color:green;">file_upload</i>
                                                <span style="top:-4px;">Upload</span>
                                            </button>
                                        </div>
                                    }
                                    else if (ViewBag.IsFormSubmmited != null && ViewBag.IsFormSubmmited.Status == "Accepted")
                                    {
                                        <input class="form-control flash" id="balance" name="balance" style="border:1px solid #607d8b; background-color:white;" type="text" readonly="" value="CONGRATS! DECLARATION FORM ACCEPTED.!">
                                        <div class="input-group-addon" style="background:#607d8b; color:white;border:1px solid #607d8b;border-right:1px solid ; padding-left:5px;">
                                            <span onclick="Download_diclarationform()" title="Click To Download Form">
                                                <i class="fa fa-download  flash" style="padding-left:3px; font-size:20px;"></i>Download
                                            </span>
                                        </div>
                                        <div class="input-group-addon" style="background:#607d8b; color:white;border:1px solid #607d8b;">
                                            <button type="submit" style="margin-top:-3px; margin-left:11px; background:none;border:none; " title="Upload GST Form" data-toggle="modal" data-target="#defaultModal">
                                                <i class="material-icons" style="color:green;">file_upload</i>
                                                <span style="top:-4px;">Upload</span>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <input class="form-control flash" id="balance" name="balance" style="border:1px solid #607d8b; background-color:white;" type="text" readonly="" value="GST NOT AVAILABLE !">
                                        <div class="input-group-addon" style="background:#607d8b; color:white;border:1px solid #607d8b;border-right:1px solid ; padding-left:5px;">
                                            <span onclick="Download_diclarationform()" title="Click To Download Form">
                                                <i class="fa fa-download  flash" style="padding-left:3px; font-size:20px;"></i>Download
                                            </span>
                                        </div>
                                        <div class="input-group-addon" style="background:#607d8b; color:white;border:1px solid #607d8b;">
                                            <button type="submit" style="margin-top:-3px; margin-left:11px; background:none;border:none; " title="Upload GST Form" data-toggle="modal" data-target="#defaultModal">
                                                <i class="material-icons" style="color:green;">file_upload</i>
                                                <span style="top:-4px;">Upload</span>
                                            </button>
                                        </div>
                                    }
                                </div>
                                <!-- /.input group -->
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <div class="form-line" style="padding-top:0px; border-bottom:none;">

                                    @using (Html.BeginForm("GST_Invoicing", "Home", FormMethod.Post, new { target = "_blank" }))
                                    {
                                        @Html.DropDownList("month", (IEnumerable<SelectListItem>)ViewBag.Months, "Month", new { required = "required", @style = "height:32px;" })
                                        <button type="submit" class="fa fa-file-pdf-o fa-2x" style="background:transparent;border:none;
color:green;" title="Click To Download Invoice Report" />
                                    }

                                </div>
                            </div>
                        </div>
                        @using (Html.BeginForm("GST_Report", "Home", FormMethod.Post))
                        {
                            <div class="col-md-4">
                                <div class="row">

                                    <div class="col-md-4">
                                        <div class="form-group" style="margin-bottom:0px;">
                                            <div class="input-group" style="margin-top:4px;">
                                                <div class="input-group-addon" style="background:#dddddd; color:white;border:1px solid #dddddd; padding-right:0px;">
                                                    <i class="material-icons" style="color:#607d8b;">date_range</i>
                                                </div>
                                                <input type="text" id="txt_frm_date" name="txt_frm_date" class="datepicker form-control" style="text-align:center;border:1px solid #dddddd; height:36px;">
                                            </div>
                                            <!-- /.input group -->
                                        </div>

                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group" style="margin-bottom:0px;">
                                            <div class="input-group" style="margin-top:4px;">
                                                <div class="input-group-addon" style="background:#dddddd; color:white;border:1px solid #dddddd;padding-right:0px;">
                                                    <i class="material-icons" style="color:#607d8b;">date_range</i>
                                                </div>
                                                <input type="text" id="txt_to_date" name="txt_to_date" class="datepicker form-control" style="text-align:center;border:1px solid #dddddd;height:36px;">
                                            </div>
                                            <!-- /.input group -->
                                        </div>

                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <button type="submit" class="btn bg-blue-grey  waves-effect" style="margin-top:3px; margin-left:-8px;">
                                                <i class="material-icons" style="top:3px;">search</i>
                                                <span style="top:-4px;">Search</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-22px;">
                <div class="card" style="margin-top:2px;">
                    <div class="">
                        <div class="col-md-4">

                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <div class="form-line" style="padding-top:10px; border-bottom:none;">
                                    <span class="label bg-pink" style="padding:12px 9px 7px 9px;border-radius:5%;"><i class="fa fa-unlock" style="font-size:23px;"></i>&nbsp;&nbsp;<span style="font-size:14px;">@ViewBag.OpnBal</span></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group">
                                <div class="form-line" style="padding-top:10px; border-bottom:none;">
                                    <span class="label bg-light-blue" style="padding:12px 9px 7px 9px;border-radius:5%;"><i class="fa fa-shopping-cart " style="font-size:23px;"></i>&nbsp;&nbsp;<span style="font-size:14px;">@ViewBag.Purchase</span></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <div class="form-line" style="padding-top:10px; border-bottom:none;">
                                    <span class="label bg-teal" style="padding:12px 9px 7px 9px;border-radius:5%;"><i class="fa fa-lock" style="font-size:23px;"></i>&nbsp;&nbsp;<span style="font-size:14px;">@ViewBag.CloseBal</span></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="form-group">
                                <span onclick="GotoPDF()" data-toggle="tooltip" title="Click To Download PDF"><i class="fa fa-file-pdf-o" style="color:red; font-size:31px;padding-top:6px;"></i></span>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="card">
                    <div class="body" style="margin-top:-20px;">
                        <div class="table-responsive " style="position:inherit;">
                            <table class="table table-bordered table-striped table-hover dataTable js-exportable" style="width:100%;">
                                <thead class="navbar" style="position:initial;color:white;">
                                    <tr>
                                        <th>SR</th>
                                        <th>OperatorName</th>
                                        <th>Sell</th>
                                        <th>SellRate</th>
                                        <th>Commission</th>
                                        @if (ViewBag.CloseBal == "ISGST")
                                        {
                                            <th> IGST</th>
                                        }
                                        else
                                        {
                                            <th>CGST</th>
                                            <th>SGST</th>
                                        }



                                    </tr>
                                </thead>
                                <tbody>
                                    @{int i = 1;}
                                    @foreach (var item in Model)
            {
                                        <tr>
                                            <td>@i</td>
                                            <td style="">@Html.DisplayFor(modelItem => item.operator_Name)</td>
                                            <td style="">@Html.DisplayFor(modelItem => item.Sell)</td>
                                            <td style="">@Html.DisplayFor(modelItem => item.DealerSellRate)</td>
                                            <td style="">@Html.DisplayFor(modelItem => item.DealerSellAmt)</td>
                                            @if (ViewBag.CloseBal == "ISGST")
                                            {
                                                <td style="">@Html.DisplayFor(modelItem => item.IGST)</td>
                                            }
                                            else
                                            {
                                                <td style="">@Html.DisplayFor(modelItem => item.CGST)</td>
                                                <td style="">@Html.DisplayFor(modelItem => item.SGST)</td>
                                            }



                                        </tr>
                                        i++;
                                    }
                                </tbody>
                                <tfoot class="navbar" style="color:white;position:inherit;">
                                    <tr style="font-weight:bold;">
                                        <td></td>
                                        <td style="">Total</td>
                                        <td style="">@Model.Sum(a => a.Sell)</td>
                                        <td style="">@Model.Sum(modelItem => modelItem.DealerSellRate)</td>
                                        <td style="">@Model.Sum(modelItem => modelItem.DealerSellAmt)</td>
                                        @if (ViewBag.CloseBal == "ISGST")
                                        {
                                            <td style="">@Model.Sum(modelItem => modelItem.IGST)</td>
                                        }
                                        else
                                        {
                                            <td style="">@Model.Sum(modelItem => modelItem.CGST)</td>
                                            <td style="">@Model.Sum(modelItem => modelItem.SGST)</td>
                                        }


                                    </tr>

                                </tfoot>

                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</section>

<!--Upload Model -->
<div class="modal fade" id="defaultModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header navbar" style="position:initial;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:white;">GST Declaration Form Submission</h4>
            </div>
            @using (Html.BeginForm("GST_Report", "Home", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                <div class="modal-body" style="margin-top:-26px;">
                    <div class="body">
                        <form>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Upload Form</label>
                                </div>

                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            <input type="file" id="file" name="file" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="submit" class="btn btn-primary waves-effect">Save Change</button>
                                <button type="button" class="btn btn-info waves-effect" data-dismiss="modal">CLOSE</button>
                            </div>
                        </form>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-colorpicker/js/bootstrap-colorpicker.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>


<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>

<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>

<script>
    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 45 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }
</script>
<!--Calendar Javascript-->
<script type="text/javascript">
    window.onload = function () {

	     	 $('#date').bootstrapMaterialDatePicker
			({
      	clearButton: false
			});
		    $('#txt_to_date').bootstrapMaterialDatePicker
			({
				weekStart: 0, format: 'DD/MM/YYYY'
			});
		    $('#txt_frm_date').bootstrapMaterialDatePicker
			({
				weekStart: 0, format: 'DD/MM/YYYY'
			}).on('change', function(e, date)
			{
			    $('#txt_to_date').bootstrapMaterialDatePicker('setMinDate', date);
			});

		    $('#min-date').bootstrapMaterialDatePicker({ format: 'DD/MM/YYYY HH:mm', minDate: new Date() });

		    var from = '@ViewBag.fromdate';
		    var to = '@ViewBag.todate';
		    if (from != "" && to != "") {
		        $('#txt_frm_date').val(from);
		        $('#txt_to_date').val(to);
		    }
		    else {
		        var month = new Array("Jan", "Feb", "Mar",
       "Apr", "May", "Jun", "Jul", "Aug", "Sep",
       "Oct", "Nov", "Dec");
		        var d = new Date();
		        var curr_date = d.getDate();
		        var curr_month = d.getMonth();
		        var curr_year = d.getFullYear();

		        var tt = curr_date + "-" + month[curr_month]
                + "-" + curr_year;
		        document.getElementById("txt_frm_date").value = tt;
		        document.getElementById("txt_to_date").value = tt;
		    }

        $('[data-toggle="tooltip"]').tooltip();
    }

</script>

<script type="text/javascript">
    $(document).ready(function () {
          if ('@ViewBag.Message' != null && '@ViewBag.Message' == "Success") {
            swal("Wow!", " Form Uploaded Successfully.", "success");
        }
        else if ('@ViewBag.Message' != null && '@ViewBag.Message' == "Faild") {
            swal("Oops!", " Faild to Upload Form!", "error");
        }
    });
</script>

<!--Download Declartion form -->
<script>
    function Download_diclarationform()
    {
        var url = '@Url.Action("Download_Declaration_form", "Home")';
        window.open(url,'_blank');
    }
</script>

<!--Generate PDF iNVOICING-->
<script type="text/javascript">
                   function GotoPDF() {
                          var fromdate = $('#txt_frm_date').val();
                       var todate = $('#txt_to_date').val();

                       if (fromdate != "") {
                           var url = '@Url.Action("GenerateGST_PDF", "Home")?frm_date=' + fromdate + '&to_date= ' + todate + '';
                           window.open(url, '_blank');
                       }
                   }
</script>


