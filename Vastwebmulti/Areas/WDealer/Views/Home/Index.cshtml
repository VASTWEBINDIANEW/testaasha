@model Vastwebmulti.Areas.WDealer.Models.WhitelabelRetailerModel
@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/WDealer/Views/Shared/_Layout.cshtml";
}
<style>
    .wdealer-dashboardclass ul li a, .wdealer-dashboardclass ul li {
        -webkit-background-clip: text !important;
        -moz-background-clip: text !important;
        -webkit-text-fill-color: transparent;font-size:16px;
    }
    .wdealer-dashboardclass ul li{list-style:none;display:inline-block;}
    .wdealer-dashboardclass ul{padding:0;}
    .wdealer-addnew button{color: #FFF;
background-color: @PageData["Globalfirst"] !important;
cursor: pointer;height: 35px;line-height: 35px;padding: 0 1.5rem;font-size: 15px !important;font-weight: 600;font-family: 'Roboto', sans-serif;letter-spacing: .8px;
text-align: center;text-decoration: none;text-transform: uppercase;white-space: nowrap;outline: none;border: none !important;border-radius: 2px !important;
-webkit-transition: all .3s ease-out;transition: all .3s ease-out;box-shadow: 0 2px 5px 0 rgba(0, 0, 0, 0.225);}
    .wdealer-tabledata-all table {background: #f5f5f5;}
.wdealer-tabledata-all table, .wdealer-tabledata-all table tr, .wdealer-tabledata-all table tr th, .wdealer-tabledata-all table tr td {
    border-color: #ddd !important;border: 1px solid;
}
    .wdealer-tabledata-all table tr th, .wdealer-tabledata-all table tr td {padding: 8px 5px;}
    .wdealer-modal-dialog{float:right;margin-top:0;z-index:9999;}
    .wdealer-modal-dialog .modal-body .col-md-6 {padding: 0;float: left;}
    .wdealer-modal-dialog .modal-body .form-control-label {text-align: left;}
    .wdealer-modal-dialog .modal-body .col-md-12 {padding-left: 0;}
    .wdealer-modal-dialog .modal-body {padding-right: 10px !important;}
    .wdealer-modal-dialog .modal-body .form-group {margin-bottom: 8px;}
    .wdealer-modal-dialog .modal-body .form-group div {border: 0 !important;}
    .wdealer-modal-dialog .modal-body .form-group input, .wdealer-modal-dialog .modal-body .form-group textarea, .wdealer-modal-dialog .modal-body .form-group select ,.wdealer-modal-dialog .modal-body .form-group button{
    border: 1px solid #ddd;

}
        .wdealer-modal-dialog .modal-body .form-control-label label {color: #777;}

    .select2-container--default .select2-selection--single {border: 1px solid #ddd !important;border-radius: 0px !important;height: 32px !important;}
    .wdealer-modal-dialog .modal-body .form-group span.select2.select2-container {width: 100% !important;}
    .wdealer-state .dropdown-menu.open {top: 31px;margin: 0 !important;padding-top: 0;}
    .wdealer-modal-dialog .modal-footer button {border: 1px solid #757575 !important;}
    .wdealer-modal-dialog .modal-footer button span{top:0 !important;}
    .modal-dialog.wdealer-modal-dialog .modal-header.navbar {padding: 10px 15px;}
    .modal-dialog.wdealer-modal-dialog .modal-body {margin-top: 0 !important;padding-top: 0;}
    .modal-dialog.wdealer-modal-dialog .modal-header.navbar {margin-bottom: 0;}
    .wdealer-tabledataclass table tr td .col-xs-4 {margin-bottom: 0 !important;width: 100%;}
    .wdealer-tabledataclass table tr td .onoffswitch span {font-size: 0;}
    .wdealer-tabledataclass table tr td .onoffswitch span{background:url('../../../../ashok-images/correct.svg')no-repeat;content:"";display:block;width: 20px;
height: 20px;background-color: green;border-radius: 50%;background-position: center;float: left;margin-right: 3px;background-size: 11px;background-position:4px;
    }
    .wdealer-tabledataclass table tr td .onoffswitch span.custom-off{
        background:url('../../../../ashok-images/closes.svg')no-repeat;background-color:red;background-size: 11px;background-position: 5px;
    }
    .wdealer-tabledataclass table tr td .onoffswitch {float: left;margin-top: -2px;}
    .wdealer-tabledataclass table tr td, .wdealer-tabledataclass table tr th {white-space: nowrap;}
    .wdealeraddnewbutton {width: 100%;float: left;}
    @@media screen and (max-width:767px){
        .wdealer-indexpage {padding-left: 0;}

        .wdealer-tabledataclass .table-responsive {border: none;padding-bottom: 15px;}
        .wdealer-modal-dialog .col-md-6 {width: 50%;float: left;}
        .wdealer-modal-dialog .col-md-12 {width: 100%;float: left;}
        .wdealer-modal-dialog {width: 98%;float: right;margin: 0;}

    }
    @@media screen and (max-width:480px){
        .wdealeraddnewbutton .wdealer-dashboardclass {width: 100% !important;float: left;}
        .wdealer-tabledataclass {margin-top: 15px !important;}
        .wdealer-modal-dialog .modal-body .col-md-6 {width: 100%;}
    }

</style>
<section class="content">
    <div class="container-fluid wdealer-indexpage">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="wdealeraddnewbutton">
                        <div class="wdealer-dashboardclass" style="width: auto; float: left; ">
                            <ul>
                                <li class="smli">
                                    <a href="@Url.Action("Dashboard","Home")" class="tmw-total-color-one" style="background-image: linear-gradient(to right , @PageData["Globalfirst"], @PageData["GlobalSecond"]);text-decoration:none;">
                                        Dashboard&nbsp;<img src="/ashok-images/rightaeps.svg" alt="right-arrow" style="width: 12px; margin-top: -2px;">
                                    </a>
                                </li>

                                <li class="fullbodydycolorbg tmw-total-color-one" style="background-image: linear-gradient(to right , @PageData["Globalfirst"], @PageData["GlobalSecond"]);">
                                    Show All Retailer's Details
                                </li>
                            </ul>
                        </div>

                        <div class="col-md-2 wdealer-addnew" style="width:auto;float:right;padding:0;">
                            <button type="button" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left: -3px; height:34px;" data-toggle="modal" data-target="#defaultModal">
                                <i class="fa fa-plus" style="top:-1px;font-size:15px;color:#fff;"></i>
                                <span style="top:-2px;color:#fff;">Add&nbsp;New</span>
                            </button>

                        </div>

                    </div>
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 wdealer-tabledataclass" style="margin-top:-21px;">
                <div class="card wdealer-tabledata-all">
                    <div class="body" style="padding:3px;">
                        <div class="table-responsive" style="position:inherit;">
                            <table class="table table-bordered table-striped" style="width:100%;font-size:12px;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>SR</th>
                                        <th style="padding-right: 96px;">Firm&nbsp;Information</th>
                                        <th>Name</th>
                                        <th>Registered&nbsp;Email&nbsp;Id</th>
                                        <th>Mobile&nbsp;No</th>
                                        <th>Remain&nbsp;Value</th>
                                        <th>State</th>
                                        <th>District</th>
                                        <th>Full&nbsp;Address</th>

                                        <th>Join&nbsp;Date</th>
                                        <th style="padding-right:30px;">Edit</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.dealer_retailer != null)
                                    {
                                        int i = 1;
                                        foreach (var item in Model.dealer_retailer)
                                        {
                                            var pendingColor = "";
                                            if (item.Emailconfirmed == false)
                                            {
                                                pendingColor = "#fff8d1";
                                            }

                                            <tr style="background:no-repeat;">
                                                <td>@i</td>
                                                <td>
                                                    <div class="onoffswitch">
                                                        @if (item.Status == "Y")
                                                        {
                                                            <span class="costom-on">Active</span>

                                                        }
                                                        else
                                                        {

                                                            <span class="custom-off">De</span>

                                                        }
                                                    </div>
                                                    @item.Frm_Name
                                                </td>
                                                <td>@item.RetailerName</td>
                                                <td>
                                                    <span style="background:@pendingColor;padding:2px 4px;">@item.Email</span>
                                                </td>
                                                <td>@item.Mobile</td>
                                                <td>@item.Remainamount</td>
                                                <td>@item.State_name</td>
                                                <td>@item.Dist_Desc</td>
                                                <td>@item.Address</td>

                                                <td>@item.JoinDate</td>
                                                <td>
                                                    <div class="row" style="margin:0px;">
                                                        <div class="col-xs-4" style="padding-left:0;padding-right:0;">
                                                            <button class="btn btn default" id="but" onclick="animation('@item.RetailerId')" style="background-color:transparent; border:none;border:1px solid #c7c2c2;height:23px; padding:1px 6px 1px 6px;" title="Edit Information">
                                                                Edit
                                                            </button>

                                                        </div>
                                                    </div>
                                                </td>
                                                @*<td style="padding:9px;">
                                                        @if (item.Status == "Y")
                                                        {
                                                            <center style="margin-top:-15px;">
                                                                <a href="#" style="text-decoration:none;border:1px solid #c7c2c2;padding:2px 0px 2px 4px;">
                                                                    <i class="fa fa-thumbs-o-up" style="margin-top:-34px;">&nbsp;<span>I'm&nbsp;Active&nbsp;</span></i>
                                                                </a>
                                                            </center>
                                                        }
                                                        else
                                                        {
                                                            <center style="margin-top:-15px;">
                                                                <a href="#" style="text-decoration:none;border:1px solid #c7c2c2;padding:2px 11px 2px 11px;">
                                                                    <i class="fa fa-thumbs-o-down" style="color:red;margin-top:-34px;">&nbsp;<span>Inactive</span></i>
                                                                </a>
                                                            </center>

                                                        }
                                                    </td>
                                                    <td style="padding:9px;">
                                                        @if (item.Emailconfirmed == true)
                                                        {
                                                            <a href="#" style="text-decoration:none;border:1px solid #c7c2c2;padding:2px 7px 2px 10px">
                                                                <i class="fa fa-thumbs-o-up" style="margin-top:6px;">&nbsp;<span>I'm&nbsp;Verified&nbsp;!</span></i>
                                                            </a>

                                                        }
                                                        else
                                                        {
                                                            <a href="#" style="text-decoration:none;border:1px solid #c7c2c2;padding:2px 11px 2px 11px;">
                                                                <i class="fa fa-thumbs-o-down" style="color:red;margin-top:6px;">&nbsp;<span>Unverified&nbsp;!</span></i>
                                                            </a>

                                                        }
                                                    </td>

                                                    <td>
                                                        <div class="row">
                                                            <div class="col-xs-4">
                                                                <button class="btn btn default" id="but" onclick="animation('@item.RetailerId')" style="background-color:transparent; border:none;border:1px solid #c7c2c2;margin-top:4px; padding:1px 6px 1px 6px;" title="Edit Information">
                                                                    Edit
                                                                </button>

                                                            </div>
                                                            <div class="col-xs-4">
                                                                @if (item.Emailconfirmed == false)
                                                                {
                                                                    <button class="btn btn default" id="but" onclick="DelteDistributor('@item.RetailerId','@item.Email')" style="background-color:transparent; border:none;border:1px solid #c7c2c2;margin-top:4px; padding:1px 6px 1px 6px;margin-left:-16px;" title="Delete Information">
                                                                        Delete
                                                                    </button>
                                                                }

                                                            </div>
                                                            <div class="col-xs-4">
                                                                @if (item.Emailconfirmed == false)
                                                                {
                                                                    <a class="btn btn default" href="@Url.Action("ResendRetailerEmail", "Home", new { email = item.Email })" title="Resend Email " style="border:1px solid #c7c2c2; padding:1px 4px 1px 4px;margin-top:4px;margin-left:-17px;">
                                                                        Resend
                                                                    </a>
                                                                }
                                                            </div>
                                                        </div>
                                                    </td>*@


                                            </tr>
                                            i++;
                                        }

                                    }

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>


    </div>
</section>
<!--Add New   modal-->
<div class="modal fade" id="defaultModal" tabindex="-1" role="dialog">
    <div class="modal-dialog wdealer-modal-dialog" role="document" style="">
