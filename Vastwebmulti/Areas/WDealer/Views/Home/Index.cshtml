                                    <label for="email_address_2">Pancard</label>
                                </div>
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBoxFor(m => m.Pan, "", new { @class = "form-control", placeholder = "Enter Pancard No", maxlength = 10, @style = "text-transform:uppercase" })
                                        </div>
