                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBoxFor(m => m.Pincode, "", new { @class = "form-control", placeholder = "Enter Pin Code", required = "required", onkeypress = "return isNumber(event)", maxlength = "6" })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.Pincode, "", new { @class = "text-danger", onkeypress = "return isNumber(event)" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="col-md-12 form-control-label">
                                    <label for="email_address_2">Aadhar Card</label>
                                </div>
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBoxFor(m => m.Adhaar, "", new { @class = "form-control", placeholder = "Enter Aadharrcard No", onkeypress = "return isNumber(event)", maxlength = "12" })
                                        </div>
                                        @*@Html.ValidationMessageFor(m => m.Adhaar, "", new { @class = "text-danger" })*@
                                    </div>
                                </div>
                            </div>




                            @*<div class="row clearfix">
                                    <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
