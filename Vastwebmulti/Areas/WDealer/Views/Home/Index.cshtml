                                </button>
                                <button type="button" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left: -3px; height:34px;" data-dismiss="modal">
                                    <span style="top:-2px;color:black;">Close</span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<!--Edit  Modal-->
<div class="modal fade" id="defaultModal1" tabindex="-1" role="dialog">
    <div class="modal-dialog wdealer-modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header navbar" style="position:initial;background:@PageData["Globalfirst"];">
                <h4 class="modal-title" id="defaultModalLabel" style="color:white;">Edit Retailer User</h4>
            </div>
            @using (Html.BeginForm("Edit_Retailer_user", "Home", FormMethod.Post))
            {
                @Html.HiddenFor(m => m.Retailerid)
                <div class="modal-body" style="margin-top:-26px;">
                    <div class="body">
                        <form id="form_validation" method="POST">

                            <div class="col-md-6">
                                <div class="col-md-12 form-control-label">
                                    <label for="email_address_2">Name</label>
                                </div>
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBoxFor(m => m.Name1, "", new { @class = "form-control", placeholder = "Enter Name", required = "required" })

                                        </div>
                                        @Html.ValidationMessageFor(m => m.Name1, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="col-md-12 form-control-label">
