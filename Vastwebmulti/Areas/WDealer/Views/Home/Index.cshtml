                                    <label for="email_address_2">Mobile<span style="color: red">*</span></label>
                                </div>
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBoxFor(m => m.Mobile, "", new { @class = "form-control", required = "required", placeholder = "Enter Mobile Number", onkeypress = "return isNumber(event)", maxlength = "10" })
