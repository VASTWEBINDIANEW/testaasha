                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.DropDownListFor(m => m.Slab, ViewBag.slabname as SelectList, "Select Slab", new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;", required = "required" })
                                           </div>
                                            @Html.ValidationMessageFor(m => m.Slab, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>*@
                            <div class="col-md-6">
                                <div class="col-md-12 form-control-label">
                                    <label for="email_address_2">Pincode<span style="color: red">*</span></label>
