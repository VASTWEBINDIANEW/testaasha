<!--Edit Retailer Users users-->

<script type="text/javascript">
        var val1 = "";
    function animation(userid) {
            var url = '@Url.Action("RetailerSearch", "Home")';
            $.ajax({
                url: url,
                data: { userid: userid },
                cache: false,
                type: "POST",
                success: function (data) {
                    var rem = JSON.parse(data);

                    $("#Retailerid").val(rem[0].RetailerId);
                    $("#Name1").val(rem[0].RetailerName);
                    $("#Firm1").val(rem[0].Frm_Name);
                    $("#Address1").val(rem[0].Address);
                    $("#Pincode1").val(rem[0].Pincode);
                    $("#Pan1").val(rem[0].PanCard);
                    $("#Adhaar1").val(rem[0].AadharCard);
                    $("#Capping1").val(rem[0].caption);
                    $("#Gst1").val(rem[0].gst);
                    $("#State1").val(rem[0].State);
                    GetDistrict1(rem[0].State);
                    var objSelect1 = document.getElementById("District1");
                    binddist(rem[0].State, rem[0].District, objSelect1);
                    $('#defaultModal1').modal('show');
                },
                error: function (req,stmsg,reponse) {
                    alert("error : " + reponse + stmsg.st);
                }
            });

        }
      function binddist(staid, dist, objSelect1) {
          var url = '@Url.Action("DistrictList","Home")';
            $.ajax({
                url: url,
                data: { Id: staid },
                cache: false,
                type: "POST",
                success: function (data) {
                    var markup = "<option value='0'>Select District</option>";
                    for (var x = 0; x < data.length; x++) {
                        markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                    }
                    $("#District").html(markup).show();
                    setSelectedValue(objSelect1, dist);
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                }
            });
        }
    function setSelectedValue(selectObj, valueToSet) {

            for (var i = 0; i < selectObj.options.length; i++) {
                if (selectObj.options[i].value == valueToSet) {
                  selectObj.options[i].selected = true;
                    return;
                }
            }
        }
    function GetDistrict1(_stateId) {
        var procemessage = "<option value='0'> Please wait...</option>";
        $("#District1").html(procemessage).show();
        var url = '@Url.Action("DistrictList","Home")'
        $.ajax({
            url: url,
            data: { Id: _stateId },
            cache: false,
            type: "POST",
            success: function (data) {
                $("#District1").html("");
                for (var x = 0; x < data.length; x++) {
                $("#District1").append($('<option></option>').val(data[x].Value).html(data[x].Text));
                }

            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
    }
</script>




