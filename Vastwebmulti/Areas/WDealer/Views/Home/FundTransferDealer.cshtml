<script>
    $('.chkoldcredit').click(function () {
        $('.old-crd').show();
        $('.old-crd').html('Loading...')

        $.ajax({
            url: $(this).attr('data-oldcr'),
            success: function (data) {

                $('.old-crd').empty();
                if (data.diff > 0) {

                    $('.old-crd').html('CR. ' + data.diff)
                }
                else {
                    $('.old-crd').html('<b>No Old Credit Balance</b>')

                }

                $("#dealerbank").html("");

                $("#dealerbank").append($('<option></option>').val('').html('Select Bank'));
                for (var x = 0; x < data.listbank.length; x++) {
                    $("#dealerbank").append($('<option></option>').val(data.listbank[x].Value).html(data.listbank[x].Text));
                }
                $("#dealerwallets").html("");
                $("#dealerwallets").append($('<option></option>').val('').html('Select Wallet'));
                for (var x = 0; x < data.walletinfo.length; x++) {
                    $("#dealerwallets").append($('<option></option>').val(data.walletinfo[x].Value).html(data.walletinfo[x].Text));
                }
            }

        })


    })
</script>

<script>
    $('#btnnshowmaster1').click(function () {
        var cashdepositcharge = $('#hdcashdepositcharge').val()
        var currentcr = $('#hdcurrentcr').val()
        var netamount = $('#hdnetamount').val()
        $('#hdcashdepositcharge').val(0)
        $('#hdcurrentcr').val(0)
        $('#hdnetamount').val(0)
        $('#hdninputvalues').empty();


        if ($('#ddlretailerID').val() == '' || $('#ddlretailerID').val() == null) {
            $("#errorss").text('Retailer REQUIRED');
            return false;
        }
        if ($('#idst').val() == '' || $('#idst').val() == null) {
            $("#errorss").text('Pay mode REQUIRED');
            return false;
        }
        if ($('#idst').val() == "Cash") {
            if ($('#txtmddistcollperson').val() == '' || $('#txtmddistcollperson').val() == null) {
                $("#errorss").text('Collection Person Name');
                return false;
            }
            if ($('#mddistamount').val() == '' || $('#mddistamount').val() == null) {
                $("#errorss").text('Amount Required');
