@model IEnumerable<Vastwebmulti.Models.Whitelabel_bank_info>
@{
    ViewBag.Title = "Bank_Details";
    Layout = "~/Areas/WDealer/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    <div class="header" style="padding:10px; padding-left:12px;">
                        <h2>
                            <i class="fa fa-university" aria-hidden="true"></i>&nbsp;&nbsp;<span style="font-size:21px;">Bank Details</span>
                        </h2>
                    </div>
                </div>
            </div>
        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">
        <div class="body" style="margin-top:-20px;">
            <div class="row">
        @foreach (var item in Model)
        {
                <div class="col-md-6">
                    <table border="1" style="margin-top:5px;margin-left:10px; margin-bottom:5px; float:left;">
                        <tr>
                            <th class="navbar" style="width:220px; height: 42px; font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:white; position:initial;">
                                Bank Name
                            </th>
                            <th style="width:320px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;">
                                @Html.DisplayFor(modelItem => item.banknm)
                            </th>
                        </tr>
                        <tr>
                            <th class="navbar" style="width:220px;   height: 42px; font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:white;position:initial;">
                                Branch Name
                            </th>
                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;">
                                @Html.DisplayFor(modelItem => item.branch_nm)
                            </th>
                        </tr>
                        <tr>
                            <th class="navbar" style="width:220px;  height: 42px; font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:white;position:initial;">
                                IFSC CODE
                            </th>
                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;">
                                @Html.DisplayFor(modelItem => item.ifsccode)
                            </th>
                        </tr>
                        <tr>
                            <th class="navbar" style="width:220px; height: 42px; font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:white;position:initial;">
                                Account Number
                            </th>
                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;">
                                @Html.DisplayFor(modelItem => item.acno)
                            </th>
                        </tr>
                        <tr>
                            <th class="navbar" style="width:220px; height: 42px; font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:white;position:initial;">
                                Account Type
                            </th>
                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;">
                                @Html.DisplayFor(modelItem => item.actype)
                            </th>
                        </tr>
                        <tr>
                            <th class="navbar" style="width:220px; height: 42px; font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:white; position:initial;">
                                Account Holder Name
                            </th>
                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;">
                                @Html.DisplayFor(modelItem => item.holdername)
                            </th>
                        </tr>
                        <tr>
                            <th class="navbar" style="width:220px;  height: 42px; font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:white;position:initial;">
                                Branch Address
                            </th>
                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;">
                                @Html.DisplayFor(modelItem => item.address)
                            </th>
                        </tr>
                    </table>
                </div>
        }
            </div>
         </div>
         </div>
        </div>
                        

        </div>
    </div>


</section>

