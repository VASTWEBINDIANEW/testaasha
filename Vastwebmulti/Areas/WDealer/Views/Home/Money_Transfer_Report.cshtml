                                                var color = "";
                                                var fontsize = "";
                                                var rchtype = "";
                                                var rchtypeicon = "";
                                                var dmtytpe = "";

                                                if (item.status.Contains("REFUND") || item.status.Contains("REFUND AGAINST"))
                                                {
                                                    color = "#673AB7";
                                                    fontsize = "9px;";
                                                }
                                                if (item.status.ToUpper().Contains("PENDING"))
                                                {
                                                    color = "#FF9800";
                                                }
                                                if (item.status.ToUpper().Contains("SUCCESS"))
                                                {
                                                    color = "green";
                                                }
                                                if (item.status.ToUpper().Contains("FAILED"))
                                                {
                                                    color = "red";
                                                }
                                                if (item.trans_from == "ONLINE")
                                                {
                                                    rchtype = "WEB";
                                                    rchtypeicon = "fa fa-globe";
                                                }
                                                if (item.trans_from == "API")
                                                {
                                                    rchtype = "WEB";
                                                    rchtypeicon = "fa fa-globe";

                                                }
                                                if (item.trans_from == "Apps")
                                                {
                                                    rchtype = "APP";
                                                    rchtypeicon = "fa fa-android";
                                                }
                                                if (item.DmtType == "DMT1")
                                                {
                                                    dmtytpe = "➊";
                                                }
                                                if (item.DmtType == "DMT2")
                                                {
                                                    dmtytpe = "➋";
                                                }
                                                <tr>
                                                    <td style="color:@color;font-weight:700;font-size:@fontsize;">@item.status&nbsp;<i class="@rchtypeicon" style="font-size:12px;"></i></td>
                                                    <td>@item.senderno</td>
                                                    <td>@item.accountno&nbsp;⇒&nbsp;@item.recivername</td>
                                                    <td>
                                                        @if (item.Trans_type == "IMPS")
                                                        {
                                                            <p style="font-size:15px;margin-left:-7px;margin-top:-3px;font-weight:normal;padding:1px 11px 1px 11px;margin-bottom:0px;border:1px solid #dddddd;border-left:3px solid @color;" title="View" data-toggle="modal" data-target="#largeModal">@dmtytpe&nbsp;<span style="font-size:12px;font-weight:bold;">IMPS</span></p>

                                                        }
                                                        else if (item.Trans_type == "NEFT")
                                                        {

                                                            <p style="font-size:15px;margin-left:-7px;margin-top:-3px;font-weight:normal;padding:1px 11px 1px 11px;margin-bottom:0px;border:1px solid #dddddd;border-left:3px solid @color;" title="View" data-toggle="modal" data-target="#largeModal">@dmtytpe&nbsp;<span style="font-size:12px;font-weight:bold">NEFT</span></p>

                                                        }
                                                        else
                                                        {

                                                            <p style="font-size:15px;margin-left:-7px;margin-top:-3px;font-weight:normal;padding:1px 11px 1px 11px;margin-bottom:0px;border:1px solid #dddddd;border-left:3px solid @color;" title="View" data-toggle="modal" data-target="#largeModal">@dmtytpe&nbsp;<span style="font-size:12px;font-weight:bold">Verify</span></p>

                                                        }
                                                    </td>
                                                    <td><span style="font-size:11px;">@String.Format("{0:dd-MMM HH:mm:ss}", item.trans_time)</span></td>
                                                    <td>
                                                        @{
                                                            decimal amount = 0;
                                                            decimal customerfee = 0;
                                                            decimal total = 0;
                                                            decimal debit = 0;
                                                            decimal remcomm = 0;
                                                            if (item.Trans_type.Contains("IMPS_VERIFY"))
                                                            {
                                                                amount = Convert.ToDecimal(item.amount);
                                                                customerfee = Convert.ToDecimal(item.income);
                                                                customerfee = customerfee - amount;
                                                                total = amount + customerfee;
                                                                debit = Convert.ToDecimal(item.income);
                                                            }
                                                            else
                                                            {
                                                                amount = Convert.ToDecimal(item.amount);
                                                                customerfee = Convert.ToDecimal(item.customer_fee);
                                                                total = amount + customerfee;
                                                                remcomm = Convert.ToDecimal(item.income);
                                                                debit = amount + remcomm;

                                                            }
                                                        }
                                                        @item.amount&nbsp;&#x002B;&nbsp;@customerfee&nbsp;=&nbsp;@total
                                                    </td>
                                                    <td>@item.totalamount</td>
                                                    <td>
                                                        @{
                                                            int dlmshare_comm = 0;
                                                            int dlm_comm_include_gst = 0;
                                                            if ((item.status.Contains("REFUND") || item.status.Contains("REFUND AGAINST")) && item.Trans_type.Contains("IMPS_VERIFY"))
                                                            {

                                                                <p></p>
                                                            }
                                                            else
                                                            {
                                                                dlmshare_comm = Convert.ToInt32(item.share_dlm_comm);
                                                                dlm_comm_include_gst = Convert.ToInt32(item.dlm_comm_include_gst);
                                                                <p>@dlmshare_comm&nbsp;%&nbsp;│&nbsp;@dlm_comm_include_gst&nbsp;₹</p>
                                                            }
                                                        }
                                                    </td>
                                                    <td>
                                                        @if ((item.status.Contains("REFUND") || item.status.Contains("REFUND AGAINST")) && item.Trans_type.Contains("IMPS_VERIFY"))
                                                        {

                                                            <p></p>
                                                        }
                                                        else
                                                        {
                                                            <p>@item.dlm_gst&nbsp;│&nbsp;@item.dlm_comm_tds</p>
                                                        }

                                                    </td>
                                                    <td>@item.dlm_income</td>
                                                    <td>

                                                        @item.dlm_remain_pre&nbsp;│&nbsp;@item.dlm_remain

                                                    </td>
                                                    <td>@item.bank_trans_id</td>
                                                    <td>@item.bank_nm</td>
                                                    <td>@item.ifsccode</td>
                                                    <td>&nbsp;@item.trans_id</td>
                                                    <td>&nbsp;@item.trans_common_id</td>
                                                    <td>@item.email</td>
                                                    <td>@item.retailername</td>
                                                    <td>@item.frm_name</td>
                                                    <td>
                                                        <p>
                                                            <span>@item.user_remain_pre</span><span style="padding-left:28px;">&nbsp;│&nbsp;</span>@debit<span style="padding-left:28px;">&nbsp;│&nbsp;</span><span>@item.user_remain</span>

                                                        </p>

                                                    </td>
                                                    @*<td>@item.totalamount</td>*@
                                                    <td>@item.response_time</td>
                                                </tr>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                foreach (var item in Model.Money_old)
                                                                {
                                                                    var color = "";
                                                                    var fontsize = "";
                                                                    var rchtype = "";
                                                                    var rchtypeicon = "";
                                                                    var dmtytpe = "";

                                                                    if (item.status.Contains("REFUND") || item.status.Contains("REFUND AGAINST"))
                                                                    {
                                                                        color = "#673AB7";
                                                                        fontsize = "9px;";
                                                                    }
                                                                    if (item.status.ToUpper().Contains("PENDING"))
                                                                    {
                                                                        color = "#FF9800";
                                                                    }
                                                                    if (item.status.ToUpper().Contains("SUCCESS"))
                                                                    {
                                                                        color = "green";
                                                                    }
                                                                    if (item.status.ToUpper().Contains("FAILED"))
                                                                    {
                                                                        color = "red";
                                                                    }
                                                                    if (item.trans_from == "ONLINE")
                                                                    {
                                                                        rchtype = "WEB";
                                                                        rchtypeicon = "fa fa-globe";
                                                                    }
                                                                    if (item.trans_from == "API")
                                                                    {
                                                                        rchtype = "WEB";
                                                                        rchtypeicon = "fa fa-globe";

                                                                    }
                                                                    if (item.trans_from == "Apps")
                                                                    {
                                                                        rchtype = "APP";
                                                                        rchtypeicon = "fa fa-android";
                                                                    }
                                                                    if (item.DmtType == "DMT1")
                                                                    {
                                                                        dmtytpe = "➊";
                                                                    }
                                                                    if (item.DmtType == "DMT2")
                                                                    {
                                                                        dmtytpe = "➋";
                                                                    }
                                                                    <tr>
                                                                        <td style="color:@color;font-weight:700;font-size:@fontsize;">@item.status&nbsp;<i class="@rchtypeicon" style="font-size:12px;"></i></td>
                                                                        <td>@item.senderno</td>
                                                                        <td>@item.accountno&nbsp;⇒&nbsp;@item.recivername</td>
                                                                        <td>
                                                                            @if (item.Trans_type == "IMPS")
                                                                            {
                                                                                <p style="font-size:15px;margin-left:-7px;margin-top:-3px;font-weight:normal;padding:1px 11px 1px 11px;margin-bottom:0px;border:1px solid #dddddd;border-left:3px solid @color;" title="View" data-toggle="modal" data-target="#largeModal">@dmtytpe&nbsp;<span style="font-size:12px;font-weight:bold;">IMPS</span></p>

                                                                            }
                                                                            else if (item.Trans_type == "NEFT")
                                                                            {

                                                                                <p style="font-size:15px;margin-left:-7px;margin-top:-3px;font-weight:normal;padding:1px 11px 1px 11px;margin-bottom:0px;border:1px solid #dddddd;border-left:3px solid @color;" title="View" data-toggle="modal" data-target="#largeModal">@dmtytpe&nbsp;<span style="font-size:12px;font-weight:bold">NEFT</span></p>

                                                                            }
                                                                            else
                                                                            {

                                                                                <p style="font-size:15px;margin-left:-7px;margin-top:-3px;font-weight:normal;padding:1px 11px 1px 11px;margin-bottom:0px;border:1px solid #dddddd;border-left:3px solid @color;" title="View" data-toggle="modal" data-target="#largeModal">@dmtytpe&nbsp;<span style="font-size:12px;font-weight:bold">Verify</span></p>

                                                                            }
                                                                        </td>
                                                                        <td><span style="font-size:11px;">@String.Format("{0:dd-MMM HH:mm:ss}", item.trans_time)</span></td>
                                                                        <td>
                                                                            @{
                                                                                decimal amount = 0;
                                                                                decimal customerfee = 0;
                                                                                decimal total = 0;
                                                                                decimal debit = 0;
                                                                                decimal remcomm = 0;
                                                                                if (item.Trans_type.Contains("IMPS_VERIFY"))
                                                                                {
                                                                                    amount = Convert.ToDecimal(item.amount);
                                                                                    customerfee = Convert.ToDecimal(item.income);
                                                                                    customerfee = customerfee - amount;
                                                                                    total = amount + customerfee;
                                                                                    debit = Convert.ToDecimal(item.income);
                                                                                }
                                                                                else
                                                                                {
                                                                                    amount = Convert.ToDecimal(item.amount);
                                                                                    customerfee = Convert.ToDecimal(item.customer_fee);
                                                                                    total = amount + customerfee;
                                                                                    remcomm = Convert.ToDecimal(item.income);
                                                                                    debit = amount + remcomm;

                                                                                }
                                                                            }
                                                                            @item.amount&nbsp;&#x002B;&nbsp;@customerfee&nbsp;=&nbsp;@total
                                                                        </td>
                                                                        <td>@item.totalamount</td>
                                                                        <td>
                                                                            @{
                                                                                int dlmshare_comm = 0;
                                                                                int dlm_comm_include_gst = 0;
                                                                                if ((item.status.Contains("REFUND") || item.status.Contains("REFUND AGAINST")) && item.Trans_type.Contains("IMPS_VERIFY"))
                                                                                {

                                                                                    <p></p>
                                                                                }
                                                                                else
                                                                                {
                                                                                    dlmshare_comm = Convert.ToInt32(item.share_dlm_comm);
                                                                                    dlm_comm_include_gst = Convert.ToInt32(item.dlm_comm_include_gst);
                                                                                    <p>@dlmshare_comm&nbsp;%&nbsp;│&nbsp;@dlm_comm_include_gst&nbsp;₹</p>
                                                                                }


                                                                            }


                                                                        </td>
                                                                        <td>
                                                                            @if ((item.status.Contains("REFUND") || item.status.Contains("REFUND AGAINST")) && item.Trans_type.Contains("IMPS_VERIFY"))
                                                                            {

                                                                                <p></p>
                                                                            }
                                                                            else
                                                                            {
                                                                                <p>@item.dlm_gst&nbsp;│&nbsp;@item.dlm_comm_tds</p>
                                                                            }

                                                                        </td>
                                                                        <td>@item.dlm_income</td>
                                                                        <td>

                                                                            @item.dlm_remain_pre&nbsp;│&nbsp;@item.dlm_remain

                                                                        </td>
                                                                        <td>@item.bank_trans_id</td>
                                                                        <td>@item.bank_nm</td>
                                                                        <td>@item.ifsccode</td>
                                                                        <td>&nbsp;@item.trans_id</td>
                                                                        <td>&nbsp;@item.trans_common_id</td>
                                                                        <td>@item.email</td>
                                                                        <td>@item.retailername</td>
                                                                        <td>@item.frm_name</td>
                                                                        <td>
                                                                            <p>
                                                                                <span>@item.user_remain_pre</span><span style="padding-left:28px;">&nbsp;│&nbsp;</span>@debit<span style="padding-left:28px;">&nbsp;│&nbsp;</span><span>@item.user_remain</span>

