@model Vastwebmulti.Areas.WDealer.Models.Money_transfer_Report_whitelabel
@{
    ViewBag.Title = "Money_Transfer_Report";
    Layout = "~/Areas/WDealer/Views/Shared/_Layout.cshtml";
}
<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 81px !important;
    }

    .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {
        height: 20px;
    }
</style>

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    <div class="">
                        <div class="col-md-7">
                            <div style="margin-left:-13px;">
                                <p style="font-size:20px;margin-top:6px;">Money Transfer&nbsp;Report&nbsp;&nbsp;</p>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="row">
                                <div class="form-group" style="margin-top:-18px; ">
                                    <div style="padding-top: 22px;  margin-right: 4px; float:right;">

                                        <button type="button" class="btn btn-success waves-effect" style="margin-top:2px;" title="Total Imps Success"><i style="font-size:15px;top:1px;" class="fa fa-check-circle-o" aria-hidden="true"></i>&nbsp;@ViewData["totals"]</button>
                                        <button type="button" class="btn btn-danger waves-effect" style="margin-top:2px;" title="Total Imps Failed"><i style="font-size:15px;top:1px;" class="fa fa-times-circle-o" aria-hidden="true"></i>&nbsp;@ViewData["totalf"]</button>
                                        <button type="button" class="btn btn-warning waves-effect" style="margin-top:2px;" title="Total Imps Pending"><i style="font-size:15px;top:1px;" class="fa fa-question-circle-o" aria-hidden="true"></i>&nbsp;@ViewData["totalp"]</button>

                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                @using (Html.BeginForm("Money_Transfer_Report", "Home", FormMethod.Post))
            {
                    <div class="card" style="margin-top: -17px;">
                        <div class="">
                            <div class="col-md-2" style="display:block;" id="rem">
                                <div class="form-group">
                                    <div class="" style="margin-top:4px;border:1px solid #dddddd;padding-bottom:10px;">
                                        @Html.DropDownList("allretailer", ViewBag.allretailer as SelectList, "All Retailer", new { id = "allretailer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-1">
                                <div class="form-group">
                                    <div class="" style="margin-top:4px;border:1px solid #dddddd;padding-bottom:10px;">
                                        @Html.DropDownList("ddl_top", new List<SelectListItem>
                                {
                                new SelectListItem{ Text="50",Value="50"},
                                new SelectListItem{Text="100",Value="100"},
                                new SelectListItem{Text="200",Value="200"},
                                new SelectListItem{Text="500",Value="500"},
                                new SelectListItem{Text="1500",Value="1500"},
                                new SelectListItem{Text="All",Value="All"}
                                }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                    </div>

                                </div>
                            </div>
                            <div class="col-md-1">
                                <div class="form-group">
                                    <div class="" style="margin-top:4px;border:1px solid #dddddd;padding-bottom:10px;">
                                        @Html.DropDownList("ddl_status", new List<SelectListItem>
                                {
                                new SelectListItem{ Text="Status",Value="ALL",},
                                new SelectListItem{Text="SUCCESS",Value="SUCCESS"},
                                new SelectListItem{Text="Pending",Value="PENDING"},
                                new SelectListItem{Text="FAILED",Value="FAILED"}
                                }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })

                                    </div>

                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="" style="margin-top:4px;border:1px solid #dddddd;padding-bottom:10px;">
                                    @Html.DropDownList("api_name", ViewBag.apiname as SelectList, "Select Api Name", new { @style = "margin-top:0px", @class = "selectpicker form-control", data_live_search = "true", })
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group" style="margin-bottom:0px;margin-top:0px;">
                                    <div class="input-daterange input-group">
                                        @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;height:33px;", autocomplete = "off" })
                                        <span class="input-group-addon">
                                            <i class="fa fa-exchange"></i>
                                        </span>
                                        @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;height:33px;", autocomplete = "off" })
                                    </div>
                                    <!-- /.input group -->
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <div class="form-line" style="border-bottom:none;">
                                        <button value="LIVE" type="submit" class="btn" id="btntype" name="btntype" style="margin-top:5px; margin-left:2px; height:32px;border:1px solid #c7c2c2;background:#dedddd;">
                                            <i class="fa fa-search" style="top:-1px;font-size:13px;color:black;"></i>
                                            <span style="top:-1px;color:black;">Today</span>
                                        </button>
                                        <button value="OLD" type="submit" class="btn" id="btntype" name="btntype" style="margin-top:5px; margin-left:2px; height:32px;border:1px solid #c7c2c2;background:#dedddd;">
                                            <i class="fa fa-search" style="top:-1px;font-size:13px;color:black;"></i>
                                            <span style="top:-1px;color:black;">OLD</span>
                                        </button>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

            </div>

        </div>
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card" style="margin-top:-27px;">
                    <div class="">
                        <ol class="breadcrumb breadcrumb-col-blue-grey" style="margin-left:5px;margin-top:9px;">
                            <li class="active" style="color:#9E9E9E; font-size:12px;">MONEY TRANSFER REPORT&nbsp;></li>
                        </ol>
                    </div>

                    <div class="body" style="margin-top: -62px;">
                        <div class="row">
                            <div class="table-responsive" style="position:inherit;">
                                <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%; font-size:12px;">
                                    <thead style="color:white; position:initial;" class="navbar">
                                        <tr>
                                            <th style="width:100px;">Status</th>
                                            <th>Sender&nbsp;No</th>
                                            <th>Beneficiary&nbsp;Account&nbsp;Information</th>
                                            <th>Type</th>
                                            <th>Request&nbsp;Date</th>
                                            <th>Transfer&nbsp;&#x002B;&nbsp;Fee&nbsp;=&nbsp;Total</th>
                                            <th>Total.Trans</th>
                                            <th>My&nbsp;Sharing</th>
                                            <th>GST&nbsp;│&nbsp;TDS</th>
                                            <th>Net&nbsp;INC</th>
                                            <th>Pre&nbsp;Amt&nbsp;&nbsp;&nbsp;│&nbsp;&nbsp;&nbsp;Post&nbsp;Amt</th>
                                            <th>Bank&nbsp;Ref&nbsp;No</th>
                                            <th>Bank&nbsp;Name</th>
                                            <th>IFSC&nbsp;Code</th>
                                            <th>Request&nbsp;ID</th>
                                            <th>Common&nbsp;Trans&nbsp;ID</th>
                                            <th>REM&nbsp;ID</th>
                                            <th>REM&nbsp;Name</th>
                                            <th>REM&nbsp;Frm&nbsp;Name</th>
                                            <th>
                                                <span>REM.Pre&nbsp;Amt&nbsp;</span><span style="padding-left:-4px;">&nbsp;│&nbsp;</span>Debit<span style="padding-left:38px;">&nbsp;│&nbsp;</span><span>REM.Post&nbsp;Amt</span>
                                            </th>
                                            @*<th>Total&nbsp;Amount</th>*@
                                            <th>Response&nbsp;Date</th>


                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.Money_live != null)
                                        {
                                            foreach (var item in Model.Money_live)
