@model List<Vastwebmulti.Models.proc_getEcommTransactionHistory_Result>
@{
    ViewBag.Title = "Transaction";
    Layout = "~/Areas/WRetailer/Views/Shared/_Layout.cshtml";
}
<section class="content" style="margin: 75px 0px 0 0px;">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="body">
                        <div class="demo-button">
                            <div class="row">
                                <div class="col-md-6" style="margin-top:-10px;">

                                    </div>
                                    <div class="col-md-6" style="margin-top:-10px;">
                                        <a href="@Url.Action("Index","ECommerce")" class="btn bg-indigo waves-effect" style="float:right;">
                                            <i class="material-icons">shopping_cart</i>
                                            <span>Continue&nbsp;Shoping</span>
                                        </a>
                                    </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-58px;">
                <div class="card">
                    <div class="">
                        <h2 style="color:black; font-size:16px;padding-top:9px; padding-left:22px;">
                            All Catagories Details
                        </h2>

                    </div>
                    <div class="body" id="lstProduct">
                        <div class="table-responsive" style="position:inherit;margin-top:-20px;">
                            <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%;">
                                <thead class="navbar" style="color:white;position:inherit;">
                                    <tr>
                                        <th style="padding-left:2px;">TXN&nbsp;ID</th>
                                        <th style="padding-left:2px;">Name</th>
                                        <th style="padding-left:2px;">Product</th>
                                        @*<th style="padding-left:2px;">List&nbsp;Price</th>*@
                                        <th style="padding-left:2px;">Price</th>
                                        <th style="padding-left:2px;">QTY</th>
                                        <th style="padding-left:2px;">Amount</th>
                                        <th style="padding-left:2px;">Status</th>
                                        @*<th style="padding-left:2px;">MIN&nbsp;Order&nbsp;QTY</th>
                        <th style="padding-left:2px;">MAX&nbsp;Order&nbsp;QTY</th>*@
                                        <th style="padding-left:2px;">Invoice</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                               {
                                        <tr>
                                            <td style="padding:3px;">@item.Idno</td>
                                            <td style="padding:3px;">@item.Buyer</td>
                                            <td style="padding:3px;">@item.Name</td>
                                            @*<td style="padding:3px;">@String.Format("{0:C2}", item.StandardPrice)</td>*@
                                            <td style="padding:3px;"> @String.Format("{0:C2}", item.StandardPrice)</td>
                                            <td style="padding:3px;">@item.QTY</td>
                                            <td style="padding:3px;">@item.Amount</td>
                                            @if (item.OrderStatus == 1)
                                            {
                                                <td style="padding:3px;">In Process</td>
                                            }
                                            else if (item.OrderStatus == 3)
                                            {
                                                <td style="padding:3px;">Cencelled</td>
                                            }
                                            else if (item.OrderStatus == 2)
                                            {
                                                <td style="padding:3px;">Delivered</td>
                                            }
                                         <td style="padding:3px;">
                                             <div class="icon" style="text-align:center;" title="GST INVOICE">
                                                 <a href="@Url.Action("EcommInvoicePdf",new { OrderID = item.OrderId})" target="_blank">
                                                     <i class="material-icons" style="font-size: 39px;line-height: 42px;">receipt</i>
                                                 </a>
                                                 
                                             </div>
                                         </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

