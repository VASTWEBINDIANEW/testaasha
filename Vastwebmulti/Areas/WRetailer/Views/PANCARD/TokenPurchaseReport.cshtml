<script>
    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 45 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }
</script>
<!--Calendar Javascript-->
<script>
    $(function () {

        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

    });
</script>
<script>
    function tokenStatus(id) {
        var url = '@Url.Action("GetTokenStatus", "PANCARD")'
        var jqxhr = $.post(url, {id : id}, function (data) {
            var response = JSON.parse(data);
            if (response.RESULT == "0") {
                swal("Wow!", response.ADDINFO, "success");
                window.location.reload();
            }
            else {
                swal("Oops!!!", response.ADDINFO, "error");
            }
        })
       .fail(function (jqXHR, textStatus, errorThrown) {

           swal("Oops!!!", jqXHR.responseText, "error");

       })

    }
</script>

<script>
    $(".input-whitelabel input").click(function () {
        $(".datepicker").addClass('whitedate-first-aeps-date');
    });


</script>