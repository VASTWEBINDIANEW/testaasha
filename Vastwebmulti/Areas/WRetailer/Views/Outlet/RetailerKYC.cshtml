<script>
    function ViewKYCstatus()
    {

        var Pan = '@Model.PanCard';
        var RetailerId = '@Model.RetailerId';
        $("#loader").show();
        var url = '@Url.Action("ViewKYCDocsAndStatus", "Outlet")';
        var jqxhr = $.post(url, { "RetailerID": RetailerId, "PanCard": Pan }, function (data) {
            $("#loader").hide();
            //alert("success");
            //alert(data);
            var response = JSON.parse(data);
            if (response.RESULT == "0") {
               // alert(response.ADDINFO);

                var SCREENING = response.ADDINFO.SCREENING;
                var APPROVED = response.ADDINFO.APPROVED;
                var REQUIRED = response.ADDINFO.REQUIRED;
                //alert(SCREENING);
                //alert(APPROVED);
                //alert(REQUIRED);

                var arrSCREENING = SCREENING.toString().split(',');
                var arrAPPROVED = APPROVED.toString().split(',');
                var arrREQUIRED = REQUIRED.toString().split(',');
                var ApprovedString = "";
                var ScreeningString = "";
                var RequiredString = "";
                if (arrAPPROVED[0] != null && arrAPPROVED[0] != "") {
                    ApprovedString = ApprovedString+"1) " + arrAPPROVED[0] + ' ';
                }
                if (arrAPPROVED[2] != null) {
                    ApprovedString = ApprovedString + "2) " + arrAPPROVED[2] + ' ';
                }
                if (arrAPPROVED[4] != null) {
                    ApprovedString = ApprovedString + "3) " + arrAPPROVED[4] + '.';
                }
                //// SCREENING
                if (arrSCREENING[1] != null && arrSCREENING[1] != "") {
                    ScreeningString = ScreeningString + "1) " + arrSCREENING[1] + ' ';
                }
                if (arrSCREENING[4] != null) {
                    ScreeningString = ScreeningString + "2) " + arrSCREENING[4] + ' ';
                }
                if (arrSCREENING[7] != null) {
                    ScreeningString = ScreeningString + "3) " + arrSCREENING[7] + '.';
                }
                //// RequiredString
                if (arrREQUIRED[1] != null && arrREQUIRED[1] != "") {
                    RequiredString = RequiredString + "1) " + arrREQUIRED[1] + ' ';
                }
                if (arrREQUIRED[4] != null) {
                    RequiredString = RequiredString + "2) " + arrREQUIRED[4] + ' ';
                }
                if (arrREQUIRED[7] != null) {
                    RequiredString = RequiredString + "3) " + arrREQUIRED[7] + '.';
                }

                $("#spanApproved").html(ApprovedString);
                $("#spanSCREENING").html(ScreeningString);
                $("#spanREQUIRED").html(RequiredString);
                $("#viewKYCModal").modal('show');

            }
            else if (response.RESULT == "1") {
                swal({
                    title: "Oops!",
                    text: response.ADDINFO,
                    icon: "error",
                    button: "OK",
                });
            }
            else {
                swal({
                    title: "Oops!",
                    text: data,
                    icon: "error",
                    button: "OK",
                });

            }
        })

          .fail(function (jqXHR) {
              $("#loader").hide();
              swal({
                  title: "Oops!",
                  text: "Some thing went wrong!",
                  icon: "error",
                  button: "OK",
              });

          })
          .always(function () {
              $("#loader").hide();

          });
    }
</script>
