<div class="modal fade" id="fileUploadModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header navbar" style="position:initial;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:white;">Upload KYC Document </h4>
            </div>
        @using (Ajax.BeginForm("Upload_KYC_Doc", "Outlet", new AjaxOptions { HttpMethod = "POST" }, new { enctype = "multipart/form-data", @id = "formDocUpload" }))
        {
            @Html.AntiForgeryToken()
                <div class="modal-body" style="margin-top:-26px;">
                    <div class="body">
                        <form>
                            @Html.ValidationSummary(true)
                            <div class="row clearfix">
                                @Html.HiddenFor(m => m.RetailerId)
                                @Html.HiddenFor(m => m.PanCard)
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Select Document</label>
                                </div>

                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.DropDownList("DocId", new List<SelectListItem> {
                                       new SelectListItem { Text = "AADHAAR CARD", Value = "14" } ,
                                       new SelectListItem { Text = "PAN CARD", Value = "1" }
                                       },

                                       "-- Select Doc Type--", new { @class = "selectpicker form-control", data_live_search = "true", @required = "required" })
                                            @Html.ValidationMessage("File Type Is Required")
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Document Image</label>
                                </div>

                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            <input type="file" name="file" id="fu1" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                                <div class="modal-footer">
                                <button type="submit" id="btnupdate" class="btn btn-primary waves-effect">Update File</button>
                                <button type="button" class="btn btn-info waves-effect" data-dismiss="modal">CLOSE</button>
                            </div>
                        </form>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

