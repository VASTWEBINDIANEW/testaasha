<script>
    function optgetval(optname) {

        $('#numbershowmobile').text("");
            $('#PrePaidbestplan').hide()
            $('#DTHCustomerInfo').hide();
            $('#ElectricityCustomerInfo').hide();
            $('#gasCustomerInfo').hide();
        $('#insurCustomerInfo').hide();

        if (optname == "Prepaid") {
            $("#radio_1").prop("checked", true);
            j('#mobileoperatorPrepaid').val("");
            j('#mobileoperatorPrepaid').select2().trigger('change');
            j('#mobileoperatorPostpaid').val("");
            j('#mobileoperatorPostpaid').select2().trigger('change');
            j("#ddlcircle").val("");
            j('#ddlcircle').select2().trigger('change');
            $('#txtmobile').val("");
            $('#droppostpaid').hide();
            $('#dropprepaid').show();
            $('#txtmobileamount').val("");
            $('#viewplan').show();
            $('#viewplan').show();
            $('#Rechargeform').show();
            $('#rechargeconfirm').hide();
            $('#confirmprepaid').hide();
        }
        else if (optname == "DTH") {

            $("#txtdthcardno").val("");
            $("#txtdthamount").val("");
            j('#dthddl').val("");
            j('#dthddl').select2().trigger('change');
            $('#rechargeconfirmDTH').hide();
            $('#dthrchform').show();
        }
        else if (optname == "Landline") {
            j('#landlineddl').val("");
            j('#landlineddl').select2().trigger('change');
            $('#txtlandline').val("");
            $('#STDCODE').val("");
            $('#txtaccount').val("");
            $('#landamount').val("");

            ChkKYC();
            $('#Landlineshow').show();
            $('#confirmlandline').hide();

            $('#rechargeconfirmlandline').hide();

        }
        else if (optname == "Electricity") {
            ChkKYC();

            j('#eddltype').val("");
            j('#eddltype').select2().trigger('change');
            $('#txtelectricity').text("");
            $('#electricityAmount').text("");
            $('#BillRefId').text("");
            $('#ProcessingCycle').text("");
            $('#billunit').text("");
            $('#elecpay').show();
            $('#rechargeconfirmelec').hide();
            $('#confirmelec').hide();
        }
        else if (optname == "Gas") {
            ChkKYC();
            $('#gasinfo').show();
            $('#confirmgas').hide();
            $('#rechargeconfirmgas').hide();
            j('#gasddltype').val("");
            j('#gasddltype').select2().trigger('change');
            $('#txtgasno').val("");
            $('#gasamount').val("");
        }
        else if (optname == "LPG Gas") {
            ChkKYC();
            $('#lpggasinfo').show();
            $('#confirmlpggas').hide();
            $('#rechargeconfirmlpggas').hide();
            j('#lpggasddltype').val("");
            j('#lpggasddltype').select2().trigger('change');
            $('#txtlpggasno').val("");
            $('#lpggasamount').val("");
        }
        else if (optname == "Insurance") {
            ChkKYC();
            $('#insurinfo').show();
            $('#confirminsur').hide();
            $('#rechargeconfirminsur').hide();
            j('#insuranceddltype').val("");
            j('#insuranceddltype').select2().trigger('change');
            $('#txtpolicyno').val("");
            $('#insuranceamount').val("");
            $('#txtDOB').val("");
        }

        else if (optname == "Water") {

            ChkKYC();
            $('#numbershowmobile').text();
            j('#walterddltype').val("");
            j('#walterddltype').select2().trigger('change');
            $('#txtwaterno').val("");
            $('#wateramount').val("");
            $('#watershow').show();
            $('#confirmwater').hide();
            $('#rechargeconfirmwater').hide();
        }
        else if (optname == "Broadband") {
            ChkKYC();
                    $('#numbershowmobile').text();
        j('#broadbandddltype').val("");
        j('#broadbandddltype').select2().trigger('change');
        $('#txtbroadbandno').val("");
        $('#broadbandamount').val("");
        $('#broadshow').show();
        $('#confirmbroad').hide();
        $('#rechargeconfirmbroad').hide();
        }

            $.ajax({
            url: '@Url.Action("Show_commsion", "Home")',
            type: 'GET',
            dataType: "html",
            data: { type: optname },
                success: function (data) {
                $('#fillopt').html(data);
            },
            error: function (data) {

            }
            });
         $.ajax({
            url: '@Url.Action("showrecentrecharge", "Home")',
            type: 'GET',
            dataType: "html",
            data: { type: optname },
                success: function (data) {
                $('#reportchk').html(data);
            },
            error: function (data) {

            }
         });

        return true;
    }

    function ChkKYC() {
        $.ajax({
            url: '@Url.Action("KYCCheck", "Home")',
            type: 'GET',
            dataType: "Json",
            success: function (data) {
                if (data === "Success") {
                    window.location.href = '@Url.Action("Profile", "Home")';
                }
            },
            error: function (data) {

            }
         });
    }
</script>

