<script>
    $("#txtdthcardno").on('keypress blur keyup', function (e) {
        var k = e.keyCode || e.which;
        var id = $(this)[0].id;
        var str = $(this)[0].value;
        var length = str.length;
        if (e.type == "keyup") {
            e.preventDefault();
            e.stopPropagation();
            if (id == 'txtdthcardno') {
                var mobileno = $("#txtdthcardno").val();
                $("#numbershowmobile").html(mobileno);

                return true;

            }
            //end
        }
        else if (length != 10 && e.type == "keyup") {

            $("#numbershowmobile").html("");
        }
    });
