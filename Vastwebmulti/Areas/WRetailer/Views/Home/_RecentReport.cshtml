@model Vastwebmulti.Areas.RETAILER.Models.Recent_report

<style>
    #example tbody tr td{padding:10px;}
</style>
<table id="example" class="table table-striped table-bordered" style="width:100%">
    @if (Model.WRecent_report_imps != null)

    {
        <thead>
            <tr>
                <th style="width: 186px;">Beneficiary&nbsp;Account</th>

                <th>Amount</th>
                <th>Beneficiary&nbsp;Bank&nbsp;Name</th>
                <th>Time</th>

                <th>Bank&nbsp;RRN</th>

            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.WRecent_report_imps)
            {
                var type = item.Trans_Type;
                var img = ""; var color = ""; var style = "";
                if (item.Trans_Type.ToUpper() == "IMPS_VERIFY")
                {
                    type = "Verify";
                    style = "height:20px;width:20px;margin-right:3px;float:left;";

                }
                if (item.Status.ToUpper() == "SUCCESS")
                {
                    img = "../../ashok-images/correct.svg";
                    color = "green";
                    style = "height:20px;width:20px;margin-right:3px;float:left;border-radius:50%;padding:4px;";
                }
                else if (item.Status.ToUpper() == "PENDING")
                {
                    img = "../../ashok-images/clock.svg";
                    style = "height: 20px;width: 20px;margin-right:3px;float:left;max-width: 100%;padding: 0;";
                    //color = "#ff9e00";

                }
                else if (item.Status.ToUpper() == "FAILED")
                {
                    img = "../../ashok-images/closes.svg";
                    color = "red";
                    style = "height:20px;width:20px;margin-right:3px;float:left;border-radius:50%;padding:4px;";
                }
                else
                {
                    img = "../../ashok-images/closes.svg";
                    color = "red";
                    style = "height:20px;width:20px;margin-right:3px;float:left;border-radius:50%;padding:4px;";
                }


                <tr>
                    <td>
                        <img style="@style background-color:@color;" src=@img />
                        @Html.DisplayFor(modelItem => item.accountno)
                    </td>

                    <td>@Html.DisplayFor(modelItem => item.amount)</td>
                    <td>@Html.DisplayFor(modelItem => item.bank_nm)</td>
                    <td>@Html.DisplayFor(modelItem => item.trans_time)</td>

                    <td>@Html.DisplayFor(modelItem => item.bank_trans_id)</td>
                </tr>
            }
        </tbody>
    }
    else if (Model.WRecent_report_Aeps != null)
    {
        <thead class="aepsdetailstabale-respons">
            <tr>

                <th>Transaction&nbsp;Status</th>
                <th>User&nbsp;Bank</th>
                <th>User&nbsp;A/c</th>
                <th>User&nbsp;Aadhaar</th>

                <th>Net&nbsp;Amount</th>
                <th>Cr&nbsp;/&nbsp;Dr</th>

                <th>Bank&nbsp;RRN</th>
                <th>Request&nbsp;Time</th>

            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.WRecent_report_Aeps)
            {
                var color = ""; var img = "";
                if (item.Status.ToUpper().Contains("SUCCESS"))
                {
                    img = "../../ashok-images/correct.svg";
                    color = "green";
                }
                else if (item.Status.ToUpper().Contains("BALANCE"))
                {
                    img = "../../ashok-images/correct.svg";
                    color = "blue";
                }
                else if (item.Status.ToUpper() == "PENDING")
                {
                    img = "../../ashok-images/clock.svg";

                    color = "#ff9e00";

                }
                else
                {
                    img = "../../ashok-images/closes.svg";
                    color = "red";
                }
                var type = "";
                if (item.Status.ToUpper() == "BALANCE")
                {
                    type = "Balance";
                }
                else if (item.Status.ToUpper().Contains("M_"))
                {
                    type = "Mini StateMent";
                }
                else
                {
                    type = "Cash Withdraw";
                }

                <tr>
                    <td>
                        <img style="height:20px;width:20px; background-color:@color;" src=@img />
                        @type
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.BankName)</td>
                    <td>A/c</td>
                    <td>
                        @Html.DisplayFor(modelItem => item.AccountHolderAadhaar)

                    </td>

                    <td>@Html.DisplayFor(modelItem => item.Amount)</td>
                    <td>cr</td>

                    <td style="width:50px;">@Html.DisplayFor(modelItem => item.BankRRN)</td>
                    <td>@Html.DisplayFor(modelItem => item.Txn_Date)</td>
                </tr>
            }
        </tbody>

    }
    else if (Model.WRecent_PAN_CARD_IPAY != null)
    {
        <thead>
            <tr>
                <th>Physical&nbsp;Token</th>
                <th>Digital&nbsp;Token</th>
                <th>Amount</th>
                <th>Time</th>
                <th>UTI&nbsp;TXN</th>
                <th>Coupon&nbsp;Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.WRecent_PAN_CARD_IPAY)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.PhysicalCount)</td>
                    <td>@Html.DisplayFor(modelItem => item.DigitalCount)</td>
                    <td>@Html.DisplayFor(modelItem => item.ProcessingFees)</td>
                    <td>@Html.DisplayFor(modelItem => item.Date)</td>
                    <td>@Html.DisplayFor(modelItem => item.UTI_TXN_ID)</td>
                    <td>@Html.DisplayFor(modelItem => item.CouponStatus)</td>
                </tr>
            }
        </tbody>
    }
    @*else if (Model.Recent_mPosInfo != null)
    {
        <thead>
            <tr>
                <th>Trans&nbsp;Type</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Time</th>
                <th>Bank&nbsp;RRN</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Recent_mPosInfo)
            {
                var sts = "Pending";
                if (item.status == "00")
                {
                    sts = "SUCCESS";
                }
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.transType)</td>
                    <td>@Html.DisplayFor(modelItem => item.amount)</td>
                    <td>@sts</td>
                    <td>@Html.DisplayFor(modelItem => item.date)</td>
                    <td>@Html.DisplayFor(modelItem => item.BankRRN)</td>
                </tr>
            }
        </tbody>
    }
    @if (Model.Recent_microatm != null)

    {
        <thead>
            <tr style="color: black;">
              
                <th>Status</th>
                <th>Amount</th>
                <th>Time</th>
                <th>BankRRN&nbsp;No</th>
                <th>Tran&nbsp;Type</th>
                <th>Card&nbsp;Type</th>
              
                <th>Net&nbsp;Work</th>
               </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Recent_microatm)
            {
                var type = item.transaction_type;
                var img = ""; var color = ""; var style = "";
                
                if (item.status.ToUpper() == "SUCCESS")
                {
                    img = "../../ashok-images/correct.svg";
                    color = "green";
                    style = "height:20px;width:20px;margin-right:3px;float:left;";
                }
                else if (item.status.ToUpper() == "PENDING")
                {
                    img = "../../ashok-images/clock.svg";
                    style = "height: 20px;width: 20px;margin-right:3px;float:left;max-width: 100%;padding: 0;";
                    //color = "#ff9e00";

                }
                else if (item.status.ToUpper() == "FAILED")
                {
                    img = "../../ashok-images/closes.svg";
                    color = "red";
                    style = "height:20px;width:20px;margin-right:3px;float:left;";
                }
                else
                {
                    img = "../../ashok-images/closes.svg";
                    color = "red";
                    style = "height:20px;width:20px;margin-right:3px;float:left;";
                }


            <tr>
                <td>
                    <img style="@style background-color:@color;" src=@img />
                    @item.status
                </td>
               
               
                <td>@item.amount</td>
                <td>@item.transtime</td>
                <td>@item.rrn</td>
                <td>@item.transaction_type</td>
                <td>@item.card_payment_type</td>
                <td>@item.network</td>
               
            </tr>
            }
        </tbody>
    }*@

</table>
<script>
    $(document).ready(function () {
        $('#example').dataTable({
            "searching": false,
            "bPaginate": false,
            "bLengthChange": true,
            "bFilter": true,
            "bInfo": false,
            "bAutoWidth": true
        });
    });
</script>


<div class="modal mastetr222Modal in" id="aepstableclickpop" tabindex="-1" role="dialog" style="display: none;">
    
    <div class="col-md-4 new-prent-page" id="aepspopshow">
        <div class="body-border-bottom" style="margin-bottom: 20px;">
            <button type="button" class="btn waves-effect" data-dismiss="modal">
                <i class="fa fa-times fulltextbodycolor fullbodydycolorbg" aria-hidden="true"></i>
            </button>
        </div>
        <div class="col-md-12 Confirm-Payment">
            
            <div class="container-fluid">
                <div class="col-md-6 successful">
                    <p>Transaction Successful</p>
                    <span> @ViewData["rrnno"]</span>
                </div>
               
            </div>
            <div class="container-fluid transaction" style="width:100%;">
                <p style="color:white;">transaction details</p>
                <ul class="transaction-detail" style="width:100%;">
                    <li class="transaction-left"><span>Retailer Firm</span></li>
                    <li class="transaction-right" style="float:right;"><span>@ViewData["firmname"]</span></li>
                    <li class="transaction-left"><span>Aadhaar Number</span></li>
                    <li class="transaction-right" style="float:right;"><span>@ViewData["aadhar"]</span></li>
                    <li class="transaction-left"><span>Register Mobile</span></li>
                    <li class="transaction-right" style="float:right;"><span>@ViewData["mobile"]</span></li>
                    <li class="transaction-left"><span>AEPS Mode</span></li>
                    <li class="transaction-right" style="float:right;"><span>BALANCE</span></li>
                    <li class="transaction-left"><span>A/C Remain</span></li>
                    <li class="transaction-right" style="float:right;"><span>@ViewData["remain"]</span></li>
                </ul>

            </div>
        </div>
    </div>
    </div>
    




