                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="">
                                    <button type="submit" class="btn bg-indigo  waves-effect" style="margin-top:3px; margin-left:1px;">
                                        <i class="material-icons" style="top:3px;">search</i>
                                        <span style="top:-4px;">Search</span>
                                    </button>
                                    <button type="button" class="btn bg-indigo waves-effect" style="margin-top:3px;" data-toggle="modal" data-target="#addmodel">
                                        <i class="material-icons" style="top:3px;">group</i>
                                        <span style="top:-4px;">Add&nbsp;New</span>
                                    </button>


                                </div>

                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-40px;">
                <div class="card">
                    <div class="">
                        <h2 style="color:black; font-size:16px;padding-top:9px; padding-left:22px;"></h2>
                    </div>
                    <div class="body">
                        <div class="table-responsive" style="position:inherit;margin-top:-20px;">
                            <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%;">
                                <thead class="navbar" style="color:white;position:inherit;">
                                    <tr>
                                        <th>Order&nbsp;No</th>
                                        <th>From</th>
                                        <th>Amount</th>
                                        <th>PayMent&nbsp;Mode</th>
                                        <th>Type</th>
                                        <th>To&nbsp;Acc&nbsp;No </th>
                                        <th>UtrNo/SlipNo </th>
                                        <th>Comment</th>
                                        <th>Status </th>
                                        <th>Screenshot </th>
                                        <th>Request&nbsp;Date </th>
                                        <th>Response&nbsp;Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@Html.DisplayFor(modelItem => item.orderno)</td>
                                                <td>@Html.DisplayFor(modelItem => item.frm).ToString().ToUpper()</td>
                                                <td>@Html.DisplayFor(modelItem => item.amount) </td>
                                                <td>@Html.DisplayFor(modelItem => item.paymode).ToString().ToUpper()</td>
                                                <td>@Html.DisplayFor(modelItem => item.type_).ToString().ToUpper()</td>

                                                <td>@Html.DisplayFor(modelItem => item.Toaccountno)</td>

                                                <td>@Html.DisplayFor(modelItem => item.utrno).ToString().ToUpper()</td>

                                                <td>@Html.DisplayFor(modelItem => item.details)</td>
                                                <td>@Html.DisplayFor(modelItem => item.sts).ToString().ToUpper()</td>
                                                <td>
                                                    @if (!string.IsNullOrWhiteSpace(item.Slip))
                                                    {
                                                        <img src="@Url.Content("~/" + item.Slip)" height="60" width="60" />
                                                    }
                                                </td>
                                                <td>@Html.DisplayFor(modelItem => item.reqdate)</td>
                                                <td>@Html.DisplayFor(modelItem => item.responsedate)</td>
                                            </tr>
                                        }
                                    </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

</section>
