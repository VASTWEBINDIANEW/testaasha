<!--broadband Continue Button script-->
<script>
    function getbroadbandcontinuebtn(b) {
        var e = document.getElementById(b);
        var broadbandddltext = e.options[e.selectedIndex].text;
        var broadbandddlvalue = e.options[e.selectedIndex].value;
        var broadbandno = $("#txtbroadbandno").val();
        var broadbandamount = $("#broadbandamount").val();
        /* call function */
        var sts = getbroadbandcontiunebtn(broadbandddltext, broadbandno, broadbandamount);

        if (sts == true) {
            $('#showoptbroad').text(broadbandddltext);
            $('#shownumberbroad').text(broadbandno);
            $('#showamountbroad').text(broadbandamount);
            $('#broadshow').hide();
            $('#confirmbroad').show();
            //    Recharge(broadbandddltext, broadbandddlvalue, broadbandno, broadbandamount, "", "", "", "", "0");
            event.preventDefault();
            return false;
        }
        else {
            event.preventDefault();
            return false;
        }
    }
</script>

<!--Broadband View Bill -->
<script>
    function Getbroadbandviewbill(b) {
        var e = document.getElementById(b);
        var broadbandddltext = e.options[e.selectedIndex].text;
        var eleddlvalue = e.options[e.selectedIndex].value;
        var broadbandno = $("#txtbroadbandno").val();
        /* call function */
        var sts = getbroadbandcontiunebtn(broadbandddltext, broadbandno, "10");
        if (sts == true) {
            viewbillbroad(broadbandddltext, eleddlvalue, broadbandno, "10", "", "", "", "");
            event.preventDefault();
            return false
        }
        else {
            event.preventDefault();
            return false
        }
    }
</script>
<script>
    function viewbillbroad(optname, optvalue, mobileno, amount, optional1, optional2, optional3, optional4) {
           $.ajax({
            type: "POST",
            url: "@Url.Action("viewbill", "Home")",
            data: { OperatorName: optname, OptCode: optvalue, mobileno: mobileno, Amount: amount, optional1: optional1, optional2: optional2, optional3: optional3, optional4: optional4 },
            cache: false,
            dataType: 'json',
            closeOnConfirm: true,
               success: function (result) {
                if (result.Response == 'SUCCESS') {
                var displayValues = "";
                    var price = result.Price;

                displayValues = price;
                    if (price != "") {
                        price = parseInt(price);
                        $('#broadbandamount').val(price);
                        //swal("Success!", displayValues, "success")
                    }
                }
            }
        })
    }
</script>

<script>
    function backbroad() {

        $('#broadshow').show();
        $('#confirmbroad').hide();
        $('#rechargeconfirmbroad').hide();
    }
</script>
<script>
    function broadrechargeconfirm() {
        var e = document.getElementById("broadbandddltype");
        var broadbandddltext = e.options[e.selectedIndex].text;
        var broadbandddlvalue = e.options[e.selectedIndex].value;
        var broadbandno = $("#txtbroadbandno").val();
        var broadbandamount = $("#broadbandamount").val();
        var servicefeebroad = $("#servicefeebroad").val();
        if (servicefeebroad != "") {
            /* call function */
            var sts = getbroadbandcontiunebtn(broadbandddltext, broadbandno, broadbandamount);
            if (sts == true) {
                $("#servicefeebroad").css("border-color", "#000000");
                $("#txtbroadbandno").val("");
                $("#broadbandamount").val("");
                if (broadbandno != "" && broadbandamount != "") {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("Recharge","Home")",
                        data: { OperatorName: broadbandddltext, OptCode: broadbandddlvalue, mobileno: broadbandno, Amount: broadbandamount, optional1: "", optional2: "", optional3: "", optional4: "", comm: "", BillRefId: "",servicefee: servicefeebroad },
                        cache: false,
                        dataType: 'json',
                        beforeSend: function () {
                            $('.loader').show();
                        },
                        success: function (result) {
                            var status = result.Response;
                            var message = result.Message;
                            $('#rchstatuschkbroad').text(status);
                            $('#rchmsgbroad').text(message);
                            $('#confirmbroad').hide();
                            $('#rechargeconfirmbroad').show();
                        },
                        complete: function () {
                            $('.loader').hide();
                            $.ajax({
                                url: '@Url.Action("showrecentrecharge", "Home")',
                                type: 'GET',
                                dataType: "html",
                                data: { type: "broadband" },
                                success: function (data) {
                                    $('#reportchk').html(data);
                                },
                                error: function (data) {

                                }
                            });
                        },
                        error: function () {
                            $('.loader').hide();
                        }
                    })
                }
            }
        }
        else {
              $("#servicefeebroad").css("border-color", "#FF0000");
        }
    }
</script>
<script>
    function Rechargeagainbroad() {
        $('#numbershowmobile').text();
        j('#broadbandddltype').val("");
        j('#broadbandddltype').select2().trigger('change');
        $('#txtbroadbandno').val("");
        $('#broadbandamount').val("");
        $('#broadshow').show();
        $('#confirmbroad').hide();
        $('#rechargeconfirmbroad').hide();
    }
</script>