@model List<Vastwebmulti.Models.Whitelabel_show_upi_txn_details_Result>
@{
    Layout = "~/Areas/WRetailer/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "UPITRANSFER";
}

<style>
    .select2-container--default .select2-selection--single {
        border: 1px solid #eee !important;
        border-radius: 0px !important;
        height: 32px !important;
    }
</style>

<section>
    <div class="all-page-container">
        <div class="back-home-page">
            <ul>
                <li><a href="~/ADMIN/Home/Dashboard">Dashboard&nbsp;<img src="/ashok-images/rightaeps.svg" alt="right-arrow" style="width: 12px;margin-top: -2px;"></a></li>
                <li>Add Wallet By UPI</li>
            </ul>
        </div>

        <div class="fundtransfer-wr">

            <div class="col-md-4 purchase-tab-wr api-tab-wr">
                <div class="custome-background-wr second-qr-code">
                    <h2 class="fullbodydycolorbg">+ Wallet By QR Code (UPI)</h2>
                    @if (ViewBag.set == "NOTOK")
                    {
                        <div class="scan-first" style="display: flex; align-items: center; justify-content: center; margin-top: 35px">
                            @using (Html.BeginForm("UPITRANSFER_add", "Home", FormMethod.Post))
                            {
                                <button type="submit" style="font-weight: bold; font-size: 30px; padding: 20px">
                                    <p> Generate</p> QR Code
                                </button>
                            }
                        </div>
                    }
                    <p style="color:red">@ViewBag.msg </p>
                    <div style="width: 100%;float:none;text-align: center;padding-bottom: 15px;padding-top: 10px;margin: 0px auto;">
                        @if (ViewBag.QRCodeImage != null)
                        {
                            <img src="@ViewBag.QRCodeImage" alt="" style=" border:5px solid black;max-width:100%;" />
                        }
                        else
                        {
                            <img alt="Currently UPI Service is Down" style=" border:1px solid black;max-width:100%;padding: 4px 6px;" />
                        }
                    </div>
                    @*<img src="data:image/png;base64," />*@
                    <div class="qr-code-notepoint">
                        <p>1. You can update the amount in your wallet by scanning the QR code.</p>
                        <p>2. You can print a hard copy of the QR code and update through all the UPI wallets.</p>
                        <p>3. Refresh the page after the customer's payment process is complete, you will get the transaction status report on the page, and after deducting the Charges on the success transaction, the balance will be updated in your wallet.</p>

                        <div class="table-responsive-bottom">
                            <table border="1">
                                <thead><tr><th colspan="2" style="text-align:center;background:#ececec;">Charges</th></tr></thead>
                                <tbody>
                                    <tr>
                                        <td>Minimum Fix Charge (In Rupees)</td>
                                        <td>@ViewBag.min ₹</td>
                                    </tr>
                                    <tr>
                                        <td>Charges (In Precentage)</td>
                                        <td>@ViewBag.charge %</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                    </div>

                </div>
            </div>

            <div class="col-md-8 fundtransfer-reportwr api-report-wr">

                <div class="custome-background-wr height-report-id">
                    <div class="purchasereport-header">
                        <h2 style="position:relative;">History<span class="fullbodydycolorbg">By upi QR Code</span><i class="fa fa-caret-down" aria-hidden="true"></i></h2>

                        <div class="col-md-2 lager-date-search">
                            <div class="form-group">
                                <div class="form-line" style="border-bottom:none;margin-top:0px;">
                                    <center>

                                        <button value="OLD" type="submit" class="btn" id="btntype" name="btntype" style="margin-top:5px; margin-left:2px; height:32px;border:1px solid #c7c2c2;background:#dedddd;">
                                            <i class="fa fa-search" style="top:-1px;font-size:13px;color:black;"></i>
                                            <span style="top:-1px;color:black;">Search</span>
                                        </button>

                                    </center>

                                </div>
                            </div>
                        </div>

                        <div class="col-md-3 lager-date-wr" style="padding:0;">
                            <div class="form-group" style="margin-bottom:0px;margin-top:1px;">
                                <div class="input-daterange input-group">
                                    <div class="input-whitelabel leftwhitellabel">
                                        <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i>
                                        <input type="date" style="text-align:center;padding-left: 27px !important;" />
                                    </div>
                                    <div class="input-whitelabel rightwhitellabel">
                                        <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i>
                                        <input type="date" style="text-align:center;padding-left: 27px !important;" />
                                    </div>
                                </div>
                                <!-- /.input group -->
                            </div>
                        </div>

                    </div>

                    <div class="table-report-purchase">
                        <div class="table-responsive-bottom">
                            <table border="1" id="">
                                <thead>
                                    <tr>
                                        <th>Payer&nbsp;Name</th>
                                        <th>Amount</th>
                                        <th>Charges</th>
                                        <th>Net&nbsp;Received</th>
                                        <th>Bank&nbsp;RRN</th>
                                        <th>Transaction Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        var img = "";
                                        var bgcolor = "";
                                        if (item.status.ToUpper() == "SUCCESS")
                                        {
                                            img = "../../ashok-images/correct.svg";
                                            bgcolor = "green";

                                        }
                                        else if (item.status.ToUpper() == "PENDING")
                                        {
                                            img = "../../ashok-images/clkk.png";
                                            bgcolor = "#FF9800";
                                        }
                                        else
                                        {
                                            img = "../../ashok-images/closes.svg";
                                            bgcolor = "red";
                                        }
                                        <tr>
                                            <td class="status-failsuccessa"><img src='@img' style="width: 20px; background:@bgcolor;">&nbsp;@item.PayerName</td>
                                            @*<td>9166940603</td>*@
                                            <td>@item.amt</td>
                                            <td>@item.charge</td>
                                            <td>@item.finalpay</td>
                                            <td>@item.BankRRN</td>
                                            <td>@item.txndate</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>


                        </div>
                    </div>

                </div>

            </div>

        </div>

    </div>
</section>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->

<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>



<link href="~/MainFrontDesign/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/MainFrontDesign/select2/dist/js/select2.full.min.js"></script>


<script>
    $('.for-select2').select2();


</script>


<script>
    $(function () {
        var loc = window.location.href; // returns the full URL
        if ('/~/WRetailer/Home/UPITRANSFER') {
            $('.list-reports-wr li:nth-child(9) a').addClass('active');
        }
    });
</script>

