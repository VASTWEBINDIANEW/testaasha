<!--Gas View Bill-->
<script type="text/javascript">
    function GetGasviewbill(ggg) {

        var e = document.getElementById(ggg);
        var eleddl = e.options[e.selectedIndex].text;
        var eleddlvalue = e.options[e.selectedIndex].value;
        var txtval = $("#txtgasno").val();
        var billgroup = $("#billgroup").val();

        //var cycleno = $("#ProcessingCycle").val();
        //var billunit = $("#billunit").val();
        //var Amount = $("#gasamount").val();

        /* call function*/
        var sts = getgascontiunebtn(eleddl, txtval, "10", billgroup);

        if (sts == true) {
            viewbillgas(eleddl, eleddlvalue, txtval, "10", billgroup, "", "", "");
            event.preventDefault();
            return false;
        }
        else {
            event.preventDefault();
            return false;
        }
    }

</script>
<script>
    function viewbillgas(optname, optvalue, mobileno, amount, optional1, optional2, optional3, optional4) {
        $(".loaderwww").show();
        $.ajax({
            type: "POST",
            url: "@Url.Action("viewbill", "Home")",
            data: { OperatorName: optname, OptCode: optvalue, mobileno: mobileno, Amount: amount, optional1: optional1, optional2: optional2, optional3: optional3, optional4: optional4 },
            cache: false,
            dataType: 'json',
            closeOnConfirm: true,
            success: function (result) {
                $(".loaderwww").hide();
                if (result.Response == 'SUCCESS') {
                                //Gas View Bill
              
                var price = result.Price;
                    var displayValues = "";
                    $.each(JSON.parse(result.DisplayValues), function (key, val) {
                        if (!val.label.includes('Incentive')) {

                            displayValues = displayValues + val.label + ' : ' + val.value + "</br>";
                        }
                    });
                if (price != "") {
                    //price = parseInt(price);
                    $('#gasamount').val(price);

                    var newrow = "<table class='col-sm-4 table-responsive table-bordered'><tr>";
                    newrow += "<td>" + displayValues + "</td></tr>";
                    newrow += "<tr><td> Bill Amount &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;;&nbsp; ::  " + result.Price + "</td></tr>";
                    newrow += "</table>";
                    $('#gasCustomerTbl').append(newrow);
                    $('#gasCustomerInfo').css('display', 'block');
                    //swal("Success!", displayValues, "success")
                }
                else {
                                var message = result.Message;
                    $('#gasamount').val(0);

                    var newRow =
                        "<div class='col-sm-4' style='text-align: left;'>" +
                        "" + message + ""
                    "</div>"
                    $('#gasCustomerTbl').append(newRow);
                    $('#gasCustomerInfo').css('display', 'block');
                }
                }
            }
        })
    }

</script>


<!--gas continue button function-->

<script>
    function backgas() {
        $('#gasCustomerInfo').hide();
        $('#gasinfo').show();
        $('#confirmgas').hide();
    }
</script>

<script>
    function getgascontinuebtn(gas) {
        var e = document.getElementById(gas);
        var gasddl = e.options[e.selectedIndex].text;
        var eleddlvalue = e.options[e.selectedIndex].value;
        var txtgasno = $("#txtgasno").val();
        var billgroup = $("#billgroup").val();
        var gasamount = $("#gasamount").val();
        var BillRefId = $("#BillRefId").val();
        /*call function */
        var sts = getgascontiunebtn(gasddl, txtgasno, gasamount, billgroup);
        if (sts == true) {

            $('#showoptgas').text(gasddl);
            $('#shownumbergas').text(txtgasno);
            $('#showamountgas').text(gasamount);
            $('#gasCustomerInfo').hide();
            $('#gasinfo').hide();
            $('#confirmgas').show();

            //  Recharge(gasddl, eleddlvalue, txtgasno, gasamount, billgroup, "", "", "", "0", BillRefId);
            event.preventDefault();
            return false;
        }
    }
</script>


<script>
    function gasrechargeconfirm() {
                var e = document.getElementById("gasddltype");
        var gasddl = e.options[e.selectedIndex].text;
        var eleddlvalue = e.options[e.selectedIndex].value;
        var txtgasno = $("#txtgasno").val();
        var billgroup = $("#billgroup").val();
        var gasamount = $("#gasamount").val();
        var BillRefId = $("#BillRefId").val();
        var servicefeegas = $("#servicefeegas").val();
        if (servicefeegas != "") {
            /*call function */
            var sts = getgascontiunebtn(gasddl, txtgasno, gasamount, billgroup);
            if (sts == true) {
                           $("#servicefeegas").css("border-color", "#000000");
                $("#txtgasno").val("");
                $("#gasamount").val("");
                if (txtgasno != "" && gasamount != "") {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("Recharge","Home")",
                        data: { OperatorName: gasddl, OptCode: eleddlvalue, mobileno: txtgasno, Amount: gasamount, optional1: billgroup, optional2: "", optional3: "", optional4: "", comm: "", BillRefId: BillRefId,servicefee: servicefeegas },
                        cache: false,
                        dataType: 'json',
                        beforeSend: function () {
                            $('.loader').show();
                        },
                        success: function (result) {
                            var status = result.Response;
                            var message = result.Message;
                            $('#rchstatuschkgas').text(status);
                            $('#rchmsggas').text(message);
                            $('#confirmgas').hide();
                            $('#rechargeconfirmgas').show();
                        },
                        complete: function () {
                            $("#remainretailer").load(location.href + " #remainretailer");
                            $('.loader').hide();
                            $.ajax({
                                url: '@Url.Action("showrecentrecharge", "Home")',
                                type: 'GET',
                                dataType: "html",
                                data: { type: "gas" },
                                success: function (data) {
                                    $('#reportchk').html(data);
                                },
                                error: function (data) {

                                }
                            });
                        },
                        error: function () {
                            $("#remainretailer").load(location.href + " #remainretailer");
                            $('.loader').hide();
                        }
                    })
                }
            }
        }
        else {
               $("#servicefeegas").css("border-color", "#FF0000");
        }
    }
</script>

<script>
    function Rechargeagaingas() {
        $('#numbershowmobile').text("");
        $('#gasCustomerInfo').show();
        $('#gasinfo').show();
        $('#confirmgas').hide();
        j('#gasddltype').val("");
        j('#gasddltype').select2().trigger('change');
        $('#txtgasno').val("");
        $('#rechargeconfirmgas').hide();
        $('#gasamount').val("");

    }
</script>


