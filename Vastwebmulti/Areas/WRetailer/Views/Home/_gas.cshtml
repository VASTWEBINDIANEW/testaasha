        var BillRefId = $("#lpgBillRefId").val();
        /*call function */
        var sts = getlpggascontiunebtn(gasddl, txtgasno, gasamount, billgroup);
        if (sts == true) {

            $('#showoptlpggas').text(gasddl);
            $('#shownumberlpggas').text(txtgasno);
            $('#showamountlpggas').text(gasamount);
            $('#lpggasCustomerInfo').hide();
            $('#lpggasinfo').hide();
             $('#showlpggassclass').hide();
             $('#confirmlpggas').show();

            //  Recharge(gasddl, eleddlvalue, txtgasno, gasamount, billgroup, "", "", "", "0", BillRefId);
            event.preventDefault();
            return false;
        }
    }
</script>


<script>
    function lpggasrechargeconfirm() {
                var e = document.getElementById("lpggasddltype");
        var gasddl = e.options[e.selectedIndex].text;
        var eleddlvalue = e.options[e.selectedIndex].value;
        var txtgasno = $("#txtlpggasno").val();
        var billgroup = $("#lpgbillgroup").val();
        var gasamount = $("#lpggasamount").val();
        var BillRefId = $("#lpgBillRefId").val();
        var servicefeegas = $("#servicefeelpggas").val();
        if (servicefeegas != "") {
            /*call function */
            var sts = getlpggascontiunebtn(gasddl, txtgasno, gasamount, billgroup);
            if (sts == true) {
                           $("#servicefeelpggas").css("border-color", "#000000");
                $("#txtlpggasno").val("");
                $("#lpggasamount").val("");
                if (txtgasno != "" && gasamount != "") {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("Recharge","Home")",
                        data: { OperatorName: gasddl, OptCode: eleddlvalue, mobileno: txtgasno, Amount: gasamount, optional1: billgroup, optional2: "", optional3: "", optional4: "", comm: "", BillRefId: BillRefId,servicefee: servicefeegas },
                        cache: false,
                        dataType: 'json',
                        beforeSend: function () {
                            $('.loader').show();
                        },
                        success: function (result) {
                            var status = result.Response;
                            var message = result.Message;
                            $('#rchstatuschklpggas').text(status);
                            $('#rchmsglpggas').text(message);
                            $('#confirmlpggas').hide();
                            $('#rechargeconfirmlpggas').show();
                        },
                        complete: function () {
                            $('.loader').hide();
                            $.ajax({
                                url: '@Url.Action("showrecentrecharge", "Home")',
                                type: 'GET',
                                dataType: "html",
                                data: { type: "LPG Gas" },
                                success: function (data) {
                                    $('#reportchk').html(data);
                                },
                                error: function (data) {

                                }
                            });
                        },
                        error: function () {
                            $('.loader').hide();
                        }
                    })
                }
            }
        }
        else {
               $("#servicefeelpggas").css("border-color", "#FF0000");
        }
    }
</script>

