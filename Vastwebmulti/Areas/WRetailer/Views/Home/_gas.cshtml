<style>
    
        .loader {
        position: fixed;
        top: -90px;
        left: 0;
        background-color: rgba(255,255,255,0.7);
        z-index: 999999999999;
        display: none;
        height: 100vw;
        width: 100vw;
    }

    @@-webkit-keyframes spin {
        from {
            -webkit-transform: rotate(0deg);
        }

        to {
            -webkit-transform: rotate(360deg);
        }
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .loader::after {
        content: '';
        display: block;
        position: absolute;
        left: 48%;
        top: 25%;
        width: 100px;
        height: 100px;
        border-style: solid;
        border-color: black;
        border-top-color: transparent;
        border-width: 4px;
        border-radius: 50%;
        -webkit-animation: spin .8s linear infinite;
        animation: spin .8s linear infinite;
    }

    .wretailernewpipedgas .viewwretailer .form-group, .viewwretailer-wrterailer.viewwretailer .form-group{
        height: auto !important;
    }

        .wretailernewpipedgas .viewwretailer .form-group .form-line, .viewwretailer-wrterailer.viewwretailer .form-group .form-line{
            height: auto !important;
        }

            .wretailernewpipedgas .viewwretailer .form-group .form-line input, .viewwretailer-wrterailer.viewwretailer .form-group .form-line input{
                height: auto !important;
                padding: 5px !important;
                background: transparent !important;
                color: #555 !important;
                font-size: 11px;
            }

    .wretailernewpipedgas .viewwretailer ,.viewwretailer-wrterailer.viewwretailer{
        padding-right: 0;
        top: 4px !important;
    }

    @@media screen and (max-width:767px) {
        .wretailergasinfo {
            width: 100%;
            float: left;
        }
        .wretailergasinfo .col-md-4, .wretailergasinfo .col-md-1, .wretailergasinfo .col-md-2, .wretailergasinfo .col-md-3 {
    padding: 0 !important;
        
    width: 100% !important;
}
    }
    
</style>
