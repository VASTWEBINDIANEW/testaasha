<style>

    .loader {
        position: fixed;
        top: -90px;
        left: 0;
        background-color: rgba(255,255,255,0.7);
        z-index: 999999999999;
        display: none;
        height: 100vw;
        width: 100vw;
    }

    @@-webkit-keyframes spin {
        from {
            -webkit-transform: rotate(0deg);
        }

        to {
            -webkit-transform: rotate(360deg);
        }
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .loader::after {
        content: '';
        display: block;
        position: absolute;
        left: 48%;
        top: 25%;
        width: 100px;
        height: 100px;
        border-style: solid;
        border-color: black;
        border-top-color: transparent;
        border-width: 4px;
        border-radius: 50%;
        -webkit-animation: spin .8s linear infinite;
        animation: spin .8s linear infinite;
    }

    .wretailer-landlineclass .col-md-2, .wretailer-landlineclass .col-md-3, .wretailer-landlineclass .col-md-1, .wretailer-landlineclass .col-md-4 {
        padding-left: 0;
        margin-top: 13px !important;
    }

    .wretailer-landlineclass input {
        margin-top: 0 !important;
    }
    @@media screen and (max-width:767px) {
        .wretailer-landlineclass {
            width: 100%;
            float: left;
        }

            .wretailer-landlineclass .col-md-2, .wretailer-landlineclass .col-md-1, .wretailer-landlineclass .col-md-3, .wretailer-landlineclass .col-md-4 {
                width: 100% !important;
                float: left !important;
                padding: 0;
            }
    }

</style>
<div id="Landlineshow" class="wretailer-landlineclass" style="">
    <!--Lnadline dropdown-->
    <div class="col-md-2 Landlineshow-first" style="margin-top:10px;">
        
        <div class="form-group" style="margin-bottom:0px;">
