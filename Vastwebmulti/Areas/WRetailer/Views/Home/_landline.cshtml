<script>
    function landlinerechargeconfirm() {
        var optional1 = ""; var optional2 = ""; var optional3 = "";
        var e = document.getElementById("landlineddl");
        var ddllandline = e.options[e.selectedIndex].text;
        var optvalue = e.options[e.selectedIndex].value;
        var radiobtn = document.querySelector('input[name="landlinegroup"]:checked').value;
        var landlineno = $("#txtlandline").val();
        var Stdcode = $("#STDCODE").val();
        var accountno = $("#txtaccount").val();
        var amountno = $("#landamount").val();
        var servicefeelandline = $("#servicefeelandline").val();
        if (servicefeelandline != "") {
                        $("#servicefeelandline").css("border-color", "#000000");
            var sts = getlandlinecontinuebtn(ddllandline, landlineno, Stdcode, accountno, amountno, radiobtn);
            if (sts == true) {
                if (ddllandline == "BSNL Landline") {
                    optional1 = accountno;
                    optional2 = radiobtn;
                    optional3 = Stdcode;
                    //  Recharge(ddllandline, optvalue, landlineno, amountno, accountno, radiobtn, Stdcode, '', "0", "");

                }
                else if (ddllandline == "MTNL Delhi Landline" || ddllandline == "MTNL - Mumbai") {
                    optional1 = accountno;
                    // Recharge(ddllandline, optvalue, landlineno, amountno, accountno, '', '', '', "0");

                }
                else if (ddllandline == "Airtel Landline") {
                    optional1 = Stdcode;
                    //  Recharge(ddllandline, optvalue, landlineno, amountno, Stdcode, '', '', '', "0");

                }
                else if (ddllandline == "Tata Docomo LANDLINE") {
                    //  Recharge(ddllandline, optvalue, landlineno, amountno, '', '', '', '');

                }
                else if (ddllandline == "Reliance LANDLINE") {
                    optional1 = Stdcode;
                    // Recharge(ddllandline, optvalue, mobileno, amountno, Stdcode, '', '', '', "0");

                }

                $("#txtlandline").val("");
                $("#landamount").val("");
                if (landlineno != "" && amountno != "") {
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("Recharge","Home")",
                        data: { OperatorName: ddllandline, OptCode: optvalue, mobileno: landlineno, Amount: amountno, optional1: optional1, optional2: optional2, optional3: optional3, optional4: "", comm: "", BillRefId: "", servicefee: servicefeelandline },
                        cache: false,
                        dataType: 'json',
                        beforeSend: function () {
                            $('.loader').show();
                        },
                        success: function (result) {
                            var status = result.Response;
                            var message = result.Message;
                            $('#rchstatuschklandline').text(status);
                            $('#rchmsglandline').text(message);
                            $('#confirmlandline').hide();
                            $('#rechargeconfirmlandline').show();
                        },
                        complete: function () {
                            $("#remainretailer").load(location.href + " #remainretailer");
                            $('.loader').hide();
                            $.ajax({
                                url: '@Url.Action("showrecentrecharge", "Home")',
                                type: 'GET',
                                dataType: "html",
                                data: { type: "landline" },
                                success: function (data) {
                                    $('#reportchk').html(data);
                                },
                                error: function (data) {

                                }
                            });
                        },
                        error: function () {
                            $("#remainretailer").load(location.href + " #remainretailer");
                            $('.loader').hide();
                        }
                    })

                }

            }
        }
        else {
            $("#servicefeelandline").css("border-color", "#FF0000");
        }
    }
</script>
