            </div>

            @*</div>*@
        </div>

    </div>
    <!--STD Code-->
    <div class="col-md-1" id="DivSTDCode" style="margin-top:10px;">
        
        <div class="form-group" style="margin-bottom:0px;">
            <div class="wretailererrorclass" style="height:28px;position:absolute;top: -21px !important;width: 100%;">
                <p id="stdcodemessage" style="color:#E91E63; font-size:10px; padding-left:1px;"></p>
            </div>
            <div class="form-line form-line-after" style="margin-top:-2px; height:37px;">
                <input type="text" id="STDCODE" name="STDCODE" class="form-control" placeholder="STD CODE" onkeypress="return isNumber(event)" style="padding-left:0px; font-size:14px;" maxlength="6" />
            </div>
        </div>
    </div>
    <!--Landline Account number-->
    <div class="col-md-2 Divaccountnumbereswr" id="Divaccountnumber" style="margin-top:10px;">
        
        <div class="form-group" style="margin-bottom:0px;">
            <div class="wretailererrorclass" style="height:28px; position:absolute;width:100%;float:left;top: -22px !important;">
                <p id="accountmessage" style="margin-top:10px; color:#E91E63; font-size:10px; padding-left:1px;"></p>
            </div>
            <div class="form-line form-line-after" style="margin-top: -2px; height: 37px;">
                <input type="text" id="txtaccount" name="txtaccount" class="form-control" placeholder="Enter Account No" onkeypress="return isNumber(event)" />
            </div>
        </div>
    </div>
    <!--Land line amount-->
    <div class="col-md-2" style="margin-top:10px;">
        
        <div class="form-group" style="margin-bottom:0px;">
            <div class="wretailererrorclass" style="height: 28px;position: absolute;top: -22px !important;">
                <p id="amountmessage" style="margin-top:10px; color:#E91E63; font-size:10px; padding-left:1px;"></p>
            </div>
            <div class="form-line" style="margin-top:-2px; height:37px;">
                <input type="text" id="landamount" name="landamount" class="form-control" placeholder="Enter Amount" onkeypress="return isNumber(event)" />
            </div>
        </div>
    </div>

    <div class="col-md-1 Divaccountnumber-second" style="margin-top:10px;">
        <div class="form-group" style="margin-bottom:0px; ">
            <div class="form-line" style="border-bottom:none;">
                <input type="button" id="btn1" class="btn bg-blue-grey" value="Continue" style="height:37px;" onclick="Getlanlinecontinuebtn('landlineddl')" />
            </div>
        </div>
    </div>
</div>

