@model Vastwebmulti.Areas.RETAILER.Models.RetailerInvoiceModel
@{
    ViewBag.Title = "InvoicePDF";
}
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.2.1/jquery.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
<!DOCTYPE html>
<html lang="">
<body>
    <div style="width:100%; height:100px;">
        <div style="float:left;">
            <div><span style="font-size:25px; ">vastwebmulti.in </span></div>
            <div><span style="font-size:18px;">Retailer Name :  @TempData["retailername"] </span> </div>
            <div><span style="font-size:18px;">Firm Name :  @TempData["frimname"] </span> </div>
            <div> <span style="font-size:18px; ">Retailer Mobile :  @TempData["retailermobile"] </span></div>
            <div> <span style="font-size:18px; ">Money Transfer Date :  @TempData["retailerdate"] </span></div>
        </div>
        <div style=" float:right;">
            <img src="@Context.Server.MapPath("~/Images/Logo.png")" alt="PayNowRecharge" />
        </div>
    </div>
    <div style="background-color:Black; margin-top:5%;">
        <center>
            <h1 style="color:White; ">FUND RECEIVE RECEIPT  </h1>
        </center>
    </div>
    <div style="height:40px;">
        <div style="float:left;">
            <span style="font-size:18px; ">Receipt No : @TempData["invoiceno"]  </span>
        </div>
        <div style="float:right;">
            <span style="font-size:18px; "> Date : @TempData["date"] </span>
        </div>
    </div>
    <table class="table" style="margin-top:40px;">
        <tr>
            <th>Sr No.</th>
            <th> Receive From  </th>
            <th> Old Remain </th>
            <th>Value</th>
            <th>Final Value</th>
            <th>New Remain </th>
            <th>Date </th>
  
        </tr>
    
            <tr>
                <td>1</td>
                <td>@Html.DisplayFor(a => a.ReciveFrom)</td>
                <td>@Html.DisplayFor(a => a.OldRemain)</td>
                <td>@Html.DisplayFor(a => a.Value)</td>
                <td>@Html.DisplayFor(a => a.FinalValue)</td>
                <td>@Html.DisplayFor(a => a.NewRemain)</td>
                <td>@Html.DisplayFor(a => a.Date)</td>
            </tr>
            
     
    </table>
    <div style="margin-top:60px;">
        <center>
            <span style="font-size:18px; padding-bottom :40px;">THIS IS A COMPUTER GENERATED RECEIPT HENCE DOES NOT REQUIRE ANY SEAL AND SIGNATURES.</span>
        </center>
    </div>

    <div style="margin-top:30px;">
        <center>
            <span style="font-size:22px; font-weight:bold;"> Thanks for using PayNowRecharge</span>
        </center>
    </div>
   
</body>
</html>
