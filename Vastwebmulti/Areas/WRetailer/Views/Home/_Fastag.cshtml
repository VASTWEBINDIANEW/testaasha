<script>
    function viewbillfast(optname, optvalue, mobileno, amount, optional1, optional2, optional3, optional4) {
         $('.loader').show();
       $.ajax({
           type: "POST",
           url: "@Url.Action("viewbill", "Home")",
           data: { OperatorName: optname, OptCode: optvalue, mobileno: mobileno, Amount: amount, optional1: "", optional2: "", optional3: "", optional4: "" },
           cache: false,
           dataType: 'json',
           closeOnConfirm: true,
           success: function (result) {

               $('.loader').hide();

               if (result.Response == 'SUCCESS') {
               var displayValues = "";
            $.each(JSON.parse(result.DisplayValues), function (key, val) {
                if (!val.label.includes('Incentive')) {

                    displayValues = displayValues + val.label + ' : ' + val.value + "</br>";
                }
            });
                   //                          var newRow ="<div class='col-sm-4' style='text-align: left;'>" +
                   //               ""+displayValues+""
                   //"</div>";
                   var newrow = "<table class='col-sm-4 table-responsive table-bordered'><tr>";
                   newrow += "<td>" + displayValues +"</td></tr>";
                   newrow += "<tr><td> Bill Amount &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;;&nbsp; ::  " + result.Price + "</td></tr>";
                   newrow += "<tr><td> Due Date &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;   ::  " + result.billduedate + "</td></tr>";
                    newrow += "</table>";
                   $('#fasttagCustomerTbl').append(newrow);
                   $('#fasttagCustomerInfo').css('display', 'block');
            var price = result.Price;
                   var fasttagRefId = result.reference_id;
                   if (fasttagRefId == "undefined" || fasttagRefId == "") {
                       if (price != "") {
                           //price = parseInt(price);
                           $('#FastTagAmount').val(price);
                           $('#fasttagRefId').val(fasttagRefId);
                           // displayValues
                       }
                   }
                   else {
                       if (price != "") {
                           //price = parseInt(price);
                           $('#FastTagAmount').val(price);
                           $('#fasttagRefId').val(fasttagRefId);
                           // displayValues
                       }
                       else {
                                 var message = result.Message;
                            $('#FastTagAmount').val('');
                           $('#fasttagRefId').val(message);
                       }
                   }
               }
               if (result.Response == 'ERROR') {
                   $('.loader').hide();
                                               var newRow ="<div class='col-sm-4' style='text-align: left;color:red'>" +
                                  ""+result.Message+""
                   "</div>";

                    $('#FastTagAmount').val('');
                   $('#fasttagCustomerTbl').append(newRow);
                   $('#fasttagCustomerInfo').css('display', 'block');
               }
           }

       })
    }
</script>
