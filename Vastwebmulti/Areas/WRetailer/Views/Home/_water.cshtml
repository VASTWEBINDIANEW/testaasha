<style>

    .loader {
        position: fixed;top: -90px;left: 0;background-color: rgba(255,255,255,0.7);
        z-index: 999999999999;display: none;height: 100vw;width: 100vw;
    }

    @@-webkit-keyframes spin {
        from {
            -webkit-transform: rotate(0deg);
        }

        to {
            -webkit-transform: rotate(360deg);
        }
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .loader::after {
        content: '';display: block;position: absolute;left: 48%;
        top: 25%;width: 100px;height: 100px;border-style: solid;
        border-color: black;border-top-color: transparent;border-width: 4px;
        border-radius: 50%;-webkit-animation: spin .8s linear infinite;animation: spin .8s linear infinite;
    }

    .wretailerwatershow .viewwretailer .form-group {height: auto !important;}
    .wretailerwatershow .viewwretailer .form-group .form-line {height: auto !important;}
    .wretailerwatershow .viewwretailer .form-group .form-line input {
       height: auto !important;padding: 5px !important;background: transparent !important;color: #555 !important;font-size: 11px;
      }

    .wretailerwatershow .viewwretailer {padding-right: 0;top: 4px !important;}
    .wretailerwatershow #wamount.col-md-1 {width: 16%;}
    .wretailerwatershow .col-md-4, .wretailerwatershow .col-md-2, .wretailerwatershow .col-md-3, .wretailerwatershow .col-md-1 {
        padding-left: 0;padding-right:15px;
    }

    .wretailerwatershow .col-md-2 .txtelectricity1 {margin-top: 0 !important;}
    .wretailerwatershow input {width: 100% !important;float: left;}
    .wretailerwatershow .input-daterange.input-group {margin-left: 0 !important;}

    @@media screen and (max-width:767px) {
        .wretailerwatershow .col-md-3, .wretailerwatershow .col-md-2, .wretailerwatershow .col-md-1, .wretailerwatershow .col-md-4 {
            width: 100% !important;padding: 0 !important;         
        }
    }
</style>
