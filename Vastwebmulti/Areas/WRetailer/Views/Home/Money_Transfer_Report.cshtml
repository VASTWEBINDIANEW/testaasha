    function Submit()
    {
        var tid = $('#TID').val();
        var otp = $('#name').val();
        $.ajax({
            url: '@Url.Action("Refund", "Home")',
            type: "Post",
            dataType: 'json',
            cache: false,
            //   async: false,
            data: { tid: tid, otp: otp },
            //cache: false,
            success: function (result) {
                swal("Response ! ", result, "success");
                if (result != "Wrong TID or OTP")
                {
                    $('#myModal').modal('hide');
                }
            }
        });

    }
