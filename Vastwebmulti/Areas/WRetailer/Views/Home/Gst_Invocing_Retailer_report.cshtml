
@model IEnumerable<Vastwebmulti.Models.GST_Monthly_WRetailer_Result>
@{
    ViewBag.Title = "Gst_Invocing_Master_report";
    Layout = "~/Areas/WRetailer/Views/Shared/_Layout.cshtml";
}

<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 81px !important;
    }

    table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px;
    }

    .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {
        height: 20px;
    }
</style>

<section class="content" style="margin:90px 0px 0px 0px; ">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:0px;">
                <div class="card">
                    <div class="">
                        <div class="col-md-4">
                            <p style="font-size:22px;margin-top:4px;">Retailer GST Invoice Report</p>
                        </div>

                        <div class="col-md-4">
                            <center>
                                <a href="@Url.Action("Account_verify_Gst_Invocing_report","Home")" class="btn  waves-effect" style="margin-top: 6px; margin-left: 3px; height:32px;border:1px solid #c7c2c2;">
                                    <i class="fa fa-long-arrow-right" style="top:-1px;font-size:16px;color:black;"></i>
                                    <span style="top:-2px;color:black;">Account Verify GST Report</span>
                                </a>
                            </center>
                        </div>
                        
                        <div class="col-md-2">
                            <p style="font-size:20px;margin-top:5px;font-weight:700;color:#55555a;">Month&nbsp;:-&nbsp;@ViewBag.OldMonth</p>
                        </div>
                        <div class="col-md-2">
                            
                        </div>
                    </div>

                </div>
            </div>
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-26px;">
                <div class="card">
                    <div class="">
                        <ol class="breadcrumb breadcrumb-col-blue-grey" style="margin-left:5px;margin-top:9px;">
                            <li class="active" style="color:#9E9E9E; font-size:12px;">RETAILER GST INVOICE REPORT&nbsp;></li>
                        </ol>

                    </div>
                    <div class="body" style="padding:7px;">
                        <div class="table-responsive" style="position:inherit;margin-top:-50px;">
                            <table class="table table-bordered table-striped table-hover dataTable js-exportable" style="width:100%; font-size:12px;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Sr.No</th>
                                        <th>Email&nbsp;ID</th>
                                        <th>Frim&nbsp;Name</th>
                                        <th>Account Transfer Comm</th>
                                        <th>Account Transfer GST</th>
                                        <th>RCH Comm</th>
                                        <th>RCH GST</th>
                                        <th>Aeps Comm</th>
                                        <th>Aeps GST</th>
                                        <th>PAN Comm</th>
                                        <th>PAN GST</th>
                                        <th>MPOS Comm</th>
                                        <th>MPOS GST</th>
                                        <th>Flight Comm</th>
                                        <th>Flight GST</th>
                                        <th>Total GST</th>
                                        <th>Print</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var i = 1;
                                    }

                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td><p style="font-size:12px;">@item.Email</p></td>
                                            <td><p style="font-size:12px;">@item.Frm_Name</p></td>
                                            <td><p style="font-size:12px;">@item.dmtcomm</p></td>
                                            <td><p style="font-size:12px;">@item.dmtgst</p></td>
                                            <td><p style="font-size:12px;">@item.rchcomm</p></td>
                                            <td><p style="font-size:12px;">@item.rchgst</p></td>
                                            <td><p style="font-size:12px;">@String.Format("{0:0.00#}", item.aepscomm)</p></td>
                                            <td><p style="font-size:12px;">@item.aepsgst</p></td>
                                            <td><p style="font-size:12px;">@item.pancomm</p></td>
                                            <td><p style="font-size:12px;">@item.pangst</p></td>
                                            <td><p style="font-size:12px;">@item.mposcomm</p></td>
                                            <td><p style="font-size:12px;">@item.mposgst</p></td>
                                            <td><p style="font-size:12px;">@String.Format("{0:0.00#}", item.flightcomm)</p></td>
                                            <td><p style="font-size:12px;">@item.flightgst</p></td>
                                            <td><p style="font-size:12px;">@item.total</p></td>
                                            <td><a href="@Url.Action("GST_Invocing_Report_Pdf","Home")" style="font-size:14px;color:blue;font-weight:500;" target="_blank">Print</a></td>
                                        </tr>
                                        i++;
                                    }

                                </tbody>

                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->

<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />



