<script>
    $(document).ready(function () {
        var current = location.pathname;
        $('.menu-top-custome ul li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('active');


            }
        })
    });
</script>
