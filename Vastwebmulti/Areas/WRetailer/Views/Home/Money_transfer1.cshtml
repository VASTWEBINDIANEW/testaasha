<script>

    function GetBankList() {
        var acno = $("#account_no").val();
        if (acno == null || acno == "") {
            sweetAlert("Oops...", "Please Enter Account No First", "error");
        }
        else {
            $.ajax({
                type: 'Get',
                url: "@Url.Action("BankListFill1", "Home")",
                data: { accountno: acno },
            dataType: 'json',
            cache: false,
            async: true,
            success: function (result) {

                //$("loadermoney").style.display = "none";
                 var sts = result.statuscode;

                var rdata = result.data;
                for (var i = 0; i < rdata.length; i++) {
                    var valuee = "";
                    if (rdata[i].branch_ifsc == "") {
                        valuee = "Please&nbsp;Enter&nbsp;Ifsc&nbsp;Code";
                    }
                    else {
                        valuee = rdata[i].branch_ifsc;
                    }
                    var div_data = "<option value=" + valuee + ">" + rdata[i].bank_name + "</option>";

                    $(div_data).appendTo('#banknm');
                    //$('#banknm').selectpicker('refresh');

                }

                cbox();
            }
        });

    }
    }

</script>

