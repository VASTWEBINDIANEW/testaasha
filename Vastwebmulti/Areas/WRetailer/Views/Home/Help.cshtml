@{
    ViewBag.Title = "Help";
    Layout = "~/Areas/WRetailer/Views/Shared/_Layout.cshtml";
}
<style>
    .table tbody tr td, .table tbody tr th {
        border-top: 0px;
        border-bottom: 0px;
    }

    .table-responsive {
        border: 0px;
    }
    .row.clearfix.help-fullpage.help-fullpage-div {
    border-top: 2px solid @PageData["GlobalSecond"] !important;
 
}
    .card.card-help-table table tr {
    border-bottom: 1px solid #9f9595;
}
    .card.card-help-table table {
    border: 1px solid #9f9595;
}
    @@media screen and (max-width:992px) {
        .wretailer-helppage .col-md-6.help-class {
            float: left;
            width: 50%;
        }
    }
    @@media screen and (max-width:767px) {
        .wretailer-helppage .col-md-6.help-class {
            float: left;
            width:100%;
        }
    }
</style>
