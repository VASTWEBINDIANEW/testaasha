                                </thead>
                                <tbody>
                                    <tr>
                                        <td>MONDAY</td>
                                        <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>
                                    </tr>
                                    <tr>
                                        <td>TUESDAY</td>
