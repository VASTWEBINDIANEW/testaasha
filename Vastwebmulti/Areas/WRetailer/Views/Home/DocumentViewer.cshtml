
@{
    ViewBag.Title = "DocumentViewer";
    Layout = "~/Areas/WRetailer/Views/Shared/_Layout.cshtml";
}
<link href="~/Areas/RETAILER/Blinking text/Blinking.css" rel="stylesheet" />
<section class="content" style="margin:90px 0px 0px 0px; ">
    <div class="row clearfix">
        <div class="col-md-12">
            <div class="card">
                <div class="header" style="padding:10px; padding-left:21px;">
                    <h2>
                        <span style="font-size:21px;"></span>PanCard Document

                        <a href='@Url.Action("Dashboard","Home")' class="btn bg-indigo  waves-effect" style="margin-top:-8px; margin-left:5px; float:right;">
                            <i class="material-icons" style="top:3px;">arrow_back</i>
                            <span style="top:-4px;">Back To Dashborad</span>
                        </a>
                    </h2>

                </div>
            </div>
        </div>
     
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                 <div class="card">
                    <div class="body" style="margin-top:-20px;">
                      <div class="row clearfix">
                          <div class="col-md-6">
                              @{ var impath = "/PAN_FirstPage/" + ViewBag.AckNo + ".jpg";
                                  var ackno = ViewBag.AckNo; }
                              @if (ackno == null || ackno == "")
                              {
                              <center><img src="~/images/pancardimage.jpg" class="img-responsive" /></center>  

                              }
                              else
                              {
                                <center><img src="@Url.Content("~/" + impath)" height="300" class="img-responsive" /></center> 

                              }
                           <div class="row" style="margin-top:19px;">
                             <div class="col-md-12">
                              <center style="font-size:19px;"><a href="@Url.Action("PAN_FirstPageDownLoad","Home",new { ackno = ViewBag.AckNo })"><span class="flash">Click to download...</span></a></center> 
                            </div>
                           </div>
                          </div>
                          <div class="col-md-6">
                              <center><img src="~/PAN_DOC_PDF/pdf-download.jpg" class="img-responsive" style="height:340px;"/></center>
                          
                              <div class="row" style="margin-top:19px;">
                                  <div class="col-md-12">
                                      <center style="font-size:19px;"><a href="@Url.Action("PAN_DocDownLoad","Home",new { ackno = ViewBag.AckNo })"><span class="flash">Click to download...</span></a></center>
                                  </div>
                              </div>
                          </div>
                      </div>
                        <div class="row">
                            <div class="col-md-12">
                                <center><input type="button" class="btn btn-primary" value="Close" onclick="javascript:self.close()" /></center>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
     

    </div>

</section>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-colorpicker/js/bootstrap-colorpicker.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>


<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>

<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>


