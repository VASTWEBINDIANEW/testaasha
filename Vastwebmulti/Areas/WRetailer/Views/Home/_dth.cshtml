<!--select DTH dropdown text for placeholder -->
<script>
    function dthddltype(l) {
        var p = l.options[l.selectedIndex].text;
        /*call dth function */
        getdthdropdowntext(p);
        showdthplanandhideplan(p);
    }
</script>
<script>
    function backDTH() {
         $('#showoptdth').text("");
            $('#shownumberdth').text("");
             $('#showamountdth').text("");
                   $('#confirmDTH').hide();
            $('#dthrchform').show();
    }
</script>
<!--dth contiune button javascript-->
<script>
    function getdthcontinuebtn(dth) {
        var e = document.getElementById(dth);
        var ddldth = e.options[e.selectedIndex].text;
        var optvalue = e.options[e.selectedIndex].value;
        var custromerid = $("#txtdthcardno").val();
        var dthamount = $("#txtdthamount").val();
        /* call continue btn function */
        var sts = getdthcontiunebtn(ddldth, custromerid, dthamount);

        if (sts == true) {
            $('#showoptdth').text(ddldth);
            $('#shownumberdth').text(custromerid);
             $('#showamountdth').text(dthamount);
            $('#confirmDTH').show();
            $('#dthrchform').hide();
            $('#DTHCustomerInfo').hide();

          //  Recharge(ddldth, optvalue, custromerid, dthamount, "", "", "", "", "0");
            event.preventDefault();
            return false;
        }
        else {
            event.preventDefault();
            return false;
        }

    }
</script>

<script>
    function DTHrechargeconfirm() {

         var e = document.getElementById("dthddl");
        var ddldth = e.options[e.selectedIndex].text;
        var optvalue = e.options[e.selectedIndex].value;
        var custromerid = $("#txtdthcardno").val();
        var dthamount = $("#txtdthamount").val();

             $("#txtdthcardno").val("");
        $("#txtdthamount").val("");
        if (custromerid != "" && dthamount != "") {
            $.ajax({
                type: "POST",
                url: "@Url.Action("Recharge","Home")",
                data: { OperatorName: ddldth, OptCode: optvalue, mobileno: custromerid, Amount: dthamount, optional1: "", optional2: "", optional3: "", optional4: "", comm: "", BillRefId: "" },
                cache: false,
                dataType: 'json',
                beforeSend: function () {
                    $('.loader').show();
                },
                success: function (result) {
                    var status = result.Response;
                    var message = result.Message;
                    $('#rchstatuschkdth').text(status);
                    $('#rchmsgdth').text(message);
                    $('#confirmDTH').hide();
                    $('#rechargeconfirmDTH').show();
                },
                complete: function () {
                    $("#remainretailer").load(location.href + " #remainretailer");
                    $('.loader').hide();
                                              $.ajax({
            url: '@Url.Action("showrecentrecharge", "Home")',
            type: 'GET',
            dataType: "html",
            data: { type: "DTH" },
                success: function (data) {
                $('#reportchk').html(data);
            },
            error: function (data) {

            }
        });
                },
                error: function () {
                    $("#remainretailer").load(location.href + " #remainretailer");
                    $('.loader').hide();
                }
            })
        }

    }
</script>
<script>
    function RechargeagainDTH() {
        $('#numbershowmobile').text("");
       $("#txtdthcardno").val("");
        $("#txtdthamount").val("");
       j('#dthddl').val("");
       j('#dthddl').select2().trigger('change');
       $('#rechargeconfirmDTH').hide();
       $('#dthrchform').show();
    }
</script>

<!--get Dth View Plans-->
<script>
    function getdthviewofferplan()
    {
        var e = document.getElementById("dthddl");
        optname = e.options[e.selectedIndex].text;
        optvalue = e.options[e.selectedIndex].value;
        var textvalue = $("#txtdthcardno").val();
        //function call
        var sts = validationbsetoffer(optname, textvalue);
      if(sts==true)
        {
          $('#dthoffertable').html('');
          $('#airteldthoffertable').html('');
          $('#Videoconoffertable').html('');
          $.ajax({
              url: '@Url.Action("RechargeBestofferplan", "Home")',
              type: 'GET',
              dataType: "json",
              data: { optname: optname, mobileno: textvalue },
              success: function (response) {
                  $('#DTHCustomerTbl').empty();
                  if (optname == "Dish TV") {
                      var sts = response.status;

                      if (sts == "SUCCESS") {
                          var jsonObj = response.Response;

                          var newRow = "<div class='col-sm-4' style='text-align: left;'>" + "Name :" + jsonObj.SubscriberName + "</br> SubBalance : " + jsonObj.SubsBalance + "</br> Address : " + jsonObj.address + "," + jsonObj.State + "</div>";
                          newRow += "<div class='col-sm-4' style = 'text-align: left;' > " +
                              "Activated ON : " + jsonObj.ActivatedOn + "</br> SchemeName : " + jsonObj.SchemeName +  "</div>";
                            newRow += "<div class='col-sm-4' style = 'text-align: left;' > " +
                              "Status : " + jsonObj.StatusName + "</br> Payterm Name : " + jsonObj.PaytermName + "</br> Package Price : " + jsonObj.PackagePrice + "</div>";

                          $('#DTHCustomerTbl').append(newRow);
                          $('#DTHCustomerInfo').css('display', 'block');
                      }
                  }
                  if(optname == "Airtel Digital TV")
                  {
                      var sts = response.status;

                          if (sts == "SUCCESS") {
                          var jsonObj = response.Response;

                          var newRow =
                              "<div class='col-sm-4' style='text-align: left;'>" +
                                  "<td>Name :" + jsonObj.name + "</br> Current Balance : " + jsonObj.currentbalance + "</br> valid Till : " + jsonObj.validTill + "</td>"
                              "</div>"

                              $('#DTHCustomerTbl').append(newRow);
                              $('#DTHCustomerInfo').css('display', 'block');
                      }
                  }

                  if (optname == "Videocon D2H") {
                      var sts = response.status;
                      if (sts == "SUCCESS") {
                          var jsonObj = response.Response;

                          var newRow = "<div class='col-sm-4' style='text-align: left;'>" + "Name :" + jsonObj.customerName + "</br> Recharge DueDate : " + jsonObj.rechargedueDate + "</div>";
                          newRow += "<div class='col-sm-4' style = 'text-align: left;' > " +
                          "Monthly Recharge : " + jsonObj.monthlyRecharge + "</br> Customer Status : " + jsonObj.customerStatus +  "</div>";

                          $('#DTHCustomerTbl').append(newRow);
                          $('#DTHCustomerInfo').css('display', 'block');
                      }
                  }
                  if (optname == "Tata Sky") {
                      var sts = response.status;

                      if (sts == "SUCCESS") {

                          var jsonObj = response.Response;

                          var newRow = "<div class='col-sm-4' style='text-align: left;'>" + "Name :" + jsonObj.customerName + "</br> Balance : " + jsonObj.balance + "</br> Recharge DueDate : " + jsonObj.rechargedueDate + "</div>"
                          newRow += "<div class='col-sm-4' style = 'text-align: left;' > " +
                          "Monthly Recharge : " + jsonObj.monthlyRecharge + "</br> Customer Status : " + jsonObj.customerStatus +  "</div>";
                          $('#DTHCustomerTbl').append(newRow);
                          $('#DTHCustomerInfo').css('display', 'block');
                      }
                  }

              },
              error: function (data) {

              }
          });
          return true;
        }
         else {
          return false;
            }

    }
</script>