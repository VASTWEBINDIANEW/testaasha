<head>
    @{
        var comnyname = "";
        var favimage = "";
        var favimage1 = "";
        VastwebmultiEntities DB1 = new VastwebmultiEntities();
        var companyname = DB1.Admin_details.ToList();
        if (companyname.Count > 0)
        {
            comnyname = companyname.FirstOrDefault().Companyname;
            ViewBag.companyname = comnyname;
        }
        else
        {
            comnyname = "";
        }
        <!-- Favicon-->
        var faviconlogo = DB1.tblfavicons.Where(p => p.Role == "ADMIN").ToList();
        if (faviconlogo.Count() > 0)
        {
            if (faviconlogo.SingleOrDefault().Role == "ADMIN")
            {
                favimage = faviconlogo.SingleOrDefault().faviconimage;
            }
        }
        else
        {
            <link rel="icon" href="" type="image/x-icon" />
        }
        var color = DB1.changecolors.FirstOrDefault(a => a.Role == "ADMIN");
        var col = "";
        var backgroundcol = "";
        if (color != null && color.ToString() != "")
        {
            col = color.adminandouterheadercolor;

        }
        else
        {
            col = "pink";

        }
        <!--Current Login Time-->
        var userid = User.Identity.GetUserId();
        var emailid = DB1.Users.Where(a => a.UserId == userid).FirstOrDefault().UserId;
        <!--Remain Balance-->
        int tokenVal = 0;
        var remainRetailerCreationToken = DB1.RetailerCreationTokens.SingleOrDefault(a => a.DealerId == userid);
        if (remainRetailerCreationToken != null)
        {
            tokenVal = remainRetailerCreationToken.Tokens;
        }
        var remainbalance = DB1.Remain_dealer_balance.SingleOrDefault(a => a.DealerID == userid)?.Remainamount;
        var chkmsg = DB1.lowbalancemsgs.Where(a => a.userid == userid).SingleOrDefault();
        var userfor = DB1.lowbalances.Where(a => a.Role == "Dealer").FirstOrDefault();
        if (userfor != null && userfor.amount < remainbalance)
        {
            if (chkmsg == null)
            {
                lowbalancemsg lb = new lowbalancemsg();
                lb.userid = userid;
                lb.message = "Message Sent";
                lb.status = false;
                DB1.lowbalancemsgs.Add(lb);
                DB1.SaveChanges();
            }
            else
            {
                chkmsg.status = false;
                DB1.SaveChanges();
            }

        }
        var logoimage = "";
        var logo = DB1.tblHeaderLogoes.Where(p => p.Role == "ADMIN").ToList();
        if (logo.Count > 0)
        {
            if (logo.SingleOrDefault().Role == "ADMIN")
            {
                logoimage = logo.Where(p => p.Role == "ADMIN").SingleOrDefault().LogoImage;
            }
        }
        else
        {
            logoimage = "images/Default_Logo.png";

        }
        //purchase order request
        var ch = DB1.rem_purchage.Count(a => a.frm == emailid && a.sts == "Pending");
        ViewBag.purchasereq = ch;

        //Notification message
        ViewBag.notificount = DB1.complaint_request.Count(a => a.userid == userid && a.sts == "Open");

        JSONReadWrite readWrite = new JSONReadWrite();
        dynamic people = Newtonsoft.Json.JsonConvert.DeserializeObject(readWrite.Read("LogoBackgroundColor.json", "~/Areas/ADMIN/Models/JsonData/"));
        string logoBgColor = people.ColorCode;


        var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Retailer").ToList();

        if (usernname.Count() > 0)
        {
            if (usernname.SingleOrDefault().Role == "Retailer")
            {
                favimage1 = usernname.SingleOrDefault().NickName;


            }
        }

    }

