@using Vastwebmulti.Models;
@model IEnumerable<Vastwebmulti.Models.microatm_rental_report_Result>
@{
    ViewBag.Title = "Dealer_Microatm_rental_report";
    Layout = "~/Areas/DEALER/Views/Shared/_Layout.cshtml";
    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Dealer").ToList();
    if (usernname.Count() > 0)
    {
        if (usernname.SingleOrDefault().Role == "Dealer")
        {
            var favimage = usernname.SingleOrDefault().NickName;
            ViewBag.nickname = favimage;
        }
    }
}
<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 81px !important;
    }

    table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px;
    }
</style>
<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 75px !important;
    }

    table.dataTable tbody th, table.dataTable tbody td {
        padding: 4px 5px;
    }

    .input-daterange.input-group.for-web-date input {
        width: 100% !important;
    }

    .input-daterange.input-group.for-web-date {
        width: 50% !important;
        float: left;
    }

    .for-web-date .custom-date-icon {
        border-right: 1px solid #ddd;
    }


    @@media screen and (max-width:768px) {

        .dealer-daybookreport .table-responsive {
            border: 0;
            overflow: scroll !important;
            padding-bottom: 7px !important;
        }
    }

    @@media screen and (max-width:580px) {


        .dealer-daybookreport .dealer-income-date {
            width: 100% !important;
            float: left !important;
            margin-top: 10px;
            padding-right: 15px !important;
        }

        .dealer-daybookreport .actualdealer-title p {
            font-size: 12px !important;
        }

        .recharge-report-dealer input {
            font-size: 12px;
        }

        .input-daterange.input-group.for-web-date input {
            text-align: right !important;
        }
    }
</style>
<section class="content dealer-daybookreport">
    <div class="container-fluid full-dealer-secondanimation">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Microatm Rental Report</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                @*<li><a href="javascript:void(0);">Account Active 2&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>*@
                <li><a href="javascript:void(0);">Rental Report</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card" style="margin-bottom: 10px; ">
                    <div class="row">
                        <div class="col-md-7 actualdealer-title dealer-none-fourclass" style="width:auto;float:left;">
                            <div class="bread-same-all-page breadsameall-second">

                                <ul style="float:left;padding:0px;">
                                    <li class="smli">
                                        <a href="@Url.Action("Dashboard","Home")" class="fullbodydycolorbg tmw-total-color-one">
                                            Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                                        </a>
                                    </li>

                                    <li class="fullbodydycolorbg tmw-total-color-one">
                                        Microatm&nbsp;Rental&nbsp;Report
                                    </li>
                                </ul>

                            </div>


                        </div>

                        <div class="col-md-2 recharge-report-dealer" style="width:auto;float:right;padding-left:5px;">
                            <div class="form-group" style="margin-bottom:0px;width:100%;float:left;">
                                <div style="padding-top:0px;float:right">
                                    <div class="for-search tablesearch-second" style="position:static;float:right;width:auto;padding-right: 5px;">
                                        <div class="search-after-third">
                                            <input id="myInput" type="text" name="myInput" placeholder="Search..." onkeyup="myFunction()" style="height: 32px; border: 1px solid #ccc; padding: 5px 8px;" />
                                        </div>
                                    </div>
                                    @*<button class="white-success-button" style="height:32px;border:1px solid #b1a6a638;background:#b1a6a638;float: right;padding: 0px 4px;margin-top:-1px;" onclick="findtotal()">Total</button>*@
                                    <div class="web-white-filter fil" style="float: left;margin-right: 0px;margin-top:0px;">
                                        <input type="button" id="btnExport" value="Export" style="margin-left:0px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);
                                background-repeat: no-repeat;background-position: 4px center;padding-left: 20px;">
                                        <input type="button" id="btnPDF" value="PDF" style="margin-left:2px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);
                                background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">
                                    </div>
                                </div>

                            </div>
                        </div>

                        <div class="col-md-6 dealer-income-date" style="float:right;width:auto;padding-right:0px;">

                            @using (Html.BeginForm("Dealer_Microatm_rental_report", "Home", FormMethod.Post))
                            {
                                <div class="col-md-8 col-sm-8 col-xs-8" style="padding:0px;">
                                    <div class="input-daterange input-group for-web-date" style="width:100%;padding-right:2px;">
                                        <div class="custom-date-icon" style="height: 32px;">
                                            <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg" aria-hidden="true"></i>
                                        </div>
                                        @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; height:32px;", @autocomplete = "off" })
                                    </div>
                                    <div class="input-daterange input-group for-web-date" style="width:100%;padding-left:2px;">
                                        <div class="custom-date-icon" style="height: 32px;">
                                            <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg" aria-hidden="true"></i>
                                        </div>
                                        @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; height:32px;", @autocomplete = "off" })
                                    </div>
                                </div>
                                <div class="col-md-4 col-sm-4 col-xs-4" style="padding:0px 5px;padding-right:0px;">
                                    <center>
                                        <button type="submit" class="btn waves-effect" style="width:100%; height:32px;">

                                            <span style="top:0px;color:black;">Search</span>
                                        </button>
                                    </center>
                                </div>
                            }

                        </div>

                        <div class="col-md-2 pdf-totalbuttonclass" style="display:none;">
                            <div class="web-white-filter" style="float:right;">
                                <table class="dataTable js-exportable ">
                                    <thead>
                                        <tr>
                                            <td></td>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card all-reporttable-css">

                    <div>
                        <div class="table-responsive table-responsive-scrolnone tableseconddes-dealer" style="position:inherit;overflow:auto;">
                            <table class="table table-bordered table-striped table-hover example-second third-design-table" style="width:100%;background:#f9f9f9;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>S.N</th>
                                        <th>Frm&nbsp;Name</th>
                                        <th>DeviceId</th>
                                        <th>Plan&nbsp;Name</th>
                                        <th>Num.of&nbsp;Trans</th>
                                        <th>Trans&nbsp;Date</th>
                                        <th>Curr&nbsp;Date</th>
                                        <th>@ViewBag.nickname&nbsp;Pre</th>
                                        <th>@ViewBag.nickname&nbsp;Commission</th>
                                        <th>@ViewBag.nickname&nbsp;GST</th>
                                        <th>@ViewBag.nickname&nbsp;TDS</th>
                                        <th>@ViewBag.nickname&nbsp;Post</th>

                                    </tr>
                                </thead>
                                <tbody id="body" class="alin  chnj">
                                    @{int i = 1;}
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td>@Html.DisplayFor(modelItem => item.Frm_Name)</td>
                                            <td>@Html.DisplayFor(modelItem => item.deviceid)</td>
                                            <td>@Html.DisplayFor(modelItem => item.planname)</td>
                                            <td>@Html.DisplayFor(modelItem => item.nooftrans)</td>
                                            <td>@Html.DisplayFor(modelItem => item.transdate)</td>
                                            <td>@Html.DisplayFor(modelItem => item.currdate)</td>
                                            <td>@Html.DisplayFor(modelItem => item.dlmpre)</td>
                                            <td>@Html.DisplayFor(modelItem => item.dlmcomm)</td>
                                            <td>@Html.DisplayFor(modelItem => item.dlmgst)</td>
                                            <td>@Html.DisplayFor(modelItem => item.dlmtds)</td>
                                            <td>@Html.DisplayFor(modelItem => item.dlmpost)</td>

                                        </tr>
                                        i++;
                                    }
                                </tbody>
                            </table>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script type="text/javascript">
    $(function () {

               $('.input-daterange').datepicker({
                format: "yyyy-mm-dd",
                todayHighlight: true,
                autoclose: true

            });
            var val = '@ViewBag.chk';
            if (val != "post") {
                $("#txt_frm_date").datepicker("setDate", new Date());
                $("#txt_to_date").datepicker("setDate", new Date());
            }


        });
</script>
