<script>
    $(document).ready(function(){
        $("#RetailerId").change(function () {
            var mid = $('option:selected', $(this)).val();
            if (mid != "Select Retailer" && mid != "") {
                $.ajax({
                    type: 'Post',
                    url: "@Url.Action("R_Creditchk", "Home")",
                    data: { MID: mid },
                    dataType: 'json',
                    cache: false,
                    async: false,
                    success: function (data) {
                        if (data > 0) {
                            $('#msg').html(data)
                            $("#creditModal").modal('show');
                        }
                    }
                });
            }
        });
    });
</script>

