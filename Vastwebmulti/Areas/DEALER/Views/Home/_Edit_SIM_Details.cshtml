                <td><p style="margin-top:6px;"> @item.GetType().GetProperty("insertdate").GetValue(item, null)</p></td>
                <td>
                    @if (item.GetType().GetProperty("status").GetValue(item, null) == true)
                    {
                        <span class="onoffswitch costom-on-second" style="float: left;border:0px;">
                            <button class="costom-on clscall" data-bind="btnsts_@item.GetType().GetProperty("idno").GetValue(item, null)" value="ON" id="@item.GetType().GetProperty("idno").GetValue(item, null)" onclick="OperatorCodestatusupdate('@item.GetType().GetProperty("idno").GetValue(item, null)','Y')" style="border:1px solid #aaa4a4;">ON</button>
                        </span>

                    }
                    else if (item.GetType().GetProperty("status").GetValue(item, null) == false)
                    {
                        <span class="onoffswitch costom-off-second" style="float: left;border:0px;">
                            <button class="custom-off clscall" data-bind="btnsts_@item.GetType().GetProperty("idno").GetValue(item, null)" id="@item.GetType().GetProperty("idno").GetValue(item, null)" value="OFF" onclick="OperatorCodestatusupdate('@item.GetType().GetProperty("idno").GetValue(item, null)','N')" style="border:1px solid #aaa4a4;">OFF</button>
                        </span>

                    }
                </td>

                <td class="last-td">
                    <button type="button" onclick="Editmode('@item.GetType().GetProperty("idno").GetValue(item, null)')" id="btnEdit" class="btn waves-effect shownextrow switch-edit-button swichedit-second" value="Edit">
                        <p>Edit</p>
                    </button>
                </td>
            </tr>
            i++;
        }
    }
}
<script>
    function btnSavedata(idno) {
         $.ajax({
             url: '@Url.Action("UpdateSeller_SIM", "Home")',
             type:'POST',
             data: {
                 idno: idno, dailyhome_limit: $('#dailyhome_limit').val(), dailyrom_limit: $('#dailyrom_limit').val(), circle: $('#circle_edit').val(), simnumber: $('#simnumber').val()
                 , simname: $('#simname').val(), userid: $('#userid').val(), password: $('#password').val(), pin: $('#pin').val()
                 , remainbal: $('#remainbal').val(), totalrecharge: $('#totalrecharge').val(), purchasecomm: $('#purchasecomm').val()
             },
             success: function (data) {

                 setTimeout(function(){ $('#addcommbody').html(data); }, 500);

            }
        });


    }

     $('.btnssl1').on('click', function () {
                    var $this = $(this);
                    $this.button('loading');
                    setTimeout(function () {
                        $this.button('reset');
                    }, 500);
     });

    $('#circle_edit').val('@ViewBag.sellerSIMChargeByID.circle').change();
</script>