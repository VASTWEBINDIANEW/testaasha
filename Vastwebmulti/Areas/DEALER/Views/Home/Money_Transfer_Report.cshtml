@model Vastwebmulti.Areas.RETAILER.Models.Money_transfer_report
@{
    ViewBag.Title = "Money_Transfer_Report";
    Layout = "~/Areas/DEALER/Views/Shared/_Layout.cshtml";
}
<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 75px !important;
    }

    .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {
        height: 20px;
    }

    @@media screen and (max-width:1290px){
        .money-transferreportpage .aepspdfexlto-button .web-white-filter.fil {margin: 0 !important;padding-right:3px;}
        .money-transferreportpage .aepspdfexlto-button .web-white-filter.fil input:last-child {margin-left: 0 !important;}
    }

    @@media screen and (max-width:992px){
        .money-transferreportpage .aeps-reportbutton ,.money-transferreportpage .col-md-2{float: left;}
        .money-transferreportpage .money-transfere-aeps {float:right;width:70%;}
        .money-transferreportpage .money-transfere-aeps .aeps-selectclass {float: left;width:23%;}
        .money-transferreportpage .col-md-5.aeps-dateclass {float: left;width: 40%;}
        .money-transferreportpage .col-md-5.aeps-dateclass input {font-size: 12px;}
        .money-transferreportpage .money-transfere-aeps .aeps-selectclass .select2 span {font-size: 12px;}
        .money-transferreportpage .col-md-2 .form-line button span {font-size: 12px;}
        .money-transferreportpage .col-md-2.aepspdfexlto-button {float: right !important;padding: 0;margin-top: 10px;width: auto;}
        .money-transferreportpage .col-md-2.aepspdfexlto-button .row {margin: 0;}
        .money-transferreportpage .money-transfere-aeps .col-md-12 {padding-right: 0;}
        .money-transferreportpage .money-transfere-aeps .col-md-12 .row.clearfix {margin: 0;}

    }
    @@media screen and (max-width:768px){
        .money-transferreportpage .money-transfere-aeps {width: 100%;float: left;padding: 0;}
        .money-transferreportpage .money-transfere-aeps .row {margin: 0;}
        .money-transferreportpage .money-transfere-aeps .col-md-12 {padding: 0;}
        .money-transferreportpage .money-transfere-aeps .aeps-selectclass {padding-left: 0;}
        .money-transferreportpage .table-responsive {border: 0;}
        .money-transferreportpage .col-md-2.aepspdfexlto-button {position: absolute;right: 0;top: -10px;}
        .money-transferreportpage .col-md-2.dmtsearchclass {float: left;width: 14%;}
        .money-transferreportpage .table-responsive {padding-bottom: 15px;}
        .money-transferreportpage .table-responsive{position:relative !important;z-index:9;}
    }

    @@media screen and (max-width:520px){
        .money-transferreportpage .money-transfere-aeps .aeps-selectclass {float: left;width: 50%;margin-bottom: 10px;}
        .money-transferreportpage .col-md-5.aeps-dateclass {float: left;width: 78%;}
        .money-transferreportpage .col-md-2.dmtsearchclass button {width: 100%;float: left;}
        .money-transferreportpage .col-md-2.dmtsearchclass {float: left;width: 22%;}
        .money-transferreportpage .col-md-2.dmtsearchclass button {padding-left: 0;padding-right: 0;}
    }
    @@media screen and (max-width:420px){
        .money-transferreportpage .col-md-2.aepspdfexlto-button {position: static;}
    }

</style>
<style>
    .slab-setting-menu li a.activee {
        background-image: linear-gradient(to right, var(--main-bg-lcolor), var(--main-bg-rcolor)) !important;
    }
</style>
<section class="content money-transferreportpage">
    <div class="container-fluid full-dealer-secondanimation">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Money Transfer Report</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Report's&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Money Transfer Report</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    <div class="col-md-4 aeps-reportbutton">
                        <div style="margin-left:-14px;">
                            @Html.Partial("Moneytransferreportpartialview")
                        </div>
                    </div>
                    <div class="col-md-6 money-transfere-aeps">
                        <div class="row">


                            <div class="col-md-12">

                                <div class="row clearfix">

                                    @using (Html.BeginForm("Money_Transfer_Report", "Home", FormMethod.Post))
                                    {



                                        <div class="col-md-3 only-select-css aeps-selectclass" style="display:block;padding-right:5px;" id="rem">
                                            <div class="form-group">
                                                <div class="" style="">
                                                    @Html.DropDownList("allretailer", ViewBag.allretailer as SelectList, "Select User", new { id = "allretailer", @class = "selectpicker form-control for-select2", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;height:32px;" })
                                                </div>
                                            </div>
                                        </div>


                                        <div class="col-md-2 only-select-css aeps-selectclass" style="padding:0px;">
                                            <div class="form-group">
                                                <div class="" style="">
                                                    @Html.DropDownList("ddl_status", new List<SelectListItem>
                                            {
                                            new SelectListItem{ Text="Status",Value="ALL",},
                                            new SelectListItem{Text="SUCCESS",Value="SUCCESS"},
                                            new SelectListItem{Text="Pending",Value="PENDING"},
                                            new SelectListItem{Text="FAILED",Value="FAILED"}
                                            }, new { @class = "selectpicker form-control for-select2", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;height:32px;" })

                                                </div>

                                            </div>
                                        </div>

                                        @*<div class="col-md-2">
                                            <div class="form-line" style="margin-top: 5px;border:1px solid #dddddd;">
                                                @Html.DropDownList("api_name", ViewBag.apiname as SelectList, "Select Api Name", new { @style = "margin-top:0px", @class = "selectpicker form-control", data_live_search = "true", })
                                            </div>
                                        </div>*@
                                        <div class="col-md-5 aeps-dateclass" style="padding:0px 5px;">
                                            <div class="form-group for-web-date" style="margin-bottom:0px;margin-top:0px;">
                                                <div class="input-daterange input-group">
                                                    <div class="all-report-inputclass all-report-inputclass-left">
                                                        <div class="custom-date-icon border-colorchangecss" style="height: 32px;">
                                                            <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg" aria-hidden="true"></i>
                                                        </div>
                                                        @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;height:32px;padding-left:20px;", autocomplete = "off" })
                                                    </div>
                                                    @*<span class="input-group-addon">
                                                        <i class="fa fa-exchange"></i>
                                                    </span>*@
                                                    <div class="all-report-inputclass all-report-inputclass-right">
                                                        <div class="custom-date-icon border-colorchangecss" style="height: 32px;">
                                                            <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg" aria-hidden="true"></i>
                                                        </div>
                                                        @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; height:32px;padding-left:20px;", autocomplete = "off" })
                                                    </div>
                                                </div>
                                                <!-- /.input group -->
                                            </div>
                                        </div>
                                        <div class="col-md-2 dmtsearchclass" style="padding:0px;">
                                            <div class="form-group">
                                                <div class="form-line" style="border-bottom:none;">
                                                    <button value="LIVE" type="submit" class="btn" id="btntype" name="btntype" style=" height:32px;border:1px solid #ccc;background:#eeebeb;">
                                                        <i class="fa fa-search" style="top:-1px;font-size:13px;color:#444;"></i>
                                                        <span style="top:-1px;color:#444;">Search</span>
                                                    </button>


                                                </div>
                                            </div>
                                        </div>

                                    }


                                </div>

                            </div>





                        </div>
                    </div>
                    <div class="col-md-2 aepspdfexlto-button">
                        <div class="row">
                            <div class="form-group" style="margin-top:-18px; ">
                                <div style="padding-top:18px; float:right">
                                    <button class="white-success-button" style="height:32px;border:1px solid #ccc;background:#eeebeb;" onclick="findtotal()">Total</button>
                                    <div class="web-white-filter fil" style="float: left;margin-right: 5px;">
                                        <input type="button" id="btnExport" value="Export" style="margin-left:0px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);
                                background-repeat: no-repeat;
                                background-position: 4px center;
                                padding-left: 20px;">
                                        <input type="button" id="btnPDF" value="PDF" style="margin-left:2px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);
                                background-repeat: no-repeat;
                                background-position: 4px center;
                                padding-left: 19px;">
                                    </div>
                                </div>
                                <div class="white-success" style="display:none; float: right; margin-top: 20px;">
                                    <span id="successtotal" class="btn btn-success waves-effect" style="font-size: 13px;padding:9px; color:white;font-weight:600;" title="Total  Success"><i style="font-size:15px;top:1px;" class="fa fa-check-circle-o" aria-hidden="true"></i> </span>
                                    <span id="Failedtotal" class="btn btn-danger waves-effect" style="font-size: 13px;padding:9px; color:white;font-weight:600;" title="Total  Failed"><i style="font-size:15px;top:1px;" class="fa fa-times-circle-o" aria-hidden="true"></i> </span>
                                    <span id="Pendingtotal" class="btn btn-warning waves-effect" style="font-size: 13px;padding:9px;color:white; font-weight:600;" title="Total  Pending"><i style="font-size:15px;top:1px;" class="fa fa-question-circle-o" aria-hidden="true"></i> </span>

                                </div>
                            </div>
                        </div>
                    </div>


                </div>
            </div>
        </div>








        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card all-reporttable-css">


                    <div>
                        <div>
                            <div class="table-responsive tableseconddes-dealer" style="position:inherit;">
                                <table id="mmm" class="table table-bordered table-striped table-hover" style="width:100%; font-size:12px;">
                                    <thead style="background-color:whitesmoke;">
                                        <tr>
                                            <th style="width:100px;">Status</th>
                                            <th>Type</th>

                                            <th>Beneficiary&nbsp;Account&nbsp;</th>
                                            <th>Sender&nbsp;No</th>
                                            <th>Net&nbsp;T/F</th>
                                            <th>Total&nbsp;Transfer&nbsp;</th>
                                            <th>User&nbsp;INC</th>
                                            <th>My&nbsp;Pre</th>
                                            <th>My&nbsp;INC</th>
                                            <th>My&nbsp;Post</th>

                                            <th>Request&nbsp;Date</th>
                                            @*<th>Bank&nbsp;Ref&nbsp;No</th>
                                            <th>Bank&nbsp;Name</th>
                                            <th>IFSC&nbsp;Code</th>*@
                                            @*<th>Request&nbsp;ID</th>
                                            <th>Common&nbsp;Trans&nbsp;ID</th>
                                            <th>REM&nbsp;ID</th>
                                            <th>REM&nbsp;Name</th>
                                            <th>REM&nbsp;Frm&nbsp;Name</th>
                                            <th>
                                                <span>REM.Pre&nbsp;Amt&nbsp;</span><span style="padding-left:-4px;">&nbsp;│&nbsp;</span>Debit<span style="padding-left:38px;">&nbsp;│&nbsp;</span><span>REM.Post&nbsp;Amt</span>
                                            </th>
                                            <th>Total&nbsp;Amount</th>
                                            <th>Response&nbsp;Date</th>*@


                                        </tr>
                                    </thead>
                                    <tbody id="trow" class="alin">
                                        @{
                                            Html.RenderAction("_MoneyTransferReport", "Home", new { Model = Model });
                                        }
                                    </tbody>
                                </table>
                                <div id="loadingdiv" style="text-align:center;display:none;margin-bottom:20px;">
