@model IEnumerable<Vastwebmulti.Models.dealer_total_fund_recive_by_admin_Result>
@{
    ViewBag.Title = "ReceiveFund_by_admin";
    Layout = "~/Areas/DEALER/Views/Shared/_Layout.cshtml";
}
<style>
    .dropdown-menu {margin-top: 75px !important;}
     
    .btn-group, .btn-group-vertical {box-shadow: none;}

    .ppp {margin-top: -20px !important;}

    .form-inline .bootstrap-select.btn-group, .form-horizontal .bootstrap-select.btn-group, .form-group .bootstrap-select.btn-group {height: 29px;}
    .selected.active::before{display:none;}

    @@media screen and (max-width:768px){
        .receivefundbyadmin .table-responsive{position:relative !important;z-index:9;}
        .receivefundbyadmin .table-responsive.web-white-table.table-responsive-customeclass {padding-bottom: 15px;}
        .fundrecive-dealer {width: 100% !important;text-align: center;}
        .reciveddate-dealer {width: 100% !important;float: left !important;}
        .search-button-report {float: left !important;padding-left: 15px !important;width: auto !important;}
        .search-button-report {order: 4;float: left !important;width: 30% !important;}
        .card.cardrecived-dealer .col-md-4.reciveddate-dealer {order: 2;}
        .card.cardrecived-dealer form {display: inline-grid;width: 100%;float: none;}
        .col-md-2.recharge-report-dealer {
            width: 68% !important;float: right !important;order: 3;position: absolute;bottom: 0;right: -16px;
        }
        .card.cardrecived-dealer .col-md-5.fundrecive-dealer {order: 1;}
        .reciveddate-dealer .form-group {margin-bottom: 10px;}
        .card.all-reporttable-css {margin-top: 15px;margin-bottom: 0px;}

    }

    @@media screen and (max-width:520px){
        .receivefundbyadmin table tr td button.btn.dropdown-toggle.btn-default::before, .selectdiv::before {width: 7px;height: 7px;right:-4px;top:12px;}
        .table-responsive-customeclass tbody tr td .btn-group {width: 100%;float: left;}
        .table-responsive-customeclass tbody tr td .btn-group button{width:100% !important;padding-left:4px;padding-right:4px;text-align:left;}
        .table-responsive-customeclass table thead tr th:first-child {padding-right: 110px;}

    }

    @@media screen and (max-width:420px){
        .receivefundbyadmin table tr td button.btn.dropdown-toggle.btn-default::before{top:9px;}
        .receivefundbyadmin table tr td button.btn.dropdown-toggle.btn-default{font-size:12px !important;}
    }

</style>
<section class="content receivefundbyadmin">
    <div class="container-fluid full-dealer-secondanimation">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>ReceiveFund By Admin</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Account Active&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">ReceiveFund By Admin</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix" style="margin:0px;">
            <div class="col-md-12" style="padding-left:0px;width:100%;float:left;">
                <div class="card cardrecived-dealer" style="margin-bottom:0px;">
                    <div class="row">
                        @using (Html.BeginForm("ReceiveFund_by_admin", "Home", FormMethod.Post))
                        {

                            <div class="col-md-5 fundrecive-dealer dealer-none-fourclass" style="width:auto;float:left;padding-right:0px;">
                                <div class="form-group">
                                    <ol style="padding:0px;">
                                        <li class="active" style="color:#555; font-size:15px;font-weight:700;">Fund&nbsp;Receive&nbsp;From&nbsp;Admin&nbsp;History</li>
                                    </ol>
                                </div>

                            </div>
                            <div class="col-md-2 recharge-report-dealer" style="width:auto;float:right;padding-left:5px;padding-right:0px;">
                                <div class="form-group" style="margin-bottom:0px;width:100%;float:left;">
                                    <div style="padding-top:0px;float:right">
                                        @*<button class="white-success-button" style="height:32px;border:1px solid #b1a6a638;background:#b1a6a638;float: right;padding: 0px 4px;margin-top:-1px;" onclick="findtotal()">Total</button>*@
                                        <div class="web-white-filter fil" style="float: left;margin-right: 0px;margin-top:0px;">
                                            <input type="button" id="btnExport" value="Export" style="margin-left:0px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);
                                background-repeat: no-repeat;background-position: 4px center;padding-left: 20px;">
                                            <input type="button" id="btnPDF" value="PDF" style="margin-left:2px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);
                                background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">
                                        </div>
                                    </div>

                                </div>
                            </div>
                            <div class="col-md-1 search-button-report" style="padding:0px 5px;float:right;padding-right:0px;">
                                <center>
                                    <button type="submit" class="btn  waves-effect" style="width:100%; height:32px;">

                                        <span style="color:#555;"><i class="fa fa-search" style="top:0px;font-size:13px;color:#444;left:-4px;" aria-hidden="true"></i>Search</span>
                                    </button>
                                </center>
                            </div>
                            <div class="col-md-4 reciveddate-dealer" style="padding:0px;float:right;">
                                <div class="form-group for-web-date" style="width:100%;">
                                    <div class="input-daterange input-group">
                                        <div class="all-report-inputclass all-report-inputclass-left">
                                            <div class="custom-date-icon" style="height: 32px;">
                                                <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg" aria-hidden="true"></i>
                                            </div>
                                            @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; ", autocomplete = "off" })
                                        </div>
                                        @*<span class="input-group-addon">
                                            <i class="fa fa-exchange"></i>
                                        </span>*@
                                        <div class="all-report-inputclass all-report-inputclass-right">
                                            <div class="custom-date-icon" style="height: 32px;">
                                                <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg" aria-hidden="true"></i>
                                            </div>
                                            @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;", autocomplete = "off" })
                                        </div>
                                    </div>
                                    <!-- /.input group -->
                                </div>
                            </div>


                        }
                        <div class="col-md-2 pdf-totalbuttonclass">
                            <div class="web-white-filter" style="float:right;">
                                <table class="dataTable js-exportable ">
                                    <thead>
                                        <tr>
                                            <td></td>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card all-reporttable-css">

                    <div>
                        <div class="table-responsive web-white-table table-responsive-customeclass tableseconddes-dealer" style="position:inherit;">
                            <table class="table table-bordered table-striped table-hover third-design-table" style="width:100%;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Admin&nbsp;Info</th>
                                        <th>Total&nbsp;Transfer</th>
                                        <th>Type</th>
                                        <th>Remain&nbsp;Pre</th>
                                        <th>Remain&nbsp;Post</th>
                                        <th>Current&nbsp;Credit</th>
                                        <th>Old&nbsp;Credit</th>
                                        <th>Net&nbsp;Amt</th>
                                        <th>Date</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr style="background:no-repeat;">
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <div class="btn-group" role="group">
                                                        <button type="button" class="btn btn-default waves-effect dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="true" title="Click to All information">
                                                            @item.email
                                                        </button>
                                                        <ul class="dropdown-menu ppp">
                                                            <li>
                                                                <a href="javascript:void(0);" class="waves-effect waves-block" style="border-bottom:1px solid #f1efef;line-height:11px;">
                                                                    @item.Name
                                                                    <p style="font-size: 11px;margin-left: 0px;margin-top: 6px;">Name</p>
                                                                </a>
                                                            </li>

                                                            <li>
                                                                <a href="javascript:void(0);" class="waves-effect waves-block" style="border-bottom:1px solid #f1efef;line-height:11px;">
                                                                    @item.comment
                                                                    <p style="font-size: 11px;margin-left: 0px;margin-top: 6px;">Comment</p>
                                                                </a>
                                                            </li>

                                                        </ul>

                                                    </div>
                                                </div>

                                            </td>
                                            <td><p style="margin-top:6px;">@item.Newbalance</p></td>

                                            <td><p style="margin-top:6px;">@item.bal_type</p></td>
                                            <td><p style="margin-top:6px;">@item.dealer_prebal</p></td>
                                            <td><p style="margin-top:6px;">@item.dealer_postbal</p></td>
                                            <td><p style="margin-top:6px;">@item.cr</p></td>
                                            <td><p style="margin-top:6px;">@item.Oldcreditbalance</p></td>

                                            <td><p style="margin-top:6px;">@item.balance</p></td>
                                            <td><p style="margin-top:6px;">@item.date_dlm</p></td>

                                        </tr>
                                    }
                                </tbody>
                                <tfoot style="background-color:whitesmoke;">
                                    <tr>
                                        <td>Total</td>
                                        <td>@Model.Sum(m => m.balance)</td>
                                        <td></td>
                                        <td>@Model.Sum(m => m.dealer_prebal)</td>
                                        <td>@Model.Sum(m => m.dealer_postbal)</td>
                                        <td>@Model.Sum(m => m.cr)</td>
                                        <td>@Model.Sum(m => m.Oldcreditbalance)</td>
                                        <td>@Model.Sum(m => m.Newbalance)</td>
                                        <td></td>

                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />

<script>

    $(function()
    {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
    });
</script>

<script>
    $(function () {
        $('#example').DataTable({
            dom: 'Bfrtip',
            buttons: [
                'copyHtml5',
                'excelHtml5',
                'csvHtml5',
                'pdfHtml5',
                'print'
            ]
        });
    });
</script>
