@model IEnumerable<Vastwebmulti.Models.bank_info>
@{
    ViewBag.Title = "Bank_Details";
    Layout = "~/Areas/DEALER/Views/Shared/_Layout.cshtml";
}

<style>
    @@media screen and (max-width:990px){
        .bank-detailspage .col-md-6{width:50%;float:left;}
    }
    @@media screen and (max-width:768px){
        .bank-detailspage .col-md-6{width:100%;}
    }
    @@media screen and (max-width:420px){
        .bank-detailspage table tr th{padding:10px 5px;font-size:12px !important;}
        .bank-detailspage .col-md-12 .card .form-group {margin-bottom: 0;}
        .bank-detailspage table tr th:first-child {width: 46% !important;}

    }
</style>



<section class="content bank-detailspage">
    <div class="container-fluid full-dealer-secondanimation">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>All Bank Information</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Account Active&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Bank Details</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="bankdeatils-dealer-third">
            <div class="row clearfix">
                <div class="col-md-12 dealer-none-fourclass">
                    <div class="card" style="margin-bottom: 0px; ">
                        <div class="form-group" style="margin-top: 2px;">
                            <ol style="margin-left:0px;padding:0px;">
                                <li class="active" style="color:#555; font-size:20px;font-weight:700;">All Bank Information</li>
                            </ol>
                        </div>

                    </div>
                </div>
                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                    <div class="card all-bank-details">
                        <div>
                            <div class="row">
                                @foreach (var item in Model)
                                {
                                    <div class="col-md-6 dealerbank-second">
                                        <table border="1" style="margin-top:5px; margin-bottom:5px; float:left;border:10px solid #e4e1e1;">
                                            <tr>
                                                <th style="width:220px; height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black; position:initial;border:1px solid #dddddd;background-color:whitesmoke;">
                                                    Bank Name
                                                </th>
                                                <th style="width:320px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                    @Html.DisplayFor(modelItem => item.banknm)
                                                </th>
                                            </tr>
                                            <tr>
                                                <th style="width:220px;background-color:whitesmoke;   height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                    Branch Name
                                                </th>
                                                <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                    @Html.DisplayFor(modelItem => item.branch_nm)
                                                </th>
                                            </tr>
                                            <tr>
                                                <th style="width:220px;background-color:whitesmoke;  height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                    IFSC CODE
                                                </th>
                                                <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                    @Html.DisplayFor(modelItem => item.ifsccode)
                                                </th>
                                            </tr>
                                            <tr>
                                                <th style="width:220px;background-color:whitesmoke; height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                    Account Number
                                                </th>
                                                <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                    @Html.DisplayFor(modelItem => item.acno)
                                                </th>
                                            </tr>
                                            <tr>
                                                <th style="width:220px; height: 42px;background-color:whitesmoke; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                    Account Type
                                                </th>
                                                <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                    @Html.DisplayFor(modelItem => item.actype)
                                                </th>
                                            </tr>
                                            <tr>
                                                <th style="width:220px; height: 42px;background-color:whitesmoke; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black; position:initial;border:1px solid #dddddd;">
                                                    Account Holder Name
                                                </th>
                                                <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                    @Html.DisplayFor(modelItem => item.holdername)
                                                </th>
                                            </tr>
                                            <tr>
                                                <th style="width:220px; background-color:whitesmoke; height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                    Branch Address
                                                </th>
                                                <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                    @Html.DisplayFor(modelItem => item.address)
                                                </th>
                                            </tr>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>



            </div>
        </div>
    </div>


</section>

