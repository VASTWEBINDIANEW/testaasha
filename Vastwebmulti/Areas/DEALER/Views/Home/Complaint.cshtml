@model IEnumerable<Vastwebmulti.Models.proc_Complaint_request_Result>
@{
    ViewBag.Title = "Complaint";
    Layout = "~/Areas/DEALER/Views/Shared/_Layout.cshtml";
}
<link href="~/Swalalert/chatting.css" rel="stylesheet" />

<style>
    .body.admin-sendmassegeclass {
    width: 100%;
    float: left;
}
    .body.admin-sendmassegeclass .form-group {
    margin-top: 0 !important;
}
    .admin-replymassage span.chat-img.img_cont_msg {
    height: auto;
    width: auto;float:left;
}
    .admin-replymassage span.chat-img.img_cont_msg img {
    width: 44px;
    height: 44px;border-radius:50%;
}
    .admin-replymassage span.chat-img.img_cont_msg p.rounded-circle.user_img_msg {
    border-radius: 0 !important;
    width: auto;
    height: auto;
    border: 0;
    background: transparent;
    font-weight: bold;
    color: var(--main-bg-lcolor);
}
    .admin-replymassage span.chat-img.img_cont_msg p.rounded-circle.user_img_msg {
    border-radius: 0 !important;
    width: auto;
    height: auto;
    border: 0;
    background: transparent;
    font-weight: bold;
    color: var(--main-bg-lcolor);
}
    .admin-replymassage .showrepalychat {
    width: 48%;
    margin-top: 0;
    float: left;
    height: auto;
    margin-bottom: 0;
    border-radius: 3px;
    min-height: inherit;
    margin-left: 40px;
    margin-top:10px;
    box-shadow: 0px 3px 5px 0px #555;
}
    .admin-replymassage .showrepalychat p {
    color: #fff !important;font-size:14px;
}
    .admin-replymassage .showrepalychat span.msg_time {
    position: static !important;
    float: right;
    color: #fff;
    font-size: 14px;
    width: 100%;
    text-align: right;
}
    .admin-replymassage li.d-flex.justify-content-start.mb-4 {
    display: block !important;
}
    .admin-replymassage .showrepalychat span.msg_time .fa.fa-clock-o {
    position: relative;
    left: -5px;
    font-weight: 400;
    font-size: 14px;
}
    .admin-replymassage .showrepalychat::before{content: "";
width: 27px;right: 0px;left: -25px;top: 0;position: absolute;border-style: solid;border-width: 0 20px 15px 0;border-color: transparent var(--main-bg-lcolor) transparent transparent;
    }
    .admin-replymassage .showrepalychat{position:relative;}
    .classmechatsent .img_cont_msg {
    border: 0;border-radius: 0;width: auto;height: auto;
}
    .classmechatsent .img_cont_msg img {
    height: 44px;width: 44px;border-radius: 50%;
} 
    .classmechatsent .img_cont_msg p.rounded-circle.user_img_msg {
    border: 0;border-radius: 0 !important;width: auto;
    height: auto;font-weight: bold;color: #555;
    text-align: center;margin-bottom: 0;font-size: 14px;
}
    .classmechatsent .chat-body.clearfix.msg_cotainer_send {
    width: 48%;border-radius: 3px;margin-right:40px;margin-top:10px;box-shadow: 0px 3px 5px 0px #555;
} 
    .classmechatsent .chat-body.clearfix.msg_cotainer_send .msg_time_send {
    position: static !important;width: 100%;float: left;
    text-align: right;font-size: 14px;
}
        .classmechatsent .chat-body.clearfix.msg_cotainer_send::before {
            width: 27px;right: 0px;top: 0;position: absolute;
            border-style: solid;
            border-width: 0 20px 15px 0;
            border-color: transparent transparent var(--main-bg-rcolor) transparent;
            right: -18px;
        }
        .classmechatsent .chat-body.clearfix.msg_cotainer_send .msg_time_send, .classmechatsent .chat-body.clearfix.msg_cotainer_send p {
            color: #fff;
            font-size: 14px;
        }
        .classmechatsent .chat-body.clearfix.msg_cotainer_send .msg_time_send .fa.fa-clock-o {
    position: relative;
    left: -5px;
    font-size: 14px;
    font-weight: 400;
}
        .admin-replymassage .showrepalychat {
    background: var(--main-bg-lcolor) !important;
}
        .classmechatsent .chat-body.clearfix.msg_cotainer_send {
    background: var(--main-bg-rcolor);
}
        @@media screen and (max-width:766px){
            .body.admin-sendmassegeclass ,.admin-replymassage .panel-body{
    height: auto !important;
}
        }
    @@media screen and (max-width:520px) {
        .admin-replymassage .showrepalychat, .classmechatsent .chat-body.clearfix.msg_cotainer_send {
            width: 76%;
            float: left;
        }
        .body.admin-sendmassegeclass textarea {
    height: 80px !important;
}
    }
    @@media screen and (max-width:420px){
        .admin-replymassage .showrepalychat {
    margin-left: 20px;
    
}
        .classmechatsent .chat-body.clearfix.msg_cotainer_send {
    margin-right: 30px;
    
}
        .classmechatsent .chat-body.clearfix.msg_cotainer_send, .admin-replymassage .showrepalychat {
            width: 75%;
        }
        .header-sentmassegeclass .col-md-12 button span {
    font-size: 16px !important;margin-left:0px !important;
}
        .header-sentmassegeclass .col-md-12 button .fa.fa-send-o {
    font-size: 14px !important;
    left: -5px !important;
}
        .header-sentmassegeclass .col-md-12 button {
    padding: 4px 12px;
}

    }
</style>

<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Complaint</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                @*<li><a href="javascript:void(0);">Report's&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>*@
                <li><a href="javascript:void(0);">Chat's</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-4 header-sentmassegeclass">
                <div class="card" style="margin-top:0px;background:#f5f5f5;">

                    <div class="header" style="background-color: #dedddd; width: 100%; float: left; padding: 10px 15px; padding-bottom: 9px; border-top-left-radius: 3px; border-top-right-radius: 3px; ">
                        <h2>
                            <i class="fa fa-keyboard-o" aria-hidden="true" style="color:#555; font-size:14px;float:left;margin-right:5px;"></i>&nbsp;&nbsp;<span style="color:#555;float:left;font-size:14px;">Insert Complaint</span>
                        </h2>

                    </div>
                    @using (Html.BeginForm("Complaint_insert", "Home", FormMethod.Post))
                    {
                        <div class="body admin-sendmassegeclass" style="height:80vh;">
                            <div class="form-group" style="margin-top:22px;">
                                <div class="">
                                    <textarea id="message" name="message" class="form-control" style="height:189px; border:1px solid #1b171714;" required="" placeholder="Enter Message"></textarea>

                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <button type="submit" class="btn  waves-effect" style="border:1px solid #c7c2c2;background:#dedddd;width:100%;height:auto;">
                                        <i class="fa fa-send-o" style="font-size: 18px;top:2px;left: -13px;padding: 8px 8px 8px 8px;background: whitesmoke;border-radius: 35px;"></i>
                                        <span style="top: 3px;font-weight: 600;font-size: 19px;text-transform: uppercase;">Insert Message</span>
                                    </button>
                                </div>
                                <div class="col-xs-6">
                                    <button type="reset" class="btn  waves-effect" style="border:1px solid #c7c2c2;background:#dedddd;width:100%;">
                                        <i class="fa fa-eraser" style="top: 1px;"></i>
                                        <span style="top:-2px;font-size: 14px;">Reset</span>
                                    </button>
                                </div>
                                <div class="col-xs-6">
                                    <a href="@Url.Action("Dashboard","Home")" class="btn  waves-effect" style="float:right;border:1px solid #c7c2c2;background:#dedddd;width:100%;">
                                        <i class="fa fa-arrow-left" style="top:0px;color: #525050;"></i>
                                        <span style="top:-2px;font-size: 14px;color:black;">Back</span>
                                    </a>
                                </div>
                            </div>




                        </div>
                    }
                </div>
            </div>

            <div class="col-md-8 admin-replymassage admin-replymassage-second">

                <div class="card" style="margin-top:0px;">
                    <div class="panel-heading" style="border:0px solid #dddddd;background:#dedddd;color:#555;">
                        <span class="fa fa-comments-o" style="color:#555;"></span> Chatting Details

                    </div>
                    <div class="panel-collapse collapse" style="display:block;">
                        <div class="panel-body" style="height:424px;">
                            <div class="card-body msg_card_body">
                                <ul class="chat">

                                    @foreach (var item in Model)
                                    {

                                        if (item.resdate != null)
                                        {

                                            <li class="d-flex justify-content-start mb-4">
                                                <span class="chat-img img_cont_msg">
                                                    <img src="../../images/reportimage/chatuserimage.png" />
                                                    <p class="rounded-circle user_img_msg">Admin</p>
                                                </span>
                                                <div class="chat-body clearfix msg_cotainer fullbodydycolorbg showrepalychat">
                                                    @*<div class="msg_time" style="border-bottom:none;">
                                                        <p class="text-muted"><span class="fa fa-clock-o"></span>&nbsp;</p>
                                                        <strong class="primary-font"></strong>
                                                    </div>*@
                                                    <p>
                                                        @item.response

                                                    </p>
                                                    <span class="msg_time"><i class="fa fa-clock-o" style="color:#fff;" aria-hidden="true"></i>@item.resdate</span>
                                                </div>
                                            </li>
                                        }
                                        if (item.rdate != null)
                                        {

                                            <li class="d-flex justify-content-end mb-4 classmechatsent">
                                                <div class="chat-body clearfix msg_cotainer_send">

                                                    @if (item.sts == "Open")
                                                    {
                                                        <p>@item.complant </p>
                                                    }
                                                    else
                                                    {
                                                        <p>@item.complant </p>

                                                    }
                                                    <span class="msg_time_send"><i class="fa fa-clock-o" style="color:#fff;" aria-hidden="true"></i>@item.rdate</span>
                                                    @*<div class="" style="border-bottom:none;">
                                                        <strong class="primary-font"></strong> <p class="text-muted">
                                                            <span class="fa fa-clock-o"></span>&nbsp;
                                                        </p>
                                                    </div>*@
                                                </div>
                                                <span class="img_cont_msg">
                                                    <img src="../../images/reportimage/chatuserimage.png" />
                                                    <p class="rounded-circle user_img_msg">You</p>
                                                </span>

                                            </li>
                                        }

                                    }


                                </ul>
                            </div>
                        </div>

                    </div>

                </div>
            </div>

        </div>

    </div>
</section>



<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>



