<!--Manual failed -->
<script>
            function Failed()
            {
             var answer = confirm('Are you sure ?');
             if(answer)
             {
                 var orderid = $("#txtorderid").val();
                 var status = $("#status").val();
                 var e = document.getElementById("ddl_refund");
                 var ddlval = e.options[e.selectedIndex].value

                 $.ajax({
                     url: '@Url.Action("GiftcardFailed", "Home")',
                     type: 'POST',
                     dataType: "html",
                     data: { orderid: orderid, status: status, ddl_refund: ddlval },
                     success: function (data) {
                         var response = JSON.parse(data);
                         if (response.Status) {
                             swal("Good Job!", response.Message, "success");
                             window.location.reload();
                              }
                         else {
                             swal("Oops...", response.Message, "error");
                         }
                     },
                     error: function (data) {

                     }
                 }).done(function () {
                     $("#defaultModal1").modal('hide');
                 });
                     return true;

                }
             else {
                 $("#defaultModal1").modal('hide');
                    return false;
                }
            }
</script>

<!--Mannual Success-->
<script>
            function success(orderid, status)
            {
             var answer = confirm('Are you sure ?');
             if(answer)
             {
                 $.ajax({
                     url: '@Url.Action("GiftcardSuccess", "Home")',
                     type: 'POST',
                     dataType: "html",
                     data: { orderid: orderid, status: status },
                     success: function (data) {
                         var response = JSON.parse(data);
                         if (response.Status) {
                             swal("Good Job!", response.Message, "success");
                             window.location.reload();
                         }
                         else {
                             swal("Oops...", response.Message, "error");
                         }
                     },
                     error: function (data) {

                     }
                 });
                     return true;

                }
             else {

                    return false;
                }
            }
</script>







