                    //$('#txtminbal').attr("readonly", true);
                    //$('#txtmaxbal').attr("readonly", true);
                    //  $('#RemTbl11').html(response);
                    //$("#txtupiid").val('');

                    //$("#ddlpaytmtype").val('');
                    // $(this).html('Save Change');
                    //$("#Saveotp").show();
                    //$("#SaveChargeminbal").hide();

                    $(".classshow11").hide();
                    $(".classhide11").show();
                    $(".sendotphide").hide();


                },
                error: function () {
