        }

    })
    </script>

    <script>
    $('#Saveotp').click(function () {
        debugger;
        $('#lblmsg').text('')
        $.ajax({
            url: '@Url.Action("DealerAddVpaID", "Home")',
            type: 'POST',
            data: { upiid: $("#hideupiid").val(), otp: $("#txtotp").val(), paymenttype: $("#hidddlpaymenttype").val() },
            success: function (response) {
                debugger;
                // $('#SaveChargeminbal').text('save')
                //$('#form_validation11').show();
                //$('#form_validation1').hide();
                $('#RemTbl222').html(response);
                //$("#txtupiid").val(''),
                //$("#txtminbal").val('')
                // $("#txtmaxbal").val('')
                //$("#Saveotp").hide();
                //$("#SaveChargeminbal").show();

                $(".classshow11").show();
                $(".tbladdbtnshow").show();
                $(".classhide11").hide();
                $(".sendotphide").hide();
                $(".clsupiaddhide").hide();

            },
            error: function () {
                //alert(error);
            }
        });
    })
    </script>

    <script>
    function Deletedata(idno) {
        $('#lblmsg').text('')
        $.ajax({
            url: '@Url.Action("deleteSelefUpiSelf", "Home")',
            type: 'POST',
            data: { upiid: idno },
            success: function (response) {
                debugger;

                $('#RemTbl222').html(response);

                $(".classshow11").show();
                $(".tbladdbtnshow").show();
                $(".classhide11").hide();
                $(".sendotphide").hide();
                $(".clsupiaddhide").hide();

            },
            error: function () {
                //alert(error);
            }
        });
    }
    function Activeset(idno) {
        $('#lblmsg').text('')
        $.ajax({
            url: '@Url.Action("DealerActiveUpiSelf", "Home")',
            type: 'POST',
            data: { upiid: idno },
            success: function (response) {
                debugger;

                $('#RemTbl222').html(response);

                $(".classshow11").show();
                $(".tbladdbtnshow").show();
                $(".classhide11").hide();
                $(".sendotphide").hide();
                $(".clsupiaddhide").hide();

            },
            error: function () {
                //alert(error);
            }
        });
    }



    </script>

