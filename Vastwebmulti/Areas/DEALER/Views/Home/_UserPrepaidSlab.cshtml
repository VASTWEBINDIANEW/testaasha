
@model Vastwebmulti.Areas.ADMIN.Models.PrepaidSlab
@using (Ajax.BeginForm("_UserPrepaidSlab", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "OnSuccess1", OnFailure = "onfailed", UpdateTargetId = "divEditFormComm", LoadingElementId = "div_Loader", InsertionMode = InsertionMode.Replace }))
{

    <style>
        span.rangeone_123 {
            font-size: 12px !important;
            font-weight: bold;
            @*color: var(--main-bg-lcolor) !important;*@
            border-bottom: 1px solid var(--main-bg-lcolor) !important;
            border-width: thin;
            padding-bottom: 3px;
        }

        #pragrap_1 p {
            font-size: 9px;
            margin-top: 10px;
            text-align: center;
        }
        input.form-control {
            padding-left: 30px;
            margin-top: 10px;
        }
        div#slab-master-detail {
            height: 60px !important;
        }
        .select2-container .select2-selection--single .select2-selection__rendered {
            display: block;
            padding-left: 30px !important;
            padding-right: 20px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            position:relative;
        }
        .select2-container--default .select2-selection--single {
            background-color: #fff;
            border: 1px solid #aaa;
            border-radius: 4px;
            margin-top: 10px;
        }
        span.select2.select2-container.select2-container--default.select2-container--focus {
            width: 20.4% !important;
        }
        span.select2-container.select2-container--default.select2-container--open {
            width: 20.4% !important;
        }
        span.select2.select2-container.select2-container--default.select2-container--below {
            width: 20.4% !important;
        }
        span.select2.select2-container.select2-container--default {
            width: 20.4% !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow b {
            border-color: #888 transparent transparent transparent;
            border-style: solid;
            border-width: 5px 4px 0 4px;
            height: 0;
            left: 50%;
            margin-left: -4px;
            margin-top: 6px !important;
            position: absolute;
            top: 50%;
            width: 0;
        }
        input#btnsubmituser {
            width: fit-content;
            position: absolute;
            top: 0;
            left: 20.4%;
        }
        input#btnsubmitusercommon {
            width: fit-content;
            position: absolute;
            top: 0;
            left: 36.2%;
        }
      


    </style>
    <input id="btnsubmituser" type="submit" name="Button" value="Update For Existing Users" class="btn  waves-effect" style="display:none;" />
    <input id="btnsubmitusercommon" type="submit" name="Button" value="Update Existing & New Users" class="btn  waves-effect" style="display:none;" />
    <input id="btnsubmitusercommondlmrem" type="submit" name="Button" value="Update Existing & New Users" class="btn  waves-effect" style="display:none;" />

    @Html.HiddenFor(m => m.role)
    <div class="row clearfix" style="margin-right:0px;">
        <div class="col-md-12">
            @*<div class="col-md-2">
                    <label for="email_address_2" style="padding-top:14px;padding-left:137px;"><i class="fa fa-users" style="font-size:25px; color:#607d8b ;"></i></label>
                </div>*@
            <div class="slab-master-block">
                <div class="slab-master-block-left">
                    <div id="allshow" class="row">
                        <div class="col-md-12" style="padding-right:20px;">
                            <div class="custom-district-img">
                                <img src="~/AdminDesign/images/slab-user.svg" style="width: 18px; position: absolute; top: 17px; z-index: 9; left: 22px;">
                            </div>
                            @Html.DropDownList("ddlUserId", Model.UserId, "All Users", new { @class = "form-control for-select2", @onchange = "ddlUserIdChange()" })
                        </div>
                    </div>
                    <div id="retailerdrop" class="row" style="display:none;">

                        <div class="col-md-6" style="padding-right:0px;">
                            <div>
                                <div class="custom-district-img">
                                    <img src="~/AdminDesign/images/slab-user.svg" style="width:18px;">
                                </div>
                                @Html.DropDownList("ddldealer", Model.UserId, "All Distributor", new { @class = "form-control for-select2", @onchange = "ddlretailerid()" })
                            </div>
                        </div>


                    </div>
                </div>
                <div class="slab-master-block-right">
                    <div id="slab-master-message" class="slab-master-message slab-master-message-show" style="display: none;">
                        <p>  If you edit the slabs of all the master distributors, you are given a data view of the common slabs.</p>
                    </div>
                    <div id="slab-master-detail" class="slab-master-detail slab-master-detail-hide" style="display: block;">
                        <div class="row clearfix">

                            <div class="col-md-4 col-sm-4 col-xs-4 col-4" style=" padding-right: 0px;">
                                <span class="master-slab-right-icon">
                                    <img src="~/AdminDesign/images/user.svg" style="width: 18px; position: absolute; top: 17px; z-index: 9; left: 22px;"  style="position:relative;">
                                </span>
                                <input class="form-control" type="text" placeholder="User Name" value="@Model.Name">

                            </div>
                            <div class="col-md-4 col-sm-4 col-xs-4 col-4" style=" padding-right: 0px;">
                                <span class="master-slab-right-icon" style="">
                                    <img src="~/AdminDesign/images/number.svg" style="width: 18px; position: absolute; top: 17px; z-index: 9; left: 22px;">
                                </span>
                                <input class="form-control" type="text" placeholder="User Registered Number" value="@Model.Phone" style="position:relative;">

                            </div>
                            <div class="col-md-4 col-sm-4 col-xs-4 col-4" style=" padding-right: 0px;">
                                <span class="master-slab-right-icon" style="">
                                    <img src="~/AdminDesign/images/email.svg" style="width: 18px; position: absolute; top: 17px; z-index: 9; left: 22px;">
                                </span>
                                <input class="form-control" type="text" placeholder="User Registered Mail" value="@Model.Email"  style="position:relative;">

                            </div>
                        </div>
                    </div>
                </div>
            </div>
            @*@if (Model.RetailerId != null)
                {
                    <div id="Retailerdropdow" style="display:block;">
                        <div class="col-md-2">
                            <label for="email_address_2" style="padding-top:14px;padding-left:137px;"><i class="fa fa-users" style="font-size:25px; color:#607d8b ;"></i></label>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group" style="margin-top:10px; margin-bottom:0px;">
                                <div class="" style="border:1px solid #9E9E9E;">

                                    @Html.DropDownList("Retailerid", Model.RetailerId, "All Retailer", new { @class = "form-control", @onchange = "ddlRetailerIdChange()" })

                                </div>
                            </div>
                        </div>
                    </div>
                }*@
        </div>
    </div>
    <table class="table table-bordered slab-table third-design-table" id="pragrap_1">
        @if (Model.Dealeruser != null)
        {
            <thead class="navbar" style="position: initial; background: var(--main-bg-lcolor);">
                <tr>
                    <th rowspan="3" style="text-align:center">User&nbsp;ID</th>
                    <th rowspan="3" style="text-align:center">Operator&nbsp;Name</th>
                    <th colspan="3" style="text-align:center">Commission&nbsp;(%)</th>
                    @*<th>Status</th>*@

                </tr>
                <tr>
                    @{
                        var range1 = Convert.ToInt32(@Model.AmountRange[0].maximum1);
                        var range2 = Convert.ToInt32(@Model.AmountRange[0].maximum2);
                        var rangee1 = range1 + 1;
                        var rangee = range2 + 1;
                    }
                    <th style="text-align:center;"><span class="rangeone_123">Range One</span><p>1 To @range1</p></th>
                    <th style="text-align:center;"><span class="rangeone_123">Range Two</span><p>@rangee1 To @range2</p></th>
                    <th style="text-align:center;"><span class="rangeone_123">Range Three</span><p>@rangee and Above</p></th>
                </tr>
            </thead>
        }
        else
        {
            <thead class="navbar" style="position: initial;">
                <tr>
                    <th>User&nbsp;ID</th>
                    <th>Operator&nbsp;Name</th>
                    <th>Commission&nbsp;(%)</th>
                    @*<th>Status</th>*@
                </tr>

            </thead>
        }
        <tbody id="tbodyshow">
            <!--Dealer User-->
            @if (Model.Dealeruser != null)
            {
                for (int i = 0; i < Model.Dealeruser.Count; i++)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(a => a.Dealeruser[i].Email)
                        </td>
                        <td>
                            @Html.DisplayFor(a => a.Dealeruser[i].OperatorName)

                        </td>
                        <td>
                            @Html.DisplayFor(a => a.Dealeruser[i].comm)

                        </td>
                        <td>
                            @Html.DisplayFor(a => a.Dealeruser[i].comm1)

                        </td>
                        <td>
                            @Html.DisplayFor(a => a.Dealeruser[i].comm2)

                        </td>

                    </tr>

                }
            }
            <!--End Dealer-->
        </tbody>
        <tbody id="tbodyedit" style="display:none;">

            <!--Dealer User-->
            @if (Model.Dealeruser != null)
            {
                for (int i = 0; i < Model.Dealeruser.Count; i++)
                {
                    <tr>
                        @Html.HiddenFor(a => a.Dealeruser[i].RolesName)
                        @Html.HiddenFor(a => a.Dealeruser[i].idno)
                        @Html.HiddenFor(a => a.Dealeruser[i].optcode)
                        <td>
                            @Html.DisplayFor(a => a.Dealeruser[i].Email)
                        </td>
                        <td>
                            @Html.DisplayFor(a => a.Dealeruser[i].OperatorName)
                        </td>
                        <td>
                            @Html.EditorFor(a => a.Dealeruser[i].comm, new { htmlAttributes = new { @style = "width:100%" } })
                            @Html.ValidationMessageFor(a => a.Dealeruser[i].comm)
                        </td>
                        <td>
                            @Html.EditorFor(a => a.Dealeruser[i].comm1, new { htmlAttributes = new { @style = "width:100%" } })
                            @Html.ValidationMessageFor(a => a.Dealeruser[i].comm1)
                        </td>
                        <td>
                            @Html.EditorFor(a => a.Dealeruser[i].comm2, new { htmlAttributes = new { @style = "width:100%" } })
                            @Html.ValidationMessageFor(a => a.Dealeruser[i].comm2)
                        </td>

                    </tr>
                }
            }
            <!--End Dealer-->
        </tbody>
        <tbody id="tbodyeditAll" style="display:none;">
            <!--Dealer User Update-->
            @if (Model.Dealeruser != null)
            {
                for (int i = 0; i < Model.UpdateDealer.Count; i++)
                {
                    var endID = Model.UpdateDealer[i].idno;
                    <tr>
                        @Html.HiddenFor(a => a.UpdateDealer[i].idno)

                        <td>
                            <p>All</p>
                        </td>
                        <td style="display:none;">
                            @Html.HiddenFor(a => a.UpdateDealer[i].optcode)
                        </td>
                        <td>
                            @Html.DisplayFor(a => a.UpdateDealer[i].OperatorName)

                        </td>
                        <td>
                            @Html.TextBoxFor(a => a.UpdateDealer[i].comm, new { @style = "width:100%" })
                            @Html.ValidationMessageFor(a => a.UpdateDealer[i].comm)
                        </td>
                        <td>
                            @Html.TextBoxFor(a => a.UpdateDealer[i].comm1, new { @style = "width:100%" })
                            @Html.ValidationMessageFor(a => a.UpdateDealer[i].comm1)
                        </td>
                        <td>
                            @Html.TextBoxFor(a => a.UpdateDealer[i].comm2, new { @style = "width:100%" })
                            @Html.ValidationMessageFor(a => a.UpdateDealer[i].comm2)
                        </td>
                    </tr>
                }
            }
            <!--End Dealer User-->
        </tbody>
    </table>
}
<link href="~/MainFrontDesign/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/MainFrontDesign/select2/dist/js/select2.full.min.js"></script>
<script>
    $('.for-select2').select2();
</script>
<script>
        function OnSuccess1(data) {
            $('#btnsubmituser').hide();
            $('#btnsubmitusercommon').hide();
            $('#btnEdit').show();
            var chk = '@Model.role';
            if (chk == "Retailer") {
                $('#retailerdrop').show();
                $('#allshow').hide();
            }
            else {
                $('#retailerdrop').hide();
                $('#allshow').show();
            }
        }
        function onfailed(error) {
            alert(error.responseText);
        }
</script>


<script>
    $('.third-design .third-design-table tbody td').mouseenter(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'var(--main-bg-rcolor)');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#fff');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'var(--main-bg-rcolor)');
    });

    $('.third-design .third-design-table tbody td').mouseleave(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'transparent');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#333');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'transparent');
    });
</script>