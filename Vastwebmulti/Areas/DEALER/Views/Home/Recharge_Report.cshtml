                                                                  new SelectListItem{Text="Electricity Bill",Value="Electricity"},
                                                                      new SelectListItem{Text="Insurance",Value="Insurance"},
                                                                  new SelectListItem{Text="Loan Payment",Value="Loan"},
                                                                       new SelectListItem{Text="Gas Bill",Value="Gas"},
                                                                  new SelectListItem{Text="Landline Bill",Value="Landline"},
                                                                            new SelectListItem{Text="PostPaid Bill",Value="PostPaid"},
                                                                  new SelectListItem{Text="PrePaid Recharge",Value="PrePaid"},
                                                                  new SelectListItem{Text="Water",Value="Water"},
                                                                 }, new { @class = "selectpicker form-control for-select2", data_live_search = "true", @style = "display:none;margin-top:0px;padding:0px;height:32px;", @onchange = "answers1()" })

                                                </div>
                                            </div>
                                        </div>
