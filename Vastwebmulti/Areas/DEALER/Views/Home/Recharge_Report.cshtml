                                            </div>
                                        </div>
                                        <div class="col-md-1 only-select-css allretailer-report-first" style="padding:0px;padding-right:5px;">
                                            <div class="form-group">
                                                <div class="">
                                                    @*@Html.DropDownList("Operator_Type", ViewBag.Operator_Type as SelectList, "ALL OPERATORS Type", new { id = "Operator_Type", @class = "selectpicker form-control", data_live_search = "true", @style = "display:none;margin-top:0px;padding:0px;height:32px;", @onchange = "answers1()" })*@
                                                    @Html.DropDownList("Operator_Type", new List<SelectListItem>
                                                                     {
                                                       new SelectListItem{Text="All Category",Value="Broadband"},
                                                                   new SelectListItem{Text="Broad Band Bill",Value="Broadband"},
