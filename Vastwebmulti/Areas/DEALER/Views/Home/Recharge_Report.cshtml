@model Vastwebmulti.Areas.RETAILER.Models.remmulti
@{
    ViewBag.Title = "Recharge_Report";
    Layout = "~/Areas/DEALER/Views/Shared/_Layout.cshtml";
}
<style>
    .table.dataTable thead th, table.dataTable thead td {padding: 8px 4px 6px 4px;}

    .table.dataTable tbody th, table.dataTable tbody td {padding: 8px 4px 6px 4px;}

    .dropdown-menu {margin-top: 81px !important;}
    body .datepicker-dropdown.datepicker{margin-top:75px !important;}

    .dataTables_wrapper .dt-buttons a.dt-button {padding: 7px 10px 8px 8px;}

    .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {height: 20px;}

    .select2-container--default .select2-selection--single {border: 1px solid #eee !important;border-radius: 0px !important;height: 32px !important;margin-top: 2px;}
    .recharge-report-dealer{padding:0;}

    .white-success-dealer {
        position: absolute;
        top: inherit;
        bottom: -35px;
        right: 15px;
        width: auto;
        z-index:99;
    }

    @@media screen and (max-width:1300px){
        .col-md-1.allretailer-report-four button span {text-transform: capitalize !important;}
        .recharge-reportdateclass {width: 27%;}
        .classrecharge-report .recharge-reportdateclass .custom-date-icon {width: 25px;}
    }

    @@media screen and (max-width:990px){
      .allretailer-report, .allretailer-report-first, .allretailer-report-second {width: 25% !important;float: left !important;}
      .col-md-1.allretailer-report-three {float: left;width: 16%;}
      .recharge-reportdateclass {width:31%;}
      .col-md-1.allretailer-report-four {float: left;width: 10%;padding-right: 0 !important;}
      .col-md-2.recharge-report-dealer {float: right;width: auto;}
      .classrecharge-report .form-group {margin-bottom: 10px;}

    }
    @@media screen and (max-width:768px){
        .recharge-reportdateclass .custom-date-icon {display: none;}
        .recharge-reportdateclass input {text-align: center !important;font-size: 12px;}
        .classrecharge-report .table-responsive{position:relative !important;z-index:9;}
        .white-success-dealer{bottom:-50px;}
    }
    @@media screen and (max-width:520px){
        .col-md-1.allretailer-report-three {float: left;width: 25%;}
        .recharge-reportdateclass {width: 57%;}
        .col-md-2.recharge-report-dealer {margin-bottom: 15px;position: relative;left: -16px;}
        .classrecharge-report .table-responsive table tr th:first-child {padding-right: 175px;}
    }
    @@media screen and (max-width:420px){
        .col-md-1.allretailer-report-four button span {margin: 0;font-size: 0;}
        .classrecharge-report .select2 span {font-size: 12px;padding-left: 2px !important;float: left;width: 100%;}
        .allretailer-report, .allretailer-report-first, .allretailer-report-second {padding-right: 1px !important;}
        .col-md-1.allretailer-report-three input {font-size: 12px;}
        .col-md-1.allretailer-report-three {padding-right: 3px !important;}
        .all-report-inputclass.all-report-inputclass-left {padding-right: 1px;}
        .all-report-inputclass.all-report-inputclass-right {padding-left: 2px;}
        .recharge-reportdateclass {width: 62%;}
        .classrecharge-report .responshive-rechargereport{padding-right:0;}
    }


</style>
<section class="content classrecharge-report">
