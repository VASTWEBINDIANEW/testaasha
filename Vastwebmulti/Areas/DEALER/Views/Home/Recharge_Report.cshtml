<script>
    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 45 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }
</script>
<!--Calendar Javascript-->
<script type="text/javascript">
    $(document).ready(function () {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",
        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
        //answers();
    });
</script>
<script type="text/javascript">
    function answers() {
        var e = document.getElementById("ddlusers");
        var answer = e.options[e.selectedIndex].value;
        if (answer == "Dealer") {
            document.getElementById("rem").style.display = "none";
            //document.getElementById("allretailer").selectedIndex = "0";

        }
        else if (answer == "Retailer") {
            document.getElementById("rem").style.display = "block";
        }
    }
</script>
<script>
    $('.white-success-button').click(function () {
        $('.white-success').toggle();
    });
</script>
<script type="text/javascript">
    function answers1()
    {
        var Operator_Type = $('#Operator_Type').val();
        if (Operator_Type === "") {
            Operator_Type = 0;
            //alert(stid)
        }
        else {
            //alert(stid)
            GetOperator(Operator_Type)
        }
    }

    function GetOperator(Operator_Type) {

                                var url = '@Url.Action("Getopt", "Home")'
                                $.ajax({
                                    url: url,
                                    data: { Id: Operator_Type },
                                    cache: false,
                                    type: "POST",
                                    success: function (data) {
                                        var markup = "<option value='ALL'>Select Operator</option>";
                                        for (var x = 0; x < data.length; x++) {
                                            markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                                            //alert(markup)
                                        }
                                        $("#Operator").html(markup).show();
                                    },
                                    error: function (reponse) {
                                        alert("error : " + reponse);
                                    }
                                });
                            }
</script>
<script>
    $('#Operator').select2();
    $('#Operator_Type').select2();
</script>
<script>
    function findtotal() {
        var ddlusers = $('#ddlusers').val();
        var Operator = $('#Operator').val();
        var ddl_status = $('#ddl_status').val();
        var txtmob = $('#txtmob').val();
        var allretailer = $('#allretailer').val();
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
             $.post("@Url.Action("TotalRecharge_Report", "Home")",
                 { "ddlusers": ddlusers, "Operator": Operator, "ddl_status": ddl_status, "txtmob": txtmob, "allretailer": allretailer, "txt_frm_date": txt_frm_date, "txt_to_date": txt_to_date },
                 function (data) {
                     $('#successtotal').text("₹ " + data.success);
                     $('#Failedtotal').text("₹ " + data.failed);
                     $('#Pendingtotal').text("₹ " + data.pending);
                 });
    }
</script>
<script>
    $("#btnExport").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var ddlusers = $('#ddlusers').val();
        var Operator = $('#Operator').val();
        var ddl_status = $('#ddl_status').val();
        var txtmob = $('#txtmob').val();
        var allretailer = $('#allretailer').val();
        var alldealer = $('#alldealer').val();
        var url = '@Url.Action("ExcelRechargereport", "Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&ddlusers=' + ddlusers + '&Operator=' + Operator + '&ddl_status=' + ddl_status + '&txtmob=' + txtmob + '&alldealer=' + alldealer + '&allretailer=' + allretailer;
        location.href = url;
});
</script>
<script>
    $("#btnPDF").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var ddlusers = $('#ddlusers').val();
        var Operator = $('#Operator').val();
        var ddl_status = $('#ddl_status').val();
        var txtmob = $('#txtmob').val();
        var allretailer = $('#allretailer').val();
        var url = '@Url.Action("PDFRecharge_Report", "Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&ddlusers=' + ddlusers + '&Operator=' + Operator + '&ddl_status=' + ddl_status + '&txtmob=' + txtmob + '&allretailer=' + allretailer;
        window.open(url,'_blank');
    });
</script>
<script>
    var ddlusers = $('#ddlusers').val();
    var Operator = $('#Operator').val();
    var ddl_status = $('#ddl_status').val();
    var txtmob = $('#txtmob').val();
    var allretailer = $('#allretailer').val();
        var pageindex = 2;
        var NoMoredata = false;
        var inProgress = false;
    $(window).scroll(function () {
        if ($(window).scrollTop() > Number($("#example").height()) / 4 && !NoMoredata && !inProgress) {
                inProgress = true;
                $("#loadingdiv").show();
                $.post("@Url.Action("InfiniteScrollRechargeReport", "Home")",
                    { "pageindex": pageindex, txt_frm_date: $('#txt_frm_date').val(),txt_to_date: $('#txt_to_date').val(), "ddlusers": ddlusers, "Operator": Operator, "ddl_status": ddl_status, "txtmob": txtmob, "allretailer": allretailer},
                    function (data) {
                        pageindex = pageindex + 1;
                        NoMoredata = data.NoMoredata;
                        $("#trow").append(data.HTMLString);
                        $("#loadingdiv").hide();
                        inProgress = false;
                    });
            }
        });
</script>

<script>
    $(document).ready(function () {
        var current = location.pathname;
        $('.sidebar-dealer-responshive ul li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('active');


            }
        })
    });
</script>


