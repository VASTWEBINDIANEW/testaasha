                    <span id="Pendingtotal" class="btn btn-warning waves-effect" style="font-size: 13px;padding:6px 9px;color:white; font-weight:600;" title="Total  Pending"><i style="font-size: 15px; top: 1px;" class="fa fa-question-circle-o" aria-hidden="true"></i> </span>
                </div>

            </div>
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">

            </div>
        </div>
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card all-reporttable-css">
                    <div>
                        <div class="table-responsive tableseconddes-dealer" style="position:inherit;">
                            <table class="table table-bordered table-striped table-hover  text-nowrap example-second third-design-table" cellspacing="0" style="width:100%;font-size:12px;">
