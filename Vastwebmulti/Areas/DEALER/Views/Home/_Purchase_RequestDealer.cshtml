@model IEnumerable<Vastwebmulti.Models.select_rem_pur_order_Result>


<div class="table-responsive" style="position:inherit;margin-top:-18px;">
    <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%;">
        <thead style="background-color:whitesmoke;">
            <tr>
                <th>Order&nbsp;No</th>
                <th>Status</th>
                <th>Retailer&nbsp;Info</th>
                <th>₹&nbsp;Amount</th>
                <th>₹&nbsp;Charge</th>
                <th>Payment&nbsp;Mode</th>
                <th>Action</th>
                <th>Request&nbsp;Date</th>
                <th>To&nbsp;Acc&nbsp;No</th>
                <th>UtrNo/SlipNo</th>
                <th>Comment</th>
                <th>Screenshot </th>
                <th>Response&nbsp;Date</th>

            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var color = "";
                var stscolor = "";
                //if (item.paymode.ToUpper() == "CASH")
                //{
                //    color = "green";
                //}
                //if (item.paymode.ToUpper() == "CREDIT")
                //{
                //    color = "red";
                //}
                //if (item.paymode == "Pending")
                //{
                //    stscolor = "#FF9800";

                //}
                //if (item.paymode == "APPROVED")
                //{
                //    stscolor = "green";

                //}
                //if (item.paymode == "REJECTED")
                //{
                //    stscolor = "red";

                //}
                <tr>

                    <td><p style="font-size:12px;">@item.orderno&nbsp;⇒&nbsp;<span style="color:@color;font-weight:600;"> @item.paymode</span></p></td>
                    <td><p style="font-size:12px;text-align:center;"><span style="color:@stscolor;font-weight:600;">@item.sts.ToUpper()</span></p></td>
                    <td><p style="font-size:10px;font-weight:700;">@Html.DisplayFor(modelItem => item.RemEmail).ToString().ToUpper()</p></td>
                    <td><p style="font-size:12px;text-align:center;">@Html.DisplayFor(modelItem => item.amount)</p></td>
                    <td><p style="font-size:12px;text-align:center;">@Html.DisplayFor(modelItem => item.cashDepositCharge)</p></td>
                    <td><p style="font-size:12px;text-align:center;">@Html.DisplayFor(modelItem => item.paymode).ToString().ToUpper()</p></td>
                    <td>
                        <div class="row">
                            @if (item.sts == "Pending")
                            {
                                <div class="col-xs-6" style="margin-bottom:0px;">
                                    <center>
                                        <button type="button" name="type" onclick="return funin('@item.idno','APP')" style="background:transparent;border:none;font-size:20px;margin-top:-6px;"><li class="fa fa-check" style="color:green;"></li> </button>
                                    </center>
                                </div>
                                <div class="col-xs-6" style="margin-bottom:0px;">
                                    <center>
                                        <button type="button" name="type" onclick="return funin('@item.idno','REJ')" style="background:transparent;border:none;font-size:20px;margin-top:-6px;"><li class="fa  fa-ban" style="color:red;"></li> </button>
                                    </center>
                                </div>
                            }
                            else
                            {

                            }
                        </div>
                    </td>
                    <td><p style="font-size:12px;text-align:center;">@Html.DisplayFor(modelItem => item.reqdate)</p></td>
                    <td><p style="font-size:12px;text-align:center;">@Html.DisplayFor(modelItem => item.Toaccountno)</p></td>
                    <td>@Html.DisplayFor(modelItem => item.utrno).ToString().ToUpper()</td>
                    <td>@Html.DisplayFor(modelItem => item.details) </td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.Slip))
                        {
                            <img src="@Url.Content("~/" + item.Slip)" height="60" width="60" />
                        }
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.responsedate) </td>

                </tr>
            }
        </tbody>
        <tfoot style="background-color:whitesmoke;">
            <tr>
                <td><p style="font-size:17px;">Total</p></td>
                <td></td>
                <td></td>
                <td><p style="font-size:18px;text-align:center;">@Model.Sum(a => a.amount)</p></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
            </tr>
        </tfoot>
    </table>
</div>