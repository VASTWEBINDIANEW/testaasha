@model Vastwebmulti.Areas.DEALER.Models.DayBookdealerreport
@{
    ViewBag.Title = "Dealer_Daybook_Report";
    Layout = "~/Areas/DEALER/Views/Shared/_Layout.cshtml";
}
<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 81px !important;
    }

    table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px;
    }
</style>
<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 75px !important;
    }

    table.dataTable tbody th, table.dataTable tbody td {
        padding: 4px 5px;
    }


    @@media screen and (max-width:768px) {

        .dealer-daybookreport .table-responsive {
            border: 0;
            overflow: scroll !important;
            padding-bottom: 7px !important;
        }
    }

    @@media screen and (max-width:580px) {


        .dealer-daybookreport .dealer-income-date {
            width: 100% !important;
            float: left !important;
            margin-top: 10px;
            padding-right: 15px !important;
        }

        .dealer-daybookreport .actualdealer-title p {
            font-size: 12px !important;
        }

        .recharge-report-dealer input {
            font-size: 12px;
        }
    }
</style>
<section class="content dealer-daybookreport">
    <div class="container-fluid full-dealer-secondanimation">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Dealer Daybook Report</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                @*<li><a href="javascript:void(0);">Account Active 2&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>*@
                <li><a href="javascript:void(0);">Day Book</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card" style="margin-bottom: 10px; ">
                    <div class="row">
                        <div class="col-md-7 actualdealer-title dealer-none-fourclass" style="width:auto;float:left;">
                            <p style="font-size:20px;margin-top:1px;color:#555;font-weight:700;margin-left:5px;"> DayBook&nbsp;Report</p>
                        </div>

                        <div class="col-md-2 recharge-report-dealer" style="width:auto;float:right;padding-left:5px;">
                            <div class="form-group" style="margin-bottom:0px;width:100%;float:left;">
                                <div style="padding-top:0px;float:right">
                                    @*<button class="white-success-button" style="height:32px;border:1px solid #b1a6a638;background:#b1a6a638;float: right;padding: 0px 4px;margin-top:-1px;" onclick="findtotal()">Total</button>*@
                                    <div class="web-white-filter fil" style="float: left;margin-right: 0px;margin-top:0px;">
                                        <input type="button" id="btnExport" value="Export" style="margin-left:0px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);
                                background-repeat: no-repeat;background-position: 4px center;padding-left: 20px;">
                                        <input type="button" id="btnPDF" value="PDF" style="margin-left:2px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);
                                background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">
                                    </div>
                                </div>

                            </div>
                        </div>

                        <div class="col-md-6 dealer-income-date" style="float:right;width:auto;padding-right:0px;">

                            @using (Html.BeginForm("Dealer_Daybook_Report", "Home", FormMethod.Post))
                            {
                                <div class="col-md-8 col-sm-8 col-xs-8" style="padding:0px;">
                                    <div class="input-daterange input-group for-web-date" style="width:100%;">
                                        <div class="custom-date-icon" style="height: 32px;">
                                            <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg" aria-hidden="true"></i>
                                        </div>
                                        @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; height:32px;", @autocomplete = "off" })
                                    </div>
                                </div>
                                <div class="col-md-4 col-sm-4 col-xs-4" style="padding:0px 5px;padding-right:0px;">
                                    <center>
                                        <button type="submit" class="btn waves-effect" style="width:100%; height:32px;">

                                            <span style="top:0px;color:black;">Search</span>
                                        </button>
                                    </center>
                                </div>
                            }

                        </div>

                        <div class="col-md-2 pdf-totalbuttonclass" style="display:none;">
                            <div class="web-white-filter" style="float:right;">
                                <table class="dataTable js-exportable ">
                                    <thead>
                                        <tr>
                                            <td></td>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card all-reporttable-css">

                    <div>
                        <div class="table-responsive table-responsive-scrolnone tableseconddes-dealer" style="position:inherit;overflow:auto;">
                            <table class="table table-bordered table-striped table-hover dataTable  " style="width:100%;font-size:12px;">
                                <thead class="thborder-cssdealer" style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Firm&nbsp;Name</th>
                                        <th>Recharge&nbsp;&&nbsp;Bill</th>
                                        <th>IMPS</th>
                                        <th>AEPS</th>
                                        <th>M&nbsp;-&nbsp;POS</th>
                                        <th>Pancard</th>
                                        <th>Travel</th>
                                        <th>Purchase</th>
                                        <th>Opening&nbsp;Bal</th>
                                        <th>Closing&nbsp;Bal</th>
                                        <th>Old&nbsp;Day&nbsp;Refund</th>
                                        <th>Old&nbsp;Day&nbsp;Failed</th>
                                        <th>Diff</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.DayBookLive != null)
                                    {
                                        foreach (var item in Model.DayBookLive)
                                        {
                                            <tr>
                                                <td>
                                                    @if (item.FarmName == null)
                                                    {
                                                        @item.DealerName
                                                    }
                                                    else
                                                    {
                                                        @item.FarmName
                                                    }
                                                </td>
                                                <td>@item.RCH</td>
                                                <td>@item.IMPS</td>
                                                <td>@item.AEPS</td>
                                                <td>0.00</td>
                                                <td>@item.PAN</td>
                                                <td>0.00</td>
                                                <td>@item.PURCHASE</td>
                                                <td>@item.openbal</td>
                                                <td>@item.closebal</td>
                                                <td>@item.OLDDAYREFUND</td>
                                                <td>@item.OLDDAYFAILED</td>
                                                <td>@item.DIFF</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        foreach (var item in Model.DayBook_Old)
                                        {
                                            <tr>
                                                <td>
                                                    @if (item.FarmName == null)
                                                    {
                                                        @item.DealerName
                                                    }
                                                    else
                                                    {
                                                        @item.FarmName
                                                    }
                                                </td>
                                                <td>@item.RCH</td>
                                                <td>@item.IMPS</td>
                                                <td>@item.AEPS</td>
                                                <td>0.00</td>
                                                <td>@item.PAN</td>
                                                <td>0.00</td>
                                                <td>@item.PURCHASE</td>
                                                <td>@item.openbal</td>
                                                <td>@item.closebal</td>
                                                <td>@item.OLDDAYREFUND</td>
                                                <td>@item.OLDDAYFAILED</td>
                                                <td>@item.DIFF</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script type="text/javascript">
    $(document).ready(function () {

               $('.input-daterange').datepicker({
                format: "yyyy-mm-dd",
                todayHighlight: true,
                autoclose: true

            });
            var val = '@ViewBag.chk';
            if (val != "post") {
                $("#txt_frm_date").datepicker("setDate", new Date());
                $("#txt_to_date").datepicker("setDate", new Date());
            }


        });
</script>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
