        }
    });
    }
</script>

<script>
    function DeleteRetailer()
    {
        var OTP = $("#txtotp").val();
        var retailerid = $("#RetailerId").val();

        if(OTP != "")
        {
            $("#OTPModal").modal('hide');
            swal({
                text: "<p style='color:#948f8b; font-size:20px;border-bottom:1px solid #dddddd;margin-top:-12px;padding-bottom:12px;'>Delete</p>" +
                       "</br><i class='fa fa-trash'style='font-size:72px;color:red;'></i></br><p style=''>Are you sure ?</p>",
                html: true,
                title: "",
                showCancelButton: true,
                confirmButtonColor: "#f9a7a7",
                confirmButtonText: "Yes, delete it!",
                closeOnConfirm: false
            },
                       function (isConfirm) {
                           if (isConfirm) {
                               $.ajax({
                                   type: "POST",
                                   url: '@Url.Action("Delete_Retailer", "Home")',
                                   data: { 'RetailerId': retailerid, 'OTP': OTP },
                                   cache: false,
                                   dataType: 'json',
                                   async: true,
                                   success: function (result) {
                                       if (result == "Success") {
                                           swal({ title: "Data Removed !", text: "Data Deleted Successfully.", type: "success" },
                                              function () {
                                                  location.reload();
                                              }
                                           );
                                       }

                                       else if (result == "OTPWrong") {

                                           swal("Wrong OTP !", "OTP Is Wrong !. Please try again.", "error");
                                           $("#OTPModal").modal('show');
                                       }
                                       else {
                                           swal({ title: "Failed !", text: "Something went wrong.", type: "error" },
                                           function () {
                                               location.reload();
                                           }
                                        );
                                       }
                                   }
                               });
                           }
                       });
            return true;
        }
        else {

            swal("Oops !", "Please Enter OTP", "error")
            $("#OTPModal").modal('show');
            return false;
        }
    }
</script>

