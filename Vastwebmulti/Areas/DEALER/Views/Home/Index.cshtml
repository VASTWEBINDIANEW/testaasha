<script>

    $('#btnEditrem').click(function () {

        $('#lblberror').text('');
        var pancard = $('#Pan1').val()
        if (pancard.length > 0) {
            var pancardformate = new RegExp('^([A-Za-z]){5}([0-9]){4}([A-Za-z]){1}$');

            if (!pancardformate.test(pancard)) {

                $('#lblberror').text('☒ Invalid Pan No');

                return false;
            }


        }



        var aadhar = $('#Adhaar1').val();
        $('#lblberror').text('');
        var res = validatesss(aadhar)
        if (res == false) {
            $('#lblberror').text('☒ Invalid AAdhar No');

            return false;

        }
        var gst = $('#Gst1').val()
        if (gst.length > 0) {
            console.log(gst.length)
            console.log(gst)
            var gstinformat = new RegExp('^([0][1-9]|[1-2][0-9]|[3][0-5])([a-zA-Z]{5}[0-9]{4}[a-zA-Z]{1}[1-9a-zA-Z]{1}[zZ]{1}[0-9a-zA-Z]{1})+$$');

            if (!gstinformat.test(gst)) {

                $('#lblberror').text('☒ Invalid GST No');

                return false;
            }


        }




    })



</script>



