<script>
    var inputs = document.getElementById('myform').querySelectorAll('input[type="text"], input[type="password"]');
    var mobile_ref = document.getElementById('Mobile');

    disable_inputs();

    mobile_ref.addEventListener('keyup', (e) => {
        if (e.target.value.length == 10) {
            block_inputs();
        }
        else {
            disable_inputs();
        }
    })

    email_ref.addEventListener('keyup', (e) => {
        if (mobile_ref && mobile_ref.value.length == 10 && e.target.value) {
            block_inputs();
        }
        else {
            disable_inputs();
        }
    })




    function disable_inputs() {
        for (i = 0; i < inputs.length; i++) {
            if (!['Mobile'].includes(inputs[i].getAttribute('id'))) {
                inputs[i].setAttribute('disabled', true);
                inputs[i].value = '';
            }
        }
    }

    function block_inputs() {
        for (i = 0; i < inputs.length; i++) {
            if (!['Mobile'].includes(inputs[i].getAttribute('id'))) {
                inputs[i].removeAttribute('disabled');
                inputs[i].value = '';
            }
        }
    }
</script>