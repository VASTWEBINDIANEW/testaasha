                                        <label for="email_address_2">Firm Name<span style="color: red">*</span></label>
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBoxFor(m => m.Firm, "", new { @class = "form-control", placeholder = "Enter Firm Name", required = "required" })
