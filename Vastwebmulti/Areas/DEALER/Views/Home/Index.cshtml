<!--Edit  Modal-->
<div class="modal fade tableeditdefaultmodal responshivemodal-class" id="defaultModal1" tabindex="-1" role="dialog" style="padding-right:0 !important;">
    <div class="modal-dialog" role="document" style="float:right;margin-top:0;padding-right:0 !important;">
        <div class="modal-content">
            <div class="modal-header" style="position:initial; background-color:whitesmoke;padding:10px 15px;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:#555;">Edit Retailer Information</h4>
            </div>
            @using (Html.BeginForm("Editretailer", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
            {
                @Html.HiddenFor(m => m.Retailerid)
                <div class="modal-body" style="margin-top:0px;">
                    <div class="body">
                        <form id="form_validation" method="POST">

                            <div class="row clearfix">

                                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                    <div class="form-group">
                                        <label for="email_address_2">Name</label>
