                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(m => m.Pin, "", new { @class = "form-control", placeholder = "Enter Pin", required = "required", onkeypress = "return isNumber(event)" })
                                            </div>
                                            @Html.ValidationMessageFor(m => m.Pin, "", new { @class = "text-danger" })
