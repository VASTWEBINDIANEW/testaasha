@using Vastwebmulti.Models;
@model Vastwebmulti.Areas.DEALER.Models.RetailerModel
@{
    ViewBag.Title = "Attributes";
    Layout = "~/Areas/DEALER/Views/Shared/_Layout.cshtml";

    string token_validate = Model.Dealertoken <= 0 ? "" : "#defaultModal";

    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Retailer").ToList();
    var favimage = "";
    if (usernname.Count() > 0)
    {
        if (usernname.SingleOrDefault().Role == "Retailer")
        {
            favimage = usernname.SingleOrDefault().NickName;

        }
    }



}
<style>
    .show_error {
        display: block;
    }

    .btn-group, .btn-group-vertical {
        box-shadow: none;
    }

    .selectcssinlineclass span.select2 span.select2-selection.select2-selection--single {
        border-radius: 0;
        border-color: #ddd !important;
        height: 34px;
    }

    .create-retaileruse span.keyfreamuse {
        width: 13px;
        height: 13px;
        float: left;
        border-radius: 50%;
        background: #fff;
        margin: 0 !important;
        margin-top: 3px !important;
        margin-right: 1px !important;
        animation: backgrounder 3s linear infinite;
    }

    @@keyframes backgrounder {
        0% {
            background: #fff;
        }

        50% {
            background: yellow;
        }

        100% {
            background: var(--main-bg-rcolor);
        }
    }

    .col-md-4.create-retaileruse button {
        background: var(--main-bg-lcolor) !important;
    }

    .new-retailer-table tr.retailer-tablefooter .onoffswitch span {
        font-size: 0;
        float: left;
        height: auto;
        padding: 0;
        background: transparent;
    }

    .new-retailer-table tr.retailer-tablefooter .onoffswitch {
        padding: 0;
        border: 0;
        background: transparent;
        float: left;
        width: auto;
    }

        .new-retailer-table tr.retailer-tablefooter .onoffswitch span::after, .new-retailer-table tr.retailer-tablefooter .onoffswitch span::before {
            position: static !important;
            margin-top: 2px;
            margin-right: 5px;
        }

    .new-retailer-table table tr.retailer-tablefooter td {
        white-space: nowrap;
    }

    .new-retailer-table table thead th {
        padding: 10px 5px;
    }

    .new-retailer-table table tbody td:nth-child(3), .new-retailer-table table tbody td:nth-child(8) {
        white-space: normal;
    }

    .new-retailer-table table tbody td {
        padding: 8px 5px;
    }

    .responshivemodal-class .modal-dialog .form-group {
        margin-bottom: 10px;
    }

    #defaultModal1, .responshivemodal-class {
        padding: 0 !important;
    }

    @@media screen and (max-width:768px) {
        #defaultModal .modal-dialog {
            width: 100% !important;
            float: left;
        }

        .indextable-page .index-pagetablefull .table-responsive {
            border: 0;
        }

        .new-retailer-table table tbody td:nth-child(3), .new-retailer-table table tbody td:nth-child(8) {
            white-space: nowrap;
        }
    }

    @@media screen and (max-width:580px) {
        .col-md-8 {
            width: 100% !important;
            text-align: center;
            float: left;
        }

            .col-md-8 .form-group {
                margin-bottom: 0px !important;
            }

        .col-md-4.create-retaileruse {
            float: left !important;
            padding-left: 15px !important;
            margin-bottom: 10px;
            padding-right: 0px !important;
        }
    }

    @@media screen and (max-width:420px) {
        .responshivemodal-class .col-lg-6.col-md-6.col-sm-6.col-xs-6 {
            width: 100%;
            float: left;
        }

        .col-md-2.recharge-report-dealer input, .col-md-2.recharge-report-dealer button {
            font-size: 11px !important;
        }

        .col-md-4.create-retaileruse button span {
            font-size: 10px;
        }

        .col-md-4.create-retaileruse button {
            padding: 0 5px !important;
        }
    }

    @@media screen and (max-width:380px) {
        .col-md-4.create-retaileruse button {
            padding: 6px 4px;
        }
    }

    @@media screen and (max-width:320px) {

        .index-pagetablefull .col-md-8 ol li {
            margin-top: 0;
        }

        .col-md-4.create-retaileruse button {
            text-align: center;
            margin: 0px auto;
            display: block;
            float: none !important;
            padding: 0 15px;
        }

        .index-pagetablefull .col-md-8 {
            width: 100% !important;
            padding: 0;
        }

            .index-pagetablefull .col-md-8 .form-group {
                margin-bottom: 0px !important;
            }

                .index-pagetablefull .col-md-8 .form-group ol {
                    margin-bottom: 8px;
                }
    }
</style>

<section class="content indextable-page" style="margin: 80px 0px 0 164px;">
    <div class="container-fluid index-pagetablefull full-dealer-secondanimation">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>User Management</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Account Active&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">User Management</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card" style="margin-bottom: 0px; ">
                    <div class="row">
                        <div class="col-md-8 dealer-none-fourclass" style="width:auto;float:left;">
                            <div class="form-group" style="margin-bottom:15px;">
                                <ol class="" style="padding:0px;">
                                    <li class="active" style=" color:#555; font-size:21px;font-weight:700;">All&nbsp;@favimage&nbsp;Details</li>

                                </ol>
                            </div>
                        </div>

                        @*<div class="col-md-2 recharge-report-dealer" style="width:auto;float:right;padding-left:0px;">
                                <div class="form-group" style="margin-bottom:0px;width:100%;float:left;">
                                    <div style="padding-top:0px;float:right">
                                        <button class="white-success-button" style="height:32px;border:1px solid #b1a6a638;background:#b1a6a638;float: right;padding: 0px 4px;margin-top:-1px;" onclick="findtotal()">Total</button>
                                        <div class="web-white-filter fil" style="float: left;margin-right: 5px;margin-top:-1px;">
                                            <input type="button" id="btnExport" value="Export" style="margin-left:0px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);
                                    background-repeat: no-repeat;background-position: 4px center;padding-left: 20px;">
                                            <input type="button" id="btnPDF" value="PDF" style="margin-left:2px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);
                                    background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">
                                        </div>
                                    </div>

                                </div>
                            </div>*@

                        <div class="col-md-4 create-retaileruse" style="width:auto;float:right;padding-right:5px;padding-left:0px;">
                            <button type="button" class="btn fullbodydycolorbg waves-effect" style="position: relative; top: -2px; height: 33px; float: right;" data-toggle="modal" data-target="@token_validate" onclick="handleCreate_btn('@token_validate')">

                                <span style="color:#fff;"><span class="keyfreamuse"></span>Create&nbsp;@favimage&nbsp;Account</span>
                            </button><br />
                            <span class="text-danger hidden" id="token_err" style="position: absolute; top: 31px;font-size:11px;padding-left: 8px;">Your Remain Token Is Low</span>



                        </div>



                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card all-reporttable-css new-retailer-table">
                    <div>
                        <div class="table-responsive tableseconddes-dealer" style="position:inherit;">
                            <table class="table table-bordered table-striped table-hover example-second third-design-table" style="width:100%;font-size:12px;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>S.R.</th>
                                        <th style="padding-right: 96px;">Firm&nbsp;Info.</th>
                                        <th>Name</th>

                                        <th>Reg&nbsp;Email&nbsp;Id</th>

                                        <th>Reg&nbsp;Mobile&nbsp;No</th>
                                        <th>Remain&nbsp;Bal.</th>


                                        @*<th>Capping</th>*@
                                        <th>State</th>
                                        <th>District</th>
                                        <th>Full&nbsp;Address</th>

                                        @*<th>Pancard</th>
                                            <th>Aadharcard</th>
                                            <th>GST</th>*@
                                        @*<th>Status</th>*@
                                        @*<th style="padding-right:25px;">Email&nbsp;Confirm</th>*@
                                        <th style="padding-right:30px;">Edit</th>
                                        <th>Join&nbsp;Date</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.dealer_retailer != null)
                                    {
                                        int i = 1;
                                        foreach (var item in Model.dealer_retailer)
                                        {
                                            var pendingColor = "";
                                            if (item.Emailconfirmed == false)
                                            {
                                                pendingColor = "#fff8d1";
                                            }

                                            <tr style="background:no-repeat;" class="retailer-tablefooter">
                                                <td>@i</td>
                                                <td>
                                                    <div class="onoffswitch">
                                                        @if (item.Status == "Y")
                                                        {
                                                            <span class="costom-on">on</span>

                                                        }
                                                        else
                                                        {

                                                            <span class="custom-off">off</span>

                                                        }
                                                    </div>
                                                    @item.Frm_Name
                                                </td>
                                                <td>@item.RetailerName</td>

                                                <td><span style="background:@pendingColor;padding:2px 4px;">@item.Email</span></td>

                                                <td>@item.Mobile</td>
                                                <td>@item.Remainamount</td>


                                                @*<td>@item.caption</td>*@
                                                <td>@item.State_name</td>
                                                <td style="white-space:nowrap;">@item.Dist_Desc</td>
                                                <td>@item.Address</td>


                                                @*<td>@item.PanCard</td>
                                                    <td>@item.AadharCard</td>
                                                    <td>@item.gst</td>*@





                                                @*<td style="padding:9px;">
                                                        @if (item.Emailconfirmed == true)
                                                        {
                                                            <a href="#" style="text-decoration:none;border:1px solid #c7c2c2;padding:5px 7px 5px 10px">
                                                                <span>DONE</span>
                                                            </a>

                                                        }
                                                        else
                                                        {
                                                            <a href="#" style="text-decoration:none;border:1px solid #c7c2c2;padding:5px 11px 5px 11px;">
                                                                <span>NOT&nbsp;DONE</span>
                                                            </a>

                                                        }
                                                    </td>*@

                                                <td>
                                                    <div class="row" style="margin:0px;">
                                                        <div class="col-xs-4" style="padding-left:0;padding-right:0;">
                                                            <button class="btn btn default" id="but" onclick="animation('@item.RetailerId')" style="background-color:transparent; border:none;border:1px solid #c7c2c2;height:23px; padding:1px 6px 1px 6px;" title="Edit Information">
                                                                Edit
                                                            </button>

                                                        </div>
                                                        @*<div class="col-xs-4" style="padding-left:0;">
                                                                @if (item.Emailconfirmed == false)
                                                                {
                                                                    <button class="btn btn default" id="but" onclick="sendotpRetailer('@item.RetailerId')" style="background-color:transparent; border:none;border:1px solid #c7c2c2;height:28px; padding:1px 10px 1px 10px;margin-left:-10px;" title="Delete Information">
                                                                        Delete
                                                                    </button>
                                                                }

                                                            </div>
                                                            <div class="col-xs-4" style="padding-left:0;padding-right:0;">
                                                                @if (item.Emailconfirmed == false)
                                                                {
                                                                    <a class="btn btn default" href="@Url.Action("ResendRetailerEmail", "Home", new { email = item.Email })" title="Resend Email " style="border:1px solid #c7c2c2; height:28px; padding:1px 10px 1px 10px;margin-left:-6px;">
                                                                        Resend
                                                                    </a>
                                                                }
                                                            </div>*@
                                                    </div>
                                                </td>
                                                <td>@item.JoinDate</td>

                                            </tr>
                                            i++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!--Add New   modal-->

<div class="modal fade responshivemodal-class" id="defaultModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document" style="margin:0px;float:right;">
        <div class="modal-content">
            <div class="modal-header" style="position:initial; background-color:whitesmoke;padding:10px 15px;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:#555;">Create&nbsp;New&nbsp;Retailer</h4>
            </div>
            @using (Html.BeginForm("InsertRetailer", "Home", FormMethod.Post))
            {
                <div class="modal-body" style="margin-top:0px;" id="myform">
