@using Vastwebmulti.Models;
@model Vastwebmulti.Models.User
@{
    ViewBag.Title = "Profile";
    Layout = "~/Areas/DEALER/Views/Shared/_Layout.cshtml";

    var passcodeset = ViewBag.passcodesetings;
    var offpasscode = passcodeset == "OFF" ? "activeupto" : "";
    var perpasscode = passcodeset == "PERDAY" ? "activeupto" : "";
    var Weakpasscode = passcodeset == "WEAKS" ? "activeupto" : "";
    var monthpasscode = passcodeset == "MONTHS" ? "activeupto" : "";
    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Dealer").ToList();
    if (usernname.Count() > 0)
    {
        if (usernname.SingleOrDefault().Role == "Dealer")
        {
           var favimage = usernname.SingleOrDefault().NickName;
            ViewBag.nickname = favimage;
        }
    }
}
<style>

    .retailer-profile-secondclass button p {
        font-size: 9px;
        left: 22px;
        bottom: -9px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .retailer-profile-secondclass p.uptotransction {
        float: left;
        background: #f9f9cb;
        color: #555;
        padding: 0 1px;
        margin-left: 8px;
        margin-top: 3px;
        margin-bottom: 0;
        width: 33%;
    }

    .retailer-profile-secondclass span {
        text-transform: uppercase;
    }

    .retailer-profile-secondclass strong {
        text-align: center;
        display: flex;
        width: 100%;
        justify-content: center;
    }

        .retailer-profile-secondclass strong span {
            font-size: 12px;
        }

    p.uptotransction.activeupto::after {
        content: "";
        float: left;
        width: 10px;
        height: 10px;
        background: url(../../ashok-images/correct.svg)no-repeat;
        background-color: green;
        background-size: 83%;
        background-position: center;
        position: relative;
        left: 1px;
        top: 3.4px;
    }
</style>
<style>
    .ribbon {
        background: #bbb;
        text-align: center;
        padding: 6px;
    }

        .ribbon span {
            font-size: 20px;
            color: #555;
            text-align: center;
            font-weight: bold;
            line-height: 20px;
        }

    .list-group-item {
        border: none;
    }

    .field-validation-error {
        color: red;
    }

    .required:after {
        color: red;
        content: " *";
    }

    .select2-container--default .select2-selection--single {
        border: 1px solid #eee !important;
        border-radius: 0px !important;
        height: 32px !important;
    }

    .profile-dealeronchange button p {
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .profile-dealeronchange button p.activeupto {
            background: green;
            color: #fff;
        }

        .profile-dealeronchange button p::after {
            display: none;
        }

        .profile-dealeronchange button p.activeupto span::before {
            content: "";
            float: left;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            color: #555;
            font-size: 12px;
            position: relative;
            left: -5px;
            background: url('../../AdminDesign/images/checkprofile.svg') no-repeat;
            background-color: #fff;
            background-size: 11px;
            background-position: center;
        }

    @@media screen and (max-width:766px) {
        .retailer-profile-secondclass strong {
            display: block;
            width: 100%;
            float: left;
        }

        .retailer-profile-secondclass p.uptotransction {
            width: 48%;
            margin-bottom: 5px;
        }
    }

    @@media screen and (max-width:420px) {
        .retailer-profile-secondclass p.uptotransction {
            width: 100%;
            margin: 0px;
            margin-bottom: 10px;
        }
    }
</style>
