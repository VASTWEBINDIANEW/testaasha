        margin-bottom: 0;
    }

    .operatior-infocssdealer .table-responsive table tr td {
        padding: 8px 5px !important;
    }

    .operatior-infocssdealer .table-responsive table tr th {
        padding: 8px 5px !important;
    }

    .operatior-infocssdealer .table-responsive {
        overflow: inherit;
    }

    .operatior-infocssdealer .table-responsive {
        overflow: auto;
    }

    .operatior-index-dealer li a {
        background: linear-gradient(to right, var(--main-bg-lcolor), var(--main-bg-rcolor));
        position:relative;
        transition: all .4s linear;
    }
    .operatior-index-dealer li a span {
        color:#fff;
        font-size:12px;
    }
    .operatior-index-dealer li.active a span {
        color:#fff !important;
    }
    .operatior-index-dealer li.active a, .operatior-index-dealer li.active a:hover, .operatior-index-dealer li.active a:focus {
        background: #a4a0a0 !important;
    }
    .operatior-index-dealer li a::after {
        content: "";
        display: block;
        width:100%;
        height: 5px;
        background: transparent;
        transition: all .4s linear;
        position: absolute;
        left: 0;
        bottom: 0;
        transform:scale(0);
    }
    .operatior-index-dealer li.active a::after {
        background:#000;
        transform:scale(1);
        transition: all .4s linear;

    }
    .operatior-index-dealer li a {
        padding-left:0px;padding-right:0px;
    }
    .operatior-index-dealer {
        display: flex;
    }
    .operatior-index-dealer li {width:10%;float:left;}
    .operatior-index-dealer li a {
        width:98%;
    }
    .operatior-index-dealer li:last-child a {
        width:100%;
    }
    .operatior-index-dealer li.active a {
    padding-top: 13px;
    padding-bottom: 13px;
    margin-top: -6px;
}
        .operatior-index-dealer li a span {
            position: relative;
            top: 3px;
        }
        .operatior-index-dealer li.active a span {
            top: 4px;
            font-weight:bold;
        }
        .operatior-index-dealer {
            margin-top:10px;
        }
    .operatior-infocssdealer table .activeinactive-dealer span {
        padding-top: 3px;
        padding-bottom: 3px;
    }

    @*Four-design-dealer-css-start*@

    .dealer-four-design .operatior-index-dealer {
        display: none;
    }
    .dealer-four-design .opratior-index-foudesign {
        display: flex !important;
        background: var( --fullbodybg-four) !important;
