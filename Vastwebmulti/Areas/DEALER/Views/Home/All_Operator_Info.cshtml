    .dealer-four-design .opratior-index-foudesign li a, .dealer-four-design .opratior-index-foudesign li.active a, .dealer-four-design .opratior-index-foudesign li.active a:hover, .dealer-four-design .opratior-index-foudesign li.active a:focus {
