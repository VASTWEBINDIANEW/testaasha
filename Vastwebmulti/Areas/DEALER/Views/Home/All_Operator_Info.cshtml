                            <table class="table table-bordered table-striped table-hover">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        @{
                                            var range1 = Convert.ToInt32(@Model.AmountRange[0].maximum1);
                                            var range2 = Convert.ToInt32(@Model.AmountRange[0].maximum2);
                                            var rangee1 = range1 + 1;
                                            var rangee = range2 + 1;
                                        }
                                        <th style="padding-left:0px; text-align:center">Operator&nbsp;Current&nbsp;Status</th>
                                        <th style="padding-left:0px; text-align:center">Operator&nbsp;Type</th>
                                        <th style="padding-left:0px; text-align:center">Code</th>
                                        @*<th style="padding-left:0px; text-align:center">Status</th>*@
                                        <th style="text-align:center;"><span class="rangeone_123">Range One</span><p>1 To @range1</p></th>
                                        <th style="text-align:center;"><span class="rangeone_123">Range Two</span><p>@rangee1 To @range2</p></th>
                                        <th style="text-align:center;"><span class="rangeone_123">Range Three</span><p>@rangee and Above</p></th>
                                        <th style="padding-left:0px; text-align:center">Blocked&nbsp;Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Prepaid)
                                    {

                                        <tr>
                                            <td>
                                                <p class="activeinactive-dealer" style="margin:0;">
                                                    @if (item.Status == "Y")
                                                    {
                                                        <span class="activebuttontable" style="color:#fff;font-size:15px;background:green;">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="inactivebuttontable" style="color:#fff;font-size:15px;background:red;">InActive</span>
                                                    }
                                                    @Html.DisplayFor(modelItem => item.OperatorName)
                                                </p>
                                            </td>
                                            <td>@Html.DisplayFor(modelItem => item.OperatorType)</td>
                                            <td>@Html.DisplayFor(modelItem => item.OperatorCode)</td>


                                            <td>@Html.DisplayFor(modelItem => item.Commission)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Commission1)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Commission2)</td>
                                            <td>@Html.DisplayFor(modelItem => item.BlockTime)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
