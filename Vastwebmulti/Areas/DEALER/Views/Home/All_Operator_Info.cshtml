    .dealer-four-design .opratior-index-foudesign li a i {
        margin: 0px !important;
        margin-top: 0px;
        position: static !important;
        border-radius: 0;
        padding: 0;
        display: block;
        width: 40px;
        height: 40px;
        background: transparent;
    }
    .dealer-four-design .opratior-index-foudesign li.active a span {
        margin-top: 2px !important;
    }

    .dealer-four-design .opratior-index-foudesign li a span {
        margin: 0 !important;
        margin-top: 0px;
        display: block;
        position: static !important;
        margin-top: 3px !important;
        padding: 0 !important;
    }
    .dealer-four-design .opratior-index-foudesign li.active a::after {
        transform: scaleX(1);
        transition: all .4s linear;
    }

    .dealer-four-design .opratior-index-foudesign li a::after {
        content: "";
        display: block;
        width: 100%;
        height: 28px;
        position: absolute;
        left: 0;
        background: var( --fullbodybg-four) !important;
        top: -21px;
        clip-path: url(#menu);
        transform: scaleX(0);
        transition: all .4s linear;
    }
    .dealer-four-design .opratior-index-foudesign li a i img {
        width: 100% !important;
        position: static !important;
        margin: 0 !important;
        display: block !important;
        max-width: 100% !important;
    }

    .dealer-four-design .opratior-index-foudesign li.active a i {
        text-align: center;
    }
    .dealer-four-design .opratior-index-foudesign li.active a i::after {
        transition: all .4s linear;
        transform: scaleX(1);
    }

    .dealer-four-design .opratior-index-foudesign li a i::after {
        content: "";
        display: block;
        width: 100%;
        height: 100%;
        background: var(--four-design-bg-first);
        position: absolute;
        top: 0;
        left: 0;
        border-radius: 50%;
        z-index: -1;
        transition: all .4s linear;
        transform: scaleX(0);
    }
    .dealer-four-design .svg-container-third-designmaster {
        width: 0;
        height: 0;
        display: block !important;
    }

