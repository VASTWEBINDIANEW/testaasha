    @@media screen and (max-width:520px) {
        .alloperator-class .col-md-1 {
            left: 0;
            padding: 0 !important;
        }

        .alloperator-class .col-md-3.only-select-css {
            padding-left: 0 !important;
        }
    }

    @@media screen and (max-width:400px) {
        .operatior-index-dealer li a span {
