            .operatior-index-dealer li a span {white-space:nowrap;}
            .operatior-index-dealer li.active a {margin-top:0px;}
            .operatior-index-dealer li a {
                padding-top: 8px !important;
                padding-bottom: 16px !important;
                height:44px;
            }
            .operatior-index-dealer li {margin-bottom:10px;}
            .operatior-index-dealer li {
                width: 20%;
                float: left;
            }
        .dealer-four-design .operatior-index-dealer.opratior-index-foudesign {
            display: none !important;
        }
        .dealer-four-design .operatior-index-dealer {
            display: block !important;
        }

