                                                #region setings
                                                var color = "";

                                                var framname = "";

                                                var rolename = "";
                                                var fontweight = "";
                                                var rchtypeicon = "";
                                                var sts = "";
                                                var refundcolor = "";
                                                var dmtytpe = "";
                                                if (item.status.Contains("Success To Failed"))
                                                {
                                                    color = "red";
                                                    sts = "Success To Failed";
                                                    fontweight = "700";

                                                }
                                                if (item.status.Contains("Failed To Success"))
                                                {
                                                    color = "green";
                                                    sts = "Failed To Success";
                                                    fontweight = "700";

                                                }
                                                if (item.status.Contains("SUCCESS"))
                                                {
                                                    color = "green";
                                                    fontweight = "700";
                                                    sts = item.status;

                                                }
                                                if (item.status.Contains("REFUND AGAINST"))
                                                {
                                                    color = "red";
                                                    fontweight = "700";
                                                    sts = "REFUND";
                                                    refundcolor = "red";
                                                }

                                                if (item.status.Contains("Pending"))
                                                {
                                                    color = "#ff9600";
                                                    fontweight = "700";
                                                    sts = item.status;

                                                }
                                                if (item.status.Contains("FAILED"))
                                                {
                                                    color = "#9C27B0";
                                                    fontweight = "700";
                                                    sts = item.status;

                                                }
                                                if (item.status.Contains("Resend"))
                                                {
                                                    color = "#2196F3";
                                                    fontweight = "700";
                                                    sts = item.status;

                                                }
