    /*@@keyframes changecolor {
        0% {
            color: #104202;
        }

        50% {
            color: #6af955;
        }

        100% {
            color: green;
        }
    }*/
    .dealer-firstclass.dealer-firstclass-responshive .tab-content {
        min-height: 638px;
    }

    .dealer-firstclass-responshive .col-xs-3 {
        margin-bottom: 20px !important;
    }

    .offerachivment-image p span {
        white-space: nowrap;
    }

    .offer-month ul li::after {
        content: "";
        display: block;
        width: 110%;
        height: 104%;
        background: var(--main-bg-rcolor);
        position: absolute;
        top: 0;
        left: -6px;
        transform: skewY(-7deg);
        opacity: 1;
        z-index: 9;
    }

    .offer-month ul li {
        position: relative;
        border: 2px solid var(--main-bg-rcolor) !important;
        padding: 5px 10px;
    }

        .offer-month ul li span {
            color: #fff;
            z-index: 99;
            position: relative;
            font-style: italic;
        }

        .offer-month ul li.activeeee::after {
            background: var(--main-bg-lcolor);
        }

        .offer-month ul li::before {
            z-index: 99;
        }

    @@keyframes offerscolor {
        0% {
            color: #6af955;
        }

        50% {
            color: #fff;
        }

        100% {
            color: yellow;
        }
    }

    .offer-month ul li.activeeee span {
        animation: offerscolor 2s linear infinite;
    }

    .col-xs-8.col-sm-8.col-md-8.col-lg-8.show-to.right-op .offer-month ul li:last-child {
        border-right: 2px solid var(--main-bg-rcolor ) !important;
    }

    #offers .offerclass-full .offer-month {
        padding: 12px 0 !important;
        padding-top: 10px !important;
    }

    .offer-month ul li::before {
        z-index: 99;
        position: relative !important;
        border-color: var(--main-bg-lcolor) !important;
    }

    .offer-month ul li.activeeee::before {
        background: green !important;
        border-color: #fff !important;
    }

    .offer-month ul {
        padding: 0;
    }

    @@keyframes text-animation {
        0% {
            width: 0;
        }

        50% {
            width: 100%;
        }

        100% {
            width: 0;
        }
    }

    .offerslider-full .offer-imageslide h3 strong {
        color: var(--main-bg-rcolor);
        display: inline-block;
        position: relative;
    }

        .offerslider-full .offer-imageslide h3 strong::before {
            content: attr(data-title);
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            width: 0;
            transition: all 1s ease-in-out;
            animation: text-animation 3s infinite;
            display: inline-block;
            border-bottom: 1px solid var(--main-bg-rcolor);
        }

    #offers-dealers .offerclass-full .offer-month {
        position: absolute;
        left: 22px;
        width: auto;
        top: 65px;
        padding: 0 !important;
    }

    .offer-imageslide {
        padding-top: 50px !important;
    }

    .offerslider-full .offer-imageslide .nofitio-imageround {
        margin-top: 20px !important;
        margin-bottom: 40px !important;
    }

    .offerclass-full .offerslider-full {
        margin-top: 15px !important;
    }

    .offerclass-full-dealer .offerachivment-image {
        height: auto;
        min-height: 95px !important;
    }

        .offerclass-full-dealer .offerachivment-image img {
            width: 72px !important;
            height: 70px !important;
        }

        .offerclass-full-dealer .offerachivment-image p span {
            white-space: normal;
        }

    .offerclass-full-dealer .offerachivment-image {
        padding-top: 1px !important;
        padding-bottom: 3px;
    }

    .nodatafoundclass-dealer {
        float: left;
        width: 100%;
    }

    .nodatafoundclass-dealer {
        z-index: 99;
    }

    @@media screen and (max-width:1366px) {
        #offers-dealers .offerclass-full .offer-month {
            padding: 0 15px !important;
            width: 42%;
            left: 0;
        }

