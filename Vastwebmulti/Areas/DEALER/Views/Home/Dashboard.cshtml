            width: auto;
            float: left;
            padding: 0 !important;
        }
    }

    @@media screen and (max-width:580px) {
        .dealer-addtabnew ul.header-tabbutton li:nth-child(3) {
            border-right: 0 !important;
        }

        .dealer-addtabnew ul.header-tabbutton li:nth-child(1), .dealer-addtabnew ul.header-tabbutton li:nth-child(2), .dealer-addtabnew ul.header-tabbutton li:nth-child(3) {
