<script>
    function OperatorCodestatusupdate(idno, status) {
        var ids = idno;
        debugger;
         $.ajax({
                type: 'POST',
                url: '@Url.Action("ChangeStatusSeller_Commission", "Home")',
             data: { idno: ids},
             success: function (data) {
                 if (data == false) {
                        $('#' + idno).removeClass('costom-on');
                     $('#' + idno).addClass('custom-off');
                     $('#' + idno).val('OFF');
                     $('#' + idno).text('OFF');

                    }
                    else if (data == true) {
                     $('#' + idno).removeClass('custom-off');
                     $('#' + idno).addClass('costom-on');
                     $('#' + idno).text('ON')
                     $('#' + idno).val('ON')

                    }
                }
            });
    }
</script>

