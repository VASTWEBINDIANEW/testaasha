                                                    <button class="costom-on clscall" data-bind="btnsts_@item.GetType().GetProperty("idno").GetValue(item, null)" value="ON" id="@item.GetType().GetProperty("idno").GetValue(item, null)" onclick="OperatorCodestatusupdate('@item.GetType().GetProperty("idno").GetValue(item, null)','Y')" style="border:1px solid #aaa4a4;">ON</button>
