@using Vastwebmulti.Models;
@model IEnumerable<Vastwebmulti.Models.select_operator_retailer_Result>
@{
    ViewBag.Title = "BlockOPT";
    Layout = "~/Areas/DEALER/Views/Shared/_Layout.cshtml";
    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var usernname = DB1.Usernicknames.Where(aa => aa.Role == "Retailer").ToList();
    if (usernname.Count() > 0)
    {
        if (usernname.SingleOrDefault().Role == "Retailer")
        {
            var favimage = usernname.SingleOrDefault().NickName;
            ViewBag.nickname = favimage;
        }
    }
}


<style>
    .dropdown-menu {
        margin-top: 75px !important;
    }

    .select2-container--default .select2-selection--single {
        border: 1px solid #eee !important;
        border-radius: 0px !important;
        height: 32px !important;
    }

    @@media screen and (max-width:766px) {
        .blockotp-dealer {
            width: 100% !important;
            float: left !important;
            margin: 10px 0;
            padding-right: 8px;
        }
    }

    @@media screen and (max-width:400px) {
        .block-pagecssclass .card-all-retailerclass ol li {
            font-size: 12px !important;
        }

        .col-md-2.recharge-report-dealer {
            padding-left: 0px !important;
        }

            .col-md-2.recharge-report-dealer input {
                font-size: 9px;
            }
    }
</style>

<section class="content block-pagecssclass">
    <div class="container-fluid full-dealer-secondanimation">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Block Service's</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Account Active&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Block Service's</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card" style="margin-bottom:10px;">
                    <div class="col-lg-6 col-md-6 col-sm-12 col-xs-12 card-all-retailerclass dealer-none-fourclass" style="padding-left:0;width:auto;float:left;">
                        <div class="form-group" style="margin-top:0px;margin-bottom:0px;">
                            <ol style="padding:0px;">
                                <li class="active" style="color:#555; font-size:20px;font-weight:700;">All @ViewBag.nickname  Block & UnBlock Status</li>
                            </ol>
                        </div>


                    </div>
                    <div class="col-md-2 recharge-report-dealer" style="width:auto;float:right;padding-left:5px;padding-right:0px;">
                        <div class="form-group" style="margin-bottom:0px;width:100%;float:left;">
                            <div style="padding-top:0px;float:right">
                                @*<button class="white-success-button" style="height:32px;border:1px solid #b1a6a638;background:#b1a6a638;float: right;padding: 0px 4px;margin-top:-1px;" onclick="findtotal()">Total</button>*@
                                <div class="web-white-filter fil" style="float: left;margin-right: 0px;margin-top:0px;">
                                    <input type="button" id="btnExport" value="Export" style="margin-left:0px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);
                                background-repeat: no-repeat;background-position: 4px center;padding-left: 20px;">
                                    <input type="button" id="btnPDF" value="PDF" style="margin-left:2px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);
                                background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">
                                </div>
                            </div>

                        </div>
                    </div>
                    <div class="col-lg-6 col-md-6 col-sm-12 col-xs-12 blockotp-dealer" style="float:right;">
                        @using (Html.BeginForm("BlockOPT", "Home", FormMethod.Post))
                        {
                            <div class="row">
                                <div class="col-md-5 only-select-css" style="padding:0px;">

                                    <div class="form-group" style="margin-bottom:0px;">
                                        <div class="">
                                            @Html.DropDownList("opttype", ViewBag.opttype as SelectList, "Operator Type", new { id = "opttype", @class = "selectpicker for-select2", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-5 only-select-css" style="padding:0px 5px;">

                                    <div class="form-group" style="margin-bottom:0px;">
                                        <div class="">
                                            @Html.DropDownList("rem", ViewBag.retailer as SelectList, "Select User", new { id = "rem", @class = "selectpicker for-select2", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;", @required = "required" })

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2" style="padding:0px;">
                                    <center>
                                        <button type="submit" class="btn bg-grey waves-effect" style="width:100%; height:32px;">

                                            <span style="color:black;"><i class="fa fa-search" style="top:0px;font-size:13px;color:black;left:-3px;" aria-hidden="true"></i>Search</span>
                                        </button>
                                    </center>
                                </div>


                            </div>
                        }
                    </div>

                </div>
            </div>

        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:0;">
                <div class="card all-reporttable-css">

                    <div class="body" style="padding:0px;">
                        <div class="table-responsive tableseconddes-dealer" style="position:inherit;margin-top:0;">
                            <table class="table table-bordered table-striped table-hover example-second third-design-table" style="width:100%;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Sr.No</th>
                                        <th>Operator Name</th>
                                        <th>Operator Type</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int i = 1;
                                        foreach (var item in Model)
                                        {
                                            var color1 = "#424242";
                                            var color = "#fff";
                                            if (item.Operator_type == "PrePaid")
                                            {
                                                color1 = "#484343";
                                                color = "#f7f1f3";
                                            }
                                            else if (item.Operator_type == "PostPaid")
                                            {
                                                color1 = "#484343";
                                                color = "#25c59121";
                                            }
                                            else if (item.Operator_type == "Landline")
                                            {
                                                color1 = "#484343";
                                                color = "#2531c51a";
                                            }
                                            else if (item.Operator_type == "Insurance")
                                            {
                                                color1 = "#484343";
                                                color = "#c525c01a";
                                            }
                                            else if (item.Operator_type == "Gas")
                                            {
                                                color1 = "#484343";
                                                color = "#c3c5251a";
                                            }
                                            else if (item.Operator_type == "Electricity")
                                            {
                                                color1 = "#484343";
                                                color = "#71c5251a";
                                            }
                                            else if (item.Operator_type == "DTH")
                                            {
                                                color1 = "#484343";
                                                color = "#13090f1a";
                                            }
                                            <tr style="color:@color1;">
                                                <td>
                                                    @i
                                                </td>
                                                <td>
                                                    @Html.DisplayFor(modelItem => item.opt_name)
                                                </td>
                                                <td>
                                                    @Html.DisplayFor(modelItem => item.Operator_type)
                                                </td>
                                                <td>
                                                    @Html.HiddenFor(modelItem => item.status)
                                                    @{
                                                        if (@item.status == true)
                                                        {
                                                            <center>
                                                                <a href="@Url.Action("BlockOPT", new { id = item.Operator_id, rem = item.RetailerId,opttype=item.Operator_type })" style="text-decoration:none;">
                                                                    <div class="onoffswitch" style="float:left;">
                                                                        <span class="costom-on">on</span>

                                                                    </div>
                                                                </a>
                                                            </center>
                                                        }
                                                        else
                                                        {
                                                            <center>
                                                                <a href="@Url.Action("BlockOPT", new { id = item.Operator_id, rem = item.RetailerId,opttype=item.Operator_type })" style="text-decoration:none;">
                                                                    <div class="onoffswitch" style="float:left;">

                                                                        <span class="custom-off">off</span>
                                                                    </div>
                                                                </a>
                                                            </center>

                                                        }
                                                    }
                                                </td>
                                            </tr>
                                            i++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>

<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>


<link href="~/MainFrontDesign/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/MainFrontDesign/select2/dist/js/select2.full.min.js"></script>


<script>
    $('.for-select2').select2();


</script>


<script>
    $(function () {
        $('.second-design-dealer .example-second').DataTable({


            paging: false
        });
    });

</script>