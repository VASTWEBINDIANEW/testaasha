<script>
    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 45 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }
</script>
<!--Calendar Javascript-->
<script type="text/javascript">
    $(document).ready(function () {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",
        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
        //answers();
    });
</script>
<script type="text/javascript">
    function answers() {
        var e = document.getElementById("ddlusers");
        var answer = e.options[e.selectedIndex].value;
        if (answer == "Dealer") {
            document.getElementById("rem").style.display = "none";
            //document.getElementById("allretailer").selectedIndex = "0";

        }
        else if (answer == "Retailer") {
            document.getElementById("rem").style.display = "block";
        }
    }
</script>
<script>
    $('.white-success-button').click(function () {
        $('.white-success').toggle();
    });
</script>







<script>
    $(document).ready(function () {
        var current = location.pathname;
        $('.sidebar-dealer-responshive ul li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('active');


            }
        })
    });
</script>

<script>
    $(document).ready(function () {
        var month = '@ViewBag.chkmonth';
        $('#Month').val(month);
        $('#Month').select2().trigger('change');
        $('#dealerid').select2();
        $('#Year').select2();
    });
</script>
<script>
    function Download(apiid) {
        var Month = $('#Month').val();
        var Year = $('#Year').val();
            var url = '@Url.Action("Print_Sell_Gst_dealer", "Home")?Month=' + Month + '&Year=' + Year + '';
            window.open(url, '_blank');
    }
</script>



