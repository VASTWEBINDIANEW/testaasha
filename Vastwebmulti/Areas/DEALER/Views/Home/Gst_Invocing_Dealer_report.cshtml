@model IEnumerable<Vastwebmulti.Models.GST_Monthly_Dealer_Result>
@{
    ViewBag.Title = "Gst_Invocing_Master_report";
    Layout = "~/Areas/DEALER/Views/Shared/_Layout.cshtml";
}

<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px 6px 4px;
    }
     
    .dropdown-menu {
        margin-top: 81px !important;
    }

    table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px;
    }
     
    .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {
        height: 20px;
    } 
    @@media screen and (max-width:766px){
        .card.gstinvocing-report .table-responsive {border: 0;padding-bottom:15px;}
    }
</style>

<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-dealer">
            <h3>Gst Invocing Dealer Report</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Account Active&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">GST Invoice</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:0px;">
                <div class="card" style="margin-bottom: 0;">
                    <div class="">
                        <div class="col-md-7 dealer-none-fourclass" style="width:auto;float:left;padding-left:0;">
                            <div class="w-100 float-left bread-same-all-page">
                                <ul class="float-left bred" style="margin: 0; padding: 0;;">
                                    <li class="smli">
                                        <a href="@Url.Action("Dashboard","Home")" class="fullbodydycolorbg tmw-total-color-one">Dashboard&nbsp;<span style="font-size:18px;">&#187;</span></a>
                                    </li>
                                    <li class="fullbodydycolorbg tmw-total-color-one" style="margin-top: 5px;">&nbsp;GST&nbsp;Invoice&nbsp;Report</li>

                                </ul>

                            </div>

                        </div>


                        <div class="col-md-5 dth-buttonpdfexl" style="width:auto;float:right;padding-right:0px;">


                            <button class="white-success-button" style="margin-left:4px;background:#eeebeb;border: 1px solid #e1dcdc;">Total</button>

                            <div class="web-white-filter fil" style="float: left;margin-right: 0px;margin-top:0px;">
                                <input type="button" id="btnExport" value="Export" style="margin-left:0px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);
                                background-repeat: no-repeat;background-position: 4px center;padding-left: 20px;">
                                <input type="button" id="btnPDF" value="PDF" style="margin-left:2px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);
                                background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">
                            </div>

                        </div>

                        <div class="col-md-2" style="width:auto;float:right;padding:0;">
                            <p style="font-size:20px;margin-top:5px;font-weight:700;color:#55555a;">Month&nbsp;:-&nbsp;@ViewBag.OldMonth</p>
                        </div>

                    </div>

                </div>
            </div>
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="">
                <div class="card gstinvocing-report">

                    <div class="body all-reporttable-css" style="padding:7px 0;">
                        <div class="table-responsive" style="position:inherit;">
                            <table class="table table-bordered table-striped table-hover" style="width:100%; font-size:12px;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Sr.No</th>
                                        <th>Email&nbsp;ID</th>
                                        <th>Frim&nbsp;Name</th>
                                        <th>Account Transfer&nbsp;Comm</th>
                                        <th>Account Transfer&nbsp;GST</th>
                                        <th>RCH&nbsp;Comm</th>
                                        <th>RCH&nbsp;GST</th>
                                        <th>Aeps&nbsp;Comm</th>
                                        <th>Aeps&nbsp;GST</th>
                                        <th>PAN&nbsp;Comm</th>
                                        <th>PAN&nbsp;GST</th>
                                        <th>MPOS&nbsp;Comm</th>
                                        <th>MPOS&nbsp;GST</th>
                                        <th>Flight&nbsp;Comm</th>
                                        <th>Flight&nbsp;GST</th>
                                        <th>Total&nbsp;GST</th>
                                        <th>Print</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var i = 1;
                                    }

                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td><p style="font-size:12px;">@item.Email</p></td>
                                            <td><p style="font-size:12px;">@item.FarmName</p></td>
                                            <td><p style="font-size:12px;">@item.dmtcomm</p></td>
                                            <td><p style="font-size:12px;">@item.dmtgst</p></td>
                                            <td><p style="font-size:12px;">@item.rchcomm</p></td>
                                            <td><p style="font-size:12px;">@item.rchgst</p></td>
                                            <td><p style="font-size:12px;">@String.Format("{0:0.00#}", item.aepscomm)</p></td>
                                            <td><p style="font-size:12px;">@item.aepsgst</p></td>
                                            <td><p style="font-size:12px;">@item.pancomm</p></td>
                                            <td><p style="font-size:12px;">@item.pangst</p></td>
                                            <td><p style="font-size:12px;">@item.mposcomm</p></td>
                                            <td><p style="font-size:12px;">@item.mposgst</p></td>
                                            <td><p style="font-size:12px;">@String.Format("{0:0.00#}", item.flightcomm)</p></td>
                                            <td><p style="font-size:12px;">@item.flightgst</p></td>
                                            <td><p style="font-size:12px;">@item.total</p></td>
                                            <td><a href="@Url.Action("GST_Invocing_Report_Pdf","Home")" style="font-size:14px;color:blue;font-weight:500;" target="_blank">Print</a></td>
                                        </tr>
                                        i++;
                                    }
                                    <tr><td colspan="17" style="text-align:center;">No&nbsp;Data&nbsp;Found</td></tr>
                                </tbody>

                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->

<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />



