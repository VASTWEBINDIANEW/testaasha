<script type="text/javascript">
    function eselectAll() {
        var items = document.getElementsByName('acs1');
        for (var i = 0; i < items.length; i++) {
            if (items[i].type == 'checkbox')
                items[i].checked = true;
        }
    }
    function eUnSelectAll() {
        var items = document.getElementsByName('acs1');
        for (var i = 0; i < items.length; i++) {
            if (items[i].type == 'checkbox')
                items[i].checked = false;
        }
    }
</script>


<script type="text/javascript">
                $(function () {
                    loadSelfUpiBlockStatus();
        $("#SaveAll").click(function () {
            var optCode = []

                $("#SelfUpiCheckUncheck input").each(function () {
                    if ($(this).prop('checked') == true) {
                        optCode.push($(this).val() + ",Y");
                    }
                    if ($(this).prop('checked') == false) {
                        optCode.push($(this).val() + ",N");
                    }
                });

            document.getElementById("loadermoney").style.display = "block";

            $.ajax({
                         type: "POST",
                         url: '@Url.Action("Blocked_Self_Upi_SettingSave", "Home")',
                         data: { 'ch': optCode },
                         cache: false,
                         dataType: 'json',
                         async: true,
                         success: function (data) {
                             var pp = data.status;
                             var mm = data.Message;

                             if (pp) {
                                 document.getElementById("loadermoney").style.display = "none";
                                 toastr.success('UPI Mode Successfully Blocked', 'Self UPI Block');
                             }
                             else {
                                 toastr.error(mm, 'Self UPI Block Error');
                             }

                         }
                     });

        });

        function loadSelfUpiBlockStatus() {
             $.ajax({
                type: "GET",
                url: '@Url.Action("Check_Unchek_Blocked_Self_Upi_Setting", "Home")',
                cache: false,
                dataType: 'json',
                async: true,
                success: function (data) {
                    var obj = data;

                    for (var item in obj) {
                        var sts = obj[item].status;
                        var name = obj[item].Upi_Mode;
                        if (sts == "Y") {
                            $("#" + name + "").prop("checked", true);
                        }
                    }
                }
            });
        }
        });
</script>
