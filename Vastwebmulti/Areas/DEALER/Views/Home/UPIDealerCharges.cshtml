                                            <tbody>
                                                @foreach (var item in Model.UPIREPORT)
                                                {

                                                    i++;
                                                    var frmname = item.Frm_Name == null || item.Frm_Name == "" ? item.RetailerName : item.Frm_Name;

                                                    TOTALAMOUNT = item.amt + TOTALAMOUNT;
                                                    TOTALNET = item.finalpay + TOTALNET;
                                                    TOTALCHARGE = item.charge + TOTALCHARGE;
                                                    var img = "";
                                                    var bg = "";
                                                    var pd = "";

                                                    if (item.status.ToUpper() == "SUCCESS")
                                                    {
                                                        img = "../../ashok-images/correct.svg";
                                                        bg = "green";
                                                        pd = "3px";

                                                    }
                                                    else if (item.status.ToUpper() == "PENDING")
                                                    {
                                                        img = "../../ashok-images/clock.svg";
                                                    }
                                                    else
                                                    {
                                                        img = "../../ashok-images/closes.svg";
                                                        bg = "red";
                                                        pd = "3px";
                                                    }
                                                    <tr>
                                                        <td>@i</td>
                                                        <td>@item.rolename</td>
                                                        <td>@frmname</td>
                                                        <td><img src='@img' style="width: 20px;background:@bg;padding:@pd;border-radius:50%;">&nbsp;@item.PayerName</td>
                                                        <td style="font-weight:bold;">@item.remainpre</td>
                                                        <td>@item.amt</td>
                                                        <td>@item.charge</td>
                                                        <td>@item.finalpay</td>
                                                        <td>@item.remainpost</td>
                                                        <td>@item.BankRRN</td>
                                                        <td>@item.txndate</td>

