<script>
    function mdActionBtn(Idno) {
        $.ajax({
            url: '@Url.Action("Money_Tranfer_Details_View", "Home")',
            type: 'POST',
            data: { Idno: Idno },
            cache: false,
            success: function (Response) {
                if (Response[0].status == "SUCCESS") {
                    status = "../../ashok-images/correct.svg";
                    var color = "green";
                }

                if (Response[0].status == "FAILED") {
                    status = "../../ashok-images/closes.svg";
                    color = "red";
                }
                if (Response[0].status == "Pending") {
                    status = "../../ashok-images/clock.svg";

                }
                document.getElementById("img12").src = status
                document.getElementById("img12").style.backgroundColor = color
                $('#Idno').val(Response[0].idno)
                $('#senderno').val(Response[0].senderno)
                $('#trans_id').val(Response[0].trans_id)
                $('#bank_nm').val(Response[0].bank_nm)
                $('#ifsccode').val(Response[0].ifsccode)
                $('#responce_time').val(Response[0].responce_time)
                $('#user_remain_pre').val(Response[0].user_remain_pre)
                $('#income').val(Response[0].income)
                $('#user_remain').val(Response[0].user_remain)
                $('#DealerPre').val(Response[0].dlm_remain_pre)
                $('#dlm_income').val(Response[0].dlm_income)
                $('#DealerPost').val(Response[0].dlm_remain)

                $('#Response').val(Response[0].response_output)
            }
        });
    }

</script>
<script>
    var pageindex = 2;
        var NoMoredata = false;
    var inProgress = false;
    $(window).scroll(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var ddlusers = $('#ddlusers').val();
        var ddl_status = $('#ddl_status').val();
        var alldealer = $('#alldealer').val();
        var allretailer = $('#allretailer').val();
        var allapiuser = $('#allapiuser').val();
        var ddl_Type = $('#ddl_Type').val();

            if ($(window).scrollTop() > Number($("#mmm").height()) / 4 && !NoMoredata && !inProgress) {
                inProgress = true;
                $("#loadingdiv").show();
                $.post("@Url.Action("InfiniteScroll1", "Home")",
                    { "pageindex": pageindex, "txt_frm_date": txt_frm_date, "txt_to_date": txt_to_date, "ddlusers": ddlusers, "alldealer": alldealer, "allretailer": allretailer, "ddl_status": ddl_status, "allapiuser": allapiuser,  "ddl_Type": ddl_Type},
                    function (data) {
                        pageindex = pageindex + 1;
                        NoMoredata = data.NoMoredata;
                        $("#trow").append(data.HTMLString);
                        $("#loadingdiv").hide();
                        inProgress = false;
                    });
            }
        });
</script>
