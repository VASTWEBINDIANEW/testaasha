<script>
    function Getvaladmin(obj)
    {
        var val = obj.value;
        var txt_frm_date=$("#txt_frm_date").val();
        var txt_to_date = $("#txt_to_date").val();
          $.ajax({
            type: 'Post',
            url: "@Url.Action("MasterImpsIncmoe", "Home")",
            data:{Type:val,txt_frm_date:txt_frm_date,txt_to_date:txt_to_date},
            dataType: 'json',
            cache: false,
            async: false,
            success: function (data) {
                var type = data.Type;

                if (type == "Master")
                {
                    document.getElementById("master").innerText = "₹ " + data.Adminincome;

                  }
                else if (type == "GST")
                {
                    document.getElementById("gst").innerText = "₹ " + data.Gst;
                   }
                else if (type == "TDS")
                {
                    document.getElementById("tds").innerText = "₹ " + data.Tds;
              }


        }
    });
    }
</script>
