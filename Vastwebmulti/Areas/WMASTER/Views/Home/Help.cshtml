@{
    ViewBag.Title = "Help";
    Layout = "~/Areas/WMASTER/Views/Shared/_Layout.cshtml";
}
<style>
    .table tbody tr td, .table tbody tr th
    {
        border-top:0px;
        border-bottom:0px;
    }
    .table-responsive{
        border:0px;
    }
    .wmaster-help p.help-wmasterheader {
    background:#ddd !important;
    
}
    .wmaster-help .col-md-6 .card .table-responsive {
    background: #eae9e9;
}
    .wmaster-help .col-md-6 .card-wmaster .table-responsive tr td:first-child {
        font-weight: bold;
        padding-left: 0;
    }
    .wmaster-help .col-md-6 .card .table-responsive tr td:first-child {
        
        padding-left: 0;
    }
    .wmaster-help .col-md-6 .card .table-responsive tr td:last-child {
        
        padding-right: 0;
    }
    .wmaster-help .col-md-6 .card .table-responsive tr td {
    padding: 18px 0;
}
    .container-fluid.wmaster-help .table-responsive{margin-bottom:0;}

    @@media screen and (max-width:767px) {
        .container-fluid.wmaster-help {
            padding-left: 0;
        }
        .wmaster-help .col-md-6 .card .table-responsive tr td, .wmaster-help .col-md-6 .card .table-responsive tr {
    width: 100% !important;
    float: left !important;
    
    display: block;
}
        .wmaster-help .col-md-6 .card .table-responsive tr td{padding: 5px 0;}
    }

</style>
<section class="content">
    <div class="container-fluid wmaster-help">
        <div class="row clearfix">
            <div class="col-md-6">
                <div class="card">
                    <p class="help-wmasterheader" style="font-size:21px;padding-top:2px;padding-bottom:7px;padding-left:15px;background-color:whitesmoke;font-weight:700;">
                        <img src="~/AdminDesign/images/headphone.svg" style="width:28px;" />&nbsp;Customer&nbsp;Care&nbsp;Support&nbsp;Timing
                    </p>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="">
                                <div style="border:1px solid #dddddd;border-radius:5px;">
                                    @*<center><p style="margin-top:-24px;font-weight:bold;padding:0px 16px 1px 16px;background:linear-gradient(#ffffff 0%, #ffffff 100%);position:absolute;right:44%;border-radius:1px;border: 1px solid #ccc;">Day&nbsp;and&nbsp;Time</p></center>*@
                                    <div class="row">
                                        <div class="col-md-12" >
                                            <div class="table-responsive">
                                                <table class="table for-table-border">
                                                    <thead>

                                                    </thead>
                                                    <tbody>
                                                        <tr>
                                                            <td>MONDAY</td>
                                                            
                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>
                                                      


                                                        </tr>
                                                        <tr>
                                                            <td>TUESDAY</td>
                                                            
                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>
                                                        
                                                        </tr>
                                                        <tr>
                                                            <td>WEDNESDAY</td>
                                                            
                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>
                                                       
                                                        </tr>

                                                        <tr>
                                                            <td>THURSDAY</td>
                                                            
                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>
                                                     
                                                        </tr>
                                                        <tr>
                                                            <td>FRIDAY</td>
                                                            
                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>
                                                   
                                                        </tr>
                                                        <tr>
                                                            <td>SATURDAY</td>
                                                            
                                                            <td><p style="font-weight:700;">9.00 AM  to  08.00 PM</p></td>
                                                     
                                                        </tr>
                                                        <tr>
                                                            <td>SUNDAY</td>
                                                            
                                                            <td><p style="font-weight:700;">9.00 AM  to  02.00 PM</p></td>
                                                     
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card card-wmaster" style="margin-top:0px;">
                    <p class="help-wmasterheader" style="font-size:21px;padding-top:5px;padding-bottom:7px;padding-left:15px;background-color:whitesmoke;font-weight:700;"><img src="~/AdminDesign/images/company.svg" style="height:24px;">&nbsp;Contact&nbsp;Information</p>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="">
                                <div style="border:1px solid #dddddd;border-radius:5px;">
                                    @*<center><p style="margin-top:-24px;border: 1px solid #ccc;font-weight:bold;padding:0px 16px 1px 16px;background:linear-gradient(#ffffff 0%, #ffffff 100%);position:absolute;right:45%;border-radius:1px;">Company&nbsp;Info</p></center>*@
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="table-responsive">
                                                <table class="table for-table-border" >
                                                    <thead>

                                                    </thead>
                                                   
                                                    <tbody>
                                                        <tr>
                                                            <td>Company Name</td>
                                                            
                                                            <td>
                                                                @if (ViewBag.admin.Companyname != null && ViewBag.admin.Companyname != "")
                                                                {
                                                                    <p>@ViewBag.admin.Companyname</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>
                                                    

                                                        </tr>
                                                        <tr>
                                                            <td>Otheride Person</td>
                                                            
                                                            <td>
                                                                @if (ViewBag.admin.Name != null && ViewBag.admin.Name != "")
                                                                {
                                                                    <p>@ViewBag.admin.Name</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>
                                           
                                                        </tr>
                                                        <tr>
                                                            <td>Support Email-Id</td>
                                                            
                                                            <td>
                                                                @if (ViewBag.admin.email != null && ViewBag.admin.email != "")
                                                                {
                                                                    <p>@ViewBag.admin.email</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>
                                                  
                                                        </tr>

                                                        <tr>
                                                            <td>Custmor Care No</td>
                                                            
                                                            <td>
                                                                @if (ViewBag.admin.mobile != null && ViewBag.admin.mobile != "")
                                                                {
                                                                    <p>@ViewBag.admin.mobile</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>
                                             
                                                        </tr>
                                                        <tr>
                                                            <td>Company Address</td>
                                                            
                                                            <td>
                                                                @if (ViewBag.admin.Address != null && ViewBag.admin.Address != "")
                                                                {
                                                                    <p>@ViewBag.admin.Address</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>
                                    
                                                        </tr>
                                                        <tr>
                                                            <td>GST IN</td>
                                                            
                                                            <td>
                                                                @if (ViewBag.admin.Address != null && ViewBag.admin.Address != "")
                                                                {
                                                                    <p>@ViewBag.admin.Address</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>
                                   
                                                        </tr>
                                                        <tr>
                                                            <td>Pancard</td>
                                                            
                                                            <td>
                                                                @if (ViewBag.admin.Address != null && ViewBag.admin.Address != "")
                                                                {
                                                                    <p>@ViewBag.admin.Address</p>
                                                                }
                                                                else
                                                                {
                                                                    <p>No Data Found !</p>
                                                                }
                                                            </td>
                                           
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
        
    </div>
</section>

