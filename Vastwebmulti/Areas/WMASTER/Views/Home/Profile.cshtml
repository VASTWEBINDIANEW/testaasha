@model Vastwebmulti.Models.User
@{
    ViewBag.Title = "Profile";
    Layout = "~/Areas/WMASTER/Views/Shared/_Layout.cshtml";

}
<link href="~/Areas/WMASTER/MasterCss/mastercss.css" rel="stylesheet" />

<style>
    .ribbon {
        position: absolute;
        right: 16px;
        top: 0px;
        z-index: 1;
        overflow: hidden;
        width: 75px;
        height: 75px;
    }

        .ribbon span {
            font-size: 11px;
            color: #fff;
            text-align: center;
            font-weight: bold;
            line-height: 20px;
            transform: rotate(45deg);
            -webkit-transform: rotate(45deg);
            width: 100px;
            box-shadow: 0 3px 10px -5px rgba(0, 0, 0, 1);
            position: absolute;
            top: 19px;
            right: -21px;
            background: linear-gradient(#c5c5c5 0%, #868686 100%);
        }

    .list-group-item {
        border: none;
    }

    .field-validation-error {
        color: red;
    }

    .required:after {
        color: red;
        content: " *";
    }

    .ltgl .list-group-item {
        background: transparent;
    }

    .ltgl {
        border: 1px solid #ddd;
        border-bottom: 0px;
    }

        .ltgl li {
            border-bottom: 1px solid #ddd;
        }

    .edtbdy .col-md-3 {
        text-align: left !important;
    }

    .edtbdy .col-md-3, .edtbdy .col-md-9 {
        margin-bottom: 0px !important;
    }

    .edtbdy .form-group {
        margin-bottom: 0px;
    }

    .edtbdy .modal-footer {
        border: 0px;
        padding: 0px;
    }

    .edtbdy .row {
        margin-bottom: 10px;
    }

    .edtbdy .col-md-9 .form-control {
        width: 100% !important;
    }

    .edtbdy .col-md-9 select {
        -webkit-appearance: none;
        background: url('~/AdminDesign/images/multimedia.svg')no-repeat;
        background-position-y: 50%;
        background-color: #fff;
    }

    .classprofileheading h1 {
        width: auto;
        float: left;
        margin-top: -8px !important;
        margin-left: 10px;
        background: #f5f5f5;
        color: #555 !important;
        padding: 0 7px;
    }

    .jonbdy p {
        background: #fff;
    }

    .select2-container--default .select2-selection--single {
        border-radius: 0px !important;
        height: 32px !important;
    }

    .spdtl-uploadclass span.select2.select2-container {
        width: 100% !important;
    }

        .spdtl-uploadclass span.select2.select2-container span.select2-selection.select2-selection--single {
            border: 1px solid #ddd !important;
            height: 34px !important;
            padding-top: 2px;
        }

    .jonbdy p {
        padding: 7px 5px;
    }

    .list-group.ltgl.ltgl-firstclass li.list-group-item {
        background: #ddd;
        border: 1px solid #555;
        margin-bottom: 10px;
    }

    .wh-masterclass .body.jonbdy p {
        background: #ddd;
        border-color: #555;
    }

    .wh-masterclass p.wmasternamefirst {
        border-right: 0;
    }

    .wh-masterclass .body.jonbdy p {
        padding: 7px 5px;
    }
    .editbuttoncssclass a:hover::before {
    opacity: 1;
    background-color: @PageData["Globalfirst"];
    -webkit-transform: rotate3d(0, 0, 1, 0deg);
    transform: rotate3d(0, 0, 1, 0deg);
    -webkit-transition-timing-function: cubic-bezier(0.2, 1, 0.3, 1);
    transition-timing-function: cubic-bezier(0.2, 1, 0.3, 1);
}
    .editbuttoncssclass a:hover ,.docoment-uploadclassbutto p.badge:hover{
        color: #fff;
        border-color: @PageData["Globalfirst"] !important;
    }
    .edit-uploadprofileimage .modal-footer button:hover ,.adresbuttonsave .modal-footer button:hover ,.docoment-uploadclassbutto p.badge::before ,.buttonfulclasscss .modal-footers button:hover{
    background: @PageData["Globalfirst"] !important;border-color: @PageData["Globalfirst"] !important;
}
        .edit-uploadprofileimage .modal-footer button:hover span, .adresbuttonsave .modal-footer button:hover span {
            color: #fff !important;
        }
        .profile-imgupload .profilebackground .classprofileheading button::before{background:@PageData["GlobalSecond"];}
@@keyframes blinkmaster {
    0% {
        color:#555;
    }

    50% {
        color: #fff;
    }

    100% {
        color: #555;
    }
}

     .address-profileupload #EditaddressModal .col-md-9 select {
    background-size: 11px;
}
    @@media screen and (max-width:1366px) {
        .wh-masterclass .spdtl-uploadclass .tftg .col-md-3 label {
            font-size: 12px;
        }

        .wh-masterclass .spdtl-uploadclass .tftg .col-md-3 {
            width: 30%;
            float: left;
            padding-right: 0;
        }

        .wh-masterclass .spdtl-uploadclass .tftg .col-md-9 {width: 69%;float: right;}
    }

  @@media screen and (max-width:766px){
      .profile-imgupload {width: 100%;float: left;padding-right: 15px !important;margin-top:5px;margin-bottom:15px;}
      .profile-imgupload .profilebackground .ribbon {right: 16px;}
      .wh-masterclass {
    width: 100%;
    float: left;
    padding-right: 15px !important;
}
      .col-md-8.docoment-uploadclassbutto {
    width: 100%;
    float: left;
}
  }

  @@media screen and (max-width:420px){
    .address-profileupload #EditaddressModal .col-md-3, .address-profileupload #EditaddressModal .col-md-9 {
        width: 100%;
        float: left;
    }
 
      .profile-imgupload .profilebackground .edit-uploadprofileimage .col-lg-3.col-md-3.col-sm-4.col-xs-5.form-control-label 
      ,.profile-imgupload .profilebackground .edit-uploadprofileimage .col-lg-9.col-md-9.col-sm-8.col-xs-7{
    float: left;
    width: 100%;
}
      .profile-imgupload .profilebackground .edit-uploadprofileimage {
    min-height: 150px;
}
      .wh-masterclass .body.jonbdy p {
    width: 100%;
    float: left;
    text-align: left;
    margin: 0;
    border: 1px solid #555;
}
      .wh-masterclass .body.jonbdy p.wmasternamefirst {
    border-bottom: 0;
    margin-top: 15px;
}
      .wh-masterclass .body.jonbdy p {
    background: transparent;
}
      .wh-masterclass .body.jonbdy p.wmasternamefirst {
    background: #dddddd;
}
      .wh-masterclass .body.jonbdy p.wmasternamefirst:first-child {
    margin-top: 0;
}
      .address-profileupload ul.ltgl-firstclass li {
    padding: 6px 4px;
}
      .address-profileupload ul.ltgl-firstclass li span, .address-profileupload ul.ltgl-firstclass li p {
    font-size: 12px;
}
      .address-profileupload .card {
    min-height: inherit !important;
}
      .wh-masterclass .card .spdtl-uploadclass .body.tftg .col-md-3 ,.wh-masterclass .card .spdtl-uploadclass .body.tftg .col-md-9{
    width: 100%;
    float: left;
}
      .wh-masterclass .card .spdtl-uploadclass .body.tftg .col-md-3 label {
    margin-top: 0;
}
      .buttonfulclasscss .upload-pancardclass ,.buttonfulclasscss .upload-text ,.buttonfulclasscss .uploadtext-img{
    width: 100%;
}
      .buttonfulclasscss .upload-text label {
    padding-top: 0;
    margin-bottom: 5px;
}
      .buttonfulclasscss .modal-footers {
    width: 100%;
    padding-left: 0;
    margin-top: 5px;
}
      .docoment-uploadclassbutto .body.panbody-content {
    padding: 0 6px;
}
      .docoment-uploadclassbutto .body.panbody-content ul.list-group.ltgl li {
    padding: 10px 5px;
}
      .docoment-uploadclassbutto .body.panbody-content ul.list-group.ltgl li p {
    font-size: 11px;
}
      .docoment-uploadclassbutto .body.panbody-content ul.list-group.ltgl li p.badge {
    font-size: 10px;
}
      .docoment-uploadclassbutto .body.panbody-content {
    min-height: inherit;
}
      .profile-imgupload .profilebackground .classprofileheading h1 {
    font-size: 13px !important;
}



  }


</style>
<section class="content" style=" margin: 75px 0px 0 170px;">
    <div class="container-fluid">

        <div class="row clearfix">
            <div class="col-md-4 profile-imgupload" style="padding-right: 4px;">
                <div class="profilebackground" style="width: 100%; float: left; min-height: 374px; background: #f5f5f5; ">
                    <div class="ribbon"><span>MASTER</span></div>

                    <div class="body">
                        <center>
                            @if (ViewBag.MD_Details.Photo != null)
                            {
                                <div class="image" style="margin-top:15px;">
                                    <img src="@Url.Content("~/"+ ViewBag.MD_Details.Photo )" class="img-circle" alt="User" width="100" height="100" title="Click Me Upload Profile Image" style="cursor:pointer;" onclick="uploadimage('@ViewBag.MD_Details.SSId')" />

                                </div>

                            }
                            else
                            {
                                <div class="image" style="margin-top:15px;">
                                    <img src="~/AdminDesign/images/user.png" width="100" height="100" class="img-circle" alt="User" title="Click Me Upload Profile Image" style="cursor: pointer;" onclick="uploadimage('@ViewBag.MD_Details.SSId')">

                                </div>
                            }

                            <div class="msg" style="padding-top:12px; font-size:19px; font-weight:600; color: #555;text-transform: capitalize;">@ViewBag.MD_Details.SuperstokistName</div>
                            <p style="margin-top:15px;font-size:14px;text-transform:uppercase;">Master Distribution Partner</p>

                        </center>
                        <div class="" style="margin-bottom: 20px;margin-top:26px !important;width: 100%;float: left;">
                            <div class="body fullbodydycolorbg classprofileheading" id="classprofileheadingnone" style="background-color:whitesmoke;height:113px;border:3px solid #555;border-radius: 5px;width: 90%;margin: 0px auto;">
                                <h1 style="color:#fff;font-size:14px;font-weight:bold;text-transform:uppercase;text-align:center;margin-top: 10px;margin-bottom: 15px;">
                                    <i class="fa fa-lock"></i>&nbsp;One Time Password Security
                                </h1>
                                <div class="row" style="margin-bottom:-20px;">
                                    <div class="col-md-12">
                                        @if (Model.TwoFactorEnabled)
                                        {
                                            using (Html.BeginForm("DisableTwoFactorAuthentication", "Manage", new { area = "" }, FormMethod.Post, new { encType = "multipart/form-data", @style = "padding-left:0px;padding-top:2px;" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                <center>
                                                    <button type="submit" class="btn  btn-circle-lg waves-effect waves-circle waves-float" style="margin-top:10px;height: 40px !important;box-shadow: 0px 0px 1px 3px rgba(0, 0, 0, 0.12);width:145px;padding: 0px !important;border-radius: 50px 50px !important;background-color:@PageData["Globalfirst"];">
                                                        <span style="font-size:20px;font-weight:700;color:#fff;">OTP&nbsp;-&nbsp;ON</span>
                                                    </button>
                                                </center>
                                            }
                                        }
                                        else
                                        {
                                            using (Html.BeginForm("EnableTwoFactorAuthentication", "Manage", new { area = "" }, FormMethod.Post, new { encType = "multipart/form-data", @style = "padding-top:2px;" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                <center>
                                                    <button type="submit" class="btn  btn-circle-lg waves-effect waves-circle waves-float" style="margin-top:10px;height: 40px !important;box-shadow: 0px 0px 1px 3px rgba(0, 0, 0, 0.12);width:145px;padding: 0px !important;border-radius: 50px 50px !important;background-color:@PageData["Globalfirst"];">
                                                        <span style="font-size:20px;font-weight:700;color:#fff;">OTP&nbsp;-&nbsp;OFF</span>
                                                    </button>
                                                </center>
                                            }
                                        }

                                    </div>
                                </div>
                            </div>

                            <div class="edit-uploadprofileimage" id="EditProfileimageModal" style="display:none;">
                                
                                    
                                        
                                            <h4 class="modal-title" id="defaultModalLabel" style="color:black;"><i class="fa fa-user" style="font-size:14px;color:#555;"></i>&nbsp;Upload Profile Image</h4>
                                        
                                        @using (Html.BeginForm("UploadProfileimage", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
                                        {
                                            
                                                
                                                    <form>
                                                        <div class="row clearfix">
                                                            <input type="text" id="txtprofileid" name="txtprofileid" style="display:none;" />
                                                            <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                                                <label for="email_address_2">Upload Image</label>
                                                            </div>

                                                            <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                                                <div class="form-group">
                                                                    <div class="" style="border:1px solid #ddd;">
                                                                        <input type="file" class="form-control" id="file" name="file" />
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="modal-footer">
                                                            <button type="submit" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-right:12px; height:34px;">
                                                                <span style="top:-2px;color:black;">Save Change</span>
                                                            </button>
                                                            <button type="button" id="close-bodyprofile" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left: -3px; height:34px;" data-dismiss="modal">
                                                                <span style="top:-2px;color:black;">Close</span>
                                                            </button>
                                                        </div>
                                                    </form>
                                                
                                            
                                        }

                                    
                               
                            </div>

                        </div>
                    </div>
                </div>

            </div>
            <div class="col-lg-8 col-md-8 col-sm-12 col-xs-12 address-profileupload">
                <div class="card" style="border: 1px solid #e6e3e3;background: #f5f5f5;min-height:374px;">
                    <div class="body editbuttoncssclass" style="margin-bottom:0px;background-color:#dddddd;height:3px;padding-bottom: 30px;">
                        @if (ViewBag.MD_Details.FarmName != null)
                        {
                            <h1 style="color:#49586e;font-size:20px;font-weight:bold;margin-top:-10px;text-transform:uppercase;">
                                <img src="~/ashok-images/store.svg" style="width:24px;margin-right: 10px;display: inline-block;">
                                @ViewBag.MD_Details.FarmName
                                <a style="float:right;cursor:pointer;text-transform: capitalize;border: 1px solid #bdbdbd;font-size: 12px !important;background: #fff;padding: 2px 10px;text-decoration:none;"><span style="color: #9E9E9E;font-size: 21px;font-weight: normal;" onclick="editeaddress('@ViewBag.MD_Details.SSId')">Edit</span></a>
                            </h1>
                        }
                        else
                        {
                            <h1 style="color:#49586e;font-size:24px;font-weight:bold;margin-top:-13px;text-transform:uppercase;">
                                No Data Found !
                                <a style="float:right;cursor:pointer;text-decoration:none;"><i class="fa fa-pencil-square-o" style="font-size:22px;margin-top:0px;" onclick="editeaddress('@ViewBag.MD_Details.SSId')"></i></a>
                            </h1>
                        }
                    </div>
                    <div class="body" style="margin-top:0px;">
                        <ul class="list-group ltgl ltgl-firstclass" style="        margin-bottom: 0px;
        background: transparent;
        border: 0;">
                            <li class="list-group-item">
                                <i class="fa fa-map-marker"></i> <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Registered Business Address</span>
                                <span style="display: block;color: #7a7676;">
                                    @if (ViewBag.MD_Details.Address != null && ViewBag.MD_Details.Address != "")
                                    {
                                        <p style="text-align:justify;margin-bottom: 0px;">@ViewBag.MD_Details.Address</p>
                                    }
                                    else
                                    {
                                        <p>ADDRESS NOT FOUND !</p>
                                    }
                                </span>
                            </li>
                            <li class="list-group-item">
                                <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;Town&nbsp;/&nbsp;City</span>
                                @if (ViewBag.MD_Details.city != null && ViewBag.MD_Details.city != "")
                                {
                                    <p style="float:right;text-transform:uppercase;margin-top:4px;">@ViewBag.MD_Details.city</p>
                                }
                                else
                                {
                                    <p style="margin-top:4px;float:right;">CITY NOT FOUND !</p>
                                }
                            </li>
                            <li class="list-group-item">
                                <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;District</span>
                                <p style="float:right;text-transform:uppercase;">@ViewBag.district</p>
                            </li>
                            <li class="list-group-item">
                                <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;State</span>
                                <p style="float:right;text-transform:uppercase;">@ViewBag.ddlstate</p>
                            </li>
                            <li class="list-group-item">
                                <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;Zip Code</span>
                                @if (ViewBag.MD_Details.Pincode != null)
                                {
                                    <p style="float:right;margin-top:0px;">@ViewBag.MD_Details.Pincode</p>
                                }
                                else
                                {
                                    <p style="float:right;margin-top:0px;">ZIP CODE NOT FOUND !</p>
                                }
                            </li>


                        </ul>

                        <div class="adresbuttonsave" id="EditaddressModal" style="display:none;">
                            <div class="dlog" role="document">
                                <div class="modal-content" style="box-shadow: none;border-radius: 0px;">
                                    <div class="modal-header" style="background-color: #ddd;padding: 5px 15px;">
                                        <h4 class="modal-title" id="defaultModalLabel" style="color:#555;">Update Address</h4>
                                    </div>
                                    @using (Html.BeginForm("UpdateMasterProfile", "Home", FormMethod.Post))
                                    {
                                        <div class="modal-body" style="margin-top:0px;background: #f5f5f5;">
                                            <div class="body edtbdy" style="padding: 0px;">
                                                <form>
                                                    <div class="row clearfix">
                                                        <input type="text" id="txtid1" name="txtid1" style="display:none;" />
                                                        <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                                            <label for="email_address_2" class="required">Frim Name</label>
                                                        </div>

                                                        <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                                            <div class="form-group">
                                                                <div class="" style="border:1px solid #ddd;">
                                                                    @Html.TextBox("txtfrimname", "", new { @class = "form-control", placeholder = "Enter Your Address", required = "required" })
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="row clearfix">
                                                        <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                                            <label for="email_address_2" class="required">Address</label>
                                                        </div>

                                                        <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                                            <div class="form-group">
                                                                <div class="" style="border:1px solid #ddd;">
                                                                    @Html.TextBox("txtaddress", "", new { @class = "form-control", placeholder = "Enter Your Address", required = "required" })
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="row clearfix">
                                                        <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                                            <label for="email_address_2" class="required">Town / City</label>
                                                        </div>

                                                        <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                                            <div class="form-group">
                                                                <div class="" style="border:1px solid #ddd;">
                                                                    @Html.TextBox("txtcity", "", new { @class = "form-control", placeholder = "Enter Your Town/city ", required = "required" })
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="row clearfix">
                                                        <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                                            <label for="email_address_2" class="required">State</label>
                                                        </div>
                                                        <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                                            <div class="form-group">
                                                                <div class="" style="border:1px solid #ddd;">
                                                                    @Html.DropDownList("State", (IEnumerable<SelectListItem>)ViewBag.Sate, "-- Select State--", new { @class = "form-control", @required = "required", @onchange = "FillDistict()" })
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="row clearfix">
                                                        <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                                            <label for="email_address_2" class="required">District</label>
                                                        </div>
                                                        <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                                            <div class="form-group">
                                                                <div class="" style="border:1px solid #ddd;">
                                                                    @Html.DropDownList("District", (IEnumerable<SelectListItem>)ViewBag.ALLDistrict, "-- Select District--", new { @class = "form-control", @required = "" })
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="row clearfix">
                                                        <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                                            <label for="email_address_2" class="required">Zip Code</label>
                                                        </div>
                                                        <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                                            <div class="form-group">
                                                                <div class="" style="border:1px solid #ddd;">
                                                                    @Html.TextBox("txtzipcode", "", new { @required = "required", @class = "form-control", @placeholder = "Enter Zip Code", onkeypress = "return isNumber(event)" })
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="modal-footer">
                                                        <button type="submit" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-right:12px; height:34px;">
                                                            <span style="top:-2px;color:black;">Save Change</span>
                                                        </button>
                                                        <button type="button" id="editbuttonclose" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left: -3px; height:34px;" data-dismiss="modal">
                                                            <span style="top:-2px;color:black;">Close</span>
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    }

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        <div class="row clearfix">
            <div class="col-md-4 wh-masterclass" style="padding-right: 4px;">
                <div class="card " style="height:auto;float: left;border: 1px solid #ddd;width: 100%;">
                    <div class="body jdt editbuttoncssclass" style="margin-bottom:0px;background-color:#dddddd;height:42px;">
                        <h1 style="color: #555 !important;font-size:14px;font-weight:bold;margin-top:-16px;text-transform:uppercase;">
