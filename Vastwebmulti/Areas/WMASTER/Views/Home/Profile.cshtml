<!--Delete Doc -->

<script type="text/javascript">

    function deleteDoc(SSID,docname) {
        swal({
            text: "<p style='color:#948f8b; font-size:20px;border-bottom:1px solid #dddddd;margin-top:-12px;padding-bottom:12px;'>Delete " + " " + docname + " !</p>" +
                   "</br><i class='fa fa-trash'style='font-size:72px;color:red;'></i></br><p style=''>Are you sure ?</p>",
             html: true,
            title:"" ,
            showCancelButton: true,
            confirmButtonColor: "#f9a7a7",
            confirmButtonText: "Yes, delete it!",
            closeOnConfirm: false
        },
function () {

    $.ajax({
        type: "POST", url: '@Url.Action("DelereprofileDoc", "Home")', data: { 'SSID': SSID, 'Docname': docname }, dataType: 'json', cache: false, success: function (result) {
            if (result == "Success") {
                swal("File Removed!", " Deleted Successfully.", "success");
                var url = '@Url.Action("Profile", "Home")';
                window.location.href = url;
            }
            else {
                swal("Failed!", "Something went wrong.", "error");
                var url = '@Url.Action("Profile", "Home")';
                window.location.href = url;
            }
        }
    });
}
);

    }

</script>


