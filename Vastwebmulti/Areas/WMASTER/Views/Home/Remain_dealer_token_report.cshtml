@model IEnumerable<Vastwebmulti.Models.dealer_remain_token_report_by_master_Result>
@{
    ViewBag.Title = "Remain_dealer_token_report";
    Layout = "~/Areas/WMASTER/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">
    

        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card" style="margin-top:-14px;">
                    <div class="">
                        <ol class="breadcrumb breadcrumb-col-blue-grey" style="margin-left:5px;margin-top:9px;">
                            <li class="active" style="color:#9E9E9E; font-size:12px;">DISTRIBUTOR REMAIN TOKEN REPORT&nbsp;></li>
                        </ol>
                    </div>
                    <div class="body" style="padding:7px;">
                        <div class="table-responsive" style="position:inherit;margin-top:-22px;">
                            <table class="table table-bordered" style="width:100%;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Sr.No</th>
                                        <th>Emain-ID</th>
                                        <th>Name</th>
                                        <th>Frim Name</th>
                                        <th>Remain Token</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var i = 1;
                                    }
                                    @if (Model.Count() > 0)
                                    {
                                        foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@i</td>
                                                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                                                <td>@Html.DisplayFor(modelItem => item.DealerName)</td>
                                                <td>@Html.DisplayFor(modelItem => item.FarmName)</td>
                                                <td>@Html.DisplayFor(modelItem => item.RemainTokenPost)</td>

                                            </tr>
                                            i++;
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td></td>
                                            <td></td>
                                            <td><p style="font-size:22px;margin-top:-5px;text-align:center;color:#e0dddd;font-weight:700;">No Data Found !</p></td>
                                            <td></td>
                                            <td></td>
                                        </tr>

                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>


    </div>
</section>




