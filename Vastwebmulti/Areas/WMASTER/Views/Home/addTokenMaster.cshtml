                                            <button type="button" class="btn waves-effect" data-dismiss="modal">
                                                <span>Close</span>
                                            </button>
                                            <button type="button" id="MdbtnSubmit" class="btn fullbodydycolorbg waves-effect btnssl2233 special-iii" data-loading-text="<i class='fa fa-spinner fa-spin'></i>">
                                                <span style="color:#fff;">Verify & Sale Token</span>
                                            </button>

                                        </div>
                                    </div>
                                    </div>
                                </div>
                            <div class="col-md-12">
