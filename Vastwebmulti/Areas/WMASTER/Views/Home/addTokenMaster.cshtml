                                                <li>
                                                    <button type="button" id="btnChildPlus2" class="btn  waves-effect btmPlusMinus2" onclick="onPluseMinuss(1)">
                                                        <i class="fa fa-plus" aria-hidden="true" style="font-size:10px;color:#757979;top:0px;"></i>
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
