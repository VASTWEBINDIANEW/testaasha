@model IEnumerable<Vastwebmulti.Models.Show_Dealer_credit_report_by_admin_Result>
@{
    ViewBag.Title = "Show_Dealer_outstandingreport";
    Layout = "~/Areas/WMASTER/Views/Shared/_Layout.cshtml";
}
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:0px;">
                <div class="card">
                    <div class="" style="display: inline-block;">
                        <ol class="breadcrumb breadcrumb-col-blue-grey" style="margin-left:0px;margin-top:0px;">
                            <li class="active" style="color:#555; font-size:16px;font-weight:600;">OUTSTANDING</li>
                        </ol>
                    </div>
                    <div class="col-md-2" style="padding: 0px;float: right;">
                        @using (Html.BeginForm("MasterLedger", "Home", FormMethod.Post))
                        {
                            <div class="col-md-7 jjp" style="padding: 0px;">
                                <div class="input-daterange input-group" style="">
                                    <div class="custom-date-icon ner">
                                        <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                    </div>
                                    @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; width: 119px !important;margin-top:0px;height:36px;" })
                                </div>
                            </div>
                            <div class="col-md-5" style="padding: 0px;">
                                <center>
                                    <button type="submit" class="btn bg-grey waves-effect" style=" background: transparent !important;border: 1px solid #ddd !important;">
                                        <i class="fa fa-search" style="top:1px;font-size:16px;color:black;"></i>
                                        <span style="top:0px;color:black;">Search</span>
                                    </button>
                                </center>
                            </div>
                        }
                    </div>
                    <div class="body" style="margin-top:0px;padding:0px;">
                        <div class="table-responsive" style="position:inherit; overflow:hidden;">
                            <table class="table table-bordered table-striped table-hover" style="width:100%;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>SR.NO</th>
                                        <th>Distributor&nbsp;Information</th>
                                        <th>Last&nbsp;Transaction&nbsp;Date</th>
                                        <th>Last&nbsp;Transaction&nbsp;Type</th>
                                        <th>Live&nbsp;Balance</th>
                                        <th>Current&nbsp;Outstanding</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int i = 1;}
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td>
                                                @if (item.FarmName == null)
                                                {
                                                    @item.Email
                                                }
                                                else
                                                {
                                                    @item.FarmName
                                                }
                                            </td>
                                            <td>@item.date_dlm</td>
                                            <td>@item.bal_type</td>
                                            <td>@item.dealer_postbal</td>
                                            <td>@item.cr</td>
                                        </tr>
                                        i++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

</section>

<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>





<script type="text/javascript">
    $(document).ready(function () {

               $('.input-daterange').datepicker({
                format: "yyyy-mm-dd",
                todayHighlight: true,
                autoclose: true

            });
            var val = '@ViewBag.chk';
            if (val != "post") {
                $("#txt_frm_date").datepicker("setDate", new Date());
                $("#txt_to_date").datepicker("setDate", new Date());
            }


        });
</script>