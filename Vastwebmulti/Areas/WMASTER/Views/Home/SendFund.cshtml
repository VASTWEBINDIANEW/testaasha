<script>
    $(window).load(function () {
        $("#DealerId").change(function () {
            var mid = $('option:selected', $(this)).val();

            if (mid != "Select Dealer ID" && mid != "") {
                $.ajax({
                    type: 'Post',
                    url: "@Url.Action("D_Creditchk", "Home")",
                    data: { MID: mid },
                dataType: 'json',
                cache: false,
                async: false,
                success: function (data) {
                    if (data > 0)
                    {
                        $('#msg').html(data)
                        $("#creditModal").modal('show');
                    }
               
                }
            });
            }
        });

    });
</script>

<script type="text/javascript">
           $(function () {
           $('#submit').on('click', function (e, data) {
               var ddl = document.getElementById("DealerId")
               var x = ddl.options[ddl.selectedIndex].text;
               var x2 = document.getElementById("balance").value;
               var paymode = document.getElementById("ddl_fund_type")
               var pay = paymode.options[paymode.selectedIndex].text;
               if (x == "" || x == "Select Dealer" || x == null) {
                   $("#DealerId").validate({
                       rules: {
                           DealerId: {
                               required: true
                           }
                       }
                   });
                   return false;
                   event.preventDefault;
               }
               if (x2 == "" || x2 == null) {

                   $("#balance").validate({
                       rules: {
                           balance: {
                               required: true
                           }
                       }
                   });
                   return false;
                   event.preventDefault;
               }
               if (pay == "" || pay == null) {


                   return false;
                   event.preventDefault;
               
               }
               else {
                   var text = "Fund Transfer To Dealer ";
                   var email = x;
                   var amount = x2;
                   if (!data) {
                       handleDelete(e, 1, text, email, amount);
                   } else {
                       window.location = $(this).attr('href');
                   }
               }
           });
       });
           function handleDelete(e, stop, text, email, amount) {
           if (stop) {
               e.preventDefault();
               swal({
                   title: "<img src='../../images/rechargepopupgifimg.svg' style='width:150px;height:152px;margin-top:-31px;'><br><p style='color:#bfb6b6;margin-top:-24px;'>Are you sure !</p>",
                   html: true,
                   text: "<p style='font-size:20px;'>" + text + "</p><br><p style='margin-top:-16px;'>" + email + "</p><br><p style='margin-top:-16px;'>&nbsp;Amount :" + amount + "&nbsp;&nbsp;Only.</p>",
                   showCancelButton: true,
                   confirmButtonColor: "#607D8B",
                   confirmButtonText: "Yes, Fund Transfer!",
                   closeOnConfirm: false,
                   showLoaderOnConfirm: true
               },
    function (isConfirm) {
        if (isConfirm) {
            setTimeout(function () {
                $(e.target).trigger('click', {});
            }, 2000);
        }
    });
           }
       };
</script>

