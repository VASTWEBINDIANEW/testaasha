                                                                <th>Description</th>
                                                                <th>HSN/SAC</th>
                                                                <th>Recharge Amount</th>
                                                                <th>Discount</th>
                                                                <th>Net Amount</th>
                                                                <th>Taxable Value</th>

                                                                @if (ViewBag.CloseBal == "ISGST")
