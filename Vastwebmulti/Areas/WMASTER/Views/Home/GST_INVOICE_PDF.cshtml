                                                                <tr style="color:black;">
                                                                    <td>@i</td>
                                                                    <td style="">@Html.DisplayFor(modelItem => item.operator_Name) (E-Top)</td>
                                                                    <td style="">@Html.DisplayFor(modelItem => item.HSN_SAC)</td>
                                                                    <td>@Html.DisplayFor(modelItem => item.Sell)</td>

                                                                    <td style="">@Html.DisplayFor(modelItem => item.APISellAmt)</td>
                                                                    <td style="">@Html.DisplayFor(modelItem => item.NetAmount)</td>
                                                                    <td style="">@Html.DisplayFor(modelItem => item.TaxableValue)</td>

                                                                    @if (ViewBag.CloseBal == "ISGST")
                                                                    {
                                                                        <td style="">@Html.DisplayFor(modelItem => item.IGST)</td>
                                                                    }
                                                                    else
                                                                    {
                                                                        <td style="">@Html.DisplayFor(modelItem => item.CGST)</td>
                                                                        <td style="">@Html.DisplayFor(modelItem => item.SGST)</td>
                                                                    }


                                                                </tr>
