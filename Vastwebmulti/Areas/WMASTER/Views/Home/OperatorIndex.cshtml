                                        <td>@Html.DisplayFor(modelItem => item.OperatorType)</td>
                                        <td>@Html.DisplayFor(modelItem => item.OperatorCode)</td>

                                        <td>@Html.DisplayFor(modelItem => item.BlockTime)</td>
