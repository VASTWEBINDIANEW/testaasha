@model List<Vastwebmulti.Models.Mpos_Report_New_paging_Result>
@{
    Layout = null;
}

@if (Model != null)
{
    foreach (var item in Model)
    {


    <tr>
        <td>
            @if (item.status == "00")
            {
                <img style='height: 20px;width: 18px;margin:5px;max-width: 100%;padding: 0; border-radius:50%; background-color:green' src='../../ashok-images/correct.svg' />
            }
            else
            {
                <img style='height: 20px;width: 18px;margin:5px;max-width: 100%;padding: 0; border-radius:50%; background-color:red' src='../../ashok-images/closes.svg' />
            }
            <i></i>&nbsp;<span>@item.Frm_Name</span>

        </td>

        <td>@item.transType</td>
        <td>@item.cardtype</td>
        <td>@item.cardbrand</td>
        <td>@item.mPOSid</td>
        <td>@item.amount</td>
        <td>@item.Rem_comm</td>
        <td>@item.MdComm</td>
        <td>@item.Dlm_Comm</td>
        <td>@item.totalamount</td>
        <td>@item.BankRRN</td>
        <td>@item.date</td>
        <td>@item.bankterminalID</td>
     
    </tr>
    }
}
