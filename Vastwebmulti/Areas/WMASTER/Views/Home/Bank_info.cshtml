@model IEnumerable<Vastwebmulti.Models.bank_info>
@{
    ViewBag.Title = "Bank";
    Layout = "~/Areas/WMASTER/Views/Shared/_Layout.cshtml";
}

<style>
    .wmaster-bankinfo .col-md-6 table {
    width: 100%;
    float: left;margin:0px !important;
    border: 1px solid #e4e1e1 !important;
}
    .wmaster-bankinfo .col-md-6 table tr th {
    padding: 8px;
    text-align: left !important;
}
    

    @@media screen and (max-width:767px){
        .wmaster-bankinfo .card .body {
    padding-left: 0;
}
        .wmaster-dashboardclass {
    padding-left: 0px !important;
}
        .wmaster-bankinfo .col-md-6 {
    width: 100%;
    float: left;
}
    }
    @@media screen and (max-width:580px){
        .wmaster-bankinfo .col-md-6 table tr th {
    width: auto !important;
}
        .container-fluid.wmaster-bankinfo {
    padding: 0;
}
        .wmaster-bankinfo .col-md-6 {
    overflow: auto;
}
        .wmaster-bankinfo .col-md-6 table tr th {
    white-space: nowrap;
}
    }

</style>

<section class="content">
    <div class="container-fluid wmaster-bankinfo">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card" style="width: 100%; float: left; margin-bottom: 0; ">
                    
                    <div class="wmaster-dashboardclass" style="padding-left: 20px;">
                        <ul>
                            <li class="smli">
                                <a href="@Url.Action("Dashboard","Home")" class="tmw-total-color-one" style="background-image: linear-gradient(to right , @PageData["Globalfirst"], @PageData["GlobalSecond"]);text-decoration:none;">
                                    Dashboard&nbsp;<img src="/ashok-images/rightaeps.svg" alt="right-arrow" style="width: 12px; margin-top: -2px;">
                                </a>
                            </li>

                            <li class="fullbodydycolorbg tmw-total-color-one" style="background-image: linear-gradient(to right , @PageData["Globalfirst"], @PageData["GlobalSecond"]);">
                                All Bank Information
                            </li>
                        </ul>
                    </div>

                </div>
            </div>
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="body" style="padding-top:0;">
                        <div class="row">
                            @foreach (var item in Model)
                            {
                                <div class="col-md-6">
                                    <table border="1" style="margin-top:5px;margin-left:10px; margin-bottom:5px; float:left;border:10px solid #e4e1e1;">
                                        <tr>
                                            <th style="width:220px; height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black; position:initial;border:1px solid #dddddd;background-color:whitesmoke;">
                                                Bank&nbsp;Name
                                            </th>
                                            <th style="width:320px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.banknm)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px;background-color:whitesmoke;   height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                Branch&nbsp;Name
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.branch_nm)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px;background-color:whitesmoke;  height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                IFSC&nbsp;CODE
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.ifsccode)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px;background-color:whitesmoke; height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                Account&nbsp;Number
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.acno)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px; height: 42px;background-color:whitesmoke; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                Account&nbsp;Type
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.actype)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px; height: 42px;background-color:whitesmoke; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black; position:initial;border:1px solid #dddddd;">
                                                Account&nbsp;Holder&nbsp;Name
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.holdername)
                                            </th>
                                        </tr>
                                        <tr>
                                            <th style="width:220px; background-color:whitesmoke; height: 42px; font-size:14px;  font-family:Arial; font-weight:300; text-align:center; color:black;position:initial;border:1px solid #dddddd;">
                                                Branch&nbsp;Address
                                            </th>
                                            <th style="width:160px;  font-size:14px;  font-family:Arial; font-weight:bold; text-align:center; color:#585858;border:1px solid #dddddd;">
                                                @Html.DisplayFor(modelItem => item.address)
                                            </th>
                                        </tr>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>




        </div>
    </div>


</section>




