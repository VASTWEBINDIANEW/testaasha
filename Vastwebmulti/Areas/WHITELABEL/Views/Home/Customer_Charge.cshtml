@model Vastwebmulti.Areas.WHITELABEL.Models.Show_All_CustomerCharge
@{
    ViewBag.Title = "Customer_Charge";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}
<script>
    $(function () {

        var chh = '@ViewData["type"]';
        $('#' + chh+'').show();
    });

    function funedit() {
        var chh1 = '@ViewData["type"]';
       
        $('#' + chh1 + '_show').hide()
        $('#' + chh1 + '_edit').show()
        $('#' + chh1 + '_Save').show()
    }



    </script>

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    <div class="col-md-6">
                        <h2 style="color:black; font-size:16px; padding-left:11px; margin-top:10px;">
                            Show All Customer Charge
                        </h2>
                    </div>
                    <div class="col-md-4">
                   @using (Html.BeginForm("Customer_Charge", "Home", FormMethod.Post, new { id = "CreateForm" }))
                   {
                            <div class="input-group" style="margin-top:3px;">
                                <div class="" style="border:1px solid #dddddd; height:38px;">
                                    @Html.DropDownList("ddltype", new List<SelectListItem>
                                        {
                                               new SelectListItem{Text="Select One",Value="Select"},
                                        new SelectListItem{Text="Prepaid Utility",Value="Prepaid"},
                                        new SelectListItem{Text="Postpaid Utility",Value="Postpaid"},
                                        new SelectListItem{Text="IMPS",Value="IMPS"}
                                        }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "border:1px solid #8e7f7f4d;height:38px;", })
                                </div>
                                <span class="input-group-addon">
                                    <button type="submit" class="btn bg-blue-grey waves-effect" style="margin-top:-6px; height:38px; ">
                                        <i class="material-icons" style="top:4px;">save</i>
                                        <span style="top:-2px;">Submit</span>
                                    </button>
                                </span>
                            </div>
                        }
                    </div>
                    <div class="col-md-2">
                        <center style="margin-right:15px; margin-top:3px;">
                            <button type="submit" class="btn bg-blue-grey waves-effect" onclick="funedit()" style="height:38px;">
                                <i class="material-icons">edit</i>
                                <span style="top:-2px;">EDIT</span>
                            </button>
                        </center>
                    </div>

                </div>
            </div>
        </div>
        
                   <div class="row clearfix" >
                            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-39px;">
                                <div class="card">
                                    <div class="">
                                        <h2 style="color:black; font-size:16px;padding-top:9px; padding-left:22px;">
                                            All Customer Charge
                                        </h2>
                                    </div>
                                    <div class="body">
                                        <div id="Prepaid" class="table-responsive" style="position:inherit; margin-top:-20px; display:none;">
                                        @using (Html.BeginForm("EditCustomerCharge", "Home", FormMethod.Post, new { id = "EditForm" }))
                                        {
                                            <div id="Prepaid_Save" style="padding-bottom: 10px; display:none;">
                                                <input type="submit" value="Save" class="btn btn-primary" style="margin-top:6px;" />
                                            </div>
                                            <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%;">
                                                <thead class="navbar" style="color:white;position:inherit;">
                                                    <tr>
                                                        <th>Operator&nbsp;Name</th>
                                                        <th>Commission</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="Prepaid_show">
                                                    @foreach (var item in Model.Prepaid)
                                                    {
                                                        <tr>
                                                            <td>@Html.DisplayFor(modelItem => item.OperatorName)</td>
                                                            <td>@Html.DisplayFor(modelItem => item.commission)</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                                <tbody id="Prepaid_edit" style="display:none;">
                                                    @{
                                                        int i = 0;
                                                        foreach (var item in Model.Prepaid)
                                                        {
                                                            @Html.HiddenFor(o => o.Prepaid[i].idno)
                                                            @Html.HiddenFor(o => o.Prepaid[i].ddltype)
                                                            @Html.Hidden("ID", "Prepaid")
                                                            <tr>
                                                                <td>@item.OperatorName</td>

                                                                <td>
                                                                @Html.EditorFor(o => o.Prepaid[i].commission)
                                                                @Html.ValidationMessageFor(o => o.Prepaid[i].commission)
                                                                </td>
                                                            </tr>
                                                            i++;
                                                        }
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                        </div>

                                        <div id="Postpaid" class="table-responsive" style="position:inherit; margin-top:-20px; display:none;">
                                            @using (Html.BeginForm("EditCustomerCharge", "Home", FormMethod.Post, new { id = "EditForm" }))
                                            {
                                                <div id="Postpaid_Save" style="padding-bottom: 10px; display:none;">
                                                    <input type="submit" value="Save" class="btn btn-primary" style="margin-top:6px;" />
                                                </div>
                                                <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%;">
                                                    <thead class="navbar" style="color:white;position:inherit;">
                                                        <tr>
                                                            <th>Operator&nbsp;Name</th>
                                                            <th>Range(1-1000)</th>
                                                            <th>Range(1001-2000)</th>
                                                            <th>Range(2001-Above)</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="Postpaid_show">
                                                        @foreach (var item in Model.Postpaid)
                                                        {
                                                            <tr>
                                                                <td>@Html.DisplayFor(modelItem => item.OperatorName)</td>
                                                                <td>@Html.DisplayFor(modelItem => item.commission1)</td>
                                                                <td>@Html.DisplayFor(modelItem => item.commission2)</td>
                                                                <td>@Html.DisplayFor(modelItem => item.commission3)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                    <tbody id="Postpaid_edit" style="display:none;">
                                                        @{
                                                            int i = 0;
                                                            foreach (var item in Model.Postpaid)
                                                            {
                                                                @Html.HiddenFor(o => o.Postpaid[i].idno)
                                                                @Html.HiddenFor(o => o.Postpaid[i].ddltype)
                                                                @Html.Hidden("ID", "Postpaid")
                                                                <tr>
                                                                    <td>@item.OperatorName</td>
                                                                    <td>
                                                                        @Html.EditorFor(o => o.Postpaid[i].commission1)
                                                                        @Html.ValidationMessageFor(o => o.Postpaid[i].commission1)
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(o => o.Postpaid[i].commission2)
                                                                        @Html.ValidationMessageFor(o => o.Postpaid[i].commission2)
                                                                    </td>
                                                                    <td>
                                                                        @Html.EditorFor(o => o.Postpaid[i].commission3)
                                                                        @Html.ValidationMessageFor(o => o.Postpaid[i].commission3)
                                                                    </td>
                                                                </tr>
                                                                i++;
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                                            }
                                        </div>

                                        <div id="IMPS" class="table-responsive" style="position:inherit; margin-top:-20px; display:none;">
                                            @using (Html.BeginForm("EditCustomerCharge", "Home", FormMethod.Post, new { id = "EditForm" }))
                                            {
                                                <div id="IMPS_Save" style="padding-bottom: 10px; display:none;">
                                                    <input type="submit" value="Save" class="btn btn-primary" style="margin-top:6px;" />
                                                </div>
                                                <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%;">
                                                    <thead class="navbar" style="color:white;position:inherit;">
                                                        <tr>
                                                            <th>Operator&nbsp;Name</th>
                                                            <th>Minimum</th>
                                                            <th>Maximum</th>
                                                            <th>Commission</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="IMPS_show">
                                                        @foreach (var item in Model.IMPS)
                                                        {
                                                            <tr>
                                                                <td>@Html.DisplayFor(modelItem => item.OperatorName)</td>
                                                                <td>@Html.DisplayFor(modelItem => item.minimum)</td>
                                                                <td>@Html.DisplayFor(modelItem => item.maximum)</td>
                                                                <td>@Html.DisplayFor(modelItem => item.commission)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                    <tbody id="IMPS_edit" style="display:none;">
                                                        @{
                                                            int i = 0;
                                                            foreach (var item in Model.IMPS)
                                                            {
                                                                @Html.HiddenFor(o => o.IMPS[i].idno)
                                                                @Html.HiddenFor(o => o.IMPS[i].ddltype)
                                                                @Html.Hidden("ID", "IMPS")
                                                                <tr>
                                                                    <td>@item.OperatorName</td>
                                                                    <td>@item.minimum</td>
                                                                    <td>@item.maximum</td>
                                                                    <td>
                                                                        @Html.EditorFor(o => o.IMPS[i].commission)
                                                                        @Html.ValidationMessageFor(o => o.IMPS[i].commission)
                                                                    </td>
                                                                </tr>
                                                                i++;
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
               </div>
</section>

<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
