                                    <label>Select Distributor </label>
                                    <div>
                                        <div class="">
                                            @Html.DropDownList("dealerid", new SelectList(ViewBag.dealerid, "Value", "Text"), "Select  Dealer Id", new { @class = "form-control", data_live_search = "true", @required = "required" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-12 col-sm-12 col-xs-12  ">
                                    <div class="distributor-detail" style="display:none;">
                                        <p>Distributor Name&nbsp;-&nbsp;&nbsp; <span id="DISNAME"></span></p>
                                        <p>Firm Name&nbsp;-&nbsp;&nbsp; <span id="DISfrmname"></span></p>
                                        <p>Mobile No.&nbsp;-&nbsp;&nbsp; <span id="DISmobile"></span></p>
