                        <li class="tab-link changetabeuser" data-tab="tab-2" data-href="@Url.Action("ChangeTabtype","Home",new { Utype="Retailer"})"><a data-toggle="tab" href=".menu1" aria-expanded="false">Retailer Switch</a></li>

                    </ul>
                    <div class="width100 home float-left tab-pane fade active in">
