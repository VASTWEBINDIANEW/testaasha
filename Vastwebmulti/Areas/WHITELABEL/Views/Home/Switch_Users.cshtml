@model Vastwebmulti.Areas.WHITELABEL.Models.vmSwitchWhitelabelUserModel
@{
    ViewBag.Title = "Switch_Users";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}
<style>
    .for-search {
        position: absolute;
        right: 15px; 
    }

        .for-search input {
            width: 250px;
            border: 1px solid #dbdbdb;
            padding: 3px 10px;
        }
    
    .select2-container--default .select2-selection--single {
        border-radius: 0px !important;
        height: 32px !important;
    }
    .switch-user-tab .switch-user-tab-left ul li.active::after, .switch-user-tab .switch-user-tab-left ul li::after, .switch-user-tab-right .nav-tabs li::after {
        content: '';
        width: 25px;
        float: left;
        top: 0;
        left: 0;
        position: absolute;
        height: 70%;
        border: 2px solid #fff;
        margin: 5px;
    }

    .switch-user-tab .switch-user-tab-left ul li.active::before, .tt-right-table ul.tabs2 li.current2::before {
        content: "";
        border-left: 2px solid #fff;
        border-bottom: 2px solid #fff;
        height: 28%;
        width: 17px;
        position: absolute;
        left: 9px;
        transform: rotate(-45deg);
        top: 9px;
    }
    .switch-user-tab .switch-user-tab-left ul li.active {
        background: @PageData["Globalfirst"] !important;
    }
    .switch-user-tab .switch-user-tab-left ul li, .switch-user-tab-right .nav-tabs li {
        background: @PageData["GlobalSecond"] !important;
    }
    .distributor-detail, .distributor-details {
        background: #f5f5f5;
        padding: 10px;
        margin-top: 10px;
        border: 1px solid #bbb;
    }
    .distributor-detail p, .distributor-details p{
        border-bottom: 1px dashed #bbb;
        margin: 0;
        padding: 5px 0;
    }
    .distributor-detail p:last-child, .distributor-details p:last-child {
    border: 0;
    }
    .fund-transfer-form {
        height: 100% !important;
        border: 1px solid #ddd;
        background: #f5f5f5 !important;
    }
    @*.distributor-detail .fund-transfer-form button, .distributor-details .fund-transfer-form button{background: @PageData["Globalfirst"] !important;}
    .distributor-detail button:first-child, .distributor-details button:first-child{background: @PageData["Globalfirst"] !important;}*@
    @@media only screen and (max-width:520px) {
        .web-white-filter {
            position: static !important;
        }

        .for-search input {
            width: 100%;
        }

        .for-search {
            position: static;
        }

        .switch-user-tab-left {
            margin-top: 15px;
        }

            .switch-user-tab-left .fund-transfer-form {
                padding-bottom: 20px;
                height: auto;
            }
        .switch-user-tab .switch-user-tab-left ul li, .switch-user-tab-right .nav-tabs li {
            width: 100%;
            margin-bottom: 10px;
        }
    }
</style>
<section class="content">
