                                        <p>Firm Name&nbsp;-&nbsp;&nbsp; <span id="RETfrmname"></span></p>
                                        <p>Mobile No.&nbsp;-&nbsp;&nbsp; <span id="RETmobile"></span></p>
                                        <p>Email&nbsp;-&nbsp;&nbsp; <span id="RETEMAIL"></span></p>
                                        <p>Address&nbsp;-&nbsp;&nbsp; <span id="RETADDRESS"></span></p>
                                        <p>Current Distributor&nbsp;-&nbsp;&nbsp; <span id="RETCRNTMD"> </span></p>
                                    </div>
                                </div>



                                <div class="col-md-12 col-sm-12 col-xs-12  ">
                                    <label>Select New Distributor </label>
                                    <div>
                                        <div class="">
                                            @Html.DropDownList("dealerdetailsid", new SelectList(ViewBag.dealerid, "Value", "Text"), "Select  Dealer Id", new { @class = "form-control", data_live_search = "true", @required = "required" })
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-12 col-sm-12 col-xs-12">
                                    <div>

                                        <button id="btnshowdetails" class="fullbodydycolorbg" style="color:#fff;float:right;padding: 6px 20px;border: 1px solid #bbb;margin-top: 10px;line-height: 22px;">
                                            Move User
                                        </button>
                                        <button type="reset" style="color:#000;float:right;padding: 6px 20px;border: 1px solid #bbb;margin-top: 10px;line-height: 22px;margin-right:10px;">Cancel</button>
                                    </div>
                                </div>
                            </form>
                        </div>




                    </div>
                </div>
                <div class="col-md-8 switch-user-tab-right">


                    <div id="home" class="width100 home float-left tab-pane fade active in">
                        <div class="switch-history-table" id="dlmd">
                            @Html.Partial("_SwitchUsertable", Model)
                        </div>
                        <div id="loadingdiv" style="text-align:center;display:none;margin-bottom:20px;">

                            <img src="~/img/ajax-loader.gif" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<link href="~/select2/dist/css/select2.css" rel="stylesheet" />
