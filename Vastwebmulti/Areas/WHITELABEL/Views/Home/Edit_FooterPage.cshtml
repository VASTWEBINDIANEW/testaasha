@model Vastwebmulti.Models.tblFooterPageContent
@{
    ViewBag.Title = "Edit_FooterPage";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}

<script src="~/Ckeditor/ckeditor.js"></script>
<script src="~/Ckeditor/adapters/jquery.js"></script>
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                @using (Html.BeginForm("Edit_FooterPage", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
                {
                    <div class="card">
                        <div class="header" style="padding:10px;">
                            <h2>
                                <span style="font-size:21px;"></span> Update Footer Page Content
                            </h2>
                        </div>
                        <div class="row">
                            <div class="body">
                                <div class="col-md-12">
                                    @Html.HiddenFor(model => model.Id)
                                    <label for="setbox">Enter Content</label>
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextAreaFor(model => model.FooterPageContent, new { @class = "ckeditor" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <button type="submit" class="btn bg-blue-grey">Update</button>
                                    <a href="@Url.Action("Footer_Content","Home")" class="btn bg-blue-grey">Back</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</section>
