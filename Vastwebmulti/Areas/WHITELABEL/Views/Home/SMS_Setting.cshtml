<script>
    function ToastrMessage() {
        toastr.options = {
            "closeButton": false,
            "debug": false,
            "positionClass": "toast-top-right1",
            "newestOnTop": false,
            "progressBar": true,
            "preventDuplicates": true,
            "onclick": null,
            "showDuration": "100",
            "hideDuration": "1000",
            "timeOut": "5000",
            "extendedTimeOut": "1000",
            "showEasing": "swing",
            "hideEasing": "linear",
            "showMethod": "show",
            "hideMethod": "hide"
        };
        //toastr.info('MY MESSAGE!');
    }
</script>

<script>
        $(document).ready(function () {
            $.ajax({
                type: "GET",
                url: '@Url.Action("Check_UnchekSMS_Setting", "Home")',
                cache: false,
                dataType: 'html',
                async: true,
                success: function (data) {
                    var obj = JSON.parse(data);
                    for (var item in obj) {
                        var sts = obj[item].Status;
                        var name = obj[item].ServiceName;
                        if (sts == "Y") {
                            $("#" + name + "").prop("checked", true);
                        }
                    }
                }
            });


        });
</script>

<script type="text/javascript">
    function selectAll() {
        var items = document.getElementsByName('acs');
        for (var i = 0; i < items.length; i++) {
            if (items[i].type == 'checkbox')
                items[i].checked = true;
        }
    }
    function UnSelectAll() {
        var items = document.getElementsByName('acs');
        for (var i = 0; i < items.length; i++) {
            if (items[i].type == 'checkbox')
                items[i].checked = false;
        }
    }
</script>
<script type="text/javascript">
    $(document).ready(function () {
        $("#SaveAll").click(function () {
                var optCode = []
                $(".for-message input:checkbox(:checked)").each(function () {
                    if ($(this).prop('checked') == true) {
                        optCode.push($(this).val() + ",Y");
                    }
                    if ($(this).prop('checked') == false) {
                        optCode.push($(this).val() + ",N");
                    }
                });
            var MsgType = "Message's";
            document.getElementById("loadermoney").style.display = "block";

            $.ajax({
                         type: "POST",
                         url: '@Url.Action("SMSSettingSave", "Home")',
                         data: { 'ch': optCode, MsgType: MsgType },
                         cache: false,
                         dataType: 'json',
                         async: true,
                         success: function (data) {
                             var pp = data.status;
                             var mm = data.Message;

                             if (pp == "Success") {
                                 document.getElementById("loadermoney").style.display = "none";


                                 $.ajax({
                                     type: "GET",
                                     url: '@Url.Action("Check_UnchekSMS_Setting", "Home")',
                                     cache: false,
                                     dataType: 'html',
                                     async: true,
                                     success: function (data) {
                                         var obj = JSON.parse(data);
                                         for (var item in obj) {
                                             var sts = obj[item].Status;
                                             var name = obj[item].ServiceName;
                                             if (sts == "Y") {
                                                 $("#" + name + "").prop("checked", true);
                                             }
                                         }
                                     }
                                 });

                                 ToastrMessage();
                                 toastr.success(mm);
                             }

                             else {
                                 ToastrMessage();
                                 toastr.error(mm);
                             }

                         }
                     });
            return true;

             $(".sweet-alert").css('background', '@PageData["globalCol"]');
        });

        });
</script>

