<script type="text/javascript">
    $(document).ready(function () {
        $("#SaveAll").click(function () {
            //if ($('#bysim2').is(':checked')) {
                //alert("it's checked Email");
                var optCode = []
                $(".for-mail input:checkbox(:checked)").each(function () {
                    if ($(this).prop('checked') == true) {
                        optCode.push($(this).val() + ",Y");
                    }
                    if ($(this).prop('checked') == false) {
                        optCode.push($(this).val() + ",N");
                    }
                });
                var MsgType = "Email's";
            //}

            document.getElementById("loadermoney").style.display = "block";

            $.ajax({
                         type: "POST",
                         url: '@Url.Action("SMSSettingSave", "Home")',
                         data: { 'ch': optCode, MsgType: MsgType },
                         cache: false,
                         dataType: 'json',
                         async: true,
                         success: function (data) {
                             var pp = data.status;
                             var mm = data.Message;

                             if (pp == "Success") {
                                 document.getElementById("loadermoney").style.display = "none";

                                 $.ajax({
                                     type: "GET",
                                     url: '@Url.Action("Check_UnchekSMS_Setting", "Home")',
                                     cache: false,
                                     dataType: 'html',
                                     async: true,
                                     success: function (data) {
                                         var obj = JSON.parse(data);
                                         for (var item in obj) {
                                             var sts = obj[item].Status;
                                             var name = obj[item].ServiceName;
                                             if (sts == "Y") {
                                                 $("#" + name + "").prop("checked", true);
                                             }
                                         }
                                     }
                                 });

                                 ToastrMessage();
                                 toastr.success(mm);
                             }

                             else {
                                 ToastrMessage();
                                 toastr.error(mm);
                             }

                         }
                     });
            return true;

             $(".sweet-alert").css('background', '@PageData["globalCol"]');
        });

        });
</script>
<script>
        $(document).ready(function () {
            $.ajax({
                type: "GET",
                url: '@Url.Action("Check_UnchekEMAIL_Setting", "Home")',
                cache: false,
                dataType: 'html',
                async: true,
                success: function (data) {
                    var obj = JSON.parse(data);
                    for (var item in obj) {
                        var sts = obj[item].Status;
                        var name = obj[item].ServiceName;
                        if (sts == "Y") {
                            $("#" + name + "").prop("checked", true);
                        }
                    }
                }
            });
        });
</script>
<script type="text/javascript">
    function GetMailList() {
            $.ajax({
            url: '@Url.Action("GetEmailbyId", "Home")',
            type: 'POST',
                data: { idno: 0 },
                success: function (data) {

                    var i = 0;
                    var mdtblHtml = "";
                    $.each(data, function (a, b) {

                        var i = b.idno;
                        var idno = "subTbl";
                        idno = idno + i;

                        var btnOnOff = "";
                        if (b.Enablessl == "true") {
                            btnOnOff = "<div class='onoffswitch' style='width:23px;float:left;'><span class='costom-on' style='height:22px;' onclick=sslOnOff('" + b.idno + "')></span></div>";
                        }
                        else {
                            btnOnOff = "<div class='onoffswitch' style='width:23px;float:left;'><span class='custom-off' style='height:22px;' onclick=sslOnOff('" + b.idno + "')></span></div>";
                        }

                        mdtblHtml += "<tr><td><p><span style='background: #bbb; font-size: 10px; padding: 0px 5px; margin-right: 2px;'>" + b.idno + "</span>" + b.Smpthost + "</p><p>" + b.Email + "</p></td>";
                        mdtblHtml += "<td>********</td>";
                        mdtblHtml += "<td>" + btnOnOff + "<button style='height: 24px; float: left; padding: 0px 3px; background: #f0f0f0; border: 1px solid #bfbebe; margin - left: 2px;' onclick=editBussMail('" + b.idno + "')>Edit</button><button style='height: 24px; float: left; padding: 0px 3px; background: #f0f0f0; border: 1px solid #bfbebe; margin - left: 2px;' onclick=delBussMail('" + b.idno + "')>Del</button></td>";
                        "</td>";
                        "</tr>";
                        i++;
                    });

                    $('#maillist > tbody').html(mdtblHtml);
            }
        });
    }


    function BussMail() {
            $.ajax({
            url: '@Url.Action("Email_Security", "Home")',
            type: 'POST',
            data: { SMTPHost: $('#SMTPHost').val(), EmailID: $('#EmailID').val(), Paswrd: $('#Paswrd').val(), Port: $('#Port').val() },
                success: function (data) {
                    if (data.status == "Success") {

                        GetMailList();
                        ToastrMessage();
                        toastr.success(data.Message);
                    }
                    else {
                        ToastrMessage();
                        toastr.error(data.Message);
                    }

                    $('#SMTPHost').val('');
                    $('#EmailID').val('');
                    $('#Paswrd').val('');
                    $('#Port').val('');
            }
        });
    }

    function delBussMail(idno) {
            $.ajax({

            url: '@Url.Action("DeleteEmail", "Home")',
            type: 'POST',
            data: { idno: idno },
                success: function (data) {
                    if (data.status == "Success") {

                        GetMailList();
                        ToastrMessage();
                        toastr.success(data.Message);
                    }
                    else {
                        ToastrMessage();
                        toastr.error(data.Message);
                    }
            }
        });
    }

    function sslOnOff(idno) {
            $.ajax({

            url: '@Url.Action("Email_enablessl", "Home")',
            type: 'POST',
            data: { id: idno },
                success: function (data) {
                    if (data.status == "Success") {
                        if (data.Message == "SSL True") {
                            GetMailList();
                            ToastrMessage();
                            toastr.success(data.Message);
                        }
                        else {
                            if (data.Message == "SSL False") {
                                GetMailList();
                                ToastrMessage();
                                toastr.error(data.Message);
                            }
                        }
                    }
                    else {
                        ToastrMessage();
                        toastr.error(data.Message);
                    }
            }
        });
    }

    function editBussMail(idno) {
            $.ajax({
            url: '@Url.Action("GetEmailbyId", "Home")',
            type: 'POST',
                data: { idno: idno },
                success: function (data) {
                    $('#EditBtnidno').val(data.idno);
                    $('#SMTPHost').val(data.Smpthost);
                    $('#EmailID').val(data.Email);
                    $('#Paswrd').val(data.Password);
                    $('#Port').val(data.Port);

                    $('#AddMBtn').css('display', 'none');
                    $('#EditBtn').css('display', 'block');
            }
        });
    }

    function editSaveMail() {
            $.ajax({

            url: '@Url.Action("Edit_Email_Security", "Home")',
            type: 'POST',
                data: { idno: $('#EditBtnidno').val(), SMTPHost: $('#SMTPHost').val(), EmailID: $('#EmailID').val(), Paswrd: $('#Paswrd').val(), Port: $('#Port').val() },
                success: function (data) {

                    if (data.status == "Success") {

                        GetMailList();
                        ToastrMessage();
                        toastr.success(data.Message);
                    }
                    else {
                        ToastrMessage();
                        toastr.error(data.Message);
                    }

                    $('#EditBtnidno').val('');
                    $('#SMTPHost').val('');
                    $('#EmailID').val('');
                    $('#Paswrd').val('');
                    $('#Port').val('');

                    $('#AddMBtn').css('display', 'block');
                    $('#EditBtn').css('display', 'none');
            }
        });
    }
</script>

<script>
    function onlyNumberKey(evt) {

        // Only ASCII charactar in that range allowed
        var ASCIICode = (evt.which) ? evt.which : evt.keyCode
        if (ASCIICode > 31 && (ASCIICode < 48 || ASCIICode > 57))
            return false;
        return true;
    }
</script>
