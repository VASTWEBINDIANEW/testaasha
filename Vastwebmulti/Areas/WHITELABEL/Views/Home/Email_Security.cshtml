@model Vastwebmulti.Areas.WHITELABEL.Models.Email_ViewModel
@{
    ViewBag.Title = "Email_Security";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}
<style> 
    .loadermoney {
        position: fixed;
        left: 0px;
        top: 0px;
        width: 100%;
        height: 100%;
        z-index: 199999;
        /*background: url('../../images/smsload.gif') 50% 50% no-repeat rgba(249, 249, 249, 0.9);*/
        background: url('../../img/loder.gif') 50% 50% no-repeat rgba(249, 249, 249, 0.9);
    }

    .toast-top-right1 {
        top: 65px;
        left: 81%;
    }

    .tmw-email-securty .table-and-remail .dropp::after {
        top: 8px;
    }

    table#divId.dataTable tbody tr {
        background-color: var(--second-bg-color);
    }

    .tmw-email-securty .mari-table tr {
        float: none;
        width: auto;
        box-sizing: border-box;
        margin-top: 0px;
    }

        .tmw-email-securty .mari-table tr th, .tmw-email-securty .mari-table tr td {
            float: none;
            width: auto;
            box-sizing: border-box;
        }

            .tmw-email-securty .mari-table tr td p {
                margin: 0px;
            }

        .tmw-email-securty .mari-table tr th {
            padding: 5px 3px !important;
        }

    .tt-right-table .tab-content2 {
        display: none;
    }

        .tt-right-table .tab-content2.current2 {
            display: block;
        }

    .tt-right-table ul.tabs2 li {
        color: #222;
        display: inline-block;
        padding: 4px 15px;
        cursor: pointer;
        float: left;
        width: 50%;
        border-right: 3px solid #fff;
    }

        .tt-right-table ul.tabs2 li.current2 {
            border-bottom: 4px solid #000;
        }

    .tt-right-table ul.tabs2 {
        background: var(--nav-tab-bg);
        width: 100%;
        float: left;
        margin: 0px;
        text-align: center;
    }

    .tmw-email-securty .header-top {
        background: #f5f5f5;
    }

    ul.smssetting-top {
        padding: 5px;
        background: #f5f5f5;
    }

        ul.smssetting-top li {
            width: 25%;
            float: right;
            padding: 0px 10px;
        }

            ul.smssetting-top li button {
                border: 1px solid #bbb;
                height: 36px !important;
                background: transparent;
                width: 100%;
            }

        ul.smssetting-top #SaveAll img {
            width: 15px;
            margin-top: -3px;
        }

        ul.smssetting-top #SaveAll span {
            color: #fff;
        }

        ul.smssetting-top li button i {
            top: 2px !important;
        }

    .for-mail {
        width: 100%;
        float: left;
        height: 72vh;
        background: var(--second-bg-color);
        overflow: scroll;
        overflow-x: hidden;
        padding: 0px 10px;
    }

        .for-mail .card {
            background: transparent;
        }

    .tt-right-table [type="checkbox"].filled-in:checked.chk-col-red + label::after {
        border: 2px solid var(--main-bg-lcolor);
        background-color: var(--main-bg-lcolor);
    }

    ul.smssetting-top li button {
        border: 1px solid #bbb;
        height: 32px !important;
        padding: 0;
    }

        ul.smssetting-top li button span {
            top: -1px !important;
        }

    ul.smssetting-top li {
        padding-left: 0;
        margin-right: 0 !important;
    }

    .tt-right-table [type="checkbox"].filled-in:checked + label::before {
        top: -1px;
        left: 0px;
    }

    .tt-right-table [type="checkbox"].filled-in:checked + label::after {
        top: 0;
        width: 18px;
        height: 18px;
    }

    .tt-right-table [type="checkbox"].filled-in:not(:checked) + label::after {
        height: 18px;
        width: 18px;
    }

    .tmw-email-securty .left-table tr td {
        border: 0px !important;
        background: transparent;
        padding: 0px !important;
    }

        .tmw-email-securty .left-table tr td .form-control {
            height: 32px;
        }
    .card .body .col-xs-12, .card .body .col-sm-12, .card .body .col-md-12, .card .body .col-lg-12 {
        margin-bottom: 0;
    }
         
    .tmw-email-securty .left-table .for-table-one table tr td {
        padding: 5px !important;
    }
    .tmw-email-securty .header-top.fi span {
        float: none;
    }
    .tmw-email-securty .header-top.fi ul li .active::after, .tt-right-table ul.tabs2 li.current2::after, .tmw-email-securty .header-top.fi ul li::after, .tt-right-table ul.tabs2 li::after {
        content: '';
        width: 25px;
        float: left;
        top: 0;
        left: 0;
        position: absolute;
        height: 70%;
        border: 2px solid #fff;
        margin: 5px;
    }
    .tmw-email-securty .header-top.fi ul li .active::before, .tt-right-table ul.tabs2 li.current2::before {
        content: "";
        border-left: 2px solid #fff;
        border-bottom: 2px solid #fff;
        height: 28%;
        width: 17px;
        position: absolute;
        left: 9px;
        transform: rotate(-45deg);
        top: 9px;
    }
    .tmw-email-securty .header-top.fi ul li .active, .tt-right-table ul.tabs2 li.current2 {
        background: @PageData["Globalfirst"] !important;
        
    }
    .tmw-email-securty .header-top.fi ul li, .tt-right-table ul.tabs2 li {
        background: @PageData["GlobalSecond"] !important;
        border: 0px !important;
        color: #fff !important;
        height: 36px;
        position: relative !important;
    }
    .tt-right-table ul.tabs2 li {
        padding: 7px;
    }
    .tt-right-table [type="checkbox"].filled-in:checked.chk-col-red + label::after{background: @PageData["Globalfirst"] !important;}
    .onoffswitch {
        margin-top: 0;
    }
    @@media only screen and (max-width:520px) {
        .tmw-email-securty .header-top.fi ul li, .tt-right-table ul.tabs2 li {
            width: 100%;
            margin-bottom: 10px;
        }
    }
</style>
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.1/css/toastr.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.1/js/toastr.js"></script>

<div id="loadermoney" class="loadermoney" style="display:none;"></div>
<section class="content tmw-email-securty">
    <div class="container-fluid">
        <div class="bread-same-all-page">
            <ul>
                <li class="smli">
                    <a href="@Url.Action("Dashboard", "Home")" class="fullbodydycolorbg tmw-total-color-one">
                        Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                    </a>
                </li>
                <li class="fullbodydycolorbg tmw-total-color-one">
                    <a href="@Url.Action("Dashboard", "Home")#setting" class="fullbodydycolorbg tmw-total-color-one">
                        Basic&nbsp;Setting
                    </a>&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                </li>
                <li class="fullbodydycolorbg tmw-total-color-one">
                    Email Setting
                </li>
            </ul>

        </div>

        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="row clearfix">

                        <div class="col-md-4  col-xs-12 left-table">
                            <div class="body" style="height: 640px;background:var(--second-bg-color);overflow:auto;">
                                <div class="">
                                    <div class="header-top fi ">
                                        <ul>
                                            <li>
                                                <button id="top-mail-setting" class="active">
                                                    <span>
                                                        <i class="fa fa-cog" aria-hidden="true"></i>
                                                    </span><span>Email Setting</span>
                                                </button>
                                            </li>
                                            <li>
                                                <button id="top-mail">
                                                    <span>
                                                        <i class="fa fa-paper-plane" aria-hidden="true"></i>
                                                    </span>
                                                    <span>Bulk Email</span>
                                                </button>
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="table-and-model" style="margin-bottom:5px;">
                                        <fieldset style="border:1px solid #333;margin: 0px 5px;margin-top:10px;">
                                            <legend style="margin:0px; padding: 0px 10px;font-size: 16px;width: auto;margin-left: 20px;">Add Sender Email</legend>
                                            <table id="divId" class="table table-bordered table-hover dataTable js-exportable email-security-left">

                                                <tbody>
                                                    <tr style="margin-top:4px;">
                                                        <th style="margin:0px;">SMTP&nbsp;Host</th>
                                                        <td><input type="text" id="SMTPHost" class="form-control" placeholder="Enter SMTP Host" required autocomplete="off" /></td>
                                                    </tr>

                                                    <tr>
                                                        <th style="margin:0px;">Email&nbsp;ID</th>
                                                        <td><input type="email" id="EmailID" class="form-control" placeholder="Enter Business Email Id" required autocomplete="off" /></td>
                                                    </tr>

                                                    <tr>
                                                        <th style="margin:0px;">Password</th>
                                                        <td><input type="password" id="Paswrd" class="form-control" placeholder="Enter Mail Password" required autocomplete="off" /></td>
                                                    </tr>

                                                    <tr>
                                                        <th style="margin:0px;">Mail Server Port</th>
                                                        <td><input type="text" id="Port" class="form-control" placeholder="Enter Mail Server Port" required autocomplete="off" onkeypress="return onlyNumberKey(event)" maxlength="4" /></td>
                                                    </tr>

                                                </tbody>
                                            </table>
                                            <div id="AddMBtn" style="float:right; padding:5px 14px 5px 0px">
                                                <button type="button" onclick="BussMail()" class="btn waves-effect bt btnssl special-iii he" data-loading-text="<i class='fa fa-spinner fa-spin'></i>">
                                                    <span>Save Change</span>
                                                </button>
                                            </div>
                                            <div id="EditBtn" style="float:right; padding:5px 14px 5px 0px; display:none;">
                                                <input type="hidden" id="EditBtnidno" />
                                                <button type="button" onclick="editSaveMail()" class="btn waves-effect bt btnssl special-iii he" data-loading-text="<i class='fa fa-spinner fa-spin'></i>">
                                                    <span>Update Changes</span>
                                                </button>
                                            </div>

                                        </fieldset>
                                        <div class="modals" id="defaultModal" tabindex="-1" role="dialog">
                                            <div class="modal-dialogs" role="document">
                                                <div class="modal-contents email-security-left">
                                                    @using (Ajax.BeginForm("Edit_Email_Security", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "SuccessRequest" }))
                                                    {

                                                        <div class="modal-body">
                                                            <input type="hidden" id="txtidno" name="txtidno" />
                                                            <div class="row clearfix">
                                                                <div class="col-md-12 col-sm-4 col-xs-12">
                                                                    <label for="email_address_2">Sender Email ID</label>
                                                                </div>
                                                                <div class="col-md-12 col-sm-8 col-xs-12">
                                                                    <div class="form-group">
                                                                        <div class="">
                                                                            <input type="email" id="txtemail" name="txtemail" class="form-control" required="" placeholder="Enter Valid Email-ID" />
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="row clearfix">
                                                                <div class="col-md-12 col-sm-4 col-xs-12">
                                                                    <label for="email_address_2">Password</label>
                                                                </div>
                                                                <div class="col-md-12 col-sm-8 col-xs-12">
                                                                    <div class="form-group">
                                                                        <div class="">
                                                                            @Html.TextBox("txtpass", "", new { @class = "form-control", placeholder = "Enter Password.", required = "required" })
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="row clearfix">
                                                                <div class="col-md-12 col-sm-4 col-xs-12">
                                                                    <label for="email_address_2">SMTP Host</label>
                                                                </div>
                                                                <div class="col-md-12 col-sm-8 col-xs-12">
                                                                    <div class="form-group">
                                                                        <div class="">
                                                                            @Html.TextBox("txtsmpthost", "", new { @class = "form-control", placeholder = "Enter Smpt Host Name.", required = "required" })
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="row clearfix">
                                                                <div class="col-md-12 col-sm-4 col-xs-12">
                                                                    <label for="email_address_2">Mail Server Port</label>
                                                                </div>
                                                                <div class="col-md-12 col-sm-8 col-xs-12">
                                                                    <div class="form-group">
                                                                        <div class="">
                                                                            @Html.TextBox("txtport", "", new { @class = "form-control", placeholder = "Enter Port Number.", required = "required" })
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" id="MyClose" class="btn waves-effect bt" data-dismiss="modal" style="float:left;">
                                                                    <span>Back</span>
                                                                </button>
                                                                <button type="submit" class="btn waves-effect bt btnssl special-iii he" data-loading-text="<i class='fa fa-spinner fa-spin'></i>">
                                                                    <span>Save Change</span>
                                                                </button>
                                                            </div>
                                                            <div>

                                                            </div>

                                                        </div>
                                                    }

                                                </div>
                                            </div>
                                        </div>
                                    </div><!--.table-and-model-->
                                    <div class="table-and-remail">

                                        <div class="bodyremail email-security-left">
                                            @using (Ajax.BeginForm("SendEmail", "Home", new AjaxOptions { OnSuccess = "OnSuccess", OnFailure = "OnFailure" }))
                                            {
                                                <div class="row">

                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <label for="email_address_2">Select Users</label>
                                                    </div>
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <div class="dropp">
                                                                @Html.DropDownList("Userform1", new List<SelectListItem> {
                                                                new SelectListItem { Text = "Master Distributor", Value= "Master" } ,
                                                                new SelectListItem { Text = "Distributor", Value= "Dealer" } ,
                                                                new SelectListItem { Text = "Retailer", Value= "Retailer" },
                                                              }, "Select User", new { @class = "form-control" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row" id="SelectID">
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <label for="email_address_2">User Email ID</label>
                                                    </div>
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <div class="">
                                                                @Html.TextBox("txtEmail", "", new { onkeyup = "apna(this)", @class = "form-control dienb" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <label for="email_address_2">Subject</label>
                                                    </div>
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <div class="">
                                                                @Html.TextBox("txtSubject", "", new { onkeyup = "apna(this)", @class = "form-control" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <label for="email_address_2">Message Description</label>
                                                    </div>
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <div class="">
                                                                @Html.TextArea("txtMsgBody", "", new { onkeyup = "apna(this)", maxlength = 160, @class = "form-control", @placeholder = "Enter Message Here" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div><label>@ViewData["msgdlm"] </label> </div>
                                                <div class="form-group remail-footer">

                                                    <button id="btn" type="reset" class="btn  waves-effect bt special-iii h2">Reset</button>
                                                    <button type="submit" class="btn  waves-effect bt btnssl special-iii h1 fullbodydycolorbg" id="start_button" style="color:#fff;margin-left:5px;" onclick="verify()" data-loading-text="<i class='fa fa-spinner fa-spin'></i>" disabled>Send Email</button>
                                                    
                                                </div>
                                            }
                                        </div>

                                    </div><!--.table-and-remail-->
                                </div><!--.table-responsive-->
                                <div class="bodys">
                                    <p>
                                        <b style="color:red; font-size:14px;">
                                            <i class="fa fa-exclamation-triangle fullbodydycolorbg" style="-webkit-background-clip: text !important;-moz-background-clip: text !important;-webkit-text-fill-color: transparent;" aria-hidden="true"></i>
                                        </b> When Send the Mail with Your Gmail Account Then SSL TRUE is <b style="color:green;background:#fff;">"ON"</b> And Send the Mail with Your Mail Account Then SSL FALSE is <b style="color:red;background:#fff;">"OFF"</b>
                                    </p>
                                </div>
                                <div class="table-responsive for-table-one" style="padding:0 5px;">
                                    <table class="table table-hover table-striped table-bordered mari-table" id="maillist">
                                        <thead>
                                            <tr>
                                                <th>SMTP/Email</th>

                                                <th>Password</th>
                                                <th><img src="~/AdminDesign/images/ssl.svg" style="width:15px;" />&nbsp;Action</th>

                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{ var EI = 1;}
                                            @if (Model.priorityEmail.Count() > 0)
                                            {
                                                foreach (var item in Model.priorityEmail)
                                                {
                                                    <tr>
                                                        <td>
                                                            <p><span style="background: #bbb;font-size: 10px;padding: 0px 5px;margin-right: 2px;">@EI</span>@item.Smpthost</p>
                                                            <p>@item.Email</p>
                                                        </td>

                                                        <td>********</td>
                                                        <td>
                                                            @if (item.Enablessl == "true")
                                                            {
                                                                <div class="onoffswitch" style="width:23px;float:left;">
                                                                    <span class="costom-on" style="height:22px;" onclick="sslOnOff(@item.idno)"></span>

                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <div class="onoffswitch" style="width:23px;float:left;">
                                                                    <span class="custom-off" style="height:22px;" onclick="sslOnOff(@item.idno)"></span>

                                                                </div>
                                                            }
                                                            <button style="height: 24px;float: left;padding: 0px 3px;background: #f0f0f0;border: 1px solid #bfbebe;margin-left: 2px;" onclick="editBussMail(@item.idno)">Edit</button><button style="height: 24px;float: left;padding: 0px 3px;background: #f0f0f0;border: 1px solid #bfbebe;margin-left: 2px;" onclick="delBussMail(@item.idno)">Del</button>
                                                        </td>

                                                    </tr>
                                                    EI++;
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-8  col-xs-12">
                            <div class="tt-right-table">
                                <ul class="tabs2">
                                    <li class="tab-link current2" data-tab="tab-5">
                                        Sending Email History
                                    </li>
                                    <li class="tab-link" data-tab="tab-6" style="border-right:0px;">
                                        Manage&nbsp;Email&nbsp;Outbox
                                    </li>
                                </ul>
                                <div class="row clearfix height-margin">
                                    <div id="tab-5" class="tab-content2 current2">
                                        <div class="header-top global_class">

                                            <div class="header-top-right special-iii">

                                                <ul>

                                                    <li class="form-group">
                                                        <div class="input-daterange input-group" style="position:relative;">
                                                            <div class="custom-date-icon">
                                                                <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                                            </div>
                                                            @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #bbb;border-left: 0px; background:#fff;", autocomplete = "off" })

                                                        </div>
                                                    </li>
                                                    <li>
                                                        <button type="submit" id="SearchEmailHistory" style="background:#fff;" class="btn waves-effect btnssl2233" data-loading-text="<i class='fa fa-spinner fa-spin'></i>">
                                                            <i class="fa fa-search" style="font-size:16px;color:black;"></i>
                                                            <span>Search</span>
                                                        </button>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                        <div id="EmailHistory" class="col-lg-12 col-md-12 col-sm-12 col-xs-12 send-right-mail heights">
                                            @Html.Partial("_EmailHistory", Model)
                                        </div>
                                    </div>
                                    <div id="tab-6" class="tab-content2 ">
                                        <div class="sms-settingpage">
                                            <ul class="smssetting-top">
                                                <li>
                                                    <button type="button" id="SaveAll" class="btn  waves-effect fullbodydycolorbg">
                                                        <img src="~/AdminDesign/images/security.svg">
                                                        <span>Save Details</span>
                                                    </button>
                                                </li>
                                                <li style="margin-right:10px;">

                                                    <button type="button" class="btn  waves-effect for-select-mail" onclick="eUnSelectAll()">
                                                        <i class="fa fa-square-o" aria-hidden="true"></i><span style="margin-left:5px;">Unselect All</span>
                                                    </button>
                                                </li>
                                                <li>

                                                    <button type="button" class="btn  waves-effect for-select-mail" onclick="eselectAll()">
                                                        <i class="far fa-check-square" aria-hidden="true" style="color:@PageData["Globalfirst"];"></i> <span>Select All</span>
                                                    </button>
                                                </li>


                                            </ul>
                                            <div class="for-mail" style="">
                                                <div class="">
                                                    <!--User Create-->
                                                    <div class="card">
                                                        <div class="demo-checkbox">
                                                            <div class="row">
                                                                <div class="col-md-12 col-sm-12 col-xs-12 col">
                                                                    <p class="algp">USER CREATE EMAIL</p>
                                                                </div>
                                                            </div>

                                                            <div class="row">
                                                                <div class="col-md-6 col-sm-6 col-xs-12 col">
                                                                    <div class="row">
                                                                        <div class="col-md-6 col-sm-6 col-xs-6 col">
                                                                            <span>Master Create</span>
                                                                        </div>
                                                                        <div class="col-md-6 col-sm-6 col-xs-6 col">
                                                                            <input type="checkbox" id="MasterCreate1" value="MasterCreate1" class="filled-in chk-col-red" name="acs1">
                                                                            <label for="MasterCreate1">Master</label>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-6 col-sm-6 col-xs-12 col">
                                                                    <div class="row">
                                                                        <div class="col-md-7 col-sm-6 col-xs-6 col">
                                                                            <span>API User Create</span>
