                            </td>
                            <td>
                                @Html.DisplayFor(a => a.Retaileruser[i].OperatorName)
                            </td>
                            <td>
                                @Html.DisplayFor(a => a.Retaileruser[i].opttype)
                            </td>
                            <td>
                                @Html.EditorFor(a => a.Retaileruser[i].comm, new { htmlAttributes = new { @style = "width:100%" } })
                                @Html.ValidationMessageFor(a => a.Retaileruser[i].comm)
                            </td>
                        </tr>
                    }
                }
                <!--End Dealer-->
                <!--dealer Retailer User-->
                @if (Model.dlmremuser != null)
                {
                    for (int i = 0; i < Model.dlmremuser.Count; i++)
                    {
                        <tr>
                            @Html.HiddenFor(a => a.dlmremuser[i].RolesName)
                            @Html.HiddenFor(a => a.dlmremuser[i].idno)
                            @Html.HiddenFor(a => a.dlmremuser[i].optcode)
                            <td>
                                @Html.DisplayFor(a => a.dlmremuser[i].Email)
                            </td>
                            <td>
                                @Html.DisplayFor(a => a.dlmremuser[i].OperatorName)
                            </td>
                            <td>
