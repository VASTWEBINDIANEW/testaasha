                    {
                        <tr>
                            @Html.HiddenFor(a => a.Retaileruser[i].RolesName)
                            @Html.HiddenFor(a => a.Retaileruser[i].idno)
                            @Html.HiddenFor(a => a.Retaileruser[i].optcode)
                            <td>
