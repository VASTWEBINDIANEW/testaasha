                                @Html.ValidationMessageFor(a => a.dlmremuser[i].comm)
                            </td>
                        </tr>
                    }
                }
                <!--End Dealer retailer-->

            </tbody>
            <tbody id="tbodyeditAll" style="display:none;">
                <!--Master User Update-->
                @if (Model.Materuser != null)
                {
                    for (int i = 0; i < Model.UpdateMaster.Count; i++)
                    {
                        var endID = Model.UpdateMaster[i].idno;
                        <tr>
                            @Html.HiddenFor(a => a.UpdateMaster[i].idno)

                            <td>
                                <p>All</p>
                            </td>
                            <td style="display:none;">
                                @Html.HiddenFor(a => a.UpdateMaster[i].optcode)
                            </td>
                            <td>
                                @Html.DisplayFor(a => a.UpdateMaster[i].OperatorName)

                            </td>
                            <td>
                                @Html.DisplayFor(a => a.UpdateMaster[i].opttype)

                            </td>
                            <td>
                                @Html.TextBoxFor(a => a.UpdateMaster[i].comm, new { @style = "width:100%" })
                                @Html.ValidationMessageFor(a => a.UpdateMaster[i].comm)
                            </td>
                        </tr>
                    }
                }
                <!--End Master User-->
                <!--Dealer User Update-->
                @if (Model.Dealeruser != null)
                {
                    for (int i = 0; i < Model.UpdateDealer.Count; i++)
                    {
                        var endID = Model.UpdateDealer[i].idno;
                        <tr>
                            @Html.HiddenFor(a => a.UpdateDealer[i].idno)

                            <td>
                                <p>All</p>
                            </td>
                            <td style="display:none;">
                                @Html.HiddenFor(a => a.UpdateDealer[i].optcode)
                            </td>
                            <td>
                                @Html.DisplayFor(a => a.UpdateDealer[i].OperatorName)

                            </td>
                            <td>
                                @Html.DisplayFor(a => a.UpdateDealer[i].opttype)

                            </td>
                            <td>
                                @Html.TextBoxFor(a => a.UpdateDealer[i].comm, new { @style = "width:100%" })
                                @Html.ValidationMessageFor(a => a.UpdateDealer[i].comm)
                            </td>
                        </tr>
                    }
                }
                <!--End Dealer User-->
                <!--Reatiler User Update-->
                @if (Model.UpdateRetailer != null)
                {
                    for (int i = 0; i < Model.UpdateRetailer.Count; i++)
                    {
                        var endID = Model.UpdateRetailer[i].idno;
                        <tr>
                            @Html.HiddenFor(a => a.UpdateRetailer[i].idno)

                            <td>
                                <p>All</p>
                            </td>
                            <td style="display:none;">
