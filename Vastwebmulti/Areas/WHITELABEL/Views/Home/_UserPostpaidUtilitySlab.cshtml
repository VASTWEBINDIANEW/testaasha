@model Vastwebmulti.Areas.WHITELABEL.Models.PostpaidUtilitySlab
@using (Ajax.BeginForm("_UserPostpaidUtilitySlab", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "OnSuccess1", OnFailure = "onfailed", UpdateTargetId = "divEditFormComm", InsertionMode = InsertionMode.Replace }))
{
    <input id="btnsubmituser" type="submit" value="Update For Existing Users" class="btn btnsubmituser-custom   waves-effect" style="display:none;" />
    <input id="btnsubmitusercommon" type="submit" name="Button" value="Update Existing & New Users" class="btn btnsubmitusercommon-custom   waves-effect" style="display:none;" />
    <input id="btnsubmitusercommondlmrem" type="submit" name="Button" value="Update Existing & New Users" class="btn btnsubmitusercommondlmrem" -custom waves-effect" style="display:none;" />

    @Html.HiddenFor(m => m.role)
    <div class="row clearfix" style="margin-right:0px;">
        <div class="col-md-12">
            <div class="slab-master-block">
                <div class="slab-master-block-left">
                    <div id="allshow" class="row">
                        <div class="col-md-12" style="padding-right:20px;">
                            <div class="custom-district-img">
                                <img src="~/AdminDesign/images/slab-user.svg" style="width:18px;">
                            </div>
                            @Html.DropDownList("ddlUserId", Model.UserId, "All Users", new { @class = "for-select2 form-control", @onchange = "ddlUserIdChange()" })
                        </div>
                    </div>
                    <div id="retailerdrop" class="row" style="display:none;">
                        <div class="col-md-6" style="padding-right:0px;">
                            <div>
                                <div class="custom-district-img">
                                    <img src="~/AdminDesign/images/slab-user.svg" style="width:18px;">
                                </div>
                                @Html.DropDownList("ddldealer", Model.UserId, "All Distributor", new { @class = "form-control for-select2", @onchange = "ddlretailerid()" })
                            </div>
                        </div>
                        <div class="col-md-6" style="padding-left:5px;padding-right:20px;">
                            <div>
                                <div class="custom-district-img">
                                    <img src="~/AdminDesign/images/slab-user.svg" style="width:18px;">
                                </div>
                                @Html.DropDownList("ddlUserIdrem", Model.RetailerId, "All Retailer", new { @class = "form-control for-select2", @onchange = "ddlUserIdChangerem()" })

                            </div>
                        </div>
                    </div>
                </div>
                <div class="slab-master-block-right">
                    <div id="slab-master-message" class="slab-master-message slab-master-message-show" style="display: none;">
                        <p>  If you edit the slabs of all the master distributors, you are given a data view of the common slabs.</p>
                    </div>
                    <div id="slab-master-detail" class="slab-master-detail slab-master-detail-hide" style="display: block;">
                        <div class="row clearfix">

                            <div class="col-md-4 col-sm-4 col-xs-4 col-4">
                                <span class="master-slab-right-icon">
                                    <img src="~/AdminDesign/images/user.svg">
                                </span>
                                <input class="form-control" type="text" placeholder="User Name" value="@Model.Name">

                            </div>
                            <div class="col-md-4 col-sm-4 col-xs-4 col-4">
                                <span class="master-slab-right-icon" style="border-left: 1px solid #bbb;">
                                    <img src="~/AdminDesign/images/number.svg">
                                </span>
                                <input class="form-control" type="text" placeholder="User Registered Number" value="@Model.Phone">

                            </div>
                            <div class="col-md-4 col-sm-4 col-xs-4 col-4">
                                <span class="master-slab-right-icon" style="border-left: 1px solid #bbb;">
                                    <img src="~/AdminDesign/images/email.svg">
                                </span>
                                <input class="form-control" type="text" placeholder="User Registered Mail" value="@Model.Email">

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="slab-table">
        <table class="table table-bordered">
            <thead class="navbar" style="position:initial;">
                <tr>
                    <th>User&nbsp;ID</th>
                    <th>Operator&nbsp;Name</th>
                    <th class="table-select">


                        <span class="for-slab-b">
                            <span>Operator&nbsp;Type</span>
                            <div class="utility-slab-select">
                                @Html.DropDownList("ddlOPttype1", Model.OPttype.Distinct(), new { @class = "form-control", @onchange = "ddlopttypeChange1()" })
                            </div>
                        </span>

                    </th>
                    <th>Commission</th>
                </tr>
            </thead>
            <tbody id="tbodyshow">
                <!--Master User-->
                @if (Model.Materuser != null)
                {
                    for (int i = 0; i < Model.Materuser.Count; i++)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(a => a.Materuser[i].Email)
                            </td>
                            <td>
                                @Html.DisplayFor(a => a.Materuser[i].OperatorName)

                            </td>
                            <td>
                                @Html.DisplayFor(a => a.Materuser[i].opttype)

                            </td>

                            <td>
                                @Html.DisplayFor(a => a.Materuser[i].comm)

                            </td>
                        </tr>
                    }
                }
                <!--End Master-->
                <!--Dealer User-->
                @if (Model.Dealeruser != null)
                {
                    for (int i = 0; i < Model.Dealeruser.Count; i++)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(a => a.Dealeruser[i].Email)
                            </td>
                            <td>
