<script>
    function checkboxinfo() {
        $("#hiddenid").val("");
        $("#restable").empty();
        var favorite = [];
        var int = 1;
        var markup = "";
        $.each($("input[name='datavalue']:checked"), function () {
            var val = $(this).val();
            var split = val.split("-");
            var id = split[0];
            var rstatus = split[1];
            var name = split[2];
            var mobile = split[3];
            var Operator_name = split[4];
            var amount = split[5];
            rstatus = rstatus.trim();
            if (rstatus.includes("Req")) {
                rstatus = "Pending";
            }
            else if (rstatus.toUpperCase().includes("FAILED TO SUCCESS")) {
                rstatus = "SUCCESS";
            }
            if (rstatus.toUpperCase() != "SUCCESS") {
                tableBody = $("#restable");

                markup = "<tr><td>" + int + "</td><td>" + rstatus + "</td><td>" + name + "</td><td>" + mobile + "</td><td>" + Operator_name + "</td><td>" + amount + "</td></tr>";
                tableBody.append(markup);
                favorite.push(id);
                int++;
            }
        });
        $("#hiddenid").val(favorite);
    }
</script>
