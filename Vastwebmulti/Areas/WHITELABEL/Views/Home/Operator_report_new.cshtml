                for (var i = 0; inputElements[i]; ++i) {
                    if (inputElements[i].checked) {
                        checkedValue = inputElements[i].value;
                        arr.push(checkedValue);
                    }
                }

                $.ajax({
                    url: '@Url.Action("resend", "Home")',
                    type: 'POST',
                    dataType: "json",
                    data: { idarrary: arr },
                    beforeSend: function () {
                        Show();
