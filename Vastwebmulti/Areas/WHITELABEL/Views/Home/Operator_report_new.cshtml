                    success: function (result) {
                        if (result.Response == 'SUCCESS') {
                            reloadPageeee('live');
                        }
                        else if (result.Response == 'EERROR') {
                            reloadPageeee('live');
                        }
                        else {
                            reloadPageeee('live');
                        }

                    },
                    complete: function () {
                        Hide();
                    },

                });
        window.location.reload();
        });
