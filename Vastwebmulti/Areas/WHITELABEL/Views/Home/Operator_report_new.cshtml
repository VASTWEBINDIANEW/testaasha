    function Edit_OPT(id) {
        var btn1 = "subTblshowEdit" + id;
        var btn2 = "subTblhideEdit" + id;
        var btn3 = "subTbl" + id;

        $('#' + btn1).css("display", "none");
        $('#' + btn2).css("display", "block");
        $('#' + btn3).css("display", "none");
    }

    function UpdateOptId(id) {
        var Idno = id;
        var btn3 = "subTbl1" + id;
        btn3 = "#" + btn3;

        var OptId = $(btn3).val();

        var LapuBal = $('#lapubal').val();


        $.ajax({
            url: '@Url.Action("Editoperator", "Home")',
            type: 'POST',
            data: { txtidno: Idno, txtoptid: OptId, txtlapubal: LapuBal },
            cache: false,
            success: function (Response) {
                window.location.reload();

            }
        });


    };
</script>



