

<style>
    .slab-setting-menu {
        float: left;
        padding: 0px;
    }

        .slab-setting-menu li {
            list-style: none;
            float: left;
            border: 1px solid #bbb;
            margin-right: 3px;
        }

            .slab-setting-menu li a {
                color: #555 !important;
                padding: 6px 6px;
                display: block;
            }

                .slab-setting-menu li a.activee {
                    color: #fff !important;
                }
</style>












<ul class="slab-setting-menu" style="background:linear-gradient(to right, @PageData["Globalfirst"],@PageData["GlobalSecond"]);">
    <li><a href="@Url.Action("WebLogin","Home")">Web&nbsp;Success&nbsp;Login</a></li>
    <li><a href="@Url.Action("WebFailedLogin","Home")">Web&nbsp;Failed&nbsp;Login</a></li>
    <li><a href="@Url.Action("AppLogin","Home")">Apps&nbsp;Success&nbsp;Login</a></li>

</ul>
<script type="text/javascript">



    $(function () {
        var current = location.pathname;
        $('.slab-setting-menu li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('activee');

            }
        })
    });

</script>
