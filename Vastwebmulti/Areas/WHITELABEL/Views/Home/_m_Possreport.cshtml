@model List<Vastwebmulti.Models.Whitelabel_Mpos_Report_Paging_Result>
@{
    Layout = null;
}

@if (Model != null)
{
    foreach (var item in Model)
    {

    <tr>
        <td>
            @if (item.status == "00")
            {
                <p style="color:green;font-weight:700;">Success</p>
            }
            else
            {
                <p style="color:red;font-weight:700;">Failed</p>
            }
        </td>
        <td>@item.mPOSid</td>
        <td>
            @if (item.Frm_Name != null)
            {
                <p>@item.Frm_Name</p>
            }
            else
            {
                <p>@item.Email</p>
            }
        </td>
        <td>@item.BankRRN</td>
        <td>@item.TxnId</td>
        <td>@item.transType</td>
        <td>@item.amount</td>
        <td>@item.merchatID</td>
        <td>@item.bankmerchantID</td>
        <td>@item.bankterminalID</td>
        <td>@item.cardbrand</td>
        <td>@item.cardholdername</td>
        <td>
            <img src="../../Images/double-down.png" style="width:16px;" />
            <div style="display:none">
                <table cellpadding="0" cellspacing="0" class="ChildGrid" style="text-align:center;">
                    <thead>
                        <tr style="background : aliceblue; text-align:center;">
                            <th>Card&nbsp;Number</th>
                            <th>Card&nbsp;Type</th>
                            <th>Date</th>
                            <th>Invoice&nbsp;No</th>
                            <th>Payment&nbsp;Id</th>
                            <th>Merchant&nbsp;Address</th>
                            <th>Admin&nbsp;Pre</th>
                            <th>Admin&nbsp;Post</th>
                            <th>Whitelabel&nbsp;Pre</th>
                            <th>Whitelabel&nbsp;Post</th>
                            <th>Dealer&nbsp;Pre</th>
                            <th>Dealer&nbsp;Post</th>
                            <th>Retailer&nbsp;Pre</th>
                            <th>Retailer&nbsp;Post</th>
                            <th>Dealer&nbsp;Comm</th>
                            <th>Retailer&nbsp;Comm</th>
                            <th>Whitelabel&nbsp;GST</th>
                            <th>Dealer&nbsp;GST</th>
                            <th>Retailer&nbsp;GST</th>
                            <th>Whitelabel&nbsp;Income</th>
                            <th>Dealer&nbsp;Income</th>
                            <th>Retailer&nbsp;Income</th>
                            <th>Admin&nbsp;Income</th>
                            <th>Purchase</th>
                            <th>Response</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@item.cardnumber</td>
                            <td>@item.cardtype</td>
                            <td>@item.date</td>
                            <td>@item.invoiceno</td>
                            <td>@item.paymentid</td>
                            <td>@item.merchantnameaddress</td>
                            <td>@item.AdminPre</td>
                            <td>@item.AdminPost</td>
                            <td>@item.MasterPre</td>
                            <td>@item.MasterPost</td>
                            <td>@item.DealerPre</td>
                            <td>@item.DealerPost</td>
                            <td>@item.RetailerPre</td>
                            <td>@item.RetailerPost</td>
                            <td>@item.MdComm</td>
                            <td>@item.Dlm_Comm</td>
                            <td>@item.Rem_comm</td>
                            <td>@item.mdgst</td>
                            <td>@item.dlmgst</td>
                            <td>@item.remgst</td>
                            <td>@item.mdincome</td>
                            <td>@item.dlmincome</td>
                            <td>@item.remincome</td>
                            <td>@item.adminincome</td>
                            <td>@item.purchase</td>
                            <td>@item.Message</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </td>
        @*<td>@item.cardholdername</td>
        <td>@item.cardnumber</td>
        <td>@item.cardtype</td>
        <td>@item.date</td>
        <td>@item.invoiceno</td>
        <td>@item.paymentid</td>
        <td>@item.merchantnameaddress</td>
        <td>@item.AdminPre</td>
        <td>@item.AdminPost</td>
        <td>@item.MasterPre</td>
        <td>@item.MasterPost</td>
        <td>@item.DealerPre</td>
        <td>@item.DealerPost</td>
        <td>@item.RetailerPre</td>
        <td>@item.RetailerPost</td>
        <td>@item.MdComm</td>
        <td>@item.Dlm_Comm</td>
        <td>@item.Rem_comm</td>
        <td>@item.mdgst</td>
        <td>@item.dlmgst</td>
        <td>@item.remgst</td>
        <td>@item.mdincome</td>
        <td>@item.dlmincome</td>
        <td>@item.remincome</td>
        <td>@item.adminincome</td>
        <td>@item.purchase</td>
        <td>@item.Message</td>*@
    </tr>
    }
}