@model IEnumerable<Vastwebmulti.Models.Whitelabel_SMS_Priority>
@{
    ViewBag.Title = "SMS_Priority";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    <div class="row">
                        <div class="col-md-12">
                            <div style="margin-right:1px;">
                                @Html.Partial("smsapipartialview")
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="body" style="margin-top:-18px;padding:7px;">
                        <div class="table-responsive" style="position:inherit;margin-top:-4px;">
                            <table class="table table-bordered " style="width:100%;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>SMS FROM</th>
                                        <th>SMS API</th>
                                        <th>SIM SMS</th>
                                        <th>Edit</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Count() > 0)
                                    {
                                        foreach (var item in Model)
                                        {
                                            <tr>
                                                <td> @Html.DisplayFor(modelItem => item.sms)</td>
                                                <td>
                                                    @Html.DisplayFor(modelItem => item.smsapi)
                                                </td>
                                                <td>
                                                    @Html.DisplayFor(modelItem => item.sim)
                                                </td>
                                                <td>
                                                    <button id="but" class="bt btn-default" onclick="animation('@item.idno','@item.sms','@item.smsapi','@item.sim')" href="#" data-toggle="modal" data-target="#defaultModal1" style="background-color:transparent;border-color:transparent;border:1px solid #c7c2c2;">
                                                        Edit
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td></td>
                                            <td><p style="font-size:22px;margin-top:-5px;text-align:center;color:#e0dddd;font-weight:700;">No Data Found !</p></td>
                                            <td></td>
                                            <td></td>

                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<!--Edit  Modal-->
<div class="modal fade" id="defaultModal1" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header navbar" style="position:initial;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:white;">Edit  API User</h4>
            </div>
            @using (Html.BeginForm("edit_smspriority", "Home", FormMethod.Post))
            {
                <div class="modal-body" style="margin-top:-26px;">
                    <div class="body">
                        <form id="form_validation" method="POST">
                            @Html.TextBox("idno", "", new { style = "Display:none;" })
                            <div class="row clearfix">
                                <div class="col-md-2">
                                    <label for="email_address_2">SMS</label>
                                </div>
                                <div class="col-md-10">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBox("txtsms", "", new { @placeholder = "Enter SMS", @required = "required", @class = "form-control", maxlength = "5", @readonly = true })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-md-2">
                                    <label for="email_address_2">SMS API</label>
                                </div>
                                <div class="col-md-10">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.DropDownList("smsapi", new List<SelectListItem>
   {
   new SelectListItem{ Text="1",Value="1",},
   new SelectListItem{Text="2",Value="2"}
   }, new { @style = "background: #fff; cursor: pointer; padding: 5px 10px; border: 1px solid #ccc; height:31px; min-height: 1px; float: left;", @class = "form-control" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix" style="margin-top:15px;">
                                <div class="col-md-2">
                                    <label for="email_address_2">SIM SMS</label>
                                </div>
                                <div class="col-md-10">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.DropDownList("sim", new List<SelectListItem>
   {
   new SelectListItem{ Text="1",Value="1",},
   new SelectListItem{Text="2",Value="2"}
   }, new { @style = "background: #fff; cursor: pointer; padding: 5px 10px; border: 1px solid #ccc; height:31px; min-height: 1px; float: left; ", @class = "form-control" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="submit" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-right: 12px; height:34px;" onclick="return check()">
                                    <span style="top:-2px;color:black;">Save Change</span>
                                </button>
                                <button type="button" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left: -3px; height:34px;" data-dismiss="modal">
                                    <span style="top:-2px;color:black;">Close</span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }

        </div>
    </div>
</div>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Swalalert/sweetalert.min.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script type="text/javascript">
    var val1 = "";
    function animation(id, sms, spisms, sim) {

        $("#idno").val(id);
        $("#txtsms").val(sms);
        $("#smsapi").val(spisms);
        $("#sim").val(sim);
    }
    function check() {
                    var smsapi = $('#smsapi').val();
                    var sim = $('#sim').val();
                    if (smsapi == sim || freesms == sim) {
                        swal("Opps!", "Not Two Priority Are Same", "error");
                        //alert("Not Two Priority Are Same ");
                        return false;
                    }
                    else {
                        return true;
                    }
    }
</script>