<script>
    function chkmasterbalance(value) {

            $.ajax({
                    type: 'Post',
                url: "@Url.Action("M_Creditchk", "Home")",
                data: { MID: $(value).val() },
                dataType: 'json',
                cache: false,
                async: false,
                success: function (data) {

                    if (data > 0) {
                        $('.old-cr').html('CR. '+data)
                       $("#idst option[value*='7']").prop('disabled', true);
                        $("#idst option[value*='8']").prop('disabled', true);
                         $("#idst option[value*='9']").prop('disabled', true);
                    }
                    else {


                         $("#idst option[value*='7']").prop('disabled', false);
                        $("#idst option[value*='8']").prop('disabled', false);
                          $("#idst option[value*='9']").prop('disabled',false);
                        $('.old-cr').html('<b>No Old Credit Balance</b>')

