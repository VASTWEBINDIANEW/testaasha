<script>
    $('#btnchangetabbutton').click(function (e) {
        var usernm = "";
        var tabtype = $("ul#tabs li.tab-link.active").attr('data-tabname')
        if (tabtype === 'home') {
            usernm = $('#SuperstokistID1').val();
        }
        else if (tabtype === 'menu1') {
            usernm = $('#ddlDistributor1').val();
        }
        else if (tabtype === 'menu2') {
            usernm = $('#RLMID1').val();
        }

      $.ajax({
          url: "@Url.Action("TABCHANGEFORFUNDTRANSFER","Home")",
          data: { nameoftab: tabtype,usernm:usernm, txt_frm_date: $('#txt_frm_date').val(),txt_to_date: $('#txt_to_date').val() },
            success: function (data) {
                $('#tblshowMasterD').html(data)

            }

        })


    });

</script>
<script>
    var validNumber = new RegExp(/^\d*\.?\d*$/);
    var lastValidmaster = document.getElementById("txtsupramount").value;
    function validateNumbermaster(elem) {
        if (validNumber.test(elem.value)) {
            lastValidmaster = elem.value;
        } else {
            elem.value = lastValidmaster;
        }
    }

    var lastValiddealer = document.getElementById("txtDISTAMOUNT").value;
    function validateNumberdistributor(elem) {
        if (validNumber.test(elem.value)) {
            lastValiddealer = elem.value;
        } else {
            elem.value = lastValiddealer;
        }
    }

    var lastValidretailer = document.getElementById("txtRETAMOUNT").value;
    function validateNumberretailer(elem) {
        if (validNumber.test(elem.value)) {
            lastValidretailer = elem.value;
        } else {
            elem.value = lastValidretailer;
        }
    }

</script>
