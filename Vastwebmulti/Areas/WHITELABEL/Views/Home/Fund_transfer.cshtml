    }
    .fund-trasfer-right .tab-content{
        overflow: hidden;
    }
    .ls-closed section.content {
        margin-left: 0;
    }

    @@media only screen and (min-width:481px) and (max-width:992px) {
        .fund-transfer-form {
            height: auto;
        }

        .fund-trasfer-right ul.nav-tabs li, .fund-trasfer-right .nav-tabs li:first-child {
            width: 100% !important;
            float: left;
        }

        .fund-trasfer-right .nav-tabs li:first-child span, .fund-trasfer-right .nav-tabs li:nth-child(2) .li-left-in {
