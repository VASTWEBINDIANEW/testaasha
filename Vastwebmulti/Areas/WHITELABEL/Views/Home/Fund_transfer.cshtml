<script>
    $('#tabs a').click(function (e) {
      $('#btnddbackshow').trigger('click')
        $('#btnbackshow').trigger('click')
        $('#btnRRbackshow').trigger('click')
        $('#btnWLbackshow').trigger('click')
        $('#btnAPIbackshow').trigger('click')
   e.preventDefault()
   var tabID = $(this).attr("href").substr(1);
          $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());

                     if (tabID === 'home') {
                 $('#masterdrop').show();
                 $('#dealerdrop').hide();
                 $('#retailerdrop').hide();
                 $('#apidrop').hide();
                 $('#whitedrop').hide();
             }


       $.ajax({
        url:"@Url.Action("FillMasterDistributorDropDownList")",
        cache: false,
       type: "POST",
       data: {nameoftab:tabID},
           success: function (result) {

             if (tabID === 'menu1') {
                 $('#masterdrop').hide();
                 $('#dealerdrop').show();
                 $('#retailerdrop').hide();
                 $('#apidrop').hide();
                 $('#whitedrop').hide();
                   var s = '<option value="">Please Select a Distributor</option>';
               for (var i = 0; i < result.length; i++) {
                   s += '<option value="' + result[i].Value + '">' + result[i].Text + '</option>';
               }
               $("#ddlDistributor").html(s);
               $("#ddlDistributor1").html(s);
             }
             if (tabID === 'menu2') {
                 $('#masterdrop').hide();
                 $('#dealerdrop').hide();
                 $('#retailerdrop').show();
                 $('#apidrop').hide();
                 $('#whitedrop').hide();
                   var s = '<option value="">Please Select a Retailer</option>';
               for (var i = 0; i < result.length; i++) {
                   s += '<option value="' + result[i].Value + '">' + result[i].Text + '</option>';
               }
               $("#RLMID").html(s);
               $("#RLMID1").html(s);
             }
        }
   });

    cahangeTab(tabID);

});

    function cahangeTab(name) {
          $.ajax({
        url:"@Url.Action("TABCHANGEFORFUNDTRANSFER")",
        cache: false,
       type: "get",
       data: {nameoftab:name},
        dataType: "html",
       success: function (result) {
        $('#tblshowMasterD').html(result);
        }
   });
    }


