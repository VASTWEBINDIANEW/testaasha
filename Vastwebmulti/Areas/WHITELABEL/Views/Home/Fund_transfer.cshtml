            border-left: 1px solid var(--border-color);
        }

        .table-responsive > .table-bordered > thead > tr > th:last-child {
            border-right: 1px solid var(--border-color);
        }

        .fund-tr-history .modal-dialog {
            width: 95%;
            margin-right: 2% !important;
        }
    }
</style>
