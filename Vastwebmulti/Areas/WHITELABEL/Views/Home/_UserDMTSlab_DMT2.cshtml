                            @Html.TextBoxFor(a => a.UpdateRetailer[i].comm_49000, new { @style = "width:100%" })
                            @Html.ValidationMessageFor(a => a.UpdateRetailer[i].comm_49000)
                        </td>
                        <td>
                            @Html.TextBoxFor(a => a.UpdateRetailer[i].comm_50000, new { @style = "width:100%" })
                            @Html.ValidationMessageFor(a => a.UpdateRetailer[i].comm_50000)
                        </td>
                        @*<td>
                                @Html.TextBoxFor(a => a.UpdateRetailer[i].gst, new { @style = "width:100%" })
                                @Html.ValidationMessageFor(a => a.UpdateRetailer[i].gst)
                            </td>*@

                    </tr>
                }
            }
            <!--End Retailer User-->
        </tbody>
    </table>

}
