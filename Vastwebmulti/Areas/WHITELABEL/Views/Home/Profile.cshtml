<script>
    function WriteOTPStatus(roleName, stsBtn) {
    debugger
        $.ajax({
            type: "POST", url: '@Url.Action("AdminOTPStatus", "Home")',
            data: { 'RoleName': roleName, 'Status': stsBtn },
            dataType: 'json',
            cache: false,
            success: function (data) {
                if (data.RoleName == "Whitelabelmaster" && data.Status == "Y") {
                    $('#masterotpoff').removeClass('custom-off');
                    $('#masterotpoff').addClass('costom-on');
                    $('#masterotpoff').text('OTP-ON');
                }
                else if (data.RoleName == "Whitelabelmaster" && data.Status == "N") {
                    $('#masterotpon').addClass('custom-off');
                    $('#masterotpon').removeClass('costom-on');
                    $('#masterotpon').text('OTP-OFF');
                }
                else if (data.RoleName == "Whitelabeldealer" && data.Status == "Y") {
                    $('#dealeroff').removeClass('custom-off');
                    $('#dealeroff').addClass('costom-on');
                    $('#dealeroff').text('OTP-ON');
                }
                else if (data.RoleName == "Whitelabeldealer" && data.Status == "N") {
                    $('#dealeron').addClass('custom-off');
