            data: { 'UserRole': roleName, 'btnVal': stsBtn, 'UserrId':'' },
            dataType: 'json',
            cache: false,
            success: function (data) {
                GetUser(data[0]);
                WriteOTPStatus(roleName, stsBtn);
        }
    });
    }

    function OtpOnOffById(userid,btnsts) {
        $.ajax({
            type: "POST", url: '@Url.Action("DisableTwoFactor", "Home")',
            data: { 'UserRole': '', 'btnVal': btnsts, 'UserrId': userid },
            dataType: 'json',
            cache: false,
            success: function (data) {
                GetUser(data[0]);
            }
        });
    }

    function GetUser(roleName) {
        $.ajax({
            type: "GET", url: '@Url.Action("GetTwoFactor", "Home")',
            data: { 'UserRole': roleName },
            dataType: 'json',
            cache: false,
            success: function (data) {
                if (data[0].UserRole == "Whitelabelmaster") {
                    var row = "";
                    var Id = 1;
                    $.each(data, function (index, item) {
                        var OnOff = item.TwoFactorEnable;
                        var btnOnOff = "";
                        if (OnOff == true) {
                            btnOnOff = "<div class='onoffswitch' style='float: left;'><button class='costom-on' onclick = OtpOnOffById('" + item.UserId + "','N') style = 'border:1px solid;'> ON</button ></div>";
                        }
                        else {
