@model Vastwebmulti.Models.User
@{
    ViewBag.Title = "Profile";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}

<style>
        .body.profile-register-address.upload-document ul .list-group-item {
            padding: 10px 0px;
        }

    .save-aadhar {
        display: flex;
        align-items: baseline;
    }

    .ribbon {
        position: absolute;
        right: 0px;
        top: 0px;
        z-index: 1;
        overflow: hidden;
        width: 75px;
        height: 75px;
    }

            .ribbon span {
                font-size: 11px;
                color: #fff;
                text-align: center;
                font-weight: bold;
                line-height: 20px;
                transform: rotate(45deg);
                -webkit-transform: rotate(45deg);
                width: 100px;
                box-shadow: 0 3px 10px -5px rgba(0, 0, 0, 1);
                position: absolute;
                top: 19px;
                right: -21px;
                background: linear-gradient(#c5c5c5 0%, #868686 100%);
            }

    .list-group-item{
        background: #ddd;
        border: 1px solid #555;
        margin-bottom: 10px;
    }
    #EditaddressModal li {
        padding: 5px;
    }


        .field-validation-error {
            color: red;
        }

        .firt {
            -webkit-transform: rotate(-90deg);
            position: absolute;
            left: -46px;
            top: 48px;
        }

        .ons1 button {
            font-size: 22px;
            text-align: center;
            padding: 5px 22px;
            font-weight: bold;
            margin: 0px auto;
            float: right;
            margin-top: 22px;
        }

        .ons1 input {
            width: 24%;
            float: right;
            border: 1px solid #c7c7c7;
            height: 28px;
            margin-left: 4px;
            padding: 0px 2px;
            font-size: 12px;
        }

        .ons1 {
            width: 100%;
            float: left;
            background: #fff;
            border: 1px solid #c7c7c7;
            padding: 3px 5px;
            margin-bottom: 5px;
        }

            .ons1 span {
                font-size: 16px;
                display: inline-block;
                float: left;
                width: 32%;
                margin-top: 3px;
            }

            .ons1 select {
                width: 17%;
                height: 28px;
                border: 1px solid #c7c7c7;
                float: left;
                background: #e1e1e1;
            }

        .firt span {
            color: var(--main-bg-lcolor);
            font-size: 16px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .firt3, .firt4 {
            margin-left: 5px;
        }

        .firt2, .firt3, .firt4 {
            padding: 0px;
            width: 32%;
        }

        .required:after {
            color: red;
            content: " *";
        }

        .profile-register-address .list-group-item {
            background-color: var(--second-bg-color);
        }

        .userwise-off ul li {
            float: left;
            padding: 0px 8px;
            border-left: 1px solid #aeaaaa;
            width: 20%;
        }

        .userwise-off ul {
            margin: 0px;
        }

        .userwise-off .onoffswitch {
            width: 55px;
            margin: 0;
        }

        .userwise-off .custom-off::before {
            content: '';
            width: 10px;
            height: 10px;
            top: 8px;
        }

        .userwise-off .costom-on::after {
            top: 7px;
        }

        #btnff.custom-off::before {
            top: 4px;
        }

        #btnon.costom-on::after {
            top: 5px;
            right: 10px;
        }

        .master-user-pop, .Distributor-user-pop, .retailer-user-pop, .api-user-pop, .white-user-pop {
            width: 100%;
            float: left;
            display: none;
            position: absolute;
            top: 80px;
            z-index: 1;
            box-shadow: 0px 0px 3px #000;
            padding: 5px;
            background: #fff;
        }

        .for-master-close {
            color: var(--main-bg-lcolor);
            font-size: 14px;
            position: absolute;
            right: 0px;
            top: 0px;
            background: #fff;
            width: 12px;
            cursor: pointer;
        }

        .my-profile-save p, #EditnameandpancardModal p {
            background: #ddd;
            border: 1px solid #555 !important;
            width: 47%;
            display: inline-block;
            margin: 4px !important;
            padding: 10px !important;
        }

            .my-profile-save p label, #EditnameandpancardModal p label {
                margin: 0;
            }

            #EditnameandpancardModal p input {
                height: 20px !important;
                background: #ddd;
            }

        #btnon.costom-on::after, #btnff.custom-off::before, .userwise-off .custom-off::before, .userwise-off .costom-on::after {
            display: none;
        }

        .admin-otpwhite .onoffswitch button::before{
            content: "";
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            width: 0;
            transition: all 1s ease-in-out;
            animation: text-animation 3s infinite;
            display: inline-block;
            z-index: 9;
            background: @PageData["GlobalSecond"];
            height: 40px;
        }

    .admin-otpwhite .onoffswitch button, .userwise-off .onoffswitch button, .modal-footer-uplod-img button {
        position: relative;
        overflow: hidden;
    }
        .userwise-off .onoffswitch button::before, .modal-footer-uplod-img button::before {
            content: "";
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: auto;
            width: 0;
            transition: .5s linear;
            display: inline-block;
            z-index: 9;
            background: @PageData["GlobalSecond"];
            height: 40px;
        }
        .userwise-off .onoffswitch button:hover::before, .modal-footer-uplod-img button:hover::before{width: 100%;right: auto;left: 0;}
    @@keyframes text-animation {
        0% {
            width: 0;
        }

        50% {
            width: 100%;
        }

        100% {
            width: 0;
        }
    }
    .onoffswitch-top-space .onoffswitch{margin-top: 0;}
    .for-master-close{color: #fff;background: @PageData["Globalfirst"];border-radius: 50%;height: 35px;width: 35px;font-size: 24px;text-align: center;top: -4px;right: -4px;}
    .editbuttoncssclass a::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 150%;
        height: 100%;
        background: #37474f;
        -webkit-transform: rotate3d(0, 0, 1, -45deg) translate3d(0, -3em, 0);
        transform: rotate3d(0, 0, 1, -45deg) translate3d(0, -3em, 0);
        -webkit-transform-origin: 0% 100%;
        transform-origin: 0% 100%;
        -webkit-transition: -webkit-transform 0.3s, opacity 0.3s, background-color 0.3s;
        transition: transform 0.3s, opacity 0.3s, background-color 0.3s;

    }
    .editbuttoncssclass a span:hover{color: #fff !important;}
    .editbuttoncssclass a:hover::before {
        opacity: 1;
        background-color: #ee4f66;
        -webkit-transform: rotate3d(0, 0, 1, 0deg);
        transform: rotate3d(0, 0, 1, 0deg);
        -webkit-transition-timing-function: cubic-bezier(0.2, 1, 0.3, 1);
        transition-timing-function: cubic-bezier(0.2, 1, 0.3, 1);
    }
    #EditnameandpancardModal .form-control, #EditaddressModal .form-control {
        width: 100%;
        float: right;
        border: 1px solid #ddd !important;
    }
    #EditaddressModal li p {
        width: 65%;
        float: right;
    }
        #EditaddressModal li p select {
            -webkit-appearance: none;
            background: url(../../../AdminDesign/images/multimedia.svg)no-repeat;
            background-position-y: 50%;
            background-size: 2%;
            background-position: 98%;
            background-color: #fff;
        }
    .custom-district::after {
        display: none;
    }
    @@media only screen and (max-width:1300px) {
        .one-time-otp{height: 130px !important;}
        #UserWiseOTPbtn {
            float: left;
            margin-left: 10px !important;
        }

        .userwise-off ul li {
            padding: 0px;
            padding-left: 4px;
        }

            .custmor-support-in button {
                margin: 12px 15px;
            }


        }
        @@media only screen and (max-width:992px) {
            .one-time-otp span, .one-time-otp #UserWiseOTPbtn{width:100% !important;margin: auto;float: left; text-align: center;}
            #UserWiseOTPbtn button{float: none;margin: auto;}
            .one-time-otp {height: 130px !important;display: flex;flex-wrap: wrap;}
            .custmor-support{margin-top: 65px;}
            #EditaddressModal li p {
                width: 50%;
            }
            }
        @@media only screen and (max-width:520px) {
            .one-time-otp {
                width: 100% !important;
                float: right;
            }

                .one-time-otp #UserWiseOTPbtn {
                    float: right;
                }

            .userwise-off.one-time-otp-user {
                width: 100% !important;
                float: left !important;
                margin-bottom: 60px;
            }

            .userwise-off ul li {
                width: 33%;
                margin-top: 10px;
            }

            .custmor-support.fullbodydycolorbg {
                margin-top: 140px;
            }

            .otp-security .table-responsive > .table-bordered > thead > tr > th:first-child, .otp-security .table-responsive > .table-bordered > tbody > tr > td:first-child {
                border-left: 1px solid var(--border-color);
            }
            .my-profile-save p, #EditnameandpancardModal p{margin: 0;width: 100%;}
            .userwise-off.one-time-otp-user ul li {
                width: 100% !important;
                border: 1px solid !important;
                padding: 20px;
            }
            .custmor-support {
                background: transparent !important;
                margin: 0;
            }
            #EditaddressModal li p {
                width: 100%;
            }
            }
</style>
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-4 admin-otpwhite">
                <div class="card " style="margin-bottom:0px;background: #f5f5f5 !important;border-top: 2px solid #ee4f66;border-left: 2px solid #ee4f66;border-right: 2px solid #3c7add;border-bottom: 2px solid #3c7add;">
                    <div class="ribbon"><span class="">ADMIN</span></div>

                    <div class="body" style="padding:15px;">
                        <center>
                            @if (ViewBag.image != null || ViewBag.image != "")
                            {
                                <div class="image" style="">
                                    <img id="Adminimage" src="@Url.Content("~/"+ ViewBag.image )" class="img-circle" alt="User" width="100" height="100" title="Click Me Upload Profile Image" style="cursor:pointer;" onclick="uploadimage(@ViewBag.admin.Idno)" />
                                </div>
                            }
                            else
                            {
                                <div class="image" style="margin-top:24px;">
                                    <img id="Adminimage" src="~/AdminDesign/images/user.png" width="100" height="100" class="img-circle" alt="User" title="Click Me Upload Profile Image" style="cursor:pointer;" onclick="uploadimage(@ViewBag.admin.Idno)">
                                </div>
                            }

                            <div class="msg" style="padding-top:12px; font-size:19px; font-weight:600;">@ViewBag.admin.Name</div>
                            <p style="margin-top:5px;margin-bottom: 0;font-size:14px;text-transform:uppercase;">Administrator</p>

                        </center>
                    </div>
                    <div class="one-time-otp" style="background-color: whitesmoke; height: 113px; border: 3px solid #555; border-radius: 5px; width: 90%; margin: 0px auto;margin-bottom: 15px;">
                        <h1 style="font-size: 20px; font-weight: bold; text-transform: uppercase; width: auto; float: left; margin-top: -10px !important; margin-left: 10px; background: #f5f5f5; color: #555 !important; padding: 0 7px;">
                            <i class="fa fa-lock"></i>&nbsp;One Time Password Security
                        </h1>
                        <span style="color:var(--main-bg-lcolor);float:left;margin-right:10px; font-family:'Open Sans',sans-serif;font-weight:400;margin-bottom: 0px;margin-left: 19px;font-size:12px;margin-top: 20px;">You Want Login (OTP) Security Purpose !</span>
                        <div class="onoffswitch" id="UserWiseOTPbtn" style="cursor: pointer; width: auto; border: 0px; margin: 0;margin-right:15px;">
                            @if (Model.TwoFactorEnabled)
                            {
                                using (Html.BeginForm("DisableTwoFactorAuthentication", "Manage", new { area = "" }, FormMethod.Post, new { encType = "multipart/form-data" }))
                                {
                                    @Html.AntiForgeryToken()

                                    <button style="margin-top: 10px; height: 40px !important; box-shadow: 0px 0px 1px 3px rgba(0, 0, 0, 0.12); width: 145px; padding: 0px !important; border-radius: 50px 50px !important; background-color: @PageData["Globalfirst"];font-size: 20px;border: 0;font-weight: 700;color: #fff;text-align: center;" type="submit" class="costom-on" value="ON" id="btnon" name="btnon"><span style="z-index: 9;position: relative;color: #fff;">OTP-ON</span></button>

                                }
                            }
                            else
                            {
                                using (Html.BeginForm("EnableTwoFactorAuthentication", "Manage", new { area = "" }, FormMethod.Post, new { encType = "multipart/form-data" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button style="margin-top: 10px; height: 40px !important; box-shadow: 0px 0px 1px 3px rgba(0, 0, 0, 0.12); width: 145px; padding: 0px !important; border-radius: 50px 50px !important; background-color: @PageData["Globalfirst"];font-size: 20px;border: 0;font-weight: 700;color: #fff;text-align: center;" value="Off" id="btnff" name="btnff"><span style="z-index: 9;position: relative;color: #fff;">OTP-OFF</span></button>
                                }
                            }

                        </div>
                    </div>
                </div>

            </div>
            <div id="saveaddressModal" class="col-lg-8 col-md-8 col-sm-12 col-xs-12">
                <div class="card" style="border: 1px solid #e6e3e3; background: #f5f5f5;">
                    <div class="editbuttoncssclass" style="background-color:#c7c7c7;padding: 10px 25px;">
                        @if (ViewBag.admin.FrmName != null)
                        {
                            <h1 style="color:#555;font-size:20px;font-weight:bold;text-transform:uppercase;margin:0px;">
                                <span id="spncompny">  @ViewBag.admin.FrmName </span>
                                <a style="float: right;cursor: pointer;text-transform: capitalize;border: 1px solid #bdbdbd;background: #fff;padding: 2px 10px;color: #9E9E9E !important;font-size: 21px;font-weight: normal;margin-top: -4px;overflow: hidden; position: relative;" onclick="editeaddress(@ViewBag.admin.Idno)"><span style="position: relative;z-index: 9;color: #9E9E9E ;">Edit</span></a>
                            </h1>
                        }
                        else
                        {
                            <h1 style="color:#555;font-size:24px;font-weight:bold;text-transform:uppercase;margin:0px;">
                                <span id="spncompny">
                                    No Data Found !
                                </span>
                                <a style="float:right;"><i class="fa fa-pencil-square-o" style="font-size:22px;margin-top:0px;" onclick="editeaddress(@ViewBag.admin.Idno)"></i></a>
                            </h1>
                        }
                    </div>
                    <div class="body profile-register-address" style="background:var(--second-bg-color);padding-top: 0px;padding-bottom: 13px;  ">
                        <ul class="list-group" style="margin:10px 4px 0;">
                            <li class="list-group-item">
                                <i class="fa fa-map-marker"></i> <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Registered Business Address</span>
                            </li>
                            <li class="list-group-item">

                                @if (ViewBag.admin.Address != null && ViewBag.admin.Address != "")
                                {
                                    <p style="text-align:justify;margin: 0;"><span style="color: #7a7676; font-family: 'Open Sans',sans-serif; font-weight: 600;" id="spnaddress"> @ViewBag.admin.Address </span></p>
                                }
                                else
                                {
                                    <p style=""><span id="spnaddress"> ADDRESS NOT FOUND !  </span></p>
                                }

                            </li>
                            <li class="list-group-item" style="">
                                <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;Zip Code</span>
                                @if (ViewBag.admin.Pincode != null)
                                {
                                    <p style="float:right;margin-top:5px;"><span id="spnpincode"> @ViewBag.admin.Pincode </span></p>
                                }
                                else
                                {
                                    <p style="float:right;margin-top:5px;"><span id="spnpincode"> ZIP CODE NOT FOUND ! </span></p>
                                }
                            </li>
                            <li class="list-group-item">
                                <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;State</span>
                                <p style="float:right;text-transform:uppercase;"><span id="spnstate">  @ViewBag.ddlstate </span></p>
                            </li>
                            <li class="list-group-item">
                                <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;District</span>
                                <p style="float:right;text-transform:uppercase;"><span id="spndistrict"> @ViewBag.dddistrict </span></p>
                            </li>

                        </ul>
                    </div>
                </div>
            </div>
            <div id="EditaddressModal" class="col-lg-8 col-md-8 col-sm-12 col-xs-12" style="display:none;">
                <div style="background:var(--second-bg-color);width:100%;float:left;border: 1px solid #e6e3e3; background: #f5f5f5;">
                    <div class="card" style="margin-bottom:0px;background: none;">

                        @using (Ajax.BeginForm("UpdateAddressProfile", "Home", new AjaxOptions
                        {
                            InsertionMode = InsertionMode.Replace,
                            OnSuccess = "OnSuccessEditAddress",
                            OnFailure = "OnFailure"
                        }))

                        {
                            <input type="hidden" id="hdidadmin" name="hdidadmin" value="" />
                            <div style="background-color:#c7c7c7;padding: 11px 20px;min-height: 42px;">

                                <h1 style="color:#555;font-size:20px;font-weight:bold;text-transform:uppercase;margin:0px;">
                                    <button type="submit" class="btn waves-effect" style="position: absolute;right: 20px;top: 5px;height: 32px;padding: 5px 16px;">
                                        <span style="position: relative;z-index: 9;color: #9E9E9E ;"> Save</span>
                                    </button>
                                </h1>

                            </div>
                            <div class="body profile-register-address" style="background:var(--second-bg-color);padding-top: 0px;padding-bottom: 13px;  ">
                                <ul class="list-group" style="">
                                    <li>
                                        <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;float: left;padding-top: 6px;">Your Name</span>
                                        <p style="text-align:justify;">@Html.TextBox("txtcompany", "", new { @class = "form-control", placeholder = "Enter Your Company Name", required = "required", @style = "width:100%;" })</p>
                                    </li>
                                    <li>
                                        <i class="fa fa-map-marker" style="float: left;padding-top: 9px;"></i> <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;float: left;padding-top: 6px;">Registered Business Address</span>
                                        <p style="text-align:justify;">   @Html.TextBox("txtaddress", "", new { @class = "form-control", placeholder = "Enter Your Address", required = "required", @style = "width:100%;" })</p>
                                    </li>
                                    <li>

                                        <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;float: left;padding-top: 6px;">&nbsp;Town / City Address</span>
                                        <p style="text-align:justify;">   @Html.TextBox("txtaddress", "", new { @class = "form-control", placeholder = "Enter Your Address", required = "required", @style = "width:100%;" })</p>


                                    </li>
                                    <li>
                                        <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;float: left;padding-top: 6px;">&nbsp;Zip Code</span>

                                        <p style="float:right;"> @Html.TextBox("txtzipcode", "", new { @required = "required", @class = "form-control", @placeholder = "Enter Zip Code", onkeypress = "return isNumber(event)" })</p>

                                    </li>
                                    <li>
                                        <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;float: left;padding-top: 6px;">&nbsp;State</span>
                                        <p class="custom-district" style="float:right;text-transform:uppercase;"> @Html.DropDownList("State", (IEnumerable<SelectListItem>)ViewBag.Sate, "-- Select State--", new { @class = "form-control", @required = "required", @onchange = "FillDistict()" })</p>
                                    </li>
                                    <li>
                                        <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;float: left;padding-top: 6px;">&nbsp;District</span>
                                        <p class="custom-district" style="float:right;text-transform:uppercase;"> @Html.DropDownList("District", (IEnumerable<SelectListItem>)ViewBag.District, "-- Select District--", new { @class = "form-control", @required = "" })</p>
                                    </li>

                                </ul>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>

        <div class="row clearfix">
            <div class="col-md-4">
                <div class="card" style="margin-top: 0px;background: #f5f5f5;border: 1px solid #ddd;">
                    <div class="editbuttoncssclass" style="background-color:#c7c7c7;padding: 5px 10px;">
                        <h1 style="color:#555;font-size:14px;font-weight:bold;text-transform:uppercase;margin:0px;">
                            Website Launching Date
                            <a style="float: right; color: #9E9E9E !important; cursor: pointer; font-size: 22px; margin-top: 0px; border: 1px solid #bdbdbd; background: #fff; padding: 5px 15px; text-transform: capitalize; font-weight: normal;position: relative;overflow: hidden;" onclick="editemobileandpancard(@ViewBag.admin.Idno)"><span style="position: relative;z-index: 9;color: #9E9E9E ;">Edit</span></a>
                        </h1>
                        <p style="text-transform:uppercase;margin-bottom:0px;">@ViewBag.admin.JoinDate</p>

                    </div>
                    <div class="my-profile-save" style="background: var(--second-bg-color);padding:10px;">
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Name</p>
                        <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;"><label id="lbladminname">@ViewBag.admin.Name</label> </p>
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Email-ID</p>
                        <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;"><label id="lbladminemail">@ViewBag.admin.EmailId </label> </p>
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Mobile</p>
                        <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;"><label id="lbladminmobile">@ViewBag.admin.Mobile </label></p>
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Aadharcard</p>
                        @if (ViewBag.admin.aadharnumber != null && ViewBag.admin.aadharnumber != "")
                        {
                            <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;"><label id="lbladminaadhar"> @ViewBag.admin.aadharnumber </label></p>
                        }
                        else
                        {
                            <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;">Data Not Found !</p>
                        }
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Pancard</p>
                        @if (ViewBag.admin.PanCardnumber != null && ViewBag.admin.PanCardnumber != "")
