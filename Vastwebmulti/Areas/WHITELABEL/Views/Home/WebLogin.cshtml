                                                <img src="~/img/red.svg" alt="Wrong Arrow image" style="width:32px;" />
                                                <span> Deactive </span>
                                            </button>
                                            <p class="dmlsing-seconddesign border-full-third">No more security required, then send password to mobile</p>
                                        </fieldset>
                                    }
                                    if (item.highsecurity == false)
                                    {
                                        <fieldset class="secondf fff secondf-custom">
                                            <legend>High Security</legend>
                                            <button data-id="@item.id" onclick="SecurityChange()" type="button" class="btn btn-firstwhite-second">
                                                <img src="~/img/red.svg" alt="Wrong Arrow image" style="width:32px;" />
                                                <span> Deactive </span>
                                            </button>
                                            <p class="dmlsing-seconddesign border-full-third">Email verification is required for high security</p>
                                        </fieldset>
                                        <fieldset class="firstf sss firstf-custom">
                                            <legend>Low Security</legend>
                                            <button data-id="@item.id" onclick="SecurityChange()" type="button" class="btn btn-firstwhite-second">
                                                <img src="~/img/green-right.svg" alt="Right Arrow image" style="width:37px;" />
                                                <span>Active </span>
                                            </button>
                                            <p class="dmlsing-seconddesign border-full-third">No more security required, then send password to mobile</p>
                                        </fieldset>
                                    }
