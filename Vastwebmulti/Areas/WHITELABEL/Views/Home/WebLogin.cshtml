            <div class="col-md-12">
                <div class="card">
                    <div class="col-md-6">
                        <div style="margin-left:-13px;">
                            @Html.Partial("_Loginmenu")
                        </div>

                    </div>
                    <div class="col-md-6">
                        @using (Html.BeginForm("WebLogin", "Home", FormMethod.Post))
                        {
