    $("#txtnewemail").blur(function () {
        var emails = $('#txtnewemail').val();
        var testEmail = /^[A-Z0-9._%+-]+@@([A-Z0-9-]+\.)+[A-Z]{2,4}$/i;
       // var confirm = $('#txtconfemail').val();
        if (!testEmail.test(emails)) {

            $('#errorshow').html('<b>Not Valid Formate of Email </b>')
            $("#btnChangeemailmobile").prop('disabled', true);
        }
        else {
            $('#errorshow').text('');

            $("#txtconfemail").focus();
            $("#btnChangeemailmobile").prop('disabled', false);
        }

    });




    ///handle mobile validation digit


     $("#txtnewmob").blur(function () {
        var txtnewmob = $('#txtnewmob').val();
        var testmob = /^\d*(?:\.\d{1,2})?$/;
       // var confirm = $('#txtconfemail').val();
         if (txtnewmob.length == 10 && testmob.test(txtnewmob)) {
              $('#errorshowmob').text('');

            $("#txtcommob").focus();
             $("#btnchangemobile").prop('disabled', false);
         }
        else {

              $('#errorshowmob').html('<b> Mobile Formate Wrong </b>')
            $("#btnchangemobile").prop('disabled', true);
        }

});


