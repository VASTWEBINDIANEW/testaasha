                            <div id="Statussetting">
                                @foreach (var item in ViewBag.setting)
                                {

                                    if (item.highsecurity == true)
                                    {

                                        <fieldset class="firstf fff">
                                            <legend>High Security</legend>
                                            <button data-id="@item.id" onclick="SecurityChange()" type="button" class="btn btn-firstwhite-second">
                                                <img src="~/img/green-right.svg" alt="Right Arrow image" style="width:37px;" />
                                                <span>Active </span>
                                            </button>
                                            <p class="dmlsing-seconddesign border-full-third">Email verification is required for high security</p>
                                        </fieldset>
                                        <fieldset class="secondf sss">
                                            <legend>Low Security</legend>
