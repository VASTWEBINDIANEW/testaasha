                            <li class="tab-link " onclick="tabopen('for-RET')" data-tab="tab-2">Change Login ID</li>
                            <li class="tab-link " onclick="tabopen('for-Distr')" data-tab="tab-3">
                                <i class="fa fa-ban" aria-hidden="true"></i>&nbsp;Block Login
                            </li>
                        </ul>
                    </div>
