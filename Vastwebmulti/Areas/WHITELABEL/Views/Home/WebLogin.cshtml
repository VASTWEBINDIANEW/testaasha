@model Vastwebmulti.Areas.WHITELABEL.Models.Whitelabel_BlockUserViewModel
@{
    ViewBag.Title = "WebLogin";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }

    .select2-selection.select2-selection--single {
        border-radius: 0px !important;
        height: 32px !important;
        border-color: #ccc !important;
    }

    .custom-district1::before {
        border-color: #888 transparent transparent transparent;
        border-style: solid;
        border-width: 5px 4px 0 4px;
        height: 0;
        right: 7px;
        position: absolute;
        top: 13px;
        content: '';
    }

    .custom-district1 {
        position: relative;
    }

    .OpertorIndex-page .oprindex-right input#txt_frm_date {
        padding-left: 25px;
    }

    #webloginhis tr td p, #APPloginhis tr td p {
        margin-bottom: 0px;
    }

    .table-bordered thead tr th {
        padding: 5px;
    }

    .web_login_page .tab-under-ul ul {
        width: 100%;
    }

        .web_login_page .tab-under-ul ul li {
            margin-right: 2px;
        }

    @@media screen and (max-width:766px) {
        .web_login_page .tab-under-ul .weblogn-admin-firsttab li:nth-child(1), .web_login_page .tab-under-ul .weblogn-admin-firsttab li:nth-child(2), .web_login_page .tab-under-ul .weblogn-admin-firsttab li:nth-child(3) {
            width: 32% !important;
            float: left;
            margin-bottom: 5px;
        }

        .web_login_page .tab-under-ul .weblogn-admin-firsttab li:nth-child(4), .web_login_page .tab-under-ul .weblogn-admin-firsttab li:nth-child(5) {
            width: 49% !important;
            float: left;
            margin-bottom: 5px;
        }

        .web_login_page .tab-under-ul .weblogn-admin-firsttab li:nth-child(6) {
            width: auto !important;
            margin: 0px !important;
        }

        .web_login_page .tab-under-ul .weblogn-admin-firsttab li:nth-child(7) {
            width: auto !important;
        }
    }

    #leftmenu > li.current {
        color: #fff !important;
        background-image: linear-gradient(to right, #78c778, #e63b3b) !important;
    }

    #leftmenu > li {
        color: #222325 !important;
        background-color: aliceblue !important;
        border-right: 2px solid #e4e4e4 !important;
    }

    /*#rightmenu > li.current2 {
        color: #fff !important;
        background-image: linear-gradient(to right, #78c778, #e63b3b) !important;
    }

    #rightmenu > li {
        color: #222325 !important;
        background-color: aliceblue !important;
        border-right: 2px solid #e4e4e4 !important;
    }*/

    /*.web_login_page .Weblogin-left .web-just-bottom {
        background: aliceblue !important;
    }*/
</style>
<section class="content web_login_page OpertorIndex-page">
    <div class="container-fluid">

        <div class="page-header-third pageheader-margin-third">
            <div class="bread-same-all-page breadsameall-second">
