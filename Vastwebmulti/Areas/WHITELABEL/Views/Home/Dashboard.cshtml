               "<td><p style='padding-top:3px;'>Financial Services</p> </td>" +
               "<td><p style='padding-top:3px;'>" + x.Moneytransfer + "</p></td>" + "</tr>" +
                 "<tr>" +
                "<td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='material-icons' style='color:#FF9800;'>fingerprint</i></p></td>" +
               "<td><p style='padding-top:3px;'>Aeps Services</p> </td>" +
               "<td><p style='padding-top:3px;'>" + x.Aeps + "</p></td>" + "</tr>" +
                "<tr>" +
                "<td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='fa fa-id-card' aria-hidden='true' style='color:#000000;'></i></p></td>" +
               "<td><p style='padding-top:3px;'>Pancard</p> </td>" +
               "<td><p style='padding-top:3px;'>" + x.Pancard + "</p></td>" + "</tr>" +
                "<tr>" +
                "<td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='fa fa-plane' style='color:#4CAF50;'></i></p></td>" +
               "<td><p style='padding-top:3px;'>Travel</p> </td>" +
               "<td><p style='padding-top:3px;'>" + 0.00+ "</p></td>" + "</tr>" +
                "<tr>" +
                "<td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='fa fa-gift' style='color:#F44336;'></i></p></td>" +
               "<td><p style='padding-top:3px;'>Gift Cards </p></td>" +
               "<td><p style='padding-top:3px;'>" + 0.00 + "</p></td>"
                 + "</tr>" +
                "<tr>" +
                "<td style='border-right:1px solid #eeeeee;'><p style='font-size:20px;margin-top:-5px'><i class='fa fa-cart-plus' style='color:#555;'></i></p></td>" +
               "<td><p style='padding-top:3px;'>E-Commerce</p> </td>" +
                 "<td><p style='padding-top:3px;'>" + 0.00 + "</p></td>"
                 + "</tr>";
                    $('#tabletoday').append(newRow);
                    $("#donut_chart").empty();
                    var rechargebillamt = x.Recharge;
                    var moneytransferamt = x.Moneytransfer;
                    var Aepsamt = x.Aeps;
                    var pancardamount = x.Pancard;
                    initDonutChart(rechargebillamt, moneytransferamt, Aepsamt, pancardamount);


            },
            error: function (data) {

            }
        });
        return true;

     }
</script>
<!-- Doughnut Chart -->
<script type="text/javascript">
    function initDonutChart(rechargebill, moneytrasfer, Aepsamt, pancardamount) {

        var rechargeandbill = rechargebill;
        var Financial = moneytrasfer;
        var aeps = Aepsamt;
        var Pancard = pancardamount;
        var Travel = 0.00
        var GiftCards = 0.00
        var ECommerce = 0.00

        Morris.Donut({
            element: 'donut_chart',

            data: [
                {
                    label: 'Recharge & bill',
                    value: rechargeandbill,
                },
                {
                    label: 'Financial',
                    value: Financial
                },
                {
                    label: 'Aeps',
                    value: aeps
                },
                {
                    label: 'Pancard',
                    value: Pancard
                },
                {
                    label: 'Travels',
                    value: Travel
                },
                {
                    label: 'Gift Cards',
                    value: GiftCards,
                },
                {
                    label: 'E-Commerce',
                    value: ECommerce
                }
            ],

            colors: [
                'rgb(233, 30, 99)',
                'rgb(0, 128, 255)',
                'rgb(255, 152, 0)',
                'rgb(0, 0, 0)',
                'rgb(76, 175, 80)',
                'rgb(255, 0, 0)',
                'rgb(128, 128, 128)'],

            formatter: function (y) {
                return y
            }
        });

    }
</script>

