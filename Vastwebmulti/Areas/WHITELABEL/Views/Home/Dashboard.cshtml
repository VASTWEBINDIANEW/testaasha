}
<style>
    .img-responsive, .thumbnail > img, .thumbnail a > img, .carousel-inner > .item > img, .carousel-inner > .item > a > img {max-width: 49%;}
    .admin-tabs .col-lg-2.col-md-2 {width: 20%;}
    .fullbodydycolorbg{background-image: linear-gradient(to right , @PageData["Globalfirst"], @PageData["GlobalSecond"]) !important;}
    .all-tabels-right li {width: 33%;float: left;margin: 0 !important;border: 0;background: none !important;}
    .all-tabels-right li:nth-child(2){width: 34%;}
    .all-tabels-right li:nth-child(2) a{margin: 0px 5px;}
    .all-tabels-right li a{padding: 10px 0px !important;margin: 0;background-color: @PageData["GlobalSecond"] !important;}
    .all-tabels-right li.active a ,.all-tabels-right li a:hover ,.all-tabels-right li.active a:hover, .all-tabels-right li.active a:focus{background-color: @PageData["Globalfirst"] !important;}
    .all-tabels-right li a span, .all-tabels-right li.active a span{color: #fff !important;}
    .white-dash-link{border-top: 2px solid @PageData["Globalfirst"];border-left: 2px solid @PageData["Globalfirst"];border-right: 2px solid @PageData["GlobalSecond"];border-bottom: 2px solid @PageData["GlobalSecond"];margin-top: 10px;}
    .white-dash-link .col-md-3.col-sm-3.col-xs-3 {padding: 15px;}
    .white-dash-link .col-md-3.col-sm-3.col-xs-3 button:hover::after{-webkit-transform: /*translateX(68%)*/ translateY(-25%) rotate(45deg);transform: /*translateX(68%)*/ translateY(-25%) rotate(45deg);}
    .white-dash-link .col-md-3.col-sm-3.col-xs-3 button::after{content: "";position: absolute;left: 0;top: 0;height: 490%;width: 140%;background: @PageData["Globalfirst"];-webkit-transition: all .5s ease-in-out;transition: all .5s ease-in-out;-webkit-transform: translateX(-189%) translateY(-25%) rotate(45deg);transform: translateX(-189%) translateY(-25%) rotate(45deg);}
    .all-tabels-right li a .fa.fa-newspaper-o, .all-tabels-right li a .fa.fa-calendar-check-o{color:#fff !important;}
    .td-border-none td {border: 0 !important;}
    .admin-tabs .col-lg-2.col-md-2 i {background-image: linear-gradient(to right , @PageData["Globalfirst"], @PageData["GlobalSecond"]) !important;}
    @@media only screen and (max-width: 992px) {
        .profile-setting {width: 33%;}
    }
    @@media only screen and (max-width: 767px) {
        .profile-setting {width: 25%;}
        .admin-tabs .col-lg-2.col-md-2.col-sm-6.col-xs-6 {width: 50%;}
    }
    @@media only screen and (max-width: 520px) {
        .profile-setting {width: 33%;}
    }
</style>
