<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.1/css/toastr.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.1/js/toastr.js"></script>
<script src="~/Ckeditor/ckeditor.js"></script>
<script src="~/Ckeditor/adapters/jquery.js"></script>
<script type="text/javascript">
    CKEDITOR.replace('txtedit');
</script>

<section class="content outside-logo-page">
    <div class="container-fluid">
        <div class="bread-same-all-page">
            <ul>
                <li class="smli">
                    <a href="@Url.Action("Dashboard", "Home")" class="fullbodydycolorbg tmw-total-color-one">
                        Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                    </a>
                </li>
                <li class="fullbodydycolorbg tmw-total-color-one">
                    <a href="@Url.Action("Dashboard", "Home")#setting" class="fullbodydycolorbg tmw-total-color-one">
                        Basic Setting&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                    </a>
                </li>
                <li class="fullbodydycolorbg tmw-total-color-one">
                    Logo&nbsp;&&nbsp;Theme
                </li>
                <button style="float: right;color: #fff;border: 0;padding: 5px 15px;margin-top: -4px;" class="fullbodydycolorbg" data-toggle="modal" data-target="#defaultModal3">about-us content</button>
            </ul>
        </div>


        <div class="modal fade sitemap-editor" id="defaultModal3" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header" style="background-color:whitesmoke;">
                        <h4 class="modal-title" id="defaultModalLabel" style="color:black;">Add About Us Content</h4>
                        <button type="button" class="btn bg-grey waves-effect" style="float:right; height:auto;padding: 0px;background-color: #f5f5f5 !important;padding: 0px;border:0px;" data-dismiss="modal">
                            <i class="fa fa-times fulltextbodycolor fullbodydycolorbg" aria-hidden="true" style="top: 0px;height: 30px;width: 30px;border-radius: 50%;padding-top: 4px;"></i>
                        </button>
                    </div>
                    <div class="modal-body" style="margin-top:0px;">
                        <div class="body">
                            @using (Ajax.BeginForm("AboutUsContext", "Home", new AjaxOptions
                            {
                                HttpMethod = "POST",
                                InsertionMode = InsertionMode.Replace,
                                OnSuccess = "OnSuccess",
                                OnFailure = "OnFailure"
                            }))
                            {
                                Vastwebmulti.Areas.WHITELABEL.Models.JsonFile.AboutUs person = new Vastwebmulti.Areas.WHITELABEL.Models.JsonFile.AboutUs();

                                <div class="row clearfix">
                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #c7c2c2;">

                                                <input type="hidden" asp-for="@person.AboutId" name="AboutId" value="1" />
                                                <br />
                                                <br />
                                                <textarea id="txtedit" asp-for="@person.AboutContent" name="AboutContent" class="ckeditor" required></textarea>
                                                <br />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer" id="silder1">
                                    <button type="submit" id="savePrivacy" class="btn bg-grey waves-effect" style=" margin-right: 12px; height:34px;">
                                        <span style="color:black;">Save Change</span>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>


        <div class="row clearfix">

            <div class="col-md-12 hgyturopo">
                <div class="row clearfix">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                        <div class="card">
                            <div class="logo-change" style="margin-top:0px;">
                                <h2>
                                    Login Page Logo Image
                                </h2>
                                <div class="image-upload">
                                    <input type="file" name="files" id="LoginPageLogo" class="form-control">
                                    <input type="submit" value="Save Change" class="for-disable" id="btnaaa" style="font-size:14px; padding: 6px 15px;height: 32px !important;background: #f0f0f0 !important;border: 1px solid #555;" />
                                </div>
                            </div>

                            <div class="body">
                                <div class="row">
                                    <div class="table-responsive" style="position:inherit;margin-top:-20px;">
                                        <table class="table table-bordered table-striped table-hover dataTable js-exportable ">
                                            <tbody id="loginlogo">
                                                @if (ViewBag.login != null)
                                                {
                                                    foreach (var item in ViewBag.login)
                                                    {
                                                        <tr>
                                                            <td> <img src="@Url.Content("~/"+item.Image)" width="100" height="70" id="LoginPageLogoImg" /></td>
                                                            <td>
                                                                <p><strong>Note :-</strong> For Best Veiw, Logo Size Must Be required 300 pixel * 300 pixel</p>
                                                                <div style="float:right;clear:both;">
                                                                    <button type="button" class="btn btn-default waves-effect" style="background-color:transparent; border:none;border:1px solid #c7c2c2;" onclick="delLoginContent1('@item.Id')">
                                                                        Delete
                                                                    </button>
                                                                    <a id="LoginPageLogoTab" href="@Url.Content("~/"+item.Image)" target="_blank"><button type="button" class="btn btn-default waves-effect" style="border:1px solid #c7c2c2;">Open Link In New Tab</button></a>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

                <div class="row clearfix">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-2px;">
                        <div class="card">
                            <div class="logo-change">
                                <h2>
                                    Header Logo Image
                                </h2>
                                <h2 class="header-logo-background" style="margin-left:10%;">Header Logo Background</h2>
                                <div class="image-upload">
                                    <input type="file" name="file" id="HeaderLogo" class="form-control">

                                    <button type="submit" id="HeaderLogoBtn" class="btn bg-grey waves-effect for-disable" onclick="return check()">
                                        <span>Save Change</span>
                                    </button>

                                </div>
                            </div>
                            <div class="body">
                                <div class="row">
                                    <div class="table-responsive" style="position:inherit;margin-top:-20px;">
                                        <table class="table table-bordered table-striped table-hover dataTable js-exportable ">
                                            @if (ViewBag.logoHeaderimage != null)
                                            {
                                                <tbody>
                                                    @foreach (var item in ViewBag.logoHeaderimage)
                                                    {
                                                        <tr>
                                                            <td> <img id="LogoHeaderImg" src="@Url.Content("~/" + item.LogoImage)" width="100" height="70" /></td>
                                                            <td style="text-align:center;">

                                                                <span style="width: 100px;height: 70px;display: inline-block;border: 1px solid var(--border-color);background:#fff;">
                                                                    <label class="container">

                                                                        <input type="radio" checked="checked" name="radio" value="#fff">
                                                                        <span class="checkmark"></span>
                                                                    </label>
                                                                    <p style="margin:0px;margin-top:30px;">White</p>
                                                                </span>
                                                                <span style="width: 100px;height: 70px;display: inline-block;border: 1px solid var(--border-color);">
                                                                    <label class="container">

                                                                        <input type="radio" name="radio" value="transparent">
                                                                        <span class="checkmark"></span>
                                                                    </label>
                                                                    <p style="margin:0px;margin-top:30px;"> Transparent</p>
                                                                </span>
                                                                <span style="width: 100px;height: 70px;display: inline-block;border: 1px solid var(--border-color);background:#000;">
                                                                    <label class="container">

                                                                        <input type="radio" name="radio" value="#000">
                                                                        <span class="checkmark"></span>
                                                                    </label>
                                                                    <p style="margin:0px;margin-top:30px;color:#fff;">Black</p>
                                                                </span>
                                                            </td>
                                                            <td>
                                                                <p><strong>Note :-</strong> For Best Veiw, Logo Size Must Be required 170 pixel * 80 pixel</p>
                                                                <div style="float:right;clear:both;">

                                                                    <button type="button" class="btn btn-default waves-effect" style="background-color:transparent; border:none;border:1px solid #c7c2c2;" onclick="delLogo1('@item.Id')">
                                                                        Delete
                                                                    </button>
                                                                    <a id="LogoHeaderTab" href="@Url.Content("~/" + item.LogoImage)" target="_blank"><button type="button" class="btn btn-default waves-effect" style="border:1px solid #c7c2c2;">Open Link In New Tab</button></a>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            }
                                        </table>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

                <div class="row clearfix">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-2px;">
                        <div class="card">
                            <div class="logo-change">
                                <h2>
                                    Favicon Image
                                </h2>
                                <div class="image-upload">

                                    <input type="file" name="file" class="form-control" id="faviconfile">

                                    <button type="submit" class="btn bg-grey waves-effect for-disable" onclick="return check()" id="faviconBtn">
                                        <span>Save Change</span>
                                    </button>
                                </div>
                            </div>
                            <div class="body">
                                <div class="row">
                                    <div class="table-responsive" style="position:inherit;margin-top:-20px;">
                                        <table class="table table-bordered table-striped table-hover dataTable js-exportable ">

                                            <tbody>
                                                @foreach (var item1 in ViewBag.faviconimage)
                                                {
                                                    <tr>
                                                        <td> <img id="faviconImg" src="@Url.Content("~/"+item1.faviconimage)" width="100" height="70" /></td>
                                                        <td>
                                                            <p><strong>Note :-</strong> For Best Veiw, Logo Size Must Be required 32 pixel * 32 Pixel</p>
                                                            <div style="float:right;clear:both;">
                                                                <button type="button" class="btn btn-default waves-effect" style="background-color:transparent; border:none;border:1px solid #c7c2c2;" onclick="delfavico('@item1.Id')">
                                                                    Delete
                                                                </button>
                                                                <a id="faviconTab" href="@Url.Content("~/"+item1.faviconimage)" target="_blank"><button type="button" class="btn btn-default waves-effect" style="border:1px solid #c7c2c2;">Open Link In New Tab</button></a>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>


                <div class="row clearfix login-bg-sitting">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 " style="margin-top:18px;">
                        <div class="card login-back-img">
                            <h2>Login Page Background Setting</h2>
                            <ul class="" for="retailer">

                                <li class="tab-link2 current2" data-tab="tab-5">
                                    <div class="background-view-first">

                                        <input type="radio" value="value1" name="group1" onclick="Img_ON_OffDefault()" id="byapi1">
                                        <label for="byapi1">Background</label>
                                        <p>Color</p>
                                    </div>
                                    <div class="background-view fullbodydycolorbg"></div>
                                    <div class="background-view-third">
                                        <p style="font-size: 18px;text-align: justify;">This is default color you can't change. You are not intersted to use this color then can use next two options.</p>

                                    </div>
                                </li>
                                <li class="tab-link2" data-tab="tab-6" id="imgg2">
                                    <div class="background-view-first">

                                        <input type="radio" onclick="Img_ON_Off()" value="value3" name="group1" id="bysim2">

                                        <label for="bysim2">Single Image</label>
                                        <span style="display:block;">(file Size Upto 824kb)</span>
                                    </div>
                                    @if (ViewBag.showimg3 != null)
                                    {
                                        <div style="background-repeat:no-repeat">

                                            <img class="background-view" id="img1" name="img1" src="@Url.Content("~/"+ ViewBag.showimg3)" />

                                        </div>
                                    }
                                    else
                                    {
                                        <div style="background-repeat:no-repeat">

                                            <img class="background-view" id="img1" name="img1" src="@Url.Content("~/"+ ViewBag.showimg3)" />
                                        </div>
                                    }
                                    <div class="background-view-third">
                                        <div class="background-view-third-one">
                                            <input type="file" id="fileInputSingle" multiple />
                                            <button type="button" class="for-disable" id="fileButtonSingle" value="Single">Save</button>
                                            <span><strong>Note :- </strong>Image Max Size 1600 * 900 Pixel</span>
                                            <label id="Single1"></label>
                                        </div>
                                        <div class="background-view-third-two">
                                            <button type="button" id="delBackLogin_ContentSingle">Delete</button>
                                            @if (ViewBag.showimg3 != null)
                                            {
                                                <a id="fileInputSingleTab" href="@Url.Content("~/" + ViewBag.showimg3)" target="_blank"><button type="button">Open Link In New Tab</button></a>
                                            }
                                            else
                                            {
                                                <a id="fileInputSingleTab" href="#" target="_blank"><button type="button">Open Link In New Tab</button></a>
                                            }
                                        </div>
                                    </div>
                                </li>
                                <li class="tab-link2" data-tab="tab-7" id="imgg3">

                                    <div class="background-view-first">

                                        <input type="radio" onclick="Img_ON_Off2()" value="value2" name="group1" id="bysim1">

                                        <label for="bysim1">Repeat Image</label>

                                        <span style="display:block;">(file Size Upto 224kb)</span>
                                    </div>
                                    @if (ViewBag.showimg2 != null)
                                    {
                                        <div id="mydiv">
                                            <div class="background-view" id="img2" name="img2" style="background:url('@Url.Content("~/" + ViewBag.showimg2)')repeat;">

                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="background-view" id="img2" name="img2">

                                        </div>
                                    }
                                    <div class="background-view-third">
                                        <div class="background-view-third-one">
                                            <input type="file" id="fileInput" multiple />
                                            <button type="button" class="for-disable" id="fileButton" value="Repeat">Save</button>
                                            <span><strong>Note :- </strong>Image Max Size 300 * 300 Pixel</span>
                                            <label id="Repeat1"></label>
                                        </div>
                                        <div class="background-view-third-two">
                                            <button type="button" id="delBackLogin_ContentRepeat">Delete</button>
                                            @if (ViewBag.showimg2 != null)
                                            {
                                                <a id="RepeatTab" href="@Url.Content("~/" + ViewBag.showimg2)" target="_blank"><button type="button">Open Link In New Tab</button></a>
                                            }
                                            else
                                            {
                                                <a id="RepeatTab" href="#" target="_blank"><button type="button">Open Link In New Tab</button></a>
                                            }
                                        </div>

                                    </div>

                                </li>
                            </ul>
                        </div>
                    </div>
                </div>



