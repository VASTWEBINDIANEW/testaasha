
@{
    ViewBag.Title = "Outside_logo";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}

<style>
    .scroll {
        width: 100%;
        max-height: 530px;
        overflow: auto;
    }

    .outside-logo-page .table.dataTable tr td {
        border-top-width: 0px;
    }

    .outside-logo-page .table-responsive {
        background: #f9f9f9;
    }

    table.dataTable {
        margin-top: 10px !important;
        margin-bottom: 10px !important;
    }

    .scroll::-webkit-scrollbar {
        width: 4px;
    }

    .scroll::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.3);
        border-radius: 10px;
    }

    .scroll::-webkit-scrollbar-thumb {
        border-radius: 10px;
        -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.5);
    }




    .toast-top-right1 {
        top: 65px;
        left: 81%;
    }

    .background-view-slider img {
        width: 100%;
        height: 188px;
    }

    .background-view-third-one input {
        margin-left: 33%;
    }

    .login-slider-status label::after {
        content: '';
        border-left: 11px solid #000;
        border-bottom: 10px solid transparent;
        border-top: 11px solid transparent;
        width: 10px;
        height: 12px;
        display: inline-block;
        position: absolute;
        right: -11px;
        top: 0px;
    }
    .table-responsive {
        border-left: 25px solid #ddd;
        border-bottom: 25px solid #c7c7c7;
        border-top: 25px solid #c7c7c7;
        border-right: 25px solid #ddd;
        margin-top: 0 !important;
    }
    .outside-logo-page .table.dataTable tr td:last-child p {
        border: 1px solid #555;
    }
    .login-bg-sitting {
        border-left: 25px solid #ddd;
        border-bottom: 25px solid #c7c7c7;
        border-top: 25px solid #c7c7c7;
        border-right: 25px solid #ddd;
        margin: 0 !important;
    }
    .login-back-img ul li {
        border: 1px solid #555 !important;
        padding: 15px;
    }
    @@media only screen and (max-width:992px) {
        .background-view-third-one input {
            margin-left: 0;
            width: 150px;
        }
    }
    @@media only screen and (max-width:767px) {
        .background-view-third-one,.background-view-third-two{
            margin:10px 0px;
        }
        .background-view-third-one span {
            margin-top: 0;
        }
        .background-view-first, .background-view {
            width: 50%;
            float: left;
            margin: 0;
        }
        .background-view-third {
            width: 100%;
        }
        .background-view-third-one input{width: 35%;}
        .col-md-12.hgyturopo {
            width: 100%;
            float: left;
        }
        }
    @@media only screen and (max-width:480px) {
        .image-upload #btnaaa {
            float: right;
        }

        .table-responsive .table-bordered tr td img {
            max-width: 100px !important;
        }

        .background-view-third-one input {
            width: 50%;
        }

        .image-upload input[type="file"], .image-upload input[type="text"] {
            float: left !important;
            width: 55% !important;
        }

        .image-upload {
            float: left;
            margin-top: 10px;
            width: 100%;
        }

        .table-responsive, .login-bg-sitting {
            border-left: 5px solid #ddd;
            border-bottom: 5px solid #c7c7c7;
            border-top: 5px solid #c7c7c7;
            border-right: 5px solid #ddd;
        }

        .logo-change h2 {
            margin: 0 5px !important;
            float: left !important;
        }

        .background-view-third-one span {
            margin-top: 10px;
            float: left;
            text-align: left;
        }

        .background-view-first, .background-view {
            width: 100%;
            text-align: center;
        }

        .login-back-img [type="radio"]:checked + label::after, .login-back-img [type="radio"]:not(:checked) + label::before, .login-back-img [type="radio"]:not(:checked) + label::after  {
            left: 0;
            right: 0;
            margin: 0 auto;
        }
        .background-view-third-two button{padding: 0 7px;}
        .background-view-third-one, .background-view-third-two {
            margin: 10px 0px;
            text-align: left;
        }
        .background-view-third{padding: 0;}
        .background-view-third-one, .background-view-third-two {
            margin: 10px 0px 0 0;
            text-align: left;
        }
        }
</style>
<style>

    .container {
        display: block;
        position: relative;
        padding-left: 35px;
        margin-bottom: 12px;
        cursor: pointer;
        font-size: 22px;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
    }


        .container input {
            position: absolute;
            opacity: 0;
            cursor: pointer;
        }

    .checkmark {
        position: absolute;
        top: 3px;
        left: 35%;
        height: 25px;
        width: 25px;
        background-color: var(--border-color);
        border-radius: 50%;
    }


    .container:hover input ~ .checkmark {
        background-color: #ccc;
    }


    .container input:checked ~ .checkmark {
        background-color: green;
    }


    .checkmark:after {
        content: "";
        position: absolute;
        display: none;
    }


    .container input:checked ~ .checkmark:after {
        display: block;
    }


    .container .checkmark:after {
        top: 8px;
        left: 6px;
        width: 14px;
        height: 7px;
        border-bottom: 2px solid #fff;
        border-left: 2px solid #fff;
        transform: rotate(-45deg);
    }


