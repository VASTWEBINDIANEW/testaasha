<script>
    function SliderStatus() {

                $.ajax({
                    url: '@Url.Action("LoginSilderIsStatus","Home")',
                    type: 'GET',
                    success: function (response) {

                        if (response === 'Success') {
                            $('#statusOff').show();//.addClass('custom-off')
                            $('#statusOn').hide();
                            ToastrMessage();
                            toastr.error('Login Slider Status Off');
                        }
                        else if (response === 'Failed') {
                            $('#statusOff').hide();
                            $('#statusOn').show();//.addClass('custom-on')
                            ToastrMessage();
                            toastr.success('Login Slider Status On');

                        }
                        else {
                            $('#statusNULL').show()//.addClass('custom-off');
                            $('#statusOff').hide();
                            ToastrMessage();
                            toastr.error('Login Slider Status Off');

                        }
                    }
                });
    }

</script>

