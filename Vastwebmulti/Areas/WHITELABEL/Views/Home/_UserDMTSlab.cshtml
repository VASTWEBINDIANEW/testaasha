                              @Html.ValidationMessageFor(a => a.WUpdateDealer[i].comm_3000)
                          </td>
                          <td>
                              @Html.TextBoxFor(a => a.WUpdateDealer[i].comm_4000, new { @style = "width:100%" })
                              @Html.ValidationMessageFor(a => a.WUpdateDealer[i].comm_4000)
                          </td>
                          <td>
                              @Html.TextBoxFor(a => a.WUpdateDealer[i].comm_5000, new { @style = "width:100%" })
                              @Html.ValidationMessageFor(a => a.WUpdateDealer[i].comm_5000)
                          </td>
                          @*<td>
                            @Html.TextBoxFor(a => a.UpdateDealer[i].gst, new { @style = "width:100%" })
                            @Html.ValidationMessageFor(a => a.UpdateDealer[i].gst)
                        </td>*@

                      </tr>
                  }
              }
              <!--End Dealer User-->
              <!--Retailer User Update-->
              @if (Model.WRetaileruser != null)
                {
                    for (int i = 0; i < Model.WUpdateRetailer.Count; i++)
                    {
                      <tr>
                          @Html.HiddenFor(a => a.WUpdateRetailer[i].idno)

                          <td>
                              <p>All</p>
                          </td>
                          <td>
                              @Html.TextBoxFor(a => a.WUpdateRetailer[i].verify_comm)
