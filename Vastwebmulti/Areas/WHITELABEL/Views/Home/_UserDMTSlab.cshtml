                            <td>
                                @Html.DisplayFor(a => a.WRetaileruser[i].comm_1000)

                            </td>
                            <td>
                                @Html.DisplayFor(a => a.WRetaileruser[i].comm_2000)

                            </td>
                            <td>
                                @Html.DisplayFor(a => a.WRetaileruser[i].comm_3000)

                            </td>
                            <td>
                                @Html.DisplayFor(a => a.WRetaileruser[i].comm_4000)

                            </td>
                            <td>
                                @Html.DisplayFor(a => a.WRetaileruser[i].comm_5000)

                            </td>
                            @*<td>
                                @Html.DisplayFor(a => a.WRetaileruser[i].gst)

                            </td>*@
                        </tr>

                    }
                }
                <!--End Retailer-->
                               
            </tbody>
            <tbody id="tbodyedit" style="display:none;">
          
                <!--Dealer User-->

                @if (Model.WDealeruser != null)
                {
                    for (int i = 0; i < Model.WDealeruser.Count; i++)
                    {
                        <tr>
                            @Html.HiddenFor(a => a.WDealeruser[i].RolesName)
                            @Html.HiddenFor(a => a.WDealeruser[i].idno)
                            @Html.HiddenFor(a => a.WDealeruser[i].whitelabelid)
                            <td>
                                @Html.DisplayFor(a => a.WDealeruser[i].Email)
                            </td>
                            <td>
                                @Html.EditorFor(a => a.WDealeruser[i].verify_comm, new { htmlAttributes = new { @style = "width:100%" } })
                                @Html.ValidationMessageFor(a => a.WDealeruser[i].verify_comm)
                            </td>
                            <td>
                                @Html.EditorFor(a => a.WDealeruser[i].comm_1000, new { htmlAttributes = new { @style = "width:100%" } })
                                @Html.ValidationMessageFor(a => a.WDealeruser[i].comm_1000)
                            </td>
                            <td>
                                @Html.EditorFor(a => a.WDealeruser[i].comm_2000, new { htmlAttributes = new { @style = "width:100%" } })
                                @Html.ValidationMessageFor(a => a.WDealeruser[i].comm_2000)
