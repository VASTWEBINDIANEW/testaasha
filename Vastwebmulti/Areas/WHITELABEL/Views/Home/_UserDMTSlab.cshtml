                                @Html.ValidationMessageFor(a => a.WDealeruser[i].comm_4000)
                            </td>
                            <td>
                                @Html.EditorFor(a => a.WDealeruser[i].comm_5000, new { htmlAttributes = new { @style = "width:100%" } })
                                @Html.ValidationMessageFor(a => a.WDealeruser[i].comm_5000)
                            </td>
                            @*<td>
                                @Html.EditorFor(a => a.WDealeruser[i].gst, new { htmlAttributes = new { @style = "width:100%" } })
                                @Html.ValidationMessageFor(a => a.WDealeruser[i].gst)
                            </td>*@
                        </tr>
                    }
