
@{
    ViewBag.Title = "LoginPage_Content";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}
<style>
    .scroll {
        width: 100%;
        max-height: 530px;
        overflow: auto;
    }

        .scroll::-webkit-scrollbar {
            width: 4px;
        }

        .scroll::-webkit-scrollbar-track {
            -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.3);
            border-radius: 10px;
        }

        .scroll::-webkit-scrollbar-thumb {
            border-radius: 10px;
            -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.5);
        }
</style>
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-2">
                <div class="row clearfix">

                    <div class="card">
                        <div class="body scroll" style="max-height:572px;">
                            <div class="demo-button ">
                                <div class="row">
                                    <div class="col-md-12">
                                        @Html.Partial("ColorPartialView")
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
            <div class="col-md-10">
                <div class="row">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 " style="margin-top:18px;">
                        <div class="card login-back-img" id="fistDiv">
                            <h2>Whitelabel Login Image Details </h2>
                            <ul class="" for="retailer">

                                <li class="tab-link2" data-tab="tab-6" id="imgg2">

                                    <div class="background-view-first">

                                        <input type="radio" value="value4" name="group4" id="bysim5" checked>

                                        <label for="bysim5">Single Image</label>
                                        <span style="display:block;">(file Size Upto 824kb)</span>
                                    </div>
                                    <div style="background-repeat:no-repeat">
                                        @if (ViewBag.login != null)
                                        {
                                            foreach (var item in ViewBag.login)
                                            {
                                                <img class="background-view" id="img1" name="img1" src="@Url.Content("~/" + item.Image)">
                                            }
                                        }
                                    </div>
                                    <div class="background-view-third">
                                        <div class="background-view-third-one">
                                            @*@using (Html.BeginForm("LoginPage_Content", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
                                            {*@
                                                <input type="file" id="LoginImageLogo" name="file">
                                                <button type="submit" id="WhitelabelLoginImageSaveBTN">Save</button>
                                            @*}*@
                                            <span><strong>Note :- </strong>Image Max Size 500 * 500 Pixel</span>
                                            <label id="Single1"></label>
                                        </div>
                                        <div class="background-view-third-two">
                                            @if (ViewBag.login != null)
                                            {
                                                foreach (var item in ViewBag.login)
                                                {
                                                    <input type="hidden" id="HDIdno" value="@item.Id"/>
                                                    <button type="button" id="delimg1" onclick="delimg1()">Delete</button>

                                                    <a id="WhitelabelLoginImage" href="@Url.Content("~/" + item.Image)" target="_blank"><button type="button">Open Link In New Tab</button></a>
                                                }
                                            }
                                        </div>
                                    </div>

                                </li>
                            </ul>
                        </div>
                    </div>
                </div>





                <div class="row">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 " style="margin-top:18px;">
                        <div class="card login-back-img">
                            <h2>Login Page Background Setting</h2>
                            <ul class="" for="retailer">

                                <li class="tab-link2 current2" data-tab="tab-5">
                                    <div class="background-view-first">

                                        <input type="radio" value="value1" name="group1" id="bysim3"  onclick="ColorStatus()">
                                        <label for="bysim3">Background</label>
                                        <p>Color</p>
                                    </div>
                                    <div class="background-view fullbodydycolorbg"></div>
                                    <div class="background-view-third">
                                        <p style="font-size: 18px;text-align: justify;">This is default color you can't change. You are not intersted to use this color then can use next two options.</p>

                                    </div>
                                </li>
                                <li class="tab-link2" data-tab="tab-6" id="imgg2">
                                    <div class="background-view-first">

                                        <input type="radio" value="value3" name="group1" id="bysim2" onclick="SingleStatus()">

                                        <label for="bysim2">Single Image</label>
                                        <span style="display:block;">(file Size Upto 824kb)</span>
                                    </div>
                                    <div style="background-repeat:no-repeat">
                                        @if (ViewBag.BackLogin_Single.Count > 0)
                                        {
                                            foreach (var item in ViewBag.BackLogin_Single)
                                            {
                                                <img class="background-view" id="imgSingle" name="imgSingle" src="@Url.Content("~/" + item.otherimage)">
                                            }
                                        }
                                        else
                                        {
                                            <img class="background-view" id="imgSingle" name="imgSingle" src="/FooterImages/70586db5-f26c-4c19-81a7-08ec6710bef1_1112.png">
                                        }
                                    </div>
                                    <div class="background-view-third">
                                        <div class="background-view-third-one">
                                            <input type="file" id="fileInputSingle" multiple="">
                                            <button type="button" id="fileButtonSingle" value="Single">Save</button>
                                            <span><strong>Note :- </strong>Image Max Size 1600 * 900 Pixel</span>
                                            <label id="Single1"></label>
                                        </div>
                                        <div class="background-view-third-two" id="mydiv1">
                                            @if (ViewBag.BackLogin_Single.Count > 0)
                                            {
                                                foreach (var item in ViewBag.BackLogin_Single)
                                                {
                                                    <a id="imgSingle" href="@Url.Content("~/" + item.otherimage)" target="_blank"><button type="button">Open Link In New Tab</button></a>
                                                }
                                            }
                                            else
                                            {
                                                <button type="button" id="Singleimg" onclick="SingleDel()">Delete</button>
                                                <a id="fileInputSingleTab" href="/FooterImages/70586db5-f26c-4c19-81a7-08ec6710bef1_1112.png" target="_blank"><button type="button">Open Link In New Tab</button></a>
                                            }
                                        </div>
                                    </div>

                                </li>
                                <li class="tab-link2" data-tab="tab-7" id="imgg3">

                                    <div class="background-view-first">

                                        <input type="radio" value="value2" name="group1" id="bysim1" onclick="RepeatStatus()">

                                        <label for="bysim1">Repeat Image</label>

                                        <span style="display:block;">(file Size Upto 224kb)</span>
                                    </div>
                                    <div id="mydiv">
                                        @if (ViewBag.BackLogin_Repeat.Count > 0)
                                        {
                                            foreach (var item in ViewBag.BackLogin_Repeat)
                                            {
                                                <div class="background-view" id="imgRepeat" name="imgRepeat" style="background:url('@Url.Content("~/" + item.otherimage)')repeat;"></div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="background-view" id="imgRepeat" name="imgRepeat" style="background:url('/FooterImages/a8dfeb4a-df05-4fa1-b150-f89be85d7d56_img79.png')repeat;"></div>
                                        }


                                    </div>
                                    <div class="background-view-third">
                                        <div class="background-view-third-one">
                                            <input type="file" id="fileInputRepeat" multiple="">
                                            <button type="button" id="fileButtonRepeat" value="Repeat">Save</button>
                                            <span><strong>Note :- </strong>Image Max Size 300 * 300 Pixel</span>
                                            <label id="Repeat1"></label>
                                        </div>
                                        <div class="background-view-third-two">
                                            @if (ViewBag.BackLogin_Repeat.Count > 0)
                                            {
                                                foreach (var item in ViewBag.BackLogin_Repeat)
                                                {
                                                    <a id="imgRepeat" href="@Url.Content("~/" + item.otherimage)" target="_blank"><button type="button">Open Link In New Tab</button></a>
                                                }
                                            }
                                            else
                                            {
                                                <button type="button" id="Repeatimg" onclick="RepeatDel()">Delete</button>
                                                <a id="RepeatTab" href="/FooterImages/a8dfeb4a-df05-4fa1-b150-f89be85d7d56_img79.png" target="_blank"><button type="button">Open Link In New Tab</button></a>
                                            }
                                        </div>

                                    </div>


                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="defaultModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header navbar" style="position:initial;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:white;">Add Whitelabel Login Image</h4>
            </div>
            @using (Html.BeginForm("LoginPage_Content", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
            {
                <div class="modal-body" style="margin-top:-26px;">
                    <div class="body">
                        <form>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Select Whitelabel Login Front Image</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            <input type="file" name="file" class="form-control">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <p style="color:red;">Image Size will Be :- 300 * 300 Pixel</p>
                                </div>
                            </div>
                            <div class="modal-footer" id="silder1">
                                <button type="submit" class="btn btn-primary waves-effect" onclick="return check()">Save Change</button>
                                <button type="button" class="btn btn-info waves-effect" data-dismiss="modal">CLOSE</button>
                            </div>


                        </form>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<script>
            function val() {
                var vv = document.querySelector('input[name="group"]:checked').value;
                var url = '@Url.Action("LoginImage", "Home")?image=' + vv + '';
                location.href = url;
            }
</script>


<script>

    $("#WhitelabelLoginImageSaveBTN").click(function () {

        var maxFileSize = 824000; // 824 kb
        var fileUpload = $('#LoginImageLogo');
        if (fileUpload.val() == '') {

            alert('Select a File!');
            return false;
        }
        else {
            if (fileUpload[0].files[0].size < maxFileSize) {
                var files = $("#LoginImageLogo").get(0).files;

                var fileData = new FormData();

                for (var i = 0; i < files.length; i++) {
                    fileData.append("LoginImageLogo", files[i]);

                }

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("LoginPage_Content", "Home")',
                    contentType: false,
                    processData: false,
                    data: fileData,
                    success: function (response) {
                        $('#img1').attr('src', "../.." + response[0].Image)
                        $("#HDIdno").val(response[0].Id)
                        $('#LoginImageLogo').val('');
                    },
                    error: function (xhr, status, error) {
                    }
                });
            }
            else {
                alert('File too big !');
            }
        };
    });


        function delimg1() {
        $.ajax({
            type: "POST", url: '@Url.Action("delLoginContent1", "Home")', data: { Id: $("#HDIdno").val() }, dataType: 'json', cache: false, success: function (result) {
                if (result == "Success") {
                    $("#HDIdno").val('')
                    $('#img1').attr('src', "")
                }
                else {
                }
            }
        });
    }
</script>
<script>

    $("#fileButtonSingle").click(function () {
        var maxFileSize = 824000; // 824 kb
        var fileUpload = $('#fileInputSingle');
        if (fileUpload.val() == '') {

            alert('Select a File!');
            return false;
        }
        else {
            if (fileUpload[0].files[0].size < maxFileSize) {
                var files = $("#fileInputSingle").get(0).files;

                var fileData = new FormData();

                for (var i = 0; i < files.length; i++) {
                    fileData.append("fileInputSingle", files[i]);

                }

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("BackLogin_Single", "Home")',
                    contentType: false,
                    processData: false,
                    data: fileData,
                    success: function (response) {
                        $('#imgSingle').attr('src', "../.." + response[0].otherimage);
                        $('#fileInputSingle').val('');
                        $("#mydiv1").load(location.href + " #mydiv1");
                    },
                    error: function (xhr, status, error) {
                    }
                });

            }
            else {
                alert('File too big !');
            }
        }

    });

 function SingleStatus() {
        
                $.ajax({
                    url: '@Url.Action("SingleStatus","Home")',
                    type: 'GET',
                    success: function (response) {

                        if (response === 'Success') {
                            $('#bysim2').attr('checked', false);
                        }
                        else {
                            $('#bysim2').attr('checked', true);
                        }
                    }
                });
    }
</script>
