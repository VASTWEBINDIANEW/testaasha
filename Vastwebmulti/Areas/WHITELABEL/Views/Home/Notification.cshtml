
@{
    ViewBag.Title = "Notification";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-5">
                        <img src="/AdminDesign/images/android-1.svg" style="width: 450px;margin: auto;display:block;" />
                    </div>
                  
                    <div class="col-md-7">
                        <div class="white-notification">
                            <div class="card">
                                <div class="header" style="padding: 10px;background: #bbb;">
                                    <h2>SEND NOTIFICATION</h2>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="body" style="background:#f5f5f5;">
                                            @using (Html.BeginForm("Send_Notification", "Home", FormMethod.Post))
                                            {
                                                <div class="row" style="margin-bottom:0px; margin-top:0px;">
                                                    
                                                    <div class="col-lg-12" style="margin-bottom:0px;">
                                                        <label for="email_address_2" >User Level :</label>
                                                        <div class="form-group">

                                                            <div class="edit-white-b" style="border:1px solid #dddddd;">
                                                                @Html.DropDownList("Userform1", new List<SelectListItem> {
                            new SelectListItem { Text = "Distributor", Value= "WDealer" } ,
                            new SelectListItem { Text = "Retailer", Value= "WRetailer" },
                              },
       "Select User", new { @class = "form-control" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row" style="margin-bottom:0px; margin-top:0px;">
                                                   
                                                    <div class="col-lg-12" style="margin-bottom:0px;">
                                                        <label for="email_address_2" >UserId :</label>
                                                        <div class="form-group">

                                                            <div class="form-line" style="border:1px solid #dddddd;">
                                                                @Html.TextBox("txtUserid", "", new { @class = "form-control", @maxlength = "10" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row" style="margin-bottom:0px; margin-top:0px;">
                                                   
                                                    <div class="col-lg-12" style="margin-bottom:0px;">
                                                        <label for="email_address_2">Message :</label>
                                                        <div class="form-group">

                                                            <div class="form-line" style="border:1px solid #dddddd;">
                                                                @Html.TextArea("txtMsgBody", "", new { maxlength = 160, @class = "form-control", @placeholder = "Enter Message Here", style = "height:120px" })
                                                                @*<ul id="sms-counter"><li>Remaining : <span class="remaining"></span></li></ul>*@
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="form-group">
                                                    <div class="col-md-12">
                                                        <button type="submit" class="btn" style="color:#fff; float:right;background:linear-gradient(to right, @PageData["Globalfirst"],@PageData["GlobalSecond"]);">Send Notification</button>&nbsp;&nbsp;&nbsp;&nbsp;
                                                        <button id="btn" type="reset" class="btn waves-effect" style="float:right; margin-right:5px;background:#bbb;">Reset</button>
                                                        @*<input id="submit1" type="submit" value="Send Sms" class="btn btn-success" style="float:right;" />
                                        <input id="btn" type="reset" value="Reset" class="btn btn-success" style="float:right;" />*@
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                   
                </div>       
            </div>
        </div>
    </div>
</section>


