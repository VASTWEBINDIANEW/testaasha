   }
</style>

<div id="custnav" style="padding-top:5px;">
    <ul id="ul">
        <li><a href="~/WHITELABEL/Home/Api_Operator" ><i class="fa fa-cog fa-spin" aria-hidden="true"></i>&nbsp;OPT&nbsp;Switching</a> </li>
        <li><a href="~/WHITELABEL/Home/Api_nm">Set&nbsp;{Get}&nbsp;API</a></li>
        
    </ul>
</div>

<script src="~/Scripts/jquery-1.10.2.min.js"></script>
<script>
    $(function () {
        var current = location.pathname;
        $('#custnav li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('activee');
                $this.addClass('navbar');
            }
        })
    });
</script>

