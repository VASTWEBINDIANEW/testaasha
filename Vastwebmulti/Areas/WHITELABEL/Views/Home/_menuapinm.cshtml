    top: 2px;
    left: 0;
    position: absolute;
    height: 18px;
    border: 2px solid #fff;
    margin: 5px;
    border-radius: 50%;
    box-shadow: 0px 0px 10px #fff;
}
    #ul li a.activee::before{content: "✔";
    position: absolute;
    left: 9px;
