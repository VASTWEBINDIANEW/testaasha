

<style>
    .slab-setting-menu {
        float: left;
        padding: 0px;
    }

        .slab-setting-menu li {
            list-style: none;
            float: left;
            border: 1px solid #bbb;
            margin-right: 3px;
        }

            .slab-setting-menu li a {
                color: #555 !important;
                padding: 6px 6px;
                display: block;
            }

                .slab-setting-menu li a.activee {
                    color: #fff !important;
                }
</style>












<ul class="slab-setting-menu" style="background:linear-gradient(to right, @PageData["Globalfirst"],@PageData["GlobalSecond"]);">
    <li><a href="@Url.Action("FundToDealer","Home")">Fund&nbsp;<i class="fa fa-exchange"></i>&nbsp;Distributor</a></li>

    <li><a href="@Url.Action("Dealer_recive_order","Home")">Distributor's</a></li>
    <li>
        <a href="~/WHITELABEL/Home/DealercrReport">Distibutor Cr</a>
    </li>
    <li style="border-color:#454e68;"><a href="@Url.Action("FundToRetailer","Home")">Fund&nbsp;<i class="fa fa-exchange"></i>&nbsp;Retailer</a> </li>
    <li style="border-color:#454e68;"><a href="@Url.Action("purcharge_request","Home")">Retailer's</a> </li>
    <li style="border-color:#454e68;">
        <a href="~/WHITELABEL/Home/RetailercrReport">Retailer Cr</a>
    </li>

</ul>
<script type="text/javascript">



    $(function () {
        var current = location.pathname;
        $('.slab-setting-menu li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('activee');

            }
        })
    });

</script>