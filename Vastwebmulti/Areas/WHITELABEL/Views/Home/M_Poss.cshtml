@model Vastwebmulti.Areas.WHITELABEL.Models.MposSlabModel
@{
    ViewBag.Title = "M_Poss";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}




    <style>
    .slab-setting-menu li a.activee {

    background:linear-gradient(to right, @PageData["Globalfirst"],@PageData["GlobalSecond"]);

    }

    </style>
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="">
                        <div class="row">
                            <div class="col-md-8">
                                @Html.Partial("_slab_setting_menu")
                            </div>
                            
                            <div class="col-md-4 slab-edit-w-b">
                                <a href="@Url.Action("M_Poss","Home")" id="Comm" class="btn bg-blue-grey waves-effect">Common</a><button type="button" id="Dlmbtn" class="btn bg-blue-grey waves-effect" onclick="editUserWise('Dealer', 'EditFormUserWise')">Distributor</button><button type="button" id="Rembtn" class="btn bg-blue-grey waves-effect" onclick="editUserWise('Retailer', 'EditFormUserWise')">Retailer</button><button id="btnEdit" type="button" class="btn bg-blue-grey waves-effect" style="margin-left:10px;" onclick="funcEdit(this, 'EditFormComm')"><img src="../../AdminDesign/images/edit.svg" style="width:14px;margin-right:6px;" />Edit</button>
                                <div class="custom-data-table">
                                    <table class=" js-exportable ">
                                        <thead>
                                            <tr>
                                                <th></th>
                                            </tr>
                                        </thead>

                                    </table>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class=" table-responsive">
                        <div id="divEditFormComm" class="table-responsive" style="position:inherit;">
                            @using (Html.BeginForm("M_Poss", "Home", FormMethod.Post, new { id = "EditFormComm" }))
                            {
                                <table class="table table-bordered">
                                    <thead class="navbar" style="position:initial;color:white;">
                                        <tr>
                                            <th>User&nbsp;Type</th>
                                            <th>Withdraw</th>
                                            <th>S&nbsp;Debit&nbsp;2000</th>
                                            <th>S&nbsp;Debit&nbsp;above&nbsp;2000</th>
                                            <th>S&nbsp;Credit&nbsp;Normal</th>
                                            <th>S&nbsp;Credit&nbsp;Grocery</th>
                                            <th>S&nbsp;Credit&nbsp;EduIns</th>
                                            <th>Gst</th>

                                        </tr>
                                    </thead>
                                    <tbody id="tbodyshow">
                                        @foreach (var item in Model.common)
                                         {
                                        <tr>
                                            <td><p>@item.usertype</p></td>
                                            <td>@item.CashWithdraw</td>
                                            <td>@item.Salesdebitupto2000</td>
                                            <td>@item.Salesdebitabove2000</td>
                                            <td>@item.SalescreditNormal</td>
                                            <td>@item.Salescreditgrocery</td>
                                            <td>@item.SalescreditEduandInsu</td>
                                            <td>@item.gst</td>
                                        </tr>
                                         }

                                    </tbody>
                                    <tbody id="tbodyedit" style="display:none;">
                                        @for (int i = 0; i < Model.common.Count; i++)
                                        {
                                        <tr>
                                            @Html.HiddenFor(a => a.common[i].idno)
                                            <td>
                                                @Html.DisplayFor(a => a.common[i].usertype)
                                            </td>
                                            <td>
                                                @Html.EditorFor(a => a.common[i].CashWithdraw ,new { htmlAttributes = new { @style = "width:100%" } })
                                                @Html.ValidationMessageFor(a => a.common[i].CashWithdraw)
                                            </td>
                                            <td>
                                                @Html.EditorFor(a => a.common[i].Salesdebitupto2000, new { htmlAttributes = new { @style = "width:100%" } })
                                                @Html.ValidationMessageFor(a => a.common[i].Salesdebitupto2000)
                                            </td>
                                            <td>
                                                @Html.EditorFor(a => a.common[i].Salesdebitabove2000, new { htmlAttributes = new { @style = "width:100%" } })
                                                @Html.ValidationMessageFor(a => a.common[i].Salesdebitabove2000)
                                            </td>
                                            <td>
                                                @Html.EditorFor(a => a.common[i].SalescreditNormal, new { htmlAttributes = new { @style = "width:100%" } })
                                                @Html.ValidationMessageFor(a => a.common[i].SalescreditNormal)
                                            </td>
                                            <td>
                                                @Html.EditorFor(a => a.common[i].Salescreditgrocery, new { htmlAttributes = new { @style = "width:100%" } })
                                                @Html.ValidationMessageFor(a => a.common[i].Salescreditgrocery)
                                            </td>
                                            <td>
                                                @Html.EditorFor(a => a.common[i].SalescreditEduandInsu, new { htmlAttributes = new { @style = "width:100%" } })
                                                @Html.ValidationMessageFor(a => a.common[i].SalescreditEduandInsu)
                                            </td>
                                            <td>
                                                @Html.EditorFor(a => a.common[i].gst, new { htmlAttributes = new { @style = "width:100%" } })
                                                @Html.ValidationMessageFor(a => a.common[i].gst)
                                            </td>
                                        </tr>
                                         }

                                    </tbody>
                                </table>
                            }
                        </div>
                        

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script>
    var FormId = "";
    function funcEdit(event,frmId)
    {
        //alert();
        $('#tbodyshow').hide();
        $('#tbodyedit').show();
        $(event).replaceWith('<button id="btnEdit" type="button" class="btn bg-blue-grey waves-effect btn-for-green" style="margin-left:10px;" onclick="funcSave()">Save</button>');
        if (FormId == "")//Use in Default Slab edit
        {
            FormId = frmId;
        }
        var ddlVal = $('#ddlUserId').val();
        if(ddlVal != null && ddlVal == '')//Update ALL
        {
            $('#tbodyeditAll').show();
            $('#tbodyedit').hide();
        } else if (ddlVal != null && ddlVal != '')//Update ALL
        {
            $('#tbodyeditAll').hide();
            $('#tbodyedit').show();
        }
    }
    function funcSave()
    {
        //alert(FormId);
        $("#" + FormId + "").submit();
    }
    function editUserWise(userRole, frmId)
    {
        //alert(userRole);
        var url = '@Url.Action("_UserMposSlab", "Home")';
        $.post(url, { role: userRole }, function (data) {
            $("#divEditFormComm").html(data);
            FormId = frmId;
            $("#btnEdit").replaceWith('<button id="btnEdit" type="button" class="btn bg-blue-grey waves-effect" style="margin-left:10px;" onclick="funcEdit(this, \'EditFormComm\')"><img src="../../AdminDesign/images/edit.svg" style="width:14px;margin-right:6px;" />Edit</button>');
            $("#role").val(userRole);
        })
          .fail(function (xhr, status, error) {
              alert("error");
              //var err = eval("(" + xhr.responseText + ")");
              //alert(err.Message);
              console.log(xhr.responseText);
          })
          .always(function () {
              //alert("finished");
          });

      
        if (userRole == "Dealer") {
            $("#Dlmbtn").removeClass("btn bg-blue-grey waves-effect").addClass("btn bg-grey waves-effect");
            $("#Mdbtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Rembtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Apibtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Whitebtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Comm").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
        }
        if (userRole == "Retailer") {
            $("#Rembtn").removeClass("btn bg-blue-grey waves-effect").addClass("btn bg-grey waves-effect");
            $("#Mdbtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Dlmbtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Apibtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Whitebtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Comm").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
        }
       
       
    }
    function ddlUserIdChange()
    {
        var ddlVal = $('#ddlUserId').val();
        var role =$("#role").val();
   
            var url = '@Url.Action("_UserMposSlab", "Home")';
            $.post(url, { role: role, userid: ddlVal }, function (data) {
                $("#divEditFormComm").html(data);
                $("#btnEdit").replaceWith('<button id="btnEdit" type="button" class="btn bg-blue-grey waves-effect" style="margin-left:10px;" onclick="funcEdit(this, \'EditFormComm\')"><img src="../../AdminDesign/images/edit.svg" style="width:14px;margin-right:6px;" />Edit</button>');

            })
              .fail(function (xhr, status, error) {
                  alert("error");
                  //var err = eval("(" + xhr.responseText + ")");
                  //alert(err.Message);
                  console.log(xhr.responseText);
              })
              .always(function () {
                  //alert("finished");
              });
        
    }
   
</script>

<script>
    window.onload=function()
    {
        $("#Comm").removeClass("btn bg-blue-grey waves-effect").addClass("btn bg-grey waves-effect");
    }
</script>
