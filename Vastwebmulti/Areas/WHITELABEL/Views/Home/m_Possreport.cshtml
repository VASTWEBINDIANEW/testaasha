<script>
    $(function()
    {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

        answers();
    });
</script>
<script type="text/javascript">
    function answers() {
        var e = document.getElementById("ddlusers");
        var answer = e.options[e.selectedIndex].value;
        if (answer == "Dealer") {
            document.getElementById("dlm").style.display = "block";
            document.getElementById("rem").style.display = "none";
        }
        else if (answer == "WAdmin") {
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "none";
        }
        else if (answer == "Retailer") {
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "block";
        }
    }
</script>

<script>
    function GotoView(idno) {
        $.ajax({
            url: '@Url.Action("MposStatus", "Home")',
            type: "Post",
            dataType: 'json',
            cache: false,
            //   async: false,
            data: { idno: idno },
            //cache: false,
            success: function (result) {
                var resp = result.split('~');
                var output = resp[0];
                var Tid = resp[1];
                $('#TID').val(Tid);
                if (output == "RefundPending") {
                    $('#myModal').modal('show');
                }
                else if (output == "Success") {
                    swal({ title: "Response !", text: "Mposs Success.", type: "success" },
                                            function () {
                                                location.reload();
                                            }
                    );
                }
                else if (output == "Failed" || output == "Refunded") {
                    swal({ title: "Response !", text: "Mposs Failed.", type: "error" },
                                           function () {
                                               location.reload();
                                           }
                   );
                }
                else if (output == "Pending") {
                    swal({ title: "Response !", text: "Mposs Pending.", type: "warning" },
                                           function () {
                                               location.reload();
                                           }
                   );
                }
            }
        });
    }
</script>


<script>
    $('.white-success-button').click(function () {
        $('.white-success').toggle();
    });
</script>

<script>
    var txt_frm_date = $('#txt_frm_date').val();
    var txt_to_date = $('#txt_to_date').val();
    var ddlusers = $('#ddlusers').val();
    var ddl_status = $('#ddl_status').val();
    var alldealer = $('#alldealer').val();
    var allretailer = $('#allretailer').val();
        var pageindex = 2;
        var NoMoredata = false;
        var inProgress = false;
    $(window).scroll(function () {
            if ($(window).scrollTop() > Number($("#tbldata").height()) / 4 && !NoMoredata && !inProgress) {
                inProgress = true;
                $("#loadingdiv").show();
                $.post("@Url.Action("mPossInfiniteScroll","Home")",
                    { "pageindex": pageindex, "txt_frm_date": txt_frm_date, "txt_to_date": txt_to_date, "ddlusers": ddlusers, "ddl_status": ddl_status, "alldealer": alldealer, "allretailer": allretailer },
                    function (data) {
                        pageindex = pageindex + 1;
                        NoMoredata = data.NoMoredata;
                        $("#trow").append(data.HTMLString);
                        $("#loadingdiv").hide();
                        inProgress = false;
                    });
            }
        });
</script>

<script>
    function findtotal() {
         var txt_frm_date = $('#txt_frm_date').val();
         var txt_to_date = $('#txt_to_date').val();
         var ddlusers = $('#ddlusers').val();
         var ddl_status = $('#ddl_status').val();
         var alldealer = $('#alldealer').val();
         var allretailer = $('#allretailer').val();
             $.post("@Url.Action("mPossFindTotal", "Home")",
                 { "txt_frm_date": txt_frm_date, "txt_to_date": txt_to_date, "ddlusers": ddlusers, "ddl_status": ddl_status, "alldealer": alldealer, "allretailer": allretailer},
                 function (data) {
                     $('#successtotal').text("₹. " + data.success);
                     $('#Failedtotal').text("₹. " + data.failed);
                     $('#Pendingtotal').text("₹. " + data.pending);
                 });
    }
</script>
