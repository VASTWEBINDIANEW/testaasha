                                    </div>
                                </div>

                                <div class="white-l-search-two responcive-fifty" style="display:none;" id="dlm">
                                    <div class="form-line" style="border:1px solid #dddddd;width:100%;padding-bottom:10px;">
                                        @Html.DropDownList("alldealer", ViewBag.alldealer as SelectList, " All Distubutor", new { id = "alldealer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                    </div>
                                </div>
                                <div class="white-l-search-two responcive-fifty" style="display:none;" id="rem">
                                    <div class="form-line" style="border:1px solid #dddddd;width:100%;padding-bottom:10px;">
                                        @Html.DropDownList("allretailer", ViewBag.allretailer as SelectList, "All Retailer", new { id = "allretailer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                    </div>
                                </div>


                                <div class="white-l-search-three responcive-fifty">
                                    <div class="form-line" style="border:1px solid #dddddd;width:100%;padding-bottom:10px;">
                                        @Html.DropDownList("ddl_status", new List<SelectListItem>
                                    {
                            new SelectListItem{ Text="Status",Value="ALL",},
                            new SelectListItem{Text="SUCCESS",Value="SUCCESS"},
                            new SelectListItem{Text="Pending",Value="PENDING"},
                            new SelectListItem{Text="FAILED",Value="FAILED"}
