
@{
    ViewBag.Title = "m_Possreport";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}

<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }

    .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {
        height: 20px;
    }
</style>
<style>
    .slab-setting-menu li a.activee {background:linear-gradient(to right, @PageData["Globalfirst"],@PageData["GlobalSecond"]);}
    .responcive-fifty button {height: 30px !important;}
    .responcive-padding button, .responcive-padding input {padding: 0px 15px;height: 32px;border: 1px solid #c7c2c2 !important;background: #dedddd;}
    .datepicker-dropdown.datepicker {margin-top: 70px !important;}
    #divEditFormComm table thead tr, .web-white-table table thead tr {background: 0;}
    .white-success {
        padding: 0;
        top: 0;
    }
    @@media only screen and (max-width: 992px) {
        .responcive-fifty, .responcive-padding {
            width: 49% !important;
            float: left;
            margin: 0;
            margin-bottom: 10px;
        }

            .responcive-fifty:nth-last-child(2n+2) {
                margin-right: 3px !important;
            }

            .responcive-fifty:nth-child(2n+2) {
                margin-left: 3px !important;
            }

        .responcive-full {
            width: 99% !important;
            margin: 0;
            margin-bottom: 10px;
        }

        .responcive-fifty:last-child {
            margin-left: 0 !important;
        }

        .responcive-fifty ul {
            margin: 0;
        }

        .responcive-fifty button {
            width: 100%;
            text-align: left;
        }

        .responcive-padding .white-l-search-nine {
            width: 100%;
        }

        .responcive-fifty ul {
            width: 100%;
        }

            .responcive-fifty ul li {
                width: 24.3%;
                text-align: center;
                margin-right: 2px;
            }
    }

    @@media only screen and (max-width: 480px) {
        .responcive-fifty button {
            margin: 0 !important;
        }

        .responcive-fifty, .responcive-padding {
            width: 48%;
        }

            .responcive-padding button, .responcive-padding input {
                padding: 0px 4px;
            }

        .white-l-search-ten.responcive-fifty {
            width: 100% !important;
        }

        .responcive-fifty ul li {
            width: 24%;
        }
    }
</style>
<section class="content">
