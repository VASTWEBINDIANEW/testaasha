
@model List<Vastwebmulti.Models.whitelabel_Recharge_Report_Paging_Result>
@{
    ViewBag.Title = "Recharge_Report";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}
<style>
        .table.dataTable thead th, table.dataTable thead td {
            padding: 8px 4px 6px 4px;
        }

        .table.dataTable tbody th, table.dataTable tbody td {
            padding: 8px 4px 6px 4px;
        }

        .dropdown-menu {
            margin-top: 81px !important;
        }

        table.dataTable tbody th, table.dataTable tbody td {
            padding: 8px 4px;
        }

        .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {
            height: 20px;
        }

        div.dt-buttons {
            float: right;
        }
        .responcive-fifty button{
            height: 30px !important;
        }
        .responcive-fifty input{height: 32px !important;}
        .responcive-padding button, .responcive-padding input {
            padding: 0px 15px;
            height: 32px;
            border: 1px solid #c7c2c2 !important;
            background: #dedddd;
        }

        .datepicker-dropdown.datepicker {
            margin-top: 70px !important;
        }
        #divEditFormComm table thead tr, .web-white-table table thead tr {
            background: 0;
        }
         .whitelable-alldatereport .custom-date-icon i {
        background-image: linear-gradient(to right , @PageData["Globalfirst"], @PageData["GlobalSecond"]) !important;
    }
    .white-success {
        padding: 0;
        top: 0;
    }
    @@media only screen and (max-width: 992px) {
        .responcive-fifty, .responcive-padding {
            width: 49%;
            float: left;
            margin: 0;
            margin-bottom: 10px;
        }
        .responcive-fifty:nth-last-child(2n+2) {
            margin-right: 3px !important;
        }
        .responcive-fifty:nth-child(2n+2) {
            margin-left: 3px !important;
        }
        .responcive-full {
            width: 99%;
            margin: 0;
            margin-bottom: 10px;
        }
        .responcive-fifty:last-child {
            margin-left: 0 !important;
        }
    }
    @@media only screen and (max-width: 480px) {
        .responcive-fifty button {
            margin: 0 !important;
        }
        .responcive-fifty, .responcive-padding {
            width: 48%;
        }
        .responcive-padding button, .responcive-padding input {
        padding: 0px 4px;
        }
        
    }
</style>


<link href="~/Swalalert/datatable.css" rel="stylesheet" />
<section class="content">
    <div class="container-fluid">



        <div class="row clearfix">

            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card" style="margin-top:2px;">
                    <div class="white-l-search">
                        @using (Html.BeginForm("Recharge_Report", "Home", FormMethod.Post))
                        {
                            <div class="white-l-search-one responcive-fifty">
                                <div class="" style="width:100%;border:1px solid #dddddd;padding-bottom:10px;">
                                    @Html.DropDownList("ddlusers", new List<SelectListItem>
                              {
                           new SelectListItem{ Text="All",Value="WAdmin"},
                           new SelectListItem{Text="Distributor",Value="Dealer"},
                           new SelectListItem{Text="Retailer",Value="Whitelabelretailer"},
                         }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding:0px;text-align:center;", @onchange = "answers()" })

                                </div>

                            </div>
                            <div class="white-l-search-two responcive-fifty" style="display:none;" id="dlm">
                                <div class="" style="width:100%;border:1px solid #dddddd;padding-bottom:10px;">
                                    @Html.DropDownList("alldealer", ViewBag.alldealer as SelectList, "Distubutor", new { id = "alldealer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                </div>
                            </div>
                            <div class="white-l-search-two responcive-fifty" style="display:none;" id="rem">
                                <div class="" style="width:100%;border:1px solid #dddddd;padding-bottom:10px;">
                                    @Html.DropDownList("allretailer", ViewBag.allretailer as SelectList, "All Retailer", new { id = "allretailer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                </div>
                            </div>

                            <div class="white-l-search-three responcive-fifty">
                                <div class="" style="width:100%;border:1px solid #dddddd;padding-bottom:10px;">
                                    @Html.DropDownList("ddl_status", new List<SelectListItem>
                                {
                        new SelectListItem{ Text="Status",Value="ALL",},
                        new SelectListItem{Text="SUCCESS",Value="SUCCESS"},
                        new SelectListItem{Text="Pending",Value="PENDING"},
                        new SelectListItem{Text="FAILED",Value="FAILED"}
                         }, new { @class = "selectpicker form-control", data_live_search = "true", @style = " padding-left:0px; padding-right:0px;text-align:center;" })
                                </div>
                            </div>
                            <div class="white-l-search-four responcive-fifty">
                                <div class="" style="width:100%;border:1px solid #dddddd;padding-bottom:10px;">
                                    @Html.DropDownList("Operator", ViewBag.Operator as SelectList, "Operator", new { id = "Operator", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;" })
                                </div>
                            </div>


                            <div class="white-l-search-five responcive-fifty" id="RCH-NUMBER">


                                <div class="" style="width:100%;">
                                    <img src="~/AdminDesign/images/search.svg" style="width: 12px;position: absolute;top: 11px;left: 5px;" />
                                    @Html.TextBox("txtmob", "", new { @style = "margin-top:0px;padding-left:25px;padding-right:0px;height:34px;border:1px solid #dddddd;", @placeholder = "Number", @class = "form-control" })
                                </div>

                            </div>
                            <div class="white-l-search-six responcive-full">
                                <div class="form-group for-web-date" style="margin-bottom:0px;width:100%;">
                                    <div class="input-daterange input-group">
                                        <div class="whitelable-alldatereport date-leftclass">
                                            <div class="custom-date-icon" style="">
                                                <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                            </div>
                                            @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; height:34px;padding-left:20px;", autocomplete = "off" })
                                        </div>
                                        @*<span class="input-group-addon">
                                            <i class="fa fa-exchange" style="padding-top:5px;"></i>
                                        </span>*@
                                        <div class="whitelable-alldatereport date-rightclass">
                                        <div class="custom-date-icon" style="">
                                            <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                        </div>
                                        @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; height:34px;padding-left:20px;", autocomplete = "off" })
                                    </div>
                                        </div>
                                </div>
                            </div>

                            <div class="white-l-search-eight responcive-fifty">

                                <center>
                                    <input name="btntype" type="submit" value="Search" class="btn" onclick="serch()" style=" width:100%;padding:0px; height:34px;border:1px solid #c7c2c2;background:transparent;" />

                                </center>




                            </div>
                        }
                        <div class="responcive-padding" style="position: relative;">
                        <div class="" style="float: right;">
                            <div style="float:right;" class="web-white-filter">
                                <input type="button" id="btnExport" value="Export" style="margin-left:2px; height:32px;border:1px solid #c7c2c2;background:#dedddd;" />
                                <input type="button" id="btnPDF" value="PDF" style="margin-left:2px; height:32px;border:1px solid #c7c2c2;background:#dedddd;" />
                                <button class="white-success-button" onclick="findtotal()">Total</button>
                            </div>
                        </div>

                        <div class="white-success" style="display:none;">
                                <button class="white-success-button" onclick="findtotal()" style="position: absolute;top: -6px;right: -1px;height: 20px;width: 20px;font-size: 16px;padding: 0;z-index: 9;color: #000;">X</button>
                                <span id="successtotal" class="btn btn-success waves-effect" style="font-size: 12px;padding:9px; color:white;font-weight:600;" title="Total  Success"><i style="font-size:15px;top:1px;" class="fa fa-check-circle-o" aria-hidden="true"></i> </span>
                                <span id="Failedtotal" class="btn btn-danger waves-effect" style="font-size: 12px;padding:9px; color:white;font-weight:600;" title="Total  Failed"><i style="font-size:15px;top:1px;" class="fa fa-times-circle-o" aria-hidden="true"></i> </span>
                                <span id="Pendingtotal" class="btn btn-warning waves-effect" style="font-size: 12px;padding:9px;color:white; font-weight:600;" title="Total  Pending"><i style="font-size:15px;top:1px;" class="fa fa-question-circle-o" aria-hidden="true"></i> </span>
                                <span id="totaldlm" class="btn bg-indigo waves-effect" style="font-size: 12px;padding:9px; color:white;font-weight:600;"> </span>
                                <span id="totalrem" class="btn bg-blue waves-effect" style="font-size: 12px;padding:9px;color:white; font-weight:600;"> </span>

                        </div>
                            </div>
                    </div>

                </div>

            </div>

        </div>


        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="">
                <div class="card">


                    <div class="row clearfix">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:10px;">
                            <div class="card">
                                <div class="row clearfix">
                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-1px;">
                                        <div class="">
                                            <div class=" table-responsive   web-white-table" style="position:inherit;">
                                                <table cellpadding="0" class="table table-bordered table-striped table-hover Grid" style="width:100%; font-size:12px;">
                                                    <thead>
                                                        <tr>
                                                            <th style="text-align:center">Status</th>

                                                            <th style="text-align:center">Recharge&nbsp;No</th>
                                                            <th style="text-align:center">User Firm</th>
                                                            <th style="text-align:center">Rch&nbsp;Amt</th>
                                                            <th style="text-align:center">Opt Name</th>
                                                            <th style="text-align:center">Pre Bal</th>
                                                            <th style="text-align:center">DR/CR</th>
                                                            <th style="text-align:center">Post Bal</th>
                                                            <th style="text-align:center">Operator&nbsp;ID</th>
                                                            <th style="text-align:center">Req&nbsp;Time</th>
                                                            <th>#</th>
                                                        </tr>
                                                    </thead>

                                                    <tbody id="trow">
                                                        @{
                                                            Html.RenderAction("_Rechargereport", "Home", new { Model = Model });
                                                        }
                                                    </tbody>

                                                </table>

                                                <div id="loadingdiv" style="text-align:center;display:none;margin-bottom:16px;">
                                                    <img src="~/img/ajax-loader.gif" />
                                                </div>

                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>


                </div>
            </div>
        </div>
    </div>
</section>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->

<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
