<script>
    $(document).ready(function () {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
        answers();
    });
</script>

<script type="text/javascript">
    function answers() {
        var e = document.getElementById("ddlusers");
        var answer = e.options[e.selectedIndex].value;
        if (answer == "Dealer") {
            document.getElementById("dlm").style.display = "block";
            document.getElementById("rem").style.display = "none";
            document.getElementById("RCH-NUMBER").style.display = "none";
            document.getElementById("allretailer").selectedIndex = "0";
        }
        else if (answer == "WAdmin") {
            $("select#allmaster1").attr('selectedIndex', 0);
            $("select#alldealer").attr('selectedIndex', 0);
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "none";
            document.getElementById("RCH-NUMBER").style.display = "block";
            document.getElementById("alldealer").selectedIndex = "0";
            document.getElementById("allretailer").selectedIndex = "0";
        }
        else if (answer == "Whitelabelretailer") {
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "block";
            document.getElementById("RCH-NUMBER").style.display = "none";
            document.getElementById("alldealer").selectedIndex = "0";
            document.getElementById("allretailer").selectedIndex = "0";
        }
    }





    $('.white-success-button').click(function () {
        $('.white-success').toggle();
    });
</script>

<script>
    $('select').select2();
</script>
<script>
    var txt_frm_date = $('#txt_frm_date').val();
    var txt_to_date = $('#txt_to_date').val();
    var ddlusers = $('#ddlusers').val();
    var ddl_status = $('#ddl_status').val();
    var Operator = $('#Operator').val();
    var alldealer = $('#alldealer').val();
    var allretailer = $('#allretailer').val();
    var txtmob = $('#txtmob').val();
    var ddl_top = $('#ddl_top').val();
        var pageindex = 2;
        var NoMoredata = false;
        var inProgress = false;
    $(window).scroll(function () {
            if ($(window).scrollTop() > Number($("#tbldata").height()) / 4 && !NoMoredata && !inProgress) {
                inProgress = true;
                $("#loadingdiv").show();
                $.post("@Url.Action("InfiniteScroll","Home")",
                    { "pageindex": pageindex, "txt_frm_date": txt_frm_date, "txt_to_date": txt_to_date, "ddlusers": ddlusers, "ddl_status": ddl_status, "Operator": Operator, "alldealer": alldealer, "allretailer": allretailer, "txtmob": txtmob, "ddl_top": ddl_top },
                    function (data) {
                        pageindex = pageindex + 1;
                        NoMoredata = data.NoMoredata;
                        $("#trow").append(data.HTMLString);
                        $("#loadingdiv").hide();
                        inProgress = false;
                    });
            }
        });
</script>

<script>
    function findtotal() {
         var txt_frm_date = $('#txt_frm_date').val();
         var txt_to_date = $('#txt_to_date').val();
         var ddl_status = $('#ddl_status').val();
         var Operator = $('#Operator').val();
         var txtmob = $('#txtmob').val();
             $.post("@Url.Action("FindTotal","Home")",
             {"txt_frm_date": txt_frm_date, "txt_to_date": txt_to_date,"ddl_status":ddl_status,"Operator":Operator,"txtmob":txtmob},
                 function (data) {
                     $('#successtotal').text("₹. " + data.success);
                     $('#Failedtotal').text("₹. " + data.failed);
                     $('#Pendingtotal').text("₹. " + data.pending);
                     $('#totaldlm').text("DLM ₹. " + data.dlmincom);
                     $('#totalrem').text("REM ₹. " + data.remincome);
                  });
    }
</script>
<script>
    $("#btnExport").click(function(){
   var txt_frm_date = $('#txt_frm_date').val();
         var txt_to_date = $('#txt_to_date').val();
         var ddl_status = $('#ddl_status').val();
         var Operator = $('#Operator').val();
        var txtmob = $('#txtmob').val();
        var url = '@Url.Action("ExcelRechargereport","Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&ddl_status=' + ddl_status + '&Operator=' + Operator + '&txtmob=' + txtmob;
        location.href = url;
});
</script>
<script>
    $("#btnPDF").click(function () {
     var txt_frm_date = $('#txt_frm_date').val();
         var txt_to_date = $('#txt_to_date').val();
         var ddl_status = $('#ddl_status').val();
         var Operator = $('#Operator').val();
        var txtmob = $('#txtmob').val();
        var url = '@Url.Action("PDFRechargereport","Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&ddl_status=' + ddl_status + '&Operator=' + Operator + '&txtmob=' + txtmob;
        window.open(url,'_blank');
    });
</script>



<script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/1.8.3/jquery.min.js"></script>
<script type="text/javascript">
    //Assign Click event to Plus Image.
    $("body").on("click", "img[src*='double-down.png']", function () {
        $(this).closest("tr").after("<tr><td></td><td colspan = '10'>" + $(this).next().html() + "</td></tr>");
        $(this).attr("src", "/images/double-up.png");
    });
    //Assign Click event to Minus Image.
    $("body").on("click", "img[src*='double-up.png']", function () {
        $(this).attr("src", "/images/double-down.png");
        $(this).closest("tr").next().remove();
    });
</script>
