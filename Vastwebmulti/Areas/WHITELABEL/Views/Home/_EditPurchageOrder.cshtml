@model Vastwebmulti.Areas.WHITELABEL.Models.Whitelabel_CashDepositeAndBank_Info_VM
@using (Ajax.BeginForm("_EditPurchageOrder", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "success", OnFailure = "failed", UpdateTargetId = "farziidhye" }))
{
    <input id="btnsubmit" type="submit" value="Save Now" class="btn btn-default" style="display:none;width: auto;padding: 0px 10px !important;" />
    <div id="tblmaster">
        <table class="table table-responsive table-bordered">
            <thead>
                <tr style="background: #c7c7c7;">
                    <th>User ID</th>
                    <th>Payment&nbsp;Type</th>
                    <th>Charge &nbsp;(%)</th>
                </tr>
            </thead>
            @if (Model.creditchargemaster != null)
            {
                <tbody id="tbodyshow">
                    @foreach (var item in Model.creditchargemaster)
                    {
                        <tr>
                            <th>@item.userid</th>
                            <th>@item.ctype</th>
                            <th>@item.Charge</th>
                        </tr>
                    }
                </tbody>
                <tbody id="tbodyedit" style="display:none;">
                    @for (int i = 0; i < Model.creditchargemaster.Count; i++)
                    {
                        <tr>
                            @Html.HiddenFor(a => a.creditchargemaster[i].userinfo)
                            <td>
                                @Html.DisplayFor(a => a.creditchargemaster[i].userid)
                            </td>
                            <td>
                                @Html.HiddenFor(a => a.creditchargemaster[i].ctype)
                                @Html.DisplayFor(a => a.creditchargemaster[i].ctype)
                            </td>
                            <td>
                                @Html.EditorFor(a => a.creditchargemaster[i].Charge, new { htmlAttributes = new { @style = "width:100%" } })
                                @Html.ValidationMessageFor(a => a.creditchargemaster[i].Charge)
                            </td>
                        </tr>
                    }
                </tbody>
            }
        </table>
    </div>
}


