@using Vastwebmulti.Models
@model IEnumerable<Vastwebmulti.Models.select_whitelabel_master_pur_order_Result>
@{
    ViewBag.Title = "Purchase_Order";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}

<style>
    .nav-tabs li.active a {
        background: none;
    }

    .dropdown-menu {
        margin-top: 81px !important;
    }
    #addmodel .form-group{
        margin-bottom:0px;

    }
</style>
<style>
    .slab-setting-menu li a.activee {

    background:linear-gradient(to right, @PageData["Globalfirst"],@PageData["GlobalSecond"]);

    }

</style>
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                   
                    <div class="row">
                        <div class="col-md-4">
                            @Html.Partial("_purchase_menu")

                        </div>
                        <div class="col-md-8">
                            <div class="row">
                                @using (Html.BeginForm("Purchase_Order", "Home", FormMethod.Post))
                                {

                                    <div class="col-md-5">
                                        <div class="form-group   for-web-date" style="margin-bottom:0px;">
                                            <div class="input-daterange input-group">
                                                <div class="custom-date-icon" style="height: 34px;">
                                                    <i class="fa fa-calendar tmw-total-color-one" aria-hidden="true" style="color: #46c837;"></i>
                                                </div>
                                                @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;", autocomplete = "off" })
                                                <span class="input-group-addon">
                                                    <i class="fa fa-exchange"></i>
                                                </span>
                                                <div class="custom-date-icon" style="height: 34px;">
                                                    <i class="fa fa-calendar tmw-total-color-one" aria-hidden="true" style="color: #46c837;"></i>
                                                </div>
                                                @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; ", autocomplete = "off" })
                                            </div>
                                            <!-- /.input group -->
                                        </div>
                                    </div>
                                    <div class="col-md-2" style="padding-left:0px;">
                                        <center>
                                            <button type="submit" class="btn  waves-effect" style="width:100%; background:transparent; height:34px;border:1px solid #c7c2c2;">
                                               
                                                <span style="color:black;">Search</span>
                                            </button>
                                        </center>

                                    </div>
                                    <div class="col-md-2" style="padding:0px;">
                                        <center>
                                            <button type="button" class="btn  waves-effect" style="width:100%;padding:6px; height:34px;border:1px solid #c7c2c2;background:transparent;" data-toggle="modal" data-target="#addmodel">
                                               
                                                <span style="top:-2px;color:black;">New&nbsp;Purchase&nbsp;Req.</span>
                                            </button>
                                        </center>

                                    </div>

                                }
                            <div class="col-md-3">
                                <div class="web-white-filter" style="float:right;">
                                    <table class="dataTable js-exportable ">
                                        <thead>
                                            <tr>
                                                <td></td>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                            </div>
                        </div>
                    </div>
                 
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div >
                        <div class="table-responsive   web-white-table" style="position:inherit;margin-top:-17px;">
                            <table class="table table-bordered table-striped table-hover" style="width:100%;">
                                <thead class="navbar" style="color:white;position:inherit;">
                                    <tr>
                                        <th>Order&nbsp;No</th>
                                        <th>Status </th>
                                        <th>From</th>
                                        <th>Amount</th>
                                        <th>Charge</th>
                                        <th>PayMent&nbsp;Mode</th>
                                        <th>To&nbsp;Acc&nbsp;No</th>
                                        <th>UtrNo/SlipNo </th>
                                        <th>Request&nbsp;Date </th>
                                        <th>Response&nbsp;Date</th>
                                        <th>Comment</th>
                                        <th>Screenshot </th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {

                                        var color = "";
                                        var stscolor = "";
                                        if (item.type_ == "Cash")
                                        {
                                            color = "green";
                                        }
                                        if (item.type_ == "Credit")
                                        {
                                            color = "red";
                                        }
                                        if (item.sts == "Pending")
                                        {
                                            stscolor = "#FF9800";

                                        }
                                        if (item.sts == "APPROVED")
                                        {
                                            stscolor = "green";

                                        }
                                        if (item.sts == "REJECTED")
                                        {
                                            stscolor = "red";

                                        }
                                        <tr>
                                            <td><p style="font-size:12px;">@item.orderno&nbsp;⇒&nbsp;<span style="color:@color;font-weight:600;">@item.type_.ToUpper()</span></p></td>
                                            <td><p style="font-size:12px;text-align:center;"><span style="color:@stscolor;font-weight:600;">@item.sts.ToUpper()</span></p></td>
                                            <td><p style="font-size:12px;">@Html.DisplayFor(modelItem => item.frm).ToString().ToUpper()</p></td>
                                            <td><p style="font-size:12px;text-align:center;">@Html.DisplayFor(modelItem => item.amount)</p> </td>
                                            <td><p style="font-size:12px;text-align:center;">@Html.DisplayFor(modelItem => item.cashDepositCharge)</p> </td>
                                            <td><p style="font-size:11px;">@Html.DisplayFor(modelItem => item.paymode).ToString().ToUpper()</p></td>
                                            <td><p style="font-size:12px;text-align:center;">@Html.DisplayFor(modelItem => item.Toaccountno)</p></td>
                                            <td><p style="font-size:12px;text-align:center;">@Html.DisplayFor(modelItem => item.utrno).ToString().ToUpper()</p></td>

                                            <td>@Html.DisplayFor(modelItem => item.reqdate)</td>
                                            <td>@Html.DisplayFor(modelItem => item.responsedate)</td>
                                            <td>@Html.DisplayFor(modelItem => item.details)</td>

                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(item.SlipUrl))
                                                {
                                                    <img src="@Url.Content("~/" + item.SlipUrl)" height="60" width="60" />
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!--Add New Modal-->
<div class="modal fade" id="addmodel" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document" style="float: right;margin: 0px;">
        <div class="modal-content">
            <div class="modal-header navbar" style="position:initial;">
                <h4 class="modal-title" id="defaultModalLabel" >Add New Purchase Order</h4>
            </div>

            <div class="modal-body" style="margin-top:-26px;">
                <div class="body">

                    <div class="row">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                            <div class="card" style="box-shadow: none">

                                <div class="body">
                                    <!-- Nav tabs -->
                                    <ul class="nav nav-tabs tab-nav-right" role="tablist" style="position: initial; border-bottom:none;">
                                        <li role="presentation" class="active" style="background-color:#4CAF50;"><a href="#FUND" data-toggle="tab" aria-expanded="false" class="btn bg-green waves-effect"><span style="color:white;font-weight:700;">CASH&nbsp;TRANSFER&nbsp;REQUEST</span> </a></li>
                                        <li role="presentation" style="background-color:#FF9800; margin-left:2px;"><a href="#CREDIT" data-toggle="tab" aria-expanded="false" class="btn bg-orange waves-effect"><span style="color:white;font-weight:700;">CREDIT REQUEST</span> </a></li>
                                        <li role="presentation" class="" style="float:right; margin-left:-1px;">
                                            <a data-toggle="tab" aria-expanded="false" class="btn btn-default waves-effect" style="border:1px solid red !important;"><span style="color:#000; font-weight:700; margin-left: 1px;">My Credit:&nbsp;@ViewData["oldcredit"]</span></a>
                                        </li>
                                    </ul>

                                    <!-- Tab panes -->
                                    <div class="tab-content">
                                        <div role="tabpanel" class="tab-pane fade active in" id="FUND">
                                            @using (Html.BeginForm("purchageorder", "Home", FormMethod.Post, new { @enctype = "multipart/form-data" }))
                                            {
                                                @Html.ValidationSummary()
                                            <form id="form_validation" method="POST" novalidate="novalidate">
                                                @Html.Hidden("type", "Cash")

                                                <div class="row clearfix">

                                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="Paymode" class="">Order&nbsp;Type</label>
                                                            <div class="" style="border:1px solid #dddddd;">
                                                                @Html.DropDownList("Paymode", new List<SelectListItem>
                                             {
                                                new SelectListItem{Text="Third Party Transfer", Value="Third Party Transfer"},
                                                new SelectListItem{Text="Online Transfer (NEFT,RTGS)", Value="Online Transfer (NEFT,RTGS)"},
                                                new SelectListItem{Text="Online Transfer (IMPS)", Value="Online Transfer (IMPS)"},
                                                new SelectListItem{Text="ATM Machine Deposit", Value="ATM Machine Deposit"},
                                                new SelectListItem{Text="Branch Cash Deposit", Value="Branch Cash Deposit"}
                                           }, new { @class = "form-control" })
                                                            </div>

                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row clearfix">

                                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group" id="balanceDiv">
                                                            <label for="balance" class="">Balance</label>
                                                            <div class="" style="border:1px solid #dddddd;">
                                                                @Html.TextBox("balance", "", new { @class = "form-control", placeholder = "Enter Balance", autocomplete = "off", @required = "required", @pattern = "[0-9]{0,20}", @title = "Only number is allowed" })

                                                            </div>
                                                            @Html.ValidationMessage("balance", new { @class = "text-danger" })
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="form-group formElement" id="dopistChargeDiv" style="display:none;">


                                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="RefNo">Deposit&nbsp;Charge</label>
                                                            <div class="" style="border:1px solid #dddddd;">
                                                                @Html.TextBox("dipositCharge", "20", new { @class = "form-control", disabled = "disabled" })
                                                            </div>
                                                            @Html.ValidationMessage("dipositCharge", new { @class = "text-danger" })
                                                        </div>
                                                    </div>
                                                </div>
                                                <div id="divPancard" class="form-group formElement" style="display:none;">

                                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="RefNo">Pancard</label>
                                                            <div class="" style="border:1px solid #dddddd;">
                                                                @Html.TextBox("pancard", "", new { @class = "form-control", pattern = @"^([a-zA-Z]){5}([0-9]){4}([a-zA-Z]){1}?$" })
                                                            </div>
                                                            @Html.ValidationMessage("pancard", new { @class = "text-danger" })
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row clearfix">


                                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="RefNo">Reffrence&nbsp;ID</label>
                                                            <div class="" style="border:1px solid #dddddd;">
                                                                @Html.TextBox("utrno", "", new { @class = "form-control", placeholder = "Enter UTR/Slip No", @required = "required" })
                                                            </div>
                                                            @Html.ValidationMessage("utrno", new { @class = "text-danger" })
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row clearfix">

                                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="firstname" class="">Account</label>
                                                            <div class="" style="border:1px solid #dddddd;">
                                                                @Html.DropDownList("accountno", ViewBag.account as SelectList, "Select Admin Account No", new { id = "accountno1", @class = "form-control acc", @required = "required" })
                                                            </div>
                                                            @Html.ValidationMessage("accountno", new { @class = "text-danger" })
                                                        </div>
                                                    </div>
                                                </div>
                                                <div id="divbranch" class="form-group formElement" style="display:none;">


                                                    <div class="row clearfix">
                                                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                            <div class="form-group">
                                                                <label for="RefNo">Branch</label>
                                                                <div class="" style="border:1px solid #dddddd;">
                                                                    @Html.TextBox("branch", "", new { @class = "form-control", placeholder = "Enter Branch" })
                                                                </div>
                                                                @Html.ValidationMessage("branch", new { @class = "text-danger" })
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div id="divpartyAcc" class="form-group formElement">
                                                    <div class="row clearfix">
                                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="RefNo">Party Account</label>
                                                            <div class="" style="border:1px solid #dddddd;">
                                                                @Html.TextBox("partyAcc", "", new { @class = "form-control", placeholder = "Enter Third Party Account", })
                                                            </div>
                                                            @Html.ValidationMessage("partyAcc", new { @class = "text-danger" })
                                                        </div>
                                                    </div>
                                                     </div>
                                                </div>
                                                <div id="divAccHolderName" class="form-group formElement">
                                                    <div class="row clearfix">
                                                            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                                <div class="form-group">
                                                                    <label for="RefNo">Account Holder Name</label>
                                                                    <div class="" style="border:1px solid #dddddd;">
                                                                        @Html.TextBox("AccHolderName", "", new { @class = "form-control", placeholder = "Enter Account Holder Name", })
                                                                    </div>
                                                                    @Html.ValidationMessage("AccHolderName", new { @class = "text-danger" })
                                                                </div>
                                                           </div>
                                                    </div>
                                                </div>
                                                 
                                                        <div class="row clearfix">
                                                            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                                <div class="form-group">
                                                                    <label for="balance" class="">Comment</label>
                                                                    <div class="" style="border:1px solid #dddddd;">
                                                                        @Html.TextBox("Comment", "", new { @class = "form-control", placeholder = "Enter Comment or remark", autocomplete = "off" })

                                                                    </div>
                                                                    @Html.ValidationMessage("Comment", new { @class = "text-danger" })
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="row clearfix">
                                                           
                                                            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                                <div class="form-group">
                                                                    <label for="balance" class="">Screenshot</label>
                                                                    <div class="" style="border:1px solid #dddddd;">
                                                                        @Html.TextBox("file", "", new { @type = "file", @class = "form-control", autocomplete = "off" })

                                                                    </div>
                                                                    @Html.ValidationMessage("file", new { @class = "text-danger" })
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer" style="margin-top:-15px;padding-right:0px;">
                                                            <button type="button" class="btn  waves-effect" style="background:transparent;border:1px solid #c7c7c7; margin-left: -3px; height:34px;" data-dismiss="modal">
                                                                <span style="color:black;">Close</span>
                                                            </button>
                                                            <button type="submit" class="btn bg-grey waves-effect" style="  height:34px;    background:linear-gradient(to right, @PageData["Globalfirst"],@PageData["GlobalSecond"]);" onclick="return confirm('Are you sure?');">
                                                                <span style="color:#fff;">Save Change</span>
                                                            </button>

                                                        </div>

</form>

                                            }
                                        </div>
                                        <div role="tabpanel" class="tab-pane fade" id="CREDIT">
                                            @using (Html.BeginForm("purchageorder", "Home", FormMethod.Post))
                                            {
                                            <form id="form_validation" method="POST">
                                                @Html.Hidden("type", "Credit")

                                                <div class="row clearfix">

                                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="balance" class="">Balance</label>
                                                            <div class="" style="border:1px solid #dddddd;">
                                                                @Html.TextBox("balance", "", new { @class = "form-control", placeholder = "Enter Balance", autocomplete = "off", @required = "required", @pattern = "[0-9]{0,20}", @title = "Only number is allowed" })

                                                            </div>
                                                            @Html.ValidationMessage("balance", new { @class = "text-danger" })
                                                        </div>
                                                    </div>
                                                </div>


                                                <div class="row clearfix">

                                                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <label for="balance" class="">Comment</label>
                                                            <div class="" style="border:1px solid #dddddd;">
                                                                @Html.TextBox("Comment", "", new { @class = "form-control", placeholder = "Enter Comment or remark", autocomplete = "off" })

                                                            </div>
                                                            @Html.ValidationMessage("Comment", new { @class = "text-danger" })
                                                        </div>
                                                    </div>
                                                </div>


                                                <div class="modal-footer" style="margin-top:-15px;padding-right:0px;">
                                                    <button type="button" class="btn  waves-effect" style="background:transparent;border:1px solid #c7c7c7; margin-left: -3px; height:34px;" data-dismiss="modal">
                                                        <span style="color:black;">Close</span>
                                                    </button>
                                                    <button type="submit" class="btn bg-grey waves-effect" style="  height:34px;    background:linear-gradient(to right, @PageData["Globalfirst"],@PageData["GlobalSecond"]);" onclick="return confirm('Are you sure?');">
                                                        <span style="color:#fff;">Save Change</span>
                                                    </button>

                                                </div>

                                               
                                            </form>

                                            }
                                        </div>


                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>



                </div>
            </div>


        </div>
    </div>
</div>

