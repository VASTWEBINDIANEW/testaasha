<script type="text/javascript">
    function GenerateInvoice(DistOldBal, Value, DistNewBal, Date) {
        //alert(ReciveFrom + '' + OldRemain + '' + Value + '' + Commission + '' + FinalValue + '' + NewRemain + '' + Date)
        var url = '@Url.Action("GotoInvoicePDF", "Home")?Value=' + Value + '&DistOldBal=' + DistOldBal + '&DistNewBal=' + DistNewBal + '&Date=' + Date + '';
        window.open(url, "_blank");
    }
</script>
<script>
    $(function () {
        $('#Paymode').change(function () {

            var amount = $('#balanceDiv').find('input[name="balance"]').val();//$("#balance").text();
            //alert('amount'+amount);
            var disCharge = 20;
            $(".formElement").hide();
            var name = $("#Paymode option:selected").val();
            if (name == "Third Party Transfer") {
                $('#divpartyAcc').show();
                $('#divAccHolderName').show();
            }
            if (name == "ATM Machine Deposit") {
                $('#divbranch').show();
                $('#divPancard').show();
                $('#dopistChargeDiv').show();
                //alert('@ViewBag.ATMMinCharge');
                //alert('@ViewBag.ATMChargePercant');
                disCharge = (amount * '@ViewBag.ATMChargePercant') / 100;
                // alert(disCharge);
                if (disCharge <= '@ViewBag.ATMMinCharge') {
                    disCharge = '@ViewBag.ATMMinCharge';
                }
            }
            if (name == "Branch Cash Deposit") {
                $('#divbranch').show();
                $('#divPancard').show();
                $('#dopistChargeDiv').show();
                disCharge = (amount * '@ViewBag.CashChargePercant') / 100;
                //alert(disCharge);
                if (disCharge <= '@ViewBag.CashMinCharge') {
                    disCharge = '@ViewBag.CashMinCharge';
                }
            }
            $('#dipositCharge').val(disCharge);
        });

        $(document).on("focusout", "#balance", function () {
            // alert();
            var disCharge = 20;
            // alert();
            var amount = $(this).val();
            // alert("amount " +amount);

            //var dipCharge = $("#dipositCharge").val();
            var name = $("#Paymode option:selected").val();
            //alert("name " + name);
            if (name == "ATM Machine Deposit") {
                disCharge = (amount * '@ViewBag.ATMChargePercant') / 100;
                //alert(disCharge);
                if (disCharge <= '@ViewBag.ATMMinCharge') {
                    disCharge = '@ViewBag.ATMMinCharge';
                }

            } else if (name == "Branch Cash Deposit") {
                disCharge = (amount * '@ViewBag.CashChargePercant') / 100;
                if (disCharge <= '@ViewBag.CashMinCharge') {
                    disCharge = '@ViewBag.CashMinCharge';
                }
            }
            // alert(disCharge);
            $("#dipositCharge").attr("disabled", false);
            $("#dipositCharge").val(disCharge);
            $("#dipositCharge").attr("disabled", true);
        });
    });

</script>

