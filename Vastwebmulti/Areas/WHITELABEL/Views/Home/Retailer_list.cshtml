<script type="text/javascript">
        var val1 = "";
        function editretailer(RetailerId) {
            var url = '@Url.Action("RetailerIdSearch", "Home")'
            $.ajax({
                url: url,
                data: { RetailerId: RetailerId },
                cache: false,
                type: "POST",
                success: function (data) {
                    var rem = JSON.parse(data);
                    console.log(rem);

                    if (rem != null && rem.State != null && rem.State > 0) {
                        $("#txtremid").val(rem.RetailerId);
                        $("#txtemailnew").val(rem.Email);
                        $("#txtretailername").val(rem.RetailerName);
                        $("#txtfirmname").val(rem.Frm_Name);
                        $("#State").val(rem.State);
                        $("#txtmobilenew").val(rem.Mobile);
                        $("#txtAddress").val(rem.Address);
                        $("#txtpincode1").val(rem.Pincode);
                        $("#txtcapping1").val(rem.caption);
                        $("#txtpencardno1").val(rem.PanCard);
                        $("#txtadharcardno1").val(rem.AadharCard);
                        $("#txtgstno1").val(rem.gst);
                        $("#PartnerID").val(rem.PartnerID);
                        $("#aepsMID").val(rem.AepsMerchandId);
                        $("#aepsMPIN").val(rem.AepsMPIN);
                        //$("#slabedit").val(data.slab_name);
                        var objSelect1 = document.getElementById("District");
                        bind(rem.State, rem.District, objSelect1);
                        $('#defaultModal1').modal('show');
                    }
                   else
                   {
                       swal("Oops!!", "Failed to fatch user details.", "error");
                    }
                },
                error: function (Xhr,err) {
                    alert("statusCode : " + Xhr.status);
                    alert("error : " + Xhr.responseText);
                }
            });

        }
    function bind(staid, dist, objSelect1) {

            var url = '@Url.Action("DistrictList","Home")'
            $.ajax({
                url: url,
                data: { Id: staid },
                cache: false,
                type: "POST",
                success: function (data) {
                    var markup = "<option value='0'>Select District</option>";
                    for (var x = 0; x < data.length; x++) {
                        markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                    }
                    $("#District").html(markup).show();
                    setSelectedValue(objSelect1, dist);
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                }
            });
        }
    function setSelectedValue(selectObj, valueToSet) {

            for (var i = 0; i < selectObj.options.length; i++) {
                if (selectObj.options[i].value == valueToSet) {
                    //alert(selectObj.options[i].value);
                    selectObj.options[i].selected = true;
                    return;
                }
            }
        }
</script>
