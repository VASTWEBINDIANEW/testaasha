<script>

    $('.for-form-in').click(function () {
        $('.form-pop-up').toggle('slow');
    });


</script>
<script>
    $(document).ready(function () {

       var succ = '@ViewData["success"]';
        if (succ != null && succ != "") {
            if (succ.includes("successfully")) {
                //swal("Data Upload!", succ, "success");
            }
            else {
                //swal("Oops!", succ, "error");
            }
        }
        var first = '@ViewData["first"]';
        var second = '@ViewData["second"]';
        if (first != "" && second != "") {
            $("#color1").val(first);
            $("#color2").val(second);
            $("#txtcolor").val(first);
            $("#txtcolor1").val(second);
        }
    });
</script>
<script type="text/javascript">

    function delNewUpdate(e) {
     

    $.ajax({
        type: "POST", url: '@Url.Action("delNewUpdate", "Home")', data: { Id: e }, dataType: 'json', cache: false, success: function (result) {
            if (result == "Success") {
               // swal("Deleted!", "New Update Data Deleted Successfully.", "success");
                var url = '@Url.Action("New_Update", "Home")';
                window.location.href = url;
            }
            else {
                swal("Failed!", "Something went wrong.", "error");
                var url = '@Url.Action("New_Update", "Home")';
                window.location.href = url;
            }
        }
    });


    }

</script>


<script>
      function fun() {
           var col = document.getElementById("color1").value;
           $("#txtcolor").val(col);
           var col = document.getElementById("color2").value;
           $("#txtcolor1").val(col);
       }
</script>
