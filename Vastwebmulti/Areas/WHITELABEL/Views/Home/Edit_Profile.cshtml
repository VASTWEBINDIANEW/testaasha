                                     new SelectListItem{Text="Beauty and Wellness",Value="Beauty and Wellness"},
                                     new SelectListItem{Text="Advertising Agenices",Value="Advertising Agenices"},
                                     new SelectListItem{Text="accounting & Tax Consultants",Value="accounting & Tax Consultants"},
                                     new SelectListItem{Text="Employment Consultants",Value="Employment Consultants"},
                                     new SelectListItem{Text="Software Development and Sales",Value="Software Development and Sales"},
                                     new SelectListItem{Text="Photo and Video Studio",Value="Photo and Video Studio"},
                                     new SelectListItem{Text="Computer Repair & Services",Value="Computer Repair & Services"},
                                     new SelectListItem{Text="Tent And Awning Shops",Value="Tent And Awning Shops"},
                                     new SelectListItem{Text="Packers and Movers",Value="Packers and Movers"},
                                     new SelectListItem{Text="RealEstate Consultants",Value="RealEstate Consultants"},
                                     new SelectListItem{Text="Laundy and Dry Cleaner",Value="Laundy and Dry Cleaner"},
                                     new SelectListItem{Text="Matrimony Services",Value="Matrimony Services"},
                                     new SelectListItem{Text="Lawyers",Value="Lawyers"},
                                     new SelectListItem{Text="Charitable Organisation",Value="Charitable Organisation"},
                                     new SelectListItem{Text="Driving Classes",Value="Driving Classes"},
                                     new SelectListItem{Text="Elementary and Secondary Schools",Value="Elementary and Secondary Schools"},
                                     new SelectListItem{Text="Correspondance Courses",Value="Correspondance Courses"},
                                     new SelectListItem{Text="Other Events & Entertainment",Value="Other Events & Entertainment"},
                                     new SelectListItem{Text="Security Brokers and Dealers",Value="Security Brokers and Dealers"},
                                     new SelectListItem{Text="Collection Agency",Value="Collection Agency"},

                                    new SelectListItem{Text="fuel Service Stations",Value="fuel Service Stations"},
                                    new SelectListItem{Text="Government",Value="Government"},
                                    new SelectListItem{Text="Home Services",Value="Home Services"},
                                    new SelectListItem{Text="Hospitals and Healthcare",Value="Hospitals and Healthcare"},
                                    new SelectListItem{Text="Hotels, Restaurants and Food",Value="Hotels, Restaurants and Food"},
                                    new SelectListItem{Text="Insurance Sale",Value="Insurance Sale"},
                                    new SelectListItem{Text="Computers and Acessories",Value="Computers and Acessories"},
                                    new SelectListItem{Text="Silver Jewellery",Value="Silver Jewellery"},
                                    new SelectListItem{Text="Hardware Shop (Paint & Building Materials)",Value="Hardware Shop (Paint & Building Materials)"},
                                    new SelectListItem{Text="Mobile shop",Value="Mobile shop"},
                                    new SelectListItem{Text="Home Decor",Value="Home Decor"},
                                    new SelectListItem{Text="Bicycle Shop, Repair and Service",Value="Bicycle Shop, Repair and Service"},
                                    new SelectListItem{Text="Tours and Travel Agency",Value="Tours and Travel Agency"},
                                    new SelectListItem{Text="Trucks and Others",Value="Trucks and Others"},
                                    new SelectListItem{Text="Taxi and Car Rentals",Value="Taxi and Car Rentals"},
                                    new SelectListItem{Text="Cruises Service",Value="Cruises Service"},
                                      new SelectListItem{Text="Tuition and Classes",Value="Tuition and Classes"},
                                    new SelectListItem{Text="Cable Service Providers",Value="Cable Service Providers"},
                                    new SelectListItem{Text="Recharges and Bill Payments",Value="Recharges and Bill Payments"},

                              }, new { @class = "selectpicker form-control", data_live_search = "true", @required = "required" })

                                                </div>
                                                @Html.ValidationMessageFor(model => model.BusinessType)
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="address" class="required">Bank Account Number</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(m => m.Bankaccountno, new { @class = "form-control", onkeypress = "return isNumber(event)", @required = "" })
                                                </div>
                                                @Html.ValidationMessageFor(model => model.Bankaccountno)
                                            </div>
                                        </div>

                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label for="address" class="required">Bank Name</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(m => m.bankname, new { @class = "form-control", @required = "" })
                                                </div>
                                                @Html.ValidationMessageFor(model => model.bankname)
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="address" class="required">IFSC Code</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(m => m.Ifsccode, new { @class = "form-control", @required = "" })
                                                </div>
                                                @Html.ValidationMessageFor(model => model.Ifsccode)
                                            </div>
                                        </div>

                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label for="address" class="required">Account Holder</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(m => m.accountholder, new { @class = "form-control", @required = "" })
                                                </div>
                                                @Html.ValidationMessageFor(model => model.accountholder)
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="address" class="required">City</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(m => m.city, new { @class = "form-control", @required = "" })
                                                </div>
                                                @Html.ValidationMessageFor(model => model.city)
                                            </div>
                                        </div>


                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <label for="address" class="required">Branch&nbsp;Address</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(m => m.bankAddress, new { @class = "form-control", @required = "" })
                                                </div>
