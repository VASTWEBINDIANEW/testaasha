                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="edit-white-b" style="border:1px solid #dddddd;">
                                                    @Html.DropDownListFor(m => m.district, (IEnumerable<SelectListItem>)ViewBag.District, "-- Select District--", new { @class = "form-control", @required = "required" })
                                                </div>
                                                @Html.ValidationMessageFor(model => model.district)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
