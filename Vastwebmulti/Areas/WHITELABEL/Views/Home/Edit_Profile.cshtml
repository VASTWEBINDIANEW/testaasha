@model Vastwebmulti.Models.WhiteLabel_userList
@{
    ViewBag.Title = "Edit_Profile";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}
<style>
    .field-validation-error {
        color: red;
    }

    .required:after {
        color: red;
        content: " *";
    }
</style>
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }
</style>
<section class="content">
    <div class="container-fluid white-l-edit">
        <div class="row clearfix">
               <div class="col-md-12">
                @using (Html.BeginForm("Edit_Profile", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
                {
                    <div class="card">
                        <div class="header" style="padding:10px;">
                            <h2>
                                <span style="font-size:21px;"></span> Update Profile Information
                            </h2>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="white-l-edit-first">
                                    <div class="row">
                                        <div class="col-md-6">
                                            @Html.HiddenFor(model => model.Idno)
                                            <label for="email_address" class="required">Email-Id</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(model => model.EmailId, new { @class = "form-control", @readonly = "readonly" })
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                            <label for="setbox" class="required">Name</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(model => model.Name, new { @class = "form-control" })
                                                </div>
                                                @Html.ValidationMessageFor(model => model.Name)
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label for="package" class="required">Frim Name</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(model => model.FrmName, new { @class = "form-control" })
                                                </div>
                                                @Html.ValidationMessageFor(model => model.FrmName)
                                            </div>
                                        </div>

                                        <div class="col-md-6">
                                            <label for="amount" class="required">Mobile Number</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(model => model.Mobile, new { @class = "form-control", @readonly = "readonly" })
                                                </div>
                                                @Html.ValidationMessageFor(model => model.Mobile)
                                            </div>
                                        </div>
                                    </div>
