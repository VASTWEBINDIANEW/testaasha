                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="address" class="required">Pancard Upload</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(m => m.pancardPath, new { @type = "file", @class = "form-control" })
                                                </div>

                                            </div>
                                        </div>


                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label for="address" class="required">Aadhaar Upload</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(m => m.aadharcardPath, new { @type = "file", @class = "form-control" })

                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="address">Passport Image Upload</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(m => m.Photo, new { @type = "file", @class = "form-control" })
                                                </div>

                                            </div>
                                        </div>


                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label for="address">Firm Registration Upload</label>
                                            <div class="form-group" style="margin-bottom:0px;">
                                                <div class="" style="border:1px solid #dddddd;">
                                                    @Html.TextBoxFor(m => m.frimregistrationPath, new { @type = "file", @class = "form-control" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">

                                            <div style="margin-top:25px;">
                                                <button type="submit" class="btn  " style="height:36px;float:right;background:red;color:#fff; ">Update Profile</button>
                                                <a href="@Url.Action("Profile","Home")" class="btn bg-blue-grey waves-effect" style="padding: 10px 23px !important; float:right;margin-right:15px;">Back</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                </div>
                           
                                
                                                   
                            </div>
                        </div>
                }
                    </div>
           
            </div>
            
        </div>
    
</section>


<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />/>
<script language="javascript" type="text/javascript">
                    $(function () {
                        $('#state').change(function () {
                            // alert('Value:' + ' ' + $('#State1').val())
                            var stid = $('#state').val()
                                GetDistrict1(stid)
                        });
                    })

                    function GetDistrict1(_stateId) {
                        var procemessage = "<option value='0'> Please wait...</option>";
                        $("#district").html(procemessage).show();
                        var url = '@Url.Action("DistrictList","Home")'
                        $.ajax({
                            url: url,
                            data: { Id: _stateId },
                            cache: false,
                            type: "POST",
                            success: function (data) {
                                $("#district").html("");
                                for (var x = 0; x < data.length; x++) {
                                    //alert(markup)
                                    $("#district").append($('<option></option>').val(data[x].Value).html(data[x].Text));
                                }

                            },
                            error: function (reponse) {
                                alert("error : " + reponse);
                            }
                        });
                    }
</script>


<script>
    $(function () {

        $('#state').val(@Model.state);
        $('#district').val(@Model.district);

    })
</script>

<script type="text/javascript">
        function isNumber(evt) {
            var iKeyCode = (evt.which) ? evt.which : evt.keyCode
            if (iKeyCode != 46 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
                return false;
            return true;
        }
</script>

