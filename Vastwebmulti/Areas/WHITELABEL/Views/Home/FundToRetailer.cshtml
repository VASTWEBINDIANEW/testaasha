@model Vastwebmulti.Areas.WHITELABEL.Models.fundtransferretailer
@{
    ViewBag.Title = "FundToRetailer";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }

    .btn-group, .btn-group-vertical {
        box-shadow: none;
    }

    .ppp {
        margin-top: -20px !important;
    }

    .form-inline .bootstrap-select.btn-group, .form-horizontal .bootstrap-select.btn-group, .form-group .bootstrap-select.btn-group {
        height: 29px;
    }
</style>
<style>
    .slab-setting-menu li a.activee {

    background:linear-gradient(to right, @PageData["Globalfirst"],@PageData["GlobalSecond"]);

    }

</style>
<section class="content">
    <div class="container-fluid">

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card" style="margin-bottom:15px;">
                    <div class="col-md-7">
                        
                                <div style="margin-left:-13px;">
                                    @Html.Partial("_Menuaccount")
                                </div>


                    </div>
                    <div class="col-md-5">
                        @using (Html.BeginForm("FundToRetailer", "Home", FormMethod.Post))
                        {
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group" style="margin-bottom:0px;">
                                       
                                        <div class="" style="padding-bottom:3px;border:1px solid #dddddd;">
                                            @Html.DropDownListFor(model => model.retailerid1, new SelectList(ViewBag.remid, "Value", "Text"), "Select Retailer Id", new { @class = "selectpicker form-control", data_live_search = "true", required = "required", @style = "height:34px;padding:0px;" })

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6"  style="padding:0px;">
                                    <div class="form-group for-web-date" style="margin-bottom:0px;">
                                        <div class="input-daterange input-group">
                                            <div class="custom-date-icon" style="height: 34px;">
                                                <i class="fa fa-calendar tmw-total-color-one" aria-hidden="true" style="color: #46c837;"></i>
                                            </div>
                                            @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;padding-right: 0px;padding-left: 20px !important; ", autocomplete = "off" })
                                            <span class="input-group-addon">
                                                <i class="fa fa-exchange"></i>
                                            </span>
                                            <div class="custom-date-icon" style="height: 34px;">
                                                <i class="fa fa-calendar tmw-total-color-one" aria-hidden="true" style="color: #46c837;"></i>
                                            </div>
                                            @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;padding-right: 0px;padding-left: 20px !important; ", autocomplete = "off" })
                                        </div>
                                        <!-- /.input group -->
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <center>
                                        <button type="submit" class="btn waves-effect" style=" background:transparent;border:1px solid #c7c7c7; height:34px;">
                                        
                                            <span style="color:black;">Search</span>
                                        </button>
                                    </center>
                                </div>

                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row clearfix">
            @using (Html.BeginForm("rem_fund_transfer", "Home", FormMethod.Post))
            {
                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                    <div class="card">
                        <div class="for-transfer-border" style="border-color: @PageData["Globalfirst"];">
                            <div class="row">

                                <div class="col-md-2">
                                    <div class="form-group" style=" margin-bottom:0px;">
                                        <div class="form-line" style="padding-bottom:3px;border:1px solid #dddddd;">
                                            @Html.DropDownListFor(model => model.retailerid, new SelectList(ViewBag.remid, "Value", "Text"), "Select Retailer Id", new { @class = "selectpicker form-control", data_live_search = "true", required = "required", @style = "padding-left:0px;" })

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-1" id="messageshow" style="display:none;">
                                    <div class="form-group" style="margin-top:2px; margin-bottom:0px; width:92px;margin-left:-11px;">
                                        <div class="" style="padding-top:3px;">
                                            <label id="msg1" style="color:red;font-weight:bold; padding-top:6px; padding-left:2px; padding-right:2px; background-color:white;height:34px;border:1px solid #dddddd;"></label>

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2" style="padding:0px;">
                                    <div class="form-group" style=" margin-bottom:0px;">
                                        <div class="" style="padding-bottom:3px;border:1px solid #dddddd;">
                                            <select id="ddl_fund_type" name="ddl_fund_type" class="selectpicker form-control" data-live-search="true" style="padding-top:4px;" required="">
                                                <option value="">Select Payment Mode</option>
                                                <option value="Cash"> CASH WALLET TRANSFER</option>
                                                <option value="Credit" style="color:red;">CREDIT VALUE TRANSFER</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group" style=" margin-bottom:0px;">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBox("balance", "", new { @class = "form-control", placeholder = "Value", required = "required", onkeypress = "return isNumber(event)", @style = "padding-top:4px;height:32px;" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2" style="padding:0px;">
                                    <div class="form-group" style=" margin-bottom:0px;">
                                        <div class="" style="border:1px solid #dddddd;">
                                            <textarea id="comment" name="comment" placeholder="Enter Comments" maxlength="120" class="form-control" style="height:32px;"></textarea>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group" style=" margin-bottom:0px;">
                                        <button type="submit" id="submit" class="btn btn-default waves-effect" style="  height:35px;border:1px solid #dddddd;">
                                            <i class="fa fa-exchange" style="top:1px;font-size:18px;"></i>
                                            <span style="top:-1px;color:black;">Go To Fund Transfer</span>
                                        </button>

                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="web-white-filter" style="float:right;">
                                        <table class="dataTable js-exportable ">
                                            <thead>
                                                <tr>
                                                    <td></td>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>


                    </div>
                </div>
            }
        </div>
      
        
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                     <div>
                        <div class="table-responsive    web-white-table" style="position:inherit;">
                            <table class="table table-bordered table-striped table-hover " style="width:100%;font-size:13px;">
                                <thead class="navbar" style="color:white;position:inherit;">
                                    <tr>
                                        <th>Date</th>
                                        <th>Retailer&nbsp;Id</th>
                                        <th>Retailer&nbsp;Name</th>
                                        <th>Amount</th>
                                        <th>Whitelabel&nbsp;Pre</th>
                                        <th>Whitelabel&nbsp;Post</th>
                                        <th>Retailer&nbsp;Pre</th>
                                        <th>Retailer&nbsp;Post</th>
                                        <th>Type</th>
                                        <th>Current&nbsp;Credit</th>
                                        <th>Old&nbsp;Credit&nbsp;Pay</th>
                                        <th>Fund&nbsp;Value</th>
                                       <th>Comment</th>
                                    


                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.FundTransfer_retailer)
                                    {
                                        <tr>
                                            <td style="font-size:11px;">@item.transfer_date</td>
                                            <td>@item.retailerid</td>
                                            <td>@item.retailername</td>
                                            <td>@item.balance</td>
                                            <td>@item.whitelabelpre</td>
                                            <td>@item.whitelabelpost</td>
                                            <td>@item.retaileridpre</td>
                                            <td>@item.retaileridpost</td>
                                            <td>@item.baltype</td>
                                            <td>@item.cr</td>
                                            <td>@item.oldcrbal</td>
                                            <td>@item.Fundvalue</td>
                                            <td>@item.comment</td>
                                           
                                        </tr>
                                    }

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="modal fade" id="creditModal" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-sm" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background-color:whitesmoke;">
                <div class="col-xs-6" style="border:1px solid #c7c2c2;">
                    <div style="margin-top:5px;margin-bottom:-7px;">
                        <p style="color:red;margin-left:-8px;">OLD&nbsp;DUE&nbsp;AMOUNT</p>
                    </div>

                </div>
                <div class="col-xs-4" style="border:1px solid #c7c2c2;">
                    <div style="margin-top:5px;margin-bottom:-7px;">
                        <p id="msg"></p>
                    </div>
                </div>
                <div class="col-xs-2">
                    <button type="button" class="btn waves-effect" style="margin-top:-8px; margin-left: -3px; height:34px;background-color:whitesmoke;" data-dismiss="modal">
                        <i class="fa fa-close" style="color:#b9b3b3;"></i>
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/plugins/bootstrap-colorpicker/js/bootstrap-colorpicker.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script src="@Url.Content("~/Scripts/jquery.validate.min.js")"></script>
<script src="@Url.Content("~/Scripts/jquery.validate.unobtrusive.min.js")"></script>
<script>

    $(document).ready(function()
    {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
    });
</script>

<script>
    window.onload = function() {
        var result = '@TempData["result"]';
        var sts = '@TempData["sts"]';
        if (result!= null && result != '')
        {
            swal("Good job!", result, sts);
        }
        

    }
</script>

<script>
    $(window).load(function () {
        $("#retailerid").change(function () {
            var mid = $('option:selected', $(this)).val();

            if (mid != "Select Retailer Id" && mid != "") {
                $.ajax({
                    type: 'Post',
                    url: "@Url.Action("Retailer_Creditchk", "Home")",
                    data: { remid: mid },
                dataType: 'json',
                cache: false,
                async: false,
                success: function (data) {
                    if (data > 0) {
                        $('#msg').html(data)
                        $("#creditModal").modal('show');
                    }
                    else {
                        alert("No Old Credit Balance");
                    }
                }
            });
            }
        });

    });
</script>

<script type="text/javascript">
           $(document).ready(function () {
           $('#submit').on('click', function (e, data) {
               var ddl = document.getElementById("retailerid")
               var x = ddl.options[ddl.selectedIndex].text;
               var x2 = document.getElementById("balance").value;
               var paymode = document.getElementById("ddl_fund_type")
               var pay = paymode.options[paymode.selectedIndex].text;
               if (x == "Select Retailer Id") {
                   $("#retailerid").validate({
                       rules: {
                           retailerid: {
                               required: true
                           }
                       }
                   });
                   return false;
                   event.preventDefault;
               }
               if (x2 == "" || x2 == null) {

                   $("#balance").validate({
                       rules: {
                           balance: {
                               required: true
                           }
                       }
                   });
                   return false;
                   event.preventDefault;
               }
               if (pay == "" || pay == null || pay == "Select Payment Mode") {


                   return false;
                   event.preventDefault;

               }
               else {
                   var text = "Fund Transfer To Retailer ID: " + x + "   Amount: " + x2 + " Only."
                   if (!data) {
                       handleDelete(e, 1, text);
                   } else {
                       window.location = $(this).attr('href');
                   }
               }
           });
       });
       function handleDelete(e, stop, kk) {
           if (stop) {
               e.preventDefault();
               swal({
                   title: "Are you sure?",
                   text: kk,
                   type: "warning",
                   showCancelButton: true,
                   confirmButtonColor: "#DD6B55",
                   confirmButtonText: "Yes, Fund Transfer!",
                   closeOnConfirm: false
               },
    function (isConfirm) {
        if (isConfirm) {
            $(e.target).trigger('click', {});
        }
    });
           }
       };
</script>
<script>
    function showfunddiv()
    {

        document.getElementById("funddivshow").style.display = "block";
        document.getElementById("btnfund").style.display = "none";
    }
</script>