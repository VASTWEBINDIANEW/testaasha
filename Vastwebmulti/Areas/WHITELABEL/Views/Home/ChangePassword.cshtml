                                                            <button type="submit" class="btn  m-t-15 waves-effect fullbodydycolorbg password-sure" data-loading-text="<i class='fa fa-spinner fa-spin'></i>" style="border:1px solid #c7c2c2;color:#fff;width:131px;display:none;font-size: 18px;line-height: 18px;">Sure ?</button>

                                                        </div>

                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                    }

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>


