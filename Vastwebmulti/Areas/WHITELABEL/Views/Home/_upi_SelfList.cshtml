@model Vastwebmulti.Areas.WHITELABEL.Models.upiChargeAndgateway
<style>
    .wallet-bank-input input[readonly="readonly"] {
        background: transparent;
        border: 0px;
    }
</style>

<table class="table table-bordered wallet-bank-input" style="width: 100%;margin-top:5px;">
    <thead>
        <tr>
            <th>UPI ID</th>
            <th>Min (Rs)</th>
            <th>Max (Rs)</th>
            <th>Delete</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Admin_UPIs)
        {
        <tr style="background:#fff;">
            <td><input type="text" value="@item.Upiid" readonly="readonly" /></td>
            <td><input type="text" value="@item.minamount" readonly="readonly" /></td>
            <td><input type="text" value="@item.maxamount" readonly="readonly" /></td>
            <td>
                <button type="submit" class="fullbodydycolorbg waves-effect bt btnssl  special-iii deleteCharged1" style="background:transparent;border:1px solid #bbb;padding: 2px 10px;margin-left: 4px;padding-bottom: 3px;color:#fff;">
                    Delete
                </button>
                <button type="submit" onclick="DeleteSelf()" class="fullbodydycolorbg waves-effect bt btnssl special-iii deleteCharge" style="background:transparent;border:1px solid #bbb;padding:2px;margin-left: 4px;color:#fff;display:none;width:61px;">
                    Sure?
                </button>
            </td>
        </tr>
        }
    </tbody>
</table>
@if (Model.msg != "DONE")
{
    <label style="color:red;">@Model.msg</label>
}
<script>
    function DeleteSelf() {
            var url = '@Url.Action("DeleteUpiself", "Home")';
            $.ajax({
                url: url,
                cache: false,
                type: "GET",
                success: function (data) {
                    $('#RemTbl11').html(data);
                }
            });
        }
</script>
<script>
    $('.wallet-edit').click(function () {
        $(this).closest('tr').find('input').removeAttr('readonly');
        $(this).closest('tr').find('.wallet-save').css('display', 'block');
        $(this).css('display', 'none');
    });
</script>
<script>
    $('.deleteCharged1').click(function () {
        $(this).hide();
        $(this).next('.deleteCharge').show();
    });
    $('#EditChrg').click(function () {
        $(this).next('.deleteCharged1').hide();
    });
</script>
