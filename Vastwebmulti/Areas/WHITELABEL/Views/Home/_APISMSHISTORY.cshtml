@model Vastwebmulti.Areas.WHITELABEL.Models.Whitelabel_SMSViewModel

<div class="tab-content-table" id="APISMSHISTORYtab">
    <div class="table-responsive">
        <table class="table table-bordered" style="width:100%;" id="APISMSHISTORY">
            <thead>
                <tr class="first-tr">
                  
                    <th>Date&nbsp;&&nbsp;Time</th>
                    <th>API Response</th>
                    <th>Sending Message</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                    if (Model.whitelabel_sms_api_entry.Count > 0)
                    {
                        foreach (var item in Model.whitelabel_sms_api_entry)
                        {
                                <tr>
                                    @*<td>@i</td>*@
                                    <td style="padding:3px;">@item.m_date</td>
                                    <td style="padding:3px;">@item.response</td>
                                    <td style="padding:3px;">@item.msg</td>


                                </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3">
                                <div class="no-data-found-img">
                                    <img src="~/img/NoDatall.svg" />
                             </div>
                            </td>

                        </tr>
                    }
                }

            </tbody>
        </table>
    </div>
</div>
