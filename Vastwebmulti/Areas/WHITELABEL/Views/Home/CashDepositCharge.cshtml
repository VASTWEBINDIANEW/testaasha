@model Vastwebmulti.Areas.WHITELABEL.Models.Whitelabel_CashDepositeAndBank_Info_VM
@{
    ViewBag.Title = "ShowPurchase_master";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}

<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }

    .cas-hdeposi-tcharge-page .bank-name ul {
        margin-top: 8px;
    }

    .cash-charg-tab .nav-pills > li.active > a {
        background: transparent;
        color: inherit;
    }

    .cash-charg-tab .nav-pills > li > a {
        background: transparent;
        color: inherit;
        padding: 0px;
    }

        .cash-charg-tab .nav-pills > li > a::before {
            content: '';
            border: 2px solid #bbb;
            width: 12px;
            height: 12px;
            display: inline-block;
            border-radius: 50%;
            margin-right: 5px;
        }

    .cash-charg-tab .nav-pills > li.active > a::before {
        background: var(--main-bg-lcolor);
        border-color: var(--main-bg-lcolor);
    }

    .cash-charg-tab .nav-pills > li {
        padding: 5px 9px;
        margin: 0px auto;
    }

    .select2-container--default .select2-selection--single {
        border-radius: 0px !important;
    }
    /*.cash-charg-tab-first .btn.btn-default{background-color:transparent !important;}*/
    .select2-container .select2-selection--single {
        height: 32px !important;
        border-color: #ccc !important;
    }

    .cash-charg-tab-first #btnsubmit1, .cash-charg-tab-first #btnsubmit, .cash-charg-tab-first #btnsubmit2, .cash-charg-tab-first #btnsubmit3,
    .cash-charg-tab-first #btnsubmit4 {
        position: absolute;
        right: 29px;
        top: 83px;
    }

    #remcash table tbody tr th, #Distributor table tbody tr th, #Master table tbody tr th, #API table tbody tr th, #WhiteLabel table tbody tr th {
        padding: 5px 10px;
    }

    #EditPurchageOrder .col-md-6 {
        padding-right: 0px;
        width: 50%;
    }

    #EditPurchageOrder .col-md-3 {
        width: 25%;
        padding: 0px 5px;
    }

    #EditPurchageOrder #editbuttonRetailer.col-md-3, #EditPurchageOrder #editbuttonDealer.col-md-3, #EditPurchageOrder #editbuttonapi.col-md-3,
    #EditPurchageOrder #editbuttonmaster.col-md-3, #EditPurchageOrder #editbuttonwhite.col-md-3 {
        width: 22%;
        padding-left: 0px;
    }

    #remcash, #dlmcash, #farziidhye, #apicash, #whitecash {
        margin-top: 5px !important;
    }
    .cash-charg-tab .nav-pills > li {
        background: #000;
    }
        /*.cash-charg-tab .nav-pills > li.active::after, .cash-charg-tab .nav-pills > li::after, */.cas-hdeposi-tcharge-page .ca-dipo-left ul.tabs3 li::after, .cas-hdeposi-tcharge-page .ca-dipo-left ul.tabs3 li.current3::after{
        content: '';
        width: 25px;
        float: left;
        top: 0;
        left: 0;
        position: absolute;
        height: 70%;
        border: 2px solid #fff;
        margin: 5px;
    }
    /*.cash-charg-tab .nav-pills > li.active::before,*/ .cas-hdeposi-tcharge-page .ca-dipo-left ul.tabs3 li.current3::before {
        content: "";
        border-left: 2px solid #fff;
        border-bottom: 2px solid #fff;
        height: 28%;
        width: 17px;
        position: absolute;
        left: 9px;
        transform: rotate(-45deg);
        top: 9px;
    }
    .cash-charg-tab .nav-pills > li.active, .cas-hdeposi-tcharge-page .ca-dipo-left ul.tabs3 li.current3, .cash-charg-tab .nav-pills > li a::before {
        background: @PageData["Globalfirst"] !important;
        border-color: #fff;
    }
    .cash-charg-tab .nav-pills > li, .cas-hdeposi-tcharge-page .ca-dipo-left ul.tabs3 li, .ca-dipo-right ul.just-bottom li {
        background: @PageData["GlobalSecond"] !important;
        border: 0px !important;
        color: #fff !important;
        height: 36px;
        border-right: 2px solid #fff !important;
        padding: 7px;
        position: relative;
        text-align: center;
    }
    .cash-charg-tab .nav-pills > li.active a::before{background: @PageData["GlobalSecond"] !important;}
    @@media only screen and (max-width:520px) {
        .un-re-wa-right .unload-item.item-one, .un-re-wa-right .unload-item.item-two, .un-re-wa-right .unload-item.special-iii.item-three {
            padding: 0px 5px !important;
            width: 100%;
        }

        .un-re-wa-right {
            padding: 0px 5px !important;
        }

            .un-re-wa-right .unload-item.item-one, .un-re-wa-right .unload-item.item-two {
                width: 50%;
            }

            .un-re-wa-right .unload-item.special-iii.item-three .input-group-addon {
                min-width: 10px;
                padding: 0px;
            }

        .modal.Un-rwls-modal.in .modal-dialog, .modal.Un-rwls-modal .modal-dialog {
            width: 95%;
        }

        .un-re-wa-right .unload-item.special-iii.item-three .rightt button {
            width: 96%;
        }

        .table-responsive > .table-bordered > thead > tr > th:first-child, .table-responsive > .table-bordered > thead > tr > td:first-child,
        .table-responsive > .table-bordered > thead > tr > th:last-child, .table-responsive > .table-bordered > thead > tr > th:last-child {
            border-left: 1px solid var(--border-color);
            border-right: 1px solid var(--border-color);
        }

        .three-page-same .unload-item .rightt button span {
            float: none;
        }
        .cash-charg-tab .nav-pills > li, .cas-hdeposi-tcharge-page .ca-dipo-left ul.tabs3 li, .ca-dipo-right ul.just-bottom li{width: 100%;margin-bottom: 10px;}
            .ca-dipo-right ul.just-bottom li.acttt::after{display: none;}
        .bread-same-all-page a {
            font-size: 14px;
        }
    }
</style>
<section class="content cas-hdeposi-tcharge-page">
