<div id="myModal" class="modal fade Wallet-To-Bank-Charge-modal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content fullbodydycolorbg">
            <div class="modal-header">
                <h4 class="modal-title" id="defaultModalLabel" style="color:#fff;">Add Charge Category</h4>
            </div>
            @using (Ajax.BeginForm("AddWalletToBankSlab", "Home", new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "dataTable", InsertionMode = InsertionMode.Replace, OnSuccess = "OnSuccess", LoadingElementId = "div_Loader" }))
            {
                @Html.AntiForgeryToken()
                <div class="modal-body" style="margin-top:0px;">
                    <div class="body">
                        <form id="form_validation" method="POST">
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2" style="color:#fff;">Amount From</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBox("amtFromTatkal", "", new { onkeypress = "validate(event)", @class = "form-control searchInput", placeholder = "Enter From Amount", required = "required" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2" style="color:#fff;">Amount To</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBox("amtToTatkal", "", new { onkeypress = "validate(event)", @class = "form-control searchInput", placeholder = "Enter To Amount", required = "required" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2" style="color:#fff;">Charge</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBox("chargeTatkal", "", new { onkeypress = "validate(event)", @class = "form-control searchInput", placeholder = "Enter Charge", required = "required" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2" style="color:#fff;">Time</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #dddddd;">
                                            @Html.TextBox("TimeTakesTatkal", "", new { @class = "form-control searchInput", placeholder = "Enter Time in Hours", required = "required" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer special-iii">
                                <button type="submit" class="btn waves-effect btnssl2233 enableOnInput" data-loading-text="<i class='fa fa-spinner fa-spin'></i>" disabled="disabled">
                                    Save Change
                                </button>
                                <button type="button" class="btn waves-effect" id="closebtn" data-dismiss="modal">
                                    Close
                                </button>

                            </div>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

</div>
<script>
    function Unblock() {
            var url = '@Url.Action("UnblockWallet", "Home")';
            $.ajax({
            url: url,
            success: function(data)
            {
                //location.reload();
                var bttnn = "";
                if (data == true) {
                    $("#falseBtn").css('display', 'none');
                    $("#trueBtn").css('display', 'none');

                    bttnn = "<button onclick='Unblock()' style='background: green; padding: 4px 23px; border: 0px; color: #fff; border-radius: 15px;'>Wallet Unload Live</button>";
                                    }
                else {
                    $("#falseBtn").css('display', 'none');
                    $("#trueBtn").css('display', 'none');

                    bttnn = "<button onclick='Unblock()' style='background: red; padding: 4px 23px; border: 0px; color: #fff; border-radius: 15px;'> Wallet Unload Off </button>";
                }
                $("#bttnnn").html(bttnn);
            }
        });
    }
</script>
