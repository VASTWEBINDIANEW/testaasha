@model Vastwebmulti.Models.tblCard
@{
    ViewBag.Title = "Edit_Card";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                @using (Html.BeginForm("Edit_Card", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
                {
                    <div class="card">
                        <div class="header" style="padding:10px;">
                            <h2>
                                <span style="font-size:21px;"></span> Update Cards Content
                            </h2>
                        </div>
                        <div class="row">
                            <div class="body">
                                <div class="row clearfix">
                                    <div class="col-md-6">
                                        @Html.HiddenFor(model => model.Id)
                                        <label for="email_address">Card Name</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.CardName, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="email_address">Discount</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.Discount, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <div class="row clearfix">
                                    <div class="col-md-6">
                                        <label for="email_address">Promocode</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.Promocode, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="setbox">Select Image</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                <input type="file" id="file" name="file" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row clearfix">
                                    <div class="col-md-6">
                                        <button type="submit" class="btn bg-blue-grey">Update</button>
                                        <a href="@Url.Action("Card_Content","Home")" class="btn bg-blue-grey">Back</a>
                                    </div>
                                    <div class="col-md-6">

                                    </div>
                                </div>
                             
                            </div>
                        </div>

                    </div>
                }
            </div>

        </div>
    </div>
</section>

