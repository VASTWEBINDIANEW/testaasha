<script>
    function DelteDistributor(e, email) {
            $.ajax({
                type: "POST",
                url: '@Url.Action("Delete_Dealer", "Home")',
                data: { 'DealerId': e },
                cache: false,
                dataType: 'json',
                async: true,
                success: function (result) {
                    if (result == "Success") {
                        location.reload();
                        //swal({ title: "Deleted !", text: "Data Deleted Successfully.", type: "success" },
                        //    function () {
                        //        location.reload();
                        //    }
                        //);
                    }
                    else if (result == "FailedDealer") {
                         location.reload();
                        //swal({ title: "Failed !", text: "This Distributor Id is Not Deleted .Please Move the Our Retailer To Another Distributor .Then Delete It.", type: "error" },
                        //    function () {
                        //        location.reload();
                        //    }
                        //);
                    }
                    else {
                         location.reload();
                        //swal({ title: "Failed !", text: "Something went wrong.", type: "error" },
                        //    function () {
                        //        location.reload();
                        //    }
                        //);
                    }
                }
            });
    }
   
</script>
<script>
    $('.first-but').click(function(){
        $(this).hide();
        $(this).next('.first-buts').show();

    })
</script>