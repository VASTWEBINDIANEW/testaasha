<div class="">
    <table class="table table-bordered" id="mdList">
        <thead>
            <tr>
                <th>Distributor&nbsp;Firm</th>
                <th>Retailer&nbsp;Firm</th>
                <th>Retailer&nbsp;Name</th>
                <th>Mobile&nbsp;No</th>
                <th>Cap&nbsp;&#9853;</th>
                <th>Balance</th>
                <th>PAN&nbsp;No</th>
                <th>KYC</th>
                <th>Email&nbsp;V/F</th>

            </tr>
        </thead>
        <tbody id="body">
            @if (Model.select_retailer_details != null)
            {
                int i = 0;
                foreach (var item in Model.select_retailer_details)
                {
                    var idno = "subTbl";
                    idno = idno + i;

                    var idshow = "subTblshow";
                    idshow = idshow + i;

                    var idhide = "subTblhide";
                    idhide = idhide + i;


                    var colorchange = "";
                    var borderleft = "";
                    var imggg = "";
                    if (item.aadharcardPath != null && item.BackSideAadharcardphoto != null && item.pancardPath != null)
                    {
                        if (item.PSAStatus == "N" && item.AadhaarStatus == "N")
                        {
                            colorchange = "#dbdb70";

                            borderleft = "7px solid var(--main-bg-lcolor)";
                            imggg = "☻";

                        }

                    }

                    <tr class="tr" style="background-color:@colorchange">
                        <td style="border-left:@borderleft">@item.DealerFarmName</td>
                        <td>
                            @*<i id="@idshow" class="fa fa-angle-double-down" aria-hidden="true" onclick="md_dlm_List('@item.RetailerId', '@i')">
                                    @item.Frm_Name
                                </i>
                                <i id="@idhide" class="fa fa-angle-double-up" aria-hidden="true" style="display:none;" onclick="md_dlm_Listhide('@i')">
                                    @item.Frm_Name
                                </i>*@
                            <span style="font-size:20px;width: 16px;display: inline-block;color: var(--main-bg-lcolor);">@imggg</span> @item.Frm_Name
                        </td>
                        <td>@item.RetailerName</td>
                        <td>@item.Mobile</td>
                        <td>@item.caption</td>
                        <td>@item.Remainamount</td>
                        <td> @item.PanCard</td>
                        <td class="kyc-button">
                            @if (item.PSAStatus == "Y" && item.AadhaarStatus == "Y")
                            {
                                <button class="btn " style="border:1px solid #bbb;font-size: 11px !important;padding: 4px 7px;height: 25px;border: 1px solid #bbb;">Done</button>
                            }
                            else
                            {
                                <div class="btn" style="background:var(--main-bg-lcolor);height: 25px;color:#fff; padding: 4px 8px;float:left; font-size: 11px;">&nbsp;Due&nbsp;</div>
                            }
                            @*<button class="btn" style="background:yellow;"><img src="~/images/reportimage/wall-clock.svg" /></button>
                                <button class="btn btn-danger"><img src="~/images/reportimage/close.svg" /></button>
                                <button class="btn btn-success"><img src="~/images/reportimage/check.svg" /></button>*@



                            @*@item.adharcard*@
                        </td>
                        <td data-toggle="modal" data-target="#defaultModal222" onclick="mdActionBtn('@item.RetailerId')">
                            @if (item.EmailConfirmed == true)
                            {
                                <button class="btn " style="border:1px solid #bbb;font-size: 11px !important;padding: 4px 7px;height: 25px;border: 1px solid #bbb;">Done</button>
                            }
                            else
                            {
                                <div class="btn" style="background:var(--main-bg-lcolor);height: 25px;color:#fff; padding: 4px 8px;float:left; font-size: 11px;">&nbsp;Due&nbsp;</div>
                            }
                            <img src="~/ashok-images/rightaeps.svg" style="width: 11px;margin-top: 6px;float: right;">
                        </td>

                    </tr>


                    @*<tr id="@i" style="display:none;background-color: rgb(245, 245, 245);">
                            <td colspan="8">
                                <div id="@idno">

                                </div>
                            </td>
                        </tr>*@

                    i++;
                }

            }
        </tbody>
    </table>
</div>



