<script>
    function DeleteRefferedCode(type) {
        $.ajax({

            url: "DeleteReferedCode",
            data: { type: type },
            success: function (data) {
                if (type == "Purchases Basis") {
                    $('.ulpurchaseshow').show();
                    $('.ulpurchasenotshow').hide();
                    $('#purchasetype').hide();
                    $('#purchred').show()
                    $('#purchgreen').hide();
                }
                if (type == "business Basis") {
                    $('.ulbussnessshow').show();
                    $('.ulbussnessnotshow').hide();
                    $('#busnesstype').hide();
                    $('#busnessred').show()
                    $('#busnessgreen').hide();

                }

            }




        })
    }
</script>





<script>


    $(function () {

            $.ajax({

            url: "@Url.Action("CHKSTATSETREFFEREDONTIME")",
         //   data: { name: $(status).prop('checked') },
            success: function (data) {

                if (data == "Purchases Basis") {
                    $('#purchgreen').show();
                    $('#busnessred').show()

                }
                else if (data == "business Basis") {
                    $('#busnessgreen').show();
                      $('#purchred').show()

                }
                else  {

                    $('#purchred').show()
                    $('#busnessred').show()
                }

            }


        })
    });


</script>


<script>
    function Chkstatusonoffpurch(type, status) {

         $.ajax({

            url: "@Url.Action("CHKSTATSETREFFERED")",
            data: { name: type,status:status },
            success: function (data) {

                if (data == "Erroe") {

                       $('#purchred').show()

                }
                else {
                    $('#purchgreen').show();
                    $('#purchred').hide()
                    $('#busnessred').show()
                    $('#busnessgreen').hide();
                }

            }


        })
    }

    function Chkstatusonoff(type,status) {

        $.ajax({

            url: "@Url.Action("CHKSTATSETREFFERED")",
             data: { name: type,status:status},
            success: function (data) {

                if (data == "Erroe") {
                    // $('#toggle-event').prop('checked', false)
                    //  $('#purchgreen').show();
                    $('#busnessred').show()
                }
                else {
                    $('#busnessgreen').show();
                    $('#busnessred').hide()
                    $('#purchred').show()
                    $('#purchgreen').hide();
                }

            }


        })

    }
</script>
<script>
    $('#btneditdataBusnessedit').click(function () {

          var type=$('#btneditdataBusnessedit').attr('data-href')
           $.ajax({
        url: "@Url.Action("InsertRefferalsettingEditdata")",
        type: "POST",
        data: {
            reftype: type, minlimit: $('#txtbusslimit').val(), noofday: $('#txtbusnessnoofday').val(), sharingtype: $('#ddlbusnesssharingtype').val(),
            sharingvalue: $('#txtbusnessssharingvlaue').val(), catetype: $('#busscatetype').val()

        },
        success: function (data) {

            $('.ulbussnessshow').show();
            $('.ulbussnessnotshow').hide();
              fillDivTable();
        },
        error: function (xhr, textStatus, errorThrown) {

             $('#lblmsg').text(textStatus + " | " + errorThrown)
        }
    });

    })

</script>

