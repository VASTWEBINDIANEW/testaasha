<script>

    function changereferral(value) {

        var res = $(value).val();
        if (res == 1) {
            $('#lblpurc').show()
            $('#lblbusness').hide();
            $('.purchase-basis').show();
            $('.business-basis').hide();
            $(".purchase-type").show();
        }
        else if (res == 2) {

            $('.purchase-basis').hide();
            $('.business-basis').show();
            $('#lblpurc').hide()
            $('#lblbusness').show();
              $(".purchase-type").hide();
        }
    }

</script>

