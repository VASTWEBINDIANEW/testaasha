@model IEnumerable<Vastwebmulti.Areas.WHITELABEL.Models.WhiteLabelRefferalListViewModel>
@{
    ViewBag.Title = "Set_Referral";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}


<style>
    .tab-link.active::after {
        content: '';
        width: 100%;
        border-bottom: 2px solid #000;
        display: block;
    }

    .ulbussnessnotshow input, .ulbussnessnotshow select, .ulpurchasenotshow select, .ulpurchasenotshow input {
        padding: 4px 10px;
        border: 0px;
        width: 150px;
    }
    .switch-user-tab-right .nav-tabs li.active::after, .switch-user-tab-right .nav-tabs li::after {
        content: '';
        width: 25px;
        float: left;
        top: 0;
        left: 0;
        position: absolute;
        height: 70%;
        border: 2px solid #fff;
        margin: 5px;
    }

    .switch-user-tab-right .nav-tabs li.active::before{
        content: "";
        border-left: 2px solid #fff;
        border-bottom: 2px solid #fff;
        height: 28%;
        width: 17px;
        position: absolute;
        left: 9px;
        transform: rotate(-45deg);
        top: 9px;
    }
    .switch-user-tab-right .nav-tabs li.active {
        background: @PageData["Globalfirst"] !important;
    }
    .switch-user-tab-right .nav-tabs li {
        background: @PageData["GlobalSecond"] !important;
    }
    .switch-user-tab-right .nav-tabs li a {
    background: transparent !important;
    color: #fff !important;
    }
    .refferal-type-left, .refferal-type-right {
        background: #f5f5f5;
    }
    .refferal-type ul li {
        border-bottom: 1px dashed #bbb;
        padding: 5px;
    }
    .refferal-type h2 {
        border: 2px solid @PageData["Globalfirst"];
    }
    .ulbussnessnotshow input, .ulbussnessnotshow select, .ulpurchasenotshow select, .ulpurchasenotshow input {
        height: 30px;
        margin-top: -10px;
    }
    @@media only screen and (max-width:992px) {
        .switch-user-tab-right {
            margin-top: 50px;
            float: left;
            width: 100%;
        }
    }
    @@media only screen and (max-width:520px) {
        .switch-history-table .table-responsive > .table-bordered > thead > tr > th:first-child {
            border-left: 1px solid var(--border-color);
        }
        .switch-user-tab-right .nav-tabs li{width: 100%;margin-bottom: 10px;}
    }

</style>

