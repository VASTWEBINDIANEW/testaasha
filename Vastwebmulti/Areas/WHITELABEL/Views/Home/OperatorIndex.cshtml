<script>
    function OperatorCodestatusupdate(id, status, opertype) {
        var ids = id;
        var datetimes = '';
        var category = '';
        var lbltext = "";
        if (opertype == 'PrePaid') {
            datetimes = $('#blockdatetime').val();
            category = $('#OperatorCategory').val();
           lbltext= $('#blockdatetimet');
        }
        if (opertype == 'Postpaid') {
            datetimes = $('#UTBlockdatetime').val();
            category = $('#UtilityService').val();
            lbltext= $('#UTBlockdatetimet');

        }
        if (opertype == 'Finance') {
            datetimes = $('#FincBlockdatetime').val();
            category = $('#FinanceServices').val();
             lbltext= $('#FincBlockdatetimet');
        }
         if (opertype == 'Travel') {
            datetimes = $('#TravelBlockdatetime').val();
             category = $('#TravelsServices').val();
              lbltext= $('#TravelBlockdatetimet');
        }
         if (opertype == 'Other') {
            datetimes = $('#OthersBlocktime').val();
             category = $('#OthersServices').val();
              lbltext= $('#OthersBlocktimet');
        }

        if (status == 'N') {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("BlockOperatorPrepaid", "Home")',
                data: { id: ids, blockdate: null, statuschk: status, category:category , opertype:opertype },
                success: function (data) {

                    if (opertype == 'PrePaid') {
                        $('#prepaiddthtable').html(data);
                    }
                    else if (opertype == 'Postpaid') {
                        $('#Utilitytableshow').html(data);
                    }
                    else if (opertype == 'Finance') {
                        $('#Financetable').html(data);
                    }
                    else if (opertype == 'Travel') {
                        $('#Travelstables').html(data);
                    }
                    else if (opertype == 'Other') {
                        $('#OthersRelatedtable').html(data);
                    }

                }
            });
        }
        else if (status == 'Y') {

                $.ajax({
        type: 'POST',
                    url: '@Url.Action("BlockOperatorPrepaid", "Home")',
                    data: { id: ids, blockdate: null, statuschk: status,opertype:opertype },
        success: function (data) {

             if (opertype == 'PrePaid') {
                     $('#prepaiddthtable').html(data);
                    }
                    if (opertype == 'Postpaid') {

                          $('#Utilitytableshow').html(data);
                    }
             if (opertype == 'Finance') {

                          $('#Financetable').html(data);
                    }
             if (opertype == 'Travel') {

                          $('#Travelstables').html(data);
            }
             if (opertype == 'Other') {
            $('#OthersRelatedtable').html(data);
        }


        }
    });


            }

    }

