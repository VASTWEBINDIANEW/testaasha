<script>
         $("#block").click(function () {
             var date = $("#txt_frm_date").val();

                        var answer = confirm("ARE YOU SURE?")
                        if (answer = true) {
                            var optCode = [];
                                $.each($("input[name='optblock']:checked"), function () {
                                    optCode.push($(this).val());
                                });
                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("check", "Home")',
                    data: { 'array': optCode, 'date': date,'type':'block' },
                    success: function (result) {
                        window.location.reload(true);
                    }
                });
            }
            else {
                return false;
            }
        });
</script>
<!--Unblock Status Code-->
<script>
    $("#unblock").click(function () {
        var date = $("#txt_frm_date").val();

        var answer = confirm("ARE YOU SURE?")
        if (answer = true) {
            var optCode = [];
            $.each($("input[name='optblock']:checked"), function () {
                optCode.push($(this).val());
            });
            $.ajax({
                type: 'POST',
                url: '@Url.Action("check", "Home")',
                data: { 'array': optCode, 'date': date, 'type': 'unblock' },
                success: function (result) {
                    window.location.reload(true);
                }
            });
        }
        else {
            return false;
        }

    });
</script>
