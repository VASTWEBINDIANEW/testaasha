@model Vastwebmulti.Areas.WHITELABEL.Models.vmWhitelabel_OperatorIndex

@{
    ViewBag.Title = "OperatorIndex";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}
<link href="~/MainFrontDesign/select2/dist/css/select2.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.1/css/toastr.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.1/js/toastr.js"></script>
<style>
    .OpertorIndex-page .width100 {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        background: #edebeb;
        z-index: 9;
        width: 100%;
        border-top: 5px solid #c4cbd1;
    }
    .seven button {
        background: linear-gradient(to right, #08a187, #ed164c ) !important;
    }
    .dropdown-menu {
        margin-top: 81px !important;
    }

    .form-inline .bootstrap-select.btn-group, .form-horizontal .bootstrap-select.btn-group, .form-group .bootstrap-select.btn-group {
        height: 29px;
    }

    [type="checkbox"].filled-in:not(:checked) + label:after {
        background-color: #f5f5f5;
        border: 2px solid #dddddd;
    }

    .toast-top-right1 {
        top: 78px;
        left: 81%;
    }

    .select2-container--default .select2-selection--single {
        border-radius: 0px !important;
        height: 32px !important;
        text-align: left;
    }
    .OpertorIndex-page .oprindex-left .op-c {
        height: auto;
        padding: 10px;
    }
    .OpertorIndex-page .oprindex-right .tab-content2 ul.top-tab-ul {
        background: linear-gradient(to right, @PageData["Globalfirst"], @PageData["GlobalSecond"] ) !important;
        margin: 10px auto;
        padding: 10px 7px;
    }
    .oprindex-right .custom-district::after {
        right: 20px;
    }
    .OpertorIndex-page .oprindex-right .tab-content2 ul.top-tab-ul li {
    padding: 0px 6px;
    margin: 0;
    width: 50% !important;
    }
    .OpertorIndex-page .oprindex-left ul.tabs li.current::after, .OpertorIndex-page .oprindex-right ul.tabs2 li.current2::after, .OpertorIndex-page .oprindex-left ul.tabs li::after, .OpertorIndex-page .oprindex-right ul.tabs2 li::after {
        content: '';
        width: 25px;
        float: left;
        top: 0;
        left: 0;
        position: absolute;
        height: 70%;
        border: 2px solid #fff;
        margin: 5px;
    }
    .OpertorIndex-page .oprindex-left ul.tabs li.current::before, .OpertorIndex-page .oprindex-right ul.tabs2 li.current2::before {
        content: "";
        border-left: 2px solid #fff;
        border-bottom: 2px solid #fff;
        height: 28%;
        width: 17px;
        position: absolute;
        left: 9px;
        transform: rotate(-45deg);
        top: 9px;
    }
    .OpertorIndex-page .oprindex-left ul.tabs li.current, .OpertorIndex-page .oprindex-right ul.tabs2 li.current2 {
        background: @PageData["Globalfirst"] !important;
    }
    .OpertorIndex-page .oprindex-left ul.tabs li, .OpertorIndex-page .oprindex-right ul.tabs2 li {
        background: @PageData["GlobalSecond"] !important;
        border-bottom: 0px !important;
        color: #fff !important;
        height: 36px;
        position: relative !important;
        padding-top: 8px;
    }
    @@media only screen and (max-width:992px) {
        .frm-small-down {
            width: 100%;float: left;
        }
    }
    @@media only screen and (max-width:767px) {
        .OpertorIndex-page .oprindex-right ul.tabs2 li{width: 33%;margin-bottom: 10px;}
        .table-responsive > .table-bordered > thead > tr > th:first-child {
            border-left: 1px solid;
        }
        .table-responsive > .table-bordered > thead > tr {
            border-right: 1px solid;
        }
    }
    @@media only screen and (max-width:520px) {
        .OpertorIndex-page .for-un ul li.one, .OpertorIndex-page .for-un ul li.two, .OpertorIndex-page .for-un ul li.three, .OpertorIndex-page .for-un ul li.four, .OpertorIndex-page .for-un ul li.six, .OpertorIndex-page .for-un ul li.five {
            width: 50% !important;
            margin-bottom: 3px;
        }
        .OpertorIndex-page .oprindex-left ul.tabs li, .OpertorIndex-page .oprindex-right ul.tabs2 li {
            width: 100% !important;
            float: left;
            border: 0 !important;
            margin-bottom: 10px;
        }
        .OpertorIndex-page .oprindex-right ul.tabs2 li {
            width: 50%;
            margin-bottom: 10px;
        }
        .bread-same-all-page a{font-size:14px;}
        .OpertorIndex-page .oprindex-right .tab-content2 ul.top-tab-ul li{padding: 0;}
    }
