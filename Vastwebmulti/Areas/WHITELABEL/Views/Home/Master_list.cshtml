@model Vastwebmulti.Areas.WHITELABEL.Models.Whitelabel_MasterDistributerModel
@{
    ViewBag.Title = "Master_list";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}

<script src="~/Scripts/jquery-1.10.2.min.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.1/css/toastr.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.1/js/toastr.js"></script>
<style>
    .Masterlist-page .left-first-tabs form, .tab-design .left-first-tabs form {
        border: 1px solid #ddd;
        background: #f5f5f5;
    }
    .btn-group, .btn-group-vertical {
        box-shadow: none;
    }

    .dropdown {
        position: relative;
        display: inline-block;
    }

    .dropdown-content {
        display: none;
        position: absolute;
        background-color: #f9f9f9;
        min-width: 160px;
        box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
        padding: 12px 16px;
        z-index: 1;
    }

    .dropdown:hover .dropdown-content {
        display: block;
    }

    .master-form-select .select2-container {
        height: 34px;
    }

    .toast-top-right1 {
        top: 65px;
        left: 81%;
    }

    .for-search {
        position: absolute;
        right: 130px;
    }

        .for-search input {
            width: 250px;
            border: 1px solid #dbdbdb;
            padding: 3px 10px;
        }
    .Masterlist-page ul.tabs li.current {
        background-image: linear-gradient(to right, @PageData["Globalfirst"], @PageData["GlobalSecond"] ) !important;
        @*background: @PageData["GlobalSecond"] !important;*@
    }
    @*.Masterlist-page ul.tabs li::before{
            content: "";
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: auto;
            width: 0;
            transition: .5s linear;
            display: inline-block;
            z-index: 9;
            background: @PageData["Globalfirst"];
            height: 40px;
        }
        .Masterlist-page ul.tabs li:hover::before {
            width: 100%;
            right: auto;
            left: 0;
        }*@
    @@media only screen and (max-width:767px) {
        #Masterlistupdate, #tab-5 {
            height: auto !important;
        }
        .for-search {
            right: 20%;
        }
    }
    @@media only screen and (max-width:520px) {
        .web-white-filter {
            position: static !important;
        }

        .for-search {
            position: static;
            float: left;
        }

            .for-search input {
                width: 100%;
            }
    }
</style>
