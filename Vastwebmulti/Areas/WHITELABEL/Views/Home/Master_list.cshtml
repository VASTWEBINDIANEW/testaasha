<script language="javascript" type="text/javascript">
                    $(function () {
                        ravi('#State').change(function () {
                            // alert('Value:' + ' ' + $('#State1').val())
                            var stid = $('#State').val()

                            GetDistrict(stid)
                            GetDistrict1(stid)
                        });
                    })

                    function GetDistrict(_stateId) {
                        var procemessage = "<option value='0'> Please wait...</option>";
                        $("#District").html(procemessage).show();
                        var url = '@Url.Action("DistrictList","Home")'
                        $.ajax({
                            url: url,
                            data: { Id: _stateId },
                            cache: false,
                            type: "POST",
                            success: function (data) {

                                ravi("#District").html("");
                                for (var x = 0; x < data.length; x++) {

                                    ravi("#District").append($('<option></option>').val(data[x].Value).html(data[x].Text));
                                }

                            },
                            error: function (reponse) {
                                alert("error : " + reponse);
                            }
                        });
                    }

    function GetDistrict1(_stateId) {
        var procemessage = "<option value='0'> Please wait...</option>";
        $("#District1").html(procemessage).show();
        var url = '@Url.Action("DistrictList","Home")'
        $.ajax({
            url: url,
            data: { Id: _stateId },
            cache: false,
            type: "POST",
            success: function (data) {
                ravi("#District1").html("");
                for (var x = 0; x < data.length; x++) {
                    //alert(markup)
                    ravi("#District1").append($('<option></option>').val(data[x].Value).html(data[x].Text));
                }

            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
    }


</script>
