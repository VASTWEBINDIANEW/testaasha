<script type="text/javascript">
        var val1 = "";
        function editdealer(DealerId) {
            var url = '@Url.Action("DealerIdSearch", "Home")'
            $.ajax({
                url: url,
                data: { dealerid: DealerId },
                cache: false,
                type: "POST",
                success: function (data) {
                    $("#txtdealerid").val(data[0].DealerId);
                    $("#txtemail").val(data[0].Email);
                    $("#txtdealername").val(data[0].DealerName);
                    $("#txtfrmname").val(data[0].FarmName);
                    $("#State1").val(data[0].State);
                    $("#txtmobileedit").val(data[0].Mobile);
                    $("#txtAddress").val(data[0].Address);
                    $("#txtpincode").val(data[0].Pincode);
                    $("#txtpancard1").val(data[0].pancard);
                    $("#txtadharcard1").val(data[0].adharcard);
                    $("#txtgst1").val(data[0].gst);
                    //$("#slabedit").val(data[0].slab_name);
                    var objSelect1 = document.getElementById("District1");
                    binddist(data[0].State, data[0].District, objSelect1);
                    $('#defaultModal1').modal('show');
                }

            });

        }
    function binddist(staid, dist, objSelect1) {

            var url = '@Url.Action("DistrictList","Home")'
            $.ajax({
                url: url,
                data: { Id: staid },
                cache: false,
                type: "POST",
                success: function (data) {
                    var markup = "<option value='0'>Select District</option>";
                    for (var x = 0; x < data.length; x++) {
                        markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                    }
                    $("#District1").html(markup).show();
                    setSelectedValue(objSelect1, dist);
                }

            });
        }
    function setSelectedValue(selectObj, valueToSet) {

            for (var i = 0; i < selectObj.options.length; i++) {
                if (selectObj.options[i].value == valueToSet) {
                    //alert(selectObj.options[i].value);
                    selectObj.options[i].selected = true;
                    return;
                }
            }
        }
</script>
