@model Vastwebmulti.Models.tblWhiteLabel_FooterServices
@{
    ViewBag.Title = "Edit_FooterService";
    Layout = "~/Areas/WHITELABEL/Views/Shared/Main.cshtml";
}
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                @using (Html.BeginForm("Edit_FooterService", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
            {
                    <div class="card">
                        <div class="header" style="padding:10px;">
                            <h2>
                                <span style="font-size:21px;"></span> Update Footer Service Data Content
                            </h2>
                        </div>
                        <div class="row">
                            <div class="body">
                                <div class="row">
                                    <div class="col-md-6">
                                        @Html.HiddenFor(model => model.Id)
                                        <label for="email_address">Service Name 1</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.ServiceName1, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="email_address">Service Name 2</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.ServiceName2, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <label for="email_address">Service Name 3</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.ServiceName3, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="email_address">Service Name 4</label>
                                        <div class="form-group">
                                            <div class="" style="border:1px solid #dddddd;">
                                                @Html.TextBoxFor(model => model.ServiceName4, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                          <div class="row">
                              <div class="col-md-6">
                                  <label for="email_address">Service Name 5</label>
                                  <div class="form-group">
                                      <div class="" style="border:1px solid #dddddd;">
                                          @Html.TextBoxFor(model => model.ServiceName5, new { @class = "form-control" })
                                      </div>
                                  </div>
                              </div>
                              <div class="col-md-6">
                                  <button type="submit" class="btn bg-blue-grey" style="margin-top:26px;height:36px;">Update</button>
                                  <a href="@Url.Action("Footer_Content","Home")" class="btn bg-blue-grey"  style="margin-top:26px;height:36px; padding-top:9px;">Back</a>
                              </div>
                          </div>
                                
                            </div>
                        </div>

                    </div>
                }
            </div>

        </div>
    </div>
</section>

