@using Microsoft.AspNet.Identity
@using Vastwebmulti.Models;
<!DOCTYPE html>
<html>
<head>
    @{
        var comnyname = "";
        VastwebmultiEntities DB1 = new VastwebmultiEntities();
        var companyname = DB1.Admin_details.AsNoTracking().ToList();
        if (companyname.Count > 0)
        {
            comnyname = companyname.FirstOrDefault().Companyname;
            ViewBag.companyname = comnyname;
        }
        else
        {
            comnyname = "";
        }
    }
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <title>@ViewBag.companyname</title>
    <!-- Favicon-->
    @{
        var favimage = "";
        VastwebmultiEntities db2 = new VastwebmultiEntities();
        var faviconlogo = db2.tblfavicons.Where(p => p.Role == "ADMIN").ToList();
        if (faviconlogo.Count() > 0)
        {
            if (faviconlogo.SingleOrDefault().Role == "ADMIN")
            {
                favimage = faviconlogo.SingleOrDefault().faviconimage;
            }
        }
        else
        {
            <link rel="icon" href="" type="image/x-icon" />
        }
    }
    <link rel="icon" href="@Url.Content("~/" + @favimage)" type="image/x-icon" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Roboto:400,700&subset=latin,cyrillic-ext" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" type="text/css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <!-- Wait Me Css -->
    <link href="~/AdminDesign/plugins/waitme/waitMe.css" rel="stylesheet" />
    <!-- Bootstrap Core Css -->
    <link href="~/AdminDesign/plugins/bootstrap/css/bootstrap.css" rel="stylesheet">
    <!-- Waves Effect Css -->
    <link href="~/AdminDesign/plugins/node-waves/waves.css" rel="stylesheet" />
    <!-- Animation Css -->
    <link href="~/AdminDesign/plugins/animate-css/animate.css" rel="stylesheet" />
    <!-- Morris Chart Css-->
    <link href="~/AdminDesign/plugins/morrisjs/morris.css" rel="stylesheet" />
    <!-- Custom Css -->
    <link href="~/AdminDesign/css/style.css" rel="stylesheet">

    <link href="~/AdminDesign/plugins/bootstrap-select/css/bootstrap-select.css" rel="stylesheet" />
    <!-- AdminBSB Themes. You can choose a theme from css/themes instead of get all themes -->
    <link href="~/AdminDesign/css/themes/all-themes.css" rel="stylesheet" />
    <link href="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/css/dataTables.bootstrap.css" rel="stylesheet">
    <link href="~/AdminDesign/plugins/bootstrap-material-datetimepicker/css/bootstrap-material-datetimepicker.css" rel="stylesheet" />
    <link href="~/AdminDesign/plugins/sweetalert/sweetalert.css" rel="stylesheet" />
    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
    <link href="~/fonts/icofont.css" rel="stylesheet" />
    @if (!HttpContext.Current.Request.IsLocal)
    {
        <!-- To Disable Inspect Element -->
        <script src="~/Scripts/Disable_Inspect_Element/Disable_Inspect.js"></script>
    }
    <style>
        .sidebar .menu .list a span {
            color: white;
        }

        .sidebar .menu .list a {
            color: white;
        }

        .navbar .navbar-toggle:before {
            /*content: '\E8D5';*/
            font-family: 'Material Icons';
            font-size: 26px;
        }

        .navbar .navbar-toggle:before {
            /*content: '\E8D5';*/
            font-family: 'Material Icons';
            font-size: 26px;
        }

        .sidebar .menu .list i.material-icons {
            margin-top: 6px;
        }

        .sidebar .menu .list .ml-menu li a {
            font-size: 11px;
        }

        .material-icons {
            font-size: 20px;
        }
    </style>
</head>
@{
    var col = "";
    VastwebmultiEntities DB = new VastwebmultiEntities();
    var color = DB.changecolors.AsNoTracking().Where(p => p.Role == "ADMIN").ToList();
    if (color.Count > 0)
    {
        if (color.SingleOrDefault().Role == "ADMIN")
        {
            col = color.Where(p => p.Role == "ADMIN").SingleOrDefault().adminandouterheadercolor;
        }
    }
    else
    {
        col = "pink";
    }
    string userid = User.Identity.GetUserId();
    var ch = DB.FeeCollector_details.FirstOrDefault(m => m.FCId == userid);
    ViewBag.api = ch;
    ViewBag.image = ch.Photo;

    var image = "";
    var backimage = DB.tblWhiteLabelLoginBackImages.AsNoTracking().FirstOrDefault(p => p.Role == "ADMIN");
    if (backimage != null)
    {
        image = backimage.ImageUrl;
    }
    else
    {
        image = "img24.png";
    }
    var logoimage = "";
    var logo = DB.tblHeaderLogoes.AsNoTracking().Where(p => p.Role == "ADMIN").ToList();
    if (logo.Count > 0)
    {
        if (logo.SingleOrDefault().Role == "ADMIN")
        {
            logoimage = logo.Where(p => p.Role == "ADMIN").SingleOrDefault().LogoImage;
        }
    }
    else
    {
        logoimage = "images/Default_Logo.png";
    }
}
<body class="theme-@col">
   
