<!--Insert Popuop-->
<script>
    window.onload = function () {
        var message = '@TempData["msgrem"]'
        if (message != "" && message != null) {
            swal("Good job!", message, "success");

        }
        var mobileconfrimation = '@TempData["mobileno"]'
        if (mobileconfrimation != "" && mobileconfrimation != null) {
            swal("Oops...", mobileconfrimation, "error");

        }

        var mailconfrimation = '@TempData["emailconfrim"]'
        if (mailconfrimation != "" && mailconfrimation != null) {
            swal("Oops...", mailconfrimation, "error");

        }
        //Edit Message
        var editdata = '@TempData["edit"]'
        if (editdata != null && editdata != "") {
            swal("Good job!", editdata, "success");
        }

    }
</script>

<script>
    function getFee(event) {
        event.preventDefault();
        var rollNo = $('#RollNO').val();
        var url = '@Url.Action("getInstallmentAmount", "Home")'
        $.ajax({
            url: url,
            data: { rollno: rollNo },
            cache: false,
            type: "POST",
            success: function (data) {
                //alert("Success");
                var respo = JSON.parse(data);
                //alert(respo.Status);
                if (respo.Status == "Failed") {
                    swal("Oops...", respo.Message, "error");
                }
                else {

                    $("#address").val(respo.Message.Address);
                    $("#Name").val(respo.Message.Name);
                    $("#FatherName").val(respo.Message.FName);
                    $("#stdClass").val(respo.Message.stdClass + '/' + respo.Message.Section);
                    $("#Section").val(respo.Message.Section);
                    $("#InsAmount").val(respo.Message.Amount);
                    $("#InsBusAmount").val(respo.Message.AmountBus);
                    $("#FixedCharges").val(respo.Message.FixedCharge);
                    $("#TotalInstallment").val(respo.Message.PaidInstallment + '/' + respo.Message.NumberOfInstallments);
                    $("#FeeAmont").val(respo.Message.DiscountedFee + '/' + respo.Message.ActualFee);
                    $("#BusFeeAmont").val(respo.Message.DiscountedBusFee + '/' + respo.Message.ActualBusFee);
                    $("#txtRollNo").val(rollNo);
                    $("#AcadmicSession").html('(' + respo.Message.Session + ')');



                    $('#largeModal').modal('show');
                }


            }
        });
        //alert(rollNo);
    }
</script>
<script>
    window.onload = function () {

        var from = '@ViewBag.fromdate';
        var to = '@ViewBag.todate';
        if (from != "" && to != "") {
            $('#txt_frm_date').val(from);
            $('#txt_to_date').val(to);
        }
        else {
            var month = new Array("Jan", "Feb", "Mar",
    "Apr", "May", "Jun", "Jul", "Aug", "Sep",
    "Oct", "Nov", "Dec");

            var d = new Date();
            var curr_date = d.getDate();
            var curr_month = d.getMonth();
            var curr_year = d.getFullYear();
            var tt = curr_date + "-" + month[curr_month]
            + "-" + curr_year;
            document.getElementById("txt_frm_date").value = tt;
            document.getElementById("txt_to_date").value = tt;
        }
        var dateformat = '@ViewBag.format';
        if (dateformat != null && dateformat != "") {
            swal("Oops...", dateformat, "error");
        }
    }
</script>











