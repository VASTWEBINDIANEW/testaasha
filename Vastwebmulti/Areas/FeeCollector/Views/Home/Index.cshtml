        <div class="row clearfix">
            <!-- Upcoming Holidays-->
            <div class="col-md-4">

                <div class="card">
                    <div class="header" style="padding: 10px;">
                        <h2><i class="fa fa-calendar" aria-hidden="true"></i>&nbsp;&nbsp;&nbsp; Upcoming Holidays</h2>
                    </div>
                    <div class="body" style="margin-top: -18px; margin-bottom: -18px;height:136px;">
                        <div class="row">
                            @foreach (var item in ViewBag.showholiday)
                            {
                                <div class="col-xs-6">
                                    <center>
                                        <span style="font-size: 30px;">@item.Day</span>
                                        <span style="font-size: 16px;display:block; margin-top:-8px;">@item.Month<span style="font-size: 10px; margin-top: 10px; padding-left:5px;"><sup style="font-size:12px; top:0px; font-weight:600;">@item.Year</sup></span></span>
                                        <span style="font-size: 11px; margin-top: 3px; display: block; font-weight:700;">@item.HolidayName</span>
                                    </center>
                                </div>

                            }
                        </div>
                    </div>
                </div>
                <div class="card navbar" style="position: initial;">
                    <div class="header" style="padding: 10px;">
                        <h2 style="color: white;"><i class="fa fa-phone-square" aria-hidden="true"></i>&nbsp;&nbsp;&nbsp; Helpdesk</h2>
                    </div>
                    <div class="body">
