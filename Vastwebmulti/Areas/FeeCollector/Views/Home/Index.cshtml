<script src="~/AdminDesign/js/pages/charts/chartjs.js"></script>

<script>
    window.onload=function()
    {
        initDonutChart();
    }
</script>
<!-- Distributor active and inactive users Chart -->
<script type="text/javascript">
    function initDonutChart() {
        var active = '@ViewData["actRtl"]';
        var inactive = '@ViewData["inRtl"]';
        var totalusers = '@ViewData["TotalRetailrs"]';
        Morris.Donut({
            element: 'donut_chart',

            data: [
                {
                    label: 'Active',
                    value: active,
                },

            {
                label: 'InActive',
                value: inactive
            },
              {
                  label: 'Total',
                  value: totalusers
              }
            ],

            colors: [
                'rgb(34,139,34)',
                 'rgb(233, 30, 99)',
                'rgb(128, 0, 255)'],

            formatter: function (y) {
                return y

            }

        });

    }
</script>

@*Today Business Pie Chart*@
<script>
    $(function () {
        var vv = (document.getElementById("pie_chart").getContext("2d"), getChartJs('pie'));
      });

    function getChartJs(type) {
        var prepaid = 8;
        var postpaid = 10;
        var Dth = 12;
        var landline = 14;
        var electricity = 8;
        var gas = 6;
        var imps = 7;
        var Insurance = 10;
        var Giftcard = 5;
        var Dthbooking = 8;
        var ecommerce = 10;
        var mpos = 16;
        var pancard = 14;
        var AEPS = 13;

        var config = null;
        if (type === 'pie') {
            config = {
                type: 'pie',
                data: {
                    datasets: [{
                        data: [prepaid, postpaid, Dth, landline, electricity, gas, imps, Insurance, Giftcard, Dthbooking, ecommerce, mpos, pancard, AEPS],
                        backgroundColor: [
                "rgb(233, 30, 99)",
                "rgb(0, 128, 255)",
                "rgb(76, 175, 80)",
                "rgb(255, 0, 0)",
                "rgb(128, 128, 128)",
                "rgb(121, 85, 72)",
                "rgb(191, 0, 255)",
                "rgb(63, 81, 181)",
                "rgb(255, 152, 0)",
                "rgb(0, 188, 212)",
                "rgb(0, 0, 0)",
                "rgb(0, 255, 255)",
                "rgb(0, 255, 191)",
                "rgb(255, 0, 255)"
                        ],
                    }],
                    labels: [
                        "Prepaid",
                        "Postpaid",
                         "DTH",
                         "Landline",
                         "Electricity",
                         "Gas",
                         "IMPS",
                         "Insurance",
                         "Gift Card",
                         "DTH Booking",
                         "E-Commerce",
                         "M-Pos",
                         "Pancard",
                         "AEPS"
                    ]
                },
                options: {
                    responsive: true,
                    legend: false
                }
            }
        }
        return config;
    }
</script>