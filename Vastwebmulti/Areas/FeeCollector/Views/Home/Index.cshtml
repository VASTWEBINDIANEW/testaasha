                            </div>
                            <div class="col-xs-4">
                                <a href="~/MASTER/Home/Complaint" class="btn btn-default waves-effect" type="button" style="text-decoration: none; box-shadow: none; border: 1px solid #dddddd; margin-left: -31px;">Complaint&nbsp;Req.</a>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <!-- News-->
            <div class="col-md-8">
                <div class="card">
                    <div class="header" style="padding: 10px;">
                        <h2>Update News</h2>
                    </div>
                    <div class="body" style="padding:3px;">
                        <div id="carousel-example-generic" class="carousel slide" data-ride="carousel">
                            <!-- Indicators -->
                            <div class="carousel-inner">
                                @{int count = 0;
                                    string activeclass = "";

                                }
                                @foreach (var item in ViewBag.news)
                                {
                                    if (count == 0)
                                    {
                                        activeclass = "item active";
                                        count++;
                                    }
                                    else
                                    {
                                        activeclass = "item";
                                    }
                                    var messagee = "";
                                    var message = item.message;
                                    if (message.Length > 340)
                                    {
                                        message = message.Substring(0, 340);
                                    }
                                    else
                                    {
                                        messagee = message;
                                    }
                                    <div class="item @activeclass">
                                        <div class="row">
                                            <div class="col-xs-12" style="margin-top:10px;">
                                                <div class="thumbnail adjust1" style="border:none;">
                                                    <div class="col-md-3 col-sm-3 col-xs-12">
                                                        <img class="media-object img-rounded img-responsive" src="@Url.Content("~/" + item.image)" style="margin-top:11px;">
                                                    </div> <div class="col-md-9 col-sm-9 col-xs-12">
                                                        <div class="caption">
                                                            <p style="text-align:justify;"><span class="glyphicon glyphicon-thumbs-up"></span>&nbsp;@message</p>
                                                            <blockquote class="adjust2">
                                                                <p>@item.name</p>
                                                            </blockquote>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div> <!-- Controls -->
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</section>

<!--Email Us Modal -->
