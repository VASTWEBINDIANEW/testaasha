@model Vastwebmulti.Areas.FeeCollector.Models.StdModel
<script src="~/Scripts/jquery-1.10.2.min.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="body">
                        <div class="demo-button">
                            <div class="row">
                                <h3>Please insert fixed external fee charges before inserting a new student.</h3>
                                <br />
                            </div>
                            <div class="row">
                                <div class="col-md-3" style="margin-top:-10px;">
                                    <button type="button" class="btn bg-indigo waves-effect" data-toggle="modal" data-target="#defaultModal">
                                        <i class="material-icons" style="top:0px;">group</i>
                                        <span style="top:-5px;">Add&nbsp;New</span>
                                    </button>
                                </div>
                                <div class="col-md-3" style="margin-top:-10px;">
                                    <button type="button" class="btn bg-indigo waves-effect" data-toggle="modal" data-target="#excelModal">
                                        <i class="fa fa-file-excel-o" style="top:0px;"></i>
                                        <span style="top:-5px;">Upload&nbsp;Excel</span>
                                    </button>
                                </div>
                                <div class="col-md-3" style="margin-top:-10px;">
                                    <a href="@Url.Action("Download","Home")" class="btn bg-indigo waves-effect">
                                        <i class="fa fa-cloud-download"  style="top:0px;"></i>
                                        <span style="top:-5px;">Download&nbsp;Formate</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-33px;">
                <div class="card">
                    <div class="">
                        <h2 style="color:black; font-size:16px;padding-top:9px; padding-left:22px;">
                            Student Details
                        </h2>
                    </div>
                    <div class="body">
                        <div class="table-responsive" style="position:inherit;margin-top:-20px;">
                            <table class="table table-bordered table-striped table-hover dataTable js-exportable" style="width:100%;">
                                <thead class="navbar" style="color:white;position:inherit;">
                                    <tr>
                                        <th style="padding-left:2px;">Roll&nbsp;No</th>

                                        <th style="padding-left:2px;">Std&nbsp;Name</th>
                                        <th style="padding-left:2px;">Father&nbsp;Name</th>
                                        <th style="padding-left:2px;">Fee</th>
                                       
                                        @*<th style="padding-left:2px;">Status</th>*@
                                        <th style="padding-left:2px;">Edit</th>
                                        <th style="padding-left:2px;">View</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.students)
                                    {
                                        <tr>
                                            <td>@item.RollNo</td>
                                            <td>@item.Name</td>
                                            <td>@item.FName</td>
                                            <th>@item.AnnualFee</th>
                                           
                                            @*<td style="padding:3px;">
                                                @if (item.Status == "Y")
                                                {
                                                    <div class="demo-switch">


                                                        <div class="switch">
                                                            <label>
                                                                <a href="@Url.Action("FCstatus",new { id = item.RollNo })" style="text-decoration:none;"><input type="checkbox" checked /> <span class="lever" style="background-color:green;"></span></a>
                                                            </label>


                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="demo-switch">
                                                        <div class="switch">
                                                            <label>
                                                                <a href="@Url.Action("FCstatus",new { id = item.RollNo  })" style="text-decoration:none;"><span class="lever" style="background-color:red;"></span></a>
                                                            </label>


                                                        </div>
                                                    </div>
                                                }
                                            </td>*@
                                            <td>
                                                <button id="but" onclick="animation('@item.RollNo')" style="background-color:transparent;color:#03a9f4; border:none;">
                                                    <i class="fa fa-edit fa-2x" style="font-size:24px;color:#673ab7;"></i>
                                                </button>
                                            </td>
                                            <td>
                                                <button type="button" style="background-color:transparent; border:none;" onclick="showdata('@item.RollNo')">
                                                    <i class="fa fa-eye fa-2x" style="font-size:23px;color:#009688;"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!--Add New Fee Collector  modal-->
<div class="modal fade" id="defaultModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header navbar" style="position:initial;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:white;">Add New Student</h4>
            </div>
            @using (Html.BeginForm("insert_Std", "Home", FormMethod.Post))
            {
                <div class="modal-body" style="margin-top:-26px;">
                    <div class="body">
                        @*@Html.ValidationSummary(true, "", new { @class = "text-danger" })*@
                        <form>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Roll No</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBoxFor(m => m.StdID, "", new { @class = "form-control", placeholder = "Enter Roll No", required = "required" })

                                        </div>
                                        @Html.ValidationMessageFor(m => m.StdID, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Name</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBoxFor(m => m.StdName, "", new { @class = "form-control", placeholder = "Enter Name", required = "required" })

                                        </div>
                                        @Html.ValidationMessageFor(m => m.StdName, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Father Name</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBoxFor(m => m.FName, "", new { @class = "form-control", placeholder = "Enter Father Name", required = "required" })

                                        </div>
                                        @Html.ValidationMessageFor(m => m.FName, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Mobile</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBoxFor(m => m.Mb, new { @class = "form-control", placeholder = "Enter Mobile Number", onkeypress = "return isNumber(event)", maxlength = "10", required = "required" })

                                        </div>
                                        @Html.ValidationMessageFor(m => m.Mb, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Address</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextAreaFor(m => m.Address, new { @class = "form-control", placeholder = "Enter Address ", @onkeypress = "javascript:return AddValidation(event)", required = "required" })

                                        </div>
                                        @Html.ValidationMessageFor(m => m.Address, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">DOB</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBoxFor(m => m.DOB,"", new { @type="date", @class = "form-control", placeholder = "Enter DOB ", required = "required" })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.DOB, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Class</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.EnumDropDownListFor(m => m.stdClass,new { @class="form-control"})
                                        </div>
                                        @Html.ValidationMessageFor(m => m.stdClass,"", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Section</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBoxFor(m => m.Section, new { @class = "form-control" })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.Section,"", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Fee</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBoxFor(m => m.AnnualFee, new { @class = "form-control" })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.AnnualFee, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Bus Fee</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBoxFor(m => m.BusFee, new { @class = "form-control" })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.BusFee, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Discount</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBoxFor(m => m.Discount, new { @class = "form-control" })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.Discount, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="form-group">
                                    <div class="col-lg-offset-3 col-lg-3 col-md-3 col-sm-3 col-xs-6">
                                        @Html.LabelFor(m => m.FeeDiscountEnabled)
                                        @Html.CheckBoxFor(m => m.FeeDiscountEnabled, new { @style = "left:0px; opacity:inherit;position:initial;" })
                                    </div>
                                    <div class="col-lg-3 col-md-3 col-sm-3 col-xs-6">

                                        @Html.LabelFor(m => m.BusDiscountEnabled)
                                        @Html.CheckBoxFor(m => m.BusDiscountEnabled, new { @style = "left:0px; opacity:inherit;position:initial;" })
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Session</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.DropDownListFor(m=>m.AcadminSession, (IEnumerable<SelectListItem>)ViewBag.AcadmicSession, new { @class = "form-control" })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.AcadminSession, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Board</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.EnumDropDownListFor(m => m.Board, new { @class = "form-control",@required="required" })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.Board, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Remark</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBoxFor(m => m.remark, new { @class = "form-control" })
                                        </div>
                                        @Html.ValidationMessageFor(m => m.remark, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                      
                            <div class="modal-footer">
                                <button type="submit" class="btn btn-primary waves-effect">Save Change</button>
                                <button type="button" class="btn btn-info waves-effect" data-dismiss="modal">CLOSE</button>
                            </div>
                        </form>
                    </div>
                </div>
            }

        </div>
    </div>
</div>
