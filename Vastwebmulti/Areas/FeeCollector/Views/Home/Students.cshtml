<!--Excel modal-->
<div class="modal fade" id="excelModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header navbar" style="position:initial;">
                <h4 class="modal-title" id="excelModalLabel" style="color:white;">Upload Student Via Excel</h4>
