<script type="text/javascript">
    var val1 = "";
    function animation(RollNo) {
        var url = '@Url.Action("RollNoSearch", "Home")'
            $.ajax({
                url: url,
                data: { id: RollNo },
                cache: false,
                type: "POST",
                success: function (data) {
                  var obj = JSON.parse(data);
                  $("#StdName1").val(obj.Name);
                  $("#txtRollNo").val(obj.RollNo);
                $("#FName1").val(obj.FName);
                $("#Mb1").val(obj.Phone);
                $("#Address1").val(obj.stdAddress);
                $("#DOB1").val(moment(new Date(obj.DOB)).format("YYYY-MM-DD"));
              
                $("#stdClass1").val(obj.stdClass);
                $("#Section1").val(obj.Section);
                //alert(obj.Board);
                $("#Board1").val(obj.Board);

              
                $("#Commission1").val(obj.Commission);
                $("#AnnualFee1").val(obj.AnnualFee);
                
                $("#remark1").val(obj.Remark);

                //GetDistrict1(data[0].State)
                //var objSelect1 = document.getElementById("District1");
                //binddist(data[0].State, data[0].District, objSelect1);
                $('#defaultModal1').modal('show');
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });

    }
    function cleanDate(d) {
        if (typeof d == 'string') {
            return new Date(d) || Date.parse(d) || new Date(parseInt(d));
        }
        if (typeof d == 'number') {
            return new Date(d);
        }
        return d;
    }
    function binddist(staid, dist, objSelect1) {
        var url = '@Url.Action("DistrictList","Home")'
        $.ajax({
            url: url,
            data: { Id: staid },
            cache: false,
            type: "POST",
            success: function (data) {
                var markup = "<option value='0'>Select District</option>";
                for (var x = 0; x < data.length; x++) {
                    markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                }
                $("#District").html(markup).show();
                setSelectedValue(objSelect1, dist);
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
    }
    function setSelectedValue(selectObj, valueToSet) {

        for (var i = 0; i < selectObj.options.length; i++) {
            if (selectObj.options[i].value == valueToSet) {
                //alert(selectObj.options[i].value);
                selectObj.options[i].selected = true;
                return;
            }
        }
    }
</script>
