@model Vastwebmulti.Areas.ADMIN.Models.Fundtransferviewmodel
@{ decimal? runningTotal = 0M; decimal? Totalcharges = 0M; decimal? TotalNetTransfer = 0M; decimal? total = 0M; decimal? oldcrs; decimal? currentcr; decimal? totalcrsattelment = 0; }
<table class="table table-bordered table-striped table-hover third-design-table">
    @if (Model.Superstocklistbalance != null)
    {
        <thead>
            <tr>
                <th>MD Firm</th>
                <th>Head</th>
                <th>Payment&nbsp;Type</th>
                <th>Total AMT</th>
                <th>Charge</th>
                <th>Margine</th>

                <th>CR Adjust</th>
                <th>Net T/F</th>
                <th>Transection Id</th>
                <th>Date</th>
            </tr>
        </thead>

        <tbody>
            @{
                List<decimal?> termsList = new List<decimal?>();
            }
            @foreach (var item in Model.Superstocklistbalance.OrderByDescending(a => a.RechargeDate))
            {
                var frmname = item.FarmName == null || item.FarmName=="" ? item.SuperstokistName: item.SuperstokistName ;
                runningTotal = Model.Superstocklistbalance.Sum(x => x.Balance);
                //Totalcharges += item.commistion;
                Totalcharges = Model.Superstocklistbalance.Sum(x => x.commistion);
                TotalNetTransfer = Model.Superstocklistbalance.Sum(x => x.fund_transfer);
                var charge = item.commistion == null ? 0 : item.commistion;

                oldcrs = item.oldcrbalance == null ? 0 : item.oldcrbalance;
                currentcr = item.cr == null ? 0 : item.cr;
                decimal? totalsattlement = 0;
                totalsattlement = oldcrs - currentcr;
                if (totalsattlement <= 0)
                {
                    totalsattlement = 0;
                }
                totalcrsattelment = Model.Superstocklistbalance.Sum(x => x.oldcrbalance) - Model.Superstocklistbalance.Sum(x => x.cr);
                if (totalcrsattelment < 0)
                {
                    totalcrsattelment = 0;
                }


                var colrss = "";
                if (@item.bal_type == "Charge Back"||@item.bal_type=="Offline Charge")
                {
                    colrss = "#ff000063";
                }
                else
                {
                    colrss = "#eae9e9";
                }

            <tr data-toggle="modal" onclick="tablerowshowdetail('MD','@item.FarmName','@item.Head','@item.bal_type','@item.remainsuperafter','@charge','@item.cr','@item.Balance','@item.remainsuper','@item.remainsuperafter','@item.oldcrbalance','@item.cr',`@item.comment`,'@item.fund_transfer','@item.RechargeDate')" data-target="#m-d-fund-transfer" style="background: @colrss">


                <td><p style="margin-top:6px;">  @item.FarmName</p></td>
                <td>@item.Head</td>

                <td><p style="margin-top:6px;">@item.bal_type</p></td>

                <td><p style="margin-top:6px;">@item.Balance</p></td>
                @*
        <td><p style="margin-top:6px;">@item.remainsuper</p></td>*@
                @if (item.commistion == null)
                {
                    <td><p style="margin-top:6px;"> <span>0.00</span>@item.commistion</p></td>

                }
                else
                {
                    <td><p style="margin-top:6px;">@item.commistion</p></td>
                }

                <td><p style="margin-top:6px;">@item.margine</p></td>
                <td><p style="margin-top:6px;">@totalsattlement</p></td>

                @*
        <td><p style="margin-top:6px;">@item.remainsuperafter</p></td>*@
                @*
        <td><p style="margin-top:6px;">@item.cr</p></td>*@

                <td>
                    <p style="margin-top:6px;">

                        @if (@item.fund_transfer < 0)
                        {
                            decimal bb = Convert.ToDecimal(item.fund_transfer);
                            bb = -bb;
                            <span>  (-) @bb</span>
                        }
                        else
                        {
                            @item.fund_transfer
                        }



                    </p>
                </td>
                @*
        <td><p style="margin-top:6px;">@item.oldcrbalance</p></td>*@
                <td><p style="margin-top:6px;">
                    @if (item.transferid == null)
                    {
                        <span> "Not Found"</span>
                    }
                    else
                    {
                        @item.transferid;
                    }

                    </p></td>
                <td><p style="margin-top:6px;">@item.RechargeDate</p></td>

            </tr>
            }
            @{
                decimal? sum = termsList.Sum();
            }
            <tr><td colspan="3">Total</td><td>@runningTotal</td><td>@Totalcharges</td><td>@sum</td><td>@TotalNetTransfer</td><td></td><td></td></tr>

        </tbody>
