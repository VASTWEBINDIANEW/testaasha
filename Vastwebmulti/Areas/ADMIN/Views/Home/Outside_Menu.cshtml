@model Vastwebmulti.Models.showmenu 
@using Vastwebmulti.Models;

@{
    ViewBag.Title = "Outside_Menu";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style>
    .scroll {
        width: 100%;
        max-height: 530px;
        overflow: auto;
    }

        .scroll::-webkit-scrollbar {
            width: 4px;
        }

        .scroll::-webkit-scrollbar-track {
            -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.3);
            border-radius: 10px;
        }

        .scroll::-webkit-scrollbar-thumb {
            border-radius: 10px;
            -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.5);
        }
</style>
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-2">
                <div class="row clearfix">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                        <div class="card">
                            <div class="body scroll" style="max-height:572px;">
                                <div class="demo-button ">
                                    <div class="row">
                                        <div class="col-md-12" style="margin-top:-10px;">
                                            @Html.Partial("ColorPartial")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-10">
                <div class="row clearfix">
                    <div class="col-md-12">
                        <div class="card">
                            <div class="header">
                                <h2 style="color:#00000082;">
                          SELECT WEBSITE MENU
                          </h2>
                               
                            </div>
                            <div class="body">
                               
                                <br />
                                @using (Html.BeginForm("Outside_Menu", "Home", FormMethod.Post))
                                {
                                    <div class="row">
                                        @for (int i = 0; i < Model.check.Count(); i++)
                                        {
                                            <div class="col-md-3" style="margin-bottom:0px;">
                                                <div class="row">
                                                    <div class="col-md-7">
                                                        @Html.HiddenFor(m => Model.check[i].Id)
                                                        @Html.HiddenFor(m => Model.check[i].Status)
                                                        @Html.TextBoxFor(m => Model.check[i].Name, new { @readonly = "readonly", @style = "border:none; margin-left:10px;" })
                                                    </div>
                                                    <div class="col-md-5">
                                                        @Html.CheckBoxFor(m => Model.check[i].Checked, new { @class = "filled-in chk-col-deep-orange", @style = "left:0px; opacity:inherit; margin-left:15px;" })
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <button type="submit" id="btnsubmit" onclick="return CheckBoxCount()" class="btn  waves-effect" style="margin-left:10px; margin-top:10px;border:1px solid #c7c2c2;background:#dedddd;">Submit</button>
                                    <br />
                                    <br />
                                    <br />
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        

    </div>
</section>


<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script src="~/Swalalert/sweetalert-dev.js"></script>
<script src="~/AdminDesign/plugins/jquery-validation/jquery.validate.js"></script>
<script>
    window.onload = function () {
        var succ = '@TempData["success"]';
        if (succ != null && succ != "")
        {
            if (succ.includes("Sucessfully"))
            {
                swal("Good job!", succ, "success");
            }
            else {
                swal("Oops!", succ, "error");
            }
        }
    }
</script>

<script type="text/javascript">
    function CheckBoxCount()
    {
        var inputList = document.getElementsByTagName("input");
        var numChecked = 0;

        for (var i = 0; i < inputList.length; i++)
        {
            if (inputList[i].type == "checkbox" && inputList[i].checked)
            {
                numChecked = numChecked + 1;
            }
        }
        if (numChecked < 6)
        {
            swal("You Select Minimum 6 ! ",'' , "error");
            return false;
        }
        if (numChecked > 8 )
        {
            swal(" You Select Maximum 8 ! ",'' , "error");
            return false;
        }
        //alert("selected count: " + numChecked);
        //return true;
    }
</script>

