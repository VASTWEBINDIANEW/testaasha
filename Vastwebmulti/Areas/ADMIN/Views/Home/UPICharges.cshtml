<script>
    function UPIOnOff(usefor) {
            $.ajax({
            url: '@Url.Action("Hide_Show_UPI", "Home")',
                type: 'POST',
            data: { usefor: usefor },
                success: function (data) {

                    if (data.status == "Success") {
                        if (data.Message == "ON") {
                            $('.'+usefor+'.onoffswitch span').removeClass('custom-off');
                            $('.'+usefor+'.onoffswitch span').addClass('costom-on');
                        }
                        else {
                            if (data.Message == "OFF") {
                                $('.' + usefor +'.onoffswitch span').removeClass('costom-on');
                                $('.' + usefor +'.onoffswitch span').addClass('custom-off');
                            }
                        }
                    }
                    else {
                        ToastrMessage();
                        toastr.error(data.Message);
                    }
            }
        });
    }
</script>
<script>
    function KYCONOFF(usefor) {
       $.ajax({
            url: '@Url.Action("KYC_ON_OFF", "Home")',
                type: 'GET',
           success: function (data) {

                    if (data.status == "Success") {

                        if (data.Message == true) {
                            $('.'+usefor+'.onoffswitch span').removeClass('custom-off');
                            $('.'+usefor+'.onoffswitch span').addClass('costom-on');
                        }
                        else {
                            if (data.Message == false) {
                                $('.' + usefor +'.onoffswitch span').removeClass('costom-on');
                                $('.' + usefor +'.onoffswitch span').addClass('custom-off');
                            }
                        }
                    }
                    else {
                        ToastrMessage();
                        toastr.error(data.Message);
                    }
            }
        });
    }
</script>


