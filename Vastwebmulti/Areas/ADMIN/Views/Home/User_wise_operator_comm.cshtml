<script>
$("#alldealer").change(function () {
    var dealerId = $(this).val();

    if (dealerId) {
        $.ajax({
            url: '@Url.Action("GetRetailerByDealer", "Home")',
            type: "GET",
            data: { dealerId: dealerId },
            success: function (data) {
                var $retailer = $("#retailerlist_Main");
                $retailer.empty();
                $retailer.append($('<option>', { value: "", text: "Select Retailer" }));

                $.each(data, function (i, retailer) {
                    $retailer.append($('<option>', {
                        value: retailer.Value,
                        text: retailer.Text
                    }));
                });

                $retailer.selectpicker('refresh');
            },
            error: function (xhr) {
            }
        });
    }
});

</script>

<script>
    $("#retailerlist_Main").change(function () {
