<script>
    $(document).ready(function () {
        $(".classshow").show();
        $(".classhide").hide();

    })
</script>


<script>
    $('.wallet-edit').click(function () {
        /*  $(this).closest('tr').find('input').removeAttr('readonly');*/
        $(this).closest('tr').find('.wallet-save').css('display', 'block');
        $(this).css('display', 'none');
    });
</script>
<script>
    $('.deleteCharged11').click(function () {
        // $(this).hide();
        // $('#txtupiid').attr("readonly", false);
        $('#txtminbal').attr("readonly", false);
        $('#txtmaxbal').attr("readonly", false);
        $('#txtpercount').attr("readonly", false);
        $(".classshow").hide();
        $(".classhide").show();
        // $(this).next('.deleteCharge').show();
    });
    //$('#EditChrg').click(function () {
    //    $(this).next('.deleteCharged11').hide();
    //});
</script>

