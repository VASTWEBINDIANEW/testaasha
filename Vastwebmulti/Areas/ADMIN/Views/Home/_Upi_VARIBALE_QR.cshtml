<script>
    $('.wallet-edit').click(function () {
        /* $(this).closest('tr').find('input').removeAttr('readonly');*/
        $(this).closest('tr').find('.wallet-save').css('display', 'block');
        $(this).css('display', 'none');
    });
</script>
<script>
    $('.deleteCharged1').click(function () {
        $(this).hide();
        $('#txtminbalUPIQRCODE').attr("readonly", false);
        $('#txtmaxbalUPIQRCODE').attr("readonly", false);
        $(this).next('.deleteCharge').show();
    });
    $('#EditChrg').click(function () {
        $(this).next('.deleteCharged1').hide();

    });
</script>
<script>
    $('#SaveChargeUPIQRCODE').click(function () {
        debugger;
      /* $('#lblmsg').text('')*/
        $.ajax({
            url: '@Url.Action("AddUpiQRCODEMINMAX","Home")',
            type: 'POST',
            data: { min: $("#txtminbalUPIQRCODE").val(), max: $("#txtmaxbalUPIQRCODE").val()},
            success: function (response) {
                toastr.success('UPI QR Range Set Successfully', 'UPI QR LIMIT');
                $('#txtminbalUPIQRCODE').attr("readonly", true);
                $('#txtmaxbalUPIQRCODE').attr("readonly", true);
                $('#RemTblQRCODE').html(response);
            },
            error: function (xhr, status, error) {
                //alert(error);

            }
        });
    })
</script>