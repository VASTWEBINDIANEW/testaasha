                    </div>

                </div>
                <button class="reportandstatus" type="button" id="btnshowhidmaster_dlmComm" value="Report">Show Report</button>
                <div class="masterdealer" style="float:right;padding-right:5px;">
                    <select class="form-control" id="ddlusers" name="ddlusers">
                        <option value="master">Master Distributor</option>
                        <option value="dealer">Distributor</option>
                    </select>
                </div>


            </div>
        </div>

    </div>

    <div class="col-md-12 fund-transfer-main-admin">
        <div class="fund-trasfer-right">

            <div id="tab-1" class="width100 float-left tab-content current" style="padding:0px;">


                @if (Model != null && Model.Common_status_master_dlmlist != null)
                {
                    <div id="tblshowMasterD" class=" table-responsive tableseconddes-admin" style="width:100%;">
                        <table class="table table-bordered table-striped table-hover third-design-table">
                            <thead>
                                <tr>
                                    <th>Role</th>
                                    <th> Name</th>
                                    <th> Firm</th>
                                    <th>Commision Hold</th>
                                    <th>Last Update Time</th>


                                </tr>
                            </thead>
                            <tbody id="body">
                                @foreach (var item in Model.Common_status_master_dlmlist)
                                {
                                    <tr class="tr">
                                        <td>@item.Role</td>
                                        <td>@item.Name</td>
                                        <td>@item.Frmname</td>
                                        <td>
                                            @if (item.Comm_Status == "Y")
                                            {
                                                <span class="onoffswitch costom-on-second" style="float: left;border:0px;">
                                                    <button class="costom-on clscall" id="btnsts_@item.idno" value="ON" onclick="changestats('@item.idno', '@item.Role','N')" style="border:1px solid #aaa4a4;">ON</button>
                                                </span>

                                            }
                                            else
                                            {
                                                <span class="onoffswitch costom-off-second" style="float: left;border:0px;">
                                                    <button class="custom-off clscall" id="btnsts_@item.idno" onclick="changestats('@item.idno', '@item.Role','Y')" value="OFF" style="border:1px solid #aaa4a4;">OFF</button>
                                                </span>
                                            }




                                        </td>
                                        <td>@item.updatetime</td>

                                    </tr>
                                }
                            </tbody>
                        </table>






                    </div>

                }

              
            <div id="tblshowmaster_dlm_comm_reports" class=" table-responsive tableseconddes-admin" style="width:100%;">
                @if (Model != null && Model.Common_status_master_dlm_Transferlist != null)
                {

                    <table class="table table-bordered table-striped table-hover third-design-table">
                        <thead>
                            <tr>
                                <th>Role</th>
                                <th> Name</th>
                                <th> Firm</th>
                                <th> Mobile</th>
                                <th>Pre Balance</th>
                                <th>Total  Comm. Recived</th>
                                <th> Post Balance</th>
                                <th> Admin  Pre bal</th>
                                <th>Admin Post bal</th>
                                <th>Hold Comm date</th>
                                <th>Hold Comm Transfer date</th>


                            </tr>
                        </thead>
                        <tbody id="bodyss">
                            @foreach (var item in Model.Common_status_master_dlm_Transferlist)
                            {
                                <tr class="tr">
                                    <td>@item.Role</td>
                                    <td>@item.Name</td>
                                    <td>@item.Frmname</td>
                                    <td> @item.mobile </td>
                                    <td> @item.master_remain_pre </td>
                                    <td> @item.totalcomm </td>
                                    <td> @item.master_remain </td>
                                    <td> @item.admin_prebal </td>
                                    <td>@item.admin_postbal</td>
                                    <td>@item.Hold_date</td>
                                    <td>@item.trasnferdate</td>

                                </tr>
                            }
                        </tbody>
                    </table>



                }


                </div>

              

                </div>

        </div>
    </div>

</section>
<link href="~/MainFrontDesign/select2/dist/css/select2.min.css" rel="stylesheet" />
