
@{
    ViewBag.Title = "Theme_Design";
}


    <section class="content">
        <div class="container-fluid">
            <div class="row clearfix">
                <div class="col-md-12 col-sm-12 col-xs-12">
                    <div role="tabpanel" class="tab-pane" id="adminprofile">
                        <div class="body" style="height:278px;">
                            <center>
                                <div class="image" style="margin-top:-6px;">
                                    @if (ViewBag.image != null && ViewBag.image != "")
                                    {
                                        <img src="@Url.Content("~/" + ViewBag.image)" width="100" height="100" class="img-circle" alt="User">

                                    }
                                    else
                                    {
                                        <img src="~/Custom-Animation/Custom-img/user.png" width="100" height="100" class="img-circle" alt="User" />
                                    }

                                </div>
                                <div class="msg" style="padding-top:6px;">@ViewBag.email</div>
                            </center>
                            <center>
                                <div class="row" style="margin-top:4%;">

                                    <div class="col-xs-6" style="margin-bottom:0px;">
                                        <a href="~/ADMIN/Home/Profile" class="btn btn-default waves-effect" type="button" style="text-decoration:none;box-shadow:none; border:1px solid #dddddd;width:100%;"><i class="fa fa-user-circle-o" style="top:1px;font-size:14px;"></i>&nbsp;My&nbsp;Profile</a>
                                    </div>

                                    <div class="col-xs-6" style="margin-bottom:0px;">
                                        <a href="@Url.Action("ChangeSecurityPassword","Home")" style="text-decoration:none;box-shadow:none; border:1px solid #dddddd;width:100%;" class="btn btn-default waves-effect"><span style="font-size:13px;"><i class="material-icons" style="font-size:14px;top:2px;">lock_outline</i>&nbsp;Manage Password</span></a>
                                    </div>
                                    <div class="col-md-12" style="margin-bottom:0px;">
                                        <center>
                                            <a class="btn  waves-effect tmw-wawe" href="@Url.Action("Outer_color","Home")"><i class="fa fa-photo" style="top:1px; color:#000;font-size:14px;"></i>&nbsp;<span style="top:1px; color:#000; font-size:13px;">Theme&nbsp;Color's & Design</span></a>
                                        </center>
                                    </div>
                                </div>
                            </center>
                        </div>
                    </div>
                </div>
            </div><!--.row-->
        </div>
    </section>
