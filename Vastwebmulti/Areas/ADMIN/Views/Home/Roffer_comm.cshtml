<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script>
    $(function () {
        var msg = '@ViewBag.msg';
        if(msg!="")
        {
            if (msg == "Succesfully Assign.")
            {
                swal("SUCCESS !", msg, "success");
            }
            else
            {
                swal("ERROR !", msg, "error");
            }
        }

    });
</script>
<script>
    function offersts() {
        $.ajax({
            url: '@Url.Action("offersts", "Home")',
            type: 'GET',
            cache: false,
            success: function () {

            }
        });
        $("#mydiv").load(location.href + " #mydiv");
    }
</script>

<script>
    $(document.documentElement)
        .on("click", "span.item-display", function (event) {
            $(event.currentTarget)
                .hide()
                .next("span.item-field")
                .show()
                .find(":input:first")
                .focus()
                .select();
        })
        .on("click", "span.item-field", function (event) {
            $(event.currentTarget)
                .show()
                .next("span.item-field")
                .hide()
                .find(":input:first")
                .focus()
                .select();
        })
</script>