@model IEnumerable<Vastwebmulti.Models.proc_SelectSettlementHistory_Result>
@{
    ViewBag.Title = "AEPS";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}

<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 81px !important;
    }

    .dataTables_wrapper .dt-buttons a.dt-button {
        padding: 7px 10px 8px 8px;
    }

    .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {
        height: 20px;
    }
     #loader {
        background: rgba(255, 255, 255, 0.8) none repeat scroll 0 0;
        height: 100%;
        position: absolute;
        top: 0;
        width: 100%;
        z-index: 999999;
    }
    .loader_innner {
        position: fixed;
        z-index: 999999;
        height: 100%;
        margin: auto;
        top: 0;
        left: 0;
        bottom: 0;
        right: 0;
        background: rgba(255, 255, 255, 0.8) none repeat scroll 0 0;
    } 
</style>
<div id="div_Loader" style="display:none;">
    <div class="loader_innner">
        <img src="~/images/MoneyTransferLoader.gif" style="margin-top:15%;margin-left:46%;" />
    </div>
</div>
<section class="content">
    <div class="container-fluid">

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    @using (Html.BeginForm("SettlementHistory", "Home", FormMethod.Post))
                    {
                        <div class="col-md-12">
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="form-line" style="margin-top:5px;margin-left:-13px;width:108%;padding-bottom:10px;">
                                        @Html.DropDownList("allretailer", ViewBag.allretailer as SelectList, "All Retailer", new { id = "allretailer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding:0px;text-align:center;height:34px;" })
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group">
                                        <div class="" style="margin-top:5px;margin-left:-13px;width:108%;padding-bottom:10px;">
                                            @Html.DropDownList("ddl_top", new List<SelectListItem>
                              {
                           new SelectListItem{ Text="50",Value="50"},
                           new SelectListItem{Text="100",Value="100"},
                           new SelectListItem{Text="200",Value="200"},
                           new SelectListItem{Text="500",Value="500"},
                           new SelectListItem{Text="1500",Value="1500"},
                           new SelectListItem{Text="All",Value="10000000"}
                          }, new { @class = "selectpicker form-control border-0", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                        </div>
                                    </div>


                                </div>
                                <div class="col-md-4">
                                    <div class="form-group" style="margin-bottom:0px;margin-top:1px;margin-left:-12px;">
                                        <div class="input-daterange input-group">
                                            @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;height:32px;", autocomplete = "off" })
                                            <span class="input-group-addon">
                                                <i class="fa fa-exchange" style="padding-top:8px;"></i>
                                            </span>
                                            @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;height:32px;", autocomplete = "off" })
                                        </div>
                                        <!-- /.input group -->
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="form-group">
                                        <center>
                                            <button type="submit" class="btn" id="btntype" name="btntype" style="margin-top:5px; margin-left:-22px; height:32px;border:1px solid #c7c2c2;background:#dedddd;">
                                                <i class="fa fa-search" style="top:-1px;font-size:13px;color:black;"></i>
                                                <span style="top:-1px;color:black;">Search</span>
                                            </button>
                                        </center>
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                    }


                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-26px;">
                <div class="card">
                    <div class="">
                        <ol class="breadcrumb breadcrumb-col-blue-grey" style="margin-left:5px;margin-top:9px;">
                            <li class="active" style="color:#9E9E9E; font-size:12px;">AEPS FOR SETTLEMENT REPORT&nbsp;></li>
                        </ol>
                    </div>
                    <div class="body" style="padding:7px;">
                        <div class="table-responsive" style="position:inherit;margin-top:-49px;">
                            <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%;font-size:12px;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th style="width:110px;">SR.No.</th>
                                        <th>Email</th>
                                        <th>Amount</th>
                                        <th>Retailer&nbsp;Pre</th>
                                        <th>Retailer&nbsp;Post</th>
                                        <th>Admin&nbsp;Pre</th>
                                        <th>Admin&nbsp;Post</th>
                                        <th>TXN&nbsp;Date</th>
                                        <th>Settled&nbsp;ON</th>


                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null)
                                    {
                                        int i = 1;
                                        foreach (var item in Model)
                                        {
                                            <tr style="font-weight:700;">
                                                <td>
                                                    <p style="font-size:12px;margin-left:-8px;margin-top:-2px;">&nbsp;@i&nbsp;</p>
                                                </td>
                                                <td>
                                                    <p style="font-size:12px;margin-left:-8px;margin-top:-2px;">&nbsp;@item.Email&nbsp;</p>
                                                </td>
                                                <td>
                                                    <p style="font-size:12px;margin-left:-8px;margin-top:-2px;">&nbsp;@string.Format("{0:0.00}", item.Amount)&nbsp;</p>
                                                </td>
                                                <td>
                                                    <p style="font-size:12px;margin-left:-8px;margin-top:-2px;">&nbsp;@string.Format("{0:0.00}", item.remPre)&nbsp;</p>
                                                </td>
                                                <td>
                                                    <p style="font-size:12px;margin-left:-8px;margin-top:-2px;">&nbsp;@string.Format("{0:0.00}", item.remPost)&nbsp;</p>
                                                </td>
                                                <td>
                                                    <p style="font-size:12px;margin-left:-8px;margin-top:-2px;">&nbsp;@string.Format("{0:0.00}", item.adminPre)&nbsp;</p>
                                                </td>
                                                <td>
                                                    <p style="font-size:12px;margin-left:-8px;margin-top:-2px;">&nbsp;@string.Format("{0:0.00}", item.adminPost)&nbsp;</p>
                                                </td>
                                                <td><p style="font-size:11px;margin-left:-7px; margin-top:-2px;">@String.Format("{0:dd-MMM HH:mm:ss}", item.TxnDate)&nbsp;&nbsp;<span style="color:green;font-weight:700;"></span></p></td>
                                                <td><p style="font-size:11px;margin-left:-7px; margin-top:-2px;">@String.Format("{0:dd-MMM HH:mm:ss}", item.SettlementDate)&nbsp;&nbsp;<span style="color:green;font-weight:700;"></span></p></td>
                                            </tr>
                                            i++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</section>




<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->

<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/Swalalert/sweetalert-dev.js">
</script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />

<!--Manual SUCCESS -->
<script>

    function SettleAepsAmount(userid,dt)
    {
        $.ajax({
            url: '@Url.Action("SettleAepsAmountInWallet", "Home")',
            type: 'POST',
            dataType: "json",
            data: {  date:dt },
            success: function (data) {
               // var response = JSON.parse(data);
                if (data.Status == "Success") {
                    swal("Good Job", data.Message, "success");
                    window.location.reload();
                    //reloadPageeee();
                }
                else {
                    swal("Oops...", data.Message, "error");
                }
                //alert(response.Message);
            },
            error: function (data) {
            }
        });
    }
</script>

<script type="text/javascript">
    $(function () {

        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

   });

</script>

<!--Generate Print-->
<script type="text/javascript">
            function GotoPDF(e) {
                // alert(e)
                var idno = e.toString(); ;
                var url = '@Url.Action("GeneratePDF", "Home")?Idno=' + idno + '';
                //window.location.href = url,;
                window.open(url, '_blank');
            }
</script>


