    function setGradientColor(s, color, prefix, className) {
        var gradientStops = document.querySelectorAll(className);

        gradientStops.forEach(function (stop) {
            stop.setAttribute('stop-color', color);
        });
        document.getElementById('col' + s + prefix).innerHTML = color;
    }

    function setBackgroundColor(color, prefix) {
        debugger;
        var gradientStops = document.querySelectorAll('.bgcolores' + prefix);
        gradientStops.forEach(function (stop) {
            stop.setAttribute('fill', color);
        });
        console.log('col3' + prefix);
        document.getElementById('col3' + prefix).innerHTML = color;
    }

    function setRadius(d, prefix) {
        var arr = [1, 10, 20, 30, 100, 200, 300, 400, 500];
        var gradientStops = document.querySelectorAll('.bgcolores' + prefix);

        gradientStops.forEach(function (stop) {
            stop.setAttribute('rx', arr[d]);
            stop.setAttribute('ry', arr[d]);
        });
        document.getElementById('col4' + prefix).innerHTML = arr[d];

        for (var i = 0; i <= 8; i++) {
            document.getElementById('sef' + i + prefix).style.background = 'lightgray';
        }
        document.getElementById('sef' + d + prefix).style.background = 'var(--main-bg-lcolor)';
    }

    function appiconcolor(s, d) {
        if (s === 1) {
            var color = document.getElementById('appcolor11').value;
            setGradientColor(s, color, '', '.coloew1');
        } else if (s === 2) {
            var color = document.getElementById('appcolor12').value;
            setGradientColor(s, color, '', '.coloew2');
        } else if (s === 3) {
            var color = document.getElementById('appBGcolor').value;
            setBackgroundColor(color, '');
        } else if (s === 4) {
            setRadius(d, '');
        }
    }

    function appiconcolorss(s, d) {
        if (s === 1) {
            var color = document.getElementById('appcolorssss').value;
            setGradientColor(s, color, 'ss', '.coloewsss');
        } else if (s === 2) {
            var color = document.getElementById('appcolor12ss').value;
            setGradientColor(s, color, 'ss', '.coloew2ss');
        } else if (s === 3) {
            var color = document.getElementById('appBGcolorss').value;
            setBackgroundColor(color, 'ss');
        } else if (s === 4) {
            setRadius(d, 'ss');
        }
    }

