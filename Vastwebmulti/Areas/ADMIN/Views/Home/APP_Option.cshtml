<script>
     $.ajax({
        type: "POST",
        url: '@Url.Action("faqsave", "Home")',
        data: { q :null , a : null },
        success: function (result) {
            var faq = document.getElementById('faqlist');
            faq.innerHTML = "";
            for (var i = 0; i < result.length; i++) {
                var br = document.createElement('tr');
                var bU = document.createElement('button');
                bU.textContent = "-";
                bU.setAttribute('onclick', 'deletefaq(' + result[i].idno + ',' + i + ')')
                bU.setAttribute('style', 'padding: 0px 20px; background: red;color: white;font-size: larger;');
                bU.setAttribute('class', 'deletefsw');
                br.setAttribute('style', 'font-size: large;');
                var br1 = document.createElement('tr');
                var br2 = document.createElement('tr');
                var hr = document.createElement('hr');
                br1.setAttribute('style', 'font-size: large;');
                br.appendChild(document.createTextNode('Q.' + (i + 1) + ' ' + result[i].question));
                br2.appendChild(bU);
                br1.appendChild(document.createTextNode('Ans.' + result[i].answer));
                faq.appendChild(br);
                faq.appendChild(br1);
                faq.appendChild(br2);
                faq.appendChild(hr);
            }
        }
     });
     $.ajax({
         type: "POST",
         url: '@Url.Action("CheckTheamactive", "Home")',
         success: function (result) {
             if (result.success) {
                 inserthtml(result.theam)
                 var groupId = 'group' + result.theam;
                 const group = document.getElementById(groupId);
                 const button = group.querySelector('button');
                 button.classList.add('ClassBtnActive');
                 ChangeColorIcon(result.theam);
             }
             else {
                 ToastrMessage();
                 toastr.error(result.message);
             }
         }
     });
     
    function ChangeColorIcon(type) {
        if (type == 'fill' || type <= 12) {
            document.getElementById('iconlineshow').style.display = 'none';
            document.getElementById('iconfillshow').style.display = 'block';
            document.getElementById('textforicon').innerHTML = 'We have 12 type fill icon groups';
            document.getElementById('fill').classList.add('filllinecolor');
            document.getElementById('line').classList.remove('filllinecolor');
        }
        else {
            document.getElementById('iconlineshow').style.display = 'block';
            document.getElementById('iconfillshow').style.display = 'none';
            document.getElementById('textforicon').innerHTML = 'We have 12 type out line icon groups';
            document.getElementById('line').classList.add('filllinecolor');
            document.getElementById('fill').classList.remove('filllinecolor');
        }
    }
