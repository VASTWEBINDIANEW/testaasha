    const maxLength = 500;
    function updateCharCount() {
        const textArea = document.getElementById("textArea");
        const charCountDiv = document.getElementById("charCount");
        const currentLength = textArea.value.length;

        if (currentLength > maxLength) {
            textArea.value = textArea.value.substring(0, maxLength);
        }

        charCountDiv.textContent = `Characters Remaining: ${maxLength - currentLength}`;
    }

    function clearText(event) {
        event.preventDefault();
        const textArea = document.getElementById("textArea");
        textArea.value = "";
        updateCharCount();
    }

    function DeleteAppNotification(id) {
        $.ajax({
            url: '@Url.Action("DeleteAppMessage", "Home")',
            type: "POST",
            data: { id : id },
            success: function (response) {
                var IHtml = '';
                var Count = 1;
                response.data.forEach(item => {
                    IHtml += `<div class="mesg_text">
                                   <span>${Count}</span> <p>${item.App_Message} <a onclick="DeleteAppNotification(${item.id})" style="text-decoration: underline;  cursor:pointer;">Delete</a></p>
                              </div>`
                    Count++;
                });
                document.getElementById('AppNotifications').innerHTML = IHtml;
                if (response.status) {
                    toastr.success(response.message);
                }
                else {
                    toastr.error(response.message);
                }
            },
            error: function (error) {
                toastr.error(error.message);
            }

        })
    }

    function handleSubmit(event) {
        event.preventDefault();
        const text = document.getElementById('textArea').value;
         $.ajax({
             url: '@Url.Action("InsertAppMessage", "Home")',
             type: 'POST',
             data: { Message: text },
             success: function (response) {
                 var IHtml = '';
                 var Count = 1;
                 response.data.forEach(item => {
                     IHtml += `<div class="mesg_text">
                                  <span>${Count}</span> <p>${item.App_Message} <a onclick="DeleteAppNotification(${item.id})" style="text-decoration: underline;  cursor:pointer;">Delete</a></p>
                               </div>`
                     Count++;
                 });
                 document.getElementById('AppNotifications').innerHTML = IHtml;
                 if (!response.status) {
                     toastr.error(response.message);
                 }
             }
         });
    }

    function ButtonActive(btn) {
        console.log(btn)
        const buttons = document.querySelectorAll('.button-container button');
        buttons.forEach(button => button.classList.remove('active'));

        const activeButton = document.getElementById(btn);
        if (activeButton) {
            activeButton.classList.add('active');
        } else {
            console.error(`Button with id ${btn} not found`);
            return;
        }
        const sections = {
            Button1: 'AppColor',
            Button2: 'AppIcon',
            Button3: 'AppIconImages',
            Button4: 'AppKYCDocs',
            Button5: 'FQAS',
            Button6: 'AppSlider',
            Button7: 'AppMessage',
        };
        Object.values(sections).forEach(sectionId => {
            const section = document.getElementById(sectionId);
            if (section) {
                section.style.display = 'none';
            } else {
                console.warn(`Section with id ${sectionId} not found`);
            }
        });

        const activeSection = document.getElementById(sections[btn]);
        if (activeSection) {
            activeSection.style.display = 'block';
            if (sections[btn] === 'AppMessage') {
                const event = new Event('submit');
                handleSubmit(event);
            }
        } else {
            console.error(`Active section for ${btn} not found`);
        }
    }

