        const button = group.querySelector('button');
        button.classList.add('ClassBtnActive');
        for (var i = 1; i <= 24; i++) {
            var id = "group" + i;
            if (groupId !== id) {
                const otherGroup = document.getElementById(id);
                if (otherGroup) {
                    const otherButton = otherGroup.querySelector('button');
                    if (otherButton) {
                        otherButton.classList.remove('ClassBtnActive');
                    }
                }
            }
            else {
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("ChangeIconTheam","Home")',
                    data: { theam: i },
