@model IEnumerable<Vastwebmulti.Models.select_dlm_pur_order_Result>
@{
    ViewBag.Title = "Dealer_showpurchase";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style>

      /*   new css     */

    .table_menu {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .t_menu .input-daterange input {
        width: 110px;
        text-align: end;
    }

    .res_div {
        width: auto;
        padding: 0px 2px !important;
    }

      /*   new css     */


    .dropdown-menu {
        margin-top: 81px !important;
    }

    .showpurchase-master-report table tr td img {
        height: 20px;width: 20px;margin-right: 3px;float: left;border-radius: 50%;padding: 3px;
    }
    .showpurchase-master-report table tr td, .showpurchase-master-report table tr th {white-space: nowrap;}
    .showpurchase-master-report table tr td:nth-child(8), .showpurchase-master-report table tr th:nth-child(8) {
        white-space: normal;
    }
    .tablemargin-master tr td p {margin-bottom: 0px;}
    .tablemargin-master tr td, .tablemargin-master tr th {padding-top: 8px !important;padding-bottom: 8px !important;}
    .custom-date-icon {
        border-color: #d4d1d1 !important;
    }


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:991px){

        .res_div {
            float: left;
        }                                                                                                                                

    }                                                                                                                                                                                                       


    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media only screen and (max-width:766px) {

        .table_menu {
            display: block;
        }

        .t_menu {
            width: 100%;
            float: left;
            padding: 3px 0;
        }

        
          .table-responsive > .table-bordered > thead > tr > th:first-child,.table-responsive > .table-bordered > tbody > tr > td:first-child{border-left:1px solid var(--border-color); }
        .showpurchase-master-report table tr th {padding: 10px !important;}
        .showpurchase-master-report table tr td, .showpurchase-master-report table tr th {
            white-space: normal !important;
        }

    }

    @@media only screen and (max-width:480px){

        .res_div {
            width: 100%;
            margin: 2px 0;
        }
        .t_menu .input-daterange input {
            width: 100%;
        }
    }


</style>
<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>Dealer Show Purchase</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Wallet-Q&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Dealer Show Purchase</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card showpurchase-thirddesign-header" style="margin-bottom:5px;">
                    <div class="row" style="margin: 0;">
                        <div class="col-md-7 page-header-third res_div1" style="width: auto; float: left;">
                            <div>
                                @Html.Partial("_menupurchase")
                            </div>
                        </div>
                        <div class="col-md-5 page-header-third res_div1" style="width: auto; float: right;">

                                <div style="float:right; " class="web-white-filter lop">

                                    <input type="button" id="btnExport" value="Export" style="margin-left:0px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 20px;">
                                    <input type="button" id="btnPDF" value="PDF" style="margin-left:2px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">

                                </div>
                           
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card page-header-third">

                    <div class="table_menu">

                        <div class="t_menu">
                            <ul class="" style="float: left; margin: 0; display: flex; align-items: center;">
                                <li class="smli">
                                    <a href="@Url.Action("Dashboard", "Home")" class="fullbodydycolorbg tmw-total-color-one">
                                        Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                                    </a>
                                </li>
                                <li class="fullbodydycolorbg tmw-total-color-one">
                                    Dealer_showpurchase
                                </li>

                            </ul>
                        </div>

                        <div  class="t_menu">
                            <div class="row show-master-purchase" style="margin:0;">

                                @using (Html.BeginForm("Dealer_showpurchase", "Home", FormMethod.Post))
                                {


                                    <div class="col-md-6 res_div" style="padding:0px;">
                                        <div class="form-group" style="margin-bottom:0px;">
                                            <div class="input-daterange input-group">
                                                <div class="custom-date-icon ner" style="border-color:#d4d1d1;">
                                                    <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true" style="left:5px;"></i>
                                                </div>
                                                @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;", autocomplete = "off" })
                                                <span class="input-group-addon" style="padding:0px;min-width:5px;">

                                                </span>
                                                <div style="position:relative;">
                                                    <div class="custom-date-icon ner" style="border-color:#d4d1d1;">
                                                        <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true" style="left:5px;"></i>
                                                    </div>
                                                    @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;", autocomplete = "off" })
                                                </div>
                                            </div>
                                            <!-- /.input group -->
                                        </div>
                                    </div>
                                    <div class="col-md-2 res_div" style="padding:0px 5px;">

                                        <button type="submit" class="btn  waves-effect" style="width:100%; height:32px;border:1px solid #c7c2c2;">
                                            <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                            <span style="top:-2px;color:black;">Search</span>
                                        </button>

                                    </div>


                                }

                            </div>
                        </div>

                    </div>
                    

                    <div style="width: 100%; float: left; margin-top: 5px;">
                        <div class="table-responsive showpurchase-master-report tablefourdesign-admin" style="position:inherit;">
                            <table class="table table-bordered table-striped table-hover tablemargin-master third-design-table" style="width:100%;background:#f9f9f9;">

                                <thead style="background-color:whitesmoke;">

                                    <tr>
                                        <th style="padding-right:36px;">Status </th>
                                        <th>Order&nbsp;No</th>

                                        <th>Distributor&nbsp;Info</th>
                                        <th>Request&nbsp;Date </th>
                                        <th>Payment&nbsp;Mode</th>
                                        <th>Amount</th>
                                        <th>Charge</th>

                                        <th> Bank&nbsp;Name</th>
                                        <th>From&nbsp;Acc&nbsp;No </th>
                                        <th>Utr&nbsp;/&nbsp;SlipNo </th>
                                        <th>Comment</th>
                                        <th>Resp.&nbsp;Date</th>
                                        <th>Action</th>
                                    </tr>

                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        var color = "";
                                        var stscolor = "";
                                        var img = "";
                                        //if (item.type_.ToUpper() == "CASH")
                                        //{
                                        //    color = "green";
                                        //}
                                        //if (item.type_.ToUpper() == "CREDIT")
                                        //{
                                        //    color = "red";
                                        //}
                                        if (item.sts == "Pending")
                                        {
                                            stscolor = "#FF9800";
                                            img = "../../ashok-images/clkk.png";
                                        }
                                        if (item.sts == "APPROVED")
                                        {
                                            stscolor = "green";
                                            img = "../../ashok-images/correct.svg";
                                        }
                                        if (item.sts == "REJECTED")
                                        {
                                            stscolor = "red";
                                            img = "../../ashok-images/closes.svg";
                                        }

                                        <tr>
                                            <td><p style="font-size:12px;text-align:center;"><span style="color:#555;font-weight:400;"><img src="@img" style="background:@stscolor;" />&nbsp;@item.sts.ToUpper()</span></p></td>
                                            <td><p style="font-size:12px;">@item.orderno&nbsp;@*⇒&nbsp;<span style="color:@color;font-weight:600;">@item.type_.ToUpper()</span>*@</p></td>

                                            <td><p style="font-size:12px;">@Html.DisplayFor(modelItem => item.DealerEmail).ToString().ToUpper()</p></td>
                                            <td><p style="font-size:12px;">@String.Format("{0:dd-MM-yyyy} {0:t}", item.reqdate)</p></td>
                                            <td><p style="font-size:12px;">@Html.DisplayFor(modelItem => item.paymode).ToString().ToUpper()</p></td>
                                            <td><p style="font-size:12px;text-align:center;">@Html.DisplayFor(modelItem => item.amount)</p> </td>
                                            <td><p style="font-size:12px;">@item.cashDepositCharge</p></td>

                                            <td>@Html.DisplayFor(modelItem => item.banknm).ToString().ToUpper()</td>
                                            <td><p style="font-size:12px;">@Html.DisplayFor(modelItem => item.Fromaccountno)</p></td>

                                            <td>@Html.DisplayFor(modelItem => item.utrno).ToString().ToUpper()</td>
                                            <td>@Html.DisplayFor(modelItem => item.details)</td>


                                            <td>@String.Format("{0:dd-MM-yyy} {0:t}", item.respodate)</td>

                                            <td>
                                                <div class="row">
                                                    @if (item.sts == "Pending")
                                                    {


                                                        <div class="col-md-12">
                                                            <button type="button" name="type" onclick="return funin('@item.id','APP')" style="background-color: transparent; color: black; border: none; margin-top: 0px;">
                                                                <i class="fa fa-check" style="top:1px;border: 1px solid #c7c2c2;padding: 3px;font-size: 10px;" aria-hidden="true"></i>
                                                            </button>

                                                            <button type="button" name="type" onclick="return funin('@item.id','REJ')" style="background-color: transparent; color: black; border: none; margin-top: 0px;">
                                                                <i class="fa fa-times" style="top:1px;border: 1px solid #c7c2c2;padding: 3px 4px;font-size: 10px;" aria-hidden="true"></i>
                                                            </button>
                                                        </div>

                                                    }
                                                    else
                                                    {

                                                    }
                                                </div>
                                            </td>

                                        </tr>
                                    }
                                    <tr>
                                        <td><p style="font-size:17px;">Total</p></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td><p style="font-size:18px;text-align:center;">@Model.Sum(a => a.amount)</p></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>

                                    </tr>
                                </tbody>

                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="modal fade" id="myModal" role="dialog">
    <div class="modal-dialog">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header" style="position:initial;background-color:whitesmoke;">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" style="color:black;">Enter Comment</h4>
            </div>
            @using (Html.BeginForm("updatepurchage_Dealer", "Home", FormMethod.Post))
            {
        <div class="modal-body">
            <input type="text" id="id" name="id" class="form-control" style="display:none;" />
            <input type="text" id="type" name="type" class="form-control" style="display:none;" />
            <input type="password" autocomplete="new-password" id="txthighsec" name="txthighsec" class="form-control" required placeholder="Enter Transection Password" /><br />
            <textarea id="txtcomment" name="txtcomment" class="form-control" required="" placeholder="Enter Comment"></textarea>

        </div>
                <div class="modal-footer">
                    <button type="submit" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-right: 12px; height:34px;">
                        <span style="top:-2px;color:black;">Save Change</span>
                    </button>
                    <button type="button" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left: -3px; height:34px;" data-dismiss="modal">
                        <span style="top:-2px;color:black;">Close</span>
                    </button>
                </div>
            }

        </div>

    </div>
</div>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
