<script>
    function showDetails(btn) {
        document.getElementById("rceid").innerText = btn.dataset.rceid;
        document.getElementById("clientname").innerText = btn.dataset.clientname;
        document.getElementById("cashlimit").innerText = btn.dataset.cashlimit;
        document.getElementById("status").innerText = btn.dataset.status;
        document.getElementById("dccode").innerText = btn.dataset.dccode;
        document.getElementById("pointname").innerText = btn.dataset.pointname;
        document.getElementById("pointmobile").innerText = btn.dataset.pointmobile;
        document.getElementById("pickupaddress").innerText = btn.dataset.pickupaddress;
        document.getElementById("subdescrtion").innerText = btn.dataset.subdescrtion;
        document.getElementById("workmode").innerText = btn.dataset.workmode;
        document.getElementById("statename").innerText = btn.dataset.statename;
        document.getElementById("districtname").innerText = btn.dataset.districtname;
        document.getElementById("cityname").innerText = btn.dataset.cityname;
        document.getElementById("pincode").innerText = btn.dataset.pincode;
        document.getElementById("additionalrequirement").innerText = btn.dataset.additionalrequirement;
        document.getElementById("latitude").innerText = btn.dataset.latitude;
        document.getElementById("longitude").innerText = btn.dataset.longitude;
        document.getElementById("depositionmode").innerText = btn.dataset.depositionmode;
        //$('#myModal').modal('show');
    }
</script>
<script>
    function myFunction(e) {
        var id = $(e).val();

        $("#district1").empty()
            .append("<option value=''>--- Select ---</option>");

        $.get("District_Bind", { state_id: id }, function (data) {
            var options = "<option value=''>--- Select ---</option>";

            $.each(data, function (i, v1) {
                options += "<option value='" + v1.value + "'>" + v1.text + "</option>";
            });

            $("#district1").html(options);
        });
    }
</script>
<script>
    function validateLatitude() {
        var lat = parseFloat(document.getElementById("txtlat").value);
        var error = document.getElementById("latError");

        if (isNaN(lat)) {
            error.innerText = "Latitude is required";
            return false;
        }

        if (lat < -90 || lat > 90) {
            error.innerText = "Latitude must be between -90 and 90";
            return false;
        }

        error.innerText = "";
        return true;
    }

    function validateLongitude() {
        var lng = parseFloat(document.getElementById("txtlong").value);
        var error = document.getElementById("longError");

        if (isNaN(lng)) {
            error.innerText = "Longitude is required";
            return false;
        }

        if (lng < -180 || lng > 180) {
            error.innerText = "Longitude must be between -180 and 180";
            return false;
        }

        error.innerText = "";
        return true;
    }

    function validateLatLongOnSubmit() {
        return validateLatitude() && validateLongitude();
    }
</script>
