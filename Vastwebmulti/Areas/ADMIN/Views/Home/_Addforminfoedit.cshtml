@model Vastwebmulti.Areas.ADMIN.Models.MasterDistributerModel

<style>
    .wallet-bank-input input[readonly="readonly"] {
        background: transparent;
        border: 0px;
    }
</style>
<style>
    .slab-first-tab {
        background: var(--second-bg-color);
        margin-left: 8px !important;
    }

    .modal .modal-content .modal-body21 {
        color: #777;
        background: #ddd;
        height: 56px;
        border-bottom: 2px solid;
        padding: 15px 122px;
    }
</style>


<table class="table special-iii table-bordered  table-hover paid-service-table example-second" id="dvCategoryResults1">
    <thead>
        <tr>
            <th>Name</th>
            <th>Action</th>
        </tr>
    </thead>


    @foreach (var item in Model.AddForm_information)
    {
        <tbody>
            <tr>
            

                @if (item.id == Model.AddForm_informationbyid.id)
                {
                    
                    @Html.Hidden("idno", Model.AddForm_informationbyid.id)

                    <td>@Html.TextBox("Name", Model.AddForm_informationbyid.Name, new { @class = "form-control" })</td>

                    <td>
                        <button type="button" id="formsavebtn" onclick="formsavebtn(@item.id)" value="Save" class="btn waves-effect btnssl1 switch-edit-button" data-loading-text="<i class='fa fa-spinner fa-spin'></i>">Save</button>


                    </td>
                }
                else
                {
                    @*<td>
                            @Html.DisplayFor(modelItem => item.Role)
                        </td>*@
                    <td>@Html.DisplayFor(modelItem => item.Name)</td>
                    <td class="last-td">
                        <button type="button" onclick="myFunctionform('@item.id')" id="formedit1" class="btn waves-effect shownextrow switch-edit-button" value="Edit">
                            <p>Edit</p>
                        </button>
                    </td>
                }

            </tr>



        </tbody>
    }
</table>


@*<script>
        $(document).ready(function () {
            $('.second-design .example-second').DataTable({
                paging: false
            });
        });

    </script>*@
<script>
    function formsavebtn(idno) {
         $.ajax({
             url: '@Url.Action("Edit_FormNameinfo", "Home")',
             type:'POST',
             data: { idno: idno, Name: $('#Name').val() },

             success: function (data) {

                 setTimeout(function () { $('#manualaddinfomatin').html(data); }, 500);

            }
        });


    }

     $('.btnssl1').on('click', function () {
                    var $this = $(this);
                    $this.button('loading');
                    setTimeout(function () {
                        $this.button('reset');
                    }, 500);
                });
</script>


