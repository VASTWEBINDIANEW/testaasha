<script type="text/javascript">
    var MSG = '@TempData["BalanceTransferMsg"]';
    var sts = '@TempData["BalanceTransfertype"]';
    var type = "";
    if (sts == "error")
    {
        type = "Failed";
    }
    else
    {
        type = "Success";
    }
    if (MSG != null && MSG != "") {
        sweetAlert(type, MSG, sts);
    }
</script>
<script>

    $(function()
    {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
