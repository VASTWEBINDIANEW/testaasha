            padding:10px;
        }
    </style>

    <div class="custom-table-responsive" style="height: 80vh !important;">
        <div class="table-responsive">
            <table class="table table-bordered third-design-table" id="mdList">
                <thead>
                    <tr>
                        <th>User&nbsp;Firm</th>
                        <th>User&nbsp;Name</th>
                        <th>Mobile&nbsp;No</th>
                        <th>PAN&nbsp;No</th>
                        <th>Email&nbsp;V/F</th>

                    </tr>
                </thead>
                <tbody  class="body">
                    @if (Model.Vendor_list != null)
                    {
                        int i = 0;
                        foreach (var item in Model.Vendor_list)
                        {
                            var idno = "subTbl";
                            idno = idno + i;

                            var idshow = "subTblshow";
                            idshow = idshow + i;

                            var idhide = "subTblhide";
                            idhide = idhide + i;

                            <tr  class="tr">

                                <td>
                                    @*<i id="@idshow" class="fa fa-angle-double-down" aria-hidden="true" onclick="md_dlm_List('@item.RetailerId', '@i')">
                                        @item.Frm_Name
                                    </i>
