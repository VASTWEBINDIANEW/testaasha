            cache: false,
            success: function (data2) {
           
                      $('#error').text("");
                var date = new Date(parseInt((data2.list[0].joindate).match(/\d+/)[0]))
                var createddate = converttoDate(date);
                $("#venderid").val(data2.list[0].userid);
                $("#venderiddelete").val(data2.list[0].userid);
                $("#venderidshow").val(data2.list[0].userid);
                $("#Names").text(data2.list[0].Name);
                $("#NameEdit").val(data2.list[0].Name);
                $("#FirmName").text(data2.list[0].Firmname);
                $("#FirmEdit").val(data2.list[0].Firmname);
                $("#RegisteredDate").text(createddate);
                $("#Email11").val(data2.list[0].emailid);
                $("#Pancard11").val(data2.list[0].pancardnumber);
                $("#pancardEdit").val(data2.list[0].pancardnumber);
                $("#Aadhar11").val(data2.list[0].aadharnumber);
                $("#AadhaarEdit").val(data2.list[0].aadharnumber);
                $("#GSTRegistrationNo11").val(data2.list[0].gstnumber);
                $("#gstEdit").val(data2.list[0].gstnumber);
                $("#pincode11").val(data2.list[0].pin);
                $("#PinEdit").val(data2.list[0].pin);
                //$("#masterremain").html(data2[0].superremain);
                //$("#dealerremain").html(data2[0].remaindlm);
