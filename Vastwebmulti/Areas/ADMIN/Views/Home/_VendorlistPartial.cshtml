                                    }
                                    <img src="~/ashok-images/rightaeps.svg" style="width: 11px;margin-top: 6px;float: right;">
                                </td>

                            </tr>

                            @*<tr id="@i" style="display:none;background-color: rgb(245, 245, 245);">
                                <td colspan="8">
                                    <div id="@idno">

                                    </div>
                                </td>
                            </tr>*@

                            i++;
                        }

                    }
                </tbody>
            </table>
        </div>
