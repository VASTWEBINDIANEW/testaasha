@model Vastwebmulti.Areas.ADMIN.Models.LoanModel
@{
    ViewBag.Title = "Loan_Slab_setting";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card" style="margin-bottom:2px;">
                    <div class="row">
                        <div class="col-md-12">

                            @Html.Partial("_ApislabSetting")

                        </div>
                    </div>

                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card">
                    <div class="header">
                        <div class="row">
                            <div class="col-md-4">
                                <h2>Loan Services Information</h2>
                            </div>

                            <div class="col-md-8">
                                <button type="button" class="btn bg-blue-grey waves-effect" data-toggle="modal" data-target="#myModal">Utility Charge</button>
                                <a href="@Url.Action("Loan_Slab_setting","Home")" id="Comm" class="btn bg-blue-grey waves-effect">Common</a>
                                <button type="button" id="Mdbtn" class="btn bg-blue-grey waves-effect" onclick="editUserWise('Master', 'EditFormUserWise')">Master</button>
                                <button type="button" id="Dlmbtn" class="btn bg-blue-grey waves-effect" onclick="editUserWise('Dealer', 'EditFormUserWise')">Distributor</button>
                                <button type="button" id="Rembtn" class="btn bg-blue-grey waves-effect" onclick="editUserWise('Retailer', 'EditFormUserWise')">Retailer</button>
                                <button type="button" id="Apibtn" class="btn bg-blue-grey waves-effect" onclick="editUserWise('API', 'EditFormUserWise')">API</button>
                                <button type="button" id="Whitebtn" class="btn bg-blue-grey waves-effect" onclick="editUserWise('Whitelabel', 'EditFormUserWise')">White Label</button>
                                <button id="btnEdit" type="button" class="btn bg-blue-grey waves-effect" style="margin-left:22px;" onclick="funcEdit(this, 'EditFormComm')">Edit</button>
                            </div>
                        </div>

                    </div>
                    <div class="table-responsive">
                        <div id="divEditFormComm" class="body table-responsive" style="position:inherit; margin-top:-20px;">
                            @using (Html.BeginForm("Loan_Slab_setting", "Home", FormMethod.Post, new { id = "EditFormComm" }))
                            {
                                <table class="table table-bordered">
                                    <thead class="navbar" style="position:initial;color:white;">
                                        <tr>
                                            <th>Operator&nbsp;Name</th>
                                            <th>Master</th>
                                            <th>Distributor</th>
                                            <th>Retailer</th>
                                            <th>API</th>
                                            <th>Whitelabel</th>
                                            <th>Gst</th>
                                            <th>SurCharge</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tbodyshow">
                                        @foreach (var item in Model.common)
                                        {
                                            <tr>
                                                <td><p>@item.OperatorName</p></td>
                                                <td>@item.mastercomm</td>
                                                <td>@item.dlmcomm</td>
                                                <td>@item.retailercomm</td>
                                                <td>@item.apicomm</td>
                                                <td>@item.whitelabelcomm</td>
                                                <td>@item.gst</td>
                                                <td>@item.surcharge</td>
                                            </tr>
                                        }

                                    </tbody>
                                    <tbody id="tbodyedit" style="display:none;">
                                        @for (int i = 0; i < Model.common.Count; i++)
                                        {
                                            <tr>
                                                @Html.HiddenFor(a => a.common[i].idno)
                                                <td>
                                                    @Html.DisplayFor(a => a.common[i].OperatorName)
                                                </td>
                                                <td>
                                                    @Html.EditorFor(a => a.common[i].mastercomm, new { htmlAttributes = new { @style = "width:100%" } })
                                                    @Html.ValidationMessageFor(a => a.common[i].mastercomm)
                                                </td>
                                                <td>
                                                    @Html.EditorFor(a => a.common[i].dlmcomm, new { htmlAttributes = new { @style = "width:100%" } })
                                                    @Html.ValidationMessageFor(a => a.common[i].dlmcomm)
                                                </td>
                                                <td>
                                                    @Html.EditorFor(a => a.common[i].retailercomm, new { htmlAttributes = new { @style = "width:100%" } })
                                                    @Html.ValidationMessageFor(a => a.common[i].retailercomm)
                                                </td>
                                                <td>
                                                    @Html.EditorFor(a => a.common[i].apicomm, new { htmlAttributes = new { @style = "width:100%" } })
                                                    @Html.ValidationMessageFor(a => a.common[i].apicomm)
                                                </td>
                                                <td>
                                                    @Html.EditorFor(a => a.common[i].whitelabelcomm, new { htmlAttributes = new { @style = "width:100%" } })
                                                    @Html.ValidationMessageFor(a => a.common[i].whitelabelcomm)
                                                </td>
                                                <td>
                                                    @Html.EditorFor(a => a.common[i].gst, new { htmlAttributes = new { @style = "width:100%" } })
                                                    @Html.ValidationMessageFor(a => a.common[i].gst)
                                                </td>
                                                <td>
                                                    @Html.EditorFor(a => a.common[i].surcharge, new { htmlAttributes = new { @style = "width:100%" } })
                                                    @Html.ValidationMessageFor(a => a.common[i].surcharge)
                                                </td>
                                            </tr>
                                        }

                                    </tbody>
                                </table>
                            }
                        </div>


                    </div>
                </div>
            </div>

        </div>

    </div>
</section>
<div id="myModal" class="modal fade" role="dialog">
    <div class="modal-dialog">

        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">Utility Charge</h4>
            </div>
            <div class="modal-body">
                <table class="table table-bordered">
                    <thead class="navbar" style="position:initial;color:white;">
                        <tr>
                            <th>Operator&nbsp;Type</th>
                            <th>Retailer Fixed Charge(Rs)</th>
                            <th>Retailer Per Charge(%)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Loan</td>
                            <td>
                                @if (ViewBag.loanf == true)
                                {
                                    <a href="@Url.Action("loancharge", "Home")" style="text-decoration:none;">
                                        <img src="~/images/reportimage/switch_on.png" style="margin-top:2px;height:23px;" />
                                    </a>
                                }
                                else
                                {
                                    <a href="@Url.Action("loancharge", "Home")" style="text-decoration:none;">
                                        <img src="~/images/reportimage/switchoff.png" style="margin-top:2px;height:23px;" />
                                    </a>
                                }
                            </td>
                            <td>
                                @if (ViewBag.loanp == true)
                                {
                                    <a href="@Url.Action("loancharge", "Home")" style="text-decoration:none;">
                                        <img src="~/images/reportimage/switch_on.png" style="margin-top:2px;height:23px;" />
                                    </a>
                                }
                                else
                                {
                                    <a href="@Url.Action("loancharge", "Home")" style="text-decoration:none;">
                                        <img src="~/images/reportimage/switchoff.png" style="margin-top:2px;height:23px;" />
                                    </a>
                                }
                            </td>
                        </tr>
                        
                        
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>

    </div>
</div>
<script>
    var FormId = "";
    function funcEdit(event, frmId) {
        //alert();
        $('#tbodyshow').hide();
        $('#tbodyedit').show();
        $(event).replaceWith('<button id="btnEdit" type="button" class="btn bg-blue-grey waves-effect" style="margin-left:22px;" onclick="funcSave()">Save</button>');
        if (FormId == "")//Use in Default Slab edit
        {
            FormId = frmId;
        }
        var ddlVal = $('#ddlUserId').val();
        if (ddlVal != null && ddlVal == '')//Update ALL
        {
            $('#tbodyeditAll').show();
            $('#tbodyedit').hide();
        }
         if (ddlVal != null && ddlVal != '')//Update ALL
        {
            $('#tbodyeditAll').hide();
            $('#tbodyedit').show();
         }
         var Retailerval = $('#Retailerid').val();

         if (Retailerval != null && Retailerval == '')//Update ALL
         {

             $('#tbodyeditAll').show();
             $('#tbodyedit').hide();

         }
         if (Retailerval != null && Retailerval != '')//Update ALL
         {

             $('#tbodyeditAll').hide();
             $('#tbodyedit').show();

         }
    }
    function funcSave() {
        //alert(FormId);
        $("#" + FormId + "").submit();
    }

    function editUserWise(userRole, frmId) {
        //alert(userRole);
        var url = '@Url.Action("_UserLoanSlab", "Home")';
        $.post(url, { role: userRole }, function (data) {
            $("#divEditFormComm").html(data);
            FormId = frmId;
            $("#btnEdit").replaceWith('<button id="btnEdit" type="button" class="btn bg-blue-grey waves-effect" style="margin-left:22px;" onclick="funcEdit(this, \'EditFormComm\')">Edit</button>');
            $("#role").val(userRole);
        })
          .fail(function (xhr, status, error) {
              alert("error");
              //var err = eval("(" + xhr.responseText + ")");
              //alert(err.Message);
              console.log(xhr.responseText);
          })
          .always(function () {
          });
        if(userRole=="Master")
        {
            $("#Mdbtn").removeClass("btn bg-blue-grey waves-effect").addClass("btn bg-grey waves-effect");
            $("#Dlmbtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Rembtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Apibtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Whitebtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Comm").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            document.getElementById("Retailerdropdow").style.display = "none";

        }
        if (userRole == "Dealer") {
            $("#Dlmbtn").removeClass("btn bg-blue-grey waves-effect").addClass("btn bg-grey waves-effect");
            $("#Mdbtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Rembtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Apibtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Whitebtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Comm").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            document.getElementById("Retailerdropdow").style.display = "none";
        }
        if (userRole == "Retailer") {
            $("#Rembtn").removeClass("btn bg-blue-grey waves-effect").addClass("btn bg-grey waves-effect");
            $("#Mdbtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Dlmbtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Apibtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Whitebtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Comm").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Retailerdropdow").show();
        }
        if (userRole == "API") {
            $("#Apibtn").removeClass("btn bg-blue-grey waves-effect").addClass("btn bg-grey waves-effect");
            $("#Mdbtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Dlmbtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Rembtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Whitebtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Comm").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            document.getElementById("Retailerdropdow").style.display = "none";
        }
        if (userRole == "Whitelabel") {
            $("#Whitebtn").removeClass("btn bg-blue-grey waves-effect").addClass("btn bg-grey waves-effect");
            $("#Mdbtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Dlmbtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Rembtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Apibtn").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            $("#Comm").removeClass("btn bg-grey waves-effect").addClass("btn bg-blue-grey waves-effect");
            document.getElementById("Retailerdropdow").style.display = "none";
        }
    }

    function ddlUserIdChange() {
        var ddlVal = $('#ddlUserId').val();
        var role = $("#role").val();
        //alert(ddlVal);
        var url = '@Url.Action("_UserLoanSlab", "Home")';
        $.post(url, { role: role, userid: ddlVal }, function (data) {
            $("#divEditFormComm").html(data);
            $("#btnEdit").replaceWith('<button id="btnEdit" type="button" class="btn bg-blue-grey waves-effect" style="margin-left:22px;" onclick="funcEdit(this, \'EditFormComm\')">Edit</button>');

        })
          .fail(function (xhr, status, error) {
              //alert("error");
              //var err = eval("(" + xhr.responseText + ")");
              //alert(err.Message);
              console.log(xhr.responseText);
          })
          .always(function () {
              //alert("finished");
          });

    }

    function ddlRetailerIdChange() {
        var ddlVal = $('#Retailerid').val();
        var role = $("#role").val();
        //alert(ddlVal);
        var url = '@Url.Action("_UserLoanSlab", "Home")';
        $.post(url, { role: role, Retailerid: ddlVal }, function (data) {
            $("#divEditFormComm").html(data);
            $("#btnEdit").replaceWith('<button id="btnEdit" type="button" class="btn bg-blue-grey waves-effect" style="margin-left:22px;" onclick="funcEdit(this, \'EditFormComm\')">Edit</button>');

        })
          .fail(function (xhr, status, error) {

              console.log(xhr.responseText);
          })
          .always(function () {

          });

    }
</script>

<!--Window Load-->
<script>
    window.onload=function()
    {
        $("#Comm").removeClass("btn bg-blue-grey waves-effect").addClass("btn bg-grey waves-effect");
    }
</script>

