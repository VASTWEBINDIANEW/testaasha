    function Search_API_His_ByTest() {

        var value = $('.API_SMS').val();


        var patt = new RegExp(value, "i");



        $('#APISMSHISTORY').find('tr').each(function () {

            if (!($(this).find('td').text().search(patt) >= 0)) {

                $(this).not('.first-tr').hide();

            }

            if (($(this).find('td').text().search(patt) >= 0)) {

                $(this).show();

            }

        });

    };
