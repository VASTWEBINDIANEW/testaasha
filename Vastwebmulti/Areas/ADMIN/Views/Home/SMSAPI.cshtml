<script type="text/javascript">
    var val1 = "";
    function animation(id, sms, spisms, sim) {
      sms=  decodeURIComponent(sms);
        $("#idno").val(id);
        $("#txtsms").val(sms);
        $("#smsapi").val(spisms);
        $("#sim").val(sim);
    }
    function check() {
        var smsapi = $('#smsapi').val();
        var sim = $('#sim').val();
        if (smsapi == sim ) {
            swal("Opps!", "Not Two Priority Are Same", "error");
            //alert("Not Two Priority Are Same ");
            return false;

        }
        else {
            //return true;
            $.ajax({
                type: 'POST',
                url: '@Url.Action("edit_smspriority","Home")',
                data: {idno: $("#idno").val(),txtsms:$("#txtsms").val(),smsapi: $("#smsapi").val(),sim: $("#sim").val()},
                success: function (response) {
                    var tblHtml="";
             $.each(response.SMS_PriorityList,function(a,b){

                       //tblHtml+= "<tr><td>"+b.idno+"</td>";
                       tblHtml+= "<tr><td>"+b.sms+"</td>";
                       tblHtml+= "<td>"+b.smsapi+"</td>";
                 tblHtml += "<td>" + b.sim + "</td>";
                 tblHtml+="<td><button class='bt btn-default switch-edit-button' data-toggle='modal' onclick=animation('"+b.idno +"','"+encodeURIComponent(b.sms)+"','"+b.smsapi+"','"+b.sim+"') data-target='#defaultModal12' > Edit</button></td></tr>"

             });
                    $("#gridtbl > tbody").html(tblHtml);
                    $('#defaultModal12').modal('hide');

                }

            });
        }
    }
</script>
