<section class="content smsapi-pages fourdesign-section-admin">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>Sms Api</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Basic Setting&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Sms Api</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="page-header-third pageheader-margin-third four-noneclass-admin-only">
            <div class="bread-same-all-page breadsameall-second">
                <ul class="padding-top-third">
                    <li class="smli">
                        <a href="@Url.Action("Dashboard", "Home")" class="fullbodydycolorbg tmw-total-color-one">
                            Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                        </a>
                    </li>
                    <li class="fullbodydycolorbg tmw-total-color-one">
                        <a href="@Url.Action("Dashboard", "Home")#setting" class="fullbodydycolorbg tmw-total-color-one">
                            Basic&nbsp;Setting
                        </a>&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                    </li>
                    <li class="fullbodydycolorbg tmw-total-color-one">
                        SMS setting
                    </li>

                    @*<li style=" float: right;" class="fullbodydycolorbg tmw-total-color-one">
                            <a href="@Url.Action("Setting_SMS_TEMPLATE", "Home")" class="btn fullbodydycolorbg tmw-total-color-one">
                                Setting_SMS_TEMPLATE
                            </a>
                        </li>*@
                </ul>

                <div class="res_div">
                    <input id="searchSms" type="text" name="myInput" placeholder="Search..." onkeyup="myFunction()" style="display: none;padding: 2px 10px;">

                </div>


            </div>
        </div>

        <div class="row clearfix">
            <div class="col-md-4 col-sm-12 col-xs-12 left-rowss">

                <div class="page-header-third">
                    <div class="head-sms">
                        <ul class="tabs2 tab-seconddesign tab-third-design">
                            <li class="tab-link2 current2 sms-first-hide-up" data-tab="tab-5">SMS PRIORITY</li>
                            <li class="tab-link2 sms-first-hide-up" data-tab="tab-6">SEND SMS</li>
                            <li class="tab-link2 sms-first-show-up" data-tab="tab-7">SET TEMPLATE</li>
                        </ul>
                    </div>
                    <div class="smsapi-first custom-table-responsive padding-top-second padding-topclass-third">
                        <div class="sams-next ">
                            <div id="tab-5" class="tab-content2 current2">
                                <div class="table-responsive tablefourdesign-admin">
                                    <table class="table table-bordered paid-service-table example-second" style="width: 100%;" id="gridtbl">
                                        <thead>
                                            <tr>
                                                <th>SMS FROM</th>
                                                <th>API SMS</th>
                                                <th>SIM SMS</th>
                                                <th>Edit</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.SMS_PriorityList)
                                            {
                                                <tr>
                                                    <td>
                                                        @item.sms
                                                    </td>
                                                    <td>
                                                        @item.smsapi
                                                    </td>
                                                    <td>
                                                        @item.sim
                                                    </td>
                                                    <td>
                                                        <button class="bt btn-default smsbbtn switch-edit-button" onclick="animation('@item.idno','@item.sms','@item.smsapi','@item.sim')">Edit</button>

                                                    </td>
                                                </tr>

                                                <tr style="display:none;">
                                                    <td>@Html.TextBox("txtsms", "", new { @placeholder = "Enter SMS", @required = "required", @class = "form-control", maxlength = "5", @readonly = true })</td>
                                                    <td>
                                                        @Html.DropDownList("smsapi", new List<SelectListItem>
                                          {
                                          new SelectListItem{ Text="1",Value="1",},
                                          new SelectListItem{Text="2",Value="2"}
                                          }, new { @class = "form-control" })
                                                    </td>
                                                    <td>
                                                        @Html.DropDownList("sim", new List<SelectListItem>
                                       {
                                       new SelectListItem{ Text="1",Value="1",},
                                       new SelectListItem{Text="2",Value="2"}
                                       }, new { @class = "form-control" })
                                                    </td>
                                                    <td>
                                                        <button type="submit" class="btn waves-effect btnssl2233 special-iii switch-edit-button" onclick="return check()" data-loading-text="<i class='fa fa-spinner fa-spin'></i>">
                                                            <span>Save</span>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }

                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <!-- #tab-5 -->
                            <div id="tab-6" class="tab-content2">
                                <div>
                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                        <div class="body paid-service-table sms-page padding-topo-second tabcurrent-seconddesign padding-top-third input-border-third">
                                            <form>
                                                <div class="radio-sms">
                                                    <fieldset>
                                                        <ul>
                                                            <li>
                                                                <input type="radio" value="value1" name="group1" id="byapi1" checked>
                                                                <label for="byapi1">BY API</label>
                                                            </li>
                                                            <li>
                                                                <input type="radio" value="value2" name="group1" id="bysim1">
                                                                <label for="bysim1">BY SIM</label>
                                                            </li>
                                                        </ul>

                                                    </fieldset>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <label for="email_address_2">Select Users</label>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group drop">
                                                            @Html.DropDownList("Userform1", new List<SelectListItem> {
                                  new SelectListItem { Text = "Master Distributor", Value= "Master" } ,
                                   new SelectListItem { Text = "Distributor", Value= "Dealer" } ,
                                 new SelectListItem { Text = "Retailer", Value= "Retailer" },
                                   new SelectListItem { Text = "API User", Value= "API" },
                                       new SelectListItem { Text = "Whitelabel", Value= "Whitelabel" },
                                   },
                                        "Select User", new { @class = "form-control" })
                                                        </div>
                                                    </div>
                                                </div>

                                                <div id="prtno" class="row" style="margin-bottom:0px; margin-top:0px;display:none; ">
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <label for="email_address_2">Port No :</label>
                                                    </div>
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                                        <div class="form-group">
                                                            <div class="lapuno" style="border:1px solid #dddddd;">
                                                                @Html.DropDownList("Lapuno", ViewBag.Lapuno as SelectList, "Select Port No", new { @class = "form-control", required = "required" })

                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="row" id="SelectID">
                                                    <div class="col-md-12 col-sm-12 col-xs-12">
