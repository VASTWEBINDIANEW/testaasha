}

<style>
    /* new css */
    .padding-top-third {
        margin: 0;
        width: auto;
        float: left;
    }

    .res_div {
        width: auto;
        float: right;
    }

    .bread-same-all-page {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
        .bread-same-all-page li {
            float: left;
            margin: 6px 0;
        }

    /* new css */



    .smsapi-pages .smsapi-second .tab-content ul li:first-child {
        width: 26% !important;
        margin-right: 0;
        padding-right: 5px;
    }

    .smsapi-pages .smsapi-second .tab-content ul li:nth-child(2) {
        width: 40%;
        padding-right: 5px;
        margin: 0;
    }

    .input-daterange .input-group-addon {
        min-width: 5px;
        padding: 4px 0px;
    }

    .smsapi-pdf {
        float: right !important;
    }

    .smsapi-pages .left-rowss ul.tabs2 li {
        width: 33.33%;
    }

    .nav-tabs li.active a:hover, .nav-tabs li.active a:active, .nav-tabs li.active a:focus {
        background-color: transparent !important;
        box-shadow: none !important;
    }

    .smsapi-pages .smsapi-first .form-group.drop::after, .sms-priority-modal .arrow::after {
        display: none;
    }

    .smsapi-pages .smsapi-first select {
        z-index: 0;
    }

    #tblshowMasterD .table-bordered tbody tr td button {
        padding: 4px 10px;
        text-align: center;
        margin: auto;
        width: 100%;
        border: 1px solid #bbb;
    }

    .smsapi-pages .smsapi-second .tab-content ul li button i {
        top: 0px;
        font-size: 14px;
        left: 0px;
    }
</style>



<style type="text/css">

    @@keyframes ldio-zdyd6mf6t5 {
        0% {
            top: 96px;
            left: 96px;
            width: 0;
            height: 0;
            opacity: 1;
        }

        100% {
            top: 18px;
            left: 18px;
            width: 156px;
            height: 156px;
            opacity: 0;
        }
    }

    .ldio-zdyd6mf6t5 div {
        position: absolute;
        border-width: 4px;
        border-style: solid;
        opacity: 1;
        border-radius: 50%;
        animation: ldio-zdyd6mf6t5 1s cubic-bezier(0,0.2,0.8,1) infinite;
    }

        .ldio-zdyd6mf6t5 div:nth-child(1) {
            border-color: #e90c59
        }

        .ldio-zdyd6mf6t5 div:nth-child(2) {
            border-color: #46dff0;
            animation-delay: -0.5s;
        }

    .loadingio-spinner-ripple-92ar2pfqk5j {
        width: 200px;
        height: 200px;
        display: inline-block;
        overflow: hidden;
        background: transparent;
    }

    .ldio-zdyd6mf6t5 {
        width: 100%;
        height: 100%;
        position: relative;
        transform: translateZ(0) scale(1);
        backface-visibility: hidden;
        transform-origin: 0 0; /* see note above */
    }

        .ldio-zdyd6mf6t5 div {
            box-sizing: content-box;
        }

    .errorss {
        color: #fff;
        background: red;
        width: 100%;
    }

    .errorss1 {
        color: #fff;
        background: green;
        width: 100%;
    }

    #showinformation .col-md-12, #DIstribotorshowinformation .col-md-12, #Retailershowinformation .col-md-12 {
        border-bottom: 1px solid #bbb;
        margin: 0px 3% !important;
        width: 94%;
        margin-bottom: 6px !important;
        padding: 0px !important;
        padding-bottom: 10px !important;
    }

        #showinformation .col-md-12 button, #DIstribotorshowinformation .col-md-12 button, #Retailershowinformation .col-md-12 button {
            margin-top: 20px;
        }

        #showinformation .col-md-12 label:last-child, #DIstribotorshowinformation .col-md-12 label:last-child, #Retailershowinformation .col-md-12 label:last-child {
            text-align: right;
            font-weight: 800;
        }

    .fund-trasfer-right .tab-content {
        height: 82vh;
    }

    input[type="password"] {
        background-color: transparent;
        border: 1px solid var(--main-bg-lcolor);
        box-shadow: none;
    }

    .fund-trasfer-right .tab-content {
        display: block;
    }
</style>


