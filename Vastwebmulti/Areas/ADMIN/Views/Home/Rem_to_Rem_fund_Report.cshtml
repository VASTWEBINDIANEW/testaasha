@model IEnumerable<Vastwebmulti.Models.Rem_to_rem_fund_transfer>
@{
    ViewBag.Title = "Rem_to_Rem_fund_Report";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }

    .btn-group, .btn-group-vertical {
        box-shadow: none;
    }

    .ppp {
        margin-top: -20px !important;
    }

    .form-inline .bootstrap-select.btn-group, .form-horizontal .bootstrap-select.btn-group, .form-group .bootstrap-select.btn-group {
        height: 29px;
    }
</style><section class="content">
<div class="container-fluid">
<div class="row clearfix">
    <div class="col-md-12">
        @using (Html.BeginForm("Rem_to_Rem_fund_Report", "Home", FormMethod.Post))
        { 
        <div class="card">
            <div class="col-md-7">
                <div class="form-group" style="margin-top:7px;">
                    <ol class="breadcrumb breadcrumb-col-blue-grey" style="margin-left:-10px;margin-top:-4px;">
                        <li class="active" style="color:#9E9E9E; font-size:12px;">FUND&nbsp;RETAILER&nbsp;To&nbsp;RETAILER&nbsp;REPORT&nbsp;></li>
                    </ol>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group" style="margin-bottom:0px;margin-left:14px;">
                    <div class="input-daterange input-group">
                        @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;", autocomplete = "off" })
                        <span class="input-group-addon">
                            <i class="fa fa-exchange"></i>
                        </span>
                        @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;", autocomplete = "off" })
                    </div>
                    <!-- /.input group -->
                </div>
            </div>
            <div class="col-md-2">
                <center>
                    <button type="submit" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left:-59px; height:34px;">
                        <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                        <span style="top:-2px;color:black;">Search</span>
                    </button>
                </center>
            </div>
        </div>
        }
    </div>

</div>

    <div class="row clearfix">
        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-39px;">
            <div class="card">
                <div class="">
                    <h2 id="word" style="color:black; font-size:16px;padding-top:9px; padding-left:22px; font-family:initial;"></h2>
                </div>
                <div class="body" style="margin-top: -18px;padding: 2px;">
                    <div class="table-responsive " style="position:inherit;">
                        <table id="example" class="table table-bordered" style="width:100%;">
                            <thead style="background-color:whitesmoke;">
                                <tr>
                                    <th>From&nbsp;Retailer</th>
                                     <th>Pre&nbsp;Amt</th>
                                    <th>Transfer&nbsp;Amt</th>
                                    <th>Post&nbsp;Amt</th>
                                    <th>To&nbsp;Retailer</th>
                                    <th>Pre&nbsp;Amt</th>
                                    <th>Post&nbsp;Amt</th>
                                    <th>Date</th>
                                    <th>Comment</th>


                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr style="background:no-repeat;">
                                        <td><p style="margin-top:6px;">@item.rem_from</p></td>
                                       <td><p style="margin-top:6px;">@item.rem_from_old_bal</p></td>
                                        <td><p style="margin-top:6px;">@item.value</p></td>
                                        <td><p style="margin-top:6px;">@item.rem_from_new</p></td>
                                        <td><p style="margin-top:6px;">@item.rem_to</p></td>
                                        <td><p style="margin-top:6px;">@item.rem_to_old_bal</p></td>
                                        <td><p style="margin-top:6px;">@item.rem_to_new</p></td>
                                        <td><p style="margin-top:6px;">@item.tran_date</p></td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <div class="btn-group" role="group">
                                                    <button type="button" class="btn btn-default waves-effect dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="true">
                                                        <p style="padding:1px 11px 1px 11px;border:1px solid #dddddd;color:black;">View</p>
                                                    </button>
                                                    <ul class="dropdown-menu ppp">
                                                        @if (item.comment != null && item.comment != "")
                                                        {
                                                            <li>
                                                                <a href="javascript:void(0);" class="waves-effect waves-block" style="border-bottom:1px solid #f1efef;line-height:11px;">
                                                                    @item.comment
                                                                </a>
                                                            </li>
                                                        }
                                                        else
                                                        {
                                                            <li>
                                                                <a href="javascript:void(0);" class="waves-effect waves-block" style="border-bottom:1px solid #f1efef;line-height:11px;">
                                                                    <p style="font-size: 11px;margin-left: 0px;margin-top: 6px;">No Data Found !</p>
                                                                </a>
                                                            </li>
                                                        }

                                                    </ul>

                                                </div>
                                            </div>
                                        </td>

                                    </tr>
                                }
                            </tbody>
                            <tfoot style="background-color:whitesmoke;">
                                <tr>
                                    <td style="font-size:17px;">Total</td>
                                     <td></td>
                                    <td style="font-size:17px;">@Model.Sum(m => m.value)</td>
                                     <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>

                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
</section>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>

<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>

<script>

    $(document).ready(function()
    {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
    });
</script>

<script>
    $(document).ready(function () {
        $('#example').DataTable({
            dom: 'Bfrtip',
            buttons: [
                'copyHtml5',
                'excelHtml5',
                'csvHtml5',
                'pdfHtml5',
                'print'
            ]
        });
    });
</script>