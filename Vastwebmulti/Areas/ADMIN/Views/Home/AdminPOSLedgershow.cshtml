<script>
       $('#RetailerPOSMAINSearch').click(function () {

        $.ajax({
            url: '@Url.Action("POS_Retailer_MAINWallet", "Home")',
            type: 'POST',
            data: { RetailerId: $("#RetailerIdpos").val(), txt_frm_date: $('#txt_frm_date').val(), txt_to_date: $('#txt_to_date').val() },
            success: function (response) {
                $('#RetailerPOSSearchList').html(response);


                }
        })
    })
</script>

<script type="text/javascript">
    $(function () {

        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

        answers();
    });

</script>

<script>
    $("#btnExport").click(function () {
        var RetailerIdpos = $('#RetailerIdpos').val();
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var url = '@Url.Action("ExcelAdminposreport", "Home")?RetailerIdpos=' + RetailerIdpos + '&txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date ;
        location.href = url;
});
</script>
