<script>
    $("#sellerapi").change(function () {
        var val = $(this).val();
           $.ajax({
            url: '@Url.Action("Showsellinfo", "Home")',
            type: "POST",
               data: { Apinm: val },
            cache: false,
               success: function (data2) {
                   $('#saccount').val(data2.AccountNo);
                   $('#sifsc').val(data2.Ifsccode);
            }
        });
    });
</script>
<script>
    function viewcomm() {
        var amt = $('#txtamt').val();
        var reciamt = $('#txtreciveamt').val();
        var commval = parseInt(reciamt) - parseInt(amt);
        var commper = (((parseInt(reciamt) / parseInt(amt)) * 100) - 100).toFixed(2);
        $('#commamt').val(commval);
        $('#percomm').text(commper);
    }
</script>
<script>
    function addbank() {
       var apinm= $('#b_Apinm').val();
       var banknm=  $('#b_Banknm').val();
       var payeenm= $('#b_payeenm').val();
       var accountnm= $('#b_accountnm').val();
       var ifsccode= $('#b_ifsccode').val();
        var comment = $('#b_comment').val();
        var email = $('#b_email').val();
        var phone = $('#b_phone').val();

        $('#Apinm').val(apinm);
        $('#Banknm').val(banknm);
        $('#payeenm').val(payeenm);
        $('#accountnm').val(accountnm);
        $('#ifsccode').val(ifsccode);
        $('#comment').val(comment);
        $('#hideemail').val(email);
        $('#hidephone').val(phone);

        $('#show_Apinm').text(apinm);
        $('#show_Banknm').text(banknm);
        $('#show_payeenm').text(payeenm);

        $('#show_accountnm').text(accountnm);
        $('#show_ifsccode').text(ifsccode);
        $('#show_comment').text(comment);
        $('#show_email').text(email);
        $('#show_phone').text(phone);

            $.ajax({
            url: '@Url.Action("add_purchase_Bank", "Home")',
            type: "POST",
                data: { apinm: apinm },
            cache: false,
                success: function (data2) {
                    $('#post1').hide();
                    $('#post2').show();
                   
                   
            }
        });
    }
</script>

<script>
    function show1(ddd) {
        $('#addmsgshow').text("");
        $('#msgidno').text("");
        $('#b_Banknm').val("");
        $('#b_payeenm').val("");
        $('#b_accountnm').val("");
        $('#b_ifsccode').val("");
        $('#b_comment').val("");
        if (ddd == "add") {
            $('#post2').hide();
            $('#post1').show();
        }
        else {
            $('#post2').hide();
        }
    }
</script>


<script>
    function pay() {
      var sellerapi= $('#sellerapi').val();
      var amt=  $('#txtamt').val();
      var reciveamt=  $('#txtreciveamt').val();
      var saccount=  $('#saccount').val();
        var ifsc = $('#sifsc').val();
        var paymodechk = $('#ddlType').val();
        $('#lblerrorpay').text("");
        if (sellerapi != "" && amt != "") {
            if (amt > 0) {
                $('#spanapinm').text(sellerapi);
                $('#hideapinm').val(sellerapi);
                $('#spanaccount').text(saccount);
                $('#spanifsccode').text(ifsc);
                $('#spanamt').text(amt);

                $('#hideamt').val(amt);
                $('#spanpaymode').text(paymodechk);

                $('#hidepaymode').val(paymodechk);

                $('#spanreciveamt').text(reciveamt);
                $('#hidereciveamt').val(reciveamt);
                
                $('#lblerrorpay').text("");
                $('#divaccountlist').show();
                $('#divaccountlistadd').hide();
            }
            else {
                $('#lblerrorpay').text("Amount Must Be Positive ");
            }
        }
        else {
            if (sellerapi != "") {
                $('#lblerrorpay').text("Select Api Name ");
            }
            else {
                $('#lblerrorpay').text("Enter Any Amount ");
            }
        }
    }
</script>