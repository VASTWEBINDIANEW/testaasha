
<style>
    .add-pur-first {height: auto;min-height: 620px;}
    .purchase-history {height: auto;}
    .add-purchase-page-right {height: 650px;overflow: auto;}

    @@media screen and (max-width:766px){
        .add-pur-first{min-height:inherit;}
    }

</style>

<ul class="add-pur-button">
    <li class="for-list-button">
        <input type="radio" value="value3" name="group1" id="byapi2" checked="" onclick="show1('sell')">
        <label for="byapi2" id="MsgSet">Seller Account List</label>
    </li>
    <li class="for-account-button">
        <input type="radio" value="value4" name="group1" id="bysim2" onclick="show1('add')">
        <label for="bysim2" id="EmailSet">Add Seller Account</label>
    </li>
</ul>
<div id="divaccountlistadd" class="for-account-list input-border-third divacc-third-respon">
    <form>
        <div class="row">
            <div class="col-md-12 only-select-third">
                <label>Select (seller) Party</label>
                @Html.DropDownList("sellerapi", new SelectList(ViewBag.sellerapi, "Value", "Text"), "Select (seller) Party", new { @class = "form-control", data_live_search = "true", @required = "required" })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Account No</label>
                @Html.TextBox("saccount", "", new { @class = "form-control", @required = true, @readonly = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>IFSC Code</label>
                @Html.TextBox("sifsc", "", new { @class = "form-control", @required = true, @readonly = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Enter Transfer Amount</label>
                @Html.TextBox("txtamt", "", new { @type = "number", @class = "form-control", placeholder = "Enter Amount", @required = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Select Pay Mode</label>
                @Html.DropDownList("ddlType", new List<SelectListItem>
                           {
                        new SelectListItem{ Text="IMPS",Value="IMPS"},
                        new SelectListItem{Text="NEFT",Value="NEFT"}
                       }, new { @class = "form-control",@style = "margin-top:0px; padding:0px;text-align:left;" })

            </div>
        </div>

        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Enter Receiving Lapu/API Balance</label>
                @*<input type="text" class="all_fields" />*@
                @Html.TextBox("txtreciveamt", "", new { @type = "number", @class = "form-control", placeholder = "Enter Receiving Amount", @required = true })
                <button type="button" onclick="viewcomm()" style="position: absolute;right: 18px;top: 28px;padding: 3px 10px;color: #000;border:0px;background:#a4a0a0;">View Commission</button>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label>Commission Amount & Ratio</label>
                @Html.TextBox("commamt", "", new { @type = "number", @class = "form-control", @required = true, @readonly = true })
                <button id="percomm" style="position: absolute;right: 18px;top: 28px;padding: 3px 10px;color: #000;border:0px;background:#a4a0a0;">0</button>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 add-pur-bottom button-seconddesign">
                <button id="resetform" type="reset" class="reset btn-second button-third-design">Reset</button>
                <button type="button" class="fullbodydycolorbg btn-first button-third" onclick="pay()"><span style="color:#fff;position:relative;">Pay</span></button>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label id="lblerrorpay" style="color:red;"></label>
            </div>
        </div>
    </form>
</div>
<div id="divaccountlist" class="for-account-list-show" style="display:none;">
    @using (Ajax.BeginForm("_Add_purchase_seller", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "success1", OnFailure = "fail1", UpdateTargetId = "tab-10" }))
    {
        <div class="row">
            <div class="select-border">
                <div class="col-md-6">
                    <span>Api Name</span>
                </div>
                <div class="col-md-6">
                    @Html.Hidden("hideapinm")
                    <span id="spanapinm"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="select-border">
                <div class="col-md-6">
                    <span>Account No</span>
                </div>
                <div class="col-md-6">
                    <span id="spanaccount"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="select-border">
                <div class="col-md-6">
                    <span>IFSC Code</span>
                </div>
                <div class="col-md-6">
                    <span id="spanifsccode"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="select-border">
                <div class="col-md-6">
                    <span>Transfer Amount</span>
                </div>
                <div class="col-md-6">
                    @Html.Hidden("hideamt")
                    <span id="spanamt"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="select-border">
                <div class="col-md-6">
                    <span>Pay Mode</span>
                </div>
                <div class="col-md-6">
                    @Html.Hidden("hidepaymode")
                    <span id="spanpaymode"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="select-border">
                <div class="col-md-6">
                    <span>Receiving Amount</span>
                </div>
                <div class="col-md-6">
                    @Html.Hidden("hidereciveamt")
                    <span id="spanreciveamt"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <span>Transition  Password</span>
                @Html.Password("txtpaass", "", new { placeholder = "Enter Transition  Password", @style = "border: 1px solid #bbb;margin-bottom:10px;margin-top:10px; height: 32px;width: 100%;float: left;padding: 0px 10px;" })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 add-pur-bottom">

                <button type="submit" class="fullbodydycolorbg for-account-list-hide">Pay</button>

            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label id="msgpurchasemanual" style="color:red;"></label>
            </div>
        </div>
    }
</div>
<div id="post1" class="for-seller-account input-border-third divacc-third-respon" style="display:none;">
    <form>
        <div class="row">
            <div class="col-md-12 only-select-third">
                <label>Select Api Name</label>
                <div class="select-purchase">
                    @Html.DropDownList("b_Apinm", new SelectList(ViewBag.apinm, "Value", "Text"), "Select Api Name", new { @class = "form-control", data_live_search = "true", @required = "required" })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Bank Name</label>
                @Html.TextBox("b_Banknm", "", new { @class = "form-control", placeholder = "Enter Bank Name", @required = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Payee Name</label>
                @Html.TextBox("b_payeenm", "", new { @class = "form-control", placeholder = "Enter Payee Name", @required = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Account Number</label>
                @Html.TextBox("b_accountnm", "", new { @class = "form-control", placeholder = "Enter Account Number", @required = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Ifsc Code</label>
                @Html.TextBox("b_ifsccode", "", new { @class = "form-control", placeholder = "Enter IFSC Code", @required = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Api User EmailId</label>
                @Html.TextBox("b_email", "", new { @class = "form-control", placeholder = "Enter Email Id", @required = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Api User Phone Number</label>
                @Html.TextBox("b_phone", "", new { @class = "form-control", placeholder = "Enter Phone", @required = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Comment</label>
                @Html.TextArea("b_comment", "", new { @class = "form-control", placeholder = "Enter Comment", @required = true })
