        </div>
        <div class="row">
            <div class="col-md-12 add-pur-bottom" style="margin-top:15px;">
                <button class="button-third" type="button" onclick="addbank()">Add Seller Account</button>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label id="msgidno" style="color:red;"></label>
            </div>
        </div>
    </form>
</div>
<div id="post2" class="for-seller-account1" style="display:none;">
    @using (Ajax.BeginForm("_Add_purchase", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "success", OnFailure = "fail", UpdateTargetId = "tab-8" }))
    {
        <div class="row">
            <div class="col-md-12">
                <label>Api Name</label>
                <div class="select-purchase">
                    @Html.Hidden("Apinm")
                    <label id="show_Apinm"></label>

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label>Bank Name</label>
                @Html.Hidden("Banknm")
                <label id="show_Banknm"></label>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <label>Payee Name</label>
                @Html.Hidden("payeenm")
                <label id="show_payeenm"></label>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label>Account Number</label>
                @Html.Hidden("accountnm")
                <label id="show_accountnm"></label>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label>Ifsc Code</label>
                @Html.Hidden("ifsccode")
                <label id="show_ifsccode"></label>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label>Comment</label>
                @Html.Hidden("comment")
                <label id="show_comment"></label>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label>Email</label>
                @Html.Hidden("hideemail")
                <label id="show_email"></label>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label>Phone</label>
                @Html.Hidden("hidephone")
                <label id="show_phone"></label>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label>Comment</label>
                @Html.Hidden("comment")
                <label id="show_comment"></label>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label>Enter OTP</label>
                @Html.TextBox("OTP", "", new { @class = "form-control", placeholder = "Enter OTP", @required = true })
            </div>
        </div>
