
@{
    Layout = null;
}
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.2.1/jquery.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
<!DOCTYPE html>
<html lang="">
<body>
    <div style="width:100%; height:100px;">
        <div style="float:left;">
            <div><span style="font-size:25px; ">vastwebmulti </span></div>
            <div><span style="font-size:18px;">Retailer Name :   </span> </div>
            <div> <span style="font-size:18px; ">Retailer Mobile :  </span></div>
            <div> <span style="font-size:18px; ">Address :   </span></div>
            <div> <span style="font-size:18px; ">Payment Date :  </span></div>
        </div>
        <div style="float:right;">
            <img src="@Context.Server.MapPath("~/Images/Logo.png")" alt="PayNowRecharge" />
        </div>
    </div>
    <br /><br />
    <div style="background-color:Black;">
        <center>
            <h1 style="color:White; ">BILL PAYMENT RECEIPT  </h1>
        </center>
    </div>
    <div style="height:40px;">
        <div style="float:left;">
            <span style="font-size:18px; ">Receipt No :  </span>
        </div>
        <div style="float:right;">
            <span style="font-size:18px; "> Date :@DateTime.Now </span>
        </div>
    </div>
    <table class="table" style="margin-top:40px;">
        <tr>
            <th>Sr No.</th>
            <th>  Consumer  </th>
            <th> Operator</th>
            <th> Amount </th>
            <th> OperatorId</th>
            <th>Recharge Date</th>
            <th>Total</th>


        </tr>

        <tr>
            <td>1</td>
            <td>NA</td>
            <td>NA</td>
            <td>NA</td>
            <td>NA</td>
            <td>NA</td>
            <td>NA</td>

        </tr>


    </table>
    <div>
        <div style="float:left;">
            <div style="font-size:14px; font-weight:bold;">  <span>Customer Signature</span></div>
            <div>
                <img src="@Context.Server.MapPath("~/Images/Signature.png")" alt="SIGNATURE" style="margin-top:20px;" />
            </div>
        </div>
        <div style="float:right;">
            <div style="font-size:14px; font-weight:bold;"> Retailer Signature</div>
            <div> <img src="@Context.Server.MapPath("~/Images/Signature.png")" alt="SIGNATURE" style="margin-top:20px;" /> </div>
        </div>
    </div><br /><br />
    <div style="margin-top:100px;">
        <center>
            <span style="font-size:18px; padding-bottom :40px;">THIS IS A COMPUTER GENERATED RECEIPT HENCE DOES NOT REQUIRE ANY SEAL AND SIGNATURES.</span>
        </center>
    </div>

    <div style="margin-top:30px;">
        <center>
            <span style="font-size:22px; font-weight:bold;"> Thanks for using PayNowRecharge</span>
        </center>
    </div>

</body>
</html>
