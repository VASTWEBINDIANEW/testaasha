<script type="text/javascript">
    function val() {
        var masterid = document.getElementById("DealerId").value;
        var dlmnm = document.getElementById("retailename1").value;
        var tel = document.getElementById("Mobile1").value;
        var pin = document.getElementById("Pincode1").value;
        var state1 = document.getElementById("State1").value;
        var dist1 = document.getElementById("District1").value;
        if (dlmnm == "" || tel == "" || pin == "" || state1 == "" || dist1 == "Select District" || masterid == "") {
            if (masterid == "") {
                $('#DealerId').css('border-color', 'red');
                return false;
            }
            if (dlmnm == "") {
                $('#DealerId').css('border-color', 'green');
                $('#retailename1').css('border-color', 'red');
                return false;
            }
            else if (state1 == "") {
                $('#DealerId').css('border-color', 'green');
                $('#retailename1').css('border-color', 'green');
                $('#State1').css('border-color', 'red');
                return false;
            }
            else if (District1 == "Select District") {
                $('#DealerId').css('border-color', 'green');
                $('#retailename1').css('border-color', 'green');
                $('#State1').css('border-color', 'green');
                $('#District1').css('border-color', 'red');
                return false;
            }
            else if (tel == "") {
                $('#DealerId').css('border-color', 'green');
                $('#retailename1').css('border-color', 'green');
                $('#State1').css('border-color', 'green');
                $('#District1').css('border-color', 'green');
                $('#Mobile1').css('border-color', 'red');
                return false;
            }
            else if (tel.length > 10) {
                $('#DealerId').css('border-color', 'green');
                $('#retailename1').css('border-color', 'green');
                $('#State1').css('border-color', 'green');
                $('#District1').css('border-color', 'green');
                $('#Mobile1').css('border-color', 'red');
                return false;
            }
            else if (tel.length < 10) {
                $('#masterid').css('border-color', 'green');
                $('#dealername1').css('border-color', 'green');
                $('#State1').css('border-color', 'green');
                $('#District1').css('border-color', 'green');
                $('#Mobile1').css('border-color', 'red');
                return false;
            }
            else if (pin == "") {
                $('#masterid').css('border-color', 'green');
                $('#dealername1').css('border-color', 'green');
                $('#State1').css('border-color', 'green');
                $('#District1').css('border-color', 'green');
                $('#Mobile1').css('border-color', 'green');
                $('#Pincode1').css('border-color', 'red');
                return false;
            }
        }
        else {
            $('#masterid').css('border-color', 'green');
            $('#dealername1').css('border-color', 'green');
            $('#State1').css('border-color', 'green');
            $('#District1').css('border-color', 'green');
            $('#Mobile1').css('border-color', 'green');
            $('#Pincode1').css('border-color', 'green');
            return true;
        }
    }
</script>

