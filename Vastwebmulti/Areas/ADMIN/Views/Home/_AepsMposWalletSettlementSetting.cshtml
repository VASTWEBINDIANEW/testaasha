@model List<Vastwebmulti.Areas.ADMIN.Models.AepsMposSettlemtSettingModel>

  @if (Model[0].IsDirect == true)
  {
    <a onclick="UpdateStatus('@Model[0].Idno',event)" style="text-decoration:none;margin-left:62px;" href="#"><i class="icofont icofont-toggle-on" style="color:green; font-size:40px;margin-left:-7px;" title="Setting Status"></i></a>
  }
  else
  {
    <a onclick="UpdateStatus('@Model[0].Idno',event)" style="text-decoration:none;margin-left:62px;" href="#"><i class="icofont icofont-toggle-off" style="color:red;font-size:40px;margin-left:-7px;" title="Setting Status"></i></a>
  }

 