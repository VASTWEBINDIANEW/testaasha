<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script src="~/Swalalert/sweetalert-dev.js"></script>
<script>
            function val() {
                var vv = document.querySelector('input[name="group"]:checked').value;
                var url = '@Url.Action("Outercolorchange", "Home")?color=' + vv + '';
                location.href = url;
            }
</script>

<script>
    $(document).ready(function () {

        var insidecol = '@ViewBag.insidecolor'
        if (insidecol != "" && insidecol != null) {
            $('input:radio[name="group"][value=' + insidecol + ']').prop('checked', true);
        }

        var first = '@ViewData["first"]';
        var second = '@ViewData["second"]';
        if (first != "" && second != "") {
           $("#color1").val(first);
            $("#color2").val(second);
            $("#txtcolor").val(first);
            $("#txtcolor1").val(second);
        }
        var selected = '@ViewData["selected"]';
        var menu = '@ViewData["menu"]';
        if (selected != "" && menu != "") {
            $("#colorselect").val(selected);
            $("#txtMenucolor").val(selected);
            $("#colormenu").val(menu);
            $("#txtMenucolor1").val(menu);
        }

        var color = '@TempData["default"]'
        $('input:radio[name="group"][value=' + color + ']').prop('checked', true);
    });

    var succ = '@TempData["success"]';
    if (succ != null && succ != "") {
        if (succ.includes("successfully")) {
            swal("Good job!", succ, "success");
        }
        else {
            swal("Oops!", succ, "error");
        }
        
    }
</script>

<script>
    function updateColor(element, color) {
        var hexColor = '@ViewData["first"]';
        if (color) hexColor = color.toHexString();
        $(element).css("color", hexColor);
        alert(hexColor);
    }
</script>

<script>
    function funMenu() {
        var color = document.getElementById("colorselect").value;
        $("#txtMenucolor").val(color);
        var color = document.getElementById("colormenu").value;
        $("#txtMenucolor1").val(color);
    }
</script>
<script>
    function SaveMenucolor() {
        var vv = $("#txtMenucolor").val();
        var col = $("#txtMenucolor1").val();
        vv = vv.replace('#', "");
        col = col.replace('#', "");
        var url = '@Url.Action("OuterMenuColor", "Home")?selected=' + vv + '&menu=' + col + '';
        location.href = url;
    }
</script>


<script>
    function fun() {
        var col = document.getElementById("color1").value;
        $("#txtcolor").val(col);
        var col = document.getElementById("color2").value;
        $("#txtcolor1").val(col);
    }
</script>
<script>
    function Savecolor() {
        var vv = $("#txtcolor").val();
        var col = $("#txtcolor1").val();
        vv = vv.replace('#', "");
        col = col.replace('#', "");
        var url = '@Url.Action("Outercolorchange", "Home")?first=' + vv + '&second='+ col + '';
        location.href = url;
    }
</script>
