                            <div class="outside-inside-color">
                                <h2 style="color:white; font-size:16px;padding-top:11px; padding-left:22px;padding-bottom:9px;background:linear-gradient(to right,@ViewData["first"],@ViewData["second"]);">
                                    HEADER THEME COLOR
                                </h2>
                            </div>

                            <div class="body">
                                <div class="row">
                                    <div class="col-md-5">
                                        <div class="form-group" style="border:1px solid #dddddd;">
                                            <div class="input-group">
                                                <div class="input-group-addon colorpicker-element" style="background:#dddddd; color:#000000b8;border:1px solid #dddddd;padding-top:7px;border-radius:0px;">
                                                    <label>&nbsp;HEX CODE&nbsp;</label> <input type="color" id="color1" value="#ff0000">
                                                </div>
                                                <input type="text" id="txtcolor" name="txtcolor" class="form-control" autocomplete="off" style="border:1px solid #dddddd;padding-left:9px; height:45px;">
                                                <div class="input-group-addon" style="padding-top:0px;">
                                                    <button type="button" id="btn" onclick="fun()" class="btn  waves-effect" style="height:45px; margin:0px -12px -6px -5px;border-radius:0px;border:1px solid #c7c2c2;background:#dedddd;">&nbsp;Set Color</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-5">
                                        <div class="form-group" style="border:1px solid #dddddd;">
                                            <div class="input-group">
                                                <div class="input-group-addon colorpicker-element" style="background:#dddddd; color:#000000b8;border:1px solid #dddddd;padding-top:7px;border-radius:0px;">
                                                    <label>&nbsp;RGB CODE&nbsp;</label> <input type="color" id="color2" value="#ff0000">
                                                </div>
                                                <input type="text" id="txtcolor1" name="txtcolor1" class="form-control" autocomplete="off" style="border:1px solid #dddddd;padding-left:9px; height:45px;">
                                                <div class="input-group-addon" style="padding-top:0px;">
                                                    <button type="button" id="btn" onclick="fun()" class="btn  waves-effect" style="height:45px; margin:0px -13px -6px -5px;border-radius:0px;border:1px solid #c7c2c2;background:#dedddd;">&nbsp;Set Color</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-2">
                                        <br />
                                        <button type="button" id="btn" name="btnsave" onclick="Savecolor()" class="btn outer-w-save btnssl special-iii" style="margin-top:-19px;height:45px;border:1px solid #c7c2c2;background:#dedddd;" data-loading-text="<i class='fa fa-spinner fa-spin'></i>">Save Color</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row clearfix">
                    <div class="col-md-12" style="margin-top:-59px; margin-bottom:30px;">
