@model IEnumerable<Vastwebmulti.Models.select_rem_pur_order_Result>
@{
    ViewBag.Title = "Retailer_showpurchase";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style>

    /*   new css    */

    #Retailerpurchasetable {
        width: 100%;
        float: left;
        margin-top: 5px;
    }
    .table_menu {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .input-daterange input {
        width: 115px !important;
        text-align: end !important;
    }
    .res_div {
        width: auto !important;
    }

    /*   new css    */


    .dropdown-menu {
        margin-top: 81px !important;
    }

    .tablemargin-master tr td p {
        margin-bottom: 0px;
    }

    .tablemargin-master tr td, .tablemargin-master tr th {
        padding-top: 8px !important;
        padding-bottom: 8px !important;
    }
    .custom-date-icon {
        border-color: #d4d1d1 !important;
    }

    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:991px){

        .res_div {
            float: left;
        }

        .search-after-third input {
            width: 100px !important;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }


    @@media only screen and (max-width:767px) {

        .table_menu {
            display: block;
        }
        .t_menu {
            width: 100%;
            float: left;
            padding: 4px 0;
        }

        
        .show-master-purchase .col-md-4 {margin: 5px 0px;}

        .table-responsive > .table-bordered > thead > tr > th:first-child, .table-responsive > .table-bordered > tbody > tr > td:first-child {
            border-left: 1px solid var(--border-color);
        }


    }

    @@media only screen and (max-width:480px){

        .res_div {
            width: 100% !important;
            padding: 0px !important;
            margin: 2px 0;
        }
        .search-after-third input {
            width: 100% !important;
        }
        .input-daterange input {
            width: 100% !important;
        }
    }


</style>
<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>Retailer Show Purchase</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Wallet-Q&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Retailer Show Purchase</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card showpurchase-thirddesign-header" style="margin-bottom:5px;">
                    <div class="row" style="margin: 0;">
                        <div class="col-md-7 page-header-third res_div1" style="width: auto; float: left;">
                            <div>
                                @Html.Partial("_menupurchase")
                            </div>
                        </div>
                        <div class="col-md-5 page-header-third res_div1" style="width: auto; float: right;">

                                <div style="float:right; " class="web-white-filter lop">

                                    <input type="button" id="btnExport" value="Export" style="margin-left: 0px; padding: 0px 4px; height: 32px; border: 1px solid #b1a6a638; background: #b1a6a638; background-image: url(../../images/reportimage/xls.png); background-repeat: no-repeat; background-position: 4px center; padding-left: 20px; font-size: 13px;">
                                    <input type="button" id="btnPDF" value="PDF" style="margin-left: 2px; padding: 0px 4px; height: 32px; border: 1px solid #b1a6a638; background: #b1a6a638; background-image: url(../../images/reportimage/pdf.png); background-repeat: no-repeat; background-position: 4px center; padding-left: 19px; font-size: 13px;">

                                </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>


        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card page-header-third">

                    <div class="table_menu">

                        <div class="t_menu">
                            <ul class="" style="float: left; margin: 0; display: flex; align-items: center;">
                                <li class="smli">
                                    <a href="@Url.Action("Dashboard", "Home")" class="fullbodydycolorbg tmw-total-color-one">
                                        Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                                    </a>
                                </li>
                                <li class="fullbodydycolorbg tmw-total-color-one">
                                    Retailer_showpurchase
                                </li>

                            </ul>
                        </div>


                        <div class="t_menu">
                            @*@using (Html.BeginForm("Retailer_showpurchase", "Home", FormMethod.Post))*@
                            @using (Ajax.BeginForm("SearchFilterPurchaseRequest", "Home", new AjaxOptions { HttpMethod = "POST", InsertionMode = InsertionMode.Replace, UpdateTargetId = "Retailerpurchasetable" }))

                            {
                                <div class="row show-master-purchase" style="margin: 0;">
                                    <div class="for-search tablesearch-second res_div" style="position:static;float:left;width:18%;padding-right: 5px;">
                                        <div class="search-after-third">
                                            <input id="myInput" type="text" name="myInput" placeholder="Search..." onkeyup="myFunction()" style="height: 32px; border: 1px solid #ccc; padding: 5px 8px;width:100%;" />
                                        </div>
                                    </div>

                                    <div class="col-md-6 res_div" style="padding:0px;width:40%;">
                                        <div class="form-group" style="margin-bottom:0px;">
                                            <div class="input-daterange input-group">
                                                <div class="custom-date-icon ner" style="border-color:#d4d1d1;">
                                                    <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true" style="left:5px;"></i>
                                                </div>
                                                @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;text-align:right;", autocomplete = "off" })
                                                <span class="input-group-addon" style="padding:0px;min-width:5px;">

                                                </span>
                                                <div style="position:relative;">
                                                    <div class="custom-date-icon ner" style="border-color:#d4d1d1;">
                                                        <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true" style="left:5px;"></i>
                                                    </div>
                                                    @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;text-align:right;", autocomplete = "off" })
                                                </div>
                                            </div>
                                            <!-- /.input group -->
                                        </div>
                                    </div>

                                    <div class="col-md-2 res_div" style="padding:0px 5px;">
                                        <center>
                                            <button type="submit" class="btn waves-effect" style=" height:32px;border:1px solid #c7c2c2;">
                                                <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                                <span style="top:-2px;color:black;">Search</span>
                                            </button>
                                        </center>
                                    </div>



                                </div>
                            }
                        </div>

                    </div>


                    <div id="Retailerpurchasetable" class="tablefourdesign-admin" style="">

                        @Html.Partial("_Retailer_showpurchasePartail", Model)

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="modal fade" id="myModal" role="dialog">
    <div class="modal-dialog">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header" style="position:initial;background-color:whitesmoke;">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title" style="color:black;">Enter Comment</h4>
            </div>
            @*@using (Html.BeginForm("updatepurchage_Retailer", "Home", FormMethod.Post))*@
            @using (Ajax.BeginForm("updatepurchage_Retailer", "Home", new AjaxOptions { HttpMethod = "POST", InsertionMode = InsertionMode.Replace, UpdateTargetId = "Retailerpurchasetable", OnSuccess = "Successhidmodel" }))
            {
                <div class="modal-body">
                    <input type="text" id="id" name="id" class="form-control" style="display:none;" />
                    <input type="text" id="type" name="type" class="form-control" style="display:none;" />
                    <input type="hidden" id="HD_frm_date" name="HD_frm_date" value="0" />
                    <input type="hidden" id="HD_to_date" name="HD_to_date" value="0" />
                    <input type="password" autocomplete="new-password" id="txthighsec" name="txthighsec" class="form-control" required placeholder="Enter Transection Password" /><br />
                    <textarea id="txtcomment" name="txtcomment" class="form-control" required="" placeholder="Enter Comment"></textarea>
                    <label id="errormsgshow"></label>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-right: 12px; height:34px;">
                        <span style="top:-2px;color:black;">Save Change</span>
                    </button>
                    <button type="button" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left: -3px; height:34px;" data-dismiss="modal">
                        <span style="top:-2px;color:black;">Close</span>
                    </button>
                </div>

            }

        </div>

    </div>
</div>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
