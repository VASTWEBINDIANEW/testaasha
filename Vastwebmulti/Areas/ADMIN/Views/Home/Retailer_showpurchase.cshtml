<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script>
    function Successhidmodel() {
        $('#myModal').modal('hide');
    }



</script>

<script>
$(document).ready(function(){

     $('.input-daterange').datepicker({
                format: "yyyy-mm-dd",
                todayHighlight: true,
                autoclose: true,
                orientation: "bottom auto",

            });
            var val = '@ViewBag.chk';
            if (val != "post") {
                $("#txt_frm_date").datepicker("setDate", new Date());
                $("#txt_to_date").datepicker("setDate", new Date());
            }

          var message = '@ViewData["successorder"]';
        if (message != "" && message != null) {
            swal("Good job!", message, "success");

        }
        var errormessage = '@ViewData["failedorder"]';
        if (errormessage != "" && errormessage != null) {
            swal("Oops!", errormessage, "error");

        }
    });
</script>
<script type="text/jscript">
    $(function () {
        var data = '@ViewData["show"]';
        if (data != "") {
            sweetAlert("Oops...", data, "error");
        }
        })


</script>



<script>
    function funin(idno, status) {
        var answer = confirm("ARE YOU SURE?")
        if (answer) {
            var id = $('#id').val(idno);
            var txtfrm = $('#txt_frm_date').val()
            var txtto = $('#txt_to_date').val();
            var type = $('#type').val(status);
            $('#myModal').modal('show');
            var txtcomment = $('#txtcomment').val();
            var type = $('#type').val();
            var id = $('#id').val();
            $('#HD_frm_date').val(txtfrm);
            $('#HD_to_date').val(txtto);
            return true;
        }
        else {
            return false;
        }
    }
</script>

<script>
    $("#btnExport").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var url = '@Url.Action("ExcelRetailerReport", "Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date ;
        location.href = url;
});
</script>

<script>
    $("#btnPDF").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var url = '@Url.Action("PDFRetailer_showpurchase", "Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date ;
        window.open(
url,
  '_blank' // <- This is what makes it open in a new window.
);
    });
</script>
<script>
    $(document).ready(function () {
        $("#myInput").on("keyup", function () {

            var value = $(this).val().toLowerCase();
            $("#body  tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });
    });
</script>