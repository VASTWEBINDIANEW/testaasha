        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
        answers();

    });
    $(document).ajaxComplete(function () {
        ravi("select").select2();
    });
</script>

