@model Vastwebmulti.Areas.ADMIN.ViewModel.Microatmdeviceadd
@{
    ViewBag.Title = "MicroAtm_Device_info";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.1/css/toastr.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.1/js/toastr.js"></script>
<style>

    /* new css */
    .retailerList_Page .left-tabs form {
        background: #fff;
    }
    .custom-table-responsive, #EmailHistory {
        background: #fff !important;
    }
    .bread-same-all-page {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }


    /* new css */


    .btn-group, .btn-group-vertical {
        box-shadow: none;
    }
    .toast-top-right1 {top: 65px;left: 81%;}
    .dropdown {position: relative;display: inline-block;}
    .dropdown-content {
        display: none;position: absolute;background-color: #f9f9f9;min-width: 160px;
        box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);padding: 12px 16px;z-index: 1;
    }
    .dropdown:hover .dropdown-content {display: block;}
    .for-search {position: absolute;right: 130px;}
    .for-search input {width: 250px;border: 1px solid #dbdbdb;padding: 3px 10px;}
    section.content {background-color: white;margin: 75px 0px 0 164px;}
    a.addnewbuttonemploy-admin {
        background: var(--main-bg-lcolor);width: auto;height: 28px;display: inline-block;float: right;
        text-align: center;padding: 4px 13px;border: 1px solid #555;color: #fff;margin-left: 10px;
    }
    .custom-date-icon i{left:4px;}
    .retailerList_Page .left-tabs form {border:0px;}
    .retailerList_Page .select2-container--default .select2-selection--single .select2-selection__arrow {
        display: block;
    }
    .select2addnew .select2.select2-container.select2-container--default{
        float:left;
        width: 150px !important;
    }

    @@keyframes microatmspin111 {
        0% {
            transform:rotate(0deg);
        }
        100% {
            transform:rotate(360deg);
        }
    }

    .editbutton-spinclass {
        width: 15px;height: 15px;border: 2px solid #aaa4a4;border-top-color: rgb(170, 164, 164);
        border-radius: 50%;border-top-color: transparent;animation: microatmspin111 2s linear infinite;display:none;
        float:left;
    }


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media screen and (max-width:766px) {
        .newemployee-admin .left-tabs ul li {width: 100%;float: left;}
        .for-search.search-after-third {
            position: static;width: 100%;float: left;margin-bottom: 10px;
        }
        .for-search.search-after-third input {width: auto;}
    }

    @@media only screen and (max-width:395px) {
        .for-search.search-after-third input {width: 100%;margin-bottom: 10px;}
        .for-search.search-after-third a {margin: 0;width: 100%;}
    }
</style>
