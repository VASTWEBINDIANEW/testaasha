                            <a href="@Url.Action("Microatm_charge_list", "Home")" style=" margin-left: 0px; font-size: 11px; float: left; padding: 0px 4px; height: 32px; border: 1px solid #b1a6a638; background: #b1a6a638; font-size: 14px; color: #555; display: flex; align-items: center; position: relative; height: 29px; top: -1px;">Charge List</a>

                        </div>
                        <div class="web-white-filter pdfexpoer-second pdf-third-design" style="float: right;position:static;width:auto;padding-left:3px;">
