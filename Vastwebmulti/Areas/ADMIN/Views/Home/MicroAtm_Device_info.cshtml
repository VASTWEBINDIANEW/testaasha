        <!--////-->
        <div class="row clearfix" style="margin-bottom:40px;">
            <div class="col-md-4 col-sm-4 col-xs-12">
                <div class="page-header-third left-tabs width100 float-left">
                    <ul class="tabs width100 float-left">
                        <li class="tab-link current" style="width:100%;float:left;" data-tab="tab-9"><img src="~/images/reportimage/add-user-button.svg" alt="add user" class="create-add-image">Create Device info</li>
                    </ul>
                    <div id="tab-9" class="tab-content current custom-table-responsive" style="height:75vh !important;">
                        @using (Ajax.BeginForm("Insert_microAtm_deviceinfo", new AjaxOptions { HttpMethod = "Post", UpdateTargetId = "devicelist_tbl", LoadingElementId = "div-loader" }))
                        {
                        <div class="left-four-tabs width100 float-left">
                            <div class="row clearfix">
                                <div class="col-md-12 col-sm-12 col-xs-12">
                                    <label for="email_address_2">Retailer ID</label>
                                    <div class="form-group">
                                        <div class="">
                                            @Html.DropDownList("Remid", (IEnumerable<SelectListItem>)ViewBag.remid, "Select Retailerid", new { @class = "form-control", required = "required" })
                                        </div>
                                    </div>
                                </div>
                            </div><!--.row-->
                            <div class="row clearfix">
                                <div class="col-md-12 col-sm-12 col-xs-12">
                                    <label for="email_address_2">Device Name </label>
                                    <div class="form-group">
                                        <div class="">

                                            @Html.DropDownList("deviceid", (IEnumerable<SelectListItem>)ViewBag.deviceid, "Select deviceid", new { @class = "form-control", required = "required" })

                                        </div>
                                    </div>
                                </div>
                            </div><!--.row-->

                            <div class="row clearfix">
                                <div class="col-md-12 col-sm-12 col-xs-12">
                                    <label for="email_address_2">Plan Name </label>
                                    <div class="form-group">
                                        <div class="">
                                            @Html.DropDownList("plannm", (IEnumerable<SelectListItem>)ViewBag.planchk, "Select PlanName", new { @class = "form-control", required = "required" })
                                        </div>
                                    </div>
                                </div>
                            </div><!--.row-->
                            <div class="row clearfix">
                                <div class="col-md-12 col-sm-12 col-xs-12">
                                    <label for="email_address_2">Plan Charge Type </label>
                                    <div class="form-group">
                                        <div class="">
                                            @Html.DropDownList("chargetype", new List<SelectListItem>
                                             {
                                              new SelectListItem{ Text="Daily",Value="Daily"},
                                                  new SelectListItem{Text="Monthly",Value="Monthly"}
                                              }, new { @class = "form-control", required = "required" })

                                        </div>
                                    </div>
                                </div>
                            </div><!--.row-->

                            <div class="row clearfix">
                                <div class="col-md-12 col-sm-12 col-xs-12">
                                    <label for="email_address_2">Start Date </label>
                                    <div class="form-group">

                                        <div class="input-daterange input-group">
                                            <div class="custom-date-icon ner" style="border-color:#aaa !important;">
                                                <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                            </div>
                                            @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #aaa !important; height: 32px !important;text-align:left;padding-left:38px;", autocomplete = "off" })

                                        </div>

                                    </div>
                                </div>
                            </div><!--.row-->
                            <div class=" width100 float-left">
                                <div id="lblSuccess">
                                    <label id="lblmsg1" class="danger" style="color:#fff;font-size: 16px;background: green;width: 96%;margin-bottom:5px;"></label>
                                </div>
                                <div id="lblerror">
                                    <label id="lblmsg" class="danger" style="color:#fff;font-size: 16px;background: red;width: 96%;margin-bottom:5px;"></label>
                                </div>
                                <button type="submit" class="btn pull-right fullbodydycolorbg insert-errorshow" style="margin-left:15px;color:#fff;border-color:transparent;margin-right: 15px;margin-top:5px;">Insert Device</button>
                                <button type="reset" class="btn pull-right" style="margin-top:5px;">Reset</button>
                            </div>
                            <label id="error-mictigit"></label>
                        </div>
                        }
                    </div>
                </div>

            </div>
            <div class="col-md-8 col-sm-8 col-xs-12">
                <div class="page-header-third right-tabs width100 float-left">
                    <div class="table-responsive custom-table-responsive tablefourdesign-admin" style="height:80vh !important;" id="devicelist_tbl">
                        @Html.Action("Get_allDeviceList")
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="div-loader" style="display:none; position: fixed;top: 0px;background: rgba(0,0,0,.5);left: 0px;bottom: 0px;right: 0px;width: 100%;height: 100vh;z-index: 9999;">
        <div id="loader" style="position: absolute;right: 34%;top: 50%;display:block; transform: translate(-34%,-50%);">
            <div class="loadingio-spinner-ripple-92ar2pfqk5j" style="background:transparent;">
                <div class="ldio-zdyd6mf6t5">
                    <div></div><div></div>
                </div>
            </div>
        </div>
    </div>
</section>
