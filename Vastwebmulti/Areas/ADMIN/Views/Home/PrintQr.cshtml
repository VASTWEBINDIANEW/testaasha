@using Vastwebmulti.Models;

@model Vastwebmulti.Areas.ADMIN.Models.QRCODE_Details
@{
    ViewBag.Title = "PrintQr";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style>
    .select2-container--default .select2-selection--single {
        border-radius: 0px !important;
    }

    .select2-container .select2-selection--single {
        height: 32px !important;border-color: #ccc !important;
    }

    .qrall-search-admin .select2.select2-container {width: 64% !important;float: left;padding-right: 6px;}
    .qrall-search-admin input#btnsubmit {padding: 0px 5px !important;border: 1px solid var(--border-color);width: auto;height: 32px !important;}

    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }


    @@media screen and (max-width:766px){
        .print-tab-third {width: 100%;float: left;}
        .print-tab-third ul li {
           margin: 0;padding-right: 4px;
        }
        .print-tab-third ul li button {width: 100%;float: left;}
       .print-qr-top-third .print-qr-top-in {
            width: 100%;float: left;margin-right: 0 !important;margin-bottom: 10px !important;
        }
        .print-qr-top-third .print-qr-top-in .print-qr-second {text-align: center;}
    }

    @@media screen and (max-width:500px){
        .print-tab-third ul li {width: 50% !important;}

        .qrall-search-admin .select2.select2-container {
            width: 100% !important;
        }
        .page-header-third .qrall-search-admin {
            width: 100% !important;
            padding: 0;
            margin-top: 4px;
        }



    }

</style>
@{ 
    VastwebmultiEntities db = new VastwebmultiEntities();
    var acticeapi = db.UPI_API.SingleOrDefault();
}
<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>Print QR Code</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                @*<li><a href="javascript:void(0);">Report's&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>*@
                <li><a href="javascript:void(0);">Print QR Code</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-12 print-tab-third">
                <ul class="upi-print-button">
                    <div class="page-header-third" style=" width: auto; float: left;">
                    <li class="active">
                        <button>Retailer</button>
                    </li>
                    <li>
                        <button>Master Distributor</button>
                    </li>
                    <li>
                        <button>Distributor</button>
                    </li>
                    <li>
                        <button>Api User</button>
                    </li>
                    <li>
                        <button>White Label</button>
                    </li>
            </div>
            <div class="page-header-third" style=" width: auto; float: right;">
                <li style="float:right;">
                    <button class="fullbodydycolorbg" onclick="print()" style="font-size:18px;padding:2px 12px;color:#fff;">
                        <img src="~/AdminDesign/images/tracking.svg" style="width:15px;margin-top:-2px;" />&nbsp;Print
                    </button>
                </li>
                @if (@acticeapi.APIID == "PAYU")
                {
                    <li style="float:right;">
                        <button class="fullbodydycolorbg" onclick="Delete()" style="font-size:18px;padding:2px 12px;color:#fff;">
                            <img src="~/MainFrontDesign/images/delete.svg" style="width:15px;margin-top:-2px;" />&nbsp;Delete
                        </button>
                    </li>
                }
                <li style="float:right;">
                    <button><i class="fa fa-check-square" aria-hidden="true" style="color:var(--main-bg-lcolor);"></i>&nbsp;Select All</button>
                </li>
                <li class="qrall-search-admin" style="float:right;">
                    @using (Html.BeginForm("PrintQr", "Home", FormMethod.Post))
                    {
                        @Html.DropDownList("RetailerList", (IEnumerable<SelectListItem>)ViewBag.allretailer, "Select Retailer", new { id = "RetailerDDL", @class = "for-select2 form-control", data_live_search = "true", @style = "border:1px solid #8e7f7f4d;height:38px;-webkit-appearance: none;" })

                        <input type="submit" id="btnsubmit" name="btnsubmit" value="SEARCH" style="padding: 5px 12px; border: 1px solid var(--border-color);" />
                        @*<button>Search</button>*@
                    }
                </li>
                <li style="float:right;width:20%;">


                    @*<select>
                    <option>select Usert</option>
                    <option>select Usert</option>
                </select>*@
                </li>
                </div>
                </ul>
            </div>
        </div>
        <div class="">
            <div class="col-md-12 page-header-third">
                <div class="print-qr-top print-qr-top-third">
                    @foreach (var item in Model.QRDetails)
                    {
                        <div class="print-qr-top-in">
                            <div class="print-qr-check">
                                <div class="print-qr-check-one">
                                    <input type="checkbox" id="@item.userid" name="sport" value="@item.userid">
                                    <label for="@item.userid"></label>
                                </div>
                            </div>
                            <div class="print-qr">
                                <div class="print-qr-first">
                                    <div class="print-qr-first-left">
                                        <img src="~/AdminDesign/images/bhim-upi.png" />
                                    </div>
                                    <div class="print-qr-first-right">
                                        <img src="../..@Model.logoimage" />

                                        @* <img src="~/Outside_logo/ab08fc1a-2d8e-48b6-b521-6344043d564b_24onlinelogo.png" />*@
                                    </div>
                                </div>
                                <div class="print-qr-third">
                                    <span style="width:10%;float:left;"><img src="~/AdminDesign/images/retail.svg" style="width:18px;" /></span>
                                    <span style="width:90%;float:right;text-align:right;">@item.firmname</span>
                                    <span style="width:10%;float:left;"><img src="~/AdminDesign/images/qr-codes.svg" style="width:18px;" /></span>
                                    <span style="width:90%;float:right;text-align:right;">@item.MerchantVPA</span>
                                    <span style="width:10%;float:left;"><img src="~/AdminDesign/images/call.svg" style="width:18px;" /></span>
                                    <span style="width:90%;float:right;text-align:right;">@item.Mobile</span>

                                </div>
                                <div class="print-qr-second">
                                    <p>Accepted Here All UPI Payments</p>
                                    <img src="@Url.Content(item.QRCODE)" />
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
<link href="~/select2/dist/css/select2.css" rel="stylesheet" />
<script src="~/select2/dist/js/select2.min.js"></script>

<script>
    function print() {
       var favorite = [];
            $.each($("input[name='sport']:checked"), function(){
                favorite.push($(this).val());
            });

        if (favorite != "") {
            var url = '@Url.Action("Print_QR","Home",new { useriddata = "__param__" })';
            url = url.replace('__param__', favorite);
             window.open(url, '_blank');
        }

                @*$.ajax({
                    url: '@Url.Action("Print_QR","Home")',
                    type: 'GET',
                    data: { useriddata: favorite },
                    success: function (response) {

                        //$('#RemTbl').html(response);

                    }
                });*@
        //});
        //    alert(favorite.join(", "));
    }

        function Delete() {
       var favorite = [];
            $.each($("input[name='sport']:checked"), function(){
                favorite.push($(this).val());
            });

        if (favorite != "") {
            var url = '@Url.Action("Delete_QR","Home",new { useriddata = "__param__" })';
            url = url.replace('__param__', favorite);
             window.open(url, '_blank');
        }
    }
</script>

<script>
    $('select').select2();
</script>

