
@{
    ViewBag.Title = "Add_purchase";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}

<style>
    /*  new css */
    .add-pur-first {
        background: #fff;
    }

    .add-purchase-page-right {
        background: #fff;
    }

    .bread-same-all-page {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    /*  new css */

    .select2-container--default .select2-selection--single {
        border-radius: 0px !important;
    }

    .select2-container .select2-selection--single {
        height: 32px !important;
        border-color: #bbb !important;
    }

    .table-bordered thead tr th {
        padding: 5px 10px;
    }

    .purchase-historyheightclass {
        height: auto !important;
    }

    .height-classnewadmin select {
        height: 32px !important;
    }

    .inputnumber-arrownone input[type="number"] {
        -webkit-appearance: none;
        -moz-appearance: textfield;
    }

    .addpurchase-pageadmin .add-purchase-page-right ul {
        display: flex;
    }

        .addpurchase-pageadmin .add-purchase-page-right ul li:last-child {
            border-right: 0px;
        }

    .addpurchase-pageadmin .addpurchase-firstclass ul {
        display: flex;
    }

        .addpurchase-pageadmin .addpurchase-firstclass ul li {
            width: 50% !important;
            float: left;
        }

    .height-classnewadmin select {
        padding-left: 2px;
    }


    @@media screen and (max-width:1366px) {
        .forminput-third .height-classnewadmin {
            width: 23%;
        }

        .forminput-third .tablesearch-third {
            width: 15%;
        }

        .forminput-third .col-md-4 {
            width: 39%;
        }

        .tablesearch-third button {
            background: #fff;
        }
    }


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:991px) {
        .forminput-third {
            float: left;
            width: 100%;
        }

        #idseller_id {
            float: left;
            width: 100%;
        }

        .forminput-third .height-classnewadmin {
            width: 50%;
            float: left;
            margin-bottom: 5px;
        }

        .forminput-third .col-md-4 {
            width: 100%;
            float: left;
        }

        .tablesearch-third {
            float: left;
            margin: 6px 0;
            width: 30%;
        }

        .forminput-third .nrr3 {
            width: 100%;
            float: left;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media screen and (max-width:766px) {
        .forminput-third .height-classnewadmin {
            width: 50%;
            float: left;
            margin-bottom: 5px;
        }

        .forminput-third .col-md-4 {
            width: 100%;
            float: left;
        }

        .tablesearch-third {
            float: left;
            margin: 6px 0;
            width: 30%;
        }

        .forminput-third .nrr3 {
            width: 100%;
            float: left;
        }

        .clear-thirddesign {
            clear: both !important;
        }

        .divacc-third-respon {
            clear: both;
        }

        .addpurchase-third {
            width: 100%;
            float: left;
            margin-bottom: 15px;
        }

        .addpurchase-pageadmin .addpurchase-firstclass {
            margin-top: 5px;
        }

        .addpurchase-pageadmin table {
            border-left: 1px solid #aaa4a4 !important;
        }

        .addpurchase-pageadmin .addpurchase-firstclass .add-pur-first {
            height: auto;
        }

        .addpurchase-pageadmin .add-purchase-page-right .purchase-history {
            height: auto;
        }

        .addpurchase-pageadmin .add-purchase-page-right {
            height: auto;
        }

            .addpurchase-pageadmin .add-purchase-page-right .table-responsive {
                height: auto !important;
            }
    }

    @@media screen and (max-width:420px) {
        .forminput-third .tablesearch-third {
            width: 40%;
        }

        .bread-same-all-page {
            display: block;
        }

        .res_div {
            width: 100% !important;
            float: left !important;
            padding: 2px 0 !important;
        }
    }

    @@media screen and (max-width:360px) {
        .tab-third-design-respo li {
            font-size: 12px;
        }
    }
</style>
<section class="content add-purchase-page fourdesign-section-admin">
    <div class="container-fluid addpurchase-pageadmin">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>Add Purchase</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Account 2&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Add Purchase</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="page-header-third pageheader-margin-third">
            <div class="bread-same-all-page breadsameall-second" style="width:100%;float:left;">
                <ul class="padding-top-third four-noneclass-admin-only res_div" style="width: auto; float: left; margin: 0;">
                    <li class="smli">
                        <a href="~/ADMIN/Home" class="fullbodydycolorbg tmw-total-color-one">
                            Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;">
                        </a>
                    </li>
                    <li class="fullbodydycolorbg tmw-total-color-one" style="line-height: 22px;">
                        Add Purchase
                    </li>
                </ul>
                <div class="col-md-2 tre4 pdf-lastclass-third widthautposit-third-respon res_div" style="padding: 0;width:auto;float:right;">
                    <div class="white-l-search-nine pdfexpoer-second totalbutton-secondclas">
                        <div class="web-white-filter" style="float: right;">
                            <input type="button" id="btnExportA" value="Export" style="margin-left:0px;font-size: 14px;float: left; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;" />
                            <input type="button" id="btnPDFA" value="PDF" style="margin-left:2px;font-size: 14px;float: left; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;" />
                            <button class="white-success-button" style="height:32px;font-size:14px;padding: 0px 4px;height: 32px;border: 1px solid #b1a6a638;float: left;margin-left: 2px;background: #b1a6a638;" onclick="findtotalA()">Total</button>
                        </div>
                    </div>
                </div>

            </div>
        </div>


        <div class="row clearfix">
            <div class="col-md-4 addpurchase-third addpurchase-firstclass">
                <div class="left-first-tabs width100 float-left Masterlist-page page-header-third">
                    <ul class="tabs width100 float-left tab-seconddesign tab-third-design ulli-width-third">
                        <li class="tab-link current" data-tab="tab-5">+ Purchase</li>
                        @*<li class="tab-link" data-tab="tab-6">+ Manualy Purchase</li>*@
                        <li class="tab-link" data-tab="tab-7">
                            <img src="~/AdminDesign/images/productivity.svg" style="width:17px;" /> Schedule
                        </li>
                    </ul>
                    <div class="add-pur-first inputnumber-arrownone">
                        <div id="tab-5" class="tab-content current">
                            @Html.Action("_Add_purchase")
                        </div>
                        <div id="tab-7" class="tab-content input-border-third beforenone-third">
                            @Html.Action("_Scheduler_add")
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="add-purchase-page-right page-header-third">

                    <ul class="tabs3 width100 float-left tab-seconddesign ulflex-second ulflex-third tab-third-design tab-third-design-respo">
                        <li class="tab-link current3" data-tab="tab-8">Bank Info</li>
                        <li id="tab9" class="tab-link" data-tab="tab-9">Schedule Details</li>
                        <li id="tab10" class="tab-link" data-tab="tab-10">Seller Fund</li>

                    </ul>
                    <div id="tab-8" class="tab-content3 current3">
                        @Html.Action("_add_Purchase_Bank")
                    </div>
                    <div id="tab-9" class="tab-content3">
                        @Html.Action("_Scheduler_History")
                    </div>
                    <div id="tab-10" class="tab-content3">
                        <div class="purchase-history purchase-history-second purchase-historyheightclass">

                            <div class="col-md-12 padding-none-second select-design-second colmd-second-padd forminput-third" style="margin-bottom:10px;padding:0px;">
                                @using (Ajax.BeginForm("_Seller_fund", "Home", new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "idseller_id" }))
                                {
                                    <div class="col-md-2 height-classnewadmin" style="padding-left: 0; padding-right: 5px;">
                                        @Html.DropDownList("SearchApinm", new SelectList(ViewBag.apinm11, "Value", "Text"), "Select Api Name", new { @class = "form-control", data_live_search = "true" })

                                    </div>
                                    <div class="col-md-2 height-classnewadmin" style="padding-left: 0; padding-right: 5px;">
                                        @Html.DropDownList("Searchsts", new List<SelectListItem>
                                                 {
                                                    new SelectListItem{Text="Success", Value="Success"},
                                                    new SelectListItem{Text="Failed", Value="Failed"},
                                                    new SelectListItem{Text="Pending", Value="Pending"}
                                                 }, "Select Status", new { @class = "form-control", data_live_search = "true" })
                                    </div>
                                    <div class="col-md-4" style="padding-left: 0; padding-right: 5px;">
                                        <div class="input-daterange input-group" style="margin-left:0px;width:100%;">
                                            <div class="custom-date-icon ner" style="border-color:#ccc !important;">
                                                <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                            </div>
                                            @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #ccc; height:32px;" })
                                            <span class="input-group-addon" style="padding: 0px !important;min-width: 3px;">

                                            </span>
                                            <div class="nrr3">
                                                <div class="custom-date-icon ner2" style="border-color:#ccc !important;">
                                                    <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                                </div>
                                                @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #ccc; height:32px;" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 tablesearch-third" style="padding-left: 0; padding-right: 5px;">
                                        <button class="input-back-second" style="width:100%;float:left;height:32px;border:1px solid #ccc;">Search</button>
                                    </div>
                                }
                            </div>
                            <div class="col-md-12 padding-none-second padding-top-secondclass clear-thirddesign" id="idseller_id" style="padding:0px;">
                                @Html.Action("_Seller_fund")
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<link href="~/select2/dist/css/select2.css" rel="stylesheet" />
<script src="~/select2/dist/js/select2.min.js"></script>

<script>
    $('.for-select').select2();
</script>
<script type="text/javascript">
    $(document).ready(function () {
        $('ul.tabs li').click(function () {
            var tab_id = $(this).attr('data-tab');
            $('ul.tabs li').removeClass('current');
            $('.tab-content').removeClass('current');
            $(this).addClass('current');
            $("#" + tab_id).addClass('current');
        })
    });
</script>

<script>
    $('.for-list-button').click(function () {
        $('.for-seller-account').hide();
        $('.for-account-list').show();
        $('.for-account-list-show').hide();
    });

    $('.for-account-button').click(function () {
        $('.for-seller-account').show();
        $('.for-account-list').hide();
        $('.for-account-list-show').hide();
    });

    $('.for-account-list-hide').click(function () {
        $('.for-account-list-show').show();
        $('.for-account-list').hide();
    });

    $('.reset').click(function () {


        $('.all_fields').val('');

    });
</script>

<script type="text/javascript">
    $(document).ready(function () {

        $('ul.tabs3 li').click(function () {
            var tab_id = $(this).attr('data-tab');

            $('ul.tabs3 li').removeClass('current3');
            $('.tab-content3').removeClass('current3');

            $(this).addClass('current3');
            $("#" + tab_id).addClass('current3');
        });

    })
</script>
@*<script src="https://jonthornton.github.io/Datepair.js/dist/datepair.js"></script>
    <script src="https://jonthornton.github.io/Datepair.js/dist/jquery.datepair.js"></script>*@
<script type="text/javascript">
    $(document).ready(function () {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true
        });
        var val = '';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
    });
</script>

