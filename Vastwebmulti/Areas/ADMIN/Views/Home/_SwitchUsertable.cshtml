@model Vastwebmulti.Areas.ADMIN.ViewModel.SwitchUserModel
@if (Model.ShowSwitch_DealerTOMD != null)
{
     int i = 1;
    <div class="table-responsive " style="width:100%;">
       
        <table id="tbldata" data-hrefscroll="@Url.Action("InfiniteScrollSwitchuser","Home",new { Utype="dealer"})" class="table table-bordered table-striped table-hover third-design-table">
            <thead>
                <tr style="background:#f9f9f9;">
                   
                    <th>Distributor&nbsp;Firm</th>
                    <th>Name</th>
                    <th>Old M/D</th>
                    <th>Current M/D</th>
                    <th>Switch Date</th>

                </tr>
            </thead>
            @foreach (var item in Model.ShowSwitch_DealerTOMD)
            {
                <tbody class="body">
                    <tr data-toggle="modal" data-target="#m-d-fund-transfer" class="tr">
                        
                        <td>@item.FarmName</td>
                        <td>@item.DealerName</td>
                        <td>@item.old</td>
                        <td>@item.curr</td>
                        <td>@item.SwitchDate</td>

                    </tr>
                </tbody>
             
            }
        </table>
    </div>

}

@if (Model.ShowRetailerDealerSwitch_Result != null)
{
  int i =1;
    <div class="table-responsive " style="width:100%;">
        <table id="tbldata" data-hrefscroll="@Url.Action("InfiniteScrollSwitchuser","Home",new { Utype="Retailer"})" class="table table-bordered table-striped table-hover third-design-table">
            <thead>
                <tr style="background:#f9f9f9;">
                    @*<th>S.R.</th>*@
                    <th>Retailer&nbsp;Firm</th>
                    <th>Name</th>
                    <th>Old Distributor</th>
                    <th>Current Distributor </th>
                    <th>Switch Date</th>

                </tr>
            </thead>


            @foreach (var item in Model.ShowRetailerDealerSwitch_Result)
            {
                <tbody class="body">
                    <tr data-toggle="modal" data-target="#m-d-fund-transfer" class="tr">
                        @*<td>@i+1</td>*@
                        <td>@item.Frm_Name</td>
                        <td>@item.RetailerName</td>
                        <td>@item.old</td>
                        <td>@item.curr</td>
                        <td>@item.SwitchDate</td>

                    </tr>
                </tbody>
            }


          
        </table>
    </div>
}


<script>
    $('.third-design .third-design-table tbody td').mouseenter(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'var(--main-bg-rcolor)');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#fff');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'var(--main-bg-rcolor)');
    });

    $('.third-design .third-design-table tbody td').mouseleave(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'transparent');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#333');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'transparent');
    });
</script>