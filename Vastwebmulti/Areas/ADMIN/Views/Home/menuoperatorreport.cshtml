<style>
    #ul {
        list-style-type: none;
        margin: 0;
        padding: 0;
        overflow: hidden;
        /*background-color: #e91e63;*/
    }

        #ul li {
            float: left;
           margin-right:2px;
        }

            #ul li a {
                display: block;
                text-align: center;
                padding: 5px 5px;
                text-decoration: none;
                border: 1px solid #b1a6a638;
                position: initial;
            }

                #ul li a:hover:not(.activee) {
                    background-color: #FFC107;
                    color: black;
                    border: 1px solid #b1a6a6;
                }

    .activee {
        /*background-color: #000000;*/
        color: white;
        margin-bottom:0px;
    }

    .bartu a img {
    width: 12px;
    float:none;
    margin-top: -2px;
}
    .kklo #custnav ul li a.activee.navbar {
   background-image: linear-gradient(to right , var(--main-bg-lcolor), var(--main-bg-rcolor)) !important;
}
    .kklo #custnav ul li a img.ddise{display:none;}
    .kklo #custnav ul li a.activee.navbar img.ddise{display:inline-block;}
    .kklo #custnav ul li a.activee.navbar img.ddis{display:none;}
      
</style>

<div class="kklo">
    <div id="custnav" style="">
        <ul id="ul">
            <li class="bartu"><a href="~/ADMIN/Home/Operator_report_new"><img class="ddis" src="~/ashok-images/glob2.svg" /><img class="ddise" src="~/ashok-images/glob.svg" />&nbsp;Live</a></li>
            @*<li><a href="~/ADMIN/Home/Recharge_Report">User&nbsp;TXN</a></li>*@
            <li class="bartu"><a href="~/ADMIN/Home/Incoming"><img class="ddis" src="~/ashok-images/sim2.svg" /><img class="ddise" src="~/ashok-images/sim.svg" />&nbsp;Incoming</a></li>
            
            <li class="bartu"><a href="~/ADMIN/Home/Roffer_history"><img class="ddis" src="~/ashok-images/roffr.svg" /><img class="ddise" src="~/ashok-images/roffer.svg" />&nbsp;R-Offer</a></li>

            </ul>
    </div>
</div>
<script src="~/Scripts/jquery-1.10.2.min.js"></script>
<script>
    $(document).ready(function () {
        var current = location.pathname;
        $('#custnav li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('activee');
                $this.addClass('navbar');
            }
        })
    });
</script>
