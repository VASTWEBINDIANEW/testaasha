<style>
    #ul {
        list-style-type: none;
        margin: 0;
        padding: 0;
        overflow: hidden;
        /*background-color: #e91e63;*/
    }

        #ul li {
            float: left;
            background: #fff;
            margin-right: 2px;
        }

            #ul li a {
                display: block;
                text-align: center;
                padding: 5px 10px;
                text-decoration: none;
                border: 1px solid #b1a6a638;
                position: initial;
                color: #9E9E9E;
            }

                #ul li a:hover:not(.activee) {
                    background-color: #FFC107;
                    color: black;
                    border: 1px solid #ddd;
                }

    #custnav {
        border-bottom: 8px solid green;
        padding-bottom: 15px;
        margin-right: -30px;
    }

    #ul li a.activee {
        color: #fff;
        /*background-image: linear-gradient(to right, var(--main-bg-lcolor), var(--main-bg-rcolor)) !important;*/
        background: var(--main-bg-lcolor);
    }


    .activee {
        background-color: #f5f5f5;
        color: #000;
    }

        .activee:hover {
            color: #000;
            border: 1px solid #00000026;
            border: 1px solid #000000;
        }

    @@media only screen and (max-width:520px) {
        #custnav {
            border-bottom: 0px;
            padding-bottom: 5px;
            margin-right: 0px;
        }

            #custnav #ul li {
                width: 49%;
                margin-bottom: 2px;
            }
    }
</style>

<div id="custnav" style="padding-top:0px;">
    <ul id="ul">
        <li><a href="~/ADMIN/Home/All_Retailer_Status">Retailer&nbsp;Status</a></li>
        <li><a href="~/ADMIN/Home/All_Dealer_Status">Distributor&nbsp;Status</a></li>
        <li><a href="~/ADMIN/Home/All_MD_Status">M/D&nbsp;Status</a></li>
        <li><a href="~/ADMIN/Home/All_Api_Status">API&nbsp;Users</a></li>


    </ul>
</div>

<script src="~/Scripts/jquery-1.10.2.min.js"></script>
<script>
    $(function () {
        var current = location.pathname;
        $('#custnav li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('activee');
                $this.addClass('navbar');
            }
        })
    });
</script>
