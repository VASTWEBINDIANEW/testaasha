<script type="text/javascript">

    function SaveAll(type) {
        var optCode = []
        document.querySelectorAll('#' + type + ' input').forEach(el => {
            if (el.checked)
                optCode.push(el.value + ',Y')
            else
                optCode.push(el.value + ',N')
        })

        var MsgType = "Message's";

            document.getElementById("loadermoney").style.display = "block";

            var whats_code = optCode.filter(s => s.search('whatsapp_') != -1);
            var optCode = optCode.filter(s => s.search('whatsapp_') == -1);

            $.ajax({
                type: "POST",
                url: '@Url.Action("SMSSettingSave", "Home")',
                data: { 'ch': optCode, whats_code, MsgType: MsgType },
                cache: false,
                dataType: 'json',
                async: true,
                success: function (data) {
                    var pp = data.status;
                    var mm = data.Message;

                    document.getElementById("loadermoney").style.display = "none";
                    if (pp == "Success") {

                        $.ajax({
                            type: "GET",
                            url: '@Url.Action("Check_UnchekSMS_Setting", "Home")',
                            cache: false,
                            dataType: 'html',
                            async: true,
                            success: function (data) {
                                var obj = JSON.parse(data);
                                for (var item in obj) {
                                    var sts = obj[item].Status;
                                    var name = obj[item].ServiceName;
                                    var whatsapp_sts = obj[item].Whatsapp_Status;

                                    if (sts == "Y") {
                                        $("#" + name + "").prop("checked", true);
                                    }
                                    if (whatsapp_sts == "Y") {
                                        $('#whatsapp_' + name).prop("checked", true);
                                    }
                                }
                            }
                        });

                        ToastrMessage();
                        toastr.success(mm);
                    }

                    else {
                        ToastrMessage();
                        toastr.error(mm);
                    }

                }
            });
            return true;

             $(".sweet-alert").css('background', '@PageData["globalCol"]');
    }
</script>

