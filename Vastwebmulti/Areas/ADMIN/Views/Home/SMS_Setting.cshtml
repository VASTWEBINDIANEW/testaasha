<style type="text/css">
    .loadermoney {
        position: fixed;
        left: 0px;
        top: 0px;
        width: 100%;
        height: 100%;
        z-index: 199999;
        /*background: url('../../images/smsload.gif') 50% 50% no-repeat rgba(249, 249, 249, 0.9);*/
        background: url('../../img/loder.gif') 50% 50% no-repeat rgba(249, 249, 249, 0.9);
    }

    [type="checkbox"].filled-in:not(:checked) + label:after {
        background-color: #f5f5f5;
        border: 2px solid #dddddd;
    }

    .smsapi-pages .smsapi-second .tab-content ul li:first-child {
        width: 34% !important;
    }

    .tab-content fieldset.for-outbox {
        margin-top: 0px !important;
    }

    .for-outbox li {
        width: 50% !important;
    }

    .for-outbox ul {
        padding: 0px !important;
    }

    .tab-content fieldset.for-outbox [type="radio"] + label {
        margin-bottom: 0px;
        margin-top: 2px;
    }

    .for-outbox [type="radio"]:checked + label::after {
        background-color: var(--main-bg-lcolor);
        border-color: var(--main-bg-lcolor);
    }

    .toast-top-right1 {
        top: 65px;
        left: 81%;
    }

    [type="checkbox"].filled-in:checked.chk-col-red + label::after {
        border: 2px solid var(--main-bg-lcolor);
        background-color: var(--main-bg-lcolor);
    }

    ul.smssetting-top li button {
        border: 1px solid #bbb;
        height: 32px !important;
        padding: 0;
    }

        ul.smssetting-top li button span {
            top: -1px !important;
        }

    ul.smssetting-top li {
        padding-left: 0;
        margin-right: 0 !important;
    }

    ul.smssetting-top li {
        width: 25%;
        float: right;
        padding: 0px 10px
    }

    [type="checkbox"].filled-in:checked + label::before {
        top: -1px;
        left: 0px;
    }

    [type="checkbox"].filled-in:checked + label::after {
        top: 0;
        width: 18px;
        height: 18px;
    }

    [type="checkbox"].filled-in:not(:checked) + label::after {
        height: 18px;
        width: 18px;
    }

    .smsapi-pages .smsapi-second .tab-content ul li button i {
        top: 1px;
        font-size: 20px;
        left: -3px;
    }

    .smsapi-pages .smsapi-second ul.tabs li:last-child button {
        position: absolute;
        top: 3px;
        right: 3px;
        padding: 3px 16px;
    }

    .smsapi-pages .smsapi-second .tab-content#tab-3 ul li {
        width: 24% !important;
        display: inline-block;
        float: none;
        padding-right: 0;
    }

    .for-message .card {
        background: transparent;
    }

    .for-message {
        width: 100%;
        float: left;
        background: var(--second-bg-color);
        padding: 0px 10px;
    }

    .custom-table-responsive, #EmailHistory {
        height: 78vh !important;
    }

    .smssetting-top {
        padding: 5px 0 0px 0px !important;
        background: #f5f5f5;
    }
</style>
