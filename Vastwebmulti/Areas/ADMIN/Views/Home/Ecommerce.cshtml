    <script>
        $('.in-category').click(function () {
            $('.for-category').fadeIn();
            $('.for-sub-category').fadeOut();
        });

        $('.category-top-close').click(function () {
            $('.for-category').fadeOut();
        });


          $('.in-sub-category').click(function () {
              $('.for-category').fadeOut();
              $('.for-sub-category').fadeIn();
        });

        $('.sub-category-top-close').click(function () {
            $('.for-sub-category').fadeOut();
        });
    </script>

    <script>

    $(function()
    {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
    });
    </script>


<script>
    $('.for-edit').click(function () {
        $(this).closest('tr').find('input').removeAttr('readonly');
        $(this).next('.for-save').css('display', 'block');
        $(this).css('display', 'none');
  
  });

    $('.for-delete').click(function () {
        $(this).css('display', 'none');
        $(this).next('.for-sure').css('display', 'block');

  });
    
</script>


