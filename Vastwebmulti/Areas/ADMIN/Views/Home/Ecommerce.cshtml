    /* new css  */



    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
        .ecomm-table-top ul li.two {
            width: 50%;
            margin-bottom: 5px;
        }
        .ecomm-table-top ul li.one {
            width: 50%;
            margin-bottom: 5px;
        }
        .ecomm-table-top ul li.first {
            width: 100%;
        }
        .ecomm-table-top ul li.three {
            width: 90%;
        }
        .ecomm-table-top ul li select, .for-category ul li select {
            width: 98%;
        }


    }

    @@media only screen and (max-width:480px){

        .ecomm-table-top ul li.three {
            width: 100%;
        }
        .ecomm-table-top ul li.four {
            width: 11%;
            margin-top: 5px;
        }

