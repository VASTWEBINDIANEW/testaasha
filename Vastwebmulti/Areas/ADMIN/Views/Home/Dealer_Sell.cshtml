                <div id="tblshowMasterD" class=" table-responsive tableseconddes-admin" style="width:100%;">
                    <table class="table table-bordered table-striped table-hover third-design-table">
                        <thead>
                            <tr style="background: #eae9e9" ;>
                                <th>Farm Name</th>
                                <th>Operator</th>
                                <th>Sell Commission</th>
                                <th>Date/Modify</th>
                                <th>Approval Status</th>
                                <th>Approved Date</th>
                                <th>Action</th>

                            </tr>
                        </thead>
                        <tbody id="addcommbody">

                            @if (ViewBag.sellercomm != null)
                            {
                                foreach (dynamic item in ViewBag.sellercomm)
                                {
                                    var stscolor = "";
                                    var img = "";
                                    if (item.GetType().GetProperty("adminapproval_sts").GetValue(item, null) == "Pending")
                                    {
                                        stscolor = "#FF9800";
                                        img = "../../ashok-images/clkk.png";
                                    }
                                    if (item.GetType().GetProperty("adminapproval_sts").GetValue(item, null) == "Approved")
                                    {
                                        stscolor = "green";
                                        img = "../../ashok-images/correct.svg";
                                    }
                                    if (item.GetType().GetProperty("adminapproval_sts").GetValue(item, null) == "Rejected")
                                    {
                                        stscolor = "red";
                                        img = "../../ashok-images/closes.svg";
                                    }

                                    <tr class="tr">

                                        <td><p style="margin-top:6px;"> @item.GetType().GetProperty("FarmName").GetValue(item, null)</p></td>
                                        <td><p style="margin-top:6px;"> @item.GetType().GetProperty("operator_Name").GetValue(item, null)</p></td>
                                        <td><p style="margin-top:6px;"> @item.GetType().GetProperty("sellcomm").GetValue(item, null)</p></td>
                                        <td><p style="margin-top:6px;"> @item.GetType().GetProperty("insertdate").GetValue(item, null)</p></td>
                                        <td> <img src=@img style="width: 20px;background:@stscolor;border-radius: 50%;padding: 3px;">&nbsp; @item.GetType().GetProperty("adminapproval_sts").GetValue(item, null)</td>
                                        <td><p style="margin-top:6px;"> @item.GetType().GetProperty("adminapproval_date").GetValue(item, null)</p></td>
                                        <td>
                                            <div class="row">
                                                @if (item.GetType().GetProperty("adminapproval_sts").GetValue(item, null) == "Pending")
                                                {


                                                    <div class="col-md-12">
                                                        <button type="button" name="type" onclick="return funin('@item.GetType().GetProperty("idno").GetValue(item, null)','APP')" style="background-color: transparent; color: black; border: none; margin-top: 0px;">
                                                            <i class="fa fa-check" style="top:1px;border: 1px solid #c7c2c2;padding: 3px;font-size: 10px;" aria-hidden="true"></i>
                                                        </button>

                                                        <button type="button" name="type" onclick="return funin('@item.GetType().GetProperty("idno").GetValue(item, null)','REJ')" style="background-color: transparent; color: black; border: none; margin-top: 0px;">
                                                            <i class="fa fa-times" style="top:1px;border: 1px solid #c7c2c2;padding: 3px 4px;font-size: 10px;" aria-hidden="true"></i>
                                                        </button>
                                                    </div>

                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }


                        </tbody>
