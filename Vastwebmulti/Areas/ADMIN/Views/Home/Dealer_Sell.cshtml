<script>
    $(function () {
        $("#myInput").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            $("#addcommbody .tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });
    });
</script>

<script>
    function Editmode(id) {

          $.ajax({
              url: '@Url.Action("Seller_CommissionChangeByID", "Home")',
              data: {id:id},
              success: function (data) {
                  $('#addcommbody').html(data);
            }
        });
    }

</script>

<script>
    function funin(idno, status) {
        var answer = confirm("ARE YOU SURE?")
        if (answer) {
            var id = $('#id').val(idno);
            var type = $('#type').val(status);
            $('#myModal').modal('show');
            var type = $('#type').val();
            var id = $('#id').val();
            return true;
        }
        else {
            return false;
        }
    }

       var message = '@ViewData["successorder"]';
            if (message != "" && message != null) {
                swal("Good job!", message, "success");

            }
            var errormessage = '@ViewData["failedorder"]';
            if (errormessage != "" && errormessage != null) {
                swal("Oops!", errormessage, "error");

            }
</script>
