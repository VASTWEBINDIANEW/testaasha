<script>
    $(document).ready(function () {

        var color = "#fff";
        var msgcolor = '@ViewBag.colors';
        if (msgcolor != "") {
            color = msgcolor;
        }
        $("input[name='radio'][value='" + color + "']").prop('checked', true);
      });
</script>
<script type='text/javascript'>
    $("input[type='radio']").click(function(){
        var radioValue = $("input[name='radio']:checked").val();
            if(radioValue){
                $.ajax({
                    url: '@Url.Action("AddColor","Home")',
             type: 'POST',
             data: {ColorCode:radioValue},
             success: function (response) {
                 if (response === 'Success') {
                     ToastrMessage();
                     toastr.success('Logo Background Color Select.');
                 }
                 else {
                     ToastrMessage();
                     toastr.success('Transparent Color Select.');
                 }

                    }
                });
            }
        });
</script>
