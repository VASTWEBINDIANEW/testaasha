<script>
    function SaveSocialAc() {
        var social = $('#ddlSocial').val();
        if (social != "") {
            var txt = $('#urlLink').val();
        var re = /(http(s)?:\\)?([\w-]+\.)+[\w-]+[.com|.in|.org]+(\[\?%&=]*)?/
        if (re.test(txt)) {
            $.ajax({
                type: "GET",
               url: '@Url.Action("Social_Media", "Home")',
                    data: { socialType: $('#ddlSocial').val(), link: $('#urlLink').val() },
                success: function (response) {

                var i = 0;
                var mdtblHtml = "";
                $.each(response, function (a, b) {
                    mdtblHtml += "<tr><td>" + b.FooterType + "</td>";
                    mdtblHtml += "<td>" + b.FooterLink + "</td>";
                    mdtblHtml += "<td>" + '<button onclick="delSocialAc('+b.Id+')"><img src="../../MainFrontDesign/images/delete.svg" style="width:16px;"></button>' + "</td>";
                    i++;
                });
                $('#social-list > tbody').html(mdtblHtml);
                }

            });
            }
            else {
            alert('Not a Valid Url !');
        }
        }

        else {
            alert('Select Social Account Type');
        }
    }
</script>
<script>
    function delSocialAc(e) {
        if (e != "") {
            $.ajax({
                type: "POST",
                url: '@Url.Action("delfooterlink", "Home")',
                data: { Id: e },
                dataType: 'json',
                cache: false,
                success: function (response) {
                var i = 0;
                var mdtblHtml = "";
                $.each(response, function (a, b) {
                    mdtblHtml += "<tr><td>" + b.FooterType + "</td>";
                    mdtblHtml += "<td>" + b.FooterLink + "</td>";
                    mdtblHtml += "<td>" + '<button onclick="delSocialAc('+b.Id+')"><img src="../../MainFrontDesign/images/delete.svg" style="width:16px;"></button>' + "</td>";
                    i++;
                });
                $('#social-list > tbody').html(mdtblHtml);
                }

            });
        }
        else {
            alert('');
        }
    }
</script>


<script>
    function SaveBadge() {
        var Badge = $('#ddlBadges').val();
        if (Badge != "") {
            var txt = $('#BadgeLink').val();
        var re = /(http(s)?:\\)?([\w-]+\.)+[\w-]+[.com|.in|.org]+(\[\?%&=]*)?/
        if (re.test(txt)) {
            $.ajax({
                type: "GET",
               url: '@Url.Action("BadgeMedia", "Home")',
                    data: { BadgeType: $('#ddlBadges').val(), Badgelink: $('#BadgeLink').val() },
                success: function (response) {

                var i = 0;
                var BadgeHtml = "";
                $.each(response, function (a, b) {
                    BadgeHtml += "<tr><td>" + b.BadgeType + "</td>";
                    BadgeHtml += "<td>" + b.Url_Link + "</td>";
                    BadgeHtml += "<td>" + '<button onclick="delBadge('+b.Id+')"><img src="../../MainFrontDesign/images/delete.svg" style="width:16px;"></button>' + "</td>";
                    i++;
                });
                $('#Badge-list > tbody').html(BadgeHtml);
                }

            });
            }
            else {
            alert('Not a Valid Url !');
        }
        }

        else {
            alert('Select Badge Type');
        }
    }
</script>
<script>
    function delBadge(e) {
        if (e != "") {
            $.ajax({
                type: "POST",
                url: '@Url.Action("delBadgesMedia", "Home")',
                data: { Id: e },
                dataType: 'json',
                cache: false,
                success: function (response) {
                var i = 0;
                var BadgeHtml = "";
                $.each(response, function (a, b) {
                    BadgeHtml += "<tr><td>" + b.BadgeType + "</td>";
                    BadgeHtml += "<td>" + b.Url_Link + "</td>";
                    BadgeHtml += "<td>" + '<button onclick="delBadge('+b.Id+')"><img src="../../MainFrontDesign/images/delete.svg" style="width:16px;"></button>' + "</td>";
                    i++;
                });
                $('#Badge-list > tbody').html(BadgeHtml);
                }

            });
        }
        else {
            alert('');
        }
    }
</script>

<script>
    $('#savePrivacy').click(function () {
        $('#defaultModal3').modal('hide');
    })

    $('#Help').click(function () {
        $('#defaultModal1').modal('hide');
    })

    $('#TC').click(function () {
        $('#defaultModal2').modal('hide');
    })
</script>
