@model Vastwebmulti.Areas.ADMIN.Models.BusSlabModel

@using (Ajax.BeginForm("_UserBUS_Slab", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "OnSuccess1", OnFailure = "onfailed", UpdateTargetId = "divEditFormComm", LoadingElementId = "div_Loader", InsertionMode = InsertionMode.Replace }))
