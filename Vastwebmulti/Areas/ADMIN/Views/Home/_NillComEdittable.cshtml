@model Vastwebmulti.Areas.ADMIN.ViewModel.NillPortalViewmodel
<table  class="table table-bordered table-striped table-hover js-exportable custum-tabel-input " style="width:99.5%;margin-top:0 !important;">
    <thead style="background-color:whitesmoke;">
        <tr>
            <th>Operator&nbsp;Name</th>

            <th>Min</th>
            <th>Max</th>
            <th>Status</th>
            <th>Edit</th>
            <th>DEL</th>

        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.NillCOmopcodeamountlist)
        {
        <tr>



            <td>@item.operator_Name</td>




            @if (item.idno == Model.NillCOmGetbyid.idno)
            {

                <td>
                    <input type="text" id="min" name="min" value="@Model.NillCOmGetbyid.min" />
                </td>
            }
            else
            {
                <td>@item.min</td>
            }
            @if (item.idno == Model.NillCOmGetbyid.idno)
            {

                <td>
                    <input type="text" id="max" name="max" value="@Model.NillCOmGetbyid.max" />
                </td>
            }
            else
            {
                <td>@item.max</td>
            }


        <td>
            <div class="onoffswitch">
                @if (item.sts == "N")
                {
           


                    @*<a href="@Url.Action("nillcomblock",new { id = item.idno})" style="text-decoration:none;">*@
                    
                    <span class="custom-off" onclick="UpdateStatus(@item.idno)">off</span>
                    @*</a>*@
            

                }
                else
                {
         
                @*<a href="@Url.Action("nillcomblock",new { id = item.idno})" style="text-decoration:none;">*@
               
                <span class="costom-on" onclick="UpdateStatus(@item.idno)">on</span>
                @*</a>*@
         

                }
                </div>
        </td>


            @if (item.idno == Model.NillCOmGetbyid.idno)
            {

                <td>
                    <button type="button" class="switch-edit-button custom-table-loading" onclick="SaveData(@item.idno)" data-loading-text="<i class='fa fa-spinner fa-spin'></i>">
                        Save
                    </button>
                </td>
            }
            else
            {
                <td>
                    <button type="button" class="switch-edit-button" onclick="EditMode(@item.idno)" >
                        Edit
                    </button>
                </td>
            }

            @*<td>

            <button type="button" style="background-color:transparent; border:none;color:#03a9f4;" data-toggle="modal" data-target="#defaultModal1" onclick="animation('@item.idno','@item.operator_Name','@item.min','@item.max' )">
            <p style="padding:1px 11px 1px 11px;border:1px solid #dddddd;color:black;">Edit</p>
        </button>
        </td>*@
            <td>

                <button class="confirm" id="DeleteBtn" onclick="Deltenillcom('@item.idno')" >
                    <img src="~/MainFrontDesign/images/delete.svg" />
                </button>
            </td>
        </tr>
           



        }
    </tbody>
</table>
<script>
    $('.custom-table-loading').on('click', function () {
        
        var $this = $(this);
        $this.button('loading');
        setTimeout(function () {
            $this.button('reset');
        }, 200);
    });
</script>
