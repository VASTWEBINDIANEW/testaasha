<div class="add-sechdule-pur">
    @using (Ajax.BeginForm("_Scheduler_add", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "success2", OnFailure = "fail2", UpdateTargetId = "tab-9", OnBegin = "begin" }))
    {
        <div class="row">
            <div class="col-md-12">
                <label>API Name</label>
                <div class="select-purchase">
                    @Html.DropDownList("Apinm1", new SelectList(ViewBag.apinm1, "Value", "Text"), "Select Api Name", new { @class = "form-control", data_live_search = "true", @required = "required" })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label>Schedule Mode</label>
                <div class="select-purchase">
                    @Html.DropDownList("mode", new List<SelectListItem>
                       {
                          new SelectListItem{Text="Timing Basis", Value="TIME"},
                          new SelectListItem{Text="Low Alert Basis", Value="LOWBAL"}
                       }, "Select Mode", new { @class = "form-control", data_live_search = "true" })
                </div>
            </div>
        </div>
        <div id="idminhours" class="row" style="display:none;">
            <div class="col-md-12">
                <label>Minimum Hours</label>
                @Html.TextBox("minhours", "", new { @type = "number", @class = "form-control", placeholder = "Enter Minimum hours" })
            </div>
        </div>
        <div id="idminfund" class="row" style="display:none;">
            <div class="col-md-12">
                <label>Minimum Fund</label>
                @Html.TextBox("minfund", "", new { @type = "number", @class = "form-control", placeholder = "Enter Minimum Fund" })
            </div>
        </div>
        <div id="idtime" class="row" style="display:none;">
            <div class="col-md-12">
                <label>Schedule Time</label>
                @Html.TextBox("timerId", "", new { @class = "form-control", placeholder = "Enter Schedule Time" })

            </div>
        </div>
        <div id="idsfree" class="row" style="display:none;">
            <div class="col-md-12">
                <label>Schedule frequency</label>
                @Html.DropDownList("sfrequency", new List<SelectListItem>
                      {
                         new SelectListItem{Text="Daily", Value="1"},
                         new SelectListItem{Text="2 Days Gap", Value="3"},
                         new SelectListItem{Text="1 Week", Value="7"},
                         new SelectListItem{Text="1 Month", Value="30"}
                      }, "Select Schedule frequency", new { @class = "form-control", data_live_search = "true" })
            </div>
        </div>
        <div id="idsdaily" class="row" style="display:none;">
            <div class="col-md-12">
                <label>Daily frequency</label>
                @Html.DropDownList("SDaily", new List<SelectListItem>
                      {
                         new SelectListItem{Text="One Time", Value="1"},
                         new SelectListItem{Text="Two Time", Value="2"},
                         new SelectListItem{Text="Three Time", Value="3"},
                         new SelectListItem{Text="Four Time", Value="4"}
                      }, "Select frequency", new { @class = "form-control", data_live_search = "true" })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 tabcurrent-seconddesign">
                <label>Amount</label>
                @Html.TextBox("samount", "", new { @type = "number", @class = "form-control", placeholder = "Enter Amount", @required = true })
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 add-pur-bottom button-seconddesign">
                <button id="resetallschdu" type="reset" class="btn-second button-third-design">Reset</button>
                <button type="submit" class="fullbodydycolorbg for-account-list-hide btn-first button-third"><span style="color:#fff;position:relative;">Submit</span></button>

            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <label id="schdulelable" style="color:red;"></label>
            </div>
            </div>
            }
        </div>

        <script>
            $("#mode").change(function () {
                var modeval = $('#mode').val();
                if (modeval == "TIME") {
                    $('#idminhours').hide();
                    $('#idminfund').hide();
                    $('#idtime').show();
                    $('#idsfree').show();
                    $('#idsdaily').hide();
                }
                else if (modeval == "LOWBAL") {
                    $('#idminhours').show();
                    $('#idminfund').show();
                    $('#idtime').hide();
                    $('#idsfree').hide();
                    $('#idsdaily').hide();
                }
                else {
                    $('#idminhours').hide();
                    $('#idminfund').hide();
                    $('#idtime').hide();
                    $('#idsfree').hide();
                    $('#idsdaily').hide();
                }
            });
            $("#sfrequency").change(function () {
                var sfre = $('#sfrequency').val();
                if (sfre == "1") {
                    $('#idsdaily').show();
                }
                else {
                    $('#idsdaily').hide();
                }
            });
        </script>

        <script>
            $(function () {
                $('#timerId').timepicker();
            });
        </script>



        <script>
            function begin() {
                $('#schdulelable').text("");
                var apinm = $('#apinm').val();
                var mode = $('#mode').val();
                var samount = $('#samount').val();
                var timerId = $('#timerId').val();
                var sfrequency = $('#sfrequency').val();
                var SDaily = $('#SDaily').val();
                var minhours = $('#minhours').val();
                var minfund = $('#minfund').val();

                if (apinm != "" && mode != "" && samount != "") {
                    if (samount > 0) {
                        if (mode == "TIME") {
                            if (timerId != "" && sfrequency != "") {
                                if (sfrequency == "1") {
                                    if (SDaily != "") {
                                        $('#schdulelable').text("");
                                        return true;
                                    }
                                    else {
                                        $('#schdulelable').text("Fill All Required Value");
                                        return false;
                                    }
                                }
                            }
                            else {
                                $('#schdulelable').text("Fill All Required Value");
                                return false;
                            }
                        }
                        else {
                            if (minhours != "" && minfund != "") {
                                if (minfund > 0 && minhours > 0) {
                                    $('#schdulelable').text("");
                                    return true;
                                }
                                else {
                                    $('#schdulelable').text("Fill All Required Value");
                                    return false;
                                }
                            }
                            else {
                                $('#schdulelable').text("Fill All Required Value");
                                return false;
                            }
                        }
                    }
                    else {
                        $('#schdulelable').text("Amount Should be Positive");
                        return false;
                    }
                }
                else {
                    $('#schdulelable').text("Fill All Required Value");
                    return false;
                }
            }
        </script>
