                    else
                    {
                        <i class="fa fa-toggle-off" style="color:red"></i>
                    }
                </td>
                <td>@Model.Dealeruser[i].upimax</td>
            </tr>


                    }
                }
                <!--End Dealer-->
                <!--Retailer-->
