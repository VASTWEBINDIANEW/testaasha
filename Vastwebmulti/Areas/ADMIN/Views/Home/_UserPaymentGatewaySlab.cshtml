@model Vastwebmulti.Areas.ADMIN.Models.GatewayPayment
@using (Ajax.BeginForm("_UserPaymentGatewaySlab", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "OnSuccess1", OnFailure = "onfailed", UpdateTargetId = "divEditFormComm", LoadingElementId = "div_Loader", InsertionMode = InsertionMode.Replace }))
{
    <input id="btnsubmituser" type="submit" value="Update For Existing Users" class="btn  waves-effect" style="display:none;" />
    <input id="btnsubmitusercommon" type="submit" name="Button" value="Update Existing & New Users" class="btn  waves-effect" style="display:none;" />
    <input id="btnsubmitusercommondlmrem" type="submit" name="Button" value="Update Existing & New Users" class="btn  waves-effect" style="display:none;" />
    @Html.HiddenFor(m => m.role)
    <div class="row clearfix" style="margin-right:0px;">
        <div class="col-md-12">
            <div class="slab-master-block">
                <div class="slab-master-block-left">
                    <div id="allshow" class="row">
                        <div class="col-md-12" style="padding-right:20px;">
                            <div class="custom-district-img">
                                <img src="~/AdminDesign/images/slab-user.svg" style="width:18px;">
                            </div>
                            @Html.DropDownList("ddlUserId", Model.UserId, "All Users", new { @class = "for-select2 form-control", @onchange = "ddlUserIdChange()" })
                        </div>
                    </div>
                    <div id="retailerdrop" class="row" style="display:none;">
                        <div class="col-md-6" style="padding-right:0px;">
                            <div>
                                <div class="custom-district-img">
                                    <img src="~/AdminDesign/images/slab-user.svg" style="width:18px;">
                                </div>
                                @Html.DropDownList("ddldealer", Model.UserId, "All Distributor", new { @class = "for-select2 form-control", @onchange = "ddlretailerid()" })
                            </div>
                        </div>
                        <div class="col-md-6" style="padding-left:5px;padding-right:20px;">
                            <div>
                                <div class="custom-district-img">
                                    <img src="~/AdminDesign/images/slab-user.svg" style="width:18px;">
                                </div>
                                @Html.DropDownList("ddlUserIdrem", Model.Retailerid, "All Retailer", new { @class = "for-select2 form-control", @onchange = "ddlUserIdChangerem()" })
                            </div>
                        </div>
                    </div>
                </div>
                <div class="slab-master-block-right">
                    <div id="slab-master-message" class="slab-master-message slab-master-message-show" style="display: none;">
                        <p>  If you edit the slabs of all the master distributors, you are given a data view of the common slabs.</p>
                    </div>
                    <div id="slab-master-detail" class="slab-master-detail slab-master-detail-hide" style="display: block;">
                        <div class="row clearfix">

                            <div class="col-md-4 col-sm-4 col-xs-4 col-4">
                                <span class="master-slab-right-icon">
                                    <img src="~/AdminDesign/images/user.svg">
                                </span>
                                <input class="form-control" type="text" placeholder="User Name" value="@Model.Name">

                            </div>
                            <div class="col-md-4 col-sm-4 col-xs-4 col-4">
                                <span class="master-slab-right-icon" style="border-left: 1px solid #bbb;">
                                    <img src="~/AdminDesign/images/number.svg">
                                </span>
                                <input class="form-control" type="text" placeholder="User Registered Number" value="@Model.Phone">

                            </div>
                            <div class="col-md-4 col-sm-4 col-xs-4 col-4">
                                <span class="master-slab-right-icon" style="border-left: 1px solid #bbb;">
                                    <img src="~/AdminDesign/images/email.svg">
                                </span>
                                <input class="form-control" type="text" placeholder="User Registered Mail" value="@Model.Email">

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="slab-table">
        <table class="table table-bordered third-design-table">
            <thead class="navbar" style="position:initial;">
                <tr>
                    <th rowspan="2">USER&nbsp;ID </th>
                    <th colspan="3" style="text-align:center;">Credit&nbsp;Card Charge/Limit</th>
                    <th colspan="3" style="text-align:center">Debit&nbsp;Card Charge/Limit</th>
                    <th colspan="4" style="text-align:center">Net&nbsp;Banking Charge/Limit</th>
                    <th colspan="2" style="text-align:center">Wallet Charge/Limit</th>
                    <th colspan="2" style="text-align:center">UPI Charge/Limit</th>
                </tr>
                <tr>
                    <!----Retailer---->
                    @*<td style="border-left: 1px; border-color: #aaa4a4;">Status</td>*@
                    <td style="border-left: 1px; border-color: #aaa4a4;">
                        Charge<sup>%</sup>
                        <br /> <span style="font-size:10px; color:red;">Exclude&nbsp;GST</span>
                    </td>
                    <td style="border-left: 1px; border-color: #aaa4a4;">Max<sup>₹</sup></td>
                    <td style="border-left: 1px; border-color: #aaa4a4;">Settlement</td>
                    <!----Dealer---->
                    @*<td style="border-left: 1px; border-color: #aaa4a4;">Status</td>*@
                <td style="border-left: 1px; border-color: #aaa4a4;">
                    UpTo 2K<sup>%</sup>
                    <br /> <span style="font-size:10px; color:red;">Exclude&nbsp;GST</span>
                </td>
                <td style="border-left: 1px; border-color: #aaa4a4;">
                    Above 2K<sup>%</sup>
                    <br /> <span style="font-size:10px; color:red;">Exclude&nbsp;GST</span>
                </td>
                    <td style="border-left: 1px; border-color: #aaa4a4;">Max<sup>₹</sup></td>
                    <!----Net Banking---->
                    @*   <td style="border-left: 1px; border-color: #aaa4a4;">Status</td>*@
