                {
                    for (int i = 0; i < Model.Retaileruser.Count; i++)
                    {

                        @Html.HiddenFor(a => a.Retaileruser[i].idno)

                        string email = string.Empty;
                        using (Vastwebmulti.Models.VastwebmultiEntities db = new Vastwebmulti.Models.VastwebmultiEntities())
                        {
