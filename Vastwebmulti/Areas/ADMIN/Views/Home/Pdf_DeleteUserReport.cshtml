                            <td></td>
                            <td></td>
                            <td style="font-size:18px;">@Model.GSTAdmin.Sum(a => a.gst)</td>
                        </tr>
                    }
                    else if (Model.GSTMaster != null)
                    {
                        <tr>
                            <td style="font-size:18px;">Total</td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td style="font-size:18px;">@Model.GSTMaster.Sum(a => a.gst)</td>
                        </tr>
                    }
                    else if (Model.GSTDealer != null)
                    {
                        <tr>
                            <td style="font-size:18px;">Total</td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td style="font-size:18px;">@Model.GSTDealer.Sum(a => a.gst)</td>
                        </tr>
                    }
                    else if (Model.GSTRetailer != null)
                    {
                        <tr>
                            <td style="font-size:18px;">Total</td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td style="font-size:18px;">@Model.GSTRetailer.Sum(a => a.gst)</td>
                        </tr>
                    }
                </tfoot>*@
        </table>
    </div>
</body>
</html>
