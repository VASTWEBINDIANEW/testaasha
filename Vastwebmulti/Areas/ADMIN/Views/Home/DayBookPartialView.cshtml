
<style>
    #ul {
        list-style-type: none;
        margin: 0;
        padding: 0;
        overflow: hidden;
    }

        #ul li {
            float: left;
            margin-right:2px;
        }

            #ul li a {
                display: block;
                text-align: center;
                padding: 5px 10px;
                text-decoration: none;
                border: 1px solid #ddd;
                position: initial;
            }

                #ul li a:hover:not(.activee) {
                    background-color:var(--main-bg-lcolor);
                    color: #fff;
                    border: 1px solid #b1a6a6;
                }

    .activee {
        color: white;
        margin-bottom: 0px;
         background-color:var(--main-bg-lcolor);
    }
    @@media only screen and (max-width:520px) {
        #custnav #ul li{width:32.7%;margin-top: 2px;}
        #custnav #ul li a{font-size:12px;padding:5px;}
    }
    
</style>
<div>
    <div id="custnav">
        <ul id="ul">
            <li><a href="~/ADMIN/Home/Actual_Admin_income">My Book</a></li>
            <li><a href="~/ADMIN/Home/DaybookRetailer">Retailer's Book</a></li>
            <li><a href="~/ADMIN/Home/DayBookDealer">Distributor's Book</a></li>
            <li><a href="~/ADMIN/Home/DayBookMaster">Master's Book</a></li>
            <li><a href="~/ADMIN/Home/DayBookAPI">API User's Book</a></li>
             <li><a href="~/ADMIN/Home/DayBookWhitelabel">White Label's Book</a></li>
       
        </ul>
    </div>
</div>
<script src="~/Scripts/jquery-1.10.2.min.js"></script>
<script>
    $(document).ready(function () {
        var current = location.pathname;
        $('#custnav li a').each(function () {
            var $this = $(this);
            if ($this.attr('href').indexOf(current) !== -1) {
                $this.addClass('activee');
                $this.addClass('navbar');

            }
        })
    });
</script>

