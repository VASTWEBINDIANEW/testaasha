            }

            .responcive-full .form-group.jjp {
                width: 100%;
                margin-bottom: 10px;
            }

        .responcive-fifty button {
            width: 100%;
            text-align: left;
        }


    }

    @@media screen and (max-width: 600px) {
        .responcive-full {
            margin-bottom: 0px !important;
        }

        .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {
            height: auto;
        }
        .D_menu {
            width: 100% !important;
        }
        .responcive-fifty {
            width: 100% !important;
            float: left;
            margin-bottom: 4px;
        }
        .responcive-full{width: 100% !important;float: left;}
        .responcive-full .form-group.jjp,.responcive-full .nrr3 input {width: 100% !important;}
        .responcive-full input {width: 100% !important;margin: 0;}
            .responcive-full .nrr3 {
                width: 100% !important;
                margin-top: 6px;
            }
        .responcive-full .mrj {width: 100% !important;}
        .responcive-full .mrj button {width: 100%;text-align: left;}

    }
</style>



