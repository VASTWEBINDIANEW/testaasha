        .responcive-fifty {
            width: 50% !important;
            float: left;
            margin: 0;
            margin-bottom: 10px;
        }

            .responcive-fifty{
                margin-right: 0px;
                margin-bottom: 10px;
            }

        .responcive-full {
            width: 100% !important;
            float: left;
            margin-bottom: 10px !important;
        }

