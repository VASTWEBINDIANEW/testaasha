                        <div class="t_menu">
                            
                                @using (Html.BeginForm("EcommerceHistory", "Home", FormMethod.Post))
                                {
                                    <div class="">
                                        <div class="col-md-2 mrj jkjk responcive-fifty">
                                            <div class="form-line">
                                                @Html.DropDownList("ddlusers", new List<SelectListItem>
                                   {
                                new SelectListItem{ Text="All User",Value="Admin"},
                                new SelectListItem{Text="Master D",Value="Master"},
                                new SelectListItem{Text="Distributor",Value="Dealer"},
                                new SelectListItem{Text="Retailer",Value="Retailer"},
                                new SelectListItem{Text="Vendor",Value="Vendor"}

                               }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;", @onchange = "answers()" })

                                            </div>
                                        </div>

                                        <div class="col-md-2 mrj responcive-fifty" style="display:none;" id="allvendor">
                                            <div class="form-line">
                                                @Html.DropDownList("allvendor", ViewBag.allvendor as SelectList, "All Vendor", new { @style = "margin-top:0px", @class = "selectpicker form-control allmasters", data_live_search = "true", })
                                            </div>
                                        </div>
                                        <div class="col-md-2 mrj responcive-fifty" style="display:none;" id="allmaster">
                                            <div class="form-line">
                                                @Html.DropDownList("allmaster", ViewBag.allmaster as SelectList, "All Master", new { @style = "margin-top:0px", @class = "selectpicker form-control allmasters", data_live_search = "true", })
                                            </div>
                                        </div>

                                        <div class="col-md-2 mrj responcive-fifty" style="display:none;" id="dlm">
                                            <div class="form-line">
                                                @Html.DropDownList("alldealer", ViewBag.alldealer as SelectList, "All Distubutor", new { id = "alldealer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                            </div>
                                        </div>
                                        <div class="col-md-2 mrj responcive-fifty" style="display:none;" id="rem">
                                            <div class="form-line">
                                                @Html.DropDownList("allretailer", ViewBag.allretailer as SelectList, "All Retailer", new { id = "allretailer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                            </div>
                                        </div>
                                        <div class="col-md-2 mrj responcive-fifty" style="width: 130px;">
                                            <div class="form-line">
                                                @Html.DropDownList("Cateid", ViewBag.category as SelectList, "Select Category", new { id = "Cateid", @class = "selectpicker form-control", data_live_search = "true" })
                                            </div>
                                        </div>

                                        <div class="col-md-2 mrj jkjk responcive-fifty">
                                            <div class="form-line">
                                                @Html.DropDownList("ddl_status", new List<SelectListItem>
                                     {
                             new SelectListItem{ Text="All Status",Value="ALL",},
                             new SelectListItem{Text="SUCCESS",Value="2"},
                             new SelectListItem{Text="Pending",Value="1"},
                             new SelectListItem{Text="Rejected",Value="3"}
                              }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                            </div>
                                        </div>

                                        <div class="col-md-5 mrj responcive-full" style="width: auto;margin-top:1px;">
                                            <div class="form-group jjp">
                                                <div class="input-daterange input-group">
                                                    <div class="custom-date-icon ner height-icon-third">
                                                        <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                                    </div>
                                                    @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; height: 33px !important;", autocomplete = "off" })

                                                    <div class="nrr3">
                                                        <div class="custom-date-icon ner height-icon-third">
                                                            <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                                        </div>
                                                        @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; height: 33px !important;", autocomplete = "off" })
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="mrj responcive-fifty search-resp-third" style="margin-right: 0px;">

                                                <button type="submit" value="Old" name="submit" class="btn input-back-second" style="background: transparent;border: 1px solid #b1a6a638;">
                                                    <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                                    <span style="top:-2px;color:black;">Search</span>
