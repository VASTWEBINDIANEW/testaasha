                        </div>
                    </div>

                </div>
            </div>

        </div>


        <div class="row clearfix margi-topo-third">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:15px;">
                <div class="card">

                    <div class="for-margin-top" style="margin-top:0px;">
                        <div class="body table-responsive page-header-third" style="position:inherit;padding:5px;">
                            <table id="example" class="table table-bordered table-striped example-second third-design-table" style="width:100%;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>User&nbsp;Details</th>

                                        <th>Customer&nbsp;No</th>
                                        <th>R-Amount</th>
                                        <th>Operator</th>
                                        <th>Roffer</th>
                                        <th>User&nbsp;(%)</th>
                                        <th>User&nbsp;Pre&nbsp;₹</th>
                                        <th>Share</th>
                                        <th>User&nbsp;Post&nbsp;₹</th>
