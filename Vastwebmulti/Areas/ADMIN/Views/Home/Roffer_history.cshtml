    <div id="defaultModal1ss">
        <div class="pppop">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="padding: 0px;">
                <div class="card">
                    <div>
                        <h2 style="color:#000000a8; display: inline-block;font-size:16px; padding-top:11px; margin-left:17px;">
                            Roffer Commission Details
                        </h2>
                        <button type="button" class="btn waves-effect" data-dismiss="modal" style="float: right;margin-top: 18px;margin-right: 10px;background: transparent;border: 0px;">
                            <i class="fa fa-times fulltextbodycolor fullbodydycolorbg" aria-hidden="true"></i>
                        </button>
                    </div>
                    <div class="klk" id="tblList">
                        <table class="table-bordered" style="width: 100%;">
                            <thead style="background-color: whitesmoke;">
                                <tr>
                                    <th>Operator Name</th>
                                    <th>Commission</th>
                                    <th>Edit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null) { 
                                if (Model.Count() > 0)
                                {
                                    int i = 1;

                                    foreach (var item in Model)
                                    {
                                        var ii = "Opt" + i;

                                        <tr>
                                            <td>@Html.DisplayFor(modelItem => item.operator_name)</td>
                                            <td>@Html.DisplayFor(modelItem => item.basevalue)</td>
                                            <td>
                                                <button class="butt" id="@ii" style="background-color:transparent;color:#03a9f4; border:none;">
                                                    <i class="fa fa-edit fa-2x" style="font-size:24px;color:#607D8B;"></i>
                                                </button>
                                            </td>
                                        </tr>

                                        <tr style="display:none;">
                                                @Html.Hidden("optcode", item.optcode)
                                                <td>@Html.DisplayFor(modelItem => item.operator_name)</td>
                                                <td>
                                                    <input type="text" id="@i" value="@item.basevalue" />
                                                </td>
                                                <td>
                                                    <input type="hidden" id="@ii" value="@item.optcode" />
                                                    <button onclick="save(@i)">Save</button>
                                                </td>
                                        </tr>
                                        
                                        i++;
                                    }
                                }
                                }
                            </tbody>
                        </table>

                    </div>
                </div>
            </div>
        </div>
    </div>



</section>


