<!--Calendar Javascript-->
<script type="text/javascript">
    $(document).ready(function () {

        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

    });

</script>

<script>
    var pageindex = 2;
    var NoMoredata = false;
    var inProgress = false;
    $(window).scroll(function () {
        if ($(window).scrollTop() > Number($("#example").height()) / 4 && !NoMoredata && !inProgress) {
            
                inProgress = true;
                $("#loadingdiv").show();
                $.post("@Url.Action("Scroll_Roffer_history", "Home")",
                    { allretailer: $('#allretailer').val(), txt_frm_date: $('#txt_frm_date').val(), txt_to_date: $('#txt_to_date').val(), PageIndex: pageindex, OperatorName: $('#OperatorName').val() },
                    function (data) {
                        pageindex = pageindex + 1;
                        NoMoredata = data.NoMoredata;
                        $("#trow").append(data.HTMLString);
                        $("#loadingdiv").hide();
                        inProgress = false;
                    });
            }
    });
</script>

<script>
    $("#btnExl").click(function(){
       var txt_frm_date = $('#txt_frm_date').val();
       var txt_to_date = $('#txt_to_date').val();
        var allretailer = $('#allretailer').val();
        var OperatorName = $('#OperatorName').val();

        var url = '@Url.Action("Excel_Roffer_history", "Home")?allretailer=' + allretailer + '&txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&OperatorName=' + OperatorName;
       location.href = url;
});
</script>
<script>
    $("#btnPDF").click(function () {
         var txt_frm_date = $('#txt_frm_date').val();
         var txt_to_date = $('#txt_to_date').val();
        var allretailer = $('#OperatorName').val();
        var OperatorName = $('#OperatorName').val();

        var url = '@Url.Action("PDF_Roffer_history", "Home")?allretailer=' + allretailer + '&txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&OperatorName=' + OperatorName;
         window.open(url,'_blank' // <- This is what makes it open in a new window.
    );
    });
</script>

<script>
    function save(id) {
        
        var idno = id;
        var CommVal = $('#' + id).val();

        $.ajax({
            url: '@Url.Action("Update_Roffer_comm", "Home")',
            data: { Idno: idno, baseval: CommVal },
            type: 'GET',
            cache: false,
            success: function (data) {

                $('#tblList').html(data);

                $('.butt').click(function () {
                    $(this).closest("tr").next().show();
                    $(this).closest("tr").hide();
                });
            }
        });
    }
</script>
<script>
    $('.butt').click(function () {
        $(this).closest("tr").next().show();
        $(this).closest("tr").hide();
    });
</script>

<script>
    function offersts() {
        $.ajax({
            url: '@Url.Action("offersts", "Home")',
            type: 'GET',
            cache: false,
            success: function () {

            }
        });
        $("#mydiv").load(location.href + " #mydiv");
    }
</script>

<script>
    $(function () {
