<script>
    $("#btnExport").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var ddlstatus = $('#ddlstatus').val();
        var url = '@Url.Action("Excel_Show_ManualUPI_REQ", "Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&ddlstatus=' + ddlstatus;
        location.href = url;
});
</script>