<script>
    $(document).ready(function()
    {
        $('.input-daterange').datepicker({

            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",
        });
        var val = '@ViewBag.chk';
        if (val != "post") {

            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

        answers();
    });
</script>
<script>
    function UPIRESPONSE(respon, id) {
        $('#hideupiidres').val(id);
        $('#hideupiidrestypes').val(respon);
    }

