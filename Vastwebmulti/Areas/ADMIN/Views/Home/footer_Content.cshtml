
@{
    ViewBag.Title = "footer_Content";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<script src="~/Ckeditor/ckeditor.js"></script>
<script src="~/Ckeditor/adapters/jquery.js"></script>
<script type="text/javascript"> CKEDITOR.replace('txtedit'); </script>
<style>
    .scroll {
        width: 100%;
        max-height: 530px;
        overflow: auto;
    }

        .scroll::-webkit-scrollbar {
            width: 4px;
        }

        .scroll::-webkit-scrollbar-track {
            -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.3);
            border-radius: 10px;
        }

        .scroll::-webkit-scrollbar-thumb {
            border-radius: 10px;
            -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.5);
        }
</style>
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-2">
                <div class="row clearfix">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                        <div class="card">
                            <div class="body scroll" style="max-height:572px;">
                                <div class="demo-button ">
                                    <div class="row">
                                        <div class="col-md-12" style="margin-top:-10px;">
                                            @Html.Partial("ColorPartial")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-10">
                   <div class="row clearfix">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-20px;">
                        <div class="card">
                            <div class="">
                                <h2 style="color:#00000082; font-size:16px;padding-top:9px; padding-left:22px;">
                                    All Footer Services Details
                                </h2>
                                <button type="button" class="btn  waves-effect" style="float:right; margin-top:-34px;margin-right:6px;border:1px solid #c7c2c2;background:#dedddd;" data-toggle="modal" data-target="#defaultModal">
                                    <i class="fa fa-plus" style="top:1px;font-size:15px;"></i>
                                    <span style="top:0px;">Add New</span>
                                </button>
                          
                            </div>
                            <div class="body">
                                <div class="row">
                                    <div class="table-responsive" style="position:inherit;margin-top:-20px;">
                                        <table class="table table-bordered table-striped table-hover dataTable js-exportable ">
                                            <thead style="background-color:whitesmoke;">
                                                <tr>
                                                    <th>Service&nbsp;Type</th>
                                                    <th>Service&nbsp;Name&nbsp;1</th>
                                                    <th>Service&nbsp;Name&nbsp;2</th>
                                                    <th>Service&nbsp;Name&nbsp;3</th>
                                                    <th>Service&nbsp;Name&nbsp;4</th>
                                                    <th>Service&nbsp;Name&nbsp;5</th>
                                                    <th>Service&nbsp;Name&nbsp;6</th>
                                                    <th>Service&nbsp;Name&nbsp;7</th>
                                                    <th>Service&nbsp;Name&nbsp;8</th>
                                                    <th>Edit</th>
                                                    <th>Delete</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in ViewBag.allfooter)
                                                {
                                                    <tr>
                                                        <td>@item.ServiceType</td>
                                                        <td>@item.ServiceName1</td>
                                                        <td>@item.ServiceName2</td>
                                                        <td>@item.ServiceName3</td>
                                                        <td>@item.ServiceName4</td>
                                                        <td>@item.ServiceName5</td>
                                                        <td>@item.ServiceName6</td>
                                                        <td>@item.ServiceName7</td>
                                                        <td>@item.ServiceName8</td>
                                                        <td>
                                                            <a class="btn btn-default waves-effect"  href='@Url.Action("Edit_FooterService", "Home", new {ServiceId = item.Id})' style="border:1px solid #c7c2c2;">
                                                              Edit
                                                            </a>
                                                        </td>
                                                        <td>
                                                            <button type="button" class="btn btn-default waves-effect" style="background-color:transparent; border:none;border:1px solid #c7c2c2;" onclick="delfooterser('@item.Id')">
                                                                Delete
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="row clearfix">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-30px;">
                        <div class="card">
                            <div class="">
                                <h2 style="color:#00000082; font-size:16px;padding-top:9px; padding-left:22px;">
                                    All Footer Links Details
                                </h2>
                                <button type="button" class="btn  waves-effect" style="float:right; margin-top:-34px;margin-right:6px;border:1px solid #c7c2c2;background:#dedddd;" data-toggle="modal" data-target="#defaultModal1">
                                    <i class="fa fa-plus" style="top:1px;font-size:15px;"></i>
                                    <span style="top:0px;">Add New</span>
                                </button>
                               
                            </div>
                            <div class="body">
                                <div class="row">
                                    <div class="table-responsive" style="position:inherit;margin-top:-20px;">
                                        <table class="table table-bordered table-striped table-hover dataTable js-exportable ">
                                            <thead style="background-color:whitesmoke;">
                                                <tr>
                                                    <th>Link Name</th>
                                                    <th>Link Url</th>
                                                    <th>Edit</th>
                                                    <th>Delete</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in ViewBag.allink)
                                                {
                                                    <tr>
                                                        <td>@item.FooterType</td>
                                                        <td>@item.FooterLink</td>
                                                        <td>
                                                            <a class="btn btn-default waves-effect" href='@Url.Action("Edit_FooterLink", "Home", new {LinkId = item.Id})' style="border:1px solid #c7c2c2;">
                                                                Edit
                                                            </a>
                                                        </td>
                                                        <td>
                                                            <button type="button" class="btn btn-default waves-effect" style="background-color:transparent; border:none;border:1px solid #c7c2c2;" onclick="delfooterlink('@item.Id')">
                                                          Delete
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="row clearfix">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-30px;">
                        <div class="card">
                            <div class="">
                                <h2 style="color:#00000082; font-size:16px;padding-top:9px; padding-left:22px;">
                                    All Footer Pages Content Details
                                </h2>
                                <button type="button" class="btn  waves-effect" style="float:right; margin-top:-34px;margin-right:6px;border:1px solid #c7c2c2;background:#dedddd;" data-toggle="modal" data-target="#defaultModal2">
                                    <i class="fa fa-plus" style="top:1px;font-size:15px;"></i>
                                    <span style="top:0px;">Add New</span>
                                </button>
                       
                            </div>
                            <div class="body">
                                <div class="row">
                                    <div class="table-responsive" style="position:inherit;margin-top:-20px;">
                                        <table class="table table-bordered table-striped table-hover dataTable js-exportable ">
                                            <thead style="background-color:whitesmoke;">
                                                <tr>
                                                    <th>Page&nbsp;Name</th>
                                                    <th>Page Content</th>
                                                    <th>Edit</th>
                                                    <th>Delete</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in ViewBag.page)
                                                {
                                                    var p = item.FooterPageContent;
                                                    var q = "";
                                                    if (p.Length > 500)
                                                    {
                                                        q = p.Substring(0, 500);
                                                    }
                                                    else
                                                    {
                                                        q = p;
                                                    }
                                                    <tr>
                                                        <td>@item.FooterPagetype</td>
                                                        <td>@Html.Raw(q)</td>
                                                        <td>
                                                            <a class="btn btn-default waves-effect" href='@Url.Action("Edit_FooterPage", "Home", new {PageId = item.Id})' style="border:1px solid #c7c2c2;">
                                                                <i class="fa fa-edit fa-2x" style="font-size:28px;color:#673ab7;"></i>
                                                            </a>
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-default waves-effect" type="button" style="background-color:transparent; border:none;border:1px solid #c7c2c2;" onclick="delfooterPage('@item.Id')">
                                                                <i class="fa fa-trash" style="font-size:23px; color:red;"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                    </div>
                </div>
