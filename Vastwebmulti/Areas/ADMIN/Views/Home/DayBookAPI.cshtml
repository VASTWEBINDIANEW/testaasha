@model Vastwebmulti.Areas.ADMIN.Models.DayBookreport
@{
    ViewBag.Title = "DayBookAPI";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}

<style>

    /* new css */
    .all-type-third {
        float: right;
    }

        .all-type-third .responcive-fifty {
            width: auto;
            float: left;
        }


    /* new css */

    .table-bordered tbody tr td, .table-bordered thead tr th {
        padding: 5px 2px;
    }

    .dropdown-menu {
        margin-top: 81px !important;
    }

    .form-iconmy {
        position: absolute;
        z-index: 99;
        top: 0px;
        bottom: 0px;
        padding: 6px 5px;
        border-right: 1px solid #bbb;
        height: 32px;
    }

    @@media screen and (max-width:1366px) {
        .actul-none-third {
            display: none;
        }

        .actul-search-third {
            width: 23%;
        }

        .actulpdf-third {
            width: 35%;
            padding-right: 5px;
        }

        .actulpdf-third {
            padding-left: 0;
        }
    }


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:992px) {
        .up-up-up #custnav li {
            width: 33.333%;
            margin: 0px;
            padding: 2px;
        }

        .responcive-fifty button {
            width: 100%;
            text-align: left;
        }

        .responcive-fifty div {
            padding-bottom: 0px !important;
        }

        .actul-search-third {
            width: auto;
        }

        .actulpdf-third {
            width: auto;
            float: right;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }


    @@media only screen and (max-width:520px) {
        .admin-day-book .col-md-5 {
            width: 38%;
            padding-left: 15px !important;
            float: left;
        }

            .admin-day-book .col-md-5 input {
                padding-left: 15px;
            }

        .admin-day-book .col-md-2 {
            width: 25%;
            float: left;
        }

        .table-responsive > .table-bordered > thead > tr > th:first-child, .table-responsive > .table-bordered > thead > tr > td:first-child,
        .table-responsive > .table-bordered > thead > tr > th:last-child {
            border-left: 1px solid var(--border-color);
        }
    }

    @@media only screen and (max-width:480px) {

        .all-type-third {
            float: right;
            width: 100%;
        }

            .all-type-third .responcive-fifty {
                width: 50%;
                float: left;
                padding: 0 !important;
            }
    }
</style>
<section class="content fourdesign-section-admin">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>Daybook Api</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Day Book&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Daybook Api</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix margin-bottom-third cardbackg-thirdclass onlymargin-third">
            <div class="col-md-12 admindaybook-four">
                <div class="card row back-transparent-third" style="margin:0px;">
                    <div class="col-md-8 up-up-up up-third-design active-nav-third padding-left-third page-header-third" style="width:auto;float:left;">
                        <div>
                            @Html.Partial("DayBookPartialView")
                        </div>
                    </div>
                    <div class="col-md-4 page-header-third" style="width:auto;float:right;">
                        <div class="row admin-day-book" style="margin:0;">

                            <div class="col-md-4 padding-right-third actulpdf-third" style="width: auto; float: left; padding: 0;">
                                <div class="rechargepdfexal pdfexport-span-second spanpdfback-third" style="float:right;">
                                    <span><img src="~/ashok-images/pdf.png"><input type="button" id="btnPDF" value="PDF" style="border:0px;background:transparent"></span>
                                    <span>
                                        <img src="~/ashok-images/xls.png"><input type="button" id="btnExport" name="btnExport" value="Export" style="border:0px;background:transparent;">
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card page-header-third">

                    <div>
                        @using (Html.BeginForm("DayBookAPI", "Home", FormMethod.Post))
                        {
                            <div class="col-md-1 actul-none-third"></div>
                            <div class="all-type-third">
                                <div class="col-md-5 responcive-fifty date-actul-third" style="padding:0px 5px;">
                                    <div class="input-daterange input-group input-icon-third" style="width:100%;">
                                        <div class="form-iconmy"><i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg" aria-hidden="true"></i></div>
                                        @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;height:32px;" })
                                    </div>
                                </div>
                                <div class="col-md-2 responcive-fifty actul-search-third" style="padding:0px;">

                                    <button type="submit" class="btn waves-effect input-back-second" style="height:32px;background:transparent;border-color:#ddd;">
                                        <i class="fa fa-search" style="top:1px;font-size:16px;color:black;"></i>
                                        <span style="top:0px;color:black;">Search</span>
                                    </button>

                                </div>
                            </div>
                        }
                    </div>

                    <div style="width: 100%; float: left; margin-top: 5px;">
                        <div class="table-responsive" style="position:inherit; ">
                            <table class="table table-bordered table-striped table-hover third-design-table" style="width:100%;font-size:12px;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th rowspan="2">API&nbsp;User&nbsp;Firm</th>
                                        <th rowspan="2">Opening&nbsp;₹</th>
                                        <th colspan="2">Purchase</th>
                                        <th rowspan="2">Prepaid&nbsp;&&nbsp;Utility</th>
                                        <th rowspan="2">Pancard</th>
                                        <th colspan="2">Success&nbsp;To&nbsp;Fail</th>
                                        <th colspan="2">Failed&nbsp;To&nbsp;Success</th>


                                        <th rowspan="2">GST&nbsp;₹</th>
                                        <th rowspan="2">TDS&nbsp;₹</th>
                                        <th rowspan="2">Closing&nbsp;₹</th>

                                        <th rowspan="2">Diff</th>
                                    </tr>
                                    <tr>
                                        <th><span style="font-size: 10px;">Net&nbsp;₹ </span></th>
                                        <th><span style="font-size: 10px;">Charge&nbsp;₹</span></th>
                                        <th><span style="font-size: 10px;">To&nbsp;Fail</span></th>
                                        <th><span style="font-size: 10px;">Refund&nbsp;₹</span></th>
                                        <th><span style="font-size: 10px;">To&nbsp;Success</span></th>
                                        <th><span style="font-size: 10px;">Debit&nbsp;₹</span></th>
                                    </tr>

                                </thead>
                                <tbody>

                                    @if (Model.daybook_api != null)
                                    {
                                        <tr>
                                            <td>
                                                Total
                                            </td>
                                            <td>@Model.daybook_api.Sum(item => item.openbal)</td>
                                            <td>@Model.daybook_api.Sum(item => item.PURCHASE)</td>
                                            <td>@Model.daybook_api.Sum(item => item.charge)</td>
                                            <td>@Model.daybook_api.Sum(item => item.RCH)</td>
                                            <td>@Model.daybook_api.Sum(item => item.PAN)</td>
                                            <td>@Model.daybook_api.Sum(item => item.OLDDAYFAILED)</td>
                                            <td>@Model.daybook_api.Sum(item => item.OLDDAYREFUND)</td>
                                            <td>@Model.daybook_api.Sum(item => item.OLDDAYSUCCESS)</td>
                                            <td>@Model.daybook_api.Sum(item => item.OLDDAYFAILEDTOSUCCESS)</td>
                                            <td>@Model.daybook_api.Sum(item => item.GST)</td>
                                            <td>@Model.daybook_api.Sum(item => item.TDS)</td>
                                            <td>@Model.daybook_api.Sum(item => item.closebal)</td>
                                            <td>@Model.daybook_api.Sum(item => item.DIFF)</td>
                                        </tr>
                                        foreach (var item in Model.daybook_api)
                                        {
                                            <tr>
                                                <td>
                                                    @if (item.farmname == null)
                                                    {
                                                        @item.username
                                                    }
                                                    else
                                                    {
                                                        @item.farmname
                                                    }
                                                </td>
                                                <td>@item.openbal</td>
                                                <td>@item.PURCHASE</td>
                                                <td>@item.charge</td>
                                                <td>@item.RCH</td>
                                                <td>@item.PAN</td>
                                                <td>@item.OLDDAYFAILED</td>
                                                <td>@item.OLDDAYREFUND</td>
                                                <td>@item.OLDDAYSUCCESS</td>
                                                <td>@item.OLDDAYFAILEDTOSUCCESS</td>
                                                <td>@item.GST</td>
                                                <td>@item.TDS</td>
                                                <td>@item.closebal</td>
                                                <td>@item.DIFF</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr style="background-color:aquamarine;">
                                            <td>
                                                Total
                                            </td>
                                            <td>@Model.daybook_api_old.Sum(item => item.openbal)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.PURCHASE)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.charge)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.RCH)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.PAN)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.OLDDAYFAILED)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.OLDDAYREFUND)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.OLDDAYSUCCESS)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.OLDDAYFAILEDTOSUCCESS)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.GST)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.TDS)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.closebal)</td>
                                            <td>@Model.daybook_api_old.Sum(item => item.DIFF)</td>
                                        </tr>
                                        foreach (var item in Model.daybook_api_old)
                                        {

                                            <tr>
                                                <td>
                                                    @if (item.farmname == null)
                                                    {
                                                        @item.username
                                                    }
                                                    else
                                                    {
                                                        @item.farmname
                                                    }
                                                </td>
                                                <td>@item.openbal</td>
                                                <td>@item.PURCHASE</td>
                                                <td>@item.charge</td>
                                                <td>@item.RCH</td>
                                                <td>@item.PAN</td>
                                                <td>@item.OLDDAYFAILED</td>
                                                <td>@item.OLDDAYREFUND</td>
                                                <td>@item.OLDDAYSUCCESS</td>
                                                <td>@item.OLDDAYFAILEDTOSUCCESS</td>
                                                <td>@item.GST</td>
                                                <td>@item.TDS</td>
                                                <td>@item.closebal</td>
                                                <td>@item.DIFF</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script type="text/javascript">
    $(function () {

               $('.input-daterange').datepicker({
                format: "yyyy-mm-dd",
                todayHighlight: true,
                autoclose: true

            });
            var val = '@ViewBag.chk';
            if (val != "post") {
                $("#txt_frm_date").datepicker("setDate", new Date());
                $("#txt_to_date").datepicker("setDate", new Date());
            }


        });
</script>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->

<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>

<script>
    $("#btnExport").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var url = '@Url.Action("Excel_DayBookAPI", "Home")?txt_frm_date=' + txt_frm_date;
        location.href = url;
});
</script>