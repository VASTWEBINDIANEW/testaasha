
@{
    ViewBag.Title = "otpmatchpopup";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style type="text/css">
    .loadermoney {
        position: fixed;
        left: 0px;
        top: 0px;
        width: 100%;
        height: 100%;
        z-index: 199999;
        background: url('../../images/mmmm.svg') 50% 50% no-repeat rgba(249, 249, 249, 0.9);
    }

    .icon-and-text-button-demo {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%,-50%);
        width: 346px;
        height: 353px;
        border-radius: 50%;
    }

    .icon-and-text-button-demo2 {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%,-50%);
        width: 500px;
        height: 475px;
        border-radius: 60px;
    }

    #txtcode {
        display: inline-block;
        width: 100%;
        padding: 6px 14px;
        border-radius: 25px;
        border: 0;
        margin: 13px 0 8px;
    }

    section.content {
        position: relative;
        background: rgba(0,0,0,.7);
        height: 100vh;
        margin: 0px;
        z-index: 999999;
    }

    p.requ {
        position: absolute;
        top: 13px;
        right: 36px;
        color: #8f0909 !important;
    }

    .form-control {
        border: 1px solid #bfbebe;
        height: 32px;
        margin: 6px !important;
        width: 97% !important;
    }
</style>

<div id="loadermoney" class="loadermoney" style="display:none;"></div>
<section class="content">
    <div class="container-fluid">
        <div class="">
            <div class="">
                <div class="">

                    <div class="body " style="margin: 127px 627px; background-color: var(--main-bg-lcolor); height: 185px; ">
                        @using (Html.BeginForm("mail_check1", "Home", FormMethod.Post, new { id = "Formsubmit" }))
                        {
                            @Html.AntiForgeryToken()

                            <div class="form-horizontal">
                                <h4 style="padding: 9px 14px; margin: 0px; color: #fff; border-bottom: 2px solid #808080; background-color: var(--main-bg-rcolor);">Email Show Passcode</h4>
                                <p>OTP has been Sent on your Email</p>

                                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                <div class="form-group" style=" margin: 15px;">
                                    @* @Html.LabelFor(model => model.passcode, htmlAttributes: new { @class = "control-label col-md-2" })*@
                                    <div class="col-md-10">
                                        @*@Html.EditorFor(model => model.otp, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter OTP" } })*@
                                        <input type="text" class = "form-control" placeholder = "Enter OTP"  />
                                        <p style="color: #ff0000; margin: -3px 7px;">@TempData["message12"]</p>
                                        @*@Html.ValidationMessageFor(model => model.otp, "", new { @class = "text-danger" })*@
                                    </div>
                                </div>

                                <div class="fhdg">

                                    <div class="col2222" style="display: flex; align-items: baseline; flex-direction: row-reverse; justify-content: center; }">
                                        <button type="button" class="btn btn-default" data-dismiss="modal"><a href="@Url.Action("Operator_report_new" , "Home")">Close</a></button>
                                        <input type="submit" value="Create" class="btn btn-default" />


                                    </div>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
<script>
    $(document).ready(function () {
        var show_btn = $('.show-modal');
        var show_btn = $('.show-modal');
        //$("#testmodal").modal('show');

        show_btn.click(function () {
            $("#testmodal").modal('show');
        })
    });

    $(function () {
        $('#element').on('click', function (e) {
            Custombox.open({
                target: '#testmodal-1',
                effect: 'fadein'
            });
            e.preventDefault();
        });
    });
</script>