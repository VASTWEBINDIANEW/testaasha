<script>
    checkcomm = (e) => {
        var userid = $('#ddlUserId').val();
        if (userid != "") {
            $('#txtvalheader').text("Status " + e);
            $('#txtmaster').val(userid)
            $('#exampleModal').modal()
        }
    }
</script>
<script>
        function OnSuccess1(data) {
            $('#btnsubmituser').hide();
            $('#btnsubmitusercommon').hide();
            $('#btnEdit').show();
            var chk = '@Model.role';
            if (chk == "Retailer") {
                $('#retailerdrop').show();
                $('#allshow').hide();
            }
            else {
                $('#retailerdrop').hide();
                $('#allshow').show();
            }
        }
        function onfailed(error) {
            alert(error.responseText);
        }
</script>
<script>
        function OnSuccess1M(data) {
            $('#btnsubmituser').hide();
            $('#btnsubmitusercommon').hide();
            $('#btnEdit').show();
            $('.modal-backdrop.in').hide();
           // $('#exampleModal').modal('hide');
            var chk = '@Model.role';
            if (chk == "Retailer") {
