<script>
    function otpsend1() {


           var id = $('#idnoset').val();
           var com = $('#Commset').val();
           var role = $('#RoleSet').val();
        var email = $('#EMailSet').val();


        $.ajax({
            url:   '@Url.Action("updatesetpccomm", "Home")',

            type: 'POST',
            data: { id: id, comm: com, roles: role, Emails: email },

        dataType: "JSON",


        })
        $('#btnsubmitusercommon').hide();
        $('#btnEdit').show();

        $('#tbodyshow').show();
        $('#tbodyeditAll').show();
        $('#tbodyedit').hide();

  
        document.getElementById('text12').innerHTML = com;
    

    }



</script>


