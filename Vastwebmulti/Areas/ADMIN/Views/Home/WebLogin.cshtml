<script>
    $(document).ready(() => {
        fetch_aadhar_pan_status();
        fetch_verification_type_status();
    })

    function fetch_aadhar_pan_status() {
        $.ajax({
            url: '@Url.Action("fetchAAdharPanVerify_Data")',
            success: (data) => {
                data = typeof (data) == 'string' ? JSON.parse(data) : data;
                var btn = document.getElementById('retailer_created_by');
                btn.setAttribute("created_type", data.type);

                if (data.type == "singup") {
                    $("#demo_tst").text("Only Self SingUp");
                    btn.style.background = "rgb(255 193 7)";
                }
                else if (data.type == "all") {
                    $("#demo_tst").text("All Users Active");
                    btn.style.background = "green";
                }
                else {
                    $("#demo_tst").text("Parmanently Off");
                    btn.style.background = "red";
                }
                //btn.innerText = data.type.toUpperCase();
            }
        })
    }

    function fetch_verification_type_status() {
        $.ajax({
            url: '@Url.Action("fetchAAdharPanVerification_Data")',
            success: (data) => {
                data = typeof (data) == 'string' ? JSON.parse(data) : data;
                var btn = document.getElementById('retailer_verification_type');
                btn.setAttribute("created_type", data.type);

                if (data.type == "aadhar") {
                    $("#verify_tst").text("Aadhar Required");
                    btn.style.background = "rgb(255 193 7)";
                }
                else if (data.type == "all") {
                    $("#verify_tst").text("Aadhar & Pan Required");
                    btn.style.background = "green";
                }
                else if (data.type == "pan") {
                    $("#verify_tst").text("Pan Required");
                    btn.style.background = "rgb(255 193 7)";
                }
            }
        })
    }

    function handle_aadhar_pan_change(val) {
        var type = 'off';

        if (val.getAttribute('created_type') == 'off') {
            type = 'singup'
        }
        else if (val.getAttribute('created_type') == 'singup') {
            type = 'all'
        }
        else if (val.getAttribute('created_type') == 'all') {
            type = 'off'
        }

        fetch('@Url.Action("ChangeAAdharPanVerify")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ type }),
        })
            .then(res => res.json())
            .then(data => {
                var btn = document.getElementById('retailer_created_by');
                btn.removeAttribute("created_type");
                btn.setAttribute("created_type", data.type);


                if (data.type == "singup") {
                    $("#demo_tst").text("Only Self SingUp");
                    btn.style.background = "rgb(255 193 7)";
                }
                else if (data.type == "all") {
                    $("#demo_tst").text("All Users Active");
                    btn.style.background = "green";
                }
                else {
                    $("#demo_tst").text("Parmanently Off");
                    btn.style.background = "red";
                }

            })
            .catch(err => console.error("AAdharPanVerify Error", err))
    }

    function handle_verification_type_change(val) {
        var type = 'all';

        if (val.getAttribute('created_type') == 'all') {
            type = 'aadhar'
        }
        else if (val.getAttribute('created_type') == 'aadhar') {
            type = 'pan'
        }
        else if (val.getAttribute('created_type') == 'pan') {
            type = 'all'
        }

        fetch('@Url.Action("ChangeVerificationTypeVerify")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ type }),
        })
            .then(res => res.json())
            .then(data => {
                var btn = document.getElementById('retailer_verification_type');
                btn.removeAttribute("created_type");
                btn.setAttribute("created_type", data.type);

                if (data.type == "aadhar") {
                    $("#verify_tst").text("Aadhar Required");
                    btn.style.background = "rgb(255 193 7)";
                }
                else if (data.type == "all") {
                    $("#verify_tst").text("Aadhar & Pan Required");
                    btn.style.background = "green";
                }
                else if (data.type == "pan") {
                    $("#verify_tst").text("Pan Required");
                    btn.style.background = "rgb(255 193 7)";
                }

            })
            .catch(err => console.error("AAdharPanVerify Error", err))


    }
</script>

<script>
    $(document).ready(() => {
        fetch_email_mobile_status();
    })

    function fetch_email_mobile_status() {
        $.ajax({
            url: '@Url.Action("fetchEmail_Mobile_sts_Data")',
            success: (data) => {
                data = typeof (data) == 'string' ? JSON.parse(data) : data;
                var btn = document.getElementById('retailer_mailphone_by');
                btn.setAttribute("created_type", data.type);

                if (data.type == "SIGNUP") {
                    $("#mail_btn").text("Only Self Signup");
                    btn.style.background = "rgb(255 193 7)";
                }
                else if (data.type == "ALL") {
                    $("#mail_btn").text("All Users Active");
                    btn.style.background = "green";
                }
                else {
                    $("#mail_btn").text("Parmanently Off");
                    btn.style.background = "red";
                }
                //btn.innerText = data.type.toUpperCase();
            }
        })
    }

    function handle_mail_phone_change(val) {
        var type = 'OFF';

        if (val.getAttribute('created_type') == 'OFF') {
            type = 'SIGNUP'
        }
        else if (val.getAttribute('created_type') == 'SIGNUP') {
            type = 'ALL'
        }
        else if (val.getAttribute('created_type') == 'ALL') {
            type = 'OFF'
        }

        fetch('@Url.Action("ChangeEmail_Mobile_sts")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ type }),
        })
            .then(res => res.json())
            .then(data => {
                var btn = document.getElementById('retailer_mailphone_by');
                btn.removeAttribute("created_type");
                btn.setAttribute("created_type", data.type);


                if (data.type == "SIGNUP") {
                    $("#mail_btn").text("Only Self Signup");
                    btn.style.background = "rgb(255 193 7)";
                }
                else if (data.type == "ALL") {
                    $("#mail_btn").text("All Users Active");
                    btn.style.background = "green";
                }
                else {
                    $("#mail_btn").text("Parmanently Off");
                    btn.style.background = "red";
                }

            })
            .catch(err => console.error("Email_Mobile_Status Error", err))
    }
</script>
