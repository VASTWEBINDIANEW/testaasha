<style>

    /* new css */

    .fund-transfer-form {
        background: #fff;
    }

    .switch-history-table {
        background: #fff;
        height: auto;
    }

    .for-search.tablesearch-second {
        float: left;
        margin-right: 3px;
    }

    .bread-same-all-page {
        width: auto;
    }

    .pageheader-margin-third {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    /* new css */

    .for-search input {
        width: 250px;
        border: 1px solid #dbdbdb;
        padding: 3px 10px;
    }

    .select2-container--default .select2-selection--single {
        border-radius: 0px !important;
        height: 32px !important;
    }

    .swichuser-reporttable table tbody {
        border-top: 1px;
    }


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media screen and (max-width:570px) {

        .pageheader-margin-third {
            display: block;
            width: 100%;
            float: left;
        }

        .bread-same-all-page {
            width: 100%;
            margin: 2px 0;
        }

        .web-white-filter {
            width: 100%;
            margin: 2px 0;
        }


        .switch-user-tab-left .fund-transfer-form {
            padding-bottom: 20px;
            height: auto;
        }
    }

    @@media only screen and (max-width:480px) {

        .for-search.tablesearch-second {
            width: 100%;
            margin-right: 0px;
            margin-bottom: 3px;
        }

        .for-search input {
            width: 100%;
        }

        .switch-user-tab-left .nav-tabs > li > a {
            font-size: 13px;
        }
    }
</style>
