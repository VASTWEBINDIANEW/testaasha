                        </thead>
                        <tbody id="body">
                            @foreach (var item in Model.AmountRange)
                            {
                                <tr class="tr">
                                    <td>@item.maximum1</td>
                                    <td>@item.maximum2</td>
                                </tr>
                            }
                        </tbody>
                        <tbody id="bodyedit" style="display:none;">
                            @using (Html.BeginForm("Edit_prePaid_amountRange", "Home", FormMethod.Post))
                            {
                                for (int i = 0; i < Model.AmountRange.Count; i++)
                                {
                                    @Html.HiddenFor(aa => aa.AmountRange[i].idno)
                                    <tr class="tr">
                                        <td>
                                            @Html.EditorFor(a => a.AmountRange[i].maximum1, new { htmlAttributes = new { @style = "width:70px !important", @required = "true" } })
                                            @Html.ValidationMessageFor(a => a.AmountRange[i].maximum1)

                                        </td>
                                        <td>
                                            @Html.EditorFor(a => a.AmountRange[i].maximum2, new { htmlAttributes = new { @style = "width:70px !important", @required = "true" } })
                                            @Html.ValidationMessageFor(a => a.AmountRange[i].maximum2)

                                        </td>
                                        <td>
                                            <button id="btnsave" type="submit" class="btn  waves-effect btn-first" style="margin-left:5px; display:none;"> <img src="~/AdminDesign/images/edit.svg" style="width:13px;" />&nbsp;<span style="color:#3c3c3c;">Save</span></button>

                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
