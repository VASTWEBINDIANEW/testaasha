<script>
    $('#tabl_1').hide();
    function funcEdit() {
        $('#btnEdit').hide();
        $('#btnsave').show();
        $('#body').hide();
        $('#bodyedit').show();
        $('#tabl_1').show();
    }
</script>

<script>
    $(document).ready(function()
    {

        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }

    })



</script>
<script>
    var btnshowhidmastertext = "Report";
    $('#btnshowhidmaster_dlmComm').click(function () {
        var btntextvalue = $('#btnshowhidmaster_dlmComm').text();
        var role = $('#ddlusers').val();

        var urlsss = '@Url.Action("Commsion_Status_master_dlm_userwise", "Home")?userwise=' + role + '&btntextvalue=' + btnshowhidmastertext ;

        if (btnshowhidmastertext == "ShowStatus") {
               $('#tblshowmaster_dlm_comm_reports').hide()

               $("#tblshowMasterD").load(urlsss + " #tblshowMasterD");
               $('#btnshowhidmaster_dlmComm').text("Show Report")
               btnshowhidmastertext = "Report";
            $('#tblshowMasterD').show()
            $('#tblshowmaster_dlm_comm_reports').empty()

          }
           else {


               $("#tblshowmaster_dlm_comm_reports").load(urlsss + " #tblshowmaster_dlm_comm_reports");
            $('#btnshowhidmaster_dlmComm').text("Show Status")
            btnshowhidmastertext = "ShowStatus";
               $('#tblshowMasterD').hide()
               $('#tblshowmaster_dlm_comm_reports').show()

            $('#tblshowMasterD').empty()
           }


    })

    function changestats(idno, role,csts) {

         $.ajax({
            url: "@Url.Action("Commsion_Status_master_dlm_change")",
            type: "GET",
             data: { idno: idno, userwise: role, sts: csts },

             success: function (result) {

                 if (result == "success") {

                     var urlsss = '@Url.Action("Commsion_Status_master_dlm_userwise", "Home")?userwise=' + role + '&btntextvalue=ShowStatus' ;


                // var urlsss = '@Url.Action("Commsion_Status_master_dlm_userwise", "Home")?userwise=' + role;

                     $("#tblshowMasterD").load(urlsss + " #tblshowMasterD");
             }

                // $("#" + tabID).html(result);
            }
        });


    }


    $('#ddlusers').change(function () {
        var btntextvalue = $('#btnshowhidmaster_dlmComm').text();
        var role = $('#ddlusers').val();
        var urlsss = '@Url.Action("Commsion_Status_master_dlm_userwise", "Home")?userwise=' + role + '&btntextvalue=' + btnshowhidmastertext ;

        if (btnshowhidmastertext == "ShowStatus") {
            $('#tblshowmaster_dlm_comm_reports').hide()

            $("#tblshowMasterD").load(urlsss + " #tblshowMasterD");

            $('#tblshowMasterD').show()
        }
        else {


            $("#tblshowmaster_dlm_comm_reports").load(urlsss + " #tblshowmaster_dlm_comm_reports");

            $('#tblshowMasterD').hide()
            $('#tblshowmaster_dlm_comm_reports').show()

        }






