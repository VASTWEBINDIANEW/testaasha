                    <table class="table table-bordered table-striped table-hover third-design-table">
                        <thead>
                            <tr>
                                <th> <div class="maximum_amt" style="letter-spacing: 0.5px; line-height: 0;">Maximum Amount Range1</div> <br /> <div class="enter_the_1" style="font-size: 9px; line-height: 0;">Enter The Max Amount According Range One.</div></th>
