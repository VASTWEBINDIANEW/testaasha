<style>

    /* new css */
    .bread-same-all-page li {
        margin: 6px 0;
    }
    .width100.float-left.card {
        background: #fff !important;
    }

    .bkpfull .col-md-4 {
        float: left;
    }
    .bkpfull .col-md-8 {
        float: left;
    }
    
    /* new css */

    .custom-district1::before {
        border-color: #888 transparent transparent transparent;
        border-style: solid;
        border-width: 5px 4px 0 4px;
        height: 0;
        right: 7px;
        position: absolute;
        top: 13px;
        content: '';
    }

    .custom-district1 {
        position: relative;
    }

    .select2-selection.select2-selection--single {
        border-radius: 0px !important;
        height: 32px !important;
        border-color: #ccc !important;
    }
    .nillsearch-data .select2-selection.select2-selection--single, .nillsearch-data button {
        border-color: #7d7a7a !important;
    }
    .nillsearch-data button {
        width: 100% !important;
    }


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
        .bkpfull .col-md-4 {
            width:100%;
        }
        .bkpfull .col-md-8 {
            width: 100%;
        }
    }

    @@media screen and (max-width:766px) {
        .nillsearch-data .col-md-2.col-xs-12.buttonsearch-second {
            padding: 0;
            width: 15%;
        }
    }

    @@media screen and (max-width:766px){
        .nillcom-form .col-md-6.col-xs-12 {
            padding: 0;
        }
    }

    @@media screen and (max-width:480px){
        .nillcom-first ul {
            display: inherit !important;
        }
            .nillcom-first ul li {
                width: 33%;
                float: left;
            }
                .nillcom-first ul li:nth-child(3) {
                    border-right: 0px;
                }
                    .nillcom-first ul li:nth-child(3) ~ li {
                        width: 50%;
                        float: left;
                        border-top: 2px solid #fff;
                    }
    }

</style>

