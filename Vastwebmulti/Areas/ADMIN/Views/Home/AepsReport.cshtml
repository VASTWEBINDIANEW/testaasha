<script>
    function success()
    {

        var bankrrn = $('#BankRRN').val();
        var trans_id =$('#trans_id').val();
        var Remark =$('#Remark').val();
        if (bankrrn == null || bankrrn == '')
        {
            swal("RRN?", 'Hit check status to update RRN first.', "error");
            return false;
        }
        var answer = confirm('Are you sure ?');
        if(answer)
        {
            $.ajax({
                url: '@Url.Action("AEPSsucess", "Home")',
                type: 'POST',
                dataType: "html",
                data: { trans_id: trans_id, RRN: bankrrn, terminalID: '', Remark: Remark },
                success: function (data) {
                    var response = JSON.parse(data);
                       if (response.Status) {
                           swal("Good Job", response.Message, "success");
                           window.location.reload();
                           reloadPageeee();
                    }
                    else {
                        swal("Oops...", response.Message, "error");
                    }
                },
                error: function (data) {
                    swal("Oops...", response.Message, "error");
                }
            });
            return true;
        }
        else {
            $("#defaultModal2").modal('hide');
            return false;
        }
    }
    function checkStaus(txnid)
    {
        
        $.ajax({
            url: '@Url.Action("AepsStatus", "Home")',
            type: 'POST',
            dataType: "json",
            data: { txnid: txnid },
            success: function (data) {
                var response = JSON.parse(data);
                if (response.Status =="Success") {
                    swal("Good Job", response.Message, "success");
                    window.location.reload();
                    //reloadPageeee();
                }
                else {
                    swal("Oops...", response.Message, "error");
                }
                //alert(response.Message);
            },
            error: function (data) {
            }
        }).done(function () {
            $("#defaultModal2").modal('hide');
        });
    }
</script>

