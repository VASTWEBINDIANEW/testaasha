
@{
    ViewBag.Title = "PushNotification";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}

<style type="text/css">
    .loadermoney {
        position: fixed;
        left: 0px;
        top: 0px;
        width: 100%;
        height: 100%;
        z-index: 199999;
        background: url('../../images/smsload.gif') 50% 50% no-repeat rgba(249, 249, 249, 0.9);
    }
     [type="checkbox"].filled-in:not(:checked) + label:after
    {
        background-color:#f5f5f5;
        border:2px solid #dddddd;
    }
</style>
<div id="loadermoney" class="loadermoney" style="display:none;"></div>
<section class="content tmw-push-notification">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card" style="margin-top:-4px;">
                    <div class="row">
                        <div class="col-md-6">
                          <div style="margin-left:2px;">
                              @Html.Partial("Notificationmenu")
                          </div>
                        </div>
                        <div class="col-md-6 top-three">
                            <div class="row">
                                <div class="col-md-4">
                                </div>
                           
                                <div class="col-md-2">
                                    <button type="button" class="btn" onclick='selectAll()'>
                                        <span>Check All</span>
                                    </button>
                                </div>
                                <div class="col-md-2">
                                    <button type="button" class="btn" onclick='UnSelectAll()'>
                                        <span>Uncheck All</span>
                                    </button>
                                </div>
                                <div class="col-md-2">
                                    <button type="button" id="SaveAll" class="btn" onclick='this.form'>
                                        <span>Save Changes</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-md-12">
                <!--User Create-->
                <div class="card">
                    <div class="" style="background-color:#bababa;">
                        <ol class="breadcrumb breadcrumb-col-blue-grey" style="margin-left:5px;margin-top:9px;">
                            <li class="active" style="color:#fff; font-size:12px;">SET WEB PUSH NOTIFICATION STATUS&nbsp;></li>
                        </ol>
                    </div>
                   
                         <div class="row clearfix">
                             <div class="col-md-12">
                                 <div class="demo-checkbox">
                                   <div class="col-md-2">
                                   </div>



                                     <div class="col-md-8">



                                         <div class="row sam">
                                             <div class="col-md-7">
                                                 <span>Admin Web Notification </span>
                                             </div>
                                             <div class="col-md-5">
                                                 <input type="checkbox" id="Admin" value="Admin" class="filled-in chk-col-red" name="acs">
                                                 <label for="Admin"></label>
                                             </div>
                                         </div>


                                         <div class="row sam">
                                             <div class="col-md-7">
                                                 <span>Master Web Notification</span>
                                             </div>
                                             <div class="col-md-5">
                                                 <input type="checkbox" id="Master" value="Master" class="filled-in chk-col-red" name="acs">
                                                 <label for="Master"></label>
                                             </div>
                                         </div>



                                         <div class="row sam">
                                             <div class="col-md-7">
                                                 <span>Distributor Web Notification</span>
                                             </div>
                                             <div class="col-md-5">
                                                 <input type="checkbox" id="Distributor" value="Distributor" class="filled-in chk-col-red" name="acs">
                                                 <label for="Distributor"></label>
                                             </div>
                                         </div>



                                         <div class="row sam">
                                             <div class="col-md-7">
                                                 <span>Retailer Web Notification</span>
                                             </div>
                                             <div class="col-md-5">
                                                 <input type="checkbox" id="Retailer" value="Retailer" class="filled-in chk-col-red" name="acs">
                                                 <label for="Retailer"></label>
                                             </div>
                                         </div>



                                         <div class="row sam">
                                             <div class="col-md-7">
                                                 <span>API User Web Notification</span>
                                             </div>
                                             <div class="col-md-5">
                                                 <input type="checkbox" id="ApiUser" value="ApiUser" class="filled-in chk-col-red" name="acs">
                                                 <label for="ApiUser"></label>
                                             </div>
                                         </div>
                                   
                                     </div>



                                     <div class="col-md-2">

                                     </div>
                                 </div>  
                             </div>
                                     
                    </div>
                </div>
                <!--End-->
            </div>
        </div>
    </div>
</section>
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<!-- Demo Js -->
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>

<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<script src="~/Swalalert/sweetalert-dev.js"></script>

