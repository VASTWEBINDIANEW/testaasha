    <script type="text/javascript">
    function GetMailList() {
            $.ajax({
            url: '@Url.Action("GetEmailbyId", "Home")',
            type: 'POST',
                data: { idno: 0 },
                success: function (data) {

                    var i = 1;
                    var mdtblHtml = "";
                    $.each(data, function (a, b) {
                        var idno = "subTbl";
                        idno = idno + i;

                        var btnOnOff = "";
                        if (b.Enablessl == "true") {
                            btnOnOff = "<div class='onoffswitch'><span class='costom-on'  onclick=sslOnOff('" + b.idno + "')>ON</span></div>";
                        }
                        else {
                            btnOnOff = "<div class='onoffswitch'><span class='custom-off' onclick=sslOnOff('" + b.idno + "')>OFF</span></div>";
                        }

                        mdtblHtml += "<tr><td style ='border: 1px solid !important;'><p><span style='background: #bbb; font-size: 10px; padding: 0px 5px; margin-right: 2px;'>" + i + "</span>" + b.Smpthost + "</p><p>" + b.Email + "</p></td>";
                     /*   mdtblHtml += "<td style ='border: 1px solid !important;'>********</td>";*/
                        mdtblHtml += "<td style ='border: 1px solid !important;'>" + btnOnOff + "</td>";
                        mdtblHtml += "<td style ='border: 1px solid !important;'><button style='height: 24px; float: left; padding: 0px 3px; background: #f0f0f0; border: 1px solid #bfbebe; margin - left: 2px;' onclick=editBussMail('" + b.idno + "')>Edit</button><button style='height: 24px; float: left; padding: 0px 3px; background: #f0f0f0; border: 1px solid #bfbebe; margin - left: 2px;' onclick=delBussMail('" + b.idno + "')>Del</button></td>";
                        "</td>";
                        "</tr>";
                        i++;
                    });

                    $('#maillist > tbody').html(mdtblHtml);
            }
        });
    }


    function BussMail() {
            $.ajax({
            url: '@Url.Action("Email_Security", "Home")',
            type: 'POST',
            data: { SMTPHost: $('#SMTPHost').val(), EmailID: $('#EmailID').val(), Paswrd: $('#Paswrd').val(), Port: $('#Port').val() },
                success: function (data) {
                    if (data.status == "Success") {

                        GetMailList();
                        ToastrMessage();
                        toastr.success(data.Message);
                    }
                    else {
                        ToastrMessage();
                        toastr.error(data.Message);
                    }

                    $('#SMTPHost').val('');
                    $('#EmailID').val('');
                    $('#Paswrd').val('');
                    $('#Port').val('');
            }
        });
    }

    function delBussMail(idno) {
            $.ajax({

            url: '@Url.Action("DeleteEmail", "Home")',
            type: 'POST',
            data: { idno: idno },
                success: function (data) {
                    if (data.status == "Success") {

                        GetMailList();
                        ToastrMessage();
                        toastr.success(data.Message);
                    }
                    else {
                        ToastrMessage();
                        toastr.error(data.Message);
                    }
            }
        });
    }

    function sslOnOff(idno) {
            $.ajax({

            url: '@Url.Action("Email_enablessl", "Home")',
            type: 'POST',
            data: { id: idno },
                success: function (data) {
                    if (data.status == "Success") {
                        if (data.Message == "SSL True") {
                            GetMailList();
                            ToastrMessage();
                            toastr.success(data.Message);
                        }
                        else {
                            if (data.Message == "SSL False") {
                                GetMailList();
                                ToastrMessage();
                                toastr.error(data.Message);
                            }
                        }
                    }
                    else {
                        ToastrMessage();
                        toastr.error(data.Message);
                    }
            }
        });
    }

    function editBussMail(idno) {
            $.ajax({
            url: '@Url.Action("GetEmailbyId", "Home")',
            type: 'POST',
                data: { idno: idno },
                success: function (data) {
                    $('#EditBtnidno').val(data.idno);
                    $('#SMTPHost').val(data.Smpthost);
                    $('#EmailID').val(data.Email);
                    $('#Paswrd').val(data.Password);
                    $('#Port').val(data.Port);

                    $('#AddMBtn').css('display', 'none');
                    $('#EditBtn').css('display', 'block');
            }
        });
    }

    function editSaveMail() {
            $.ajax({

            url: '@Url.Action("Edit_Email_Security", "Home")',
            type: 'POST',
                data: { idno: $('#EditBtnidno').val(), SMTPHost: $('#SMTPHost').val(), EmailID: $('#EmailID').val(), Paswrd: $('#Paswrd').val(), Port: $('#Port').val() },
                success: function (data) {

                    if (data.status == "Success") {

                        GetMailList();
                        ToastrMessage();
                        toastr.success(data.Message);
                    }
                    else {
                        ToastrMessage();
                        toastr.error(data.Message);
                    }

                    $('#EditBtnidno').val('');
                    $('#SMTPHost').val('');
                    $('#EmailID').val('');
                    $('#Paswrd').val('');
                    $('#Port').val('');

                    $('#AddMBtn').css('display', 'block');
                    $('#EditBtn').css('display', 'none');
            }
        });
    }
