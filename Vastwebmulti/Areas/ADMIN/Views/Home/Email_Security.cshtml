    <script type="text/javascript">
    $(function () {
        $("#SaveAll").click(function () {
            //if ($('#bysim2').is(':checked')) {
                //alert("it's checked Email");
                var optCode = []
                $(".for-mail input:checkbox(:checked)").each(function () {
                    if ($(this).prop('checked') == true) {
                        optCode.push($(this).val() + ",Y");
                    }
                    if ($(this).prop('checked') == false) {
                        optCode.push($(this).val() + ",N");
                    }
