    <script>
        function onlyNumberKey(evt) {

            // Only ASCII charactar in that range allowed
            var ASCIICode = (evt.which) ? evt.which : evt.keyCode
            if (ASCIICode > 31 && (ASCIICode < 48 || ASCIICode > 57))
                return false;
            return true;
        }

        function UpdateCC() {

            $.ajax({
                type: "POST",
                url: '@Url.Action("UpdateCC", "Home")',
                data: { CCmail: $("#tocc").val() },
                cache: false,
                dataType: 'json',
                cache: false,
                success: function (data) {
                    if (data == "Success") {
                        toastr.success("Your CC mail is Update Successfully.")
                        $("#tocc").val('')

                        $("#showdivv").css('display', 'none');
                        $("#btnnshow").css('display', 'block');
                    }
                    else {
                        toastr.error(data);
                    }
                }
            });
        }
        $("#btnnshow").click(function () {
            $("#showdivv").css('display', 'block');
            $("#btnnshow").css('display', 'none');
        });
    </script>