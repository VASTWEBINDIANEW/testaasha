        background: var(--second-bg-color);
        overflow: scroll;
        overflow-x: hidden;
        padding: 0px 10px;
    }

        .for-mail .card {
            background: transparent;
        }

    .tt-right-table [type="checkbox"].filled-in:checked.chk-col-red + label::after {
        border: 2px solid var(--main-bg-lcolor);
        background-color: var(--main-bg-lcolor);
    }



    ul.smssetting-top li button span {
        top: -2px !important;
        font-size: 12px;
    }

    ul.smssetting-top li {
        padding-left: 0;
        margin-right: 0 !important;
    }

    .tt-right-table [type="checkbox"].filled-in:checked + label::before {
        top: -1px;
        left: 0px;
    }

    .tt-right-table [type="checkbox"].filled-in:checked + label::after {
        top: 0;
        width: 18px;
        height: 18px;
    }

    .tt-right-table [type="checkbox"].filled-in:not(:checked) + label::after {
        height: 18px;
        width: 18px;
    }

    .tmw-email-securty .left-table tr td {
        border: 0px !important;
        background: transparent;
        padding: 0px !important;
    }

        .tmw-email-securty .left-table tr td .form-control {
            height: 32px;
        }

    .tmw-email-securty .left-table .for-table-one table tr td {
        padding: 5px !important;
    }

    .special-iii .custom-date-icon, .custom-date-icon {
        position: absolute;
        left: 0px;
        z-index: 9;
        top: 0px !important;
        background: transparent;
        height: 24px;
        width: 30px;
        border: 1px solid #bbb;
    }

    .cc_email_se {
        width: 21%;
        float: left;
        display: flex;
    }

    input#tocc {
        border: 1px solid #ddd;
        background-color: #b1a6a638;
        color: #000;
    }

    span.cc_email {
        font-size: 12px;
        padding-left: 3px;
        vertical-align: middle;
        color: #fff;
        font-weight: 600;
    }

    #element a {
        color: #fff !important;
    }

    .page-header-third .pageheader-second-third {
        padding: 6px !important;
    }

    .bread-same-all-page a {
        font-size: 15px;
        color: #000;
        float: left;
        font-weight: normal;
        margin-left: 3px;
    }

    .special-iii .custom-date-icon, .custom-date-icon {
        position: absolute;
        left: 0px;
        z-index: 9;
        top: 0px !important;
        background: transparent;
        height: 27px;
        width: 30px;
        border: 1px solid #bbb;
    }

        .special-iii .custom-date-icon i, .custom-date-icon i {
            top: 4px !important;
            position: absolute;
            left: 8px;
            background-color: #fff;
        }

    #SearchEmailHistory {
        height: 27px;
    }


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media only screen and (max-width:460px) {

        .bread-same-all-page {
            display: block;
        }

