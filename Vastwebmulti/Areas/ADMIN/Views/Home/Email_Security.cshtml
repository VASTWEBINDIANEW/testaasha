                background: transparent;
                width: 100%;
                padding: 0px 5px;
                margin-right: -2px
            }

        ul.smssetting-top #SaveAll img {
            width: 15px;
            margin-top: -3px;
        }

        ul.smssetting-top #SaveAll span {
            color: #fff;
        }

        ul.smssetting-top li button i {
            top: 2px !important;
        }

    .for-mail {
