@model IEnumerable<Vastwebmulti.Models.proc_failed_Move_Result>
@{
    ViewBag.Title = "FailedMove";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style>
   /* new css  */
    #ul li {
        width: 15%;
    }
    #ul {
        display: flex;
        justify-content: space-between;
    }
    .vacrivet {
        padding: 0px 4px;
    }



   /* new css  */


    .col-md-5 for-r-width {
        width: 30.666667%;
    }

    .col-md-5 {
        /* width: 41.66666667%;*/
        padding-left: 4px;
        padding-right: 0;
    }

    .for-r-width .row {
        display: flex;
        padding: 0;
        justify-content: end;
    }

    .rtyfrty.rtyfrtyclass-third {
        padding: 0;
    }






    .dropdown-menu {
        margin-top: 81px !important;
    }

    .form-inline .bootstrap-select.btn-group, .form-horizontal .bootstrap-select.btn-group, .form-group .bootstrap-select.btn-group {
        height: 29px;
    }

    .select2-selection.select2-selection--single {
        border-radius: 0px !important;
        height: 34px !important;
        border-color: #ccc !important;
    }

    .form-control-label {
        text-align: left;
    }

        .form-control-label label {
            margin: 0px;
            border: 1px solid #dddddd;
            border-right: 0px;
            height: 34px;
            padding: 8px 0px;
            width: 100%;
            text-align: left;
            padding-left: 5px;
            font-size: 12px;
            background: #f5f5f5;
        }

    .form-group {
        margin-bottom: 0px;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 32px !important;
    }

    .bread-same-all-page li {
        margin: 6px 0px;
    }


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media screen and (max-width: 992px) {
        .rtyfrty {
            width: 100%;
            float: left;
        }

        .for-r-width {
            width: 100%;
        }

        .rtyfrty ul li {
            width: 33.3333%;
            float: left;
            margin-bottom: 10px;
            margin-right: 0px !important;
        }

            .rtyfrty ul li a {
                margin-bottom: 0;
            }

        .vacrivet {
            width: 50%;
            float: left;
            padding: 0 4px !important;
        }

