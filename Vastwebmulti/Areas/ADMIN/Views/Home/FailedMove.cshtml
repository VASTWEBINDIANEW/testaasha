            width: 50% !important;
        }

        .for-r-width .col-xs-5 {
            width: 100%;
            padding: 0px 5px;
        }

        .for-r-width .col-xs-2 {
            width: 100%;
            float: right;
            padding: 0px 0px !important;
        }

            .for-r-width .col-xs-2 button {
                width: 100%;
                margin: 0px !important;
                margin-top: 2px !important;
            }
