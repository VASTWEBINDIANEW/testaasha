<script>
    function Deletedata(idno) {
        $('#lblmsg').text('')
        $.ajax({
            url: '@Url.Action("deleteSelefUpiSelf", "Home")',
            type: 'POST',
            data: { upiid: idno },
            success: function (response) {
                debugger;

                $('#RemTbl222').html(response);

                $(".classshow11").show();
                $(".tbladdbtnshow").show();
                $(".classhide11").hide();
                $(".sendotphide").hide();
                $(".clsupiaddhide").hide();

            },
            error: function () {
                //alert(error);
            }
        });
    }
    function Activeset(idno) {
        $('#lblmsg').text('')
        $.ajax({
            url: '@Url.Action("ActiveUpiSelf", "Home")',
            type: 'POST',
            data: { upiid: idno },
            success: function (response) {
                $('#RemTbl222').html(response);

                $(".classshow11").show();
                $(".tbladdbtnshow").show();
                $(".classhide11").hide();
                $(".sendotphide").hide();
                $(".clsupiaddhide").hide();

            },
            error: function () {
                //alert(error);
            }
        });
    }



</script>

