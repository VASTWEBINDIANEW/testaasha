<style>
    #ul {
        list-style-type: none;
        margin: 0;
        padding: 0;
        overflow: hidden;
        /*background-color: #e91e63;*/
    }

        #ul li {
            float: left;
            border: 1px solid #b5b7b7;
        }

            #ul li a {
                display: block;
                text-align: center;
                padding: 8px 10px;
                text-decoration: none;
                border: 1px solid #b1a6a6;
            }

                #ul li a:hover:not(.activee) {
                    background-color: #FFC107;
                    color: black;
                    font-weight: 600;
                    border: 1px solid #b1a6a6;
                }

    .activee {
        background-color: #000000;
        color: white;
        border: 1px solid #b1a6a6;
    }

        .activee:hover {
            color: white;
            border: 1px solid #00000026;
            border: 1px solid #000000;
        }
</style>

<div >
