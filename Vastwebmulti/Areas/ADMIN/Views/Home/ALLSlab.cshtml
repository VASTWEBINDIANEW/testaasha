<!------------all select value change------------->
<script>
    function changeclass(value) {
        if (value == 1) {

            $(".slab-master-message-show").css("display", "block");
            $(".slab-master-detail-hide").css("display", "none");
        } else {
            $(".slab-master-message-show").css("display", "none");
            $(".slab-master-detail-hide").css("display", "block");

        }

    }
    function changeclassd(value) {
        if (value == 1) {

            $(".slab-distributor-detail-hide").css("display", "none");
            $(".slab-distributor-message-show").css("display", "block");
        } else {
            $(".slab-distributor-detail-hide").css("display", "block");
            $(".slab-distributor-message-show").css("display", "none");
        }

    }

    function changeclassr(value) {
        if (value == 1) {

            $(".slab-retailer-detail-hide").css("display", "none");
            $(".slab-retailer-message-show").css("display", "block");
        } else {
            $(".slab-retailer-detail-hide").css("display", "block");
            $(".slab-retailer-message-show").css("display", "none");
        }

    }

    function changeclassa(value) {
        if (value == 1) {

            $(".slab-api-detail-hide").css("display", "none");
            $(".slab-api-message-show").css("display", "block");
            $(".api-day-limit").css("display", "none");
        } else {
            $(".slab-api-detail-hide").css("display", "block");
            $(".slab-api-message-show").css("display", "none");
            $(".api-day-limit").css("display", "block");
        }

    }

    function changeclassw(value) {
        if (value == 1) {

            $(".slab-white-detail-hide").css("display", "none");
            $(".slab-white-message-show").css("display", "block");
        } else {
            $(".slab-white-detail-hide").css("display", "block");
            $(".slab-white-message-show").css("display", "none");
        }

    }


</script>

