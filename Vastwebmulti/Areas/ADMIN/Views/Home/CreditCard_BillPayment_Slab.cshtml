<section class="content fourdesign-section-admin">
    <div id="loadermoney" class="loadermoney" style="display:none;"></div>
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>Commission</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Basic Setting&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Commission</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->
        @*<div class="row clearfix">
            <div class="col-md-12">
                <div class="card" style="margin-bottom:2px;">
                    <div class="row">
                        <div class="col-md-12">
                            @Html.Partial("_ApislabSetting")
                        </div>
                    </div>

                    </div>
                </div>
            </div>*@
        <div class="row clearfix">
            <div class="col-md-12">
                @Html.Partial("_Slab_Menu")
                <div class="col-md-10 slab-first-tab-content">
                    <div class="row clearfix">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                            <div class="card">
                                <div class="header" style="width:auto;">
                                    <div class="row">
                                        <div class="all-slab-header all-slab-header-second slab-btn-second allbuttonclicknon page-header-third" style="float:left;">
                                            @using (Html.BeginForm("CreditCard_BillPayment_Slab", "Home", FormMethod.Post))
                                            {
                                                <div class="col-sm-5">
                                                    <div class="form-group">
                                                        @Html.DropDownList("DealerId", ViewBag.DealerId as SelectList, "Select dealer", new { @class = "form-control country-dropdown", onchange = "SelectDealer(this)" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-5">
                                                    <div class="form-group">
                                                        @Html.DropDownList("RetailerId", Enumerable.Empty<SelectListItem>(), "Select retailer", new { @class = "form-control country-dropdown" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-2">
                                                    <div class="form-group">
                                                        <input type="submit" name="name" value="Search" class="btn fullbodydycolorbg" style="color: white;" />
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <div class="all-slab-header all-slab-header-second slab-btn-second allbuttonclicknon page-header-third p_range" style="float:right;">
                                            <div id="box" class="col-md-12" style="display: none;">
                                                <div class="row">
                                                    @using (Html.BeginForm("UpdateCreditCardBillpaymentAllUser", "Home", FormMethod.Post))
                                                    {
                                                        <div class="col-md-8">
                                                            <input class="form-control" type="number" step="any" name="AllCharge" value="0.00" />
                                                        </div>
                                                        <div class="col-md-4">
                                                            <input class="btn  waves-effect fullbodydycolorbg" type="submit" style="color: white;" />
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                            <button id="EditSlabAll" onclick="togglePopup()" class="fullbodydycolorbg for-button-upi back-button-third" style=" margin-right: 2px;color: #fff; padding: 7px 6px !important;width:auto; border: 1px solid #bfbebe; background: #f0f0f0 !important; color: #777; "><i style=' padding-right: 6px; font-size: 14px;' class='fas'>&#xf543;</i>Edit All User Slab</button>
                                            <button id="EditSlab" type="button" class="btn  waves-effect btn-first" style="margin-left: 2px; width: auto; display: inline-block; padding: 4px !important;" onclick="EditSlab()"> <img src="~/AdminDesign/images/edit.svg" style="width:13px;" />&nbsp;<span style="color: #3c3c3c; top: 1px !important; margin-left: 0px !important;">Edit Slab</span></button>
                                            <input id="SaveSlab" type="submit" value="Save Slab" class="btn  waves-effect" style="display: none !important;" />
                                        </div>
                                    </div>
                                </div>
                                <div class="table-responsive tablefourdesign-admin table-respo11" style="margin-top: 10px;">
                                    <div id="divEditFormComm" class="slab-edit-table table-responsive" style="position:inherit;">
                                        <div class="slab-table">
                                            <table class="table table-bordered example-second third-design-table" style="">
                                                <thead class="navbar" style="position:initial;">
                                                    <tr>
                                                        <th style="text-align:center">FrmName</th>
                                                        <th style="text-align:center">Charge</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @using (Ajax.BeginForm("UpdateCreditBillPaymentCartCharges", "Home", new AjaxOptions { HttpMethod = "POST", InsertionMode = InsertionMode.Replace }, new { id = "chargesForm" }))
                                                    {
                                                        if (Model.Count > 0)
                                                        {
                                                            foreach (var item in Model)
                                                            {
                                                                <tr>
                                                                    <td>@item.Frm_Name</td>
                                                                    <td>
                                                                        <input type="hidden" name="RetailerId" value="@item.RetailerId" />
                                                                        <input class="ReadOnlyInput" step="any" style="width: 80px;" type="number" name="Charges" value="@item.Charge" readonly />
                                                                    </td>
                                                                </tr>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <tr>
                                                                <td colspan="2" style="text-align:center;"><h3>No data found</h3></td>
                                                            </tr>
                                                        }
                                                    }
                                                </tbody>

                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    $(document).ready(function () {
        $("#SaveSlab").click(function () {
            $("#chargesForm").submit();
        });
    });
     function SelectDealer(dealer) {
        var selectedValue = dealer.value;
        $.ajax({
           type: "GET",
           url: '@Url.Action("GetRetailer", "Home")',
           data: { dealerId: selectedValue },
           success: function (data) {
               var selectElement = $('#RetailerId');
               for (var i = 0; i < data.retailer.length; i++) {
                   var retailer = data.retailer[i];
                   selectElement.append(`<option value="${retailer.Value}">${retailer.Text}</option>`);
               }
           },
           error: function (error) {
               console.log('Error:', error);
           }
        });
    }
    function EditSlab() {
        var inputs = document.querySelectorAll('input[name="Charges"]');
        inputs.forEach(function (input) {
            input.removeAttribute('readonly');
        });
        document.getElementById('SaveSlab').style.display = 'block';
        document.getElementById('EditSlabAll').style.display = 'none';
        document.getElementById('EditSlab').style.display = 'none';
    }
    function togglePopup() {
        document.getElementById('box').style.display = 'block';
        document.getElementById('EditSlabAll').style.display = 'none';
        document.getElementById('EditSlab').style.display = 'none';
        document.getElementById('SaveSlab').style.display = 'none';
    }
</script>
