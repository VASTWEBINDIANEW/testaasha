<style>
    /* new css */
    section.content {
        margin: 75px 0px 0 180px;
    }

    .body_sidebar_menu span {
        background: #000 !important;
        border-radius: 6px;
        color: #fff;
        cursor: pointer;
        width: 50px;
        float: left;
        height: 42px;
    }
    
    .tablinks a {
        cursor: pointer !important;
    }
    .disablevalue {
        width: 50%;
        float: left;
    }   

    .disablevalue {
        padding: 7px 10px;
        background: #ddd;
        color: #555;
    }
    .reffael-fullseting select.form-control {
        width: 50%;
        float: left;
    }

    .reffael-fullseting button.reffralactivedeacrt {
        float: right;
        padding: 7px 14px !important;
        text-align: center;
        border: 0;
        font-weight: bold;
    }

    .classfullsavechange button {
        width: 100%;
        float: left;
        margin-top: 30px;
        border: 0 !important;
        background: #d3d3d3;
        width: 100%;
        border-radius: 30px !important;
        height: 40px !important;
    }

    p.prag_1 {
        font-size: 9px;
        padding-right: 0px;
        font-weight: 500;
        padding-top: 2px;
    }

    p.prag_2 {
        position: absolute;
        top: 10px;
        right: 5px;
        font-size: 14px;
        color: #000;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 1.4px;
    }

    .butttuno_2 {
        width: auto;
        height: 22px;
        float: left;
        border: 1px #ddd solid;
        margin-left: 5px;
        margin-top: 3px;
        text-align: center;
        color: #000;
        padding: 0px 3px;
    }

    #refferalsetinpartial {
        height: 29px;
        margin-right: 4px;
    }

    div#refferalsetinpartial button {
        width: 137px;
        height: 29px;
        border: 1px solid #ddd;
        text-align: end;
        padding-right: 5px;
        position: relative;
    }

    .bkp:hover .dropdown-submenu {
        visibility: visible;
        opacity: 1;
        transform: translateY(0);
        top: 34px;
        border-top: 0;
    }

    .bkp.seventd {
        float: left;
        position: relative;
    }

    .dropdown-submenu {
        background: #fff;
        width: 200px;
        display: block;
        float: left;
        position: absolute;
        top: 51px;
        left: 2px;
        transform: translateY(25px);
        visibility: hidden;
        opacity: 0;
        transition: 0.4s linear;
        padding: 10px 15px;
        border: 1px solid #ccc;
        font-size: 14px;
        text-transform: capitalize;
        font-weight: 300;
        z-index: 9999;
    }

        .dropdown-submenu::before, .custum-dropdown::before {
            border-style: solid;
            border-width: 0 6px 6px;
            content: "";
            height: 0;
            position: absolute;
            left: 1em;
            top: -6px;
            width: 0;
            z-index: 9999;
            border-color: transparent transparent #fff;
            display: block;
        }

    .all_page_alert {
        position: absolute;
        top: 109px;
        z-index: 99;
        right: 15px;
        display: none;
        padding: 10px;
    }

    .res_div {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .res_div svg:hover + .all_page_alert {
            display: block;
        }

        .res_div svg {
            width: 23px;
            color: #000;
            margin-left: 8px;
            cursor: pointer;
        }

    .retailerlist-header-resp {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .refferal-type-left, .refferal-type-right {
        height: 400px;
    }

    .bread-same-all-page {
        width: auto;
    }

    .refferal-type ul li {
        border-bottom: 2px solid #eaeaea;
    }

    .switch-history-table {
        background: #fff;
    }

    .fund-transfer-form {
        background: #fff;
    }

    /* new css */


    .table-responsive {
        min-height: .01%;
        overflow-x: inherit;
        height: 75vh;
        overflow: overlay !important;
    }

    .tab-link.active::after {
        content: '';
        width: 100%;
        border-bottom: 2px solid #000;
        display: block;
    }

    .ulbussnessnotshow input, .ulbussnessnotshow select, .ulpurchasenotshow select, .ulpurchasenotshow input {
        padding: 4px 10px;
        border: 0px;
        width: 150px;
    }


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }

        .modal-dialog {
            margin: 0;
        }
    }

    @@media only screen and (max-width:480px) {
        .switch-history-table .table-responsive > .table-bordered > thead > tr > th:first-child {
            border-left: 1px solid var(--border-color);
        }

        .switch-user-tab-right .nav-tabs li a {
            height: 61px;
        }
    }
</style>

