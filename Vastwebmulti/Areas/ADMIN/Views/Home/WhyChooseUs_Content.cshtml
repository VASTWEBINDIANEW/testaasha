                <h4 class="modal-title" id="defaultModalLabel" style="color:black;">Add Why Choose Us All Content</h4>
            </div>
            @using (Html.BeginForm("WhyChooseUs_Content", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
            {
                <div class="modal-body" style="margin-top:0px;">
                    <div class="body">
                        <form>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Enter Service Name</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #c7c2c2;">
                                            <input type="text" id="txtname" name="txtname" maxlength="30" class="form-control" placeholder="Enter Provided Service Name " />
