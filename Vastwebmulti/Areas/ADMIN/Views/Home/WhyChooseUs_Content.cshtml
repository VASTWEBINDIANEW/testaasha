                             </h2>
                             <button type="button" class="btn  waves-effect" style="float:right; margin-top:-34px;margin-right:6px;border:1px solid #c7c2c2;background:#dedddd;" data-toggle="modal" data-target="#defaultModal1">
                                 <i class="fa fa-plus" style="top:1px;font-size:15px;"></i>
                                 <span style="top:0px;">Add New</span>
                             </button>
                   
                         </div>
                         <div class="body">
                             <div class="row">
                                 <div class="table-responsive" style="position:inherit;margin-top:-20px;">
                                     <table class="table table-bordered table-striped table-hover dataTable js-exportable ">
                                         <thead style="background-color:whitesmoke;">
                                             <tr>
                                                 <th>Name</th>
                                                 <th>Image&nbsp;content</th>
                                                 <th>Image</th>
                                                 <th>Edit</th>
                                                 <th>Delete</th>
                                                 <th>View Image</th>
                                             </tr>
                                         </thead>
                                         <tbody>
                                             @foreach (var item in ViewBag.allcontent)
                                             {
                                                 <tr>
                                                     <td>@item.Name</td>
                                                     <td>@item.Imagecontent</td>
                                                     <td><img src="@Url.Content("~/"+item.Image)" width="100" height="70" /></td>
                                                     <td>
                                                         <a class="btn btn-default waves-effect" href='@Url.Action("Edit_WhyChooseUsData", "Home", new {WhyChooseUsDataid = item.Id})' style="border:1px solid #c7c2c2;">
                                                         Edit
                                                         </a>
                                                     </td>
                                                     <td>
                                                         <button type="button" class="btn btn-default waves-effect" style="background-color:transparent; border:none;border:1px solid #c7c2c2;" onclick="delallcontent('@item.Id')">
                                                            Delete
                                                         </button>
                                                     </td>
                                                     <td>
                                                         <a class="btn btn-default waves-effect" href="@Url.Content("~/" + item.Image)" style="border:1px solid #c7c2c2;" target="_blank">
                                                             View
                                                         </a>
                                                     </td>
                                                 </tr>
                                             }
                                         </tbody>
                                     </table>
                                 </div>
                             </div>
                             
                         </div>
                     </div>
                 </div>
             </div>
