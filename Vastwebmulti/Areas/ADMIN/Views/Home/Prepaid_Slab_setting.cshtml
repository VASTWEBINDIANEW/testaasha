                                        @foreach (var item in Model.AmountRange)
                                        {
                                            <tr class="tr">
                                                <td>@item.maximum1</td>
                                                <td>@item.maximum2</td>
                                                <th>
                                                    <button id="btnEdit1" type="button" class="btn  waves-effect btn-first" style="margin-left: 5px;" onclick="funcEdit1()"> <img src="~/AdminDesign/images/edit.svg" style="width:13px;" />&nbsp;<span style="color:#3c3c3c;">Edit</span></button>
