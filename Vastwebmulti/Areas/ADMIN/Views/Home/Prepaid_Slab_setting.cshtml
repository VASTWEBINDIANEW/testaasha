                             dataType: 'json',
                             async: true,
                             success: function (data) {
                                 var pp = data.status;
                                 var mm = data.Message;

                                 if (pp) {
                                     document.getElementById("loadermoney").style.display = "none";
                                     toastr.success('Recharge Slip Mode Successfully Blocked', 'Recharge Slip Block');
                                 }
                                 else {
                                     toastr.error(mm, 'Recharge Slip Block Error');
                                 }

                             }
                         });

            });

                        function loadRechargeSlipBlockStatus() {
                 $.ajax({
                    type: "GET",
                    url: '@Url.Action("Check_Unchek_Recharge_slip_Setting", "Home")',
                    cache: false,
                    dataType: 'json',
                    async: true,
                    success: function (data) {
                        var obj = data;

                        for (var item in obj) {
                            var sts = obj[item].status;
                            var name = obj[item].Upi_Mode;
                            if (sts == "Y") {
                                $("#" + name + "").prop("checked", true);
                            }
                        }
                    }
                });
            }
            });
    </script>

