<!--Manual SUCCESS -->
<script>
    function success(trans_id, bank_trans_id, recivername,status)
    {
        var answer = confirm('Are you sure ?');
        if(answer)
        {
            $.ajax({
                //url: '@Url.Action("Moneysucess", "Home")',
                url: '@Url.Action("IndoNepalsucess", "Home")',
                type: 'POST',
                dataType: "html",
                data: { trans_id: trans_id, bank_trans_id: bank_trans_id, recivername: recivername, currentstatus: status },
                success: function (data) {
                    var response = JSON.parse(data);
                       if (response.Status) {
                           swal("Good Job", response.Message, "success");
                           window.location.reload();
                           reloadPageeee();
                    }
                    else {
                        swal("Oops...", response.Message, "error");
                    }
                },
                error: function (data) {
                }
            });
            return true;
        }
        else {
            return false;
        }
    }
</script>

