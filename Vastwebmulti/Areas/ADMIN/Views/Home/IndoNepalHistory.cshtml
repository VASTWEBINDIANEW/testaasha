<!--Manual failed -->
<script>
    function Failed()
    {
     var answer = confirm('Are you sure ?');
     if(answer)
     {
         var secuirtypass = $("#securitypass").val();
         var id = $("#txtrefidno").val();
         var bankid = $("#txtbankid").val();
         var recivername = $("#txtrecivername").val();
         var status = $("#txtstatus").val();
         var e = document.getElementById("ddl_refund");
         var ddlval = e.options[e.selectedIndex].value
         if (secuirtypass != "" && secuirtypass != null)
         {
         $.ajax({
             // url: '@Url.Action("MoneyFailed", "Home")',
             url: '@Url.Action("IndoNepalFailed", "Home")',
             type: 'POST',
             dataType: "html",
             data: { txtrefidno: id, bankid: bankid, recivername: recivername, ddl_refund: ddlval, secuirtypass: secuirtypass, currentstatus: status },
             success: function (data) {
                 var response = JSON.parse(data);
                 if (response.Status) {
                     swal("Good Job!", response.Message, "success");
                     window.location.reload();
                     reloadPageeee();
                 }
                 else {
                     swal("Oops...", response.Message, "error");
                 }
             },
             error: function (data) {

             }
         }).done(function () {
             $("#defaultModal1").modal('hide');
         });
             return true;
           }
            else {
             swal("Oops..!", "Please Enter security Password", "error");
             return false;
              }
        }
     else {
         $("#defaultModal1").modal('hide');
            return false;
        }
    }
</script>

