@model IEnumerable<Vastwebmulti.Models.proc_report_IndoNepal_Result>
@using Newtonsoft.Json;
@{
    ViewBag.Title = "IndoNepal";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style>
    .table.dataTable thead th, table.dataTable thead td {
        padding: 8px 4px 6px 4px;
    }

    .table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px 6px 4px;
    }

    .dropdown-menu {
        margin-top: 81px !important;
    }

    table.dataTable tbody th, table.dataTable tbody td {
        padding: 8px 4px;
    }
</style>
<style type="text/css">
    .loadermoney {
        position: fixed;
        left: 0px;
        top: 0px;
        width: 100%;
        height: 100%;
        z-index: 199999;
        background: url('../../images/mmmm.svg') 50% 50% no-repeat rgba(249, 249, 249, 0.9);
    }

    .ss :hover {
        color: green;
    }

    .ff :hover {
        color: red;
    }

    .ress :hover {
        color: #ff9600;
    }

    .view :hover {
        color: #3F51B5;
    }
</style>
<div id="loadermoney" class="loadermoney" style="display:none;"></div>
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                <div class="card">
                    <div class="col-md-6">
                        <div style="margin-left:-14px;">
                            @Html.Partial("_finicalmenureport")
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="row">
                            <div class="form-group" style="margin-top:-18px; ">
                                <div style="padding-top: 22px;  margin-right: 4px; float:right;">
                                    <button type="button" id="admin" value="Admin" class="btn bg-grey waves-effect" style="margin-top:2px;" title="Admin income" onclick="Getvaladmin(this)">My Earn</button>
                                    <button type="button" id="gst" value="GST" class="btn bg-grey waves-effect" style="margin-top:2px;" title="Total GST" onclick="Getvaladmin(this)">GST</button>
                                    <button type="button" id="tds" value="TDS" class="btn bg-grey waves-effect" style="margin-top:2px;" title="Total TDS" onclick="Getvaladmin(this)">TDS</button>
                                    <button type="button" id="countverify" value="Verify" class="btn bg-grey waves-effect" style="margin-top:2px;" title="Total Imps Verify" onclick="totaocount(this)">Verify</button>
                                    <button type="button" id="countimps" value="IMPS" class="btn bg-grey waves-effect" style="margin-top:2px;" title="Total Imps " onclick="totaocount(this)">IMPS</button>
                                    <button type="button" class="btn btn-success waves-effect" style="margin-top:2px;" title="Total Imps Success"><i style="font-size:15px;top:1px;" class="fa fa-check-circle-o" aria-hidden="true"></i>&nbsp;@ViewData["Totals"]</button>
                                    <button type="button" class="btn btn-danger waves-effect" style="margin-top:2px;" title="Total Imps Failed"><i style="font-size:15px;top:1px;" class="fa fa-times-circle-o" aria-hidden="true"></i>&nbsp;@ViewData["Totalf"]</button>
                                    <button type="button" class="btn btn-warning waves-effect" style="margin-top:2px;" title="Total Imps Pending"><i style="font-size:15px;top:1px;" class="fa fa-question-circle-o" aria-hidden="true"></i>&nbsp;@ViewData["Totalp"]</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-17px;">
                <div class="card">
                    @using (Html.BeginForm("IndoNepalHistory", "Home", FormMethod.Post))
                    {
                        <div class="">
                            <div class="col-md-1">
                                <div class="" style="margin-top:4px; margin-left:-13px;width:108%;">
                                    @Html.DropDownList("ddlusers", new List<SelectListItem>
                              {
                           new SelectListItem{ Text="Admin",Value="Admin"},
                           new SelectListItem{Text="Master",Value="Master"},
                           new SelectListItem{Text="Dealer",Value="Dealer"},
                           new SelectListItem{Text="Retailer",Value="Retailer"},
                           new SelectListItem{Text="Api User",Value="APIID"}
                          }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding:0px;text-align:center;", @onchange = "answers()" })

                                </div>
                            </div>

                            <div class="col-md-2" style="display:none;" id="allmaster">
                                <div class="" style="margin-top:4px;margin-left:-13px;width:108%;">
                                    @Html.DropDownList("allmaster", ViewBag.allmaster as SelectList, "All Master", new { @style = "margin-top:0px;padding:0px;", @class = "selectpicker form-control", data_live_search = "true", })
                                </div>
                            </div>

                            <div class="col-md-2" style="display:none;" id="dlm">
                                <div class="" style="margin-top:4px;margin-left:-13px;width:108%;">
                                    @Html.DropDownList("alldealer", ViewBag.alldealer as SelectList, " All Distubutor", new { id = "alldealer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding:0px;text-align:center;" })
                                </div>
                            </div>
                            <div class="col-md-2" style="display:none;" id="rem">
                                <div class="" style="margin-top:4px;margin-left:-13px;width:108%;">
                                    @Html.DropDownList("allretailer", ViewBag.allretailer as SelectList, "All Retailer", new { id = "allretailer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding:0px;text-align:center;" })
                                </div>
                            </div>
                            <div class="col-md-2" style="display:none;" id="apiid">
                                <div class="" style="margin-top:4px;margin-left:-13px;width:108%;">
                                    @Html.DropDownList("allapiuser", ViewBag.apiid as SelectList, "All API", new { id = "allapiuser", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding:0px;text-align:center;" })
                                </div>
                            </div>
                            <div class="col-md-1" id="top">
                                <div class="" style="margin-top:4px;margin-left:-16px;width:109%;">
                                    @Html.DropDownList("ddl_top", new List<SelectListItem>
                              {
                           new SelectListItem{ Text="TOP 50",Value="50"},
                           new SelectListItem{Text="TOP 100",Value="100"},
                           new SelectListItem{Text="TOP 200",Value="200"},
                           new SelectListItem{Text="TOP 500",Value="500"},
                           new SelectListItem{Text="TOP 1500",Value="1500"},
                           new SelectListItem{Text="All Entry",Value="All"}
                          }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding:0px;text-align:center;" })
                                </div>

                            </div>
                            <div class="col-md-1" id="sts">
                                <div class="" style="margin-top:4px;margin-left:-13px;width:108%;">
                                    @Html.DropDownList("ddl_status", new List<SelectListItem>
                                {
                        new SelectListItem{ Text="Status",Value="ALL",},
                        new SelectListItem{Text="Success",Value="SUCCESS"},
                        new SelectListItem{Text="Pending",Value="PENDING"},
                        new SelectListItem{Text="Failed",Value="FAILED"}
                         }, new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding:0px;text-align:center;" })
                                </div>
                            </div>

                            <div class="col-md-1">

                                <div class="" style="margin-top:4px;margin-left:-13px;width:108%;">
                                    @Html.DropDownList("api_name", ViewBag.apiname as SelectList, "Select Api", new { @style = "margin-top:0px;padding:0px;", @class = "selectpicker form-control", data_live_search = "true" })
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="input-group" style="border:1px solid #bfbebe;margin-top:4px;margin-left:-13px;width:108%;">
                                    <span class="input-group-addon">
                                        <i class="fa fa-search" style="margin-left:3px;"></i>
                                    </span>
                                    <div class="">
                                        @Html.TextBox("txtmob", "", new { @class = "form-control", @placeholder = "NUMBER / BANK", @style = "height:37px;margin-left:-8px;padding:0px; background:none;" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group" style="margin-bottom:0px;margin-left:-10px;width:100%;">
                                    <div class="input-daterange input-group">
                                        @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;height:36px;", autocomplete = "off" })
                                        <span class="input-group-addon">
                                            <i class="fa fa-exchange"></i>
                                        </span>
                                        @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;height:36px;", autocomplete = "off" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-1">
                                <center>
                                    <button type="submit" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left:-60px; height:36px;">
                                        <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                        <span style="top:-2px;color:black;">Search</span>
                                    </button>
                                </center>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-26px;">
                <div class="card">
                    <div class="">
                        <ol class="breadcrumb breadcrumb-col-blue-grey" style="margin-left:5px;margin-top:9px;">
                            <li class="active" style="color:#9E9E9E; font-size:12px;">MONEY&nbsp;TRANSFER&nbsp;REPORT&nbsp;></li>
                        </ol>
                    </div>
                    <div class="row clearfix">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-42px;">
                            <div class="">
                                <div class="table-responsive" style="position:inherit;">
                                    <table id="example" class="table table-bordered table-striped table-hover dataTable js-exportable" cellspacing="0" style="width:100%;font-size:12px;">
                                        <thead class="navbar" style="color:white;position:inherit;">
                                            <tr>
                                                <th style="width:110px;">Live&nbsp;Status</th>
                                               
                                                <th>Sender&nbsp;Number</th>
                                                <th>Beneficiary&nbsp;A/C</th>
                                                <th>Type</th>
                                                <th>&nbsp;⇗&nbsp;&nbsp;&nbsp;Request&nbsp;Date</th>
                                                <th>&nbsp;⇙&nbsp;&nbsp;Response</th>
                                                <th>Net&nbsp;Tr&nbsp;</th>
                                               
                                                <th>User&nbsp;Debit&nbsp;</th>
                                               
                                                <th>Bank&nbsp;UTR&nbsp;/&nbsp;Transaction&nbsp;Id&nbsp;</th>
                                                <th style="width:80%;">
                                                    @* <a href="#" id="res" data-toggle="tooltip" title="Resend" style="border:1px solid white; padding:1px 1px 1px 1px; margin-left:-16px; color:white;text-decoration:none;">Res</a>*@
                                                    <center><span data-toggle="tooltip" title="Success" style="margin-left:38px;margin-right:38px;">Action</span></center>
                                                </th>
                                               
                                                <th>User&nbsp;Pre&nbsp;₹&nbsp;│&nbsp;Debit&nbsp;│&nbsp;Post&nbsp;Amt&nbsp;₹</th>
                                                @*<th>Bank&nbsp;Name</th>*@
                                              
                                                <th>Reciver&nbsp;Name</th>
                                                <th>User's&nbsp;Information</th>
                                                <th><span>User&nbsp;</span><span style="padding-left:4px;">⇒</span><span style="padding-left:8px;">Charge&nbsp;│&nbsp;Margin&nbsp;│&nbsp;GST&nbsp;│&nbsp;TDS&nbsp;<span style="padding-left:9px;">⇒</span><span style="padding-left:10px;">Net&nbsp;INC</span></span></th>
                                                <th><span>Master&nbsp;</span><span style="padding-left:4px;">⇒</span><span style="padding-left:8px;">Charge&nbsp;│&nbsp;Margin&nbsp;│&nbsp;GST&nbsp;│&nbsp;TDS&nbsp;<span style="padding-left:9px;">⇒</span><span style="padding-left:10px;">Net&nbsp;INC</span><span style="padding-left:9px;"></th>
                                                <th><span>Master&nbsp;Pre&nbsp;Amt</span><span style="padding-left:5px;">│</span><span>Credit</span><span style="padding-left:5px;">│</span><span>Master&nbsp;Post&nbsp;Amt</span></th>
                                                <th><span>Dealer&nbsp;</span><span style="padding-left:4px;">⇒</span><span style="padding-left:8px;">Charge&nbsp;│&nbsp;Margin&nbsp;│&nbsp;GST&nbsp;│&nbsp;TDS&nbsp;<span style="padding-left:9px;">⇒</span><span style="padding-left:10px;">Net&nbsp;INC</span><span style="padding-left:9px;"></th>

                                                <th><span>Dealer&nbsp;Pre&nbsp;Amt</span><span style="padding-left:5px;">│</span><span>Credit</span><span style="padding-left:5px;">│</span><span>Dealer&nbsp;Post&nbsp;Amt</span></th>
                                                @*<th><span>API&nbsp;Share</span><span style="padding-left:4px;">⇒</span><span style="padding-left:8px;">GST&nbsp;│&nbsp;TDS&nbsp;<span style="padding-left:9px;">⇒</span><span style="padding-left:10px;">Net&nbsp;INC</span></span></th>
                                                <th><span>W.L&nbsp;Share</span><span style="padding-left:4px;">⇒</span><span style="padding-left:8px;">GST&nbsp;│&nbsp;TDS&nbsp;<span style="padding-left:9px;">⇒</span><span style="padding-left:10px;">Net&nbsp;INC</span></span></th>*@
                                                <th>Request&nbsp;ID&nbsp;</th>
                                                @*<th>Common&nbsp;Trans&nbsp;ID</th>*@
                                                @*<th>API&nbsp;Name</th>*@
                                                @*<th>IP&nbsp;Address</th>*@
                                                <th>Request&nbsp;Url</th>
                                                <th>Response&nbsp;Url</th>


                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model != null)
                                            {
                                                foreach (var item in Model)
                                                {
                                                    #region setings
                                                    var color = "";

                                                    var framname = "";

                                                    var rolename = "";
                                                    var fontweight = "";
                                                    var rchtypeicon = "";
                                                    var sts = "";
                                                    var refundcolor = "";
                                                    var dmtytpe = "";
                                                    if (item.status.Contains("Success To Failed"))
                                                    {
                                                        color = "red";
                                                        sts = "Success To Failed";
                                                        fontweight = "700";

                                                    }
                                                    if (item.status.Contains("Failed To Success"))
                                                    {
                                                        color = "green";
                                                        sts = "Failed To Success";
                                                        fontweight = "700";

                                                    }
                                                    if (item.status.Contains("SUCCESS"))
                                                    {
                                                        color = "green";
                                                        fontweight = "700";
                                                        sts = item.status;

                                                    }
                                                    if (item.status.Contains("REFUND AGAINST"))
                                                    {
                                                        color = "red";
                                                        fontweight = "700";
                                                        sts = "REFUND";
                                                        refundcolor = "red";
                                                    }

                                                    if (item.status.Contains("Pending"))
                                                    {
                                                        color = "#ff9600";
                                                        fontweight = "700";
                                                        sts = item.status;

                                                    }
                                                    if (item.status.Contains("FAILED"))
                                                    {
                                                        color = "#9C27B0";
                                                        fontweight = "700";
                                                        sts = item.status;

                                                    }
                                                    if (item.status.Contains("Resend"))
                                                    {
                                                        color = "#2196F3";
                                                        fontweight = "700";
                                                        sts = item.status;

                                                    }
                                                    #endregion
                                                    <tr style="font-weight:700;">
                                                        <td>
                                                        <p style="font-size:13px;text-transform:uppercase;"><span style="color:@color;">@sts</span>&nbsp;</p>
                                                        </td>
                                                       
                                                        <td>
                                                            <p style="font-size:13px;margin-left:-8px;">&nbsp;@item.senderidnumber&nbsp;</p>
                                                        </td>
                                                        @if (item.Transfer_Type.ToUpper().Contains("BANK"))
                                                        {
                                                        <td>
                                                            <p style="font-size:13px;margin-left:-7px; ">@item.Accountno</p>
                                                        </td>
                                                        }
                                                        

                                                        <td>
                                                                <p style="font-size:18px;margin-left:-7px;margin-top:-5px;font-weight:normal;">@dmtytpe&nbsp;<span style="font-size:12px;font-weight:bold">@item.Transfer_Type</span></p>
                                                        </td>

                                                        <td>
                                                        <p style="font-size:11px;margin-left:-7px; margin-top:2px;">@String.Format("{0:dd-MMM HH:mm:ss}", item.Transfertime)&nbsp;&nbsp;<span style="color:green;font-weight:700;"></span></p>
                                                        </td>
                                                        <td>

                                                            @if (item.Responsetime != null)
                                                            {
                                                                DateTime end = (DateTime)item.Responsetime;
                                                                DateTime now = (DateTime)item.Transfertime;
                                                                var diff = end.Subtract(now.TimeOfDay);
                                                                <p style="font-size:13px;font-weight:700;margin-left:-7px;">@String.Format("{0:HH:mm:ss}", diff)</p>
                                                            }
                                                            else
                                                            {
                                                                <p style="font-size:13px; margin-left:-7px;"></p>
                                                            }

                                                        </td>
                                                        <td>
                                                            <p style="font-size:13px;margin-left:-7px;">@item.Amount</p>
                                                        </td>
                                                        
                                                        <td>
                                                          
                                                            <p style="font-size:13px;margin-left:-7px;">@item.FinalAmount</p>

                                                        </td>
                                                      
                                                        <td><p style="font-size:13px;margin-left:-7px;">@item.bankrefid</p></td>
                                                        <td>
                                                            <div class="row">
                                                                <div class="col-md-12">
                                                                    <div class="row">
                                                                        @if (item.status.ToUpper() == "PENDING" || item.status.ToUpper() == "FAILED")
                                                                        {
                                                                            <div class="col-xs-3" style="margin-bottom:0px;">

                                                                                <button class="ss" data-toggle="tooltip" onclick="success('@item.agentid','@item.bankrefid','@item.reciverName','@item.status')" style="font-size:31px;border:none;color:black; background:transparent; margin-top:-14px; margin-left:-10px;" title="Success"><i class="fa fa-check-circle-o" style="font-size:21px;"></i></button>

                                                                            </div>

                                                                        }
                                                                        @if (item.status.ToUpper() == "PENDING" || item.status.ToUpper() == "SUCCESS")
                                                                        {
                                                                            <div class="col-xs-3" style="margin-bottom:0px;">

                                                                                <button type="button" class="ff" style="background-color:transparent; color:black;border:none;margin-top:0px;margin-left:-10px;" data-toggle="modal" title="Refund" data-toggle="modal" data-target="#defaultModal1" onclick="refundshow('@item.agentid','@item.bankrefid','@item.reciverName','@item.status')">
                                                                                    <i class="fa fa-times-circle" style="font-size:20px;"></i>
                                                                                </button>
                                                                            </div>

                                                                        }
                                                                       
                                                                        @if (item.status.ToUpper() == "PENDING" || item.status.ToUpper() == "FAILED" || item.status.ToUpper() == "SUCCESS" || item.status == "Manual SUCCESS")
                                                                        {
                                                                            <div class="col-xs-3" style="margin-bottom:0px;">
                                                                                <button type="button" class="view" style="background-color:transparent;color:black; border:none;margin-top:0px;margin-left:-16px;" title="View" data-toggle="modal" data-target="#largeModal" onclick="response('@item.Idno')">
                                                                                    <i class="fa fa-eye" style="font-size:20px;"></i>
                                                                                </button>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </td>

                                                       
                                                        <td>
                                                            
                                                            @item.RemainPre&nbsp;│&nbsp;@item.FinalAmount&nbsp;│&nbsp;@item.RemainPost

                                                        </td>
                                                        @*<td><p style="font-size:13px;">@item.Bankname</p></td>*@
                                                       
                                                        <td><p style="font-size:13px;">@item.reciverName</p></td>
                                                        <td>
                                                            <p style="font-size:13px;">@item.Frm_Name</p>
                                                        </td>

                                                        <td>
                                                            <p><span>&nbsp;</span><span style="padding-left:39px;"></span><span>&nbsp;@item.ServiceCharge</span><span style="padding-left:24px;"></span><span>&nbsp;@item.Margin</span><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@item.gst&nbsp;&nbsp;&nbsp;</span><span>&nbsp;@item.Tds&nbsp;&nbsp;&nbsp;&nbsp;</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@item.FinalAmount</p>
                                                        </td>
                                                        <td>
                                                            <p><span>&nbsp;&nbsp;&nbsp;&nbsp;</span><span style="padding-left:39px;"></span><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@item.MasterServiceCharge</span><span style="padding-left:24px;"></span><span>&nbsp;&nbsp;&nbsp;@item.MasterMargin</span><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@item.Mastergst&nbsp;&nbsp;&nbsp;</span><span>&nbsp;@item.MasterTds&nbsp;&nbsp;&nbsp;&nbsp;</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@item.MasterFinalAmount</p>

                                                        </td>
                                                        <td>
                                                            <p><span>@item.MasterRemainPre</span><span style="padding-left:39px;">+</span><span>&nbsp;@item.MasterFinalAmount</span><span style="padding-left:24px;">=</span><span>&nbsp;@item.MasterRemainPost</span></p>

                                                        </td>
                                                        <td>
                                                            <p><span>&nbsp;&nbsp;&nbsp;&nbsp;</span><span style="padding-left:39px;"></span><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@item.DlmServiceCharge</span><span style="padding-left:24px;"></span><span>&nbsp;&nbsp;&nbsp;@item.DlmMargin</span><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@item.DlmGst&nbsp;&nbsp;&nbsp;</span><span>&nbsp;@item.DlmTds&nbsp;&nbsp;&nbsp;&nbsp;</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@item.DlmFinalAmount</p>

                                                        </td>
                                                        <td>
                                                            <p><span>@item.DlmRemainPre</span><span style="padding-left:39px;">+</span><span>&nbsp;@item.DlmFinalAmount</span><span style="padding-left:24px;">=</span><span>&nbsp;@item.DlmRemainPost</span></p>

                                                        </td>

                                                        @*<td>
                                                            @{
                                                                int apishare_comm = 0;
                                                                int apicomm_include_gst = 0;
                                                                if ((item.status.Contains("REFUND") || item.status.Contains("REFUND AGAINST")))
                                                                {
                                                                    <p></p>
                                                                }
                                                                else
                                                                {
                                                                    <p></p>
                                                                }
                                                            }
                                                        </td>*@
                                                        @*<td>
                                                            @{
                                                                int whiteshare_comm = 0;
                                                                int whitecomm_include_gst = 0;

                                                                if ((item.status.Contains("REFUND") || item.status.Contains("REFUND AGAINST")) )
                                                                {
                                                                    <p></p>
                                                                }
                                                                else
                                                                {
                                                                    <p></p>
                                                                }

                                                            }
                                                        </td>*@
                                                        @*<td>
                                                            <p style="font-size:13px;color:@refundcolor;">@item.agentid</p>
                                                        </td>*@
                                                        @*<td>
                                                            <p style="font-size:13px;color:@refundcolor;"></p>
                                                        </td>*@

                                                        @*<td>
                                                            <p style="font-size:13px;">To&nbsp;-&nbsp;</p>
