<script>
    $(function () {

               $('.input-daterange').datepicker({
                format: "yyyy-mm-dd",
                todayHighlight: true,
                   autoclose: true,
                orientation: "bottom auto",
            });
            var val = '@ViewBag.chk';
            if (val != "post") {
                $("#txt_frm_date").datepicker("setDate", new Date());
                $("#txt_to_date").datepicker("setDate", new Date());

        }
    });

    function answers() {
        var selectElement = document.getElementById("ddlusers");
        var selectedValue = selectElement.value;
        if (selectedValue == 'master') {
            document.getElementById('allmaster').style.display = 'block';
            document.getElementById('dlm').style.display = 'none';
            document.getElementById('rem').style.display = 'none';
            document.getElementById('apiid').style.display = 'none';
        }
        else if (selectedValue == 'Dealer') {
            document.getElementById('dlm').style.display = 'block';
            document.getElementById('allmaster').style.display = 'none';
            document.getElementById('rem').style.display = 'none';
            document.getElementById('apiid').style.display = 'none';
        }
        else if (selectedValue == 'Retailer') {
            document.getElementById('rem').style.display = 'block';
            document.getElementById('allmaster').style.display = 'none';
            document.getElementById('dlm').style.display = 'none';
            document.getElementById('apiid').style.display = 'none';
        }
        else if (selectedValue == 'API') {
            document.getElementById('apiid').style.display = 'block';
            document.getElementById('allmaster').style.display = 'none';
            document.getElementById('dlm').style.display = 'none';
            document.getElementById('rem').style.display = 'none';
        }
        else if (selectedValue == 'ALL') {
            document.getElementById('apiid').style.display = 'none';
            document.getElementById('allmaster').style.display = 'none';
            document.getElementById('dlm').style.display = 'none';
            document.getElementById('rem').style.display = 'none';
        }
    }

     $("#btnExport").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
         var RoleType = $('#ddlusers').val();
        var allmaster = $('#allmaster1').val();
        var alldealer = $('#alldealer').val();
        var allretailer = $('#allretailer').val();
        var allapiuser = $('#allapiuser').val();
         var url = '@Url.Action("ExcelCreditReport", "Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&RoleType=' + RoleType + '&allmaster1=' + allmaster + '&alldealer=' + alldealer + '&allretailer=' + allretailer + '&allapiuser' + allapiuser;
        location.href = url;
     });

    $("#btnPDF").click(function () {
        var txt_frm_date = $('#txt_frm_date').val();
        var txt_to_date = $('#txt_to_date').val();
        var RoleType = $('#ddlusers').val();
        var allmaster = $('#allmaster1').val();
        var alldealer = $('#alldealer').val();
        var allretailer = $('#allretailer').val();
        var allapiuser = $('#allapiuser').val();
        var url = '@Url.Action("PDFCreditReport", "Home")?txt_frm_date=' + txt_frm_date + '&txt_to_date=' + txt_to_date + '&RoleType=' + RoleType + '&allmaster1=' + allmaster + '&alldealer=' + alldealer + '&allretailer=' + allretailer + '&allapiuser' + allapiuser;
        window.open(url,'_blank');
    });
</script>