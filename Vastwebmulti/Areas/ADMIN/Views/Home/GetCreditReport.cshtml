                <li><a href="javascript:void(0);">Aeps Report</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix margin-bottom-third cardbackg-third onlymargin-third">
            <div class="col-md-12">
                <div class="card card-rel-third-respo">
                    <div class="col-md-12" style="padding:0px;">

                        <div class="page-header-third" style="width: auto; float: left;">
                            @Html.Partial("_finicalmenureport")
                        </div>

                        <div class="page-header-third d_menu" style="width: auto; float: right;">
                            <div class="col-md-2 fin3 responcive-fify pdfresponsive-second pdf-lastclass-third widthauto-resp-third exl-respo-third pdfadmin-allpageclass" style="padding: 0px;">
                                <div class="row">
                                    <div class="form-group">
                                        <div style="float:right; text-align:right;" class="web-white-filter">
                                            <input type="button" id="btnExport" value="Export" style="margin-left:0px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 20px;" />
                                            <input type="button" id="btnPDF" value="PDF" style="margin-left:2px; padding: 0px 4px;height:32px;border:1px solid #b1a6a638;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;" />

                                        </div>

                                    </div>
                                </div>
                            </div>

                            <div class="white-success white-successadmin-money" style="display:none;position: absolute;width: auto;right: 53px !important;z-index: 9;">
                                <span id="successtotal" class="btn btn-success waves-effect" style="font-size: 13px;padding:9px; color:white;font-weight:600;float: left;" title="Total  Success"><i style="font-size:15px;top:1px;" class="fa fa-check-circle-o" aria-hidden="true"></i> </span>
                                <span id="Failedtotal" class="btn btn-danger waves-effect" style="font-size: 13px;padding:9px; color:white;font-weight:600;float: left;" title="Total  Failed"><i style="font-size:15px;top:1px;" class="fa fa-times-circle-o" aria-hidden="true"></i> </span>
                                <span id="Pendingtotal" class="btn btn-warning waves-effect" style="font-size: 13px;padding:9px;color:white; font-weight:600;float: left;" title="Total  Pending"><i style="font-size:15px;top:1px;" class="fa fa-question-circle-o" aria-hidden="true"></i> </span>

                            </div>

                        </div>

                    </div>

                </div>
            </div>
        </div>
        <div class="row clearfix">

            <div class="col-md-12" style="margin-top: 10px;">
                <div class="card page-header-third">

                    <div class="col-md-12 fin2 all-type-third allpagefinincal-report" style="padding: 0px; margin-top: 0px; position: relative; display: flex; align-items: center; justify-content: space-between;">

                        <div class="t_menu">
                            <div class="bread-same-all-page breadsameall-second">
                                <ul>
                                    <li class="smli">
                                        <a href="~/ADMIN/Home" class="fullbodydycolorbg tmw-total-color-one">
                                            Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;">
                                        </a>
                                    </li>

                                    <li class="fullbodydycolorbg tmw-total-color-one">
                                        AepsReport
                                    </li>
                                </ul>

                            </div>
                        </div>

                        <div class="t_menu">
                            @using (Html.BeginForm("GetCreditReport", "Home", FormMethod.Post))
                            {

                                <div class="col-md-1 cltu responcive-fify" style="padding: 0px; margin-right: 3px;">
                                    <div class="form-line">
                                        <select class="selectpicker form-control" data-live-search="true" id="ddlusers" name="RoleType" style="margin-top:4px;padding-left:0px; padding-right:0px;text-align:center;" onchange="answers()">
                                            <option value="ALL">All User</option>
                                            <option value="master">Master</option>
                                            <option value="Dealer">Distributor</option>
                                            <option value="Retailer">Retailer</option>
                                            <option value="API">Api User</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-2 responcive-fify" style="display:none;padding: 0px; margin-right: 3px; margin-bottom: 10px;" id="allmaster">
                                    <div class="form-line">
                                        @Html.DropDownList("allmaster1", ViewBag.allmaster as SelectList, "All Master", new { @style = "margin-top:0px", @class = "selectpicker form-control", data_live_search = "true", })
                                    </div>
                                </div>

                                <div class="col-md-2 responcive-fify" style="display:none;padding: 0px; margin-right: 3px; margin-bottom: 10px;" id="dlm">
                                    <div class="form-line">
                                        @Html.DropDownList("alldealer", ViewBag.alldealer as SelectList, " All Distubutor", new { id = "alldealer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                    </div>
                                </div>
                                <div class="col-md-2 responcive-fify" style="display:none;padding: 0px; margin-right: 3px; margin-bottom: 10px;" id="rem">
                                    <div class="form-line">
                                        @Html.DropDownList("allretailer", ViewBag.allretailer as SelectList, "All Retailer", new { id = "allretailer", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                    </div>
                                </div>
                                <div class="col-md-2 responcive-fify" style="display:none;padding: 0px; margin-right: 3px; margin-bottom: 10px;" id="apiid">
                                    <div class="form-line">
                                        @Html.DropDownList("allapiuser", ViewBag.apiid as SelectList, "All API", new { id = "allapiuser", @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                    </div>
                                </div>
                                <div class="col-md-3 responcive-full reportdate-money-allpage" style="padding: 0px;float: left;">
                                    <div class="form-group" style="margin-bottom: 0px;">
                                        <div class="input-daterange input-group">
                                            <div class="inputiconsateall" style="padding-right:2px;">
                                                <div class="custom-date-icon ner">
                                                    <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                                </div>
                                                @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #b1a6a638; margin-top:0px;height:32px;padding-right: 0px;padding-left: 23px;width: 105px;margin-right: 3px;" })
                                            </div>
                                            <div class="nrr3 inputiconsateall" style="padding-left:2px;">
                                                <div class="custom-date-icon ner2">
                                                    <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                                </div>
                                                @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #b1a6a638; margin-top:0px;height:32px;padding-right: 0px;padding-left: 23px;width: 105px;" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-1 responcive-fify respon-third-button responcive-fify-search" style="padding: 0px;float: left;width: 10px;">

                                    <center>
                                        <button type="submit" value="Old" name="submit" class="btn llpo input-back-second" style=" border:1px solid #b1a6a638;background: transparent;">
                                            <i class="fa fa-search" style="top:0px;font-size:16px;color:black;"></i>
                                            <span style="top:0px;color:black;">SEARCH</span>
                                        </button>
                                    </center>

                                </div>

                            }

                        </div>
                    </div>


                    <div class="body" style="padding: 0px; float: left; width: 100%; margin-top: 6px;">
                        <div class="table-responsive tableseconddes-admin" style="position:inherit;margin-top:0px;">
                            <table id="Aeps" class="table table-bordered table-striped table-hover example-second thpadding-second whitetable-second" cellspacing="0" style="width:100%;background:#f5f5f5;">
                                <thead style="background-color:whitesmoke;">
                                    <tr style="color: black;font-size: 13px;">
                                        <th>Transfer From</th>
                                        <th>Transfer To</th>
                                        <th>Frm Name</th>
                                        <th>Person Name</th>
                                        <th>Mobile No.</th>
                                        <th>District</th>
                                        <th>State</th>
                                        <th>Admin Credit Amount</th>
                                        <th>Account Balance</th>
                                        <th>Due Credit</th>
                                        <th>Live Due Credit</th>
                                        <th>Transfer Time</th>
                                    </tr>
                                </thead>
                                <tbody id="trow" class="alin chnj">
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.FromRole</td>
                                            <td>@item.ToRole</td>
                                            <td>@item.FrmName</td>
                                            <td>@item.Name</td>
                                            <td>@item.Mobile</td>
                                            <td>@item.Dist_Desc</td>
                                            <td>@item.State_name</td>
                                            <td>@item.Amount</td>
                                            <td>@item.ToRemainPose</td>
                                            <td>@item.CrPose</td>
                                            <td>@item.livecr</td>
                                            <td>@item.TransferTime</td>
                                        </tr>
                                    }

                                </tbody>
                            </table>
                            <div id="loadingdiv" style="text-align:center;display:none;margin-bottom:20px;">
                                <img src="~/img/ajax-loader.gif" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</section>

