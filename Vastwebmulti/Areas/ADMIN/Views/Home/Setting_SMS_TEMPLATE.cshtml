<script>

    function DeleteTemplate(idno) {

        $('.clssresetshow').show();
        $('.clssresetnotshow').hide();

        var showid = "#show-" + idno;
        var Notshowid = "#Notshow-" + idno;

       $(showid).hide();
     $(Notshowid).show();

    }



    function ConfirmDeleteTemplate(idno) {

        $('.clssresetshow').show();
        $('.clssresetnotshow').hide();

        var showid = "#show-" + idno;
        var Notshowid = "#Notshow-" + idno;

        $(showid).hide();
        $(Notshowid).show();


          $.ajax({
              url: "@Url.Action("DeleteTemplatebyid")",
            data: { id: idno },
            type: 'POST',
              success: function (result) {
                  $('#tblshowMasterD').html(result);

            }
        });




    }





</script>
<script>

    $(function () {
        $('.copy-to-clipboard').click(function () {

            var idno = $(this).data("idss")
            var txtcurent = "#txt-" + idno;
            $(txtcurent).focus();
            $(txtcurent).select();
            document.execCommand('copy');
            toastr.success('Copied to clipboard', 'Success')
            /*  $(".copied").text("Copied to clipboard").show().fadeOut(1200);*/
        });
    });




