@model Vastwebmulti.Areas.ADMIN.Models.CashDepositeAndBank_Info_VM
@using (Ajax.BeginForm("_white_CashDepositCharge", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "success4", OnFailure = "failed4", UpdateTargetId = "whitecash" }))
{
    <input id="btnsubmit4" type="submit" value="Save Now" class="btn btn-default" style="display:none;width:20%;" />
    <div id="tblwhite">
        <table class="table table-responsive table-bordered example-second">
            <thead>
                <tr style="background: #c7c7c7;">
                    <th>User ID</th>
                    <th>Payment&nbsp;Type</th>
                    <th>Charge &nbsp;(%)</th>
                </tr>
            </thead>
            @if (Model.creditchargewhite != null)
            {
                <tbody id="tbodyshowwhite">
                    @foreach (var item in Model.creditchargewhite)
                    {
                        <tr>
                            <th>@item.userid</th>
                            <th>@item.ctype</th>
                            <th>@item.Charge</th>
                        </tr>
                    }
                </tbody>
                <tbody id="tbodyeditwhite" style="display:none;">
                    @for (int i = 0; i < Model.creditchargewhite.Count; i++)
                    {
                        <tr>
                            @Html.HiddenFor(a => a.creditchargewhite[i].userinfo)
                            <td>
                                @Html.DisplayFor(a => a.creditchargewhite[i].userid)
                            </td>
                            <td>
                                @Html.HiddenFor(a => a.creditchargewhite[i].ctype)
                                @Html.DisplayFor(a => a.creditchargewhite[i].ctype)
                            </td>
                            <td>
                                @Html.EditorFor(a => a.creditchargewhite[i].Charge, new { htmlAttributes = new { @style = "width:100%" } })
                                @Html.ValidationMessageFor(a => a.creditchargewhite[i].Charge)
                            </td>
                        </tr>
                    }
                </tbody>
            }
        </table>
    </div>
}








<script>

        $('.second-design .example-second').DataTable({


            paging: false
        });

</script>