        var currenclass = $(this);
       $.ajax({
                url: '@Url.Action("UpdatePanCardLimit", "Home")',
                type: 'POST',
                 data: { per: e },
                success: function (data) {

                    if (data == 'okok')
                    {
                        currenclass.addClass('activeupto').siblings().removeClass('activeupto');

                    }
                    else {
                        //swal("Oops...", response.Message, "error");
                    }
                },
                error: function (data) {
                }
            });
    });


</script>
