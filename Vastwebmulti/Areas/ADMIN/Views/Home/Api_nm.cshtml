@model IEnumerable<Vastwebmulti.Models.api_name>
@{
    ViewBag.Title = "Api_nm";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style>

   /* new css */
    .rtyfrty {
        margin-bottom: 5px;
    }
    .col-md-9.rtyfrtyclass-third {
        padding: 0;
    }
   
   /* new css */


    .table-bordered tbody tr td{padding:5px 10px;}
     .bread-same-all-page li{margin:6px 0px;}


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media screen and (max-width: 992px) {
        .col-md-9.rtyfrtyclass-third {
            width: 100%;
            padding: 0;
        }


        .rtyfrty{width: 100%;float: left;}
        .rtyfrty ul li {
            width: 33%;
            float: left;
            margin-bottom: 10px;
        }

            .rtyfrty ul li a {
                margin-bottom: 0;
            }

        .vacrivet {
            width: 50%;
            float: left;
            padding: 0 4px !important;
        }
    }

    @@media only screen and (max-width:767px){
        .rtyfrty ul li {
            width: 33.333%;
            margin-bottom: 6px;
            margin-right: 0px !important;
        }

    }

    @@media only screen and (max-width:500px){

        .rtyfrtyclass-third #custnav ul li {
            width: 50% !important;
        }
        div#custnav ul li a {
            font-size: 12px;
        }

    }


</style>
<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>API Setting</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Basic Setting 2&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">API Setting</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="page-header-third pageheader-second-third">
            <div class="bread-same-all-page breadsameall-second">
                <ul class="padding-top-thirdclass four-noneclass-admin-only" style="margin:0px;">
                    <li class="smli">
                        <a href="@Url.Action("Dashboard", "Home")" class="fullbodydycolorbg tmw-total-color-one">
                            Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                        </a>
                    </li>
                    <li class="fullbodydycolorbg tmw-total-color-one">
                        <a href="@Url.Action("Dashboard", "Home")#setting" class="fullbodydycolorbg tmw-total-color-one">
                            Basic&nbsp;Setting
                        </a>&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                    </li>
                    <li class="fullbodydycolorbg tmw-total-color-one">
                        Set {Get} API
                    </li>
                </ul>

            </div>
        </div>

       

        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card page-header-third">
                    <div class="col-md-12 rtyfrty" style="padding: 0;">
                        <div class="">
                            <div class="col-md-9 rtyfrtyclass-third">
                                <div style="">
                                    @Html.Partial("_menuapinm")
                                </div>

                            </div>
                            <div class="col-md-3" style="padding-right:0px;">
                                <button type="button" class="btn waves-effect fullbodydycolorbg for-margin" style="float:right;border:none;color:#fff;" data-toggle="modal" data-target="#largeModal">
                                    <i class="fa fa-plus" style="top:1px;font-size:16px;color:#fff;"></i>
                                    <span style="color:#fff;">Add New Api</span>
                                </button>
                            </div>
                        </div>

                    </div>

                    <div class="" style="width:100%;float:left;">
                        <div class=" table-responsive tablefourdesign-admin" style="position:inherit;">
                            <table class="table table-bordered table-striped example-second exampletable-second whitetable-second" style="width:100%;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Sr.No</th>
                                        <th>API Name</th>
                                        <th style="width:72%;">API&nbsp;Url Details</th>

                                        <th><center>Action</center></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int i = 1;}
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td>@item.apiname</td>

                                            <td><input type="text" value="@item.api_url" id="@i" name="myInput" class="input-set-api" style="height:34px; border:1px dashed #9E9E9E ;width:92%;float:left;" readonly=""><button onclick="myFunction('@i')" class="btn  waves-effect" style="margin-top:0px;border-top-left-radius:0px;border-bottom-left-radius:0px;background:#dedddd;border:1px solid #c7c2c2; height:34px;color:black;">Copy</button></td>


                                            <td>
                                                <button id="but" onclick="animation('@item.idno', '@item.apiname', '@item.api_url', '@item.viewbill', '@item.heavyRefresh', '@item.status_url','@item.Report_url','@item.ipaddress')" style="background-color:transparent;color:#03a9f4; border:none;float:left;margin-right:1px;" data-toggle="modal" data-target="#defaultModal1">
                                                    <p class="deletebuttoback-second" style="padding:1px 11px 1px 11px;border:1px solid #dddddd;color:black;height: 34px;margin:0px; line-height: 32px;">Edit</p>
                                                </button>
                                                <button type="button" class="first-button" style="background-color:transparent; border:none;">
                                                    <p class="deletebuttoback-second" style="padding:1px 11px 1px 11px;border:1px solid #dddddd;color:black;height: 34px;margin:0px; line-height: 32px;">Delete</p>
                                                </button>

                                                <button class="second-button" type="button" style=" border:none;display:none;width:63px;" onclick="deletedata('@item.idno')">
                                                    <p class="fullbodydycolorbg" style="padding:1px 11px 1px 11px;border:1px solid #dddddd;color:#fff;height: 34px;margin:0px; line-height: 32px;">Sure ?</p>
                                                </button>

                                            </td>

                                        </tr>
                                        i++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!--Add New  modal-->
<div class="modal fade" id="largeModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background-color:whitesmoke;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:black;">Add New API</h4>
            </div>
            @using (Html.BeginForm("Api_nm", "Home", FormMethod.Post))
            {
                <div class="modal-body" style="margin-top:0px;padding-bottom:0px;">
                    <div class="body">
                        <label for="email_address">API Name</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("apinm", "", new { @placeholder = "Enter Api Name", @maxlength = "10", @required = "required", @class = "form-control", @style = "text-transform: uppercase;" })
                            </div>
                        </div>
                        <label for="password">API Url</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("apiurl", "", new { @placeholder = "http://sitedomainname/pagename?uid=uuu&pass=ppp&mno=mmm&op=ooo&amt=aaa&refid=iii", @required = "required", @class = "form-control" })
                            </div>
                        </div>
                        <label for="password">Check Balance Url</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("CheckbalUrl", "", new { @placeholder = "http://sitedomainname/pagename?uid=uuu&pass=ppp&mno=mmm&op=ooo&amt=aaa&refid=iii", @class = "form-control" })
                            </div>
                        </div>
                        <label for="password">Complain Url</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("Report_url", "", new { @placeholder = "http://sitedomainname/pagename?uid=uuu&pass=ppp&mno=mmm&op=ooo&amt=aaa&refid=iii", @class = "form-control" })
                            </div>
                        </div>
                        <label for="password">DTH Heavy Refresh</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("dthheavyrefresh", "", new { @placeholder = "http://sitedomainname/pagename?uid=uuu&pass=ppp&mno=mmm&op=ooo&amt=aaa&refid=iii", @class = "form-control" })
                            </div>
                        </div>
                        <label for="password">Status Check Url</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("status_url", "", new { @placeholder = "http://sitedomainname/pagename?uid=uuu&pass=ppp&mno=mmm&op=ooo&amt=aaa&refid=iii", @class = "form-control" })
                            </div>
                        </div>
                        <label for="password">Callback IP Address</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                <input class="form-control" type="text" id="ipaddress" name="ipaddress" placeholder="Enter IP Address(Optional)" title="Please Enter Valid IP Format" pattern="^(?:[0-9]{1,3}\.){3}[0-9]{1,3}$">
                            </div>
                        </div>

                    </div>
                </div>
                <div class="modal-footer" style="padding-bottom:15px;padding-right: 25px;">
                    <button type="button" class="btn bg-grey waves-effect" style=" margin-right: 12px;  height:32px;" data-dismiss="modal">
                        <span style="color:black;">Close</span>
                    </button>
                    <button type="submit" class="btn  waves-effect fullbodydycolorbg" style=" height:32px;">
                        <span style="top:-2px;color:#fff;">Save Change</span>
                    </button>

                </div>
            }
        </div>
    </div>
</div>

<!--Edit M  modal-->
<div class="modal fade" id="defaultModal1" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document" style="margin: 0px;float: right;width:50%;">
        <div class="modal-content">
            <div class="modal-header" style="background-color:whitesmoke;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:black;">Edit API Url </h4>
            </div>
            @using (Html.BeginForm("Editapi_nm", "Home", FormMethod.Post))
            {
                <div class="modal-body" style="margin-top:0px;padding-bottom:0px;">
                    <div class="body">
                        <label for="email_address">API Name</label>
                        <div class="form-group">
                            @Html.TextBox("txtid", "", new { style = "display:none;" })
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("txtapiname", "", new { @placeholder = "Enter Api Name", @required = "required", @class = "form-control", @readonly = "readonly" })
                            </div>
                        </div>
                        <label for="password">API Url</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("txtapiurl", "", new { @placeholder = "http://sitedomainname/pagename?uid=uuu&pass=ppp&mno=mmm&op=ooo&amt=aaa&refid=iii", @required = "required", @class = "form-control" })
                            </div>
                        </div>
                        <label for="password">Check Balance Url</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("viewurledit", "", new { @placeholder = "http://sitedomainname/pagename?uid=uuu&pass=ppp&mno=mmm&op=ooo&amt=aaa&refid=iii", @class = "form-control" })
                            </div>
                        </div>  
                        <label for="password">Complain Url</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("Report_url1", "", new { @placeholder = "http://sitedomainname/pagename?uid=uuu&pass=ppp&mno=mmm&op=ooo&amt=aaa&refid=iii", @class = "form-control" })
                            </div>
                        </div>
                        <label for="password">DTH Heavy Refresh</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("viewdthheavyrefresh", "", new { @placeholder = "http://sitedomainname/pagename?uid=uuu&pass=ppp&mno=mmm&op=ooo&amt=aaa&refid=iii", @class = "form-control" })
                            </div>
                        </div>
                        <label for="password">Status Check Url</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                @Html.TextBox("status_url_edit", "", new { @placeholder = "http://sitedomainname/pagename?uid=uuu&pass=ppp&mno=mmm&op=ooo&amt=aaa&refid=iii", @class = "form-control" })
                            </div>
                        </div>
                        <label for="password">Callback IP Address</label>
                        <div class="form-group">
                            <div class="" style="border:1px solid #dddddd;">
                                <input class="form-control" type="text" id="ipaddress_edit" name="ipaddress_edit" placeholder="Enter IP Address(Optional)" title="Please Enter Valid IP Format" pattern="^(?:[0-9]{1,3}\.){3}[0-9]{1,3}$">
                            </div>
                        </div>

                    </div>
                </div>
                <div class="modal-footer" style="padding-bottom:15px;padding-right: 25px;">
                    <button type="button" class="btn bg-grey waves-effect" style=" margin-right: 12px;  height:32px;" data-dismiss="modal">
                        <span style="color:black;">Close</span>
                    </button>
                    <button type="submit" class="btn  waves-effect fullbodydycolorbg" style=" height:32px;">
                        <span style="top:-2px;color:#fff;">Save Change</span>
                    </button>

                </div>
            }

        </div>
    </div>
</div>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>


<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<!--Insert Popuop-->
<script>
    window.onload = function () {
        var message = '@TempData["add"]'
        if (message != "" && message != null) {
            swal("Good job!", message, "success");

        }
        //Edit Message
        var editdata = '@TempData["edit"]'
        if (editdata != null && editdata != "") {
            swal("Good job!", editdata, "success");
        }

    }
</script>


<script type="text/javascript">
    var val1 = "";
    function animation(id, apiname, apiurl, viewbillurl, heavyrefresh, status_url, reporturl, ipaddress) {
 
        $("#txtid").val(id);
        $("#txtapiname").val(apiname);
        $("#txtapiurl").val(apiurl);
        $("#viewurledit").val(viewbillurl);
        $("#viewdthheavyrefresh").val(heavyrefresh);
        $("#status_url_edit").val(status_url);
        $("#ipaddress_edit").val(ipaddress);
        $("#Report_url1").val(reporturl);
    }
</script>

<!--View View Bill javascript-->
<script type="text/javascript">
    function showviewbilldata(id, viewbillurl) {
        $("#txtviewbillurlid").val(id);
        $("#txtviewbillurl1").val(viewbillurl);
        }
</script>
<!--Delete-->
<script type="text/javascript">

    function deletedata(e) {


    $.ajax({
        type: "POST", url: '@Url.Action("Delte_API_From_info", "Home")', data: { idno: e }, dataType: 'json', cache: false, success: function (result) {
            if (result == "Success") {
                //swal("Deleted!", "API Url Deleted Successfully.", "success");
                var url = '@Url.Action("Api_nm", "Home")';
                window.location.href = url;
            }
            else {
                //swal("Failed!", "Something went wrong.", "error");
                var url = '@Url.Action("Api_nm", "Home")';
                window.location.href = url;
            }
        }
    });

    }


</script>
<!--Copy Url javascript-->
<script>
    function myFunction(p) {
        var copyText = document.getElementById(p);
       copyText.select();
     document.execCommand('copy');
         }
</script>

<script>
    $('.first-button').click(function () {
        $(this).hide();
        $(this).next('.second-button').show();
    })
</script>

<script>
    $(function () {
        $('.second-design .example-second').DataTable({


            paging: false
        });
    });

</script>