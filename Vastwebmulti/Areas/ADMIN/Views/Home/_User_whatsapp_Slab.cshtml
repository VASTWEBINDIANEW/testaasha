@model Vastwebmulti.Areas.ADMIN.Models.whatsappslab
@using (Ajax.BeginForm("_User_whatsapp_Slab", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "OnSuccess1", OnFailure = "onfailed", UpdateTargetId = "divEditFormComm", LoadingElementId = "div_Loader", InsertionMode = InsertionMode.Replace }))
{
    <input id="btnsubmituser" type="submit" name="Button" value="Update For Existing Users" class="btn  waves-effect" style="display:none;" />
    <input id="btnsubmitusercommon" type="submit" name="Button" value="Update Existing & New Users" class="btn  waves-effect" style="display:none;" />
    <input id="btnsubmitusercommondlmrem" type="submit" name="Button" value="Update Existing & New Users" class="btn  waves-effect" style="display:none;" />

    @Html.HiddenFor(m => m.role)
    <div class="row clearfix" style="margin-right:0px;">
        <div class="col-md-12">
            @*<div class="col-md-2">
                    <label for="email_address_2" style="padding-top:14px;padding-left:137px;"><i class="fa fa-users" style="font-size:25px; color:#607d8b ;"></i></label>
                </div>*@
            <div class="slab-master-block">
                <div class="slab-master-block-left">
                    <div id="allshow" class="row">
                        <div class="col-md-12" style="padding-right:20px;">
                            <div class="custom-district-img">
                                <img src="~/AdminDesign/images/slab-user.svg" style="width:18px;">
                            </div>
                            @Html.DropDownList("ddlUserId", Model.UserId, "All Users", new { @class = "form-control for-select2", @onchange = "ddlUserIdChange()" })
                        </div>
                    </div>
                </div>
                <div class="slab-master-block-right">
                    <div id="slab-master-message" class="slab-master-message slab-master-message-show" style="display: none;">
                        <p>  If you edit the slabs of all the master distributors, you are given a data view of the common slabs.</p>
                    </div>
                    <div id="slab-master-detail" class="slab-master-detail slab-master-detail-hide" style="display: block;">
                        <div class="row clearfix">

                            <div class="col-md-4 col-sm-4 col-xs-4 col-4">
                                <span class="master-slab-right-icon">
                                    <img src="~/AdminDesign/images/user.svg">
                                </span>
                                <input class="form-control" type="text" placeholder="User Name" value="@Model.Name">

                            </div>
                            <div class="col-md-4 col-sm-4 col-xs-4 col-4">
                                <span class="master-slab-right-icon" style="border-left: 1px solid #bbb;">
                                    <img src="~/AdminDesign/images/number.svg">
                                </span>
                                <input class="form-control" type="text" placeholder="User Registered Number" value="@Model.Phone">

                            </div>
                            <div class="col-md-4 col-sm-4 col-xs-4 col-4">
                                <span class="master-slab-right-icon" style="border-left: 1px solid #bbb;">
                                    <img src="~/AdminDesign/images/email.svg">
                                </span>
                                <input class="form-control" type="text" placeholder="User Registered Mail" value="@Model.Email">

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <table class="table table-bordered slab-table third-design-table">
        <thead class="navbar" style="position: initial;">
            <tr>
                <th>User&nbsp;ID</th>
                <th>@Model.PP1 &nbsp;Month</th>
                <th>@Model.PP2 &nbsp;Month</th>
                <th>@Model.PP3 &nbsp;Month</th>
            </tr>
        </thead>
        <tbody id="tbodyshow">
            <!--Master User-->
            @if (Model.Apiuser != null)
            {
                for (int i = 0; i < Model.Apiuser.Count; i++)
                {
            <tr>
                <td> @Html.DisplayFor(a => a.Apiuser[i].Email)</td>
                <td>@Html.DisplayFor(a => a.Apiuser[i].P1)</td>
                <td>@Html.DisplayFor(a => a.Apiuser[i].P2)</td>
                <td>@Html.DisplayFor(a => a.Apiuser[i].P3)</td>
            </tr>

                }
            }

        </tbody>
        <tbody id="tbodyedit" style="display:none;">
            <!--Master User-->
            @if (Model.Apiuser != null)
            {
                for (int i = 0; i < Model.Apiuser.Count; i++)
                {
            <tr>
                @Html.HiddenFor(a => a.Apiuser[i].RolesName)
                @Html.HiddenFor(a => a.Apiuser[i].idno)
                <td>
                    @Html.DisplayFor(a => a.Apiuser[i].Email)
                </td>
                <td>
                    @Html.EditorFor(a => a.Apiuser[i].P1, new { htmlAttributes = new { @style = "width:100%" } })
                    @Html.ValidationMessageFor(a => a.Apiuser[i].P1)
                </td>
                <td>
                    @Html.EditorFor(a => a.Apiuser[i].P2, new { htmlAttributes = new { @style = "width:100%" } })
                    @Html.ValidationMessageFor(a => a.Apiuser[i].P2)
                </td>
                <td>
                    @Html.EditorFor(a => a.Apiuser[i].P3, new { htmlAttributes = new { @style = "width:100%" } })
                    @Html.ValidationMessageFor(a => a.Apiuser[i].P3)
                </td>
            </tr>
                }
            }
        </tbody>
        <tbody id="tbodyeditAll" style="display:none;">
            <!--Master User Update-->
            @if (Model.Apiuser != null)
            {
                for (int i = 0; i < Model.Update_whatsapp_api.Count; i++)
                {

            <tr>
                @Html.HiddenFor(a => a.Update_whatsapp_api[i].idno)

                <td>
                    <p>All</p>
                </td>
                <td>
                    @Html.TextBoxFor(a => a.Update_whatsapp_api[i].P1, new { @style = "width:100%" })
                    @Html.ValidationMessageFor(a => a.Update_whatsapp_api[i].P1)
                </td>
                <td>
                    @Html.TextBoxFor(a => a.Update_whatsapp_api[i].P2, new { @style = "width:100%" })
                    @Html.ValidationMessageFor(a => a.Update_whatsapp_api[i].P2)
                </td>
                <td>
                    @Html.TextBoxFor(a => a.Update_whatsapp_api[i].P3, new { @style = "width:100%" })
                    @Html.ValidationMessageFor(a => a.Update_whatsapp_api[i].P3)
                </td>
            </tr>
                }
            }
            <!--End Master User-->
        </tbody>
    </table>
}
<link href="~/MainFrontDesign/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/MainFrontDesign/select2/dist/js/select2.full.min.js"></script>
<script>
    $('.for-select2').select2();


</script>
<script>
        function OnSuccess1(data) {
            $('#btnsubmituser').hide();
            $('#btnsubmitusercommon').hide();
            $('#btnEdit').show();
            var chk = '@Model.role';
            if (chk == "Retailer") {
                $('#retailerdrop').show();
                $('#allshow').hide();
            }
            else {
                $('#retailerdrop').hide();
                $('#allshow').show();
            }
        }
        function onfailed(error) {
            alert(error.responseText);
        }
</script>


<script>
    $('.third-design .third-design-table tbody td').mouseenter(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'var(--main-bg-rcolor)');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#fff');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'var(--main-bg-rcolor)');
    });

    $('.third-design .third-design-table tbody td').mouseleave(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'transparent');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#333');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'transparent');
    });
</script>

