<!--Edit Lapu Report-->
<script type="text/javascript">
    var val1 = "";
    function animation(port, simno, idno, Operator, Code, pinno, method, minbal, maxdaily, txtpurcharge,imeino) {
        $("#txtsimno").val(simno);
        $("#txtidno").val(idno);
        $("#txtOperator").val(Operator);
        $("#txtCode").val(Code);
        $("#txtpinno").val(pinno);
        $("#txtmethod").val(method);
        $("#txtminbal").val(minbal);
        $("#txtport").val(port);
        $("#txtport").val(port);
        $("#txtdailymax").val(maxdaily);
        $("#txtpurcharge").val(txtpurcharge);
        $("#txtimeino").val(imeino);
    }
    $(document).ready(function () {
        var hh = $("#lapuno11").val();
        if (hh != "") {
            jQuery('#chkchk').css("display", "block")
        }
    });
    function animation1(port, simno) {
        $("#txtportnonew").val(port);
        $("#txtSimnonew").val(simno);
    }
    function del(id, portno) {

       
       
            var url = '@Url.Action("deleteport", "Home")';

            $.ajax({
                url: url,
                data: { id: id, Port:portno },
                cache: false,
                async: false,
                type: "GET",
                success: function (data) {
                     var url = '@Url.Action("LapuReport", "Home")?portno=' + data + '';
                    window.location.href = url
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                }
            });
          
       
       
    }
</script>


<script type="text/javascript">
        function isNumber(evt) {
            var iKeyCode = (evt.which) ? evt.which : evt.keyCode
            if (iKeyCode != 46 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
                return false;
            return true;
        }
</script>
<script>
     $('.click-to-sure').click(function () {
        $(this).hide();
        $(this).next('button').show();
    });
</script>



