@model Vastwebmulti.Areas.ADMIN.Models.PostpaidUtilitySlab
@using (Ajax.BeginForm("_ExtraInfo", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "OnSuccessExtra", UpdateTargetId = "divEditFormEXTRA", LoadingElementId = "div_Loader", InsertionMode = InsertionMode.Replace }))
{
    <style>
        input.move1, .move2, .move3, .move4, .move5 {
            border: 1px solid #ddd;
            padding: 4px;
        }
    </style>
    <div class="" style=" height: auto; display: flow-root; background: rgb(255 255 255 / 95%); padding: 5px; box-shadow: 0px 0px 5px -2px; border-radius: 4px; margin: 7px -1px;">
        <div class="orm11" style="float: left; width: 35%; ">
            <input type="button" value="Replace Table Data" style="width: 100% !important; background: #fbb773 !important; color: #000; " onclick="Replaceall()" class="btn btn-default" />
        </div>
        <div class="orm22" style=" float: right; width: 12%;">
            <button type="button" class="btn btn-default" style="width: 100%;" data-dismiss="modal">Close</button>
        </div>
        <div class="orm11" style="float: left; width: 20%;">
            <input type="submit" value="Save Data" class="btn btn-default" style="background: var(--main-bg-lcolor) !important;color:#fff;" />
        </div>
        </div>

        <table id="tblEntAttributes" class="table table-bordered ">
            <thead class="navbar" style="position:initial;">
                <tr>
                    <th>Operator Name</th>
                    <th>0 to 1500(%)</th>
                    <th>1501 to& 10000(%)</th>
                    <th>10001 to 50000(%)</th>
                    <th>50001 to 100000(%)</th>
                    <th>100001 & Above(%)</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Extra.Count; i++)
                {
                    @Html.HiddenFor(a => a.Extra[i].optcode)
                    <tr>
                        <td>
                            @Html.DisplayFor(a => a.Extra[i].operator_Name)
                        </td>
                        <td>
                            @Html.EditorFor(a => a.Extra[i].move1, new { htmlAttributes = new { @style = "width:100%", @class = "move1" } })
                            @Html.ValidationMessageFor(a => a.Extra[i].move1)
                        </td>
                        <td>
                            @Html.EditorFor(a => a.Extra[i].move2, new { htmlAttributes = new { @style = "width:100%", @class = "move2" } })
                            @Html.ValidationMessageFor(a => a.Extra[i].move2)
                        </td>
                        <td>
                            @Html.EditorFor(a => a.Extra[i].move3, new { htmlAttributes = new { @style = "width:100%", @class = "move3" } })
                            @Html.ValidationMessageFor(a => a.Extra[i].move3)
                        </td>
                        <td>
                            @Html.EditorFor(a => a.Extra[i].move4, new { htmlAttributes = new { @style = "width:100%", @class = "move4" } })
                            @Html.ValidationMessageFor(a => a.Extra[i].move4)
                        </td>
                        <td>
                            @Html.EditorFor(a => a.Extra[i].move5, new { htmlAttributes = new { @style = "width:100%", @class = "move5" } })
                            @Html.ValidationMessageFor(a => a.Extra[i].move5)
                        </td>
                        @*<td>@item.retailercomm</td>*@
                    </tr>

                }
            </tbody>
        </table>
        }
