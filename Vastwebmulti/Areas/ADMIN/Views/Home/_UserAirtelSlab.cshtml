<!-- The Modal -->
<!-- Modal -->
<div class="modal fade" id="exampleModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">

        <div class="modal-content commision-model">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel"><span id="txtvalheader"></span></h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>1. All The Commision is Handal using Master And Distrubor. </p>
                <p>2. Retailer And Distritutor not Allow by Admin. </p>
            </div>
            <div class="modal-footer">
                @using (Ajax.BeginForm("_UserAirtelSlab_master", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "OnSuccess1M", OnFailure = "onfailed1M", UpdateTargetId = "divEditFormComm", LoadingElementId = "div_Loader", InsertionMode = InsertionMode.Replace }))
                {
                    @Html.Hidden("txtmaster")
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary fullbodydycolorbg">Save changes</button>
                }
            </div>
        </div>
    </div>
</div>

<link href="~/MainFrontDesign/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="~/MainFrontDesign/select2/dist/js/select2.full.min.js"></script>
<script>
    $('.for-select2').select2();
</script>
<script>
    checkcomm = (e) => {
        var userid = $('#ddlUserId').val();
        if (userid != "") {
            $('#txtvalheader').text("Status " + e);
            $('#txtmaster').val(userid)
            $('#exampleModal').modal()
        }
    }
</script>
<script>
        function OnSuccess1(data) {
            $('#btnsubmituser').hide();
            $('#btnsubmitusercommon').hide();
            $('#btnEdit').show();
            var chk = '@Model.role';
            if (chk == "Retailer") {
                $('#retailerdrop').show();
                $('#allshow').hide();
            }
            else {
                $('#retailerdrop').hide();
                $('#allshow').show();
            }
        }
        function onfailed(error) {
            alert(error.responseText);
        }
</script>
<script>
        function OnSuccess1M(data) {
            $('#btnsubmituser').hide();
            $('#btnsubmitusercommon').hide();
            $('#btnEdit').show();
            $('.modal-backdrop.in').hide();
           // $('#exampleModal').modal('hide');
            var chk = '@Model.role';
            if (chk == "Retailer") {
                $('#retailerdrop').show();
                $('#allshow').hide();
            }
            else {
                $('#retailerdrop').hide();
                $('#allshow').show();
            }
        }
</script>


<script>
    $('.third-design .third-design-table tbody td').mouseenter(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'var(--main-bg-rcolor)');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#fff');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'var(--main-bg-rcolor)');
    });

    $('.third-design .third-design-table tbody td').mouseleave(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'transparent');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#333');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'transparent');
    });
</script>