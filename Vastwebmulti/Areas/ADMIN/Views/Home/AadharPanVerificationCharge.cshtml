        .moneytransferslab-admin .admin-slabcardclass button:nth-child(8) {
            width: 17% !important;
        }

        .moneytransferslab-admin .admin-slabcardclass button .uptotransction {
            margin-left: 6px;
        }
    }

    @@media screen and (max-width:766px) {
        .moneytransferslab-admin .admin-slabcardclass a, .moneytransferslab-admin .admin-slabcardclass button {
            width: 25% !important;
            float: left !important;
        }

            .moneytransferslab-admin .admin-slabcardclass button:nth-child(8), .moneytransferslab-admin .admin-slabcardclass button:nth-child(9) {
