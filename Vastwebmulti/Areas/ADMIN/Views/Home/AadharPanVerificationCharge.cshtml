        }
        .col-md-10.slab-first-tab-content {
            width: 100% !important;
        }




    }   
</style>

<section class="content fourdesign-section-admin">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                @Html.Partial("_Slab_Menu")
                <div class="col-md-10 slab-first-tab-content">
                    <div class="row clearfix">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 moneytransferslab-admin">
                            <div class="page-header-third">
                                @Html.Partial("_slab_Financal")
                            </div>
                            <div class="card admin-slabcardclass">
                                <div class="page-header-third">
                                    <h2 style=" margin-top: 6px;">Pan & Aadhar Verification Charges</h2>

                                    <table class="table table-bordered example-second third-design-table">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Pan Charge</th>
                                                <th>Aadhar Charge</th>
                                                <th>Type</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model)
                                            {
                                                <tr id="details">
                                                    <td>@item.idno</td>
                                                    <td>@item.PanCharge</td>
                                                    <td>@item.AadharCharge</td>
                                                    <td>@item.Type</td>
                                                    <td>
                                                        <a style="border-radius: 4px; background-color: #f4f4f4;" href="#" onclick="Edit()" class="btn ">Edit</a>
                                                    </td>
                                                </tr>
                                                <tr id="SaveChange" style="display: none;">
                                                    <td>@item.idno</td>
                                                    <td>
                                                        <input class="form-control" id="PanCharge" name="PanCharge" type="number" value="@item.PanCharge">
                                                    </td>
                                                    <td>
                                                        <input class="form-control" id="AadharCharge" name="AadharCharge" type="number" value="@item.AadharCharge">
                                                    </td>
                                                    <td>@item.Type</td>
                                                    <td>
                                                        <a style="border-radius: 4px; background-color: #f4f4f4;" href="#" onclick="Save()" class="btn ">Save</a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script>
    function Edit() {
        document.getElementById("details").style.display = 'none';
        document.getElementById("SaveChange").style.display = 'contents';
    }
    function Save() {
        let PanCharge = document.getElementById("PanCharge").value;
        let AadharCharge = document.getElementById("AadharCharge").value;
    
        if (PanCharge === "" || PanCharge === null || AadharCharge === "" || AadharCharge === null) {
            alert("Both PanCharge and AadharCharge are required.");
            return;
        }
        else if (PanCharge < 0 || AadharCharge < 0) {
            alert("Both PanCharge and AadharCharge cannot be negative.");
            return;
        }
    
        $.ajax({
            url: '@Url.Action("AepsAadharpayChargeSet", "Home")',
            method: 'POST',
            data: { PanCharge: PanCharge, AadharCharge: AadharCharge },
            success: (data) => {
                window.location.reload();
            },
            error: (xhr, status, error) => {
                console.error("AJAX Error:", error);
                alert("Failed to update charges. Please try again.");
            }
        });
    }
</script>

