@model Vastwebmulti.Areas.ADMIN.Models.MasterDistributerModel

<style type="text/css">
    .mastetr222Modal .modal-dialog {
        margin: 0px;
    }

    @@keyframes ldio-zdyd6mf6t5 {
        0% {
            top: 96px;
            left: 96px;
            width: 0;
            height: 0;
            opacity: 1;
        }

        100% {
            top: 18px;
            left: 18px;
            width: 156px;
            height: 156px;
            opacity: 0;
        }
    }

    #userinfodiv input:placeholder-shown {
        border-color: red !important;
    }

    .ldio-zdyd6mf6t5 div {
        position: absolute;
        border-width: 4px;
        border-style: solid;
        opacity: 1;
        border-radius: 50%;
        animation: ldio-zdyd6mf6t5 1s cubic-bezier(0,0.2,0.8,1) infinite;
    }

        .ldio-zdyd6mf6t5 div:nth-child(1) {
            border-color: var(--main-bg-lcolor);
        }

        .ldio-zdyd6mf6t5 div:nth-child(2) {
            border-color: #c7c7c7;
            animation-delay: -0.5s;
        }

    .loadingio-spinner-ripple-92ar2pfqk5j {
        width: 200px;
        height: 200px;
        display: inline-block;
        overflow: hidden;
        background: #ffffff;
    }

    .ldio-zdyd6mf6t5 {
        width: 100%;
        height: 100%;
        position: relative;
        transform: translateZ(0) scale(1);
        backface-visibility: hidden;
        transform-origin: 0 0;
    }

        .ldio-zdyd6mf6t5 div {
            box-sizing: content-box;
        }

    .table-bordered tbody tr td, .table-bordered tbody tr th {
        padding: 10px;
    }
</style>



<div class="table-responsive ">
    <table class="table table-bordered table-due-second third-design-table" id="mdList">
        <thead>
            <tr>
                <th>Sr</th>
                <th>Master&nbsp;Distributor&nbsp;Firm</th>
                <th>Master&nbsp;Distributor&nbsp;Name</th>
                <th>Mobile&nbsp;No</th>
                <th>PAN&nbsp;No</th>
                <th>M/D&nbsp;Bal</th>
                <th>KYC</th>
                <th style="width:90px;">E-Verify</th>

            </tr>
        </thead>
        <tbody id="body">
            @if (Model._Select_super_total_Result != null)
            {
                int i = 0;
                int id = 1;
                foreach (var item in Model._Select_super_total_Result)
                {
                    var idno = "subTbl";
                    idno = idno + i;

                    var idshow = "subTblshow";
                    idshow = idshow + i;

                    var idhide = "subTblhide";
                    idhide = idhide + i;

                    <tr class="tr">

                        <td>@id</td>
                        <td>

                            <span id="@idshow" onclick="md_dlm_List('@item.SSId', '@i')">
                                @*<img src="~/AdminDesign/images/down-arrow.svg" style="width:14px;float:left;margin-top:4px;">*@
                                <i class="fa fa-caret-down" aria-hidden="true"></i>&nbsp;&nbsp;
                                @item.FarmName
                            </span>

                            <span id="@idhide" style="display:none;" onclick="md_dlm_Listhide('@i')">
                                @*<img src="~/AdminDesign/images/up-arrow.svg" style="width:14px;float:left;margin-top:4px;">*@
                                <i class="fa fa-caret-up" aria-hidden="true"></i>&nbsp;&nbsp;
                                @item.FarmName
                            </span>

                        </td>
                        <td>@item.SuperstokistName</td>
                        <td>@item.Mobile</td>
                        <td> @item.pancard</td>
                        <td>@item.superremain</td>
                        <td class="kyc-button">
                            @if (item.PSAStatus == "Y" && item.AadhaarStatus == "Y")
                            {
                                <button class="btn ">Done</button>
                            }
                            else
                            {
                                <div class="btn" style="background:var(--main-bg-lcolor);height: 25px;color:#fff; padding: 4px 10px;float:left; font-size: 11px;">Due</div>
                            }
                            @*<button class="btn" style="background:yellow;"><img src="~/images/reportimage/wall-clock.svg" /></button>
                                <button class="btn btn-danger"><img src="~/images/reportimage/close.svg" /></button>
                                <button class="btn btn-success"><img src="~/images/reportimage/check.svg" /></button>*@



                            @*@item.adharcard*@
                        </td>
                        <td data-toggle="modal" data-target="#defaultModal222" onclick="mdActionBtn('@item.SSId',this)">
                            @if (item.EmailConfirmed == true)
                            {
                                <button class="btn due-done-second done-third" style="border:1px solid #bbb;font-size: 11px;padding: 4px 7px;height: 25px;border: 1px solid #bbb;">Done</button>
                            }
                            else
                            {
                                <center>
                                    <div class="btn" style="background:var(--main-bg-lcolor);height: 25px;color:#fff; padding: 4px 10px;float:left; font-size: 11px;">Due</div>
                                </center>
                            }
                            <img class="email-popup-second" src="~/ashok-images/rightaeps.svg" style="width: 11px;margin-top: 6px;float: right;" />
                        </td>

                    </tr>

                    <tr id="@i" style="display:none;background-color: #fff;">
                        <td colspan="8" style="padding:0px;">
                            <div id="@idno">
                                @Html.Partial("_SelectDlmID")
                            </div>
                        </td>
                    </tr>

                    i++;
                    id++;
                }

            }
        </tbody>
    </table>
</div>


