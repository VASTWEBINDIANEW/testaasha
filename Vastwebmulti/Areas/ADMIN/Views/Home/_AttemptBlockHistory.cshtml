
@model Vastwebmulti.Areas.ADMIN.Models.BlockUserViewModel




@foreach (var item in Model.userslist)
{
    <tr>
        <td>@item.Email</td>
        <td>@item.PhoneNumber</td>
        <td>@item.UserName</td>
        <td>@item.LockoutEndDateUtc</td>
        <td>
            <button class="btn btn default first-button" id="DeleteBtn"  style="background-color:transparent; border:none;border:1px solid #c7c2c2; padding:2px 11px 1px 11px;margin-top:2px;" title="Click to Unlock Userid">
                Click To Unlock
            </button>
            <button class="btn btn default fullbodydycolorbg second-buttt"  onclick="RenivalId('@item.UserId')" style="color:#fff;display:none; border:none;border:1px solid #c7c2c2; padding:2px 11px 1px 11px;margin-top:2px;" title="Click to Unlock Userid">
                Are You Sure ?
            </button>
        </td>
    </tr>
}

<script>
    $('.first-button').click(function() {
        $(this).hide();
        $(this).next('.second-buttt').show();
    })
</script>


