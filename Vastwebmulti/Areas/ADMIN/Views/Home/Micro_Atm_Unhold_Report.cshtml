}

<style>
    .table-responsive {width: 100%;float: left;}

    section.content {
        background-color: white;margin: 56px 0px 0 175px;-moz-transition: 0.5s;-o-transition: 0.5s;
        -webkit-transition: 0.5s;transition: 0.5s;
    }
    .microatmnewpdf-class {
        padding-left: 3px;
    }
    .micro-unhold {
        border-radius: 0px;
        border: 1px solid #aaa4a4;
        padding: 2px 5px;
    }
    .unhold-modal .modal-dialog.modal-md {
        float: right;
        margin-top: 0;
    }
    .unhold-modal .modal-header h4 {
        text-transform: uppercase;
        color: #555;
        letter-spacing: 1px;
    }
    .unhold-modal .modal-header {position: relative;}
    .unhold-modal .modal-header button.close {
        position: absolute;right: 15px;font-size: 30px;top: 12px;
        font-weight: 400;opacity: 1;color: #555;
    }
    .unhold-modal .modal-body label {
        font-size: 14px !important;float: left;margin-top:10px;
    }
    
    .unhold-modal .modal-body .form-group input {
        float: right;font-size: 14px !important;padding: 8px 5px;
    }
    .unhold-modal .modal-body {padding: 15px 15px !important;background: #f3f3f3;width:100%;float:left;}
    .unhold-modal .modal-body .form-group {width: 100%;float: left;}
    .unhold-modal .modal-body .form-group input {box-shadow: none;border-radius: 0;border: 1px solid #aaa4a4;background: #f3f3f3;}
    .unhald-modal-confirm {margin-bottom: 0;}
    .unhald-modal-confirm input, .unhald-modal-confirm button {
        padding: 8px !important;height: auto !important;font-size: 14px !important;text-transform: uppercase;
    }
    .unhald-modal-confirm button {margin-left: 5px;}
    .unhald-modal-confirm input {background: #d0cfcf !important;color: #000;}
    .table-responsive table tr th span {
        color: #555;
    }
    .back-white-third-de {
        background: #eeebeb !important;
    }

             /*    new css  */

    .bread-same-all-page {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
             
             /*    new css  */
    
    @@media screen and (max-width:1366px) and (min-width:1320px){
        .microatmreportnew {
            padding-left: 10px;
        }
    }

    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 56px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media screen and (max-width:766px){
        .bread-same-all-page {
            display: block;
        }
        .res_div1 {
            padding: 4px 0;
            width: 100%;
        }
        .microatm-responsive {margin-bottom: 5px;}
        .microatm-section{padding-left:5px;}
        .microatm-responsive {width: 100% !important;float: left !important;}
        .microatm-responsive a {width: 49%;margin-bottom: 5px;}
        .unhold-modal .modal-body label, .unhold-modal .modal-body input {width: 100%;float: left;}
        .unhold-modal .modal-body .form-group {margin-bottom: 0;}
        .unhald-modal-confirm input {width: auto !important;}
        .unhald-modal-confirm {margin-top: 15px;}
        .unhold-modal .modal-dialog.modal-md {padding: 0;margin: 0;}
    }

    @@media screen and (max-width:480px){
        .white-l-search-nine.pdfexpoer-second.totalbutton-secondclas {margin-bottom:5px;}
    }

</style>


