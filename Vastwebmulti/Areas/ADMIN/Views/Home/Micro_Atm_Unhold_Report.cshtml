                    <input type="text" id="txtfrmname" readonly name="txtfrmname" style="font-size: 28px;" />

                </div>
                <div class="form-group">
                    <label style="font-size: 20px;">Bank RRN:</label>
                    <input type="text" id="txtbnkrrnno" readonly name="txtbnkrrnno" style="font-size: 28px;" />

                </div>
                <div class="form-group">
                    <label style="font-size: 20px;">Amount</label>
                    <input type="text" id="txtamountss" readonly name="txtamountss" style="font-size: 28px;" />

                </div>
                <div class="form-group">
                    <label style="font-size: 20px;">Card PayMent Type</label>
                    <input type="text" id="txtcardPaymentType" readonly name="txtcardPaymentType" style="font-size: 28px;" />

                </div>

                <div class="form-group">
                    <label style="font-size: 20px;">Transection Type</label>
                    <input type="text" id="txttransectionType" readonly name="txttransectionType" style="font-size: 28px;" />

                </div>
                <div class="form-group">
                    <label style="font-size: 20px;">Transection Type</label>
                    <input type="text" id="txtPaymentMethode" readonly name="txtPaymentMethode" style="font-size: 28px;" />

                </div>
                <div class="form-group">
                    <label style="font-size: 20px;">NetWork</label>
                    <input type="text" id="txtnetwork" readonly name="txtnetwork" style="font-size: 28px;" />

                </div>


