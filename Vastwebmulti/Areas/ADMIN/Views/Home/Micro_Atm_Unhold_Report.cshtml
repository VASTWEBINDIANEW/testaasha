</div>

<script>
    function EditModel(idno,frmname, rrn, amount, cardpaymenttype, transectiontype, paymentmethode, network) {
        
      
        if (idno != null && idno == '' && idno == 0) {
            $('#txtfrmname').val('');
            $('#txtbnkrrnno').val('');
            $('#txtamountss').val('');
            $('#txtcardPaymentType').val('');
            $('#txttransectionType').val('');
            $('#txtPaymentMethode').val('');
            $('#txtnetwork').val('');
            $('#hdid').val('');
        } else {
            $('#txtfrmname').val(frmname);
            $('#txtbnkrrnno').val(rrn);
            $('#txtamountss').val(amount);
            $('#txtcardPaymentType').val(cardpaymenttype);
            $('#txttransectionType').val(transectiontype);
            $('#txtPaymentMethode').val(paymentmethode);
            $('#txtnetwork').val(network);
            $('#hdid').val(idno);
        }
     


    }
</script>

<script>
    $("#btnExport").click(function () {
        var url = '@Url.Action("Excel_Micro_Atm_Unhold_Report", "Home")';
        location.href = url;
});
</script>


<script>
    $("#btnPDF").click(function () {
      
        var url = '@Url.Action("PDFMicro_Atm_Unhold_Report", "Home")' ;
