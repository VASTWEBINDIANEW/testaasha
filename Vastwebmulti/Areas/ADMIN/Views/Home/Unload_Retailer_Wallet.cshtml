            <div class="body" style="padding:0;float:left;width:100%;">


                <!-- Static Data Start-->
                <div class="table-responsive action-design" style="height: 100vh !important;background:var(--second-bg-color);overflow: auto;">
                    <table class="table table-bordered third-design-table" style="width:100%;">
