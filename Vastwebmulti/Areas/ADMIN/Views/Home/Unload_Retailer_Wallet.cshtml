                                <th>Action&nbsp;&&nbsp;View</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.WalletUnloadReportAdmin.Count() > 0)
                            {
                                foreach (var item in Model.WalletUnloadReportAdmin)
                                {
                                    var i = item.Idno;
                                    var idno = "MNLSuccess";
                                    idno = idno + i;
                                    var idno1 = "MNLFailed";
                                    idno1 = idno1 + i;

                                    var color = ""; var sts = ""; var src = "";
                                    if (item.Status.ToUpper().Contains("PENDING"))
                                    {
                                        color = "#ff9f3a";
                                        sts = "Pending";
                                        src = "../../ashok-images/clock.svg";
                                    }
                                    else if (item.Status.ToUpper().Contains("SUCCESS"))
                                    {
                                        color = "#008000";
                                        sts = item.Status;
                                        src = "../../ashok-images/correct.svg";
                                    }
                                    else if (item.Status.ToUpper().Contains("REJECTED"))
                                    {
                                        color = "#ff0000";
                                        sts = "Rejected";
                                        src = "../../ashok-images/closes.svg";
                                    }
                                    else if (item.Status.ToUpper().Contains("REFUND"))
                                    {
                                        color = "brown";
                                        sts = "Refund";
                                        src = "../../ashok-images/backresnd.svg";

                                    }
                                    <tr>
                                        <td><img src=@src style="font-size: 14px;float: left;width: 20px;background:@color;padding: 4px;border-radius: 50%;" /><p>&nbsp;@sts</p></td>
                                        <td><p style="font-size:12px;">@Html.DisplayFor(modelItem => item.FirmName)</p></td>
                                        <td><p style="font-size:12px;">@Html.DisplayFor(modelItem => item.TransferType)</p></td>
                                        <td><p style="font-size:12px;">@Html.DisplayFor(modelItem => item.BankAccount)</p></td>
                                        <td><p style="font-size:12px;">@Html.DisplayFor(modelItem => item.Amount)</p></td>
                                        <td><p style="font-size:12px;">@Html.DisplayFor(modelItem => item.ProcessingCharge)</p></td>
                                        <td><p style="font-size:12px;">@Html.DisplayFor(modelItem => item.BankRRN)</p></td>
                                        <td><p style="font-size:12px;">@Html.DisplayFor(modelItem => item.RequestDate)</p></td>
                                        <td class="btn-succes-second">
                                            @if (item.Status.ToUpper().Contains("PENDING"))
                                            {
                                                <button type="button" class="btn checks btn-firstwhite-second" id="@idno" onclick="ManualSuccessAction('@item.Idno')" title="Manual Success">
                                                    <i class="fa fa-check" aria-hidden="true"></i>
                                                </button>
                                                <button type="button" class="btn time btn-firstwhite-second" onclick="ManualReject('@item.Idno')" title="Manual Reject">
                                                    <i class="fa fa-times" aria-hidden="true"></i>
                                                </button>
                                            }
                                            @*else if (item.Status.ToUpper() == "SUCCESS")
                                            {
                                                <button type="button" class="btn time btn-firstwhite-second" onclick="SuccessToFailed('@item.Idno', '@item.Status')" title="Manual Reject">
                                                    <i class="fa fa-times" aria-hidden="true"></i>
                                                </button>
                                            }*@
                                            else if (item.Status.ToUpper().Contains("REJECTED"))
                                            {
                                                <button type="button" class="btn checks btn-firstwhite-second" id="@idno" onclick="FailedToSuccess('@item.Idno', '@item.Status')" title="Manual Success">
                                                    <i class="fa fa-check" aria-hidden="true"></i>
                                                </button>
                                            }
                                            @*else
                                                {
                                                    <button type="button" class="btn checks btn-firstwhite-second" id="@idno" onclick="FailedToSuccess('@item.Idno', '@item.Status')" title="Manual Success">
                                                        <i class="fa fa-check" aria-hidden="true"></i>
                                                    </button>
                                                    <button type="button" class="btn time btn-firstwhite-second" onclick="SuccessToFailed('@item.Idno', '@item.Status')" title="Manual Reject">
                                                        <i class="fa fa-times" aria-hidden="true"></i>
                                                    </button>
                                                }*@

                                            <input type="hidden" id="HdIdno" value="0" />
                                            @*<button type="button" onclick="Actions('@item.Idno')" class="btn special-iii" style="border:0;background:transparent;color:#000;width:77px;padding:2px;border:1px solid #bbb;" data-toggle="modal">Action&nbsp;<i class="fa fa-chevron-right tmw-total-color-one fullbodydycolorbg" aria-hidden="true" style="font-size:12px;top:1px;"></i></button>*@
                                            <button type="button" onclick="Actions('@item.Idno')" class="btn special-iii btn-firstwhite-second" style="border:0;background:#ededed;color:#000;padding:2px 12px;border:1px solid #bbb;" data-toggle="modal" @*data-target="#exampleModal"*@> &nbsp;<i class="fa fa-chevron-right tmw-total-color-one fullbodydycolorbg" aria-hidden="true" style="font-size:12px;top:1px;"></i></button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Static Data End-->
                <!-- Table for modal -->
            </div>
        </div>
    </div>
</div>
<!-- Manual Success Modal Start -->
<div class="modal fade Un-rwls-modal" id="ManualSuccessModal" tabindex="-1" role="dialog" aria-labelledby="ManualSuccessModalLabel" aria-hidden="true" style="width:500px; position:absolute; left:406px;">
    <div class="modal-content">
        <div class="modal-header">
            <h4 class="modal-title">Approve Request</h4>
        </div>
        <div class="modal-body">
            <input type="text" id="idNo" name="idNo" class="form-control" style="display:none;" />
            <input type="text" id="txnpass" name="txnpass" class="form-control" required placeholder="Enter Transaction Password" />
            <input  type="text" id="RRN" name="RRN" class="form-control" required placeholder="Enter Bank RRN" />
            <textarea id="txtcomment" name="txtcomment" class="form-control" placeholder="Enter Remark (Optional)"></textarea>
        </div>
        <div class="modal-footer">
            <button type="button" onclick="ManualAccept()" id="btn" class="btn btn-primary" value="Submit">Submit</button>
            <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
        </div>
    </div>
</div>

