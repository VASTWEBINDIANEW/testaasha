<script>
    function Actions(Idno) {
        $('#HdIdno').val(Idno);
        $.ajax({
            url: '@Url.Action("WLActionReport","Home")',
            type: "POST",
            data: {
                Idno: Idno,
                UserType: "Retailer"
            },
            dataType: "json",
            success: function (data) {
                $("#exampleModal .modal-body #ReqId").html(data[0].RequestId);
                $("#exampleModal .modal-header #ActionHeader").html(data[0].FirmName);
                $("#exampleModal .modal-body #bnkAc").html(data[0].BankAccount);
                $("#exampleModal .modal-body #AcHldr").html(data[0].accountholder);
                $("#exampleModal .modal-body #Ifcd").html(data[0].IfscCode);
                $("#exampleModal .modal-body #BnkNm").html(data[0].BankName);
                $("#exampleModal .modal-body #Amt").html(data[0].Amount);
                $("#exampleModal .modal-body #chrg").html(data[0].ProcessingCharge);
                $("#exampleModal .modal-body #PreRm").html(data[0].RemPre);
                $("#exampleModal .modal-body #Dbt").html(data[0].Total_Debit);
                $("#exampleModal .modal-body #PostRm").html(data[0].RemPost);
                $("#exampleModal .modal-body #BnkRrn").html(data[0].BankRRN);
            /*************************Start JSON Date Convertion*******************/
                var MyDate_String_Value = data[0].RequestDate;
                var value = new Date
                    (
                        parseInt(MyDate_String_Value.replace(/(^.*\()|([+-].*$)/g, ''))
                    );
                //var dat = value.getMonth() +
                //    1 +
                //    "/" +
                //    value.getDate() +
                //    "/" +
                //    value.getFullYear();
                dat = value.toLocaleString();

            /**********************************End JSON Date Convertion**************/
                $("#exampleModal .modal-body #DtTm").html(dat);

                //if (data[0].Status == "Pending") {
                //    $('#Manual_SuccessFailed').css('display', 'block');
                //    $('#myApproveRequest').css('display', 'none');
                //}
                //else {
                //    $('#Manual_SuccessFailed').css('display', 'none');
                //    $('#myApproveRequest').css('display', 'none');
                //}
                $("#exampleModal").modal("show");

            },
            error: function (error) {
            }
        });
    }

</script>
<script>
    function ManualAccept() {
        $.ajax({
            url: '@Url.Action("AcceptWalletToBank","Home")',
            type: "POST",
            data: {
                idNo: $('#HdIdno').val(),
                txnpass: $('#txnpass').val(),
                RRN: $('#RRN').val(),
                txtcomment :$('#txtcomment').val()
            },
            dataType: "json",
            success: function (data) {
                var responseJson = JSON.parse(data);
                if (responseJson.status == "Success") {
                    $("#exampleModal").modal("hide");
                    //$('#myApproveRequest').css('display', 'none');
                    $("#ManualSuccessModal").modal("hide");
                $.ajax({
                    url: '@Url.Action("Unload_Retailer_Wallet","Home")',
                    type: 'POST',
                    data: { ddlusers: "Retailer",RetailerId: $("#RetailerId").val(),ddlstatus: $("#ddlstatus").val(), txt_frm_date: $('#txt_frm_date').val(), txt_to_date: $('#txt_to_date').val() },
                    success: function (response) {

                    $('#RetailerSearchList').html(response);

                    }
                  })
                }
            },
            error: function (error) {
                $("#exampleModal").modal("hide");
                $("#ManualSuccessModal").modal("hide");
            }
        });

        $('#HdIdno').val('')
        $('#RRN').val('')
        $('#txtcomment').val('')
    }


    function ManualReject(Idno) {
        $('#HdIdno').val(Idno);
        $.ajax({
            url: '@Url.Action("RefundWalletToBank","Home")',
            type: "POST",
            data: {
                idNo: $('#HdIdno').val()
            },
            dataType: "json",
            success: function (data) {
                $("#exampleModal").modal("hide");
                var responseJson = JSON.parse(data);
                if (responseJson.status == "Success") {
                $.ajax({
                    url: '@Url.Action("Unload_Retailer_Wallet","Home")',
                    type: 'POST',
                    data: { ddlusers: "Retailer",RetailerId: $("#RetailerId").val(),ddlstatus: $("#ddlstatus").val(), txt_frm_date: $('#txt_frm_date').val(), txt_to_date: $('#txt_to_date').val() },
                    success: function (response) {

                    $('#RetailerSearchList').html(response);


                    }
                  })
                }
            },
            error: function (error) {
            }
        });

        $('#HdIdno').val('')
    }

    $('#Manual-Success').on('click', function () {
        $('#myApproveRequest').css('display', 'block');
    });


    function ManualSuccessAction(Idno) {
        $('#HdIdno').val(Idno);
        $("#ManualSuccessModal").modal("show");
    }
</script>


<script>
    $('.third-design .third-design-table tbody td').mouseenter(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'var(--main-bg-rcolor)');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#fff');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'var(--main-bg-rcolor)');
    });

    $('.third-design .third-design-table tbody td').mouseleave(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'transparent');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#333');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'transparent');
    });

    function FailedToSuccess(idno, status) {

        if (status == 'Rejected') {
            $.ajax({
                url: '@Url.Action("wallet_upload_failed_to_success")' + '?idno=' + idno,
                method: 'POST',
                body: { idno },
                success: () => {
                    //location.reload()
                }
            })
        }
    }

    function SuccessToFailed(idno, status) {
        if (status == 'Success') {
            $.ajax({
                url: '@Url.Action("wallet_upload_success_to_failed")' + '?idno=' + idno,
                method: 'POST',
                body: { idno },
                success: () => {
                    //location.reload()
                }
            })
        }
    }
</script>