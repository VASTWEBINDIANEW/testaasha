<!-- Doughnut Chart -->
<script type="text/javascript">
    function initDonutChart(rechargebill, moneytrasfer, Aepsamt, pancardamount) {

        var rechargeandbill = rechargebill;
        var Financial = moneytrasfer;
        var aeps = Aepsamt;
        var Pancard = pancardamount;
        var Travel = 0.00
        var GiftCards = 0.00
        var ECommerce = 0.00

        Morris.Donut({
            element: 'donut_chart',

            data: [
                {
                    label: 'Recharge & bill',
                    value: rechargeandbill,
                },
                {
                    label: 'Financial',
                    value: Financial
                },
                {
                    label: 'Aeps',
                    value: aeps
                },
                {
                    label: 'Pancard',
                    value: Pancard
                },
                {
                    label: 'Travels',
                    value: Travel
                },
                {
                    label: 'Gift Cards',
                    value: GiftCards,
                },
                {
                    label: 'E-Commerce',
                    value: ECommerce
                }
            ],

            colors: [
                'rgb(233, 30, 99)',
                'rgb(0, 128, 255)',
                'rgb(255, 152, 0)',
                'rgb(0, 0, 0)',
                'rgb(76, 175, 80)',
                'rgb(255, 0, 0)',
                'rgb(128, 128, 128)'],

            formatter: function (y) {
                return y
            }
        });

    }
</script>


