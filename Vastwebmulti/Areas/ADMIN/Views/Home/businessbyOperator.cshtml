<script>
    function grossbusiness1(out) {

        if (out == "date") {
            out = $('#txt_frm_date').val();
        }
        else if (out == "today") {
            $("#txt_frm_date").datepicker("setDate", new Date());
        }
        else if (out == "lastday") {
        const today = new Date()
        const tomorrow = new Date(today)
          tomorrow.setDate(tomorrow.getDate() - 1)
           $("#txt_frm_date").datepicker("setDate",tomorrow);
        }
         var url = '@Url.Action("_business", "Home")';
        $.post(url, { data: out }, function (data) {

                    $("#busn_show").html(data);
             })
    }
</script>





