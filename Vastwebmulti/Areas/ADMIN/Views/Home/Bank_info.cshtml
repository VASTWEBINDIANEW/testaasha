                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #ddd;">
                                            @Html.TextBox("txtacnameedit", "", new { @class = "form-control", placeholder = "Enter Holder Name ", required = "required" })
                                        </div>
