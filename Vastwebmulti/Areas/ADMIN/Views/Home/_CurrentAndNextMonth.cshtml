
@model Vastwebmulti.Areas.ADMIN.ViewModel.TargetSetviewmodel
@{

    DateTime todaysDate = DateTime.Now.Date;
    int month = todaysDate.Month;
    int year = todaysDate.Year;
}
<style>
    .edit-target-table tr td input[readonly] {
        background: transparent;
    }
</style>
<table class="table table-bordered table-striped table-hover third-design-table third-design-table table-input-color-third" id="categoryList">
    <thead>
        <tr>
            <th style="text-align: center;">Category</th>
            <th style="text-align: center;">Target&nbsp;Business<br /><span style="color:red;font-size:11px;text-align:center;"> (Total Business)</span></th>
            <th style="text-align: center;">Offer&nbsp;Type</th>
            <th style="text-align: center;">(60%)&nbsp;Achieved <br /><span style="color:red;font-size:11px;text-align:center;">On 60% Of Buss.</span></th>
            <th style="text-align: center;">(70%)&nbsp;Achieved <br /><span style="color:red;font-size:11px;text-align:center;">On 70% Of Buss.</span></th>
            <th style="text-align: center;">(80%)&nbsp;Achieved <br /><span style="color:red;font-size:11px;text-align:center;">On 80% Of Buss.</span></th>
            <th style="text-align: center;">(90%)&nbsp;Achieved <br /><span style="color:red;font-size:11px;text-align:center;">On 90% Of Buss.</span></th>
            <th style="text-align: center;">(100%)&nbsp;Achieved <br /><span style="color:red;font-size:11px;text-align:center;">On 100% Of Buss.</span></th>
            <th style="text-align: center;">Status</th>
            <th style="text-align: center;">Edit</th>

        </tr>
    </thead>
    <tbody>
        <tr id="beforload" style="display:none">
            <td colspan="10"><div class="loader"></div></td>
        </tr>
        <tr id="AfterLoding">
            @if (Model.remTargetCategory != null)
            {
                foreach (var item in Model.remTargetCategory)
                {
                    if (item.Date.Value.Month == month && item.Date.Value.Year == year)
                    {
                    <tr id="id_@item.targetID">
                        <td>@item.Categories</td>
                        <td><input type="text" value="@item.settarget" class="txtsettarget" name="txtsettarget" readonly="readonly" /></td>
                        <td>
                            <div class="for-custom-select-icon">
                                <input type="text" class="ddloffertypeDisplay third-tr-color" disabled="true" value="@item.OfferType" />
                                <select class="ddloffertype" disabled="true" onchange="changeachive(this)" style="display:none;">
                                    <option value="Fixrupees">Fix Rupees</option>
                                    <option value="Giftitem">Gift Item</option>
                                </select>
                            </div>
                        </td>
                        <td>
                            <input type="text" class="txt60achive" value="@item.Achived60" readonly="readonly" />
                            <div class="for-custom-select-icon-other">
                                <select class="ddl60achive" style="display:none;">
                                    @foreach (var Giftitem in Model.tblproductlist)
                                    {
                                        <option value="@Giftitem.Text">@Giftitem.Text</option>
                                    }

                                </select>
                            </div>
                        </td>
                        <td>
                            <input type="text" class="txt70achive" value="@item.Achived70" readonly="readonly" />
                            <div class="for-custom-select-icon-other">
                                <select class="ddl70achive" style="display:none;">
                                    @foreach (var Giftitem in Model.tblproductlist)
                                    {
                                        <option value="@Giftitem.Text">@Giftitem.Text</option>

                                    }
                                </select>
                            </div>
                        </td>
                        <td>
                            <input type="text" class="txt80achive" value="@item.Achived80" readonly="readonly" />
                            <div class="for-custom-select-icon-other">
                                <select class="ddl80achive" style="display:none;">
                                    @foreach (var Giftitem in Model.tblproductlist)
                                    {
                                        <option value="@Giftitem.Text">@Giftitem.Text</option>

                                    }
                                </select>
                            </div>
                        </td>
                        <td>
                            <input type="text" class="txt90achive" value="@item.Achived90" readonly="readonly" />
                            <div class="for-custom-select-icon-other">
                                <select class="ddl90achive" style="display:none;">
                                    @foreach (var Giftitem in Model.tblproductlist)
                                    {
                                        <option value="@Giftitem.Text">@Giftitem.Text</option>

                                    }
                                </select>
                            </div>
                        </td>
                        <td>
                            <input type="text" class="txt100achive" value="@item.Achived100" readonly="readonly" />
                            <div class="for-custom-select-icon-other">
                                <select class="ddl100achive" style="display:none;">
                                    @foreach (var Giftitem in Model.tblproductlist)
                                    {
                                        <option value="@Giftitem.Text">@Giftitem.Text</option>

                                    }
                                </select>
                            </div>
                        </td>
                        <td>
                            @if (item.Status == true)
                            {
                                <div class="onoffswitch onoffswitch-secondclass">
                                    <span class="costom-on custom-on-secondbutton" id="@item.targetID" onclick="RetailerStatus(@item.targetID)">on</span>
                                </div>
                            }
                            else
                            {
                                <div class="onoffswitch onoffswitch-secondclass">
                                    <span class="custom-off custom-off-secondbutton" id="@item.targetID" onclick="RetailerStatus(@item.targetID)">off</span>
                                </div>
                            }

                        </td>
                        <td class="last-target">
                            <button class="edit-target deletebuttoback-second third-tr-color">Edit</button>
                            <button class="save-target third-tr-color" 
                                    @*onclick="handleSubmit('@item.targetID', '@item.settarget','@item.OfferType','@item.Achived60','@item.Achived70','@item.Achived80','@item.Achived90','@item.Achived100')"*@
                                    data-href="@Url.Action("UpdateSetTargerRetailer", "Home", new { targetID = @item.targetID })"
                                    style="display:none;">
                                Save
                            </button>
                        </td>

                    </tr>
                }
            }
        }
        </tbody>
    </table>

    <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>

