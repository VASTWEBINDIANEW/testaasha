                            </h2>
                        </div>
                        <div class="row">
                            <div class="body">
                                <div class="col-md-6">
                                    @Html.HiddenFor(model => model.Id)
                                    <label for="email_address">Service Name 1</label>
                                    <div class="form-group">
                                        <div class="" style="border:1px solid #c7c2c2;">
                                            @Html.TextBoxFor(model => model.ServiceName1, new { @class = "form-control" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label for="email_address">Service Name 2</label>
