@model Vastwebmulti.Models.tblFooterService
@{
    ViewBag.Title = "Edit_FooterService";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                @using (Html.BeginForm("Edit_FooterService", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
