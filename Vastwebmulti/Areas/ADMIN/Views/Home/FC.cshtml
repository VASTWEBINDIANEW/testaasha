                }

            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
    }


</script>
<!--Edit master detail-->
<script type="text/javascript">
    var val1 = "";
    function animation(FCId) {
        var url = '@Url.Action("FCIdSearch", "Home")'
        $.ajax({
            url: url,
            data: { fcid: FCId },
            cache: false,
            type: "POST",
            success: function (data) {
                $("#FeeCollectorName1").val(data[0].FCName);
                $("#txtFCId").val(FCId);
                $("#FirmName1").val(data[0].FirmName);
                $("#Address1").val(data[0].Address);
                $("#SchoolName1").val(data[0].SchoolName);
                $("#Website1").val(data[0].Website);

                $("#Pincode1").val(data[0].Pincode);
                $("#pancard1").val(data[0].pancard);
                $("#adharcard1").val(data[0].adharcard);
                $("#gst1").val(data[0].gst);
                $("#CommissionAdmin1").val(data[0].CommissionAdmin);
                $("#CommissionMD1").val(data[0].CommissionMD);
                $("#CommissionDLM1").val(data[0].CommissionDLM);
                $("#CommissionREM1").val(data[0].CommissionREM);
                $("#CommissionWL1").val(data[0].CommissionWL);
                $("#State1").val(data[0].State);
                GetDistrict1(data[0].State)
                var objSelect1 = document.getElementById("District1");
                binddist(data[0].State, data[0].District, objSelect1);
                $('#defaultModal1').modal('show');
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });

    }
    function binddist(staid, dist, objSelect1) {
        var url = '@Url.Action("DistrictList","Home")'
        $.ajax({
            url: url,
            data: { Id: staid },
            cache: false,
            type: "POST",
            success: function (data) {
                var markup = "<option value='0'>Select District</option>";
                for (var x = 0; x < data.length; x++) {
                    markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                }
                $("#District").html(markup).show();
                setSelectedValue(objSelect1, dist);
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
    }
    function setSelectedValue(selectObj, valueToSet) {

        for (var i = 0; i < selectObj.options.length; i++) {
            if (selectObj.options[i].value == valueToSet) {
                //alert(selectObj.options[i].value);
                selectObj.options[i].selected = true;
                return;
            }
        }
    }
</script>
