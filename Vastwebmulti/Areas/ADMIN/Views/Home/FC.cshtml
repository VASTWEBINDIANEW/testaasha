                                            @Html.TextBoxFor(m => m.CommissionMD, new { @class = "selectpicker form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;", required = "required" })
                                            @*@Html.ValidationMessageFor(m => m.Commission, "", new { @class = "text-danger" })*@
