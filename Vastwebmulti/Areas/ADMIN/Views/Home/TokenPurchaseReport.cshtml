<script>

    function tokenStatus(id) {

        var url = '@Url.Action("GetTokenStatus", "Home")'
        var jqxhr = $.post(url, {id : id}, function (data) {
            var response = JSON.parse(data);
            if (response.RESULT == "0") {
                //swal("Wow!", response.ADDINFO, "success");
                //location.reload();
                ToastrMessage();
                toastr.success('Wow! ' +response.ADDINFO);

            }
            else {
                //swal("Oops!!!", response.ADDINFO, "error");

                ToastrMessage();
                toastr.error('Oops!!! ' +response.ADDINFO);
            }
        })
       .fail(function (jqXHR, textStatus, errorThrown) {

           //swal("Oops!!!", jqXHR.responseText, "error");

           ToastrMessage();
           toastr.error('Oops!!! ' +jqXHR.responseText);

       })

    }
    function manuallyfailed(id,msg) {
        var url = '@Url.Action("PanManualFailed", "Home")'
        var jqxhr = $.post(url, { id: id, remark :msg}, function (data) {
            var response = JSON.parse(data);
            if (response.RESULT == "0") {
                swal("Wow!", response.ADDINFO, "success");
                //location.reload();


            }
            else {
                swal("Oops!!!", response.ADDINFO, "error");


            }
        })
       .fail(function (jqXHR, textStatus, errorThrown) {

           //swal("Oops!!!", jqXHR.responseText, "error");

           ToastrMessage();
           toastr.error('Oops!!!' +jqXHR.responseText);

       })

    }
</script>
