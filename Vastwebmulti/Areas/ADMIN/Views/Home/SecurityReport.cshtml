                                                    {
                                                        icon = "../../ashok-images/closes.svg";
                                                        backcolor = "red";
                                                        padd = "3px";
                                                    }
                                                    else if (item.Status.ToUpper() == "PENDING")
                                                    {
                                                        icon = "../../ashok-images/clock.svg";
                                                        backcolor = "";
                                                        padd = "0px";
                                                    }
                                                    else
                                                    {
                                                        icon = "../../ashok-images/backresnd.svg";
                                                        backcolor = "brown";
                                                        padd = "2px";
                                                    }
                                                    decimal final = Convert.ToDecimal(item.amount) - Convert.ToDecimal(item.total_rem_pay);

                                                    var idnn = item.idno + "divchk";
                                                    var rchsuc = item.idno + "nrchsuccess";
                                                    var rchfailed = item.idno + "nrchfailed";

                                                    <tr>


                                                        <td>
