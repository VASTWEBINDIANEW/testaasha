                                                        <td>@item.plan_nm</td>
                                                        <td>@item.Frm_Name</td>
                                                        <td>@item.amount</td>
                                                        <td>@item.total_rem_pay</td>
                                                        <td>@item.rempre</td>

                                                        <td>@final</td>
                                                        <td>@item.rempost</td>
                                                        <td>@item.OPerator_id</td>

                                                        <td>@item.transfer_time</td>
                                                        <td>
                                                            <p id="@idnn" style="margin:0px;">
                                                                @if (item.Status.ToUpper() == "PENDING")
