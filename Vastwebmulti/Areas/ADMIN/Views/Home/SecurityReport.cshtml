<script>
    function ActionBtn(resptime, dlmpre, dlmincome, dlmpost, mdpre, mdincome, mdpost, adminincome, apireq, apiresp) {
        $('#resptm').text(resptime);
        $('#distpre').val(dlmpre);
        $('#distincome').val(dlmincome);
        $('#distpost').val(dlmpost);
        $('#mdpre').val(mdpre);
        $('#mdincome').val(mdincome);
        $('#mdpost').val(mdpost);
        $('#adminincome').val(adminincome);
        $('#APIRequest').val(apireq);
        $('#APIResponse').val(apiresp);
    }
</script>

<script>
    function Successchk(idno) {
        let idnn = idno + "divchk";
        let rchsuc = idno + "nrchsuccess";
        let rchfailed = idno + "nrchfailed";
        $('#' + idnn).hide();
        $('#' + rchsuc).show();
        $('#' + rchfailed).hide();
    }
    function Failedchk(idno) {
        let idnn = idno + "divchk";
        let rchsuc = idno + "nrchsuccess";
        let rchfailed = idno + "nrchfailed";
        $('#' + idnn).hide();
        $('#' + rchsuc).hide();
        $('#' + rchfailed).show();
    }
</script>

