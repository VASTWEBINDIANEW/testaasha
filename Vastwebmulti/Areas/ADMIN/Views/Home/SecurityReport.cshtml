                                                                        <i class="fa fa-check" style="top:1px;border:1px solid var(--border-color);padding: 3px;font-size: 13px;" aria-hidden="true"></i>
                                                                    </button>
                                                                    <button class="ff" onclick="Failedchk('@item.idno')" style="background:transparent;border:none;float:left;margin-right:2px;" title="Manual Failed">
                                                                        <i class="fa fa-times" style="top:1px;border:1px solid var(--border-color);padding: 3px 4px;font-size: 13px;" aria-hidden="true"></i>
