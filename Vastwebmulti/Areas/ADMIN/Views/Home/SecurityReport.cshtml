                                                                <button class="ff" data-toggle="modal" data-target="#defaultModal222" onclick="ActionBtn('@item.Response_time','@item.dlmpre','@item.total_dlm_pay','@item.dlmpost','@item.mdpre','@item.total_md_pay','@item.mdpost','@item.purchase_final','@item.Api_request','@item.Api_response')" style="color:#ffc107;background:transparent;border:none;margin-top:0px !important;float:left;">
                                                                    <img src="~/ashok-images/rightaeps.svg" style="border: 1px solid var(--border-color);padding: 3px 3px;font-size: 10px;height:20px !important;">
                                                                </button>
                                                            </p>

                                                            <p id="@rchsuc" class="nrchsuccess" style="display: none;margin:0px; text-align: center; background: green; width: 100%; padding: 5px;">
                                                                <button style="color: #fff; font-weight: 800;font-size: 11px; background-color:transparent;border-color:transparent;" onclick="Response('@item.req_id','Success')">
                                                                    I'M SURE&nbsp;>&nbsp;SUCCESS
