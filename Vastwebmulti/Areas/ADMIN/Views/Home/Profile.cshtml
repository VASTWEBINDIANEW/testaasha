<section class="content fourdesign-section-admin">

    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>Profile</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard", "Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>

                <li><a href="javascript:void(0);">Profile</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix">
            <div class="col-md-4 profile-third-design">
                <div class="card page-header-third" style="">
                    <div class="ribbon"><span class="fullbodydycolorbg">ADMIN</span></div>

                    <div class="body fullbodydycolorbg">
                        <center>
                            @if (!string.IsNullOrWhiteSpace(ViewBag.image))
                            {
                                <div class="image" style="margin-top:24px;">
                                    <img id="Adminimage" src="@Url.Content("~/" + ViewBag.image)" class="img-circle profileimg-third" alt="User" width="100" height="100" title="Click Me Upload Profile Image" style="cursor:pointer;" onclick="uploadimage(@ViewBag.admin.ID)" />
                                </div>
                            }
                            else
                            {
                                <div class="image" style="margin-top:24px;">
                                    <img id="Adminimage" src="~/AdminDesign/images/user.png" width="100" height="100" class="img-circle profileimg-third" alt="User" title="Click Me Upload Profile Image" style="cursor:pointer;" onclick="uploadimage(@ViewBag.admin.ID)">
                                </div>
                            }

                            <div class="msg" style="padding-top:12px; font-size:19px; font-weight:600; color:#fff">@ViewBag.admin.Name</div>
                            <p style="margin-top:5px;font-size:14px;text-transform:uppercase;color:#fff;">Administrator</p>

                        </center>
                    </div>

                    <div class="res_p" style="background-color: #c7c7c7; padding: 5px 10px; width: 100%; float: left; display: flex; align-items: center; justify-content: space-between; margin-top: 14px;">

                        <h2 style="margin: 0; font-size: 20px; text-transform: uppercase;">Auto Credit on/off</h2>

                        @{
                            VastwebmultiEntities db = new VastwebmultiEntities();
                            var set = db.Email_show_passcode.SingleOrDefault().cr_status;
                        }
                        @if (set == true)
                        {
                            @Html.ActionLink("Auto Credit ON", "CreaditSetting", "ADMIN", new { @style = "padding: 6px 12px; font-size: 14px; background: forestgreen; color: aliceblue;float: right;" })
                            @*<button style=" margin: 10px 10px 10px 10px; padding: 5px 10px 5px 10px; font-size: 16px; background: forestgreen; color: aliceblue;">
                    Auto Credit ON
                </button>*@
                        }
                        else
                        {
                            @Html.ActionLink("Auto Credit OFF", "CreaditSetting", "ADMIN", new { style = "padding: 6px 12px;font-size: 14px; background: red; color: aliceblue; float: right;" })
                            @*<button style=" margin: 10px 10px 10px 10px; padding: 5px 10px 5px 10px; font-size: 16px; background: red; color: aliceblue;">
                    Auto Credit OFF
                </button>*@
                        }
                    </div>

                    <div class="res_p" style="background-color: #c7c7c7; padding: 5px 10px; width: 100%; float: left; display: flex; align-items: center; justify-content: space-between; margin-top: 14px;">

                        <h2 style="margin: 0; font-size: 20px; text-transform: uppercase;">Rediant Status</h2>

                        @{

                            var set1 = db.rediantdistresponses.ToList();
                            var set2 = db.radiantauths.ToList();
                        }
                        @if (set1.Count == 0)
                        {
                            if (set2.Count == 0)
                            {
                                <div>Rediant Auth is Required</div>
                            }
                            else
                            {
                            @Html.ActionLink("Create Rediant Distributer", "rediantdisform", "ADMIN", new { @style = "padding: 6px 12px; font-size: 14px; background: forestgreen; color: aliceblue;float: right;" })
                            }
                        }
                        else if (set1[0].status == "Approved")
                        {
                            <div>APPROVED</div>
                        }
                        else
                        {
                            <div id="redfull">  <div id="redtext">@set1[0].status</div> <div id="redbutton"><button onclick="checkrediantsts();">Check Status</button></div> </div>
                        }
                        <script>
                           function checkrediantsts() {
                               $.ajax({
                                type: "POST", url: '@Url.Action("checkrediantdissts", "Home")',
                          
                                   cache: false,
                                   success: function (data) {
                                       alert(data);
                                       if (data == "Approved") {
                                        document.getElementById('redfull').innerHTML = "APPROVED";

                                    }

                                }
                            });
                        }
                        </script>
                    </div>
                </div>

            </div>

            <div id="saveaddressModal" class="col-lg-8 col-md-8 col-sm-12 col-xs-12">
                <div class="card page-header-third" style="margin-bottom:0px;">
                    <div class="heading-back-third boxback-allpage-admin" style="background-color:#c7c7c7;padding: 5px 10px; padding:10px;">
                        @if (ViewBag.admin.Companyname != null)
