<script>
function WriteOTPStatus(roleName, stsBtn) {

        $.ajax({
            type: "POST", url: '@Url.Action("AdminOTPStatus", "Home")',
            data: { 'RoleName': roleName, 'Status': stsBtn },
            dataType: 'json',
            cache: false,
            success: function (data) {
                if (data.RoleName == "master" && data.Status == "Y") {
                    $('#masterotpoff').removeClass('custom-off');
                    $('#masterotpoff').addClass('costom-on');
                    $('#masterotpoff').text('ON');

                    $('.loader').hide();
                }
                else if (data.RoleName == "master" && data.Status == "N") {
                    $('#masterotpon').addClass('custom-off');
                    $('#masterotpon').removeClass('costom-on');
                    $('#masterotpon').text('OFF');
                }
                else if (data.RoleName == "Dealer" && data.Status == "Y") {
                    $('#dealeroff').removeClass('custom-off');
                    $('#dealeroff').addClass('costom-on');
                    $('#dealeroff').text('ON');
                }
                else if (data.RoleName == "Dealer" && data.Status == "N") {
                    $('#dealeron').addClass('custom-off');
                    $('#dealeron').removeClass('costom-on');
                    $('#dealeron').text('OFF');
                }
                else if (data.RoleName == "Retailer" && data.Status == "Y") {
                    $('#retaileroff').removeClass('custom-off');
                    $('#retaileroff').addClass('costom-on');
                    $('#retaileroff').text('ON');
                }
                else if (data.RoleName == "Retailer" && data.Status == "N") {
                    $('#retaileron').addClass('custom-off');
                    $('#retaileron').removeClass('costom-on');
                    $('#retaileron').text('OFF');
                }
                else if (data.RoleName == "API" && data.Status == "Y") {
                    $('#apioff').removeClass('custom-off');
                    $('#apioff').addClass('costom-on');
                    $('#apioff').text('ON');
                }
                else if (data.RoleName == "API" && data.Status == "N") {
                    $('#apion').addClass('custom-off');
                    $('#apion').removeClass('costom-on');
                    $('#apion').text('OFF');
                }
                if (data.RoleName == "Whitelabel" && data.Status == "Y") {
                    $('#whitelabeloff').removeClass('custom-off');
                    $('#whitelabeloff').addClass('costom-on');
                    $('#whitelabeloff').text('ON');
                }
                else if (data.RoleName == "Whitelabel" && data.Status == "N") {
                    $('#whitelabelon').addClass('custom-off');
                    $('#whitelabelon').removeClass('costom-on');
                    $('#whitelabelon').text('OFF');
                }

                window.location.href = "@Url.Action("Profile","Home")";
            },
        });

    }
</script>
