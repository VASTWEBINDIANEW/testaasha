@model IEnumerable<Vastwebmulti.Models.Login_setting_email_phone>
<style>

    .Weblogin-left .tab-content#tab-1 fieldset.secondf.fff.secondf-custom {
        border-color: var(--border-color);
    }


    .Weblogin-left .tab-content#tab-1 fieldset legend {
        color: #000;
    }

    .Weblogin-left .tab-content#tab-1 legend {
        width: auto;
        border: 0;
        padding: 0 5px;
        margin-bottom: 6px;
        text-align: center;
    }

    .registr {
        position: absolute;
        top: -15px;
        width: 50%;
        left: 20px;
        border: 0px;
        background: #eae9e9;
        font-size: 11px;
        font-weight: 700;
    }

        .registr legend {
            width: auto;
            display: block;
            margin-bottom: 20px;
            font-size: 28px;
            line-height: inherit;
            color: #333;
            border: 0;
            padding: 10px;
            margin-left: 30px;
        }

    .Weblogin-left .tab-content#tab-1 fieldset.secondf button {
        border: 2px solid #ff0000;
    }



    .Weblogin-left .tab-content#tab-1 fieldset button img {
        display: block;
        margin: auto;
        margin-bottom: auto;
        margin-bottom: 10px;
    }

    .btn:not(.btn-link):not(.btn-circle) span {
        position: relative;
        top: 0px;
        margin-left: 3px;
    }

    .Weblogin-left .tab-content#tab-1 fieldset.secondf p {
        width: 100%;
    }

    .tab-content fieldse {
        margin-top: 15px !important;
        float: left;
        width: 46.3%;
        border: 15px solid var(--main-bg-lcolor);
        margin: 0px 11px 11px 11px;
        background: #eae9e9;
        position: relative;
    }

    #Statussetting button {
        border-radius: 81px;
        height: 130px;
        width: 130px;
    }

    .dmlsing-seconddesign.border-full-third {
        background: #ccc;
        border-radius: 10px;
        margin: 20px;
    }

    .adm {
        background: var(--main-bg-rcolor);
        text-transform: uppercase;
        color: #fff;
        width: 96%;
        margin: 0px 11px 11px 11px;
        font-size: 24px;
    }
</style>
