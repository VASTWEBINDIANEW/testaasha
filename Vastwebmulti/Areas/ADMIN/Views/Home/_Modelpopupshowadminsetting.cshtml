<div id="tab-1" class="tab-content currents" style="text-align:center">
    <div id="Statussetting">
        <h2 class="adm">Admin     Login     Permission</h2>
        @foreach (var item in Model)
        {
            <fieldse class="secondf fff secondf-customs">


                <legend class="registr">By Registr Mobile No.</legend>
                @if (item.mobile == true)
                {

                    <button data-id="2" onclick="updatedata('mobile')" type="button" class="btn btn-firstwhite-second" style="margin-top:18px;width:99px;height:99px;">
                        <img src="~/img/green-right.svg" alt="Right Arrow image" style="width:32px;">
                        <span style="width: 100% !important; float: left;position:relative;top:10px;margin-left:0px;"> Active </span>
                    </button>


                }
                else
                {
                    <button data-id="2" onclick="updatedata('mobile')" type="button" class="btn btn-firstwhite-second" style="margin-top: 18px; width: 99px; height: 99px;">
                        <img src="~/img/red.svg" alt="Wrong Arrow image" style="width:32px;">
                        <span style="width: 100% !important; float: left;position:relative;top:10px;margin-left:0px;"> Deactive </span>
                    </button>

                }


                <p class="dmlsing-seconddesign border-full-third">@*Email verification is required for high security*@</p>
            </fieldse>


            <fieldse class="firstf sss firstf-custom">
                <legend class="registr">By Registr Email ID</legend>

                @if (item.email == true)
                {
                    <button data-id="2" onclick="updatedata('email')" type="button" class="btn btn-firstwhite-second" style="margin-top: 18px; width: 99px; height: 99px;">
                        <img src="~/img/green-right.svg" alt="Right Arrow image" style="width:32px;">
                        <span style="width: 100% !important; float: left;position:relative;top:10px;margin-left:0px;"> Active </span>
                    </button>

                }
                else
                {

                    <button data-id="2" onclick="updatedata('email')" type="button" class="btn btn-firstwhite-second" style="margin-top: 18px; width: 99px; height: 99px;">
                        <img src="~/img/red.svg" alt="Wrong Arrow image" style="width:32px;">
                        <span style="width: 100% !important; float: left;position:relative;top:10px;margin-left:0px;"> Deactive </span>
                    </button>
                }
                <p class="dmlsing-seconddesign border-full-third">@*No more security required, then send password to mobile*@</p>
            </fieldse>
        }
    </div>


</div>





