<script>
    function updatedata(chk) {
       // $("#modeldeiv").html("")

        $.ajax({
            url: "@Url.Action("updateadminlogin","Home")",
            type: 'POST',
            data: { name: chk},
            success: function (response) {
               // location.reload();

                $("#modeldeiv").html(response)
            },
            error: function () {
                //$("#loader").show();
                alert("error occured");
            }
        });
    }
</script>