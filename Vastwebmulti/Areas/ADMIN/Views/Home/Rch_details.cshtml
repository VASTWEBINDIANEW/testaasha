<script type="text/javascript">
        var val1 = "";
        function editrch(RCHId) {
            var url = '@Url.Action("ShowRchIdsearch", "Home")'
            $.ajax({
                url: url,
                data: { Rchid: RCHId },
                cache: false,
                type: "POST",
                success: function (data) {

                    $("#txtrchid").val(data[0].RCHId);
                    $("#txtemail").val(data[0].Email);
                    $("#txtname").val(data[0].RCHName);
                    $("#txtfrimname").val(data[0].FarmName);
                    $("#State").val(data[0].State);
                    $("#txtmobil").val(data[0].Mobile);
                    $("#Address").val(data[0].Address);
                    $("#Pincode").val(data[0].Pincode);
                    var objSelect1 = document.getElementById("District");
                    bind(data[0].State, data[0].District, objSelect1);
                    $('#defaultModal1').modal('show');
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                }
            });

        }
    function bind(staid, dist, objSelect1) {

            var url = '@Url.Action("DistrictList","Home")'
            $.ajax({
                url: url,
                data: { Id: staid },
                cache: false,
                type: "POST",
                success: function (data) {
                    var markup = "<option value='0'>Select District</option>";
                    for (var x = 0; x < data.length; x++) {
                        markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                    }
                    $("#District").html(markup).show();
                    setSelectedValue(objSelect1, dist);
                },
                error: function (reponse) {
                    alert("error : " + reponse);
                }
            });
        }
    function setSelectedValue(selectObj, valueToSet) {

            for (var i = 0; i < selectObj.options.length; i++) {
                if (selectObj.options[i].value == valueToSet) {
                    //alert(selectObj.options[i].value);
                    selectObj.options[i].selected = true;
                    return;
                }
            }
        }
</script>



