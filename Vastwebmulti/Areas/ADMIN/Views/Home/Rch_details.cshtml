<style>
    .btn-group, .btn-group-vertical {
        box-shadow: none;
    }

    .dropdown {
        position: relative;
        display: inline-block;
    }

    .dropdown-content {
        display: none;
        position: absolute;
        background-color: #f9f9f9;
        min-width: 160px;
        box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
        padding: 12px 16px;
        z-index: 1;
    }

    .dropdown:hover .dropdown-content {
        display: block;
    }

    .toast-top-right1 {
        top: 65px;
        left: 81%;
    }

    .table-bordered tbody tr td, .table-bordered tbody tr th {
        padding: 10px;
    }

    @@keyframes ldio-zdyd6mf6t5 {
        0% {
            top: 96px;
            left: 96px;
            width: 0;
            height: 0;
            opacity: 1;
        }

        100% {
            top: 18px;
            left: 18px;
            width: 156px;
            height: 156px;
            opacity: 0;
        }
    }



    .ldio-zdyd6mf6t5 div {
        position: absolute;
        border-width: 4px;
        border-style: solid;
        opacity: 1;
        border-radius: 50%;
        animation: ldio-zdyd6mf6t5 1s cubic-bezier(0,0.2,0.8,1) infinite;
    }

        .ldio-zdyd6mf6t5 div:nth-child(1) {
            border-color: var(--main-bg-lcolor);
        }

        .ldio-zdyd6mf6t5 div:nth-child(2) {
            border-color: #c7c7c7;
            animation-delay: -0.5s;
        }

    .loadingio-spinner-ripple-92ar2pfqk5j {
        width: 200px;
        height: 200px;
        display: inline-block;
        overflow: hidden;
        background: #ffffff;
    }


    .ldio-zdyd6mf6t5 {
        width: 100%;
        height: 100%;
        position: relative;
        transform: translateZ(0) scale(1);
        backface-visibility: hidden;
        transform-origin: 0 0;
    }

        .ldio-zdyd6mf6t5 div {
            box-sizing: content-box;
        }


    .for-search {
        position: absolute;
        right: 130px;
    }

        .for-search input {
            width: 250px;
            border: 1px solid #dbdbdb;
            padding: 3px 10px;
        }

    ul.other-serve li a {
        display: block;
        text-align: center;
        padding: 3px 10px;
        text-decoration: none;
        border: 1px solid #b1a6a638;
        position: initial;
    }

    ul.other-serve {
        position: absolute;
        right: 390px;
    }

        ul.other-serve li {
            float: left;
            margin-left: 3px;
        }

    @@media only screen and (max-width:520px) {
        .web-white-filter {
            position: static !important;
        }

        .for-search input {
            width: 100%;
        }

        .for-search {
            top: 108px;
        }

        ul.other-serve {
            right: 15px;
        }
    }


    .secend_b-type {
        background-image: linear-gradient(to right, var(--main-bg-lcolor), var(--main-bg-rcolor));
        font-size: 16px;
        color: #fff;
        padding: 5px 23px;
        float: right;
        border: 1px solid;
        margin: 0px 5px;
    }

