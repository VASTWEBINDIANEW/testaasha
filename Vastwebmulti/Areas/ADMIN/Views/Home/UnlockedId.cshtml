@model IEnumerable<Vastwebmulti.Models.User>
@{
    ViewBag.Title = "UnlockedId";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style>
    .dropdown-menu {
        margin-top: 81px !important;
    }
</style>
<section class="content">
    <div class="container-fluid">
        <div class="row">
<div class="col-md-12">
    <div class="card">
        <div class="col-md-6">
            <div style="margin-left:-13px;">
                @Html.Partial("_Loginmenu")
            </div>

        </div>
        <div class="col-md-6">
            @using (Html.BeginForm("UnlockedId", "Home", FormMethod.Post))
            {
                <div class="row">
                    <div class="col-md-2">

                    </div>
                    <div class="col-md-6">
                        <div class="form-group" style="margin-bottom:0px;">
                            <div class="input-daterange input-group">
                                @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;", autocomplete = "off" })
                                <span class="input-group-addon">
                                    <i class="fa fa-exchange"></i>
                                </span>
                                @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; margin-top:4px;", autocomplete = "off" })
                            </div>
                            <!-- /.input group -->
                        </div>
                    </div>
                    <div class="col-md-2">
                        <center>
                            <button type="submit" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left: -3px; height:34px;">
                                <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                <span style="top:-2px;color:black;">Search</span>
                            </button>
                        </center>
                    </div>
                </div>
            }
        </div>

    </div>
</div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-7px;">
                <div class="card">
                       <div class="body" style="padding:7px;margin-top:-10px;">
                        <div class="table-responsive" style="position:inherit;margin-top:-1px;">
                            <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>UserId</th>
                                        <th>Register&nbsp;Number</th>
                                        <th>Register&nbsp;Email</th>
                                        <th>Lock&nbsp;Out&nbsp;DateTime</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Count() >0)
                                    {
                                        foreach (var item in Model)
                                        {
                                      <tr>
                                            <td>@item.Email</td>
                                            <td>@item.PhoneNumber</td>
                                            <td>@item.UserName</td>
                                          <td>@item.LockoutEndDateUtc</td>
                                            <td>
                                                <button class="btn btn default" id="DeleteBtn" onclick="RenivalId('@item.UserId')" style="background-color:transparent; border:none;border:1px solid #c7c2c2; padding:2px 11px 1px 11px;margin-top:2px;" title="Click to Unlock Userid">
                                                    Click To Unlock
                                                </button>
                                    </td>
                                        </tr>
                                        }
                                    }
                                    else
                                    {
                                    <tr>
                                        <td></td>
                                        <td></td>
                                        <td><p style="font-size:22px;margin-top:20px;text-align:center;color:#e0dddd;font-weight:700;">No Data Found !</p></td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
               
    </div>
</section>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>

<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script>
    function RenivalId(userid)
    {
        var r = confirm("Are You Sure!");
        if (r == true)
        {
            $.ajax({
                type: "POST",
                url: '@Url.Action("Unlockuserid", "Home")',
                cache: false,
                dataType: 'json',
                data:{userid:userid},
                async: true,
                success: function (data) {
                    var sts = data.Status;
                    var message = data.Message;
                    if (sts == "Success") {
                        swal({ title: "UnLock !", text: message, type: "success" },
                             function () {
                                                 location.reload();
                              }
                          );
                       }
                }
            });
            return true;
        }
        else {
      
            return false;
        }
    }
</script>
<script>
    $(document).ready(function () {
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
    });
</script>
