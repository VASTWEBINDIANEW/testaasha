<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />

<!--Insert Popuop-->
<script>
        window.onload = function()
        {
            var message = '@TempData["success"]'
            if (message != "" && message != null)
            {
                if (message.includes("successfully")) {
                    swal("Insert Item!", message, "success");
                }
                else {
                    swal("Oops!", message, "error");
                }
            }
                       //Edit Message
            var editdata = '@TempData["edit"]'
            if (editdata != null && editdata != "")
            {
                swal("Update Item!", editdata, "success");
            }

        }
</script>

<script type="text/javascript">
     var val1 = "";
     function animation(ID,Border) {
         $("#txtBorderedit").val(Border);
         $("#txtidno").val(ID);
     }
</script>
<!--Delete-->
<script type="text/javascript">

    function delmessage(e) {

        swal({
            title: "Are you sure?",
            text: "Do you want to delete Outer Border Data " + e + " !",
            type: "warning",
            showCancelButton: true,
            confirmButtonColor: "#DD6B55",
            confirmButtonText: "Yes, delete it!",
            closeOnConfirm: false
        },
function () {

    $.ajax({
        type: "POST", url: '@Url.Action("delBorderinfo", "Home")', data: { id: e }, dataType: 'json', cache: false, success: function (result) {
            if (result == "Success") {
                swal("Data Removed!", "Outer Border Deleted Successfully.", "success");
                var url = '@Url.Action("Outer_Page_Border", "Home")';
                window.location.href = url;
            }
            else {
                swal("Failed!", "Something went wrong.", "error");
                var url = '@Url.Action("Outer_Page_Border", "Home")';
                window.location.href = url;
            }
        }
    });
}
);

    }

</script>
<script type="text/javascript">
        function isNumber(evt) {
            var iKeyCode = (evt.which) ? evt.which : evt.keyCode
            if (iKeyCode != 46 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
                return false;
            return true;
        }
</script>

