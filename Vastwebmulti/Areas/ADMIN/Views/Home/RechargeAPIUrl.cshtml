        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card page-header-third">
                    <div class="col-md-12">
                        <div class="col-md-12 rtyfrty rtyfrtyclass-third" style=" float:left; ">
                            <div style="">
                                @Html.Partial("_menuapinm")
                            </div>

                        </div>
                        <div class="col-md-12 rtyfrty rtyfrtyclass-third" style="float: right;  ">
                            <div style="">
                                @Html.Partial("_menu_rch_Api")
                            </div>

                        </div>


                    </div>

                    <div class="" style="width: 100%; float: left; margin-top: 6px;">
                        <div class="table-responsive tablefourdesign-admin" style="position:inherit;">
                            <table class="table table-bordered table-striped example-second" style="width:100%;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Api Name</th>
                                        <th>Api URL</th>
                                        <th>Api Type</th>
                                        <th>Request Type</th>
                                        <th>Key Userid</th>
                                        <th>Val Userid</th>
                                        <th>Key Password</th>
                                        <th>Value Password</th>
                                        <th>Key Recharge No</th>
                                        <th>Key OptCode</th>
                                        <th>Key Amount</th>
                                        <th>Key RequestID</th>
                                        <th>is STV</th>
                                        <th>Key State Code</th>
                                        <th>Key No Romaing</th>
                                        <th>Status</th>
                                        <th>Success To Failed</th>
                                        <th>Failed To Success</th>
                                        <th>#</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.apiname</td>
                                            <td>@item.apiendpoint</td>
                                            <td>@item.apitype</td>
                                            <td>@item.Requesttype</td>
                                            <td>@item.Keyuserid</td>
                                            <td>@item.valuserid</td>
                                            <td>@item.Keypasscode</td>
                                            <td>@item.valpasscode</td>
                                            <td>@item.Keyrechargeno</td>
                                            <td>@item.Keyoptcode</td>
                                            <td>@item.KeyAmount</td>
                                            <td>@item.KeyReqid</td>
                                            <td>@item.isstv</td>
                                            <td>@item.keystatecode</td>
                                            <td>@item.keynoromaing</td>
                                            <td>
                                                @if (item.Sts == true)
                                                {
                                                    <button style="background-color:transparent;border-color:transparent" onclick="update('@item.id')">
                                                        <i class="fa fa-toggle-on fa-2x" style="color:green"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button style="background-color:transparent;border-color:transparent" onclick="update('@item.id')">
                                                        <i class="fa fa-toggle-off fa-2x" style="color:red"></i>
                                                    </button>
                                                }
                                            </td>
                                            <td>
                                                @if (item.success_to_failed == true)
                                                {
                                                    <button style="background-color:transparent;border-color:transparent" onclick="success_failed_change('@item.id', 'success_to_failed')">
                                                        <i class="fa fa-toggle-on fa-2x" style="color:green"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button style="background-color:transparent;border-color:transparent" onclick="success_failed_change('@item.id', 'success_to_failed')">
                                                        <i class="fa fa-toggle-off fa-2x" style="color:red"></i>
                                                    </button>
                                                }
                                            </td>
                                            <td>
                                                @if (item.failed_to_success == true)
                                                {
                                                    <button style="background-color:transparent;border-color:transparent" onclick="success_failed_change('@item.id', 'failed_to_success')">
                                                        <i class="fa fa-toggle-on fa-2x" style="color:green"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button style="background-color:transparent;border-color:transparent" onclick="success_failed_change('@item.id', 'failed_to_success')">
                                                        <i class="fa fa-toggle-off fa-2x" style="color:red"></i>
                                                    </button>
                                                }
                                            </td>
                                            <td style=" display: flex;">
                                                <button style="background-color:transparent;border-color:transparent" onclick="Edit('@item.id')">
                                                    <i class="fa fa-edit fa-2x" style="color:red"></i>
                                                </button>
                                                <button style="background-color:transparent;border-color:transparent;" onclick="Delete('@item.id')">
                                                    <i class="fa fa-trash-o fa-2x" style="color:red"></i>
                                                </button>
                                            </td>
                                        </tr>

                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
