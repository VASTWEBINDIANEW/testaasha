                                    <i class="fa fa-plus" style="top:1px;font-size:16px;color:#fff;" aria-hidden="true"></i>
                                    <span style="color:#fff;">Add New</span>
                                </button>
                                @*<button class="btn btn-sm btn-primary" data-toggle="modal" data-target="#myModalAdd">
                    <i class="ace-icon glyphicon glyphicon-plus"></i>
                    <span class="bigger-110 no-text-shadow">Add New</span>
                </button>*@
