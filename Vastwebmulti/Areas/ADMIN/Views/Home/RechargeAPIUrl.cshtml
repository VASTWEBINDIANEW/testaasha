            @using (Html.BeginForm("EDITAPI", "Home", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("editid")
                <div class="modal-header" style="background-color:whitesmoke;">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title">Edit Recharge API Url's</h4>
                </div>
                <div class="modal-body">
                    <div class="body">
                        <div class="row clearfix">
                            <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                <label for="email_address_2">Enter Api Name</label>
                            </div>
                            <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                <div class="form-group">
                                    <div class="" style="border:1px solid #dddddd;">
                                        @Html.TextBox("editApinm", "", new { @class = "form-control", placeholder = "Enter Api Name", required = "required", @disabled=true })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row clearfix">
                            <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                <label for="email_address_2">Api URL</label>
                            </div>
                            <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                <div class="form-group">
                                    <div class="" style="border:1px solid #dddddd;">
                                        @Html.TextArea("editApiUrl", "", new { @style = "height:100px;", @class = "form-control", placeholder = "Enter Api URL", required = "required" })
                                    </div>
                                </div>
                            </div>
