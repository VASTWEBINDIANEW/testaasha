    }

    .cashdeposit-pdfexl .item-three .leftt {
        width: 50%;
        float: left;
    }

        .cashdeposit-pdfexl .item-three .leftt span.input-group-addon {
            padding: 0 !important;
            min-width: 5px !important;
        }

    .cashdeposit-pdfexl .rightt.buttonsearch-second button {
        width: 100% !important;
        text-align: center !important;
        display: flex;
        justify-content: center;
    }

        .cashdeposit-pdfexl .rightt.buttonsearch-second button .fa.fa-search {
            position: relative;
            left: -1px;
            top: 2px !important;
        }

    .cashdeposit-pdfexl .rightt.buttonsearch-second {
        width: 19%;
        padding-left: 5px;
    }


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media only screen and (max-width:992px){

        .cashdeposit-pdfexl .unload-item.item-one {
            width: 50%;
            padding-bottom: 3px;
        }
        .three-page-same .unload-item.item-two {
            width: 50%;
            margin: 0;
        }
        .cas-hdeposi-tcharge-page .ca-dipo-right .un-re-wa-right {
            padding: 5px 0 !important;
        }



    }

    @@media screen and (max-width:766px) {
        .cashdeposit-pdfexl .unload-item.item-one, .cashdeposit-pdfexl .unload-item.item-two {
            width: 50%;
            float: left;
        }

        .cashdeposit-pdfexl .unload-item.special-iii.item-three {
            width: 100%;
            float: left;
        }

            .cashdeposit-pdfexl .unload-item.special-iii.item-three .leftt {
                width: 100%;
                float: left;
            }

        .cashdeposit-pdfexl .rightt.buttonsearch-second {
            width: auto;
            padding-left: 0;
            float: left;
        }
    }


    @@media only screen and (max-width:520px) {
        .un-re-wa-right .unload-item.item-one, .un-re-wa-right .unload-item.item-two, .un-re-wa-right .unload-item.special-iii.item-three {
            padding: 0px 5px !important;
            width: 100%;
        }

        .un-re-wa-right {
            padding: 0px 5px !important;
        }

            .un-re-wa-right .unload-item.item-one, .un-re-wa-right .unload-item.item-two {
                width: 50%;
            }

            .un-re-wa-right .unload-item.special-iii.item-three .input-group-addon {
                min-width: 10px;
                padding: 0px;
            }

        .modal.Un-rwls-modal.in .modal-dialog, .modal.Un-rwls-modal .modal-dialog {
            width: 95%;
        }

        .un-re-wa-right .unload-item.special-iii.item-three .rightt button {
            width: 96%;
        }

        .table-responsive > .table-bordered > thead > tr > th:first-child, .table-responsive > .table-bordered > thead > tr > td:first-child,
        .table-responsive > .table-bordered > thead > tr > th:last-child, .table-responsive > .table-bordered > thead > tr > th:last-child {
            border-left: 1px solid var(--border-color);
            border-right: 1px solid var(--border-color);
        }

        .three-page-same .unload-item .rightt button span {
            float: none;
        }
    }

    @@media only screen and (max-width:480px){

        .tab-third-design {
            font-size: 11px;
        }

        .un-re-wa-right .unload-item.item-one, .un-re-wa-right .unload-item.item-two, .un-re-wa-right .unload-item.special-iii.item-three {
            padding: 3px 0 !important;
            width: 100%;
        }

    }

</style>
