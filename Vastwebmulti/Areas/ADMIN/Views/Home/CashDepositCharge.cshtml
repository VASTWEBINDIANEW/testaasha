<script type="text/javascript">

    function show(elementId) {
        if (elementId == "RetailerSRC") {
            document.getElementById("RetailerSRC").style.display = "block";
            document.getElementById("WAdminSRC").style.display = "none";
            document.getElementById("RetailerPOS").style.display = "none";

        }
        if (elementId == "RetailerPOS") {
            document.getElementById("RetailerSRC").style.display = "none";
            document.getElementById("WAdminSRC").style.display = "none";
            document.getElementById("RetailerPOS").style.display = "block";

        }
        else if (elementId == "WAdminSRC") {
            document.getElementById("RetailerSRC").style.display = "none";
            document.getElementById("WAdminSRC").style.display = "block";
            document.getElementById("RetailerPOS").style.display = "none";

        }
        else {
            document.getElementById("RetailerSRC").style.display = "block";
            document.getElementById("WAdminSRC").style.display = "none";
            //   document.getElementById("VendorSRC").style.display = "block";
            document.getElementById("RetailerPOS").style.display = "none";
        }
    }
</script>
