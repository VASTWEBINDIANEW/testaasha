        width: 22%;
        padding-left: 0px;
    }

    #remcash, #dlmcash, #farziidhye, #apicash, #whitecash {
        margin-top: 5px !important;
    }

    .table-responsive-cashdeposit {
        height: 350px;
        overflow: auto;
    }

    .cas-hdeposi-tcharge-page .ca-dipo-right {
        height: auto;
    }

    .cashdeposit-pdfexl .unload-item.item-one {
        width: 20%;
        margin: 0;
        padding-right: 3px;
    }

    .cashdeposit-pdfexl .unload-item.special-iii.item-three {
