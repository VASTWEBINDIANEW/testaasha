<style>

    /* new css */
    .bread-same-all-page li {
        margin: 6px 0px;
    }
    .cas-hdeposi-tcharge-page .ca-dipo-left {
        background: #fff;
    }
    .cas-hdeposi-tcharge-page .ca-dipo-right {
        background: #fff;
    }
