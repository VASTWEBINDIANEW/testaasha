<script type="text/javascript">
    $(document).mouseup(function (e) {
       
        if ($(e.target).closest(".clickevent").length === 0) {
          
              $('.second-success').hide();
        }
        else {
              $('.second-success').fadeIn();
             //alert('in')
        }
    });
</script>
<script>
    function show(data) {
         $('#loader').show();
        var date = $('#txt_frm_date').val();
            var url = '@Url.Action("_business_Operator", "Home")';
        $.post(url, { data: data, frmdate: date }, function (data) {
                            $('#loader').hide();
                     $('.gross-business-first').hide();
                     $('.gross-business-second').show();
                  $("#business_s").html(data);

             })
    }
</script>
