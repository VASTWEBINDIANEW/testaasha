@model IEnumerable<Vastwebmulti.Models.admin_income_report_Result>
@{
    ViewBag.Title = "Actual_Admin_income";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style>

    /* new css */

    .all-type-third {
        float: right;
    }

        .all-type-third .responcive-fifty {
            width: auto;
        }

    /* new css */

    .table-bordered tbody tr td, .table-bordered tbody tr th {
        padding: 10px;
    }

    .form-iconmy {
        position: absolute;
        z-index: 9;
        top: 0px;
        bottom: 0px;
        padding: 6px 5px;
        border-right: 1px solid #bbb;
        height: 32px;
    }

    #custnav ul li a {
        font-size: 13px;
    }

    .newfourdesign-admin .col-md-5 {
        padding-right: 0;
    }

    .newfourdesign-admin .col-md-4.spanpdfback-third.actulpdf-third {
        padding-right: 0;
    }

    .ner i, .ner2 i {
        left: 5px !important;
    }

    @@media screen and (max-width:1366px) {
        .actul-none-third {
            display: none;
        }

        .actul-search-third {
            width: 23%;
        }

        .actulpdf-third {
            width: 35%;
            padding-right: 5px;
        }

        .newfourdesign-admin .col-md-8.up-up-up.up-third-design.active-nav-third {
            padding-right: 0;
        }

            .newfourdesign-admin .col-md-8.up-up-up.up-third-design.active-nav-third #custnav ul li a {
                font-size: 13px;
            }

        .responcive-fifty.date-actul-third input, .responcive-fifty.date-actul-third button {
            font-size: 13px;
        }

        .newfourdesign-admin #custnav ul li a {
            font-size: 12px;
        }

        .newfourdesign-admin .responcive-fifty.date-actul-third input, .newfourdesign-admin .responcive-fifty.date-actul-third button {
            font-size: 12px;
        }
    }


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:991px) {

        .all-type-third .responcive-fifty {
            float: left;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media only screen and (max-width:767px) {
        .up-up-up #custnav li {
            width: 33.333%;
            margin: 0;
            padding: 3px;
        }

        .responcive-fifty button {
            width: 100%;
            text-align: left;
        }

        .responcive-fifty div {
            padding-bottom: 0px !important;
        }

        .actul-search-third {
            width: auto;
        }

        .actulpdf-third {
            width: auto;
            float: right;
        }

        #custnav ul li:nth-child(3n) {
            margin-right: 0 !important;
        }
    }

    @@media only screen and (max-width:520px) {
        .all-type-third {
            width: 100%;
            float: left;
            padding: 0 !important;
        }

        .admin-day-book .col-md-5 {
            width: 38%;
            padding-left: 15px !important;
            float: left;
        }

            .admin-day-book .col-md-5 input {
                padding-left: 15px;
            }

        .admin-day-book .col-md-2 {
            width: 50%;
            float: left;
            margin-top: 3px;
        }

        .table-responsive > .table-bordered > thead > tr > th:first-child, .table-responsive > .table-bordered > thead > tr > td:first-child,
        .table-responsive > .table-bordered > thead > tr > th:last-child {
            border-left: 1px solid var(--border-color);
        }

        .responcive-fifty.date-actul-third {
            width: 100%;
            float: left;
        }

            .responcive-fifty.date-actul-third .nrr3 {
                width: 98%;
            }

        .newfourdesign-admin .onlymargin-third .col-md-12 {
            padding-right: 0;
        }

        .newfourdesign-admin #custnav #ul li {
            width: 49%;
        }

        #custnav ul li:nth-child(2n) {
            margin-right: 0 !important;
        }
    }

    @@media only screen and (max-width:480px) {

        #custnav #ul li {
            width: 50%;
            margin: 0;
        }
    }
</style>
<section class="content">
    <div class="container-fluid">


        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>Day Book</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                @*<li><a href="javascript:void(0);">User's & Account&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>*@
                <li><a href="javascript:void(0);">Day Book</a></li>
            </ul>
        </div>

        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="row clearfix margin-bottom-third cardbackg-thirdclass onlymargin-third">
            <div class="col-md-12">
                <div class="card back-transparent-third" style=" ">
                    <div class="row" style="margin: 0;">
                        <div class="col-md-7 up-up-up up-third-design active-nav-third page-header-third" style="width: auto; float: left;">
                            <div>
                                @Html.Partial("DayBookPartialView")
                            </div>
                        </div>

                        <div class="col-md-5 page-header-third" style="width: auto; float: right;">

                            <div class="col-md-4 spanpdfback-third actulpdf-third" style="padding:0px;width:auto;float:right;">
                                <div class="rechargepdfexal pdfexport-span-second" style="float:right;">
                                    <span><img src="~/ashok-images/pdf.png"><input type="button" onclick="Export()" id="btnPDF" value="PDF" style="border:0px;background:transparent"></span>
                                    <span>
                                        <img src="~/ashok-images/xls.png"><input type="submit" name="btnExport" id="btnExport" value="Export" style="border:0px;background:transparent;">
                                    </span>
                                </div>
                            </div>



                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row clearfix" id="tblpdf">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card page-header-third">
                    <div>
                        @using (Html.BeginForm("Actual_Admin_income", "Home", FormMethod.Post))
                        {
                            <div class="row admin-day-book" style="margin: 0;">
                                @*<div class="col-md-1 actul-none-third"></div>*@
                                <div class="all-type-third">
                                    <div class="col-md-6 responcive-fifty date-actul-third" style="padding:0px 5px;">
                                        <div class="input-daterange input-group">
                                            <div class="custom-date-icon ner" style="border-color:#ddd !important;">
                                                <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                            </div>
                                            @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #ddd; height:32px;text-align:right;" })
                                            <span class="input-group-addon" style="padding: 0px !important;min-width: 3px;">

                                            </span>
                                            <div class="nrr3">
                                                <div class="custom-date-icon ner2" style="border-color:#ddd !important;">
                                                    <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                                </div>
                                                @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #ddd; height:32px;text-align:right;" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 responcive-fifty actul-search-third" style="padding:0px;">

                                        <button type="submit" class="btn waves-effect input-back-second" style="height:32px;background:transparent;border-color:#ddd;">
                                            <i class="fa fa-search" style="top:1px;font-size:16px;color:black;"></i>
                                            <span style="top:0px;color:black;">Search</span>
                                        </button>

                                    </div>
                                </div>


                            </div>
                        }
                    </div>

                    <div style="width: 100%; float: left; margin-top: 5px;">
                        <div class="table-responsive tableseconddes-admin" style="position:inherit;">
                            <table class="table table-bordered table-striped table-hover example-second third-design-table" style="width:100%;background:#eae9e9;">
                                <thead style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Sr.&nbsp;No</th>
                                        <th>Type</th>
                                        <th>Amount</th>
                                        <th>Purchase</th>
                                        <th>Retailer Comm</th>
                                        <th>Dealer Comm</th>
                                        <th>Master Comm</th>
                                        <th>Income</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{int i = 1;}
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td>@Html.DisplayFor(modelItem => item.trntype)</td>
                                            <td>@Html.DisplayFor(modelItem => item.amount)</td>
                                            <td>@Html.DisplayFor(modelItem => item.purchase)</td>
                                            <td>@Html.DisplayFor(modelItem => item.retailerfinal)</td>
                                            <td>@Html.DisplayFor(modelItem => item.dealerfinal)</td>
                                            <td>@Html.DisplayFor(modelItem => item.mdfinal)</td>
                                            <td>@Html.DisplayFor(modelItem => item.income)</td>
                                        </tr>
                                        i++;
                                    }
                                    <tr>
                                        <td><p style="font-size:17px;margin-left:-8px;">Total</p></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td><p style="font-size:18px;margin-left:-8px;">@Model.Sum(a => a.income)</p></td>
                                    </tr>
                                </tbody>




                            </table>
                        </div>
                    </div>


                </div>
            </div>
        </div>
    </div>

</section>

<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>
<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.flash.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/jszip.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/pdfmake.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/vfs_fonts.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.html5.min.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/buttons.print.min.js"></script>
<script src="~/AdminDesign/js/pages/tables/jquery-datatable.js"></script>

<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.22/pdfmake.min.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/0.4.1/html2canvas.min.js"></script>
<script>
$(function(){

     $('.input-daterange').datepicker({
                format: "yyyy-mm-dd",
                todayHighlight: true,
                autoclose: true,
                orientation: "bottom auto",

            });
            var val = '@ViewBag.chk';
            if (val != "post") {
                $("#txt_frm_date").datepicker("setDate", new Date());
                $("#txt_to_date").datepicker("setDate", new Date());
            }
    });
</script>


<script type="text/javascript">
    function Export() {
        html2canvas(document.getElementById('tblpdf'), {
            onrendered: function (canvas) {
                var data = canvas.toDataURL();
                var docDefinition = {
                    content: [{
                        image: data,
                        width: 500
                    }]
                };
                pdfMake.createPdf(docDefinition).download("Admin_income.pdf");
            }
        });
    }
</script>



<script>
    $(function () {
        $('.second-design .example-second').DataTable({
            paging: false
        });
    });

</script>