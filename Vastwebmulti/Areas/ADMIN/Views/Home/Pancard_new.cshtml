                            <th>dis&nbsp;Pre&nbsp;₹</th>
                            <th>dis&nbsp;Post&nbsp;₹</th>
                            <th>master&nbsp;Pre&nbsp;₹</th>
                            <th>Master&nbsp;Post&nbsp;₹</th>
                            <th>#</th>
                            <th>#</th>
                        </tr>
                    </thead>
                    <tbody class="alin chnj">

                        @if (Model.pancard_Transations_report_new != null)
                        {


                            foreach (var i in Model.pancard_Transations_report_new)
                            {
                                <tr>
                                    @{
                                        var sts = i.status;


                                        if (i.status.Contains("Refund"))
                                        {
                                            sts = "Refund";
                                        }





                                        <td>
                                            @if (i.status.Contains("PENDING"))
                                            {
                                                <img style="height: 20px;width: 18px;margin-right:5px;max-width: 100%;padding: 0; border-radius:50%; background-color:#ffc107" src="../../ashok-images/clkk.png"> @sts


                                            }
                                            @if (i.status.Contains("Refund"))
                                            {
                                                <img style="height: 20px;width: 18px;margin-right:5px;max-width: 100%;padding: 0; border-radius:50%; background-color:brown" src="../../ashok-images/backresnd.svg"> @sts

                                            }
                                            @if (i.status.Contains("Failed"))
                                            {
                                                <img style="height: 20px;width: 18px;margin-right:5px;max-width: 100%;padding: 0; border-radius:50%; background-color:red" src="../../ashok-images/closes.svg"> @sts

                                            }
                                            @if (i.status.Contains("Success"))
                                            {
                                                <img style="height: 20px;width: 18px;margin-right:5px;max-width: 100%;padding: 0; border-radius:50%; background-color:green" src="../../ashok-images/correct.svg"> @sts

                                            }
                                        </td>

                                        <td>@i.name = > @i.Email</td>
                                        <td>@i.Amount</td>
                                        <td>@i.Rem_comm</td>
                                        <td>@i.Rem_tds</td>
                                        <td>@i.Rem_pre</td>
                                        <td>@i.rem_post</td>
                                        <td>@i.request_time</td>
                                        <td>@i.Rem_final</td>
                                        <td>@i.dlm_pre</td>
                                        <td>@i.dlm_post</td>
                                        <td>@i.master_pre</td>
                                        <td>@i.master_post</td>
                                        <td>
                                            @if (i.status.Contains("PENDING"))
                                            {
                                                <button class="s_button" style="border: 1px solid #fb483a; background: #ee837b;" onclick="openPopup('@i.name', '@i.Email', '@i.Amount', '@i.Rem_comm', '@i.idno', '@i.requestid', '@i.status', 'Failed')">Failed</button>

                                                @* <td><a href="#">succes</a></td>*@
                                            }
                                        </td>
                                        <td>
                                            @if (i.status.Contains("PENDING"))
                                            {
                                                <button class="s_button" style="border: 1px solid #5cb85c; background: #94ca94;" onclick="openPopup('@i.name', '@i.Email', '@i.Amount', '@i.Rem_comm', '@i.idno', '@i.requestid', '@i.status', 'success')">success</button>

                                            }
                                        </td>
                                    }
                                </tr>

                            }

                        }

                    </tbody>

                </table>

                <div id="loadingdiv" style="text-align:center;display:none;margin-bottom:20px;">
                    <img src="~/img/ajax-loader.gif" />
                </div>
            </div>
        </div>
    </div>
    </div>
</section>

