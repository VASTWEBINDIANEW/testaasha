<script>
   function stsupd(u, i, s) {
    $.ajax({
        url: '@Url.Action("daywisecommupdate", "Home")',
        type: "POST",
        data: { userid: u, sts: s },
        cache: false,
        success: function (Response) {
            if (Response == "OK") {
                document.getElementsByClassName('idchanges')[i].innerHTML = "";
                if (s == true) {
                    // Fixing the onclick attribute syntax
                    document.getElementsByClassName('idchanges')[i].innerHTML = "<button  class='btn btn-success'  onclick=\"stsupd('" + u + "', " + i + ", " + false + ")\">ON</button>";
                }
                else {
                    document.getElementsByClassName('idchanges')[i].innerHTML = "<button  class='btn btn-danger'  onclick=\"stsupd('" + u + "', " + i + ", " + true + ")\">OFF</button>";
                }
            }
        }
    });
}

</script>
