<script>
function changeidss() {
            var masterid = document.getElementById('maststs').value;
            $.ajax({
                url: "@Url.Action("GetDealerDetails","Home")",
                data: { masterId: masterid },
                success: function (data) {
                    var dealer = document.getElementById('dealesds');
                    dealer.innerHTML = '';
                    var option1 = document.createElement('option');
                    option1.value = "";
                    option1.text = "ALL Dealer";
                    dealer.appendChild(option1);
                    data.forEach(dealerDetail => {
                        var option = document.createElement('option');
                        option.value = dealerDetail.DealerId;
                        option.text = dealerDetail.FarmName;
                        dealer.appendChild(option);
                    });
                },
                error: function (xhr, status, error) {
                    console.error('Error:', error);
                }
            });
    }


    function changeretailrsidss() {
        var masterid = document.getElementById('dealesds').value;
            $.ajax({
                url: "@Url.Action("GetReailerDetails","Home")",
                data: { masterId: masterid },
                success: function (data) {
                    var dealer = document.getElementById('retailss');
                    dealer.innerHTML = '';
                    var option1 = document.createElement('option');
                    option1.value = "";
                    option1.text = "ALL Retailer";
                    dealer.appendChild(option1);
                    data.forEach(dealerDetail => {
                        var option = document.createElement('option');
                        option.value = dealerDetail.RetailerId;
                        option.text = dealerDetail.Frm_Name;
                        dealer.appendChild(option);
                    });
                },
                error: function (xhr, status, error) {
                    console.error('Error:', error);
                }
            });
        }


</script>