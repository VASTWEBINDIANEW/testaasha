                            <div class="KYCON onoffswitch onoffswitch1" style="float: right; width: auto; background: #f0f0f0 !important; ">
                                <span class="costom-on" style=" font-size: 10px;" onclick="Recharge('ON')">Recharge/Utility Failed OTP</span>
                            </div>
