<script>
    //Retailer Reset IMPS PIN
    function GetRetaileretails() {
        if ($('#RetailerList').val() != "") {
            $.ajax({
            type: 'POST',
            url: '@Url.Action("GetDLM_REM_Details", "Home")',
                data: { UserType: "Retailer", UserId: $('#RetailerList').val() },
            dataType:"Json",
                success: function (data) {
                $('#RetailerName').val(data[0].RetailerName);
                $('#FirmName').val(data[0].Frm_Name);
                $('#MobileNo').val(data[0].Mobile);
                $('#RetailerAddress').val(data[0].Address);
                }
            });
        }
    }

    function ResetPin() {
        $.ajax({
            type: 'POST',
            url: '@Url.Action("Retailer_Reset_IMPSPin", "Home")',
            data: { RetailerId: $('#RetailerList').val(), oTP: $('#oTP4').val(), oTP1: $('#oTP5').val(), oTP2: $('#oTP6').val(), oTP3: $('#oTP7').val()},
           /* data: { OTp: $('#OTp2').val()},*/
            dataType:"Json",
            success: function (data) {
                if (data.status === "Success") {
                    ToastrMessage();
                    toastr.success(data.Message);
                }
                else {
                    ToastrMessage();
                    toastr.error(data.Message);
                }
                $('#myModal2').modal('hide');

                $('#RetailerList').val('');
                $('#RetailerName').val('');
                $('#FirmName').val('');
                $('#MobileNo').val('');
                $('#RetailerAddress').val('');

              }
            });
    }
    //Dealer Reset Trans PIN
    function GetDistributorDetails() {
        if ($('#DistributorDDL').val() != "") {
            $.ajax({
            type: 'POST',
            url: '@Url.Action("GetDLM_REM_Details", "Home")',
