@using Vastwebmulti.Models;
@model Tuple<ChangePasswordViewModel, ChangeTransactionViewModel, ChangeSecurityViewModel>

@{
    ViewBag.Title = "ChangeSecurityPassword";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}

<style>

    /* new css */

    .pageheader-second-third {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    
    
    /* new css */


    .custom-off {
        text-align: right;
        width: 100%;
        padding: 8px 5px 2px 29px !important;
        background: #f0f0f0;
        color: #2b2929;
        font-weight: 700;
    }

    .costom-on {
        text-align: right;
        width: 100%;
        padding: 8px 5px 2px 29px !important;
        background: #f0f0f0;
        color: #2b2929;
        font-weight: 700;
    }
    .onoffswitch {
        width: 32px;
        height: 32px;
        margin-left: 5px;
        float: right;
    }
    .onoffswitch1 {
        width: 32px;
        height: 32px;
        margin-left: 5px;
        float: right;
    }

    .costom-on::after {
        width: 20px;
        height: 20px;
        top: 5px;
        left:5px;
    }

    .custom-off::before {
        width: 20px;
        height: 20px;
        top: 5px;
        left: 5px;
    }

    .field-validation-error {
        color: red;
    }

    .required:after {
        color: red;
        content: " *";
    }

    #error-message-one, #error-message-security, #error-message {
        color: red;
        font-size: 14px;
        width: 100%;
        margin-bottom: 15px;
    }

    @@media only screen and (max-width:480px) {
        .login-pass-top {
            display: inline-block;
            width: 100%;
        }

        .login-pass-top-inner > .col-md-5 p {
            line-height: 22px !important;
            margin-bottom: 6px;
        }

        .login-pass-top-inner > .col-md-5 .body {
            padding: 0px;
            margin-bottom: 10px;
        }

        .login-pass-seond.body {
            padding: 0px;
            margin-bottom: 10px;
            margin-top: 20px;
        }
    }
    /********************** Start Reset Pin Popup************************************/
    .modal.left .modal-dialog,
    .modal.right .modal-dialog {
        position: fixed;
        margin: auto;
        width: 420px;
        height: 100%;
        -webkit-transform: translate3d(0%, 0, 0);
        -ms-transform: translate3d(0%, 0, 0);
        -o-transform: translate3d(0%, 0, 0);
        transform: translate3d(0%, 0, 0);
    }

    .modal.left .modal-content,
    .modal.right .modal-content {
        height: 100%;
        overflow-y: auto;
        padding-bottom: 25px;
        height: auto;
    }

    .modal.left .modal-body,
    .modal.right .modal-body {
        padding: 15px 25px 80px;
    }

    /*Left*/
    .modal.left.fade .modal-dialog {
        left: -320px;
        -webkit-transition: opacity 0.3s linear, left 0.3s ease-out;
        -moz-transition: opacity 0.3s linear, left 0.3s ease-out;
        -o-transition: opacity 0.3s linear, left 0.3s ease-out;
        transition: opacity 0.3s linear, left 0.3s ease-out;
    }

    .modal.left.fade.in .modal-dialog {
        left: 0;
    }

    /*Right*/
    .modal.right.fade .modal-dialog {
        right: -320px;
        -webkit-transition: opacity 0.3s linear, right 0.3s ease-out;
        -moz-transition: opacity 0.3s linear, right 0.3s ease-out;
        -o-transition: opacity 0.3s linear, right 0.3s ease-out;
        transition: opacity 0.3s linear, right 0.3s ease-out;
    }

    .modal.right.fade.in .modal-dialog {
        right: 0;
    }

    /* ----- MODAL STYLE ----- */
    .modal-content {
        border-radius: 0;
        border: none;
    }

    .modal-header {
        border-bottom-color: #EEEEEE;
        background-color: #FAFAFA;
    }

    /* ----- v CAN BE DELETED v ----- */
    

    .demo {
        padding-top: 60px;
        padding-bottom: 110px;
    }

    .btn-demo {
        margin: 15px;
        padding: 10px 15px;
        border-radius: 0;
        font-size: 16px;
        background-color: #FFFFFF;
    }

        .btn-demo:focus {
            outline: 0;
        }

    .demo-footer {
        position: fixed;
        bottom: 0;
        width: 100%;
        padding: 15px;
        background-color: #212121;
        text-align: center;
    }

        .demo-footer > a {
            text-decoration: none;
            font-weight: bold;
            font-size: 16px;
            color: #fff;
        }

    .toast-top-right1 {
        top: 78px;
        left: 81%;
    }

    .modai-body-out .form-group .form-control, .modai-body-out .btn {
        background: transparent;
        padding: 0px 20px;
        margin: 0;
    }

    .modai-body-out .row {
        margin: 0px;
    }

    .modai-body-out .col-xs-12, .modai-body-out .col-sm-12, .modai-body-out .col-md-12, .modai-body-out .col-lg-12 {
        padding: 0px;
    }

    .modai-body-out .form-group {
        margin-bottom: 15px;
    }

    .modal-header span {
        color: var(--main-bg-lcolor);
        font-size: 34px;
    }

    .modal-header button {
        opacity: 1;
    }

   
    .modai-body-out .btn {
        float: right;
        margin-top: 15px;
    }

    .modai-body-in {
        background: #eae9e9;
        width: 100%;
        float: left;
        padding-top: 20px;
        border: 5px solid;
    }

    .select2-selection.select2-selection--single {
        border-radius: 0px !important;
        height: 32px !important;
        border-color: #ccc !important;
    }

    @@media only screen and (max-width:480px) {
        .reset-responcive {
            width: 100% !important;
            float: left;
            text-align: left !important;
        }

            .reset-responcive button {
                width: 100%;
                margin-bottom: 10px !important;
            }
    }


    .hide_otp input {
        width: 40px !important;
        height: 32px !important;
        text-align: center;
        font-size: 19px;
    }
    /* Chrome, Safari, Edge, Opera */
        .hide_otp input::-webkit-outer-spin-button,
        .hide_otp input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

    /* Firefox */
        .hide_otp input[type=number] {
            -moz-appearance: textfield;
        }
    .otp_set2 {
        text-align: left;
    }
    .otp_set3 {
        text-align: left;
    }

    /********************** End Reset Pin Popup************************************/

