                            <div class="KYCON onoffswitch" style="float: right; width: auto; background: #f0f0f0 !important; ">
                                <span class="costom-on" style=" font-size: 10px;" onclick="KYCONOFF('KYCON')">IMPS PIN/OTP SWITCH</span>
                            </div>
                        }
                        else
                        {
                            <div class="KYCON onoffswitch" style="float: right; width: auto; background: #f0f0f0 !important; ">
                                <span class="custom-off" style="font-size: 10px;" onclick="KYCONOFF('KYCON')">IMPS PIN/OTP SWITCH</span>
                            </div>
                        }
                    }
                </div>
                <div class="res_div" style="float: left;">
                    @if (ViewBag.rechargeotpsts != null)
                    {
                            if (ViewBag.rechargeotpsts.status == true)
                            {
                              <div class="RECHARGEON onoffswitch" style="float: right; width: auto; background: #f0f0f0 !important; ">
                                  <span class="costom-on" style=" font-size: 10px;" onclick="RECHARGEPINONOFF('RECHARGEON')">RECHARGE PIN </span>   
                              </div>
                            }
                            else
