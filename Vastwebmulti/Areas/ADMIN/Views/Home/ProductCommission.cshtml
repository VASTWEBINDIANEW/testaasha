@using System.Net.Mime
@using Vastwebmulti.Models
@model List<Vastwebmulti.Models.proc_ProductList_Result>
@{
    ViewBag.Title = "CatagoryList";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
        <div class="col-md-12">
        <div class="card">
@Html.Partial("Ecommercemenu")
        </div>
        </div>
        </div>
        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-26px;">
                <div class="card">
                    <div class="">
                        <ol class="breadcrumb breadcrumb-col-blue-grey" style="margin-left:5px;margin-top:9px;">
                            <li class="active" style="color:#9E9E9E; font-size:12px;">PRODUCT COMMISSION DETAILS&nbsp;></li>
                        </ol>
                    </div>
                  
                    <div class="body" style="padding:7px;">
                        <div class="table-responsive" style="position:inherit;margin-top:-49px;">
                            <table class="table table-bordered table-striped table-hover dataTable js-exportable ">
                                <thead  style="background-color:whitesmoke;">
                                    <tr>
                                        <th>Product&nbsp;Name</th>
                                        <th>Sub&nbsp;Catagory</th>
                                        <th>Actual&nbsp;Price</th>
                                        <th>List&nbsp;Price</th>
                                        @*<th style="padding-left:2px;">Active</th>*@
                                        <th>Photo</th>
                                        <th>Total&nbsp;Comm</th>
                                        <th>MD&nbsp;Comm</th>
                                        <th>DE&nbsp;Comm</th>
                                        <th>REM&nbsp;Comm</th>
                                        <th>Whitelabel&nbsp;Comm</th>
                                        <th>Order&nbsp;Date</th>
                                        

                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.Name</td>
                                            <td>@item.SubCatName</td>
                                            <td>₹&nbsp;@String.Format("{0:N}", item.StandardPrice)</td>
                                            <td>₹&nbsp;@String.Format("{0:N}", item.ListPrice)</td>
                                           
                                            @*<td style="padding:3px;">@item.IsActive</td>*@
                                            @if (!string.IsNullOrWhiteSpace(item.Photo))
                                            {
                                                <td>

                                                    <img src="@Url.Content("~" + item.Photo)" height="60px" width="60px"/>
                                                </td>
                                            }
                                            <td>₹&nbsp;@String.Format("{0:N}", item.AdminComm)</td>
                                            <td>₹&nbsp;@String.Format("{0:N}", item.MDComm)</td>
                                            <td>₹&nbsp;@String.Format("{0:N}", item.DEComm)</td>
                                            <td>₹&nbsp;@String.Format("{0:N}", item.RemComm)</td>
                                            <td>₹&nbsp;@String.Format("{0:N}", item.WhiteLabelComm)</td>
                                            <td>@item.UpdatedOn</td>
                                        </tr>
                                    }

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!--Add New   modal-->
<div class="modal fade" id="defaultModal1" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background-color:whitesmoke;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:black;">Approve Product</h4>
            </div>
            @using (Html.BeginForm("ApproveProduct", "Home", FormMethod.Post))
            {
                <div class="modal-body" style="margin-top:-26px;">
                    <div class="body">
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                        @Html.Hidden("ProductID")
                        <form>
                            <div class="row clearfix">
                                <div class="col-lg-4 col-md-4 col-sm-5 col-xs-5 form-control-label">
                                    <label for="MDComm">Master Commission</label>
                                </div>
                                <div class="col-lg-8 col-md-8 col-sm-7 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBox("MDComm", "", new { @class = "form-control", required = "required" })
                                            @Html.ValidationMessage("MDComm", "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-4 col-md-4 col-sm-5 col-xs-5 form-control-label">
                                    <label for="DEComm">Dealer Commission</label>
                                </div>
                                <div class="col-lg-8 col-md-8 col-sm-7 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBox("DEComm", "", new { @class = "form-control", required = "required" })
                                            @Html.ValidationMessage("DEComm", "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-4 col-md-4 col-sm-5 col-xs-5 form-control-label">
                                    <label for="REMComm">Retailer Commission</label>
                                </div>
                                <div class="col-lg-8 col-md-8 col-sm-7 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBox("REMComm", "", new { @class = "form-control", required = "required" })
                                            @Html.ValidationMessage("REMComm", "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-4 col-md-4 col-sm-5 col-xs-5 form-control-label">
                                    <label for="WLComm">White Label Commission</label>
                                </div>
                                <div class="col-lg-8 col-md-8 col-sm-7 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBox("WLComm", "", new { @class = "form-control", required = "required" })
                                            @Html.ValidationMessage("WLComm", "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="modal-footer">
                                <button type="submit" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-right: 12px; height:34px;">
                                    <span style="top:-2px;color:black;">Save Change</span>
                                </button>
                                <button type="button" class="btn bg-grey waves-effect" style="margin-top: 4px; margin-left: -3px; height:34px;" data-dismiss="modal">
                                    <span style="top:-2px;color:black;">Close</span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

