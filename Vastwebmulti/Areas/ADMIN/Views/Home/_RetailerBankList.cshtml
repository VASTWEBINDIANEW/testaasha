@model IEnumerable<Vastwebmulti.Models.ShowBankRequest_Result>

<style>
    .buttonload {
        background-color: #4CAF50;
        border: none;
        color: white;
        padding: 12px 24px;
        font-size: 16px;
    }

    /* Add a right margin to each icon */

    img {
        max-width: 100%;
    }

    .inputtextpopuadmin input {
        width: 100%;
        border: 1px solid var(--border-color);
        height: 30px;
    }


    .imageDiv:hover {
        width: 300px;
        height: 250px;
        position: relative;
        display: block;
        border: 3px solid #fed136;
        background-color: #b20000;
        border-radius: 20px;
        position: relative;
        z-index: 999;
    }

    .retailer-banlist-admin table tr td p {
        margin-bottom: 0px !important;
    }

    .image-modal-content button {
        color: #000;
        z-index: 9;
        width: 100%;
        float: left;
        text-align: right;
        border-bottom: 1px solid #aaa4a4;
        padding: 10px 15px;
        opacity: 1;
    }

    .image-modal-content .modal-body {
        padding: 15px !important;
    }

    .image-modal-content button span {
        font-size: 1.2em !important;
        color: #000 !important;
        font-weight: 400;
        line-height: 1;
        text-shadow: 0 1px 0 #fff;
    }

    .image-modal-content button.close-footer {
        border-bottom: 0px;
        border-top: 0;
        background: #6c757d;
        width: auto;
        float: right;
        padding: 0;
        font-size: 14px;
        border-radius: .25rem;
        padding: 10px 15px;
    }

        .image-modal-content button.close-footer span {
            text-shadow: none;
            color: #fff !important;
        }

    .button-footer-close {
        width: 100%;
        float: left;
        padding: 9px 15px;
        border-top: 1px solid #e1e1e1;
    }

    @@media screen and (max-width:766px) {
        #galleryimageprofile-modal .modal-dialog {
            width: 100% !important;
            float: left !important;
            margin: 0;
            padding: 0 15px;
        }
    }

    @@media screen and (max-width:420px) {
        .image-modal-content img {
            height: 250px !important;
        }
    }
</style>
<div class="modal fade" id="galleryimageprofile-modal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true" style=" margin-top: 78px;">
    <div class="modal-dialog" role="document" style="">
        <div class="modal-content image-modal-content" style="width:100%;float:left;border-radius: 5px;border: 1px solid #aaa4a4;">
            <div class="modal-body" style="width:100%;float:left;">



                <img src="" class="" id="uploadprofileim111g" alt="User" width="100" height="100" style="cursor:pointer; float:right;width: 100%;height: 340px;" />


            </div>
            <div class="button-footer-close">
                <button type="button" class="close close-footer" data-dismiss="modal" aria-label="Close" style="color: #000;z-index:9;">
                    <span aria-hidden="true" style=" font-size: 36px; color: #000; opacity: 1;">Close</span>
                </button>
            </div>
        </div>
    </div>
</div>
<table class="table table-bordered table-striped third-design-table" style="width:100%;background:#f5f5f5;">

    <thead style="background-color:whitesmoke;">

        <tr>
            <th>Cancel Check</th>
            <th>User&nbsp;Firm&nbsp;&&nbsp;Mobile</th>
            <th>Account&nbsp;Holder&nbsp;Name</th>
            <th>Bank&nbsp;Account&nbsp;No</th>
            <th>IFSC&nbsp;Code</th>
            <th>Bank&nbsp;Name</th>
            <th>Branch&nbsp;Address</th>
            @*<th>Status</th>*@
            <th>A/C&nbsp;Added&nbsp;Date</th>
            <th>Approved&nbsp;Date</th>
            <th>Action</th>
        </tr>

    </thead>
    <tbody>
        @foreach (var item in Model)
        {

            <tr>
                <td style="display:none;">@item.Idno</td>
                <td>
                    @if (item.CancelCheckFile == null)
                    {

                        <span>Image Not Found</span>
                    }
                    else
                    {
                        <button class="image-profilemodal" data-toggle="modal" data-target="#galleryimageprofile-modal">
                            <img src="@Url.Content("~/"+ item.CancelCheckFile )" class="img img-responsive" onclick="imgfullsizecopy('@item.Idno')" id="upload-@item.Idno" alt="User" width="100" height="100"
                                 style="display: flex; align-items: center; justify-content: center" />
                        </button>

                    }
                </td>
                <td>
                    @if (item.Status.ToUpper() == "PENDING")
                    {
                        <p><img src="~/ashok-images/clock.svg" style="width: 20px;">&nbsp;&nbsp;@Html.DisplayFor(modelItem => item.Firm_Name).ToString().ToUpper()&nbsp; - &nbsp; @item.Mobile&nbsp;</p>
                    }
                    else
                    {
                        <p><img src="~/ashok-images/correct.svg" style="width: 19px;background:green;border-radius: 50%;padding: 3px;">&nbsp;&nbsp;@Html.DisplayFor(modelItem => item.Firm_Name).ToString().ToUpper()&nbsp; - &nbsp; @item.Mobile&nbsp</p>
                    }


                </td>
                <td>@Html.DisplayFor(modelItem => item.AcconutHolderName)</td>
                <td>@item.BankAccountNo</td>

                <td>@Html.DisplayFor(modelItem => item.IFSC_CODE)</td>

                @if (!String.IsNullOrWhiteSpace(@item.topfilter))
                {
                    <td>@Html.DisplayFor(modelItem => item.Bank_Name).ToString().ToUpper()<span>&nbsp;>&nbsp;</span><strong> @item.topfilter</strong></td>
                }
                else
                {
                    <td>@Html.DisplayFor(modelItem => item.Bank_Name).ToString().ToUpper()</td>
                }

                <td>@Html.DisplayFor(modelItem => item.Bank_Address)</td>
                @*<td><div class="onoffswitch">
                        <span class="costom-on">on</span>
                        <span class="custom-off" style="display:none;">off</span>
                    </div></td>*@
                <td>
                    @Html.DisplayFor(modelItem => item.Date)
                </td>
                <td>@Html.DisplayFor(modelItem => item.Approved_Date)</td>
                <td>
                    @if (item.Status.ToUpper() == "PENDING")
                    {
                        <div id="buttonload-@item.Idno" style="display:none">
                            <button class="buttonload">
                                <i class="fa fa-refresh fa-spin"></i>Loading
                            </button>


                        </div>
                        <div id="showde-@item.Idno" class="showde" style="display:flex;">

                            <a href="#" onclick="sendotp('@item.UserId', '@item.Idno', '@item.Firm_Name', '@item.AcconutHolderName', '@item.BankAccountNo', '@item.IFSC_CODE', '@item.CancelCheckFile')" style="text-decoration:none;border:1px solid #c7c2c2;padding: 2px 0px;margin: 0px 2px;">
                                &nbsp;<span>Approve</span>
                            </a>
                            <a href="@Url.Action("RetailerBnkReject", new { Idno = item.Idno })" style="text-decoration:none;border:1px solid #c7c2c2;padding: 2px 5px;margin: 0px 2px;">
                                &nbsp;<span>Reject</span>
                            </a>
                        </div>
                        @*<div id="hidede-@item.Idno" class="hidede" style="display:none;">
                                <input placeholder="ENTER OTP" id="txtotp-@item.Idno" type="text" />
                                <label id="txtmsg-@item.Idno" style="color:red;"></label>
                                <button onclick="approvedotp('@item.Idno','@item.UserId')"> Submit </button>



                                <button onclick="cancle()"></button>
                            </div>*@
                    }
                    else if (item.Status.ToUpper() == "APPROVED")
                    {
                        <button class="first-button" style="background: transparent;border:0;padding: 1px 15px;padding-top:0px;">
                            <img src="../../MainFrontDesign/images/delete.svg" style="width:16px;position:relative;top:-2px;">
                        </button>
                        <a href="@Url.Action("DeleteRetailerBnkt", new { Idno = item.Idno })" class="second-button fullbodydycolorbg" style="background: transparent;border: 1px solid #bbb;padding: 1px 4px;color:#fff;display:none;">
                            Sure ?
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>

</table>

<div class="modal-showpopup" id="exampleModal" style="display:none;    position: absolute;right: 0;top: -61px;" @*tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true"*@>
    <div class="modal-dialog" role="document">
        @using (Html.BeginForm("RetailerBnkApprove", "Home", FormMethod.Post))

        {
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel" style="float:left;">Firm Name&nbsp;</h5>
                    <button type="button" class="close closebuttonexamid" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>

                    </button>
                </div>
                <div class="modal-body inputtextpopuadmin" style="width:100%;float:left;">
                    <div class="table-responsive col-md-12" style="width:100%;float:left;">
                        <img src="" id="imgcheck" class="img imageDiv" style="height: 500px; width: 100%;" />
                    </div>
                    <input type="hidden" required id="hdidno" name="hdidno" value="" />
                    <input type="hidden" required id="hduserid" name="hduserid" value="" />
                    <div class="" style="width:100%;float:left;margin-bottom:10px;margin-top:10px;">
                        <div class="col-md-4">
                            <label>Account Holder Name</label>
                        </div>
                        <div class="col-md-7">
                            <input type="text" placeholder="" style="" id="txtaccountholdername" name="txtaccountholdername" required readonly />
                        </div>
                    </div>
                    <div class="" style="width:100%;float:left;margin-bottom:10px;margin-top:10px;" readonly>
                        <div class="col-md-4">
                            <label>IFSC Code</label>
                        </div>
                        <div class="col-md-7">
                            <input type="text" placeholder="" style="" id="txtifsccode" name="txtifsccode" required readonly />
                        </div>
                    </div>
                    <div class="" style="width:100%;float:left;margin-bottom:10px;margin-top:10px;">
                        <div class="col-md-4">
                            <label>Account Number</label>
                        </div>
                        <div class="col-md-7">
                            <input type="text" placeholder="" style="" id="txtaccountnumber" name="txtaccountnumber" required readonly />
                        </div>
                    </div>


                    <div class="" style="width:100%;float:left;margin-bottom:10px;margin-top:10px;">
                        <div class="col-md-4">
                            <label>Retailer Otp</label>
                        </div>
                        <div class="col-md-7">
                            <input type="text" placeholder="" style="" id="remotp" name="remotp" required />
                        </div>
                    </div>
                    <div class="" style="width:100%;float:left;margin-bottom:10px;">
                        <div class="col-md-4">

                            <label>Admin Otp</label>
                        </div>
                        <div class="col-md-7">
                            <input type="text" placeholder="" id="adminotp" name="adminotp" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary closebuttonexamid" data-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Submit</button>
                </div>
            </div>

        }
    </div>
</div>
<script src="~/AdminDesign/plugins/jquery-datatable/jquery.dataTables.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/skin/bootstrap/js/dataTables.bootstrap.js"></script>
<script src="~/AdminDesign/plugins/jquery-datatable/extensions/export/dataTables.buttons.min.js"></script>
<script>
    function sendotp(userid, id, Firm_Name, AcconutHolderName, BankAccountNo, IFSCCODE) {

        $('#hdidno').val('');
        $('#txtaccountholdername').val('');
        $('#txtifsccode').val('');
        $('#txtaccountnumber').val('');
        $('#exampleModalLabel').text('');
       // var showids = '#showde-' + id
        var hidss = '#hidede-' + id
        var imgids = '#upload-' + id
        var imgfile = $(imgids).attr('src');
       // var loader = '#buttonload-' + id
        var idnos = id;
        var useridss = userid
       // $('.showde').show();
      //  $('.hidede').hide();
      //  $(loader).show();
       // $(showids + '.showde').hide();

       // $('#hdidno').val(idnos)

        $.ajax({
            type: "GET",
            url: '@Url.Action("bankApproveOTP", "Home")',
            cache: false,
            dataType: 'json',
            data: { userid: userid},
            async: true,
            success: function (data) {

                if (data == "DONE") {
                    // $(loader).hide();
                    $('#txtaccountholdername').val(AcconutHolderName);
                    $('#txtifsccode').val(IFSCCODE);
                    $('#txtaccountnumber').val(BankAccountNo);
                    $('#exampleModalLabel').text(Firm_Name);
                    //  $(showids + '.showde').hide();
                    //// $(hidss + '.hidede').show();

                    $('#imgcheck').attr('src', imgfile);
                    $('#hdidno').val(idnos)
                    $('#hduserid').val(userid)
                    $('#exampleModal').show();
                    //  $('#showde').hide();
                    // $('#hidede').show();
                }
                else {
                    alert(data)
                }

            }
        });
    }
    @*function approvedotp(idno, userid) {

        var otp = $('#txtotp-' + idno).val();

           $.ajax({
            type: "GET",
            url: '@Url.Action("RetailerBnkApprove", "Home")',
            cache: false,
               dataType: 'json',
               data: { Idno: idno, otp: otp, userid1: userid },
            async: true,
               success: function (data) {
                   if (data == "OK") {
                       var url = '@Url.Action("RetailerBnk", "Home")';
                       location.href = url;
                   }
                   else {
                       $('#txtmsg-'+idno).text(data);
                   }
            }
        });
    }*@
</script>

<script>
    function RetailerBnkReject(Idno)
    {
        $.ajax({
            type: "GET",
            url: '@Url.Action("RetailerBnkReject", "Home")',
            cache: false,
            dataType: 'json',
            data: {Idno:Idno},
            async: true,
            success: function (data) {
                var sts = data.Status;

                if(sts=="Success")
                {
                    var url = '@Url.Action("RetailerBnk", "Home")';
                    location.href = url;
                }
            }
        });
    }
</script>
<script>
    $('.first-button').click(function () {
        $(this).hide();
        $(this).next('.second-button').show();
    });
</script>
<script>
    function cancle() {
      var url = '@Url.Action("RetailerBnk", "Home")';
                    location.href = url;
    }
</script>

<script>
    $('.closebuttonexamid').click(function () {
        $('#exampleModal').hide();
    });
</script>

<script>

    function imgfullsizecopy(id) {
        debugger;
        var srcids = '#upload-' + id

        var imgsss = $(srcids).attr('src')
        $('#uploadprofileim111g').attr('src', imgsss);
    }
</script>