                            @Html.ValidationMessageFor(a => a.UpdateRetailer[i].comm)
                        </td>
                    </tr>
                }
            }
            <!--End Retailer User-->
            <!--WHITELABEL User Update-->
            @if (Model.Whitelabeluser != null)
            {
                for (int i = 0; i < Model.UpdateWhitelabel.Count; i++)
                {
                    var endID = Model.UpdateWhitelabel[i].idno;
                    <tr>
                        @Html.HiddenFor(a => a.UpdateWhitelabel[i].idno)

                        <td>
                            <p>All</p>
                        </td>
                        <td style="display:none;">
                            @Html.HiddenFor(a => a.UpdateWhitelabel[i].optcode)
                        </td>
                        <td>
                            @Html.DisplayFor(a => a.UpdateWhitelabel[i].OperatorName)

                        </td>
                        <td>
                            @Html.TextBoxFor(a => a.UpdateWhitelabel[i].comm, new { @style = "width:100%" })
