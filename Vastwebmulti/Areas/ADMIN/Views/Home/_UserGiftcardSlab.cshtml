                        </td>

                    </tr>

                }
            }
            <!--End Retailer-->
            <!--Whitelabel User-->
            @if (Model.Whitelabeluser != null)
            {
                for (int i = 0; i < Model.Whitelabeluser.Count; i++)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(a => a.Whitelabeluser[i].Email)
                        </td>
                        <td>
                            @Html.DisplayFor(a => a.Whitelabeluser[i].OperatorName)

                        </td>
                        <td>
                            @Html.DisplayFor(a => a.Whitelabeluser[i].comm)

                        </td>

                    </tr>

                }
            }
            <!--End Whitelabel-->

        </tbody>
        <tbody id="tbodyedit" style="display:none;">
            <!--Master User-->
            @if (Model.Materuser != null)
            {
                for (int i = 0; i < Model.Materuser.Count; i++)
                {
                    <tr>
                        @Html.HiddenFor(a => a.Materuser[i].RolesName)
                        @Html.HiddenFor(a => a.Materuser[i].idno)
                        @Html.HiddenFor(a => a.Materuser[i].optcode)
                        <td>
                            @Html.DisplayFor(a => a.Materuser[i].Email)
                        </td>
                        <td>
                            @Html.DisplayFor(a => a.Materuser[i].OperatorName)
                        </td>
                        <td>
                            @Html.EditorFor(a => a.Materuser[i].comm, new { htmlAttributes = new { @style = "width:100%" } })
                            @Html.ValidationMessageFor(a => a.Materuser[i].comm)
                        </td>


                    </tr>
                }
            }
            <!--End Master-->
            <!--Dealer User-->
            @if (Model.Dealeruser != null)
            {
                for (int i = 0; i < Model.Dealeruser.Count; i++)
