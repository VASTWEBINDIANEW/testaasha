<script>
    function Deleteuser() {
        var role = $('#rolesname').val()
       var RCHId = $('#RCHId').val();
          $.ajax({
              url: '@Url.Action("DeleteRCHuserByID", "Home")',
            type: 'POST',
            data: {RCHId:RCHId,role:role },
             cache: false,
            success: function (response) {
                if (response == "success") {
                   $('#otpmodal').modal('show');

                }
                else {
                    $('#error').text(response);
                }
            }
        });
    }
</script>


