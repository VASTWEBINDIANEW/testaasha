<div id="otpmodal" class="modal fade" role="dialog">
    <div class="modal-dialog" style="width:520px;float:right;margin:0px;">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 id="headershow" class="modal-title"><img src="~/MainFrontDesign/images/delete.svg" style="width:18px;margin-top:-4px;">&nbsp;One Time Password</h4>
            </div>
            <div class="modal-body">
                @using (Ajax.BeginForm("ConfirmDeleteRCHuserOTP", "Home", new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "RECTable", OnSuccess = "OnSuccessconfirm", OnFailure = "OnFailureotperror" }))
                {
                    @Html.Hidden("roledelete")
                    @Html.Hidden("RCHIddelete")
                    <div class="row">
                        <div class="col-md-12 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <label>OTP</label>
                                @Html.TextBox("Deleteotp", "", new { @class = "form-control", placeholder = "Enter OTP", required = "required", @style = "background: #f5f5f5;border: 1px solid #bbb;" })
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12 col-sm-12 col-xs-12 button-seconddesign">
                            @*<span id="otpwrong" style="color:red"></span>*@
                            <button type="submit" value="SaveChange" class="btn special-iii btnssl2233 fullbodydycolorbg btn-first" data-loading-text="<i class='fa fa-spinner fa-spin'></i>" style="float: right;color: #fff;font-weight: 600;"><span style="color:#fff;">Delete User</span></button>
                        </div>
                    </div>


                }
            </div>
        </div>

    </div>
</div>
<script>

    function OnSuccessconfirm(data) {


        $('#RECTable').html(data);
        $('#defaultModal222').hide();
        $('#otpmodal').hide();
        $(".modal-backdrop").hide();
        ToastrMessage();
        toastr.success("Account Deleted Successfully");
    }

    function OnFailureotperror(data) {
        $('#otpmodal').modal('show');
        $('#otpwrong').text("otpmismatch");
        ToastrMessage();
        toastr.warning("OTP Mismatch , Please enter Correct OTP");
        //$('#otpwrong').text("OTP Mismatch , Please enter Correct OTP");
    }


</script>
