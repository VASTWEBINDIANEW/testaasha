                    <li class="smli" style="margin: 0;">
                        <a href="@Url.Action("Dashboard", "Home")" class="fullbodydycolorbg tmw-total-color-one" style="font-size: 14px;">
                            Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;">
                        </a>
                    </li>
                    <li class="fullbodydycolorbg tmw-total-color-one" style="font-size: 14px;margin: 0;">
                        Dealer Allow IMEI
                    </li>
                </ul>
                @Html.Partial("_menu_login")
                @Html.Partial("_menu_block_imei")
                <div class="three-page-same upi-charge all-type-third upiclass-respfull-third" style="width:70%;">
                    <div class="un-re-wa-right" style="padding-left: 10px;">
                        @using (Html.BeginForm("Dealerblockadd", "Home", FormMethod.Post))
                        {
                            <div class="unload-item item-one" style="width:20%;">
                                @Html.DropDownList("dealerid", ViewBag.apiid as SelectList, "Select Dealer ID", new { @class = " form-control border-0", @style = "border:1px solid #8e7f7f4d;", required = true })
                            </div>
                            <div class="unload-item item-one" style="width:20%;">
                                @Html.TextBox("txtimeino", "", new { @class = " form-control", @style = "border:1px solid #8e7f7f4d;", placeholder = "IMEI NO", required = true })
                            </div>
                            <div class="unload-item special-iii item-three" style="width: auto;">
                                <div class="rightt" style="width:26%;">
                                    <button type="submit" id="RetailerSearch" class="btn  waves-effect btnssl2233 input-back-second button-center-third" data-loading-text="<i class='fa fa-spinner fa-spin'></i>" style="width: 94%;margin-left: 8px;display:flex;justify-content:center;align-items:center;">
                                        <i class="fa fa-search"></i>
                                        <span>Add IMEI</span>
                                    </button>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
        <div class="row clearfix">
            <div class="col-md-12 col-sm-12 col-xs-12">
                <div class="ca-dipo-right height-auto-second height-auto-third" style="height:;">
                    <div class="three-page-same">
                        <div class="row clearfix" id="RetailerSRC">
                            <div class="col-md-12 col-sm-12 col-xs-12">
                                <div id="RetailerSearchList">
                                    <div class="table-responsive table-responsive-payugateway tableseconddes-admin" style="width:100%;">

                                        <div id="WAdminSearchList">
                                            <table class="table table-bordered table-striped table-hover third-design-table table-white-third">
                                                <thead style="background-color:whitesmoke;">
                                                    <tr>
                                                        <th>Firm Name</th>
                                                        <th>Email</th>
                                                        <th>IMEI NO</th>
                                                        <th>#</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in Model)
                                                    {
                                                        <tr>
                                                            <td>@item.firmname</td>
                                                            <td>@item.email</td>
                                                            <td>@item.imeino</td>
                                                            <td>
                                                                <i id="del-@item.idno" class="fa fa-remove fa-2x" style="color:red;cursor:pointer;" onclick="deletechk('@item.idno')"></i>
                                                                <button id="@item.idno" class="btn btn-primary" style="display:none;" onclick="deletedone('@item.idno')">Are You Sure?</button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!--.row-->


                        <div class="row clearfix" id="WAdminSRC" style="display:none">
                            <div id="divEmp" class="col-md-12 col-sm-12 col-xs-12">
                            </div>
                        </div><!--.row-->



                    </div><!--.three-page-same-->
                </div>
            </div>
        </div>
