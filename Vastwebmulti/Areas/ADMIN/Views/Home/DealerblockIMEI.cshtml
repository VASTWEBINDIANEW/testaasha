</section>



<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.8/js/select2.min.js" defer></script>
<script>
    $(document).ready(function () {
        $('#dealerid').select2();
    });
</script>
<script>
    function deletechk(idno) {
        var idnochk = "del-" + idno;
        $('#' + idnochk).hide();
        $('#' + idno).show();
    }
</script>

<script>
    function deletedone(idno) {
        $.ajax({
            url: "@Url.Action("DeleteDealerblockIMEI","Home")",
            type: 'POST',
            data: { idno: idno},
            success: function (response) {
                location.reload();
            },
            error: function () {
                //$("#loader").show();
                alert("error occured");
            }
        });
    }
</script>