@model  Vastwebmulti.Areas.ADMIN.ViewModel.EmployeeAdvancePermissionViewmodellist

<style>
    .cc-check [type="checkbox"]:not(:checked), .cc-check [type="checkbox"]:checked {
        position: static;
        opacity: 1;
    }

    .employfirstclass {
        width: 32.8%;
        float: left;
        border: 1px solid var(--border-color);
        text-align: center;
        padding: 5px 5px;
        background: #eae9e9;
        color: #555;
        margin-right: 10px;
    }

    .employfirstclass {
        width: 32.5%;
        float: left;
        border: 1px solid var(--border-color);
        text-align: center;
        padding: 5px 5px;
        background: #eae9e9;
        color: #555;
        margin-right: 1%;
    }

    .employ-fullclass {
        width: 100%;
        float: left;
    }

    .employfirstclass:last-child {
        border-right: 1px solid #aaa4a4;
        margin-right: 0px;
    }

    .employfirstclass li {
        display: inline-block;
        padding-right: 10px;
    }

        .employfirstclass li strong {
            display: block;
        }

    .new {
        padding: 50px;
    }

    .form-group {
        display: block;
        margin-bottom: 15px;
    }

        .form-group input {
            padding: 0;
            height: initial;
            width: initial;
            margin-bottom: 0;
            display: none;
            cursor: pointer;
        }

        .form-group label {
            position: relative;
            cursor: pointer;
        }

            .form-group label::before {
                content: '';
                -webkit-appearance: none !important;
                background-color: transparent !important;
                border: 1px solid #555 !important;
                background: #fff !important;
                padding: 10px !important;
                display: inline-block !important;
                position: relative !important;
                vertical-align: middle !important;
                cursor: pointer !important;
                margin-right: 5px !important;
                transform: none !important;
                top: -1px !important;
            }

    .employfirstclass label {
        font-size: 14px;
        color: #555;
        text-transform: uppercase;
        font-weight: bold;
    }

    .form-group input:checked + label::after {
        content: '';
        display: block !important;
        position: absolute !important;
        top: 2px !important;
        left: 9px !important;
        width: 6px !important;
        height: 12px !important;
        border: solid #fff !important;
        border-width: 0 2px 2px 0 !important;
        transform: rotate(45deg) !important;
        left: 33px !important;
        top: 3px !important;
    }
    .form-group input:checked + label::before {
        background: #555 !important;
    }

    .employfirstclass:nth-child(3n) {
        border-right: 1px solid var(--border-color);
        margin-right: 0px;
    }

    .employfirstclass:nth-child(3n) {
        border-right: 1px solid #aaa4a4;
        margin-right: 0px;
        margin-bottom: 15px;
    }

    .employfirstclass h2 {
        text-transform: uppercase;
    }

    .addnew-save-button {
        position: absolute;
        right: 0;
        top: 0;
        top: -50px;
        border: 1px solid #aaa4a4;
        height: 36px;
        padding: 4px 8px;
        right: 7px;
    }
    .addnewclass-advance form {
        position: relative;
    }
    .employfirstclass {
        margin-bottom: 15px;
    }


    @@media screen and (max-width: 766px) {
        .employfirstclass {
            width: 100%;
            float: left;
            margin: 0;
            margin-bottom: 0px;
            margin-bottom: 20px;
        }

        .empolyresponsiveadmin {
            position: static !important;
            width: auto !important;
            margin-bottom: 20px;
        }
        .addnew-save-button {
            position: static;
            margin-bottom: 15px;
        }
    }
</style>

@*<div class="empolyresponsiveadmin" style=" position: absolute; right: 19px; top: 72px; width: 11%; }">
    <input type="submit" id="btnsubmit" name="btnsubmit" value="Save Permission" style="width: 100%; border-radius: 0; border: 1px solid var(--border-color);" />
</div>*@

@if (Model.statewiselist != null)
{
    @*<input type="hidden" id="EmployeeIDforpart" name="EmployeeIDforpart" value="@Model" />*@

    using (Html.BeginForm("Addpermisionstatewise", "Home", FormMethod.Post))
    {
        <input type="submit" class="addnew-save-button" value="Save" id="btnsumbit" />
        <input type="hidden" id="EmployeeIDfortstaepermission" name="EmployeeIDfortstaepermission" value="@Model.Employeeid" />
        @Html.HiddenFor(x => x.usertype)
        @Html.HiddenFor(x => x.permissiontype)
        <div class="employ-fullclass">
            @foreach (var item in Model.statewiselist)
            {

                var chk = item.isaccess == true ? "Checked" : "";
                //var chk1 = item == true ? "Checked" : "";
                <div class="employfirstclass">
                    <h2>@item.usertype </h2>

                    <ul>
                        <li>

                            <strong class="form-group">
                                <input type="checkbox" name="Read" id="Read_@item.stateid" value="Read_@item.stateid" @chk/>

                                <label for="Read_@item.stateid">@item.user_statename</label>
                            </strong>
                        </li>

                    </ul>
                </div>
            }
        </div>
    }



}

else if (Model.userwiselist != null)
{
    @*<input type="hidden" id="EmployeeIDforpart" name="EmployeeIDforpart" value="@Model" />*@
    using (Html.BeginForm("Addpermisionstatewise", "Home", FormMethod.Post))
    {

        <input type="hidden" id="EmployeeIDfortstaepermission" name="EmployeeIDfortstaepermission" value="@Model.Employeeid" />
        @Html.HiddenFor(x => x.usertype)
        @Html.HiddenFor(x => x.permissiontype)
        <input type="submit" class="addnew-save-button" value="Save" id="btnsumbit" />

        <div class="employ-fullclass">
            @foreach (var item in Model.userwiselist)
            {

                var chk = item.isaccess == true ? "Checked" : "";
               // var chk1 = item.isaccess == true ? "Checked" : "";
                <div class="employfirstclass">
                    <h2>@item.usertype</h2>

                    <ul>
                        <li>

                            <strong class="form-group">
                                <input type="checkbox" name="Read" id="Read_@item.userID" value="Read_@item.userID" @chk/>

                                <label for="Read_@item.userID">@item.user_statename</label>
                            </strong>
                        </li>

                    </ul>
                </div>
            }
        </div>

    }


}


