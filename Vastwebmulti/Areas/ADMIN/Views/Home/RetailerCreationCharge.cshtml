        $("#active-reffrasl").show();
        $(this).hide();
    });
    $("#active-reffrasl").click(function () {
        $('#status123').val("N")
        $("#deactive-reffrasl").show();
        $(this).hide();
    });

    $("#limit123").change(function () {
        var selectvalue = $(this).find(":selected").val();
        $("#showvalueid").html(selectvalue);
    });

    $("#tnSave").click(function () {
        $("#tnSave").hide();
        $("#Editbutton").show();
        $(".loaderclick").hide();
        $(".loaderclickspiner").show();
        setTimeout(function () { $(".loaderclick").show(); }, 3000);
        setTimeout(function () { $(".loaderclickspiner").hide(); }, 3000);

        $("#limit123").hide();
        $("#showvalueid").show();

    });
    $("#Editbutton").click(function () {
        $("#tnSave").show();
        $("#Editbutton").hide();
        $("#limit123").show();
        $("#showvalueid").hide();


    });
    function togglereferrel(status) {
        $.ajax({
            url: '@Url.Action("Refferal_Status", "Home")',
            method: 'GET',
            data: {status123: status },
            success: function ({ data }) {
                $('#status123').val(data.status)
          }
        });
    }

    function Rerffaralse() {
        $('.body.body-one').hide()
        $.ajax({
            url: '@Url.Action("ReferrelLimit", "Home")',
            method: 'GET',
            success: function ({ data }) {
                if (!data) {
                    data = { status: 'Y', limit : '3'};
                }
                if (!data?.status) data.status = 'Y';
                if (!data?.limit) data.limit = '3';

                $('#limit123').val(data.limit)

                if (data.status == "Y") {
                    $('#status123').val(data.status)
                    $('#active-reffrasl').show()
                    $('#deactive-reffrasl').hide();
                    $('#showvalueid').show();
                    $('#limit123').hide();
                    $('#showvalueid').html(data.limit);
                }
                else {
                    $('#status123').val(data.status)
                    $('#active-reffrasl').hide()
                    $('#deactive-reffrasl').show();
                    $('#showvalueid').show();
                    $('#limit123').hide();
                    $('#showvalueid').html(data.limit);
                }

            }
        })
    }

</script>
