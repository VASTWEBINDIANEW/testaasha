
@{
    ViewBag.Title = "Desktop_popupimage";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<section class="content tmw-desktop-popuping">
    <div class="container-fluid">
        <div class="row clearfix">
         <div class="col-md-12">
@using (Html.BeginForm("Desktop_popupimage", "Home", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
         <div class="card">
             <div class="col-md-6">
                 <textarea id="headercontent" name="headercontent" class="form-control" placeholder="Enter Header Content" style="height:32px; margin-top:3px;" required="" maxlength="70"></textarea>
             </div>
             <div class="col-md-4">
                 <div class="input-group" style="margin-top:3px;">
                     <div class="file" style="border:1px solid #dddddd;background:#dddddd33;">
                         <input type="file" name="file" class="form-control" style="padding-left:5px;background:#dddddd33;" />
                     </div>

                 </div>
             </div>
             <div class="col-md-2">
                 <button type="submit" class="btn waves-effect" style="margin-top:3px; margin-left: -3px;">
                     <span style="top:0px;color:black;">Upload Image</span>
                 </button>
             </div>
          
         </div>
}
         </div>
        </div>
        
            <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-26px;">
                <div class="card">
                   <div class="row" style="margin-top:9px;">
                       <div class="col-md-1">

                       </div>
                        <div class="col-md-6">
                            <h2>
                                <span>POPUP IMAGE FOR</span> &nbsp;&nbsp; <span>[BEST VIEW "1194 x 540" Pixel]</span>
                          </h2>
                        </div>
                       <div class="col-md-1">

                       </div>
                        <div class="col-md-2">
                          <h2>
                                    <p>STATUS</p>
                                        @if (ViewData["but"] == "OPEN")
                                        {
                                            <center>
                                                <a href="@Url.Action("Update_desktopsts","Home",new {sts="Y" })" style="text-decoration:none;">
                                                    <img src="~/images/reportimage/switch_on.png" style="height:20px;" />
                                                </a>
                                            </center>
                                        }
                                        else
                                        {
                                            <center>
                                                <a href="@Url.Action("Update_desktopsts","Home",new {sts="N" })" style="text-decoration:none;">
                                                    <img src="~/images/reportimage/switchoff.png" style="height:20px;" />
                                                </a>
                                            </center>

                                        }
                                    
                                </h2>
 
                        </div>
                       <div class="col-md-2">

                       </div>
                           
                    </div>
                    <div class="row">
                     <div class="col-md-1">

                     </div>
                        <div class="col-md-11">
                            <div class="body">
                                @*<p><span style="font-weight:700;font-size:18px;">Header Content</span>:&nbsp;&nbsp;@ViewBag.headercontent</p>*@
                              
                                <img src="@Url.Content("~/"+@ViewBag.ImageURL)" class="img-responsive" />

                            </div>
                        </div>
                    </div>
                
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
<!--Insert Popuop-->
<script>
    $(document).ready(function()
    {
                var message = '@TempData["add"]'
            if(message !="" && message!=null)
            {
              swal("Good job!", message, "success");

        }
        $(".sweet-alert").css('background', '@PageData["globalCol"]');
        });
</script>

