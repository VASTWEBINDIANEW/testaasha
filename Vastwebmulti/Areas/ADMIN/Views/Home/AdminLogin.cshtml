                        Admin Login Seeting
                    </li>
                </ul>
                @Html.Partial("_menu_login")
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-md-12 col-sm-12 col-xs-12">
                <div class="ca-dipo-right height-auto-second height-auto-third" style="height:;">
                    <div class="three-page-same">
                        <div class="row clearfix" id="RetailerSRC">
                            <div class="col-md-12 col-sm-12 col-xs-12">
                                <div id="RetailerSearchList">
                                    <div class="table-responsive table-responsive-payugateway tableseconddes-admin" style="width:100%;">
                                        <div id="WAdminSearchList">
                                            <table class="table table-bordered table-striped table-hover third-design-table table-white-third">
                                                <thead style="background-color:whitesmoke;">
                                                    <tr>
                                                        <th>User</th>
                                                        <th>Mobile Login</th>
                                                        <th>Email Login</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in Model)
                                                    {

                                                        <tr>
                                                            <td><label>Admin</label></td>
                                                            <td>
                                                                @if (item.mobile == true)
                                                                {
                                                                    <i class="fa fa-toggle-on fa-2x" style="color:green;cursor:pointer;" onclick="update('mobile')"></i>
                                                                }
                                                                else
                                                                {
                                                                    <i class="fa fa-toggle-off fa-2x" style="color:red;cursor:pointer;" onclick="update('mobile')"></i>
                                                                }
                                                            </td>
                                                            <td>
                                                                @if (item.email == true)
                                                                {
                                                                    <i class="fa fa-toggle-on fa-2x" style="color: green; cursor: pointer;" onclick="update('email')"></i>
                                                                }
                                                                else
                                                                {
                                                                    <i class="fa fa-toggle-off fa-2x" style="color: red; cursor: pointer;" onclick="update('email')"></i>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>


    </div>
</section>

<script>
    function update(chk) {
        $.ajax({
            url: "@Url.Action("updateadminlogin","Home")",
            type: 'POST',
            data: { name: chk},
            success: function (response) {
                location.reload();
            },
            error: function () {
                //$("#loader").show();
                alert("error occured");
            }
        });
    }
</script>