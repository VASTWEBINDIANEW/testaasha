            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                @*<li><a href="javascript:void(0);">Report's&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>*@
                <li><a href="javascript:void(0);">API GST Invoice</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="margin-bottom-third cardbackg-third onlymargin-third newcardclass leftrightpadd-third positionrelavtive-third" style=" width: auto; float: left;margin-bottom:7px;">
            <div class="page-header-third margin-bottom-third cardbackg-third onlymargin-third newcardclass leftrightpadd-third positionrelavtive-third" style="background-image: linear-gradient(to right, var(--main-bg-lcolor), var(--main-bg-rcolor)) !important; margin-bottom: 0px;  padding: 0px !important; border-radius: 2px; ">
                <div class="bread-same-all-page dust-gr-terw breadsameall-second margin-bottomo-third payment-responsi" style="background: rgb(255 255 255 / 95%); padding: 4px; box-shadow: 0px 0px 5px -2px; border-radius: 2px; ">

                    @Html.Partial("_menu_invoice")

                </div>
            </div>
        </div>
        <div class="page-header-third margin-bottom-third cardbackg-third onlymargin-third newcardclass leftrightpadd-third positionrelavtive-third" style=" width: auto; float: right;">
            @Html.Partial("_menu_invoice_API")
        </div>

        

        <div class="row clearfix">

            <div class="col-md-12 col-sm-12 col-xs-12">
                <div class="ca-dipo-right height-auto-second height-auto-third" style="">

                    <div class="un-re-wa-right11" style="padding-left: 10px; width: 40%; float: left; padding: 10px 5px;">
                        <li><a href="~/ADMIN/Home/ApiuploadgstRecharge">Api&nbsp;Recharge&nbsp;Upload&nbsp;Gst</a></li>
                        <li><a href="~/ADMIN/Home/Apisellgst" style="color: var(--main-bg-rcolor);">API&nbsp;GST </a><i class="fa fa-angle-right" style=" font-size: 14px; padding: 0px 3px 0px 7px;"></i></li>
                    </div>

                    <div class="un-re-wa-right" style=" width: 60%; float: right; background: none; padding: 5px 2px;">
                        @using (Html.BeginForm("ApiuploadgstRecharge", "Home", FormMethod.Post))
                        {
                            <div class="unload-item item-one" style="width:17%;">
                                @Html.DropDownList("apiid", ViewBag.apiid as SelectList, "Select API ID", new { @class = " form-control border-0", @style = "border:1px solid #8e7f7f4d;" })
                            </div>
                            <div class="unload-item item-one" style="width:17%;">
                                @Html.DropDownList("Month", ViewBag.month as SelectList, new { @class = " form-control border-0", @style = "border:1px solid #8e7f7f4d;" })
                            </div>
                            <div class="unload-item item-one" style="width:17%;">
                                @Html.DropDownList("Year", ViewBag.year as SelectList, new { @class = " form-control border-0", @style = "border:1px solid #8e7f7f4d;" })
                            </div>
                            <div class="unload-item special-iii item-three" style="width: auto;">
                                <div class="rightt" style="width:auto;">
                                    <button type="submit" id="RetailerSearch" class="btn  waves-effect btnssl2233 input-back-second button-center-third" data-loading-text="<i class='fa fa-spinner fa-spin'></i>" style="width: 94%;margin-left: 8px;display:flex;justify-content:center;align-items:center;">
                                        <i class="fa fa-search"></i>
                                        <span>Search</span>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="three-page-same">
                        <div class="row clearfix" id="RetailerSRC">
                            <div class="col-md-12 col-sm-12 col-xs-12">
                                <div id="RetailerSearchList">
                                    <div class="table-responsive table-responsive-payugateway tableseconddes-admin" style="width:100%;">

                                        <div id="WAdminSearchList">
                                            <table class="table table-bordered table-striped table-hover third-design-table table-white-third">
                                                <thead style="background-color:whitesmoke;">
                                                    <tr>
                                                        <th>Email Id</th>
                                                        <th>Firm Name</th>
                                                        <th>Month</th>
                                                        <th>Year</th>
                                                        <th>Status</th>
                                                        <th>Reason</th>
                                                        <th>View</th>
                                                        <th>#</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in Model)
                                                    {
                                                        <tr>
                                                            <td>@item.email</td>
                                                            <td>@item.firmname</td>
                                                            <td>@item.monthchk</td>
                                                            <td>@item.yearchk</td>
                                                            <td>@item.status</td>
                                                            <td>@item.reason</td>
                                                            <td>
                                                                <i class="fa fa-file-pdf-o fa-2x" style="color:red;cursor:pointer;" onclick="show('@item.uploadfile')"></i>
                                                            </td>
                                                            <td>
                                                                @if (item.status == "Pending")
                                                                {
                                                                    <i class="fa fa-check fa-2x" style="color:green;cursor:pointer;" onclick="approved('@item.idno', '@item.firmname', '@item.monthchk', '@item.yearchk')" title="Approved"></i>
                                                                    <i class="fa fa-ban fa-2x" style="color:red;cursor:pointer;" onclick="Rejected('@item.idno', '@item.firmname', '@item.monthchk', '@item.yearchk')" title="Rejected"></i>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-------------orderrecive-->
                </div>
</section>
