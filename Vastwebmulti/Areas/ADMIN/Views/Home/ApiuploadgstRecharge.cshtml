<script>
    $(function () {
        var month = '@ViewBag.chkmonth';
        var val = '@ViewBag.chk';
        if (val != "post") {
            $('#Month').val(month);
            $('#Month').select2().trigger('change');
            $('#apiid').select2();
            $('#Year').select2();
        }
    });
</script>
