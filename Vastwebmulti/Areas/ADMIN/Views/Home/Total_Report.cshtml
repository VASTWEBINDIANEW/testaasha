@model IEnumerable<Vastwebmulti.Models.total_report_Result>
@{
    ViewBag.Title = "Total_Report";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">
                <div class="row clearfix">
            <div class="col-lg-6 col-md-6 col-sm-12 col-xs-12">
                <div class="card" style="margin-top:2px;">
                    @Html.Partial("menuoperatorvalue")

                </div>
            </div>
      @using (Html.BeginForm("Total_Report", "Home", FormMethod.Post))
      {
                <div class="col-lg-6 col-md-6 col-sm-12 col-xs-12">
                    <div class="card" style="margin-top:2px;">
                        <div class="row">
                            <div class="col-md-5">
                                  <div class="form-group" style="margin-bottom:0px;">
                                    <div class="form-line" style="padding-top:3px;">
                                        <input type="text" id="txt_frm_date" name="txt_frm_date" class="datepicker form-control" placeholder="Select From Date" style="text-align:center;">
                                    </div>
                                </div>
                            </div>
                               <div class="col-md-5">
                              <button type="submit" class="btn bg-indigo waves-effect" style="margin-top:3px; ">
                                    <i class="material-icons">search</i>
                                    <span>Search</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
         <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="margin-top:-39px;">
                <div class="card">
                    <div class="">
                        <h2 style="color:black; font-size:16px;padding-top:9px; padding-left:22px;">
                            Value Difference Details
                        </h2>
                    </div>
                    <div class="body" style="margin-top:-25px;">
                        <div class="table-responsive " style="position:inherit;">
                            <table class="table table-bordered table-striped table-hover dataTable js-exportable " style="width:100%;">
                                <thead class="navbar" style="color:white;position:inherit;">
                                    <tr>
                                        <th>Port&nbsp;No</th>
                                        <th>Sim&nbsp;Number</th>
                                        <th>Operator&nbsp;Name</th>
                                        <th>Opening&nbsp;Balance</th>
                                        <th>Total&nbsp;Recharge</th>
                                        <th>Total&nbsp;purchasing</th>
                                        <th>Closing&nbsp;Balance</th>
                                        <th>Difference</th>
                                        <th>Edit</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@Html.DisplayFor(modelItem => item.portno)</td>
                                            <td>@Html.DisplayFor(modelItem => item.simnumber)</td>
                                            <td>@Html.DisplayFor(modelItem => item.optname)</td>
                                            <td>@Html.DisplayFor(modelItem => item.openbal)</td>
                                            <td>@Html.DisplayFor(modelItem => item.total)</td>
                                            <td>@Html.DisplayFor(modelItem => item.purcharge)</td>
                                            <td>@Html.DisplayFor(modelItem => item.closebal)</td>
                                            <td>@Html.DisplayFor(modelItem => item.diff)</td>
                                            <td>
                                                <button type="button" style="background-color:transparent; border:none;" data-toggle="modal" data-target="#defaultModal" onclick="animation('@item.portno','@item.optname','@item.purcharge')">
                                                    <i class="material-icons">edit</i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="defaultModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="defaultModalLabel">Edit Purchase</h4>
            </div>
            <div class="modal-body">
                <div class="body">
                    @using (Html.BeginForm("insert_purchage", "Home", FormMethod.Post))
                    {
                        <form id="form_validation" method="POST">
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Port No</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            <input type="text" id="txtport" name="txtport" class="form-control" readonly="">
                                            <input type="text" id="tttt" name="tttt" class="form-control" readonly="" style="display:none;">

                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Operator Name</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            <input type="text" id="txtoptname" name="txtoptname" class="form-control" readonly="">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row clearfix">
                                <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                                    <label for="email_address_2">Purchase</label>
                                </div>
                                <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                                    <div class="form-group">
                                        <div class="form-line">
                                            <input type="text" id="purcharge" name="purcharge" class="form-control" required>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="submit" class="btn btn-primary waves-effect">Save Change</button>
                                <button type="button" class="btn btn-info waves-effect" data-dismiss="modal">CLOSE</button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Jquery Core Js -->
<script src="~/AdminDesign/plugins/jquery/jquery.min.js"></script>
<script src="~/AdminDesign/js/demo.js"></script>


<!-- Custom Js -->
<script src="~/AdminDesign/js/pages/forms/basic-form-elements.js"></script>
<script src="~/AdminDesign/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>

<script>
    window.onload = function () {
        var from = '@ViewBag.fromdate';
         if (from != "") {
             $('#txt_frm_date').val(from);
           
        }
        else {
            var month = new Array("Jan", "Feb", "Mar",
    "Apr", "May", "Jun", "Jul", "Aug", "Sep",
    "Oct", "Nov", "Dec");

            var d = new Date();
            var curr_date = d.getDate();
            var curr_month = d.getMonth();
            var curr_year = d.getFullYear();
            var tt = curr_date + "-" + month[curr_month]
            + "-" + curr_year;
            document.getElementById("txt_frm_date").value = tt;
        }
    }
</script>
<!--Edit model -->
<script type="text/javascript">
    function animation(portno, optname, purcharge) {

            st = document.getElementsByName("txt_frm_date")[0].value;
            $("#tttt").val(st);
            $("#txtport").val(portno);
            $("#txtoptname").val(optname);
            $("#purcharge").val(purcharge);
        }
</script>


