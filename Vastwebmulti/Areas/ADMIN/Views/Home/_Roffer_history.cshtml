@model IEnumerable<Vastwebmulti.Models.roffer_All_history_Result>
@{
    Layout = null;
}

@if (Model != null)
{
    foreach (var item in Model)
    {
        <tr>
            <td>@item.Firm_Name</td>
            
            <td>@item.Number</td>
            <td>@item.Price</td>
            <td>@item.Operator_Name</td>
            <td>@item.Comm</td>
            <td>@item.userPerc</td>
            <td>@item.RemainPre</td>
            <td>@item.ShareComm</td>
            <td>@item.RemainPost</td>
            <td>@item.tdate</td>
        </tr>
    }
}


<script>
    $(document).ready(function () {
        $('.second-design .example-second').DataTable({


            paging: false
        });
    });

</script>