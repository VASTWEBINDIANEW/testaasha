<style type="text/css">

    /*  new css   */

    #apiusertable {
        background: #fff !important;
    }

    .left-user-md.width100.float-left {
        background: #fff !important;
    }

    .API_User_Page .left-user-md form {
        background: #fff;
    }

    .custom-table-responsive, #EmailHistory {
        background: #fff !important;
    }

    .for-search.tablesearch-second {
        float: left;
        margin-right: 3px;
    }

    .pageheader-margin-third {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bread-same-all-page {
        width: auto;
    }

    /*  new css   */


    .table-bordered tbody tr td, .table-bordered tbody tr th {
        padding: 10px;
    }

    @@keyframes ldio-zdyd6mf6t5 {
        0% {
            top: 96px;
            left: 96px;
            width: 0;
            height: 0;
            opacity: 1;
        }

        100% {
            top: 18px;
            left: 18px;
            width: 156px;
            height: 156px;
            opacity: 0;
        }
    }



    .ldio-zdyd6mf6t5 div {
        position: absolute;
        border-width: 4px;
        border-style: solid;
        opacity: 1;
        border-radius: 50%;
        animation: ldio-zdyd6mf6t5 1s cubic-bezier(0,0.2,0.8,1) infinite;
    }

        .ldio-zdyd6mf6t5 div:nth-child(1) {
            border-color: var(--main-bg-lcolor);
        }

        .ldio-zdyd6mf6t5 div:nth-child(2) {
            border-color: #c7c7c7;
            animation-delay: -0.5s;
        }

    .loadingio-spinner-ripple-92ar2pfqk5j {
        width: 200px;
        height: 200px;
        display: inline-block;
        overflow: hidden;
        background: #ffffff;
    }


    .ldio-zdyd6mf6t5 {
        width: 100%;
        height: 100%;
        position: relative;
        transform: translateZ(0) scale(1);
        backface-visibility: hidden;
        transform-origin: 0 0;
    }

        .ldio-zdyd6mf6t5 div {
            box-sizing: content-box;
        }
</style>
<style>
    .btn-group, .btn-group-vertical {
        box-shadow: none;
    }

    .dropdown {
        position: relative;
        display: inline-block;
    }

    .toast-top-right1 {
        top: 65px;
        left: 81%;
    }

    .dropdown-content {
        display: none;
        position: absolute;
        background-color: #f9f9f9;
        min-width: 160px;
        box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
        padding: 12px 16px;
        z-index: 1;
    }

    .dropdown:hover .dropdown-content {
        display: block;
    }


    .for-search input {
        width: 250px;
        border: 1px solid #dbdbdb;
        padding: 3px 10px;
    }

    .left-user-md.width100.float-left {
        height: auto !important;
    }

    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media only screen and (max-width:550px) {

        .pageheader-margin-third {
            display: block;
            float: left;
            width: 100%;
        }

        .bread-same-all-page {
            width: 100%;
            margin: 2px 0;
        }

        .web-white-filter {
            width: 100%;
        }

        .for-search.tablesearch-second {
            width: 100%;
            margin-bottom: 3px;
            margin-right: 0px;
        }

        .for-search input {
            width: 100%;
        }

        .create-bulk-add-image {
            margin-right: 0px;
        }

        .Upload-form input[type="file"] {
            padding: 0px;
        }
    }
</style>
