        $.ajax({
            url: url,
            data: { Id: _stateId },
            cache: false,
            type: "POST",
            success: function (data) {
                $("#District1").html("");
                for (var x = 0; x < data.length; x++) {
                    //alert(markup)
                    $("#District1").append($('<option></option>').val(data[x].Value).html(data[x].Text));
                }

            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
    }
</script>


