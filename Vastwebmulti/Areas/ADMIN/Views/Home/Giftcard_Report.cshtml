                                                            @*<td><p><span>Dealer</span><span style="padding-left:4px;">⇒</span><span style="padding-left:8px;">@item.dlm_pre_remain</span><span style="padding-left:18px;">│</span><span style="padding-left:3px;">@item.comm_dlm</span><span style="padding-left:14px;">│</span><span style="padding-left:9px;">@item.dlm_post_remain</span></p></td>
                                                            <td><p><span>Master</span><span style="padding-left:4px;">⇒</span><span style="padding-left:8px;">@item.master_pre_remain</span><span style="padding-left:18px;">│</span><span style="padding-left:3px;">@item.comm_master</span><span style="padding-left:14px;">│</span><span style="padding-left:9px;">@item.master_post_remain</span></p></td>
                                                            <td><p><span>Whitelabel</span><span style="padding-left:4px;">⇒</span><span style="padding-left:8px;">@item.whitelabel_pre_remain</span><span style="padding-left:18px;">│</span><span style="padding-left:3px;">@item.comm_whitelabel</span><span style="padding-left:14px;">│</span><span style="padding-left:9px;">@item.whitelabel_post_remain</span></p></td>*@
                                                            <td><p style="font-size:13px;">&nbsp;@String.Format("{0:dd-MMM-yy HH:mm:ss}", item.Response_time)</p></td>
                                                            <td><p style="font-size:13px;">&nbsp;@item.api_remain</p></td>
                                                            @*<td><p style="font-size:13px;">&nbsp;@item.gift_message</p></td>
                                                            <td><p style="font-size:13px;">&nbsp;@item.api_request</p></td>
                                                            <td><p style="font-size:13px;">&nbsp;@item.api_response</p></td>*@

                                                            <td>
                                                                <div class="row">

                                                                    <button class="ss" onclick="success('@item.orderid','success')" style="background-color: transparent; color: black; border: none; margin-top: 0px;" title="Mannual Success">
                                                                        <i class="fa fa-check" style="top:1px;border: 1px solid #c7c2c2;padding: 3px;font-size: 10px;" aria-hidden="true"></i>
                                                                    </button>


                                                                    <button class="ff" onclick="refundshow('@item.orderid','failed')" style="background-color: transparent; color: black; border: none; margin-top: 0px;" data-target="#defaultModal1" data-toggle="modal" title="Mannual Failed">
                                                                        <i class="fa fa-times" style="top:1px;border: 1px solid #c7c2c2;padding: 3px 4px;font-size: 10px;" aria-hidden="true"></i>
                                                                    </button>

                                                                    <span class="nrch" data-toggle="modal" data-target="#defaultModal222"> <img src="~/ashok-images/rightaeps.svg" style="border: 1px solid #c7c2c2; font-size: 10px; height: 18px !important; padding: 3px !important;" /> </span>
                                                                </div>


                                                            </td>

                                                        </tr>
                                                    }
                                                }

                                            </tbody>
                                            <tfoot class="navbar" style="color:white;position:inherit;">

                                            </tfoot>
                                        </table>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>


