    }
  
    
    .report-status {
        width: 80%;
        float: left;
    }

        .report-status label {
            float: left;
        }

        .report-status input {
            float: left;
            font-size: 16px;
            background-color: transparent !important;
            font-weight: 800;
            height: 17px !important;
        }

        .report-status .form-group {
            width: 46%;
            float: left;
            margin: auto 2%;
        }
    .mastetr222Modal .modal-body .form-group input {
        min-height: 32px;
        width: 100%;
    }
    .newfourdesign-admin  .gift-select::before {
        display: none;
    }
    .newfourdesign-admin .btn:not(.btn-link):not(.btn-circle), .newfourdesign-admin .form-group .form-control {
        border: 1px solid #ddd !important;
        background: transparent !important;
    }
    .newfourdesign-admin .margi-topo-third .col-lg-12.col-md-12.col-sm-12.col-xs-12.for-margin-top {
