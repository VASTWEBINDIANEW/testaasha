                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (Model != null)
                                                {
                                                    foreach (var item in Model)
                                                    {
                                                        var color = "";
                                                        var fontweight = "";
                                                        var icon = "";
                                                        var pandingcolor = "";

                                                        if (item.status.Contains("success"))
                                                        {
                                                            color = "green";
                                                            fontweight = "700";
                                                            icon = "../../ashok-images/correct.svg";
                                                        }
                                                        if (item.status.Contains("failed"))
                                                        {
                                                            color = "red";
                                                            fontweight = "700";
                                                            icon = "../../ashok-images/closes.svg";
                                                        }

                                                        if (item.status.Contains("Pending"))
                                                        {
                                                            color = "#FF9800";
                                                            fontweight = "700";
                                                            icon = "../../ashok-images/clkk.png";
                                                            pandingcolor = "#fff8d1";
                                                        }
                                                        if (item.status.Contains("Refund "))
                                                        {
                                                            color = "#9C27B0";
                                                            fontweight = "700";
                                                            icon = "../../ashok-images/undo.svg";
                                                        }


