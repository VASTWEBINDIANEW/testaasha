        <script type="text/javascript">
            function answers() {
                var e = document.getElementById("ddlusers");
                var answer = e.options[e.selectedIndex].value;
                if (answer == "Dealer") {
                    $("#optt").removeClass("col-md-3");
                    $("#optt").addClass("col-md-2");
                    document.getElementById("allmaster").style.display = "none";
                    document.getElementById("whitelabelid").style.display = "none";
                    document.getElementById("dlm").style.display = "block";
                    document.getElementById("rem").style.display = "none";
                    document.getElementById("allretailer").selectedIndex = "0";
                    document.getElementById("allmaster1").selectedIndex = "0";
                    document.getElementById("Whitelabel").selectedIndex = "0";
                }
                else if (answer == "Master") {
                    $("#optt").removeClass("col-md-3");
                    $("#optt").addClass("col-md-2");
                    document.getElementById("allmaster").style.display = "block";
                    document.getElementById("whitelabelid").style.display = "none";
                    document.getElementById("dlm").style.display = "none";
                    document.getElementById("rem").style.display = "none";
                    document.getElementById("alldealer").selectedIndex = "0";
                    document.getElementById("allretailer").selectedIndex = "0";
                    document.getElementById("Whitelabel").selectedIndex = "0";
                }
                else if (answer == "Admin") {
                    $("select#allmaster1").attr('selectedIndex', 0);
                    $("select#alldealer").attr('selectedIndex', 0);
                    $("#optt").removeClass("col-md-3");
                    $("#optt").addClass("col-md-2");

                    document.getElementById("whitelabelid").style.display = "none";
                    document.getElementById("allmaster").style.display = "none";
                    document.getElementById("dlm").style.display = "none";
                    document.getElementById("rem").style.display = "none";
                    document.getElementById("alldealer").selectedIndex = "0";
                    document.getElementById("allretailer").selectedIndex = "0";
                    document.getElementById("allmaster1").selectedIndex = "0";
                    document.getElementById("Whitelabel").selectedIndex = "0";
                }
                else if (answer == "Retailer") {
                    $("#optt").removeClass("col-md-3");
                    $("#optt").addClass("col-md-2");
                    document.getElementById("allmaster").style.display = "none";
                    document.getElementById("whitelabelid").style.display = "none";
                    document.getElementById("dlm").style.display = "none";
                    document.getElementById("rem").style.display = "block";
                    document.getElementById("alldealer").selectedIndex = "0";
                    document.getElementById("allmaster1").selectedIndex = "0";
                    document.getElementById("Whitelabel").selectedIndex = "0";
                }

                else if (answer == "WAdmin") {
                    $("#optt").removeClass("col-md-3");
                    $("#optt").addClass("col-md-2");
                    document.getElementById("allmaster").style.display = "none";
                    document.getElementById("whitelabelid").style.display = "block";
                    document.getElementById("dlm").style.display = "none";
                    document.getElementById("rem").style.display = "none";
                    document.getElementById("alldealer").selectedIndex = "0";
                    document.getElementById("allretailer").selectedIndex = "0";
                    document.getElementById("allmaster1").selectedIndex = "0";
                    document.getElementById("Whitelabel").selectedIndex = "0";
                }


            }
        </script>

