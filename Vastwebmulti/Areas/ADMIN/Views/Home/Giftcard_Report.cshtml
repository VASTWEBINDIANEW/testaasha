        white-space: nowrap;
    }

        .giftadmin-tableste tbody tr td .row {
            margin: 0px;
        }

        .giftadmin-tableste tbody tr td:nth-child(17) {
            white-space: normal;
        }

    .status-gift-admin img {
        height: 18px !important;
        padding: 3px !important;
        width: 18px;
        border-radius: 50%;
    }

    .status-gift-admin p {
        font-size: 0px !important;
    }

    .second-design .giftth-seconclass, .giftth-seconclass {
