                            <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;"><label id="lbladmintan"> @ViewBag.admin.tanno </label></p>
                        }
                        else
                        {
                            <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;">Data Not Found !</p>
                        }

                        @*<p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">TAN No.</p>
                    <p style="text-transform:uppercase;margin-top:-7px;padding-bottom: 6px;margin-bottom: 6px;">265498468</p>*@
                    </div>
                    <div id="EditnameandpancardModal" style="background: #f5f5f5;padding:10px; display:none;">
                        @*@using (Html.BeginForm("UpdatePanccardandmobile", "Home", FormMethod.Post))*@
                        @using (Ajax.BeginForm("UpdatePanccardandmobile", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "UpdateProfilesOnsucc", OnBegin = "ajaxValidate()" }))
                        {
                            <button type="submit" class="btn waves-effect " style="margin-top: 4px;background:#c7c7c7; margin-right:12px;position: absolute;right: -2px;top: -2px;height: 32px;padding: 5px 16px;">
                                <span style="color:#555;"> Save</span>
                            </button>
                            <input type="hidden" id="hdid1" name="hdid1" value="0" />

                            <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Name</p>
                            <p style="text-transform:uppercase;margin-top:-7px;padding-bottom: 6px;margin-bottom: 6px;">   @Html.TextBox("txtname", "", new { @class = "form-control", placeholder = "Enter Your Name", required = "required" })</p>

                            <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Mobile</p>
                            <p style="text-transform:uppercase;margin-top:-7px;padding-bottom: 6px;margin-bottom: 6px;"> @Html.TextBox("txtmobile", "", new { @required = "required", @class = "form-control", @placeholder = "Enter Mobile Number", onkeypress = "return isNumber(event)", maxlength = "10" })</p>
                            <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Aadharcard</p>
                            <p style="text-transform:uppercase;margin-top:-7px;padding-bottom: 6px;margin-bottom: 6px;"> @Html.TextBox("txtaadhaarcard", "", new { @required = "required", @class = "form-control", @placeholder = "Enter Aadhaar Number", onkeypress = "return isNumber(event)", maxlength = "12" })</p>
                            <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Pancard</p>
                            <p style="text-transform:uppercase;margin-top:-7px;padding-bottom: 6px;margin-bottom: 6px;">@Html.TextBox("txtpancard", "", new { @required = "required", @class = "form-control", @placeholder = "Enter Pancard Number", @style = "text-transform:uppercase", maxlength = 10 })</p>
                            <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">GST No</p>
                            <p style="text-transform:uppercase;margin-top:-7px;padding-bottom: 6px;margin-bottom: 6px;"> @Html.TextBox("txtgst", "", new { @required = "required", @class = "form-control", @placeholder = "Enter GST Number", maxlength = "15", @style = "text-transform:uppercase" })</p>
                            <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">TAN No</p>
                            <p style="text-transform:uppercase;margin-top:-7px;padding-bottom: 6px;margin-bottom: 6px;"> @Html.TextBox("txtTAN", "", new { @class = "form-control", @placeholder = "Enter TAN Number", maxlength = "15", @style = "text-transform:uppercase" })</p>
                            <label id="lblmsg"></label>
                        }
                    </div>





                </div>

            </div>
            <!--Otp security Password -->
            <div class="col-md-8 otp-security">
                <div class="card " style="margin-bottom: 0px;">
                    <div style="background-color:#c7c7c7;padding:10px;">
                        <h1 style="color:#555;font-size:20px;display: inline-block;font-weight:bold;text-transform:uppercase;margin:0px;">
                            <i class="fa fa-lock"></i>&nbsp;One Time Password Security
                        </h1>
                        <div class="onoffswitch" style="float:right;cursor:pointer;width: 66px;font-size: 18px;">
                            @if (Model.TwoFactorEnabled)
                            {
                                using (Html.BeginForm("DisableTwoFactorAuthentication", "Manage", new { area = "" }, FormMethod.Post, new { encType = "multipart/form-data" }))
                                {
                                    @Html.AntiForgeryToken()

                                    @*<span class="costom-on">on</span>*@
                                    <button style="border:0px;" type="submit" class="costom-on" value="ON" id="btnon" name="btnon">ON</button>

                                }
                            }
                            else
                            {
                                using (Html.BeginForm("EnableTwoFactorAuthentication", "Manage", new { area = "" }, FormMethod.Post, new { encType = "multipart/form-data" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @*<span class="custom-off">off</span>*@
                                    <button style="border:0px;" type="submit" class="custom-off " value="Off" id="btnff" name="btnff">OFF</button>
                                }
                            }

