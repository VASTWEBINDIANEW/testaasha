                   "</br><i class='fa fa-trash'style='font-size:72px;color:red;'></i></br><p style=''>Are you sure ?</p>",
             html: true,
            title:"" ,
            showCancelButton: true,
            confirmButtonColor: "#f9a7a7",
            confirmButtonText: "Yes, delete it!",
            closeOnConfirm: false
        },
function () {

    $.ajax({
        type: "POST", url: '@Url.Action("DelereprofileDoc", "Home")', data: { 'ID': ID, 'Docname': docname }, dataType: 'json', cache: false, success: function (result) {
            if (result == "Success") {
                debugger
                swal("File Removed!", " Deleted Successfully.", "success");
                if (docname == 'Pancard') {
                    $('#panspnadivshow').hide();
                    $('#panspnadivnotshow').show();
                                
                }
                else if (docname == 'ServiceAgrrement') {
                        $('#servicespnadivshow').hide();
                    $('#servicespnadivnotshow').show();
                }
                else {
                    $('#aadharspnadivshow').hide();
                    $('#aadharspnadivnotshow').show();
                }
              
              //  var url = '@Url.Action("Profile", "Home")';
             //   window.location.href = url;
            }
            else {
                swal("Failed!", "Something went wrong.", "error");
                var url = '@Url.Action("Profile", "Home")';
                window.location.href = url;
            }
        }
    });
}
);

    }

</script>

