@model Vastwebmulti.Models.User

@{
    ViewBag.Title = "Profile";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<style>
    .ribbon {
        position: absolute;
        right: -2px;
        top: -2px;
        z-index: 1;
        overflow: hidden;
        width: 75px;
        height: 75px;
    }

        .ribbon span {
            font-size: 11px;
            color: #fff;
            text-align: center;
            font-weight: bold;
            line-height: 20px;
            transform: rotate(45deg);
            -webkit-transform: rotate(45deg);
            width: 100px;
            box-shadow: 0 3px 10px -5px rgba(0, 0, 0, 1);
            position: absolute;
            top: 19px;
            right: -21px;
        }

    .list-group-item {
        border: none;
    }
    .custom-off::before {
    content: '';
    width: 15px;
    height: 15px;
    
    top: 8px;
}

    .field-validation-error {
        color: red;
    }
    .firt {
    -webkit-transform: rotate(-90deg);
    position: absolute;
    left: -46px;
    top: 48px;
}
    .ons1 button {
    font-size: 22px;
text-align: center;
padding: 5px 22px;
font-weight: bold;
margin: 0px auto;float:right;
   
margin-top: 22px;
}
    .ons1 input {
width: 24%;
float: right;
border: 1px solid #c7c7c7;
height: 28px;
margin-left: 4px;
padding: 0px 2px;
font-size: 12px;
}
    .ons1 {
    width: 100%;
    float: left;
    background: #fff;
    border: 1px solid #c7c7c7;
padding: 3px 5px;
margin-bottom: 5px;
}
    .ons1 span {
    font-size: 16px;
    display: inline-block;
    float: left;
    width: 32%;margin-top: 3px;
}
    .ons1 select {
    width: 17%;
    height: 28px;
    border: 1px solid #c7c7c7;float: left;
background: #e1e1e1;
}
    .firt span {
    color: var(--main-bg-lcolor);
    font-size: 16px;
    font-weight: bold;
    text-transform: uppercase;

}
    .firt3, .firt4 {
    margin-left: 5px;
}
    .firt2, .firt3, .firt4 {
    padding: 0px;
    width: 32%;
}
    .required:after {
        color: red;
        content: " *";
    }

    .profile-register-address .list-group-item {
        background-color: #f5f5f5;
    }
</style>
<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-4">
                <div class="card " style="margin-bottom:0px;">
                    <div class="ribbon"><span class="fullbodydycolorbg">ADMIN</span></div>

                    <div class="body fullbodydycolorbg">
                        <center>
                            @if (ViewBag.image != null)
                            {
                                <div class="image" style="margin-top:24px;">
                                    <img id="Adminimage" src="@Url.Content("~/"+ ViewBag.image )" class="img-circle" alt="User" width="100" height="100" title="Click Me Upload Profile Image" style="cursor:pointer;" onclick="uploadimage(@ViewBag.admin.ID)" />
                                </div>
                            }
                            else
                            {
                                <div class="image" style="margin-top:24px;">
                                    <img id="Adminimage" src="~/AdminDesign/images/user.png" width="100" height="100" class="img-circle" alt="User" title="Click Me Upload Profile Image" style="cursor:pointer;" onclick="uploadimage(@ViewBag.admin.ID)">
                                </div>
                            }

                            <div class="msg" style="padding-top:12px; font-size:19px; font-weight:600; color:#fff">@ViewBag.admin.Name</div>
                            <p style="margin-top:5px;font-size:14px;text-transform:uppercase;color:#fff" ">Administrator</p>

                        </center>
                    </div>
                </div>

            </div>
            <div id="saveaddressModal" class="col-lg-8 col-md-8 col-sm-12 col-xs-12">
                <div class="card" style="margin-bottom:0px;">
                    <div style="background-color:#c7c7c7;padding: 5px 10px; padding:10px;">
                        @if (ViewBag.admin.Companyname != null)
                        {
                            <h1 style="color:#555;font-size:20px;font-weight:bold;text-transform:uppercase;margin:0px;">
                                <span id="spncompny">  @ViewBag.admin.Companyname </span>
                                <a style="float:right;font-size:14px; color:#555; border: 1px solid  #bbb;padding: 5px 15px;text-transform:capitalize; cursor: pointer;" onclick="editeaddress(@ViewBag.admin.ID)">Edit</a>
                            </h1>
                        }
                        else
                        {
                            <h1 style="color:#555;font-size:24px;font-weight:bold;text-transform:uppercase;margin:0px;">
                                <span id="spncompny">
                                    No Data Found !
                                </span>
                                <a style="float:right;"><i class="fa fa-pencil-square-o" style="font-size:22px;margin-top:0px;" onclick="editeaddress(@ViewBag.admin.ID)"></i></a>
                            </h1>
                        }
                    </div>
                    <div class="body profile-register-address" style="background:#f5f5f5;padding-top: 0px;padding-bottom: 13px;  ">
                        <ul class="list-group" style="margin-bottom:4px;">
                            <li class="list-group-item">
                                <i class="fa fa-map-marker"></i> <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Registered Business Address</span>
                            </li>
                            <li class="list-group-item">

                                @if (ViewBag.admin.Address != null && ViewBag.admin.Address != "")
                                {
                                    <p style="text-align:justify;margin-top:-12px;"><span id="spnaddress"> @ViewBag.admin.Address </span></p>
                                }
                                else
                                {
                                    <p style="margin-top:-12px;"><span id="spnaddress"> ADDRESS NOT FOUND !  </span></p>
                                }

                            </li>
                            <li class="list-group-item" style="margin-top:-19px;">
                                <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;Zip Code</span>
                                @if (ViewBag.admin.pincode != null)
                                {
                                    <p style="float:right;margin-top:5px;"><span id="spnpincode"> @ViewBag.admin.pincode </span></p>
                                }
                                else
                                {
                                    <p style="float:right;margin-top:5px;"><span id="spnpincode"> ZIP CODE NOT FOUND ! </span></p>
                                }
                            </li>
                            <li class="list-group-item">
                                <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;State</span>
                                <p style="float:right;text-transform:uppercase;"><span id="spnstate">  @ViewBag.ddlstate </span></p>
                            </li>
                            <li class="list-group-item">
                                <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;District</span>
                                <p style="float:right;text-transform:uppercase;"><span id="spndistrict"> @ViewBag.dddistrict </span></p>
                            </li>

                        </ul>
                    </div>
                </div>
            </div>
            <div id="EditaddressModal" class="col-lg-8 col-md-8 col-sm-12 col-xs-12" style="display:none;">
                <div style="background:#f5f5f5;width:100%;float:left;">
                    <div class="card" style="margin-bottom:0px;">
                        @*@using (Html.BeginForm("UpdateAddressProfile", "Home", FormMethod.Post))*@

                        @using (Ajax.BeginForm("UpdateAddressProfile", "Home", new AjaxOptions
                        {
                            InsertionMode = InsertionMode.Replace,
                            OnSuccess = "OnSuccessEditAddress",
                            OnFailure = "OnFailure",

                            // LoadingElementId = "progress"
                        }))

                        {
                            <input type="hidden" id="hdidadmin" name="hdidadmin" value="" />
                            <div style="background-color:#c7c7c7;padding: 5px 10px; padding:10px;">

                                <h1 style="color:#555;font-size:20px;font-weight:bold;text-transform:uppercase;margin:0px;">
                                    @Html.TextBox("txtcompany", "", new { @class = "form-control", placeholder = "Enter Your Company Name", required = "required", @style = "width:300px;" })
                                    <button type="submit" class="btn waves-effect" style="margin-top: 4px;background:#c7c7c7; margin-right:12px;position: absolute;right: -2px;top: 5px;height: 32px;padding: 5px 16px;">
                                        <span style="color:#555;"> Save</span>
                                    </button>
                                </h1>

                            </div>
                            <div class="body profile-register-address" style="background:#f5f5f5;padding-top: 0px;padding-bottom: 13px;  ">
                                <ul class="list-group" style="margin-bottom:0px;padding-bottom:4px;">
                                    <li>
                                        <i class="fa fa-map-marker"></i> <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Registered Business Address</span>
                                    </li>
                                    <li>


                                        <p style="text-align:justify;">   @Html.TextBox("txtaddress", "", new { @class = "form-control", placeholder = "Enter Your Address", required = "required", @style = "width:100%;" })</p>


                                    </li>
                                    <li>
                                        <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;Zip Code</span>

                                        <p style="float:right;"> @Html.TextBox("txtzipcode", "", new { @required = "required", @class = "form-control", @placeholder = "Enter Zip Code", onkeypress = "return isNumber(event)" })</p>

                                    </li>
                                    <li>
                                        <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;State</span>
                                        <p class="custom-district" style="float:right;text-transform:uppercase;"> @Html.DropDownList("State", (IEnumerable<SelectListItem>)ViewBag.Sate, "-- Select State--", new { @class = "form-control", @required = "required", @onchange = "FillDistict()" })</p>
                                    </li>
                                    <li>
                                        <span style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">&nbsp;District</span>
                                        <p class="custom-district" style="float:right;text-transform:uppercase;"> @Html.DropDownList("District", (IEnumerable<SelectListItem>)ViewBag.District, "-- Select District--", new { @class = "form-control", @required = "" })</p>
                                    </li>

                                </ul>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>

        <div class="row clearfix">
            <div class="col-md-4">
                <div class="card ">
                    <div class="" style="background-color:#c7c7c7;padding: 5px 10px;">
                        <h1 style="color:#555;font-size:14px;font-weight:bold;text-transform:uppercase;margin:0px;">
                            Website Launching Date
                            <a style="float: right;border: 1px solid  #bbb;padding: 5px 15px;color:#555; text-transform:capitalize; cursor: pointer;" onclick="editemobileandpancard(@ViewBag.admin.ID)">Edit</a>
                        </h1>
                        <p style="text-transform:uppercase;margin-bottom:0px;">@ViewBag.admin.Date</p>

                    </div>
                    <div class="my-profile-save" style="background: #f5f5f5;padding:10px;">
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Name</p>
                        <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;"><label id="lbladminname">@ViewBag.admin.Name</label> </p>
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Email-ID</p>
                        <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;"><label id="lbladminemail">@ViewBag.admin.email </label> </p>
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Mobile</p>
                        <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;"><label id="lbladminmobile"> @ViewBag.admin.mobile </label></p>
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Aadharcard</p>
                        @if (ViewBag.admin.Aadhar != null && ViewBag.admin.Aadhar != "")
                        {
                            <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;"><label id="lbladminaadhar"> @ViewBag.admin.Aadhar </label></p>
                        }
                        else
                        {
                            <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;">Data Not Found !</p>
                        }
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">Pancard</p>
                        @if (ViewBag.admin.pencardno != null && ViewBag.admin.pencardno != "")
                        {
                            <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;"><label id="lbladminpencard"> @ViewBag.admin.pencardno </label></p>
                        }
                        else
                        {
                            <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;">Data Not Found !</p>
                        }
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">GST No</p>
                        @if (ViewBag.admin.Gstno != null && ViewBag.admin.Gstno != "")
                        {
                            <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;"><label id="lbladmingst"> @ViewBag.admin.Gstno </label></p>
                        }
                        else
                        {
                            <p style="text-transform:uppercase;margin-top:-7px;border-bottom: 1px solid #fff;padding-bottom: 6px;margin-bottom: 6px;">Data Not Found !</p>
                        }
                        <p style="color:#7a7676;font-family:'Open Sans',sans-serif;font-weight:600;">TAN No.</p>
                        @if (ViewBag.admin.tanno != null && ViewBag.admin.tanno != "")
