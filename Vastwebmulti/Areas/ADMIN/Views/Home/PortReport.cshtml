<!--Login -->
<script type="text/javascript">

    function login(portno) {
        $.ajax({
            type: "GET",
            url: '@Url.Action("portlogin", "Home")?Id=' + portno,
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            beforeSend: function(){
                Show(); // Show loader icon
            },
            success: function (response) {

                if (response == "Your OTP has been sent to registered mobile, please enter to proceed" || response == "Otp Sent Successfully" || response == "An OTP has been sent. Please check your SMS" || response == "Otp Send SuccessFully")
                {
                    $('#porthidden').val(portno);
                    $('#defaultModal2').modal('show');
                }
                else
                {
                   swal("Error!", response, "error");
                }
            },
            complete: function(){
                Hide(); // Hide loader icon
            },
            failure: function (jqXHR, textStatus, errorThrown) {
                alert("HTTP Status: " + jqXHR.status + "; Error Text: " + jqXHR.responseText); // Display error message
            }
        });
    }

    $(function () {
        $("#div_Loader").hide();
    });

    function Show() {
        $('#div_Loader').show();
    }

    function Hide() {
        $('#div_Loader').hide();
    }
</script>

