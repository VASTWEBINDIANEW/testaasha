@model Vastwebmulti.Areas.ADMIN.Models.Show_all_slab

@{
    ViewBag.Title = "ShowAllSlab";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/jquery-1.10.2.min.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

<script>
    $(function () {
        var chh = '@ViewData["type"]';
        var chh1 = '@ViewData["slabname"]';
        if (chh == "INDO NEPAL")
        {
            chh = "NEPAL";
        }
        $('#' + chh+'').show();
        $('#slabfor').change(function () {
            var slabfor = $('#slabfor').val()
            listfill(slabfor)
        });
        var slabfor = $('#slabfor').val()
        listfill(slabfor,chh1)

       
    });
    function listfill(slabfor,chh1)
    {
        var procemessage = "<option value='0'> Please wait...</option>";
        $("#slabname").html(procemessage).show();
        var url = '@Url.Action("SlabList","Home")'
        $.ajax({
            url: url,
            data: { Id: slabfor },
            cache: false,
            type: "POST",
            success: function (data) {
                var markup = "<option value='0'> Select Slab Name</option>";
                for (var x = 0; x < data.length; x++) {
                  
                    markup += "<option value='" + data[x].Value + "'>" + data[x].Text + "</option>";
                 
              
                }
                $("#slabname").html(markup).show();
                var objSelect1 = document.getElementById("slabname");
                setSelectedValue(objSelect1, chh1);
            },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
  
    }
    function setSelectedValue(selectObj, valueToSet) {
        for (var i = 0; i < selectObj.options.length; i++) {
            if (selectObj.options[i].text == valueToSet) {

                selectObj.options[i].selected = true;
                return;
            }
        }
    }
    function funedit()
    {
        var chh1 = '@ViewData["type"]';
        if (chh1 == "INDO NEPAL") {
            chh1 = "NEPAL";
        }
        $('#' + chh1 + '_show').hide()
        $('#' + chh1 + '_edit').show()
        $('#' + chh1 + '_Save').show()
    }
</script>
