<script>
    function Editbtn(idno) {
        
        $('.timeshowclass').show();
        $('.timehideclass').hide();
        var btnedit = "editbtnshow_" + idno;
        var btnsave = "savebtnnotshow_" + idno;
        var opentmeshow = "opentimeshow_" + idno;
        var opentimenotshow = "opentimenotshow_" + idno;
        var closetimeshow = "closetimeshow_" + idno;
        var stsidshow = "stsidshow_" + idno;
        var closetimenotshow = "closetimenotshow_" + idno;
        var ddlstsid = "ddlstsid_" + idno;
        var closetimenotshow = "closetimenotshow_" + idno;
        $('#'+btnedit).hide();
        $('#' + btnsave).show()
        $('#' + opentmeshow).hide();
        $('#' + opentimenotshow).show();
        $('#' + closetimeshow).hide();
        $('#' + stsidshow).hide();
        $('#' + closetimenotshow).show();
        $('#' + ddlstsid).show();



    }


    function SaveTimeInformation(idno) {
        
        var fromtime=  $('#txttimeopen_' + idno).val();
        var totime = $('#txttimeclose_' + idno).val();
        var spntimefrom = "spntimefrom_" + idno;
        var spnclose = "spntimeclose_" + idno;
        var spnstss = "spnsts_" + idno;
        var ddlopenclosestatus = "ddlopenclosestatus_" + idno;
      
        var dataa = { idno: idno, fromtime: fromtime, totime: totime, statuscurrent: $('#' + ddlopenclosestatus).val() }
         $.ajax({
            type: "POST",
            url: '@Url.Action("Addscheduletime", "Home")',
             data: dataa,
            success: function (data) {
                if (data.sts == 'OK') {
                    

                    var converdattinformate = new Date(parseInt(data.openstime.replace("/Date(", "").replace(")/", ""), 10));
                    converdattinformate = converdattinformate.toLocaleTimeString()
                    $('#' + spntimefrom).text(converdattinformate);
                    converdattinformate = new Date(parseInt(data.closingtime.replace("/Date(", "").replace(")/", ""), 10));
                    converdattinformate = converdattinformate.toLocaleTimeString()
                    $('#' + spnclose).text(converdattinformate);
                    if (data.currentsts == "Y") {
                        $('#' + spnstss).text('Open');
                    } else {
                        $('#' + spnstss).text('Close');
                    }
                    $('#' + ddlopenclosestatus).val(data.currentsts);
                    $('.timeshowclass').show();
                    $('.timehideclass').hide();

                }
            }
        })


    }

</script>
