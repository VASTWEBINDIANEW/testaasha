}
<style type="text/css">

    /* new css */
    .tab-sam-start .card {
        background: #fff;
    }
    .tmw-notifications .tab-content.current, .tmw-notifications .tab-content2.current2 {
        background: #fff;
    }
    .bread-same-all-page li {
        margin: 6px 0;
    }
    .tmw-notifications .tab-content2 .holiday-cal ul li.three {
        width: 30%;
    }
    .tmw-notifications .tab-content2 .holiday-cal ul li.four {
        padding-left: 8px;
    }
    /* new css */

    .loadermoney {
        position: fixed;
        left: 0px;
        top: 0px;
        width: 100%;
        height: 100%;
        z-index: 199999;
        background: url('../../images/Progess.svg') 50% 50% no-repeat rgba(249, 249, 249, 0.9);
    }


    table.table.table-responsive.tests input.custom-checkbox {
        position: inherit;
        opacity: inherit;
    }
</style>
<style>
    .dropdown-menu {margin-top: 81px !important;}

    .custom-district-selectclass .custom-district::after {display: none;}
    .customer-support-time tr th, .customer-support-time tr td, .customer-support-time tr, .customer-support-time table, .customer-support-time tr th {
        border: 1px solid #ccc;
    }
        .customer-support-time tr td button {
            border: 1px solid #ccc;padding: 2px 10px;background: #f0f0f0;height:32px;
        }
        .customer-support-time tr td input {
            width: 100%;padding: 1px 2px;text-align: center;box-shadow: none !important;
            outline: none !important;border:1px solid #ccc;height:32px;
        }
        .customer-support-time tr td select {border: 1px solid #ccc;padding: 4px 0;height:32px;}
    .customer-support-time .popup_img {width: 100%;float: left;}
    .customer-support-time .popup_img .width100.margin0, .customer-support-time .popup_img ul, .customer-support-time .popup_img .width100.margin0, .customer-support-time .popup_img ul li {
        width: 100%;float: left;text-align: center;
    }
        .customer-support-time .popup_img h2 {padding: 8px 0 !important;color: #555;}
    .customer-support-time .appslider-admin table tr td a {float: left;}
    .customer-support-time .appslider-admin table tr td form {
        float: left;padding-left: 5px;
    }
    .app-content-class ul {display:flex;}


    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media screen and (max-width:767px){
        .customer-support-time tr th, .customer-support-time tr td, .customer-support-time tr, .customer-support-time table, .customer-support-time tr th {
            white-space:nowrap;
        }
        .notification-customer ul.tabs2 li {width: 33.3% !important;border-bottom: 2px solid #fff;}
        .notification-customer ul.tabs2 li:nth-child(3) {border-right: 0;}
        .notification-customer ul.tabs2 li:nth-child(4), .notification-customer ul.tabs2 li:nth-child(5) {
            width: 50% !important;border-bottom-color: #a4a0a0;
        }
        .notification-customer ul.tabs2 li.current2 {border-bottom: 2px solid #000;}
        .app-content-class ul {display: block;}
        .app-content-class ul li {
            margin: 0 !important;float: left;width: 50% !important;padding-right: 3px;
            margin-bottom: 10px !important;min-height: 34px !important;
        }
        .app-content-class .popup_img.width100 li {
            width: 100% !important;margin: 0px !important;padding: 0px !important;
        }
        .customer-support-time .appslider-admin table tr td img {max-width: 118px;}

    }

    @@media only screen and (max-width:480px){

        .tab-link {
            font-size: 12px;
        }
        .tmw-notifications .tab-content2 ul.tk1 li.two {
            width: 100%;
        }
        .tmw-notifications .tab-content2 ul.tk1 li.three {
            width: 100%;
            margin-top: 4px;
        }
        .tmw-notifications .tab-content2 ul li {
            width: 100% !important;
        }

    }

</style>

