                                                         @*<input id="btntype_TODAY" name="btntype" type="submit" value="TODAY" class="btn" style="margin-top:0px; height:32px;border:1px solid #c7c2c2;background:#dedddd;" />*@
                                                         <input id="btntype_OLD" name="btntype" type="submit" value="SEARCH" class="btn input-back-second" style="padding-left: 20px;margin-top:0px; height:32px;border:1px solid #b1a6a638;background:#fff ;" />
                                                     </div>
                                                 </center>
                                             </div>
                                         </div>


                                     </div>

                                 </div>
                         }
