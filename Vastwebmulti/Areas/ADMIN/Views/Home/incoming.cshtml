                                             <div class="col-md-10 clk" style="padding: 0px;margin-left: 4px;float:right;">
                                                 <div class="input-daterange input-group" style="margin-left:0px;width:100%;margin-top: 0px;">
                                                     <div class="custom-date-icon ner">
                                                         <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                                     </div>
                                                     @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #b1a6a638; margin-top:0px;height:32px;" })
