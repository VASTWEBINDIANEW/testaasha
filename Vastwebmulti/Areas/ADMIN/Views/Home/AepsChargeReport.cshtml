        }
    }

    @@media screen and (max-width:767px) {


        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media only screen and (max-width:520px) {

        .fin3 {
            position: relative;
            right: 0;
        }
    }

    @@media only screen and (max-width:480px) {
        .d_menu {
            width: 100% !important;
        }

        .kklo.money-transfer-admin #custnav ul li a {
