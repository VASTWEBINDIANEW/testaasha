        }

        .inputiconsateall {
            width: 50% !important;
        }

        .t_menu {
            margin: 4px 0;
            float: left;
            width: 100%;
        }

        .fin1, .fin2 {
            width: 100% !important;
            display: block !important;
        }

            .fin1 .kklo #custnav ul li a {
                padding: 5px 15px;
            }

            .fin2 .col-md-2, .fin2 .cltu.col-md-1 {
                width: 49% !important;
                float: left;
                margin-left: 0px !important;
            }

            .fin2 .col-md-1.cltu.for-width {
                width: 49.2% !important;
            }

            .fin2 .col-md-1.cltu.for-width-r {
                width: 48% !important;
            }

            .fin2 .col-md-3 {
                width: 100% !important;
                margin-bottom: 5px;
            }

                .fin2 .col-md-3 input {
                    width: 49% !important;
                }

                .fin2 .col-md-3 .nrr3 {
                    width: 48%;
                }

                    .fin2 .col-md-3 .nrr3 input {
                        width: 100% !important;
                    }

        .cltu {
            margin-bottom: 15px !important;
        }

        .llpo span {
            display: inline-block;
        }

        .fin2 .col-md-1 {
            width: 40% !important;
        }

            .fin2 .col-md-1 .button {
                width: 100%;
            }

        .table-responsive > .table-bordered > thead > tr > th:first-child {
            border-left: 1px solid var(--border-color);
        }

        .table-responsive > .table-bordered > thead > tr > th:last-child {
            border-right: 1px solid var(--border-color);
        }

        .col-md-12.classbottomo-third {
            width: 100%;
            float: left;
            position: relative;
        }



        .card.card-rel-third-respo {
