    .bootstrap-select.btn-group:not(.input-group-btn), .bootstrap-select.btn-group[class*="col-"] {
        height: 20px;
    }

    table.dataTable thead > tr > th, table.dataTable thead > tr > td {
        padding-right: 10px;
    }

    .card {
        margin-bottom: 0px;
    }

    .table-bordered tbody tr td span {
