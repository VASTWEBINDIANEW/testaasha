            float: left;
            display: block !important;
        }

        .left-space-no {
            margin-left: 0px !important;
        }

        .responcive-fify button.btn.llpo {
            width: 100%;
            text-align: left;
        }

        .responcive-full input {
            width: 49% !important;
        }

        .responcive-full .nrr3 input {
            width: 100% !important;
        }

        .responcive-fify .web-white-filter {
            width: 100%;
        }

        .fin1.gjut-ruty ul li {
            width: 24.5%;
            position: relative;
        }

            .fin1.gjut-ruty ul li img {
                position: absolute;
                left: 30%;
            }

        .col-md-1.cltu.for-width-r.responcive-full {
            margin-bottom: 23px;
        }

        .white-success {
            float: left !important;
            width: auto !important;
            right: 52% !important;
        }

        .col-md-12.classbottomo-third {
