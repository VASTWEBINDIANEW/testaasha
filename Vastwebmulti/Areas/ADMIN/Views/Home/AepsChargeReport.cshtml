    .kklo.money-transfer-admin #custnav ul {
        margin-bottom: 0px;
    }

    .d_menu .row {
        margin: 0;
    }

    .allpagefinincal-report .responcive-fify {
        width: auto !important;
    }

    .filter-option.pull-left {
        margin: 0px 9px;
    }

    .allpagefinincal-report .reportdate-money-allpage {
        width: auto;
    }

    .inputiconsateall {
