<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>Giftcard Report</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard", "Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Report's&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>
                <li><a href="javascript:void(0);">Giftcard Report</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->
     
        <div class="row clearfix">

            <div class="col-lg-12 col-md-12 gift-card-top all-type-third">
                <div class="card page-header-third margin-bottom-third cardbackg-third onlymargin-third newcardclass borderclassgift" style="margin-top:2px;">
                    @using (Html.BeginForm("Showclosingbalance", "Home", FormMethod.Post))
                    {
                    <div class="">
                        <div class="col-md-4 gift-select">
                            <div class="form-line selecthotel-third" style="width: 146px;">
                                @Html.DropDownList("allretailer", ViewBag.retailer as SelectList, "All Retailer", new { id = "allretailer", @class = "select-s form-control", data_live_search = "true", @style = "margin-top:0px; padding:0px;text-align:center;height:32px;" })
                            </div>
                        </div>

                        <div class="col-md-3 clk responcive-full" style="padding-right: 0px; padding-left: 5px;">
                            <div class="input-daterange input-group" style="margin-left:0px;width:100%;">
                                <div class="custom-date-icon ner">
                                    <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                </div>
                                @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #b1a6a638; height:32px; width: 100%;" })
                                <span class="input-group-addon" style="padding: 0px !important;min-width: 3px;">

                                </span>
                                <div class="nrr3">
                                    <div class="custom-date-icon ner2">
                                        <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg " aria-hidden="true"></i>
                                    </div>
                                    @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #b1a6a638; height:32px; width: 100%;" })
                                </div>
                            </div>
                        </div>

                        <div class="col-md-1 ytr-okpli gift-respo-thired search-resp-third" style="padding:0px;padding-left:5px;">
                            <div class="">
                                <div class="">
                                    <center>
                                        <button name="btntype" type="submit" class="btn input-back-second" style="  height:32px;border: 1px solid #b1a6a638;background: #fff;margin-top:1px;background: #f9f9f9;width: 100%;" onclick="serch()">
                                            <i class="fa fa-search" style="top:-1px;font-size:13px;color:black;"></i>
                                            <span style="top:-1px;color:black;">Search</span>
                                        </button>
                                    </center>

                                </div>


                            </div>
                        </div>

                    </div>
                    }

                </div>


            </div>

            <div>
                <table class="table table-bordered table-striped table-hover table-background-second third-design-table">
                    <tr>
                        <th>Sr.</th>
                        <th>USER</th>
                        <th>Dealer</th>
                        <th>Master</th>
                        <th>Opening Balance</th>
                        <th>Date & Time</th>
                    </tr>
                    @{ var id = 0; }
                    @{ var id1 = 1; }
                    @foreach (var i in Model)
                    {
                        var frmname = db.Retailer_Details.Where(s => s.RetailerId == i.userid).SingleOrDefault();
                        var dlmfrmname = db.Dealer_Details.Where(s => s.DealerId == frmname.DealerId).SingleOrDefault();
                        var ssfrmname = db.Superstokist_details.Where(s => s.SSId == dlmfrmname.SSId).SingleOrDefault();

                <tr>
                    <td>@id1</td>
                    <td>@frmname.Frm_Name</td>
                    <td>@dlmfrmname.FarmName</td>
                    <td>@ssfrmname.FarmName</td>
                    <td>
                        @i.closingbalance1
                    </td>
                    <td>
                        @i.date
                    </td>
                </tr>
                        id++;
                        id1++;
                    }
                </table>
            </div>




        </div>
    </div>
</section>




