@using Vastwebmulti.Models;
@model Vastwebmulti.Areas.ADMIN.Models.Fundtransferviewmodel
@{
    ViewBag.Title = "Fund_transfer";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}
@{
    VastwebmultiEntities DB = new VastwebmultiEntities();
    string hspass = "OK";
    var chksec = DB.admin_new_pass.SingleOrDefault();
    DateTime currenttime = DateTime.Now;
    DateTime lastchangedpassdss = Convert.ToDateTime(chksec.lastupdatetrans);
    lastchangedpassdss = lastchangedpassdss.AddDays(Convert.ToInt32(chksec.transexpdays));
    if (chksec.transpass == "lOW3n9XMM8fCuXPLyaQkkQ==" || (lastchangedpassdss <= currenttime))
    {
        hspass = "NOTOK";
    }
}
