@*@model IEnumerable<Vastwebmulti.Models.ShowBankRequest>*@
@{
    ViewBag.Title = "Retailer_showpurchase";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";

    var msg = Convert.ToString(TempData["msgbox"]);

    if (msg != null && msg != "")
    {
        <script>
                alert(@msg)
        </script>
    }
}
<style>

    /* new css   */

    .breadsameall-second {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    #Retailerpurchasetable {
        overflow-x: scroll;
    }


    /* new css   */

    .dropdown-menu {
        margin-top: 81px !important;
    }

    .buttonload .fa.fa-refresh.fa-spin {
        margin-left: -12px;
        margin-right: 8px;
    }

    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }


    @@media screen and (max-width:767px) {
        .table.table-bordered.table-striped.third-design-table {
            border-left: 1px solid #aaa4a4 !important;
            border-right: 1px solid #aaa4a4 !important;
        }
    }

    @@media screen and (max-width:520px) {

        .res_div {
            width: 100% !important;
            padding: 3px 0px !important;
        }

        .retaile-bank-ul {
            width: 100% !important;
            float: left !important;
        }

        .bread-same-all-page a.second-button {
            font-size: 13px !important;
        }


        .breadsameall-second {
            display: block;
        }
    }

    @@media only screen and (max-width:480px) {
        .lop {
            padding: 0px !important;
        }

        .res_p {
            padding: 0 !important;
        }

        .table-responsive > .table-bordered > thead > tr > th:first-child, .table-responsive > .table-bordered > tbody > tr > td:first-child {
            border-left: 1px solid var(--border-color);
        }
    }
</style>
<section class="content">
    <div class="container-fluid">

        <!--Four-Design-Admin-page-Header-Section-Start-->
        <div class="page-title-box-fourde-admin">
            <h3>User A/C Q</h3>
            <ul>
                <li><a href="@Url.Action("Dashboard","Home")" style="color:var(--fullbodybg-four);">Home&nbsp;&nbsp;<i class="fa fa-angle-right" style="margin:0px;"></i></a></li>
                @*<li><a href="javascript:void(0);">Complaint&nbsp;&nbsp;<i class="fa fa-angle-right"></i></a></li>*@
                <li><a href="javascript:void(0);">User A/C Q</a></li>
            </ul>
        </div>
        <!--Four-Design-Admin-page-Header-Section-End-->

        <div class="page-header-third pageheader-margin-third">
            <div class="bread-same-all-page breadsameall-second" style="width:100%;float:left;">
                <ul class="padding-top-third retaile-bank-ul four-noneclass-admin-only res_div" style="width: auto; float: left; margin: 0;">
                    <li class="smli">
                        <a href="@Url.Action("Dashboard", "Home")" class="fullbodydycolorbg tmw-total-color-one">
                            Dashboard&nbsp;<img src="~/ashok-images/rightaeps.svg" alt="right-arrow" style="width:12px;margin-top:-2px;" />
                        </a>
                    </li>

                    <li class="fullbodydycolorbg tmw-total-color-one">
                        Retailer Bank
                    </li>


                </ul>
                <div class="col-md-4 retailerbank-pdf res_div" style="padding-right:0px;width:auto;float:right;padding-left:5px;">

                    <div class="res_p" style="float: left; padding: 0px 3px;">
                        <a href="@Url.Action("Delete_Approve_Bank_list" )" class="second-button back-white-third-de" style="background: #eeebeb;border: 1px solid #bbb;color:#333;height: 32px;padding: 3px 5px;font-weight:400 !important;">
                            Delete Bank Approve List
                        </a>
                    </div>

                    <div style="float:right; " class="web-white-filter lop res_p">

                        <input type="button" id="btnExport" class="back-white-third-de" value="Export" style="margin-left:0px; padding: 0px 4px;height:32px;border:1px solid #bbbbbb;background:#b1a6a638;background-image: url(../../images/reportimage/xls.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 20px;">
                        <input type="button" id="btnPDF" class="back-white-third-de" value="PDF" style="margin-left:2px; padding: 0px 4px;height:32px;border:1px solid #bbbbbb;background:#b1a6a638;background-image: url(../../images/reportimage/pdf.png);background-repeat: no-repeat;background-position: 4px center;padding-left: 19px;">

                    </div>
                </div>

            </div>
        </div>


        <div class="row clearfix">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="card page-header-third">
                    <div id="Retailerpurchasetable">
                        @Html.Partial("_RetailerBankList")
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


