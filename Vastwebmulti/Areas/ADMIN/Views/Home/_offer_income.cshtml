@model IEnumerable<Vastwebmulti.Models.select_all_offer_income_Result>

@{
    Layout = null;
}

@if (Model != null)
{
    foreach (var item in Model)
    {
        <tr>
            <td> @Html.DisplayFor(modelItem => item.portno)</td>
            <td> @Html.DisplayFor(modelItem => item.msg)</td>
            <td>@Html.DisplayFor(modelItem => item.edate)</td>
        </tr>
    }
}