@model Vastwebmulti.Models.GiftCard
@{
    ViewBag.Title = "Edit_Gift";
    Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-md-12">
                @using (Html.BeginForm("Edit_Gift", "Home", FormMethod.Post, new { encType = "multipart/form-data" }))
            {
                    <div class="card">
                        <div class="header" style="padding:10px;">
                            <h2>
                                <span style="font-size:21px;"></span> Update Travel Content
                            </h2>
                        </div>
                        <div class="row">
                            <div class="body">
                                <div class="col-md-12">
                                    @Html.HiddenFor(model => model.ID)
                                    <label for="setbox">Enter Content</label>
                                    <div class="form-group">
                                        <div class="form-line">
                                            @Html.TextBoxFor(model => model.Category, new { @class = "form-control" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <label for="setbox">Select Image</label>
                                    <div class="form-group">
                                        <div class="form-line">
                                            <input type="file" id="file" name="file" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <button type="submit" class="btn btn-info">Update</button>
                                </div>
                            </div>
                        </div>

                    </div>
                }
            </div>

        </div>
    </div>
</section>

<script src="~/Swalalert/sweetalert-dev.js"></script>
<link href="~/Swalalert/sweetalert.css" rel="stylesheet" />

