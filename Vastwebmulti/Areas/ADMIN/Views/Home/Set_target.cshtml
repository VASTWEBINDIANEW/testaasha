    }
    .table-responsive {
        height: 500px;
    }
    #target4 .table-responsive {
        overflow: auto;
    }

    .target-tab-inner {
        background: #fff;
    }
    .slab-first-tab .nav.nav-tabs.set-target-left {
        width: 100%;
    }
    .col-md-2.slab-first-tab {
        padding-right: 15px;
        padding-left: 15px;
    }

      
      /* new css */

    .table-responsive > .table-bordered > thead > tr > th:first-child, .table-responsive > .table-bordered > thead > tr > td:first-child, .table-responsive > .table-bordered > thead > tr > th:last-child {
        border-left: 1px solid var(--border-color);
        border-right: 1px solid var(--border-color);
    }

    .toast-top-right1 {top: 65px;left: 81%;}
    .for-custom-select-icon.custom-district::after{display:none;}

    .target-achived select, .target-achived button {
        border: 1px solid #aaa4a4;background: #fff;padding: 5px 2px;
    }
    .target-achived button {padding: 5px 10px;line-height:normal;}
    .target-achived {
        float: left;margin-top: 6px;margin-bottom: 6px;display:flex;
    }
    .target-achived select {margin-right: 4px;}



    @@media only screen and (max-width:1280px) {

        section.content {
            margin: 75px 0px 0 160px;
        }
    }

    @@media only screen and (max-width:1169px) {

        .ls-closed section.content {
            margin-left: 0px;
        }
    }

    @@media only screen and (max-width:1024px) {

        #sidebar-open {
            top: 29px;
            left: -147px;
        }
    }

    @@media only screen and (max-width:767px) {
        #sidebar-open {
            top: -1px;
            left: -4px;
        }
    }

    @@media screen and (max-width:992px){
        .col-md-10.slab-first-tab-content.set-target-right {
            width: 100%;float: left;margin-top: 15px;
        }
        .set-target-left {
            height: inherit !important;width: 100%;float: left;padding: 25px 10px;
        }
        .col-md-2.slab-first-tab {width: 100%;float: left;}
        .target-achived {width: 100% !important;float: left;}
