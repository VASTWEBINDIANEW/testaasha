<style>

      /* new css */
    .bread-same-all-page li {
        margin: 6px 0px;
    }
    .slab-first-tab {
        background: #fff;
    }
        .slab-first-tab ul li {
            background: #f1f1f1;
        }
    .set-target-left {
        background: #fff !important;
    }
    .set-target-right .tab-content {
        background: #fff;
