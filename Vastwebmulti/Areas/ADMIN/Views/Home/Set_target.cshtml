<script>
    function AchivedHistory(monthVal, userRole, UserId, ddlcategory) {
       $.ajax({
          url: "@Url.Action("AchivedHistory")",
           data: { monthVal: monthVal, userRole: userRole, UserId: UserId, ddlcategory: ddlcategory },
           success: function (response) {
               $('#hdselect').val(monthVal);
               if (userRole == "Retailer") {
                   $('#RemAchHis > tbody').html(response)
               }
               else if (userRole == "Dealer") {
                   $('#DlmAchHis > tbody').html(response)
               }
               else if (userRole == "Master") {
                   $('#MdAchHis > tbody').html(response)
               }
               else if (userRole == "Api") {
                   $('#ApiAchHis > tbody').html(response)
               }
            }
        })
    }
