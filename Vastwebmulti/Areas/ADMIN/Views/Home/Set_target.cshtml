<script>
    function changeachive(value) {
        var res = $(value).val();
        if (res == 'Giftitem') {
            $(value).closest('tr').find('td:not(:lt(2))').find('select').css('display', 'block');
            $(value).closest('tr').find('.for-custom-select-icon-other').addClass('custom-district');
            $(value).closest('tr').find('td:not(:lt(2))').find('input').css('display', 'none');
        }
        else {
            $(value).closest('tr').find('td:not(:lt(3))').find('select').css('display', 'none');
            $(value).closest('tr').find('td:not(:lt(3))').find('.for-custom-select-icon-other').removeClass('custom-district');
            $(value).closest('tr').find('td:not(:lt(2))').find('input').css('display', 'block');
        }
    }
</script>
