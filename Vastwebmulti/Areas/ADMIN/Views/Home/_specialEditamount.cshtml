@model Vastwebmulti.Areas.ADMIN.ViewModel.NillPortalViewmodel
<table class="table table-bordered custum-tabel-input" style="width:100%;">
    <thead style="background-color:whitesmoke;">
        <tr>
            <th>Recharge&nbsp;From</th>
            <th>Port&nbsp;No /&nbsp;API</th>
            <th>Operator&nbsp;Name</th>
            <th>Min</th>
            <th>Max</th>
            @*<th>Recharge&nbsp;To</th>*@
            <th>Status</th>
            <th>Edit</th>
            <th>DEL</th>

        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.ShowREchargelist)
        {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.rch_from)</td>
            <td>@Html.DisplayFor(modelItem => item.portno)</td>
            <td>@Html.DisplayFor(modelItem => item.operator_Name) </td>

            @if (item.idno == Model.GetRechargeSpecialGetById.idno)
            {

                <td>
                    <input type="text" id="amount" name="amount" value="@Model.GetRechargeSpecialGetById.amount" />
                </td>
            }
            else
            {
                <td>@Html.DisplayFor(modelItem => item.amount)</td>
            }
            @if (item.idno == Model.GetRechargeSpecialGetById.idno)
            {

                <td>
                    <input type="text" id="maxamount" name="maxamount" value="@Model.GetRechargeSpecialGetById.maxamount" />
                </td>
            }
            else
            {
                <td>@Html.DisplayFor(modelItem => item.maxamount)</td>
            }


            @*<td>@Html.DisplayFor(modelItem => item.rct_to) </td>*@
            <td>
                <div class="onoffswitch">
                    @if (item.sts == "N")
                    {



                        <span class="custom-off" onclick="changebyamount('@item.idno')">off</span>


                    }
                    else
                    {


                        <span class="costom-on" onclick="changebyamount('@item.idno')">on</span>



                    }
                </div>
            </td>
            @if (item.idno == Model.GetRechargeSpecialGetById.idno)
            {
                <td>
                    <button type="button" class="switch-edit-button custom-table-loading" onclick="SaveAmountData(@item.idno)" data-loading-text="<i class='fa fa-spinner fa-spin'></i>">
                        Save
                    </button>
                </td>
            }
            else
            {
                <td>
                    <button type="button" class="switch-edit-button" onclick="EditByamount(@item.idno)">
                        Edit
                    </button>
                </td>
            }

            <td>
                <button id="DeleteBtn" class="confirm" onclick="Deletebyamount('@item.idno')">
                    <img src="~/MainFrontDesign/images/delete.svg" />
                </button>
            </td>
        </tr>
        }
    </tbody>
</table>
<script>
    $('.custom-table-loading').on('click', function () {

        var $this = $(this);
        $this.button('loading');
        setTimeout(function () {
            $this.button('reset');
        }, 200);
    });
</script>