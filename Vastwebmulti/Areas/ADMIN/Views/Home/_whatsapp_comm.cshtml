@model Vastwebmulti.Areas.ADMIN.Models.whatsappslab
@using (Ajax.BeginForm("_whatsapp_comm", "Home", new AjaxOptions { HttpMethod = "POST", OnSuccess = "OnSuccess", UpdateTargetId = "divEditFormComm", LoadingElementId = "div_Loader", InsertionMode = InsertionMode.Replace }))
{
    <input id="btnsubmit" type="submit" value="Save Now" class="btn  waves-effect" style="display:none;" />

    <table id="updatecolm" class="table table-bordered slab-table example-second third-design-table" style="margin-top: 15px;">
        <thead class="navbar" style="position:initial;">
            <tr>
                <th>#</th>
                <th><p>@Model.common[0].T1 &nbsp;Months </p></th>
                <th><p>@Model.common[0].T2 &nbsp;Months</p></th>
                <th><p>@Model.common[0].T3 &nbsp;Months</p></th>
            </tr>
        </thead>
        <tbody id="tbodyshow">
            @*@foreach (var item in Model.common)
        {*@
            <tr>
                <td>All Api Users</td>
                <td>@Model.common[0].P1</td>
                <td>@Model.common[0].P2</td>
                <td>@Model.common[0].P3</td>
            </tr>
            <tr>
                <th>Purchase</th>
                <td>@Model.common[0].PP1</td>
                <td>@Model.common[0].PP2</td>
                <td>@Model.common[0].PP3</td>
            </tr>
            @*}*@
        </tbody>
        <tbody id="tbodyedit" style="display:none;">
            @for (int i = 0; i < Model.common.Count; i++)
            {
                <tr>
                    @Html.HiddenFor(a => a.common[i].idno)
                    <td>
                        All Api Users
                    </td>
                    <td>
                        @Html.EditorFor(a => a.common[i].P1, new { htmlAttributes = new { @style = "width:100%" } })
                        @Html.ValidationMessageFor(a => a.common[i].P1)
                    </td>
                    <td>
                        @Html.EditorFor(a => a.common[i].P2, new { htmlAttributes = new { @style = "width:100%" } })
                        @Html.ValidationMessageFor(a => a.common[i].P2)
                    </td>
                    <td>
                        @Html.EditorFor(a => a.common[i].P3, new { htmlAttributes = new { @style = "width:100%" } })
                        @Html.ValidationMessageFor(a => a.common[i].P3)
                    </td>
                </tr>
            }
            <tr>
                <th>Purchase</th>
                <td>@Model.common[0].PP1</td>
                <td>@Model.common[0].PP2</td>
                <td>@Model.common[0].PP3</td>
            </tr>
        </tbody>
    </table>

}

<script>
    function OnSuccess() {
        $('#btnsubmit').hide();
        $('#btnEdit').show();
    }
</script>

<script>
    $(document).ready(function () {
        $('.second-design .example-second').DataTable({


            paging: false
        });
    });

</script>


<script>
    $('.third-design .third-design-table tbody td').mouseenter(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'var(--main-bg-rcolor)');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#fff');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'var(--main-bg-rcolor)');
    });

    $('.third-design .third-design-table tbody td').mouseleave(function () {
        var colIndex = $(this).parent().children().index($(this)) + 1;
        var rowIndex = $(this).parent().parent().children().index($(this).parent()) + 1;
        $(".third-design-table td:nth-child(" + colIndex + ")").css('background', 'transparent');
        $(".third-design-table td:nth-child(" + colIndex + ")").css('color', '#333');
        $(".third-design-table tbody tr:nth-child(" + rowIndex + ")").css('background', 'transparent');
    });
</script>
