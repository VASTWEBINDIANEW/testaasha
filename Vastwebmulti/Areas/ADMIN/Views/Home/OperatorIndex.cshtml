                    if (opertype == 'Postpaid') {

                          $('#Utilitytableshow').html(data);
                    }
                     if (opertype == 'Finance') {

                          $('#Financetable').html(data);
                    }
                     if (opertype == 'Travel') {

                          $('#Travelstables').html(data);
                    }
                    if (opertype == 'Other') {
            $('#OthersRelatedtable').html(data);
        }


                }
            });
        }
        else if (status == 'Y') {
            if (datetimes == "" || datetimes == null) {

                lbltext.text('Please Select date!')
                //swal("Sorry !", "Pls Select date!", "error");
                return false;
