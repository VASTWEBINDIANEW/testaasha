                    //tblHtml+= "<tr><td>"+b.idno+"</td>";
                    // tblHtml += "<tr><td>" + b.OperatorName + "</td>";
                    tblHtml += "<tr><td>" + b.Amount + "</td>";
                    tblHtml += "<td>" + b.User + "</td>";
                      if (b.status=="Y") {
                            tblHtml += "<td> <div class='onoffswitch'> <span class='costom-on' onclick=BlockAmountStatusUpdate('"+b.idno +"','"+encodeURI(b.OperatorName) +"','Y')>on</span></div></td>";
                      }
                      else if (b.status=="N") {
                     
                            tblHtml += "<td><div class='onoffswitch'><span class='custom-off'  onclick=BlockAmountStatusUpdate('"+b.idno +"','"+encodeURI(b.OperatorName) +"','N')>off</span></div></td>";
