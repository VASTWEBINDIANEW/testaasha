@{
    VastwebmultiEntities DB = new VastwebmultiEntities();
    var color = DB.changecolors.FirstOrDefault(a => a.Role == "ADMIN");
    var col = "";
    if (color != null && color.ToString() != "")
    {
        col = color.multipaloutercolor;
    }
    else
    {
        col = "pink";
    }

    var image = "";
    var backimage = DB.tblWhiteLabelLoginBackImages.FirstOrDefault(p => p.Role == "ADMIN");
    if (backimage != null)
    {
        image = backimage.ImageUrl;
    }
    else
    {
        image = "img24.png";
    }

    var logoimage = "";
    var logo = DB.tblHeaderLogoes.Where(p => p.Role == "ADMIN").ToList();
    if (logo.Count > 0)
    {
        if (logo.SingleOrDefault().Role == "ADMIN")
        {
            logoimage = logo.Where(p => p.Role == "ADMIN").SingleOrDefault().LogoImage;
        }
    }
    else
    {
        logoimage = "";
    }
    var userid = User.Identity.GetUserId();
    var cont = (from nm in DB.dispute_list where nm.sts == "Pending" select nm).Count();
    var complant = (from nm in DB.complaint_request where nm.sts == "Open" select nm).Count();
    var email = DB.Users.Where(a => a.UserId == userid).Single().Email;
    //count purcahseorder request
    var pp = DB.show_purchaserequest_totalcount(userid).SingleOrDefault();
    ViewBag.purchasereq = pp.Totalcount;
    //reneval date
    var shoreneval = DB.showReniwaldaydiff().SingleOrDefault().Daydiff;
    //master Purchase Total Count
    var masteruser = (from m in DB.master_purchase where m.frm == userid && m.sts == "Pending" select m).Count();
    //Distributor Purchase Total Count
    var dealeruser = (from m in DB.dlm_purchage where m.frm == userid && m.sts == "Pending" select m).Count();
    //Retailer Purchase Total Count
    var retaileruser = (from m in DB.rem_purchage where m.frm == userid && m.sts == "Pending" select m).Count();
    //API Purchase Total Count
    var apiuser = (from m in DB.api_purchase where m.frm == userid && m.sts == "Pending" select m).Count();
    //whitelabel  Purchase Total Count
    var whitelabeluser = (from m in DB.Whitelabel_master_purchase where m.frm == userid && m.sts == "Pending" select m).Count();

    var WalletUloadCount = DB.WalletToBankAmountTransferRequests.Count(a => a.Status == "Pending");
    var WalletUloadwhitelableCount = DB.Whitelabel_WalletToBankAmountTransferRequestsToAdmin.Count(a => a.Status == "Pending");
    var WalletUloadVendorCount = DB.VendorWalletToBankAmountTransferRequests.Count(a => a.Status == "Pending");
    var totalholdamount = db2.MicroAtm_Trans_info.Where(x => x.IsHold == true && x.status.ToUpper() == "SUCCESS" && x.transaction_type == "purchase").Sum(aa => aa.amount);

    ViewBag.walletbankreq = WalletUloadCount + WalletUloadwhitelableCount + WalletUloadVendorCount;

    var RetailerBank = DB.UpdateREMAccounts.Count(a => a.Status == "Pending");
    ViewBag.RetailerAddBank = RetailerBank;

    JSONReadWrite readWrite = new JSONReadWrite();
    dynamic people = Newtonsoft.Json.JsonConvert.DeserializeObject(readWrite.Read("LogoBackgroundColor.json", "~/Areas/ADMIN/Models/JsonData/"));
    string logoBgColor = people.ColorCode;
}

