
@using Microsoft.AspNet.Identity
@using Vastwebmulti.Models;
<!DOCTYPE html>
<html>
<head>

    @{
        // Single DB context reused across the entire layout to minimize connections
        VastwebmultiEntities DB1 = new VastwebmultiEntities();
        // Cache Admin_details once; reused throughout layout (avoids repeated queries)
        var adminDetails = DB1.Admin_details.AsNoTracking().FirstOrDefault();
        var comnyname1 = adminDetails != null ? (adminDetails.Companyname ?? "") : "";
        ViewBag.companyname = comnyname1;
    }
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <title>@ViewBag.companyname</title>
    <!-- Favicon (uses DB1 from above block) -->
    @{
        var favimage = "";
        // Reuse DB1 - no new connection needed
        var faviconRec = DB1.tblfavicons.AsNoTracking().FirstOrDefault(p => p.Role == "ADMIN");
        if (faviconRec != null)
        {
            favimage = faviconRec.faviconimage ?? "";
        }
    }
    <link rel="icon" href="@Url.Content("~/" + @favimage)" type="image/x-icon" />
    <!-- Google Fonts (combined into single request) -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,400;0,700;1,400&family=IBM+Plex+Sans+Condensed:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&family=Nunito:ital,wght@0,200;0,300;0,400;0,600;0,700;0,800;0,900;1,200;1,300;1,400;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" type="text/css">
    <!-- Font Awesome (single load) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <!-- Wait Me Css -->
