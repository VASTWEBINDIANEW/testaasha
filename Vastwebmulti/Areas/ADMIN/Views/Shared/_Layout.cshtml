@{
    // Reuse DB1 from head block - no new DB connection needed
    var color = DB1.changecolors.AsNoTracking().FirstOrDefault(a => a.Role == "ADMIN");
    var col = "";
    if (color != null && color.ToString() != "")
    {
        col = color.multipaloutercolor;
    }
    else
    {
        col = "pink";
    }

    var image = "";
    var backimage = DB1.tblWhiteLabelLoginBackImages.AsNoTracking().FirstOrDefault(p => p.Role == "ADMIN");
    if (backimage != null)
    {
        image = backimage.ImageUrl;
    }
    else
    {
        image = "img24.png";
    }

    var logoimage = "";
    var logoRec = DB1.tblHeaderLogoes.AsNoTracking().FirstOrDefault(p => p.Role == "ADMIN");
    if (logoRec != null)
    {
        logoimage = logoRec.LogoImage ?? "images/Default_Logo.png";
    }
    else
    {
        logoimage = "images/Default_Logo.png";
    }
    var userid = User.Identity.GetUserId();
    var cont = DB1.dispute_list.Count(nm => nm.sts == "Pending");
    var complant = DB1.complaint_request.Count(nm => nm.sts == "Open");
    var email = DB1.Users.AsNoTracking().Where(a => a.UserId == userid).Select(a => a.Email).FirstOrDefault();
    //count purcahseorder request
    var pp = DB1.show_purchaserequest_totalcount(userid).SingleOrDefault();
    ViewBag.purchasereq = pp.Totalcount;
    //renewal date - reuse adminDetails cached in block 1 (no extra query)
    var shoreneval = DB1.showReniwaldaydiff().SingleOrDefault().Daydiff;
    var ren_date = adminDetails != null ? adminDetails.RenivalDate.ToString() : DateTime.Now.ToString();
    var renewaldate = DateTime.Parse(ren_date).ToString("dd MMM yyy");
    //ip address - reuse adminDetails cached in block 1
    var websiteurl = adminDetails != null ? (adminDetails.WebsiteUrl ?? "") : "";
    dynamic ipaddress = "Not Found";
    try
    {
        ipaddress = Dns.GetHostAddresses(websiteurl)[0];
    }
    catch
    { }

    //domain date
    var expire = DB1.Domain_Expiration.AsNoTracking().FirstOrDefault();
    string expiredate;

    //master Purchase Total Count
    var masteruser = DB1.master_purchase.Count(m => m.frm == userid && m.sts == "Pending");
    //Distributor Purchase Total Count
    var dealeruser = DB1.dlm_purchage.Count(m => m.frm == userid && m.sts == "Pending");
    //Retailer Purchase Total Count
    var retaileruser = DB1.rem_purchage.Count(m => m.frm == userid && m.sts == "Pending");
    //API Purchase Total Count
    var apiuser = DB1.api_purchase.Count(m => m.frm == userid && m.sts == "Pending");
    //whitelabel  Purchase Total Count
    var whitelabeluser = DB1.Whitelabel_master_purchase.Count(m => m.frm == userid && m.sts == "Pending");

    var WalletUloadCount = DB1.WalletToBankAmountTransferRequests.Count(a => a.Status == "Pending");
    var WalletUloadwhitelableCount = DB1.Whitelabel_WalletToBankAmountTransferRequestsToAdmin.Count(a => a.Status == "Pending");
    var WalletUloadVendorCount = DB1.VendorWalletToBankAmountTransferRequests.Count(a => a.Status == "Pending");
    // Reuse DB1 instead of db2
    var totalholdamount = DB1.MicroAtm_Trans_info.Where(x => x.IsHold == true && x.status.ToUpper() == "SUCCESS" && x.transaction_type == "purchase").Sum(aa => aa.amount);

    ViewBag.walletbankreq = WalletUloadCount + WalletUloadwhitelableCount + WalletUloadVendorCount;

    var RetailerBank = DB1.UpdateREMAccounts.Count(a => a.Status == "Pending");
    ViewBag.RetailerAddBank = RetailerBank;

    var Sellercomm = DB1.operatorcommforsellStatus.Count(a => a.status.ToUpper() == "PENDING");
    ViewBag.Sellercomm = Sellercomm;

    JSONReadWrite readWrite = new JSONReadWrite();
    dynamic people = Newtonsoft.Json.JsonConvert.DeserializeObject(readWrite.Read("LogoBackgroundColor.json", "~/Areas/ADMIN/Models/JsonData/"));
    string logoBgColor = people.ColorCode;
    int rchreportcount = 0;
    try
    {
        rchreportcount = DB1.Recharge_info_Failed_TO_Success_Reports.Count(x => x.ISREAD == false);
    }
    catch { }

    // Total_account() called once; result cached in variable (was calling ch.Single() 8 times)
    var ch = DB1.Total_account().ToList();
    var chResult = ch.Single();
    ViewData["admin"] = chResult.totaladmin;
    ViewData["Dlm"] = chResult.totaldlm;
    ViewData["super"] = chResult.totalsuper;
    ViewData["Rem"] = chResult.totalrem;
    ViewData["API"] = chResult.totalapi;
    ViewData["whitelabel"] = chResult.totalwhitelabel;
    ViewData["posbal"] = chResult.totalposremain;
    ViewData["total"] = chResult.total;
}

