<script>
    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 45 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }
</script>
<!--Calendar Javascript-->
<script>
    function OnSuccess(data) {
        //alert("success");
        $("#guestDescription").html(data);
        $("#guestDetailsModal").modal('show');
    }
    function OnFailed() {
        swal("Oops!", "Failed to fatch data.", "error");
    }
    function OnSuccessPrice(data) {
        //alert("success");
        $("#priceDescription").html(data);
        $("#guestPriceModal").modal('show');
    }
    function OnFailedPrice() {
        swal("Oops!", "Failed to fatch data.", "error");
    }
    function OnSuccessStatus(data)
    {
        var respo = JSON.parse(data);
        if(respo.Status == "Success")
        {
            swal("Wow!", respo.Message, "success");
        } else {
            swal("Oops!", respo.Message, "error");
        }
    }
    function OnFailedStatus(data) {
        swal("Oops!", "Failed to fatch data.", "error");
    }
    $(function () {

            var sts = '@TempData["Status"]';
        var msg = '@TempData["Message"]';
        if (sts != null && sts != '')
        {
            if(sts == "Success")
            {
                swal("Wow!", msg, "success");
            } else {
                swal("Oops!", msg, "error");
            }
        }
        $('.input-daterange').datepicker({
            format: "yyyy-mm-dd",
            todayHighlight: true,
            autoclose: true,
            orientation: "bottom auto",

        });
        var val = '@ViewBag.chk';
        if (val != "post") {
            $("#txt_frm_date").datepicker("setDate", new Date());
            $("#txt_to_date").datepicker("setDate", new Date());
        }
        answers();

    });
</script>
