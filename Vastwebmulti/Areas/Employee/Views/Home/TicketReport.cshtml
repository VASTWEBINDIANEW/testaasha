                    { "pageindex": pageindex, txt_frm_date: $('#txt_frm_date').val(), txt_to_date: $('#txt_to_date').val(), PNR: PNR, ddl_status: ddl_status, ddlusers: ddlusers, allmaster: allmaster1, alldealer: alldealer, allretailer: allretailer, allwhitelabel: Whitelabel },
