        var date = new Date(str),
            mnth = ("0" + (date.getMonth() + 1)).slice(-2),
            day = ("0" + date.getDate()).slice(-2),
            Hrs = (date.getHours()),
            mnts = (date.getMinutes()),
            sec = (date.getSeconds());
        return dd = [day, mnth, date.getFullYear()].join("-") + " " + [Hrs + ":" + mnts + ":" + sec];
    }

