<script>
        var pageindex = 2;
        var NoMoredata = false;
        var inProgress = false;
    $(window).scroll(function () {

            var ddlusers = $('#ddlusers').val();
        var allmaster = $('#allmaster2').val(); allwhitelabel1
        var allwhitelabel = $('#allwhitelabel1').val();
            var alldealer = $('#alldealer').val();
            var allretailer = $('#allretailer').val();
            var ddl_status = $('#ddl_status').val();
            var txt_frm_date = $('#txt_frm_date').val();
            var txt_to_date = $('#txt_to_date').val();
        if ($(window).scrollTop() > Number($("#mpos").height()) / 4 && !NoMoredata && !inProgress) {
                inProgress = true;
                $("#loadingdiv").show();
                $.post("@Url.Action("InfiniteScroll_mpos", "Home")",
                    { "pageindex": pageindex, "ddlusers": ddlusers, "allmaster2": allmaster, "allwhitelabel1": allwhitelabel, "alldealer": alldealer, "allretailer": allretailer,"ddl_status":ddl_status, "txt_frm_date": txt_frm_date, "txt_to_date": txt_to_date },
                    function (data) {
                        pageindex = pageindex + 1;
                        NoMoredata = data.NoMoredata;
                        $("#loadingdiv").load("content.html");
                        $("#trow").append(data.HTMLString);
                        $("#loadingdiv").hide();
                        inProgress = false;
                    });
            }
        });


</script>


