                            @Html.Partial("~/Areas/ADMIN/Views/Air/_travelReportMenu.cshtml")
                        </div>
                    </div>
                    <div class="col-md-2 tre2 up-third-design airtab-respon-third" style="padding: 0;">
                        @Html.Partial("HotelpartialView")
                    </div>
                    <div class="col-md-6 tre3 all-type-third tickt-third-responsive" style="padding: 0;">

                        @using (Html.BeginForm("CancellationQueue", "Hotel", FormMethod.Post))
                        {



                            <div class="col-md-2 mrj jkjk responcive-fifty">
                                <div class="" style="">
                                    @Html.DropDownList("ddlusers", new List<SelectListItem>
                              {
                           new SelectListItem{ Text="Admin",Value="Admin"},
                           new SelectListItem{Text="Master",Value="Master"},
                           new SelectListItem{Text="Distributor",Value="Dealer"},
                           new SelectListItem{Text="Retailer",Value="Retailer"},
                           //new SelectListItem{Text="Api User",Value="APIID"},
                            new SelectListItem{Text="Whitelabel",Value="Whitelabel"}
                          }, new { @class = "for-select2 form-control", data_live_search = "true", @style = "margin-top:0px; padding:0px;;", @onchange = "answers()" })

                                </div>
                            </div>

                            <div class="col-md-2 mrj dip jkjk responcive-fifty" style="display:none;" id="allwhitelabel">
                                <div class="form-line">
                                    @Html.DropDownList("allwhitelabel", ViewBag.allwhitelabel as SelectList, "All Whitelabel", new { @style = "margin-top:0px", @class = "for-select2 form-control", data_live_search = "true", })
                                </div>
                            </div>
                            <div class="col-md-2 mrj  dip jkjk responcive-fifty" style="display:none;" id="allmaster">
                                <div class="form-line">
                                    @Html.DropDownList("allmaster", ViewBag.allmaster as SelectList, "All Master", new { @style = "margin-top:0px", @class = "for-select2  form-control", data_live_search = "true", })
                                </div>
                            </div>

                            <div class="col-md-2 mrj  dip jkjk responcive-fifty" style="display:none;" id="dlm">
                                <div class="form-line">
                                    @Html.DropDownList("alldealer", ViewBag.alldealer as SelectList, " All Distubutor", new { id = "alldealer", @class = "for-select2 form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                </div>
                            </div>
                            <div class="col-md-2 mrj  dip jkjk responcive-fifty" style="display:none;" id="rem">
                                <div class="form-line">
                                    @Html.DropDownList("allretailer", ViewBag.allretailer as SelectList, "All Retailer", new { id = "allretailer", @class = "for-select2 form-control", data_live_search = "true", @style = "margin-top:0px; padding-left:0px; padding-right:0px;text-align:center;" })
                                </div>
                            </div>
                            <div class="col-md-2 mrj jkjk responcive-fifty" id="sts">
                                <div class="">
                                    @Html.DropDownList("ddl_status", new List<SelectListItem>
                                    {
                                    new SelectListItem{ Text="Status",Value="",},
                                    new SelectListItem{Text="Success",Value="Confirmed"},
                                    new SelectListItem{Text="Pending",Value="Proccessed"},
                                    new SelectListItem{Text="Failed",Value="Failed"}
                                    }, new { @class = "for-select2 form-control", data_live_search = "true", @style = "margin-top:0px; padding:0px;text-align:center;" })
                                </div>
                            </div>



                            <div class="col-md-2 mrj responcive-fifty" style="width: 100px;">
                                <div class="inp">
                                    @Html.TextBox("BookingId", "", new { placeholder = "TXN/REF NO", autocomplete = "off", @style = "height:32px;border:1px solid #dddddd;padding:5px;" })
                                </div>
                            </div>

                            <div class="col-md-5 mrj responcive-full" style="width: auto;">
                                <div class="form-group jjp">
                                    <div class="input-daterange input-group">
                                        <div class="custom-date-icon ner">
                                            <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i>
                                        </div>
                                        @Html.TextBox("txt_frm_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd; height:32px;", autocomplete = "off" })
                                        <div class="nrr3">
                                            <div class="custom-date-icon ner">
                                                <i class="fa fa-calendar tmw-total-color-one fullbodydycolorbg"></i>
                                            </div>
                                            @Html.TextBox("txt_to_date", "", new { @class = "form-control", required = "required", style = "border:1px solid #dddddd;height:32px;", autocomplete = "off" })
                                        </div>
                                    </div>
                                    <!-- /.input group -->
                                </div>
                                <div class="mrj responcive-fifty" style="margin-right: 0px;">
                                    <button type="submit" name="submit" class="btn input-back-second" style=" height:32px;border:1px solid #c7c2c2;background:transparent;">
                                        <i class="fa fa-search" style="top:-1px;font-size:16px;color:black;"></i>
                                        <span style="top:-2px;color:black;">Search</span>
                                    </button>
                                </div>
                            </div>






                        }

