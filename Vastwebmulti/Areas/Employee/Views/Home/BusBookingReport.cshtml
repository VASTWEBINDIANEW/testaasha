<script>
    function CancelBooking(id,bid,tcno)
    {

         swal({
                   title: 'Are you sure?',
                   //text: 'Total Fare : ' + totalTicketFare + '\nCancellation Charges :' + cancellationCharges + '\nRefund Amount :  ' + totalRefundAmount + '\n\nNote: You will not be able to recover this again!',
                   text: 'Once cancelled, You will not be able to recover this again!',
                   type: 'warning',
                   showCancelButton: true,
                   confirmButtonColor: '#dd6b55',
                   cancelButtonColor: '#999',
                   confirmButtonText: 'Yes!',
                   cancelButtonText: 'No',
                   closeOnConfirm: false
               }, function (data) {
             if(data == true)
             {
                 CancelBookingConfirm(id,bid,tcno);
             }
         })

    }
    function CancelBookingConfirm(id, bid, tcno) {
        try{
            $("#BusLoader").show();
            var url = '@Url.Action("seatCancellationConfirm", "Bus")'
            var jqxhr = $.post(url, { TraceId: id, BusId: bid, Ticketno: tcno }, function (data) {
                $("#BusLoader").hide();
                var response = JSON.parse(data);
                if (response.Status == "Success") {
                    console.log(response.Message);
                    if (response.Message.Content.Addinfo.Error.ErrorCode == 0) {

                        //var totalTicketFare = response.Message.totalTicketFare;
                        //var totalRefundAmount = response.Message.totalRefundAmount;
                        //var cancellationCharges = response.Message.cancellationCharges;
                        //console.log(totalTicketFare);
                        //console.log(totalRefundAmount);
                        //console.log(cancellationCharges);
                        swal("Wow!!!", "Ticket cancellation proceeded successfully", "success");
                        setTimeout(function () {
                            location.reload();
                        }, 5000);

                    } else {
                        swal("Oops!!!", response.Message.Content.Addinfo.Error.ErrorMessage, "error");
                    }
                    //swal("Wow!", response.Message, "success");
                }
                else {
                    swal("Oops!!!", response.Message, "error");
                }
            })
           .fail(function (jqXHR, textStatus, errorThrown) {
               $("#BusLoader").hide();
               swal("Oops!!!", jqXHR.responseText, "error");
           })
        } catch (err) {
            $("#BusLoader").hide();
            console.log('Error : ' +err.message)
        }
    }
</script>

<script type="text/javascript">
    function answers() {
        var e = document.getElementById("ddlusers");
        var answer = e.options[e.selectedIndex].value;
        if (answer == "Dealer") {
            document.getElementById("allmaster").style.display = "none";
            document.getElementById("allwhitelabel").style.display = "none";
            document.getElementById("dlm").style.display = "block";
            document.getElementById("rem").style.display = "none";
            //document.getElementById("apiid").style.display = "none";
        }
        else if (answer == "Whitelabel") {
            document.getElementById("allmaster").style.display = "none";
            document.getElementById("allwhitelabel").style.display = "block";
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "none";
            //document.getElementById("apiid").style.display = "none";
        }
        else if (answer == "Master") {
            document.getElementById("allmaster").style.display = "block";
            document.getElementById("allwhitelabel").style.display = "none";
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "none";
            //document.getElementById("apiid").style.display = "none";
        }
        else if (answer == "Admin") {
            document.getElementById("allwhitelabel").style.display = "none";
            document.getElementById("allmaster").style.display = "none";
            //document.getElementById("apiid").style.display = "none";
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "none";
        }
        else if (answer == "Retailer") {
            document.getElementById("allwhitelabel").style.display = "none";
            document.getElementById("allmaster").style.display = "none";
            document.getElementById("dlm").style.display = "none";
            document.getElementById("rem").style.display = "block";
            // document.getElementById("apiid").style.display = "none";
        }
        //else if (answer == "APIID") {
        //    document.getElementById("allwhitelabel").style.display = "none";
        //    document.getElementById("allmaster").style.display = "none";
        //    document.getElementById("apiid").style.display = "block";
        //    document.getElementById("dlm").style.display = "none";
        //    document.getElementById("rem").style.display = "none";
        //      }
    }
</script>


