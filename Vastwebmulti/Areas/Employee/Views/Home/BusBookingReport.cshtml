<script>
    function BookingDetails(id) {
        $("#BusLoader").show();
        var url = '@Url.Action("getBookingDetails", "Home")'
        var jqxhr = $.post(url, { TraceId: id }, function (data) {
            console.log(data);
            var response = JSON.parse(data);
            if (response.Status == "Success") {
                $("#BusLoader").hide();
                console.log(response.Message);
                //console.log(response.Message.apiStatus);
                if (response.Message.Error.ErrorCode == 0)
                {
                    $("#spanSourceCityName").html(response.Message.Itinerary.Origin);

                    $("#spanDepartureDateTime").html(response.Message.Itinerary.DepartureTime + "," + response.Message.Itinerary.DateOfJourney);
                    $("#spanDestinationCityName").html(response.Message.Itinerary.Destination);
                    $("#spanArrivalDateTime").html(response.Message.Itinerary.ArrivalTime);
                    $("#spanBoardingPoint").html(response.Message.Itinerary.BoardingPointdetails.CityPointName);
                    $("#spanBoardingcontantno").html(response.Message.Itinerary.BoardingPointdetails.CityPointContactNumber);
                    $("#spanDroppingPoint").html(response.Message.Itinerary.BoardingPointdetails.CityPointLandmark);
                    $("#spanBusOptName").html(response.Message.Itinerary.TravelName);
                    $("#spanTicketNum").html(response.Message.Itinerary.TicketNo);
                    $("#spanPNR").html(response.Message.Itinerary.TravelOperatorPNR);
                    $("#spanBaseFare").html(response.Message.Itinerary.Price.BasePrice);
                    $("#spanTaxAmount").html(parseInt(response.Message.Itinerary.Price.OtherCharges + response.Message.Itinerary.Price.Tax));
                    $("#spanTotalFareWithTax").html(response.Message.Itinerary.Price.PublishedPriceRoundedOff);
                    var tabRow = '';
                    var PaxCount = 1;
                    response.Message.Itinerary.Passenger.forEach(function (entry) {
                        var Paxgender;
                        if (entry.Gender == "1")
                        {
                            Paxgender = "Male";
                        } else {
                            Paxgender = "Female";
                        }
                        tabRow = tabRow + '<tr><th scope="row">' + PaxCount + '</th><td>' + entry.FirstName + ' ' + entry.LastName + '</td><td>' + entry.Seat.SeatName + '</td><td>'+ Paxgender +'</td></tr>';
                        PaxCount = PaxCount + 1;
                        console.log(entry);
                    });
                    $("#travellerDetails").html(tabRow);
                    $("#BookingDetailsModel").modal('show');
                } else {
                    swal("Oops!!!", response.Message.Error.ErrorMessage, "error");
                }
                //swal("Wow!", response.Message, "success");
            }
            else {
                $("#BusLoader").hide();
                swal("Oops!!!", response.Message, "error");
            }
        })
       .fail(function (jqXHR, textStatus, errorThrown) {
           $("#BusLoader").hide();
           swal("Oops!!!", jqXHR.responseText, "error");
       })
    }
</script>
