           success: function (result) {

             if (tabID === 'menu1') {
                 $('#masterdrop').hide();
                 $('#dealerdrop').show();
                 $('#retailerdrop').hide();

                   var s = '<option value="">Please Select a Distributor</option>';
               for (var i = 0; i < result.length; i++) {
                   s += '<option value="' + result[i].Value + '">' + result[i].Text + '</option>';
               }

               $("#ddlDistributor1").html(s);
           // $("#" + tabID).html(result);
