<script>
    function chkmasterbalance(value) {
        $('.old-cr').empty();
        $('.dlmremainbalance').empty();
        $("input:text").val("");
        var mid = $('#MastersID').val();
            $.ajax({
                    type: 'Post',
                url: "@Url.Action("MToDLM_Creditchk", "Home")",
                data: { MID:mid,dlmid: $(value).val() },
                dataType: 'json',
                cache: false,
                async: false,
                success: function (data) {

                    if (data.currntcr > 0) {
                        $('.old-cr').html('CR. ' + data.currntcr)

                        $("#idst option[value*='6']").prop('disabled', true);

                    }
                    else {



                        $("#idst option[value*='6']").prop('disabled', false);
                       $('.old-cr').html('C.R. 0')

                    }
                    $('.dlmremainbalance').html('CB. ' + data.rembal)
                }
            });
    }

    function chkDealerbalance(value) {
          $("input:text").val("");
            var dlmid = $('#DDDealerid').val();
            $.ajax({
                    type: 'Post',
                url: "@Url.Action("DLMTORLM_Creditchk", "Home")",
                 data: { retailerid:$(value).val(),dlmid:dlmid  },
                dataType: 'json',
                cache: false,
                async: false,
                success: function (data) {

                    if (data.currntcr > 0) {
                        $('.old-crd').html('CR. ' + data.currntcr)
                       $("#ddldealerPaymentMode option[value*='5']").prop('disabled', true);
                        $("#ddldealerPaymentMode option[value*='6']").prop('disabled', true);

                    }
                    else {


                         $("#ddldealerPaymentMode option[value*='5']").prop('disabled', false);
                        $("#ddldealerPaymentMode option[value*='6']").prop('disabled', false);

                        $('.old-crd').html('<b>C.R. 0/b>')

                    }
                    $('.dlmtoremremainbalance').html('CB. ' + data.rembal)
                }
            });
    }


</script>

