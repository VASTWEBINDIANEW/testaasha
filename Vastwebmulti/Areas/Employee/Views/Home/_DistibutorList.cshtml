<script>


    function Approved(val) {
         var DealerId = $('#DealerId').val();
         $.ajax({
            url: '@Url.Action("Approveddealersts","Home")',
            type: 'POST',
            data: { val: val,DealerId:DealerId },
             cache: false,
             success: function (response) {
                 if (response==='pan') {
                     $('#panapproved').hide();


                 }
                 else if (response === 'aadhar') {
                     $('#aadharapproved').hide();

                 }
                 else if (response === 'gst') {
                     $('#gstapproved').hide();

                 }
                 else if (response==='Aggrement') {
                     $('#frmagrapproved').hide();

                 }
                  if ($('#panapproved').css('display') == 'none' && $('#aadharapproved').css('display') == 'none' ) {
                      $('#frmagrEdit').val('Aggrement Status Pending');


                      $('#frmagrapproved').hide();

                 }

               // $('#Masterlistupdate').html(response);
                  //  $(".modal-backdrop").hide();
          }
        });
    }
     function Rejected(val) {
        var DealerId = $('#DealerId').val();
         $.ajax({
            url: '@Url.Action("Rejecteddealersts","Home")',
            type: 'POST',
            data: { val: val,DealerId:DealerId },
             cache: false,
            success: function (response) {
              //  $('#Masterlistupdate').html(response);
              //  $(".modal-backdrop").hide();

                if (response === 'pan') {
                   $("#pandocnotshow").show();
                    $("#pandocshow").hide();

                    $('#frmagrdocshow').hide();
                    $("#frmagrdocnotshow").show();
                      $('#frmagrEdit').val('KYC Due');

                 }
                 else if (response === 'aadhar') {
                    $("#aadhardocnotshow").show();
                    $("#aadhardocshow").hide();

                    $('#frmagrdocshow').hide();
                    $("#frmagrdocnotshow").show();
                      $('#frmagrEdit').val('KYC Due');
                 }
                 else if (response === 'gst') {
                     $("#gstdocnotshow").show();
                    $("#gstdocshow").hide();
                 }
                 else if (response === 'Aggrement') {
                    $("#frmagrdocnotshow").show();
                    $('#frmagrdocshow').hide();
                     if ($('#pandocnotshow').css('display') == 'block' || $('#aadhardocnotshow').css('display') == 'block') {
                    $('#frmagrdocshow').hide();
                     $("#frmagrdocnotshow").show();
                    $('#frmagrEdit').val('KYC Due');
                   // $('#frmagrEdit').val('Aggrement Status Pending');
                    //if ($('#frmagrapproved').css('display') == 'none') {
                    //    $('#frmagrEdit').val('Aggrement Status Pending');

                    //    $('#alinks').empty();
                    //}
                    //else {
                    //    $('#Edittxtlrole').hide();
                    //    ravi("#DivEditddlrole").show();
                    //    $('#frmagrdocshow').hide();
                    //    $('#frmagrapproved').hide();
                    //    $("#frmagrdocnotshow").show();
                    //    $('#frmagrEdit').val('KYC Due');
                    //    //  $('#frmagrEdit').val('Aggrement Status Pending');
                    //}



                }
                else {
                     $('#frmagrapproved').hide();
                        $("#frmagrdocnotshow").show();
                    $('#frmagrEdit').val('Aggrement Status Pending');
                    $('#alinks').empty();
                }

                }
          }
        });
    }
