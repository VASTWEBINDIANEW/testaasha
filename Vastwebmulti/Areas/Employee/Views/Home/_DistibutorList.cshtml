<style type="text/css">

    @@keyframes ldio-zdyd6mf6t5 {
        0% {
            top: 96px;
            left: 96px;
            width: 0;
            height: 0;
            opacity: 1;
        }

        100% {
            top: 18px;
            left: 18px;
            width: 156px;
            height: 156px;
            opacity: 0;
        }
    }

    #defaultModal222 input:placeholder-shown {
        border-color: red !important;
    }

    .ldio-zdyd6mf6t5 div {
        position: absolute;
        border-width: 4px;
        border-style: solid;
        opacity: 1;
        border-radius: 50%;
        animation: ldio-zdyd6mf6t5 1s cubic-bezier(0,0.2,0.8,1) infinite;
    }

        .ldio-zdyd6mf6t5 div:nth-child(1) {
            border-color: var(--main-bg-lcolor);
        }

        .ldio-zdyd6mf6t5 div:nth-child(2) {
            border-color: #c7c7c7;
            animation-delay: -0.5s;
        }

    .loadingio-spinner-ripple-92ar2pfqk5j {
        width: 200px;
        height: 200px;
        display: inline-block;
        overflow: hidden;
        background: #ffffff;
    }

    #distributorlist table tr td:nth-child(5) button {
        padding: 4px 7px;
    }

    .ldio-zdyd6mf6t5 {
        width: 100%;
        height: 100%;
        position: relative;
        transform: translateZ(0) scale(1);
        backface-visibility: hidden;
        transform-origin: 0 0;
    }

        .ldio-zdyd6mf6t5 div {
            box-sizing: content-box;
        }

    .table-bordered tbody tr td, .table-bordered tbody tr th {
        padding: 10px;
    }

    .mastetr222Modal .modal-dialog {
        margin: 0px;
    }

    .costom-on {
        text-align: end;
        float: left;
        width: 100%;
        padding: 2px 4px;
        background: #f0f0f0;
        padding-top: 3px;
        color: #999;
        vertical-align: text-bottom;
        padding-top: 6px;
    }

        .costom-on::after {
            float: left;
            margin-right: 9.5rem;
        }

    .onoffswitch {
        width: 27%;
        height: 32px;
        margin-left: 5px;
    }


    .costom-on::after {
        width: 20px;
        height: 20px;
        top: 5px;
    }

    .custom-off::before {
        width: 20px;
        height: 20px;
        top: 5px;
    }
</style>
<div class="table-responsive">
    <table class="table table-bordered table-due-second table-due-second-desti third-design-table" id="mdList">
        <thead>
            <tr>
                <th>Sr</th>
                <th>Master&nbsp;Distributor&nbsp;Firm</th>
                <th>Distributor&nbsp;Firm</th>
                <th>Distributor&nbsp;Name</th>
                <th>Mobile&nbsp;No</th>
                <th>Balance</th>
                @*   <th>Aadhar&nbsp;No</th>*@
                @*<th>PAN&nbsp;No</th>*@
                <th>KYC</th>
                <th>Email&nbsp;V/F</th>

            </tr>
        </thead>
        <tbody id="body">
            @if (Model.Select_dealer_list != null)
            {
                int i = 0;
                var id = 1;
                foreach (var item in Model.Select_dealer_list)
                {
                    var idno = "subTbl";
                    idno = idno + i;

                    var idshow = "subTblshow";
                    idshow = idshow + i;

                    var idhide = "subTblhide";
                    idhide = idhide + i;

                    var colorchange = "";
                    var borderleft = "";
                    var imggg = "";

                    if (item.aadharcardPath != null && item.BackSideAadharcardphoto != null && item.pancardPath != null)
                    {
                        if (item.PSAStatus == "N" && item.AadhaarStatus == "N")
                        {
                            colorchange = "#dbdb70";
                            borderleft = "7px solid var(--main-bg-lcolor)";
                            imggg = "☻";

                        }

                    }
                    <tr class="tr" style="background-color:@colorchange">
                        <td>@id</td>
                        <td>@item.MasterEmail</td>
                        <td style="border-left:@borderleft">
                            <span id="@idshow" onclick="md_dlm_List('@item.DealerId', '@i')">
                                <i class="fa fa-caret-down" aria-hidden="true"></i>&nbsp;&nbsp;
                                @item.FarmName
                            </span>
                            <span id="@idhide" style="display:none;" onclick="md_dlm_Listhide('@i')">
                                <i class="fa fa-caret-up" aria-hidden="true"></i>&nbsp;&nbsp;
                                @item.FarmName
                            </span>
                        </td>
                        <td><span style="font-size:20px;width: 16px;display: inline-block;color: var(--main-bg-lcolor);">@imggg</span>&nbsp;@item.DealerName</td>
                        <td>@item.Mobile</td>
                        <td>@item.remaindlm</td>
                        @*  <td>@item.adharcard</td>*@
                        @* <td> @item.pancard</td>*@
                        <td class="kyc-button">
                            @if (item.PSAStatus == "Y" && item.AadhaarStatus == "Y" && item.pancardsts == "Y")
                            {
                                <button class="btn done-third">Done</button>
                            }
                            else
                            {
                                <div class="btn" style="background:var(--main-bg-lcolor);height: 25px;color:#fff; padding: 4px 10px;float:left; font-size: 11px;">Due</div>
                            }
                            @*<button class="btn" style="background:yellow;"><img src="~/images/reportimage/wall-clock.svg" /></button>
                                <button class="btn btn-danger"><img src="~/images/reportimage/close.svg" /></button>
                                <button class="btn btn-success"><img src="~/images/reportimage/check.svg" /></button>*@



                            @*@item.adharcard*@
                        </td>
                        <td data-toggle="modal" data-target="#defaultModal222" onclick="mdActionBtn('@item.DealerId')">
                            @if (item.Emailconfirmed == true)
                            {
                                <button class="btn due-done-second done-third" style="border:1px solid #bbb;font-size: 11px;padding: 4px 7px;height: 25px;border: 1px solid #bbb;">Done</button>
                            }
                            else
                            {
                                <div class="btn" style="background:var(--main-bg-lcolor);height: 25px;color:#fff; padding: 4px 10px;float:left; font-size: 11px;">Due</div>
                            }
                            <img class="email-popup-second" src="~/ashok-images/rightaeps.svg" style="width: 11px;margin-top: 6px;float: right;" />
                        </td>

                    </tr>

                    <tr id="@i" style="display:none;background-color: #fff;">
                        <td colspan="8" style="padding:0px;">
                            <div id="@idno">
                                @*@Html.Partial("_SelectRID")*@
                            </div>
                        </td>
                    </tr>

                    i++;
                    id++;
                }

            }
        </tbody>
    </table>
</div>



