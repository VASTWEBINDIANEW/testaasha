@model Vastwebmulti.Areas.ADMIN.Models.MasterDistributerModel
@{
    ViewBag.Title = "Master_list";
    Layout = "~/Areas/Employee/Views/Shared/_Layout.cshtml";
}

@using Vastwebmulti.Models;
@using Microsoft.AspNet.Identity
@{
    Layout = "~/Areas/Employee/Views/Shared/_Layout.cshtml";
    VastwebmultiEntities DB1 = new VastwebmultiEntities();
    var currentuser = User.Identity.GetUserId();
    var iswritepermision = DB1.tbl_permission_Services.Where(x => x.Employee_ID == currentuser && x.Servicename == "USERS" && x.iswrite == true).Any();

}
@if (iswritepermision)
{
    <input type="submit" value="Add New API User" />
}
