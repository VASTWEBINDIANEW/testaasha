@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Areas/Employee/Views/Shared/_Layout.cshtml";
}

<style type="text/css">
    @@keyframes ldio-zdyd6mf6t5 {
        0% {
            top: 96px;
            left: 96px;
            width: 0;
            height: 0;
            opacity: 1;
        }

        100% {
            top: 18px;
            left: 18px;
            width: 156px;
            height: 156px;
            opacity: 0;
        }
    }

    .ldio-zdyd6mf6t5 div {
        position: absolute;
        border-width: 4px;
        border-style: solid;
        opacity: 1;
        border-radius: 50%;
        animation: ldio-zdyd6mf6t5 1s cubic-bezier(0,0.2,0.8,1) infinite;
    }

        .ldio-zdyd6mf6t5 div:nth-child(1) {
            border-color: #e90c59
        }

        .ldio-zdyd6mf6t5 div:nth-child(2) {
            border-color: #46dff0;
            animation-delay: -0.5s;
        }

    .loadingio-spinner-ripple-92ar2pfqk5j {
        width: 200px;
        height: 200px;
        display: inline-block;
        overflow: hidden;
        background: transparent;
    }

    .ldio-zdyd6mf6t5 {
        width: 100%;
        height: 100%;
        position: relative;
        transform: translateZ(0) scale(1);
        backface-visibility: hidden;
        transform-origin: 0 0; /* see note above */
    }

        .ldio-zdyd6mf6t5 div {
            box-sizing: content-box;
        }
</style>
<style>
    .tmw-dashaboard .card .table.dash-table tbody tr td {
        padding: 10px 5px;
    }

    .table.dash-table tbody tr {
        height: 51px;
    }

    .nav-tabs > li {
        margin-bottom: 0px;
    }

    .info-box-4 {
        height: 46px;
    }

        .info-box-4 .content .text {
            margin-top: 0px;
        }

    .nav-tabs + .tab-content {
        padding: 0px 0;
    }

    .table tbody tr td, .table tbody tr th {
        /*padding:5px;*/
        border-top: none;
    }

    .table {
        margin-bottom: 16px;
    }

    .dash-table thead {
        background: var(--second-bg-color);
    }

    .dash-table tbody {
        background: var(--second-bg-color);
    }

    .second-design #loader {
        right: 37% !important;
    }

    .third-design #loader {
        right: 37% !important;
    }

    @@media only screen and (max-width:992px) {
        .dash-board-top .col-lg-2 {
            width: 24.28%;
        }

            .dash-board-top .col-lg-2:first-child {
                padding-left: 10px;
            }
    }

    @@media only screen and (max-width:480px) {
        .dash-board-top .col-lg-2 {
            width: 49.28%;
        }
    }
</style>
<section class="content tmw-dashaboard">
    <div class="container-fluid">

    </div>
</section>
