@model Vastwebmulti.Areas.ADMIN.Models.MasterDistributerModel
<div class="table-responsive">
    <table class="table table-bordered" style="background: #f5f5f5;margin:0px;border:5px solid #e4e4e4;">
        <thead>
            <tr>
                <th>Retailer&nbsp;Firm</th>
                <th>Retailer&nbsp;Name</th>
                <th>Mobile&nbsp;No</th>
                <th>PAN&nbsp;No</th>
                <th>KYC</th>
               
                <th>&#174;-Bal</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Select_Retailer_list != null)
            {
                foreach (var item in Model.Select_Retailer_list)
                {

                    <tr>
                        <td>
                            <i class="" aria-hidden="true"></i>
                            @item.Frm_Name
                        </td>
                        <td>@item.RetailerName</td>
                        <td>@item.Mobile</td>
                        <td>@item.PanCard</td>
                        <td class="kyc-button">
                            @if (item.PSAStatus == "Y" && item.AadhaarStatus == "Y")
                            {
                                <button class="btn " style="border:1px solid #bbb;font-size: 11px !important;padding: 2px 10px;height: 25px;border: 1px solid #bbb;">Done</button>
                            }
                            else
                            {
                                <div class="btn" style="background:var(--main-bg-lcolor);height: 25px;color:#fff; padding: 4px 10px;float:left; font-size: 11px;">Due</div>
                            }
                            @*<button class="btn" style="background:yellow;"><img src="~/images/reportimage/wall-clock.svg" /></button>*@
                        </td>
                        <td>
                            @item.Remainamount
                            @*@if (item.Status == "Y")
                                {
                                    <center>
                                        <a href="@Url.Action("dealer_sts_update",new { id = item.DealerId })" style="text-decoration:none;border:1px solid #c7c2c2;padding:2px 0px 2px 4px;">
                                            <i class="fa fa-thumbs-o-up" style="margin-top:12px;">&nbsp;<span>I'm&nbsp;Active&nbsp;</span></i>
                                        </a>
                                    </center>
                                }
                                else
                                {
                                    <center>
                                        <a href="@Url.Action("dealer_sts_update",new { id = item.DealerId  })" style="text-decoration:none;border:1px solid #c7c2c2;padding:2px 11px 2px 11px;">
                                            <i class="fa fa-thumbs-o-down" style="color:red;margin-top:12px;">&nbsp;<span>Inactive</span></i>
                                        </a>
                                    </center>

                                }*@
                        </td>
                       

                    </tr>
                }
            }
        </tbody>
    </table>
</div>
