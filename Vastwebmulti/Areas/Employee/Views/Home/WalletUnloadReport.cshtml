                    <div class="row clearfix">
                        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                            <div class="">
                                <div class="body table-responsive tableseconddes-admin status-img-allclass" style="position:inherit;padding:3px;">
                                    <table class="table table-bordered table-striped table-hover example-second table-background-second third-design-table" cellspacing="0" style="width:100%;font-size:12px;background:#f9f9f9;">
                                        <thead class="navbar" style="color:#000; position:inherit;">
                                            <tr>

                                                <th>SR. NO.</th>
                                                <th>Status</th>
                                                <th>Role</th>
                                                <th>Firm Name</th>

                                                <th>Transfer Type</th>
                                                <th>Bank Name</th>
                                                <th>Remain Pre</th>
                                                <th>Amount</th>
                                                <th>Charge</th>
                                                <th>Remain Post</th>
                                                <th>Request Time</th>
                                                <th>Response Time</th>
                                                <th>Bank RRN</th>
                                            </tr>
                                        </thead>
                                        <tbody id="throwssss">
                                            @if (Model != null)
                                            {

                                                foreach (var item in Model)
                                                {
                                                    var img = "";
                                                    var color = "";

                                                    if (item.Status.ToUpper() == "SUCCESS")
                                                    {
                                                        color = "green";
                                                        img = "../../ashok-images/correct.svg";
                                                    }
                                                    if (item.Status.ToUpper() == "PENDING")
                                                    {
                                                        color = "#FF9800";
                                                        img = "../../ashok-images/clkk.png";
                                                    }
                                                    if (item.Status.ToUpper() == "REJECTED")
                                                    {
                                                        color = "red";
                                                        img = "../../ashok-images/closes.svg";
                                                    }
                                                    else
                                                    {
                                                        img = "../../ashok-images/backresnd.svg";
                                                        color = "brown";
                                                    }


                                                    <tr>
                                                        <td><img src="@img" style="background:@color;" />@item.Status</td>
                                                        <td>@item.RoleName</td>
                                                        <td>@item.FirmName</td>

                                                        <td>@item.TransferType</td>
                                                        <td>@item.BankName</td>
                                                        <td>@item.Rempre</td>
                                                        <td>@item.Amount</td>
                                                        <td>@item.ProcessingCharge</td>
                                                        <td>@item.RemPost</td>
                                                        <td>@item.RequestDate</td>
                                                        <td>@item.ResponseDate</td>
                                                        <td>@item.BankRRN</td>

                                                    </tr>
                                                }
                                            }

                                            <tr>
                                                <td><p style="font-size:17px;">Total</p></td>

                                                <td></td>
                                                <td></td>
                                                <td></td>
                                                <td></td>
                                                <td></td>
                                                <td><p style="font-size:18px;text-align:center;">@Model.Sum(a => a.Amount)</p></td>
                                                <td></td>
                                                <td></td>
                                                <td></td>
                                                <td></td>
                                                <td></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<!--Refund Model-->
<div class="modal fade" id="defaultModal1" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header" style="border-bottom:1px solid #ece7e7;background-color:whitesmoke;">
                <h4 class="modal-title" id="defaultModalLabel" style="color:black;">Refund</h4>
            </div>
            <div class="modal-body">
                <div class="body">
                    <div class="row clearfix">
                        <div class="col-lg-3 col-md-3 col-sm-4 col-xs-5 form-control-label">
                            <label for="email_address_2">Reason</label>
                        </div>
                        <div class="col-lg-9 col-md-9 col-sm-8 col-xs-7">
                            <div class="form-group">
                                @Html.TextBox("txtorderid", "", new { style = "display:none;" })
                                @Html.TextBox("status", "", new { style = "display:none;" })
