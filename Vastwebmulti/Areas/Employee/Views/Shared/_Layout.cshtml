    <script>
        function websitepayment(val) {
            var gststs = $('#websitecheck').is(":checked");

            $.ajax({

                type: "GET",
                url: '@Url.Action("websitepayment", "Home")',
                data: { month: val, gststs: gststs },
                cache: false,
                success: function (data) {
                    $('.comfirsmclasscss').hide();
                    //---------hide confirm
                  //  alert(data);
                    if (data.includes("Low") || data.includes("Not Enable")) {
                        //------------show failed
                        $('.payment-faild').show();

                        var msg = data;
                        if (msg == "Low") {
                            msg = "Your Remain Balance is Low";
                        }
                        $('.faild').text(msg);
                        //Failed
                    }
                    else {
                        //-------show success
                        $('.payment-sucess').show();
                        var msg ="Your Next Due Date is "+ data;

                        $('.sucess').text(msg);
                        //success
                    }
                   // location.reload();
                }
            });
        }
    </script>

