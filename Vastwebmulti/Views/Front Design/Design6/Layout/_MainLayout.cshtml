            }

        .sixdesign-header {
            padding: 9px 0;
        }

        .container.flex-sixclass .flex-sixclass-first {
            width: 100%;
            float: left;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .sixdesign-header.sixdesign-headerfixed {
            width: 100%;
            float: left;
        }

        .sixdesign-header.sixdesign-headerfixed {
            position: fixed;
            top: 0;
            z-index: 99;
        }

        .footer-fullclass {
            background: #313a46;
        }

        .footer-title {
            font-size: 15px;
            letter-spacing: .05em;
            text-transform: uppercase;
            font-family: "Poppins", sans-serif;
            font-weight: 400;
            color: #fff;
        }

        .footer-title {
            display: block;
            line-height: normal;
            border-bottom: 1px solid #6f6f6f;
            padding-bottom: 10px;
            position: relative;
            margin-bottom: 30px;
            transition: all .4s linear;
        }

            .footer-title::after {
                content: "";
                display: block;
                width: 30px;
                height: 2px;
                background: #727cf5;
                position: absolute;
                bottom: -1.5px;
                left: 0;
                transition: all .4s linear;
            }

        .footer-fullclass {
            padding-top: 50px !important;
        }

            .footer-fullclass .col-md-3:hover .footer-title::after {
                width: 100%;
            }

        .footer-content ul li::before {
            content: "\f095";
        }

        .footer-content ul li {
            font: normal normal normal 14px/1 FontAwesome;
            text-rendering: auto;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

            .footer-content ul li::before {
                content: "\f095";
                background: #727cf5;
                width: 25px;
                height: 25px;
                display: block;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #fff;
                position: absolute;
                left: 0;
                font: normal normal normal 14px/1 FontAwesome;
                transition: all .4s linear;
            }

        .footer-content ul li {
            padding-left: 35px;
            position: relative;
            margin-bottom: 25px;
        }

            .footer-content ul li a, .footer-content ul li {
                color: #fff;
                font-family: 'Open Sans', sans-serif;
                font-size: 13px;
                letter-spacing: 1px;
            }

                .footer-content ul li:nth-child(2)::before {
                    content: "\f199";
                }

                .footer-content ul li:nth-child(3)::before {
                    content: "\f1c6";
                }

                .footer-content ul li:nth-child(4)::before {
                    content: "\f3c5";
                }

                .footer-content ul li:nth-child(5)::before {
                    content: "\f3c5";
                }

        .footer-content-news .footer-social li::before {
            display: none;
        }

        .footer-content-news ul.footer-social li a {
            background: #727cf5;
            width: 25px;
            height: 25px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .footer-content-news ul.footer-social li {
            display: inline-block;
            padding: 0;
            padding-right: 0px;
            margin: 0;
            width: auto;
            padding-right: 15px;
            transition: all .4s linear;
        }

            .footer-content-news ul.footer-social li:last-child {
                padding-right: 0px;
            }

            .footer-content-news ul.footer-social li a:hover {
                background: #fff;
            }

                .footer-content-news ul.footer-social li a:hover i {
                    color: #000;
                }

        .footer-content ul li:hover::before {
            color: #000;
            background: #fff;
        }

        .footer-iteam h5 {
            margin-bottom: 5px;
            color: #fff;
            font-family: "Poppins", sans-serif;
            text-transform: capitalize;
            font-size: 16px;
            line-height: normal;
        }

        .footer-iteam ul li {
            list-style: none;
            display: inline-block;
            color: #fff;
            padding-right: 5px;
            font-size: 12px;
            text-transform: capitalize;
        }

        .footer-iteam {
            border-bottom: 1px solid #6f6f6f;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }

        .footerhelplink ul li {
            float: left;
            padding-right: 15px;
        }

            .footerhelplink ul li:last-child {
                padding-right: 0px;
            }

