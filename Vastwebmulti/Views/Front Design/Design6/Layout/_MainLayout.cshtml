    <style>
        * {
            font-family: 'Open Sans', sans-serif;
        }

        .navbar.navbar-sixdesign {
            float: right;
            min-height: inherit;
        }

        .navbar-sixdesign ul {
            margin: 0;
            padding: 0px;
        }

            .navbar-sixdesign ul li {
                display: inline-block;
                list-style: none;
            }

