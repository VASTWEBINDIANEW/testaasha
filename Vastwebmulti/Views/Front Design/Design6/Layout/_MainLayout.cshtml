                font-family: 'Open Sans', sans-serif;
                color: #fff;
                font-size: 13px;
                text-transform: capitalize;
            }

        .footercopyrightsix {
            float: right;
        }

        .footerhelplink {
            float: left;
        }

        .footer-help {
            padding: 20px 0;
            margin-top: 50px;
            margin-bottom: 0px;
        }

        .term-pop.for-help-pop {
            z-index: 99999;
        }

        .sixdesign-header .container.flex-sixclass {
            width: 100%;
            padding: 0 20px;
        }

        .responsivemenu {
            transition: all .4s linear;
            border: 0;
            background: transparent;
        }

            .responsivemenu span {
                width: 20px;
                height: 2px;
                background: #fff;
                display: block;
                margin-bottom: 6px;
                transition: all .4s linear;
            }

                .responsivemenu span:last-child {
                    margin-bottom: 0px;
                }

        .responsivemenu-show span {
            transform: rotate(45deg);
        }

            .responsivemenu-show span:nth-child(3) {
                transform: rotate(-45deg);
                position: absolute;
                top: 0px;
            }

            .responsivemenu-show span:nth-child(2) {
                transform: translate(602%);
            }

        @@media screen and (max-width:991px) {
            .footer-content-same {
                transform: translateX(-401%);
                height: 0;
                transition: all .4s linear;
            }

            .footer-title-show ~ .footer-content-same {
                transform: translateX(0);
                height: auto;
                transition: all .4s linear;
            }

            .logi-six-de img.sixdesign-logo {
                max-width: 58px;
            }

            .responsivemenu {
                display: block !important;
            }

            .responsivemenu-nav li {
                display: block;
                float: none;
                width: 100%;
                margin-bottom: 0;
            }

                .responsivemenu-nav li a {
                    border-radius: 0 !important;
                    padding: 10px 15px !important;
                }

            .responsivemenu-nav {
                position: fixed;
                background: #313a46;
                top: 46px;
                right: 0;
                transform: translate(700%);
                transition: all .4s linear;
            }

            .responsivemenu-show + .responsivemenu-nav {
                transform: translate(0);
            }
        }

        @@media screen and (max-width:766px) {
            .footer-help {
                margin-top: 0;
            }

                .footer-help div {
                    width: 100%;
                    text-align: center;
                }

                .footer-help .footerhelplink ul {
                    text-align: center;
                    width: 100%;
                    float: left;
                    margin-bottom: 15px;
                }

                    .footer-help .footerhelplink ul li {
                        float: none;
                        display: inline-block;
                    }

            .app-linkdesign a {
                margin-right: 0;
                width: 100%;
            }
        }
    </style>
</head>
