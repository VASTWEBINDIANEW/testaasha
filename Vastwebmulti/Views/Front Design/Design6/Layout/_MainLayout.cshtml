                    white-space: nowrap;
                    border-radius: 50px;
                    display: flex;
                }

                .navbar-sixdesign ul li.active a {
                    background: #fff;
                    color: #000;
                }

                .navbar-sixdesign ul li a:first-child {
                    margin-left: 0px;
                }

        .logi-six-de {
            float: left;
        }

            .logi-six-de img.sixdesign-logo {
