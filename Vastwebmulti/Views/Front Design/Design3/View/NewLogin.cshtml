    <script>
        document.onreadystatechange = function () {

            if (document.readyState !== "complete") {
                document.querySelector(
                    "#btnnewlogin").style.visibility = "visible";
                document.querySelector(
                    ".loadingio-spinner-gear-94vo528ab8.first-login").style.display = "none";
                $('#btnforget').show();
                $('.loadingio-spinner-gear-94vo528ab8.third-login').hide()
            } else {
                document.querySelector(
                    "#btnnewlogin").style.display = "block";
                document.querySelector(
                    ".loadingio-spinner-gear-94vo528ab8.first-login").style.display = "none";


            }
        };
    </script>
