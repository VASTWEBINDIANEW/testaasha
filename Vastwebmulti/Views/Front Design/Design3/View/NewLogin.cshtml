<script>
    window.onload = function () {
        var forgotmsg = '@ViewBag.msgchhhk'
        if (forgotmsg != "") {
                swal("Message ", forgotmsg, "success");
        }
        var message = '@ViewData["aaaa"]'
        if (message != "") {
            if (message == "Failure") {
                swal("Oops...", "User ID Or Password Wrong.", "error");
            }
        }
        var slaberror = '@ViewData["slaberror"]';
        if (slaberror != null && slaberror != "") {
            swal("Oops!", slaberror, "error");
        }
        var success = '@ViewData["success"]'
        if (success != "") {
            var vv = success.replace(".", "\n");
            swal("You got registered !!", vv, "success");
           }
        var error = '@ViewData["error"]'
        if (error !="" && error !=null)
        {
            swal("Oops..", error, "error");
        }
        var existuser = '@ViewData["existuser"]'
        if (existuser != "" && existuser != null) {
            swal("Oops..", existuser, "error");
        }
        var ch2 = '@ViewData["bbbb"]';
        if (ch2 != "" && ch2 != null) {
            if (ch2 == "Confrimed") {
                swal("Oops...", "Your E-mail verification is pending.\n Please confirm firstly.", "error");
            }
        }
        var block = '@ViewData["msg1"]';
        if (block == "websiteblock") {
            $('#btnsleep').click();
            $("#sleep-modal").modal('show');
        }
    }
</script>
<script>
    function FillDistict() {
        var State_id = $('#state').val();
        var dist = $('#distict').val();
        if (dist == "") {
            $("#divdistributor").css("display", "none");
            document.getElementById('loginformimage').style.height = "396px";
        }
    $.ajax({
       // url: '/Home/FillCity',
        url: '@Url.Action("FillDistict", "Home")',
        type: "GET",
        dataType: "JSON",
        data: { State: State_id },
        success: function (data) {
            var markup = "<option value=''> -- Select District --</option>";
            for (var x = 0; x < data.length; x++) {
                markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                //alert(markup)
            }
            $("#distict").html(markup).show();
        },
        error: function (reponse) {
            alert("error : " + reponse);
        }
    });
  }
</script>
<!--fill dealer according to district id-->
<script>
    function FillDealer() {
        var district_id = $('#distict').val();
        $.ajax({
             url: '@Url.Action("whitelabelFillDealerList", "Home")',
            type: "GET",
            dataType: "JSON",
            data: { District: district_id },
            success: function (show) {
                $("#Distributorid").html("");
                var procemessage = "<option value=''>Select your Nearest & Known Distributor Point</option>";
                $("#Distributorid").html(procemessage).show();
                $("#divdistributor").css("display", "block");
                document.getElementById('loginformimage').style.height = "434px";
                for (var x = 0; x < show.length; x++) {
                    $("#Distributorid").append($('<option></option>').val(show[x].Value).html(show[x].Text));
                }
                },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
    }
</script>
