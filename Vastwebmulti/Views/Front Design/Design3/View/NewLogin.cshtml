@using Vastwebmulti.Models
@model RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    @{
        var cname = "";
        VastwebmultiEntities db = new VastwebmultiEntities();
        string currenturl = HttpContext.Current.Request.Url.Authority;
        currenturl = currenturl.Replace("www.", "").Replace("https://", "").Replace("http://", "");
        currenturl = currenturl.ToUpper();
        var whitelabelid = "";
        if (currenturl.Contains("LOCALHOST"))
        {
            whitelabelid = db.WhiteLabel_userList.Where(aa => aa.localhost.Replace("www.", "").Replace("https://", "").Replace("http://", "").ToLower() == currenturl.ToLower()).SingleOrDefault().WhiteLabelID;
        }
        else
        {
            whitelabelid = db.WhiteLabel_userList.Where(aa => aa.websitename.Replace("www.", "").Replace("https://", "").Replace("http://", "").ToLower() == currenturl.ToLower()).SingleOrDefault().WhiteLabelID;
        }
        var admindetail = db.Admin_details.ToList();
        var mailid = admindetail.SingleOrDefault().email;
        var mobile = admindetail.SingleOrDefault().mobile;
        var company = db.tblWhiteContactDatas.Where(p => p.UserId == whitelabelid).ToList();
        if (company.Count > 0)
        {
            cname = company.SingleOrDefault().CompnayName;
        }
        else
        {
            cname = "";
        }
    }
    <title>@cname</title>
    @{
        var favimage = "";
        VastwebmultiEntities db2 = new VastwebmultiEntities();
        var faviconlogo = db2.tblfavicons.Where(p => p.UserId == whitelabelid).ToList();
        if (faviconlogo.Count() > 0)
        {
            favimage = faviconlogo.SingleOrDefault().faviconimage;
        }
        else
        {
            <link rel="icon" href="" type="image/x-icon" />
        }
        var logoimage = "";
        var logo = db.tblwhitelabelLoginContents.Where(aa => aa.UserId == whitelabelid).ToList();
        if (logo.Count > 0)
        {
            logoimage = logo.SingleOrDefault().Image;
        }
        else
        {
            logoimage = "Login_Images/login22.png";
        }
    }
    <link rel="icon" href="@Url.Content("~/" + @favimage)" type="image/x-icon" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
