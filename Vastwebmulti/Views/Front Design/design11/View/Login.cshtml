<body class="body Login_body" style="background: url(@background);background-size: @size; background-repeat:@repeat; height:@height; background-image : @backgroundImage;">

    <div class="width_set">
        <div class="login_header">
            <a class="d-flex align-items-center" href="@Url.Action("Index1", "Home")">
                <img src="@Url.Content("~/"+@logoimage)" alt="@Firm_Name">
            </a>

            <a class="home_a" href="@Url.Action("Index1", "Home")">Back to Home</a>
        </div>

        <div class="main custome-loginpage mt-4" style="width: 100%;float: left;">
            <div id="horizontalTab">
                <div class="container-fluid">
                    <div class="row gg" style="padding:0px !important;">

                        <div class="col-md-7 col-sm-12 col-xs-12 border-md gg-item">


                            @if (ViewBag.Loginsilder != null)
                            {
                                try
                                {
                                    <div id="carousel" class="owl-carousel">
                                        @foreach (var item in ViewBag.Loginsilder)
                                        {
                                            if (item.Status == "Y")
                                            {

                                                <div class="item">
                                                    <img src="@Url.Content("~/" + item.ImagePath)" />
                                                </div>

                                            }
                                            else
                                            {
                                                <div class="item">
                                                    <img src="~/images/Default_Login.jpg" />
                                                </div>
                                            }
                                        }
                                    </div>
                                }

                                catch
                                {

                                }

                            }
                            else if (ViewBag.Logo != null)
                            {
                                <div class="item">


                                    <img src="@Url.Content("~/" + ViewBag.Logo)" style="position: absolute;width: auto;top: 50%;left: 50%;transform: translate(-50%,-50%);" />
                                </div>
                            }
                            else
                            {
                                <div class="item">
                                    <img src="~/Default_Img_Logo/Default_Login_Logo.svg" style="position: absolute;width: auto;top: 50%;left: 50%;transform: translate(-50%,-50%);" />
                                </div>
                            }
                        </div>

                        <div class="col-md-5 col-sm-12 col-xs-12 border-md gg-item">
                            <div class="span5">

                                <a class="d-flex align-items-center" href="@Url.Action("Index1", "Home")">
                                    <img class="res_set" src="@Url.Content("~/"+@logoimage)" alt="@Firm_Name" style="width: 120px;margin: auto;">
                                </a>
                                <h1>Welcome to @Firm_Name</h1>
                                <div class="resp-tabs-list">
                                    @if (ViewBag.signin_signup == "singin")
                                    {
                                        <script>
                                            $(function () {
                                                $('#signinform').css('display', 'block');
                                                $('#signupform').css('display', 'none');
                                                $('#singin').addClass('resp-tab-active');
                                                $('#singup').removeClass('resp-tab-active');
                                            });
                                        </script>
                                    }
                                    else if (ViewBag.signin_signup == "singup")
                                    {
                                        <script>
                                            $(function () {
                                                $('#signinform').css('display', 'none');
                                                $('#signupform').css('display', 'block');
                                                $('#singup').addClass('resp-tab-active');
                                                $('#singin').removeClass('resp-tab-active');
                                            });
                                        </script>
                                    }
                                    <button class="resp-tab-item" id="singin" value="singin">Sign In</button>

                                </div>

                                <div class="resp-tabs-container">
                                    @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form", @id = "UpdateForm" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("latloc")
                                        @Html.Hidden("longloc")
                                        @Html.Hidden("hdaddress")
                                        <div class="tab-1 resp-tab-content" id="signinform">
                                            <div class="login-top">

                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="for-border-effect" style="position:relative;">
                                                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                                                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", @placeholder = "Enter Registered Email Id / Mobile No", @required = "" })

                                                            <div class="focus-border"><i></i></div>
                                                        </div>
                                                    </div>
                                                </div>


                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="for-border-effect">
                                                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                                                            @Html.PasswordFor(m => m.Password, new { @class = "form-control", @placeholder = "Enter Password", @required = "" })
                                                            <div class="focus-border"><i></i></div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="login-bottom">
                                                    <ul>
                                                        <li>
                                                            <label>@Html.CheckBoxFor(m => m.RememberMe)&nbsp;Remember Me&nbsp;?</label>
                                                        </li>
                                                        <li>
                                                            <a href="#" onclick="show(this.id)" id="forgetpass">Forgot password&nbsp;?</a>
                                                        </li>
                                                    </ul>
                                                </div>

                                                <div class="submit" style="float:none;">
                                                    <div class="loadingio-spinner-gear-94vo528ab8 first-login" style="display:none;">
                                                        <div class="loader"></div>
                                                    </div>

                                                    <input id="login" type="submit" value="LOGIN" class="fullbodydycolorbg" />
                                                    <span id="login-error" class="locationafterbefore"></span>
                                                    <span id="login-error1"></span>
                                                    <span id="login-error2" class="locationafterbefore" style="display:none"></span>
                                                </div>

                                                @*<input id="login" type="submit" value="LOGIN" class="fullbodydycolorbg">*@

                                            </div>
                                            <ul class="list-inline mt-2">

                                                <li class="list-inline-item">

                                                    @if (ViewBag.Afac != "")
                                                    {
                                                        <a href="@ViewBag.Afac" target="_blank"><img src="~/AdminDesign/images/facebook.svg" /></a>
                                                    }
                                                    else
                                                    {
                                                        <img src="~/AdminDesign/images/facebook.svg" />
                                                    }

                                                </li>
                                                <li class="list-inline-item">

                                                    @if (ViewBag.Atwi != "")
                                                    {
                                                        <a href="@ViewBag.Atwi" target="_blank"><img src="~/AdminDesign/images/twitter.svg" /></a>
                                                    }
