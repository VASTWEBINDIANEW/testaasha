<script>
    var inputs = document.getElementById('frmsignup').querySelectorAll('input[type="text"], input[type="password"], input[type="email"], select');
    var mobile_ref = document.getElementsByName('Mobile')[0];
    var email_ref = document.querySelector('input[type="email"]');

    $('#btnsendOTP_Email').hide();
    disable_inputs();






    function disable_inputs() {
        for (i = 0; i < inputs.length; i++) {
            if (!['Mobile'].includes(inputs[i].getAttribute('id'))) {
                inputs[i].setAttribute('disabled', true);
                inputs[i].value = '';
            }
        }
    }

    function block_inputs(email_verify = false) {
        var omit_field = ['Mobile'];
        if (email_verify) {
            omit_field.push('Email');
        }
        for (i = 0; i < inputs.length; i++) {
            if (!omit_field.includes(inputs[i].getAttribute('id'))) {
                inputs[i].removeAttribute('disabled');
                inputs[i].value = '';
            }
        }
    }


</script>
