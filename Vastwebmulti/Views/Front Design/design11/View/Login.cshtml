<script>
    var mobile_loading = false;
    var email_loading = false;
    var mobile_clientId = null;
    var email_clientId = null;
    var mobile_verify = false;
    var email_verify = false;
    window.addEventListener('load', () => {
        var sendBtnOtp = document.getElementById('btnsendOTP');
        var txtmobileno = document.getElementById('txtmobileno');
        var resend_btn_otp = document.getElementById('resend_btn_otp');
        var otp_continer_inputs = document.getElementById('otp_continer_inputs');
        otp_continer_inputs.classList.add('hidden');


        $('input[name="Mobile"]').keyup(e => {
            $('#mobile_err').text('');
            if (mobile_loading) return;
            var mobileno = e.target.value;

            if (mobileno.length == 10) {
                mobile_loading = true;

                $('#Mobileno_spinner').show();

                fetch('@Url.Action("IsMobileEmailExist")?entry=' + mobileno + '&type=mobile')
                    .then(res => res.json())
                    .then(data => {
                        $('#Mobileno_spinner').hide();
                        mobile_loading = false;

                        if (data.status == true) {
                            $('#otp_continer_inputs').show();
                            mobile_clientId = data.client_id;
                            $('#codeBox1').focus();
                            $('input[name="Mobile"]').hide();
                        }
                        else if (data.status == false) {
                            mobile_clientId = null;
                            var message = data.message;
                            $('#mobile_err').text(message);
                            $('#otp_continer_inputs').hide();
                            $('#singup').focus();
                        }
                    })
                    .catch(err => {
                        mobile_loading = false;
                        mobile_clientId = null;
                        $('#Mobileno_spinner').hide();
                    })

            }
            else {
                $('#txtmobileno_spinner').hide();
            }

        })


        $('#btnsendOTP_Email').click(() => {
            $('#email_err').text('');
            if (email_loading) return;
            var emaild = $('input[type="email"]').val();

            if (!emaild) {
                return $('#email_err').text('Please Enter Email');
            }
            $('#btnsendOTP_Email').hide();

            email_loading = true;

            $('#Email_spinner').show();

            fetch('@Url.Action("IsMobileEmailExist")?entry=' + emaild + '&type=email')
                    .then(res => res.json())
                    .then(data => {
                        $('#Email_spinner').hide();
                        email_loading = false;

                        if (data.status == true) {
                            $('#otp_continer_inputs_email').show();
                            $('#btnsendOTP_Email').hide();
                            $('input[type="email"]').hide();
                            email_clientId = data.client_id;
                            $('#codeBox5').focus();
                        }
                        else if (data.status == false) {
                            email_clientId = null;
                            $('#singup').focus();
                            var message = data.message;
                            $('#email_err').text(message);
                            $('#btnsendOTP_Email').show();
                        }
                    })
                    .catch(err => {
                        email_loading = false;
                        mobile_clientId = null;
                        $('#Email_spinner').hide();
                    })


        })

    })
    function getCodeBoxElement(index) {
        return document.getElementById('codeBox' + index);
    }

    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 46 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }

    function onKeyUpEvent(index, event) {
        $('#mobile_err').text('');
        const eventCode = event.which || event.keyCode;
        if (getCodeBoxElement(index).value.length === 1) {
            if (index !== 4) {
                getCodeBoxElement(index + 1).focus();
            } else {
                getCodeBoxElement(index).blur();
                // Submit code
                $('#Mobileno_spinner').show();
                var otp = $('#codeBox1').val() + $('#codeBox2').val() + $('#codeBox3').val() + $('#codeBox4').val();
                fetch('@Url.Action("OtpVerify")?type=mobile&clientId=' + mobile_clientId + '&otp=' + otp)
                    .then(res => res.json())
                    .then(data => {
                        $('#Mobileno_spinner').hide();
                        if (data.status) {
                            $('#otp_continer_inputs').hide();
                            $('input[name="Mobile"]').show();
                            document.querySelector('input[name="Mobile"]').setAttribute('disabled', 'disabled');
                            mobile_clientId = null;
                            $('#success_mobile_img').show();
                            document.querySelector('input[type="email"]').removeAttribute('disabled');
                            $('#btnsendOTP_Email').show();
                            mobile_verify = true;

                            fetch('@Url.Action("fetchEmail_Mobile_sts_Data")')
                                .then(res => res.json())
                                .then(data1 => {
                                    if (data1.type == 'OFF') {
                                        email_verify = true;
                                        $('#btnsendOTP_Email').hide()
                                    }
                                    else {
                                        $('#btnsendOTP_Email').show()
                                    }
                                    if (email_verify && mobile_verify) {
                                        block_inputs();
                                        document.getElementById('SignUp').removeAttribute('disabled');
                                    }

                                    $('#Mobile_Id').val(data.id);
                                })
                        }
                        else {
                            $('#mobile_err').text(data.message);
                        }
                    })
                    .catch(err => {
                        mobile_clientId = null;
                    })
            }
        }
        if (eventCode === 8 && index !== 1) {
            getCodeBoxElement(index - 1).focus();
        }
    }

    function onKeyUpEvent_Email(index, event) {
        $('#email_err').text('');
        const eventCode = event.which || event.keyCode;
        if (getCodeBoxElement(index).value.length === 1) {
            if (index !== 8) {
                getCodeBoxElement(index + 1).focus();
            } else {
                getCodeBoxElement(index).blur();
                // Submit code
                $('#Email_spinner').show();
                var otp = $('#codeBox5').val() + $('#codeBox6').val() + $('#codeBox7').val() + $('#codeBox8').val();
                fetch('@Url.Action("OtpVerify")?type=email&clientId=' + email_clientId + '&otp=' + otp)
                    .then(res => res.json())
                    .then(data => {
                        $('#Email_spinner').hide();
                        if (data.status) {
                            $('#otp_continer_inputs_email').hide();
                            $('input[type="email"]').show();
                            document.querySelector('input[type="email"]').setAttribute('disabled', 'disabled');
                            email_clientId = null;
                            $('#success_email_img').show();
                            email_verify = true;
                            if (email_verify && mobile_verify) {
                                block_inputs(true);
                                document.getElementById('SignUp').removeAttribute('disabled');
                            }
                            $('#Email_Id').val(data.id);
                        }
                        else {
                            $('#email_err').text(data.message);
                        }
                    })
                    .catch(err => {
                        mobile_clientId = null;
                    })
            }
        }
        if (eventCode === 8 && index !== 1) {
            getCodeBoxElement(index - 1).focus();
        }
    }

    function onFocusEvent(index) {
        for (item = 1; item < index; item++) {
            const currentElement = getCodeBoxElement(item);
            if (!currentElement.value) {
                currentElement.focus();
                break;
            }
        }
    }
</script>



