<script>
    function FillDealer() {
        var district_id = $('#distict').val();

        $.ajax({
             url: '@Url.Action("FillDealerList", "Home")',
            type: "GET",
            dataType: "JSON",

            data: { District: district_id },
            success: function (show) {
                $("#Distributorid").html("");
                var procemessage = "<option value=''>Select your Nearest & Known Distributor Point</option>";
                $("#Distributorid").html(procemessage).show();
                $("#divdistributor").css("display", "block");
                for (var x = 0; x < show.length; x++) {

                    $("#Distributorid").append($('<option></option>').val(show[x].Value).html(show[x].Text));
                }
                },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
    }
</script>
