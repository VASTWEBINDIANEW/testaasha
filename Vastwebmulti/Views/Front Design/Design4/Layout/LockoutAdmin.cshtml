@model System.Web.Mvc.HandleErrorInfo
@using Vastwebmulti.Models;
@{
    ViewBag.Title = "Locked Out";
    Layout = null;
}
@{
    VastwebmultiEntities db = new VastwebmultiEntities();
    var image = db.tblWhiteLabelLoginBackImages.Where(p => p.Role == "WHITELABEL").ToList();
    ViewBag.image = image.Count == 0 ? "" : image.SingleOrDefault().ImageUrl;
}
<link href="https://fonts.googleapis.com/css?family=Roboto:400,700&subset=latin,cyrillic-ext" rel="stylesheet" type="text/css">
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" type="text/css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
<link href="~/MainFrontDesign/css/globalallcss.css" rel="stylesheet" />
<script src="~/Scripts/jquery-1.10.2.min.js"></script>
@if (!HttpContext.Current.Request.IsLocal)
{
    <!-- To Disable Inspect Element -->
    <script src="~/Scripts/Disable_Inspect_Element/Disable_Inspect.js"></script>
}
<style>
    .navbar-default {
        background-color: transparent;
        border-color: transparent;
    }
</style>
@*<hgroup>
        <h1 class="text-danger">Locked out.</h1>
        <h2 class="text-danger">This account has been locked out, please try again later.</h2>
    </hgroup>*@
<div class="section secondary-section fullbodydycolorbg" style="padding:20px 0px; width:100%;height:100vh; float:left;border-top: 5px solid #fff;border-bottom: 5px solid #fff;">
    <div class="container centered">
        <center>
            <img src="~/AdminDesign/images/locked-user.svg" style="width:190px;" />
            <p class="large-text" style="font-weight:700; font-size: 42px;color:#fff; padding: 32px;line-height:42px;">
                Account Temporary Locked
            </p>
        </center>
        <div class="row-fluid" style="margin-top:30px; margin-bottom:30px;text-align:center;">
            <div class="span3"></div>
            <div class="span8">
                <p style="color:#fff; font-size:15px;">
                    <b>The account has been blocked for 30 minutes due to login with wrong password 5 times. If you want to unblock soon, call Customer Care.</b>
                </p>
            </div>
            <div class="span1"></div>

        </div>
    </div>
</div>