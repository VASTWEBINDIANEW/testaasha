            .helepopo-newdesign .term-pop-in {
                width: 100%;
            }

            .helepopo-newdesign h2.help-foot-head {
                font-size: 24px;
            }

            .helepopo-newdesign .term-pop-close {
                padding: 9px 15px;
                font-size: 20px;
            }

            .helepopo-newdesign h3 strong {
                font-size: 14px;
            }

            .helepopo-newdesign p {
                font-size: 11px;
            }

            .helepopo-newdesign h3 {
                margin-bottom: 10px;
            }
        }
