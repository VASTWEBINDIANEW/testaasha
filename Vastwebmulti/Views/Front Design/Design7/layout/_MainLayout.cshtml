            background: transparent !important;
            transition: all .4s linear;
        }

            .new-header-one .nav.navbar-nav.navbar-right.responsivemenu-nav li a:hover,
            .new-header-one .nav.navbar-nav.navbar-right.responsivemenu-nav li.active a {
                color: var(--main-front-bg-lcolor);
            }

        .oneheader-class {
            width: 100%;
            float: left;
        }

            .oneheader-class.fixedoneadd {
                position: fixed;
                top: 0;
                z-index: 9999;
                background: rgba(255, 255, 255, 0.9);
            }

                .oneheader-class.fixedoneadd .new-header-one {
                    padding-top: 4px !important;
                    padding-bottom: 4px !important;
                    min-height: inherit;
                    box-shadow: 0 1px 3px -1px #555;
                }

        .oneheader-class {
            background: #fff;
        }

        .responsivemenu {
            transition: all .4s linear;
            border: 0;
            background: transparent;
        }

            .responsivemenu span {
                width: 20px;
                height: 2px;
                background: #333;
                display: block;
                margin-bottom: 6px;
                transition: all .4s linear;
                float: right;
            }

                .responsivemenu span:last-child {
                    margin-bottom: 0px;
                }

        .responsivemenu-show span {
            transform: rotate(45deg);
        }

            .responsivemenu-show span:nth-child(3) {
                transform: rotate(-45deg);
                position: absolute;
                top: 13px;
                right: 0;
            }

            .responsivemenu-show span:nth-child(1) {
                position: absolute;
                top: 13px;
                right: 0;
            }

            .responsivemenu-show span:nth-child(2) {
                transform: translate(602%);
            }

        .responsivemenu {
            float: right;
        }

        .oneheader-class .container-fluid.new-header-one.navbar.navbar-collapse .col-md-12.new-one-flex .navbar .nav.navbar-nav.navbar-right.responsivemenu-navnewde li a, .oneheader-class .container-fluid.new-header-one.navbar.navbar-collapse .col-md-12.new-one-flex .navbar .nav.navbar-nav.navbar-right.responsivemenu-navnewde li {
