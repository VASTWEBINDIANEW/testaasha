                transition: all .4s linear;
                opacity: 0;
            }

            .responsivemenu.responsivemenu-show ~ .responsivemenu-navnewde {
                transform: translateX(0);
                opacity: 1;
            }

            .responsivemenu-navnewde {
                position: fixed;
                top: 51px;
                right: 0;
                background: #fff;
                z-index: 99;
                width: 100%;
            }

                .responsivemenu-navnewde li {
                    display: block;
                    float: none;
                }

