            .oneheader-class .new-header-one {
                padding: 5px 40px !important;
                min-height: 51px !important;
            }

            .responsivemenu {
                position: relative;
                top: 12px;
            }

            .responsivemenu {
                position: relative;
                top: 2px;
                width: 30px;
                height: 30px;
                overflow: hidden;
            }
        }

        @@media screen and (max-width:766px) {
            .responsivemenu-navnewde {
                top: 43px;
            }

            .oneheader-class .new-header-one {
                padding: 5px 15px !important;
