@{

    var correctString = "";
    var col = "";
    var raj = "";
    var whitelabelid = "";
    using (VastwebmultiEntities db = new VastwebmultiEntities())
    {
        string currenturl = HttpContext.Current.Request.Url.Authority;

        currenturl = currenturl.Replace("www.", "").Replace("https://", "").Replace("http://", "");
        currenturl = currenturl.ToUpper();
        
        if (currenturl.Contains("LOCALHOST"))
        {
            whitelabelid = db.WhiteLabel_userList.Where(aa => aa.localhost.Replace("www.", "").Replace("https://", "").Replace("http://", "").ToLower() == currenturl.ToLower()).SingleOrDefault().WhiteLabelID;
        }
        else
        {
            whitelabelid = db.WhiteLabel_userList.Where(aa => aa.websitename.Replace("www.", "").Replace("https://", "").Replace("http://", "").ToLower() == currenturl.ToLower()).SingleOrDefault().WhiteLabelID;
        }
        var color = db.changecolors.Where(p => p.UserId == whitelabelid).ToList();
        if (color.Count > 0)
        {
            col = color.SingleOrDefault().multipaloutercolor;
            if (col != "")
            {
                String s = col;
                Char charRange = ',';
                int startIndex = s.IndexOf(charRange);
                int endIndex = s.LastIndexOf(charRange);
                int length = endIndex - startIndex + 1;
                var res = s.Substring(startIndex, length);
                raj = res.Trim(',');
            }
            else
            {
                col = "linear-gradient(to right,#ff0000,#000000)";
                String s = col;
                Char charRange = ',';
                int startIndex = s.IndexOf(charRange);
                int endIndex = s.LastIndexOf(charRange);
                int length = endIndex - startIndex + 1;
                var res = s.Substring(startIndex, length);
                raj = res.Trim(',');
            }
        }
        else
        {
            col = "";
        }
        var image = db.tblSilderWhiteBackImages.Where(p => p.UserId == whitelabelid).ToList();
        if (image.Count > 0)
        {
            var image2 = db.tblSilderWhiteBackImages.Where(p => p.UserId == whitelabelid).FirstOrDefault().SilderBackImage;
            correctString = image2.Replace(@"\", @"/");
        }
        else
        {
            correctString = "";
        }
        ViewBag.aboutimage1 = db.tblAboutUsContents.Where(p => p.UserId == whitelabelid).ToList();
        ViewBag.alltravelbus1 = db.tblTravels.Where(p => p.UserId == whitelabelid).ToList();
        ViewBag.companyname1 = db.tblWhiteContactDatas.Where(p => p.UserId == whitelabelid).ToList();
        var silder = db.tblWhitlabelSilders.ToList();
        ViewBag.silder = db.tblWhitlabelSilders.ToList();
        if (silder.Count > 0)
        {
            ViewBag.indexsilder = silder.Where(p => p.UserId == whitelabelid).ToList();
        }
    }
}

