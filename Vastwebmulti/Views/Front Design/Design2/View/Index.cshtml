<script src="~/AdminDesign/plugins/sweetalert/sweetalert.min.js"></script>
<script src="~/MainFrontDesign/js/vendor/bootstrap.min.js"></script>
<script src="~/CSS/multislider.js"></script>
<script>
    $("#readmore").click(function () {
        var collapse_content_selector = $(this).attr('href');
        var toggle_switch = $(this);
        $(collapse_content_selector).toggle(function () {
            if ($(this).css('display') == 'none') {
                toggle_switch.html('Read More');
            }
            else {
                toggle_switch.html('Read Less');
            }
        });
    });
</script>
<script>
    $('button').click(function () {
        if (this.id == 'viewmore') {
            $('#allcard').show();
            $('#silderid').hide();
            $('#viewless').show();
            $('#viewmore').hide();
        }
        else {
            $('#allcard').hide();
            $('#silderid').show();
            $('#viewless').hide();
            $('#viewmore').show();
        }
    })
</script>
<script>
    $('#basicSlider').multislider({
        continuous: true,
        duration: 2000
    });
    $('#mixedSlider').multislider({
        duration: 750,
        interval: 3000
    });
</script>
<script>
    window.onload = function () {
        var succ = '@TempData["front"]';
        if (succ != null && succ != "") {
            if (succ.includes("Successfully")) {
                swal("Good job!", succ, "success");
            }
            else {
                swal("Oops!", succ, "error");
            }
        }
    }
</script>
<script>
    $(function() {
		var selectedClass = "";
        $(".service-section span").click(function () {
            $(".service-section span").removeClass('active');
            $(this).addClass('active');
		selectedClass = $(this).attr("data-rel");
    $(".our-service-w").fadeTo(100, 0.1);
		$(".our-service-w li").not("."+selectedClass).fadeOut();
    setTimeout(function() {
      $("."+selectedClass).fadeIn();
      $(".our-service-w").fadeTo(500, 1);
    }, 500);
		
	});
});
</script>
