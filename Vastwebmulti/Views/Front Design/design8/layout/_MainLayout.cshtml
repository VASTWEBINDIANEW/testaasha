    <script>
        // scrolltop
        $('.scrollup').click(function () {
            $("html,body").animate({
                scrollTop: 0
            }, 1000);
            return false;
        });
        $(window).scroll(function () {
            if ($(this).scrollTop() > 400) {
                $('.scrollup').fadeIn();
            } else {
                $('.scrollup').fadeOut();
            }
        });
    </script>
