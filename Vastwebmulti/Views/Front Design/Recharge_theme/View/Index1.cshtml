                        </div>
                    </div>
                </div>


            </div>
        </div>
    </div>
</section>

<!-- end offer section -->
<!-- about section -->

<section id="about_section" class="about_section layout_padding">
    <div class="container  ">

        <div class="row">
            <div class="col-md-6 ">
                <div class="img-box">
                    <img style=" border-radius: 1px 45px 1px 45px;" src="~/MainFrontDesign/Recharge_theme_css/images/about_img.jpg" alt="">
                </div>
            </div>
            <div class="col-md-6">
                <div class="detail-box">
                    <div class="heading_container">
                        <h2>
                            Our About Us
                        </h2>
                    </div>
                    <p>
                        Our website offers a fast, secure, and convenient platform for all your recharge and bill payment needs. Whether it’s mobile recharge, DTH recharge, or paying utility bills, you can do it all in just a few clicks. With instant transactions, multiple payment options, and exclusive offers, we make sure you stay connected and your services never get interrupted. Enjoy hassle-free recharges and bill payments anytime, anywhere, all in one place.
                    </p>
                    <a href="">
                        Contact Us
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- end about section -->
<!-- book section -->
<section id="book_section" class="book_section layout_padding">
    <div class="container">
        <div class="heading_container">
            <h2>
                Contact Us
            </h2>
        </div>
        <div class="row">
            <div class="col-md-6">
                <div class="form_container">
                    <form action="">
                        <div>
                            <input type="text" class="form-control" placeholder="Your Name" />
                        </div>
                        <div>
                            <input type="text" class="form-control" placeholder="Phone Number" />
                        </div>
                        <div>
                            <input type="email" class="form-control" placeholder="Your Email" />
                        </div>
                        
                        <div>
                            <input type="date" class="form-control">
                        </div>
                        <div class="btn_box">
                            <button>
                                Sbmit Now
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-md-6">
                <div class="map_container ">
                    <div class="embed-map-fixed">
                        <iframe width="100%" height="450" frameborder="0" scrolling="no" marginheight="0" marginwidth="0" src="https://maps.google.com/maps?width=100%25&height=450&hl=en&q= + @Address + &t=&z=14&ie=UTF8&iwloc=B&output=embed"></iframe>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- end book section -->

<!-- food section -->
<section id="our_app" class="food_section layout_padding-bottom">
    <div class="container">
        <div class="heading_container heading_center">
            <h2>
                Our App
            </h2>
        </div>


        <div class="filters-content">
            <div class="row grid" style="height:auto;">
                <div class="col-sm-12 col-lg-12 all pizza">
                    <div class="box">
                        <div>
                            <div class="img-box">

                                <img style=" border-radius: 50px;" src="~/MainFrontDesign/Recharge_theme_css/images/android.jpg" />
                            
                                <div class="Download_app">
                                    <img src="~/MainFrontDesign/Recharge_theme_css/images/download.jpg" />
                                    
                                    <p style=" margin-top: 15px;">Download Version = @Apk_Version</p>

                                </div>
                            
                            </div>
                            <div class="detail-box">
                                <h5>
                                    Download Our App
                                </h5>
                                <p>
                                    To download the Android application directly from the website, the download button is given below, to download the application, open the website in the Android device.

                                </p>

                                <div class="btn-box">

                                    @if (!string.IsNullOrEmpty(urllinks))
                                    {
                                        <a style=" margin-right: 10px;" href="@Url.Action("DownloadAPK", "Home")">Download Android App </a>
                                    }
                                    else
                                    {
                                        <a style=" margin-right: 10px;" href="">App Link Not Available</a>
                                    }

                                    <a style=" margin-right: 10px;" href="javascript:void(0);" onclick="myFunction()" onmouseout="outFunc()" >Copy Download Link</a>



                                    @if (!string.IsNullOrEmpty(urllinks))
                                    {
                                        <input type="text" id="txthdlink" name="txthdlink" readonly value="@urllinks" style="opacity:0;" />
                                    }

                                    <a href="">
                                        Download Play Store Link
                                    </a>
                                </div>

                                
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        
    </div>
    </section>

<!-- end food section -->
