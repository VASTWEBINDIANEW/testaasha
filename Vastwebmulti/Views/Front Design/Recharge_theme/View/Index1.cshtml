                            <a href="">
                                Click Now
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-md-4  ">
                    <div class="box ">
                        <div class="img-box">
                            <img style=" width: 85px;" src="~/images/ecommerceouter.png" alt="">
                        </div>
                        <div class="detail-box">
                            <h5>
                                E-Commerce
                            </h5>
                            <h6>
                                We are provide India largest E commerce market minimum price and maximum standard.
                            </h6>
                            <a href="">
                                Click Now
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-md-4  ">
                    <div class="box ">
                        <div class="img-box">
                            <img style=" width: 120px;" src="~/images/new_dmt.jpg" alt="">
                        </div>
                        <div class="detail-box">
                            <h5>
                                DMT
                            </h5>
                            <h6>
                                DMT is a fast and secure service for transferring money within the country.
                            </h6>
                            <a href="">
                                Click Now
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-md-4  ">
                    <div class="box ">
                        <div class="img-box">
                            <img style=" width: 160px;" src="~/images/new_aeps.jpg" alt="">
                        </div>
                        <div class="detail-box">
                            <h5>
                                Aeps
                            </h5>
