<script>
    var mobile_loading = false;
    var email_loading = false;
    var mobile_clientId = null;
    var email_clientId = null;
    var mobile_verify = false;
    var email_verify = false;
    window.addEventListener('load', () => {
        var sendBtnOtp = document.getElementById('btnsendOTP');
        var txtmobileno = document.getElementById('txtmobileno');
        var resend_btn_otp = document.getElementById('resend_btn_otp');
        var otp_continer_inputs = document.getElementById('otp_continer_inputs');
        otp_continer_inputs.classList.add('hidden');


        $('input[name="Mobile"]').keyup(e => {
            $('#mobile_err').text('');
            if (mobile_loading) return;
            var mobileno = e.target.value;

            if (mobileno.length == 10) {
                mobile_loading = true;

                $('#Mobileno_spinner').show();

                fetch('@Url.Action("IsMobileEmailExist")?entry=' + mobileno + '&type=mobile')
                    .then(res => res.json())
                    .then(data => {
                        $('#Mobileno_spinner').hide();
                        mobile_loading = false;

                        if (data.status == true) {
                            $('#otp_continer_inputs').show();
                            mobile_clientId = data.client_id;
                            $('#codeBox1').focus();
                            $('input[name="Mobile"]').hide();
                        }
                        else if (data.status == false) {
                            mobile_clientId = null;
                            var message = data.message;
                            $('#mobile_err').text(message);
                            $('#otp_continer_inputs').hide();
                            $('#singup').focus();
                        }
                    })
                    .catch(err => {
                        mobile_loading = false;
                        mobile_clientId = null;
                        $('#Mobileno_spinner').hide();
                    })

            }
            else {
                $('#txtmobileno_spinner').hide();
            }

        })


        $('#btnsendOTP_Email').click(() => {
            $('#email_err').text('');
            if (email_loading) return;
            var emaild = $('input[type="email"]').val();

            if (!emaild) {
                return $('#email_err').text('Please Enter Email');
            }
            $('#btnsendOTP_Email').hide();

            email_loading = true;

            $('#Email_spinner').show();

            fetch('@Url.Action("IsMobileEmailExist")?entry=' + emaild + '&type=email')
                    .then(res => res.json())
                    .then(data => {
                        $('#Email_spinner').hide();
                        email_loading = false;

                        if (data.status == true) {
                            $('#otp_continer_inputs_email').show();
                            $('#btnsendOTP_Email').hide();
                            $('input[type="email"]').hide();
                            email_clientId = data.client_id;
                            $('#codeBox5').focus();
