<body class="body Login_body" style="padding:0;">
    @*<h1>Login with @companyname</h1>*@


    <div class="page-login-singup">
        <div class="container-fluid p-0">


            <div class="gx-0 min-vh-100 row" style="min-height: 100vh;">

                <div class="header">

                    <div class="logo">

                        <h1 class="text-light"><a href="@Url.Action("index", "Home")"><img src="@Url.Content("~/"+@logoimage)" alt="@Firm_Name" style="width: 115px; " /></a></h1>

                    </div>

                    <div class="header-icon">

                        <i class="fas fa-user-tie"></i>

                        <i class="fa fa-heart"></i>
                    </div>

                </div>


                @*Background-image*@

                <div class="login-page" style="padding-left:0px;">

                    <div class="sixbackgroundimg">
                        <div class="longhover11">

                            <h2 style="margin-bottom: 50px; text-transform: uppercase; font-size: 30px; text-align: center;">Welcome to <span>@Firm_Name</span></h2>

                            <p style="font-size: large; font-family: cursive;">
                                We are work Prepaid & Dth Recharge, Postpaid payments, Electricity bill payments, Gas & insurance payments, Domestic & internationnal Hotel booking, Domestic & internationnal flight booking, Bus booking, New PAN registration & edit, Mini ATM (M-Pos), AEPS services and largest Ecommerace that offers comprehensive payment services for customer and merchants.
                            </p>

                            <p class="imagecenterback" style="color:#000;"> &copy; 2019 - @DateTime.Now.Year All Rights Reserved | @Firm_Name </p>
                        </div>
                    </div>

                </div>


                <div class="login-page">
                    <div class="longhover1">

                        <div class="longhover2">

                            <div class="text-center longhover">
                                <div class="logo" style="width: auto; padding: 13px; ">

                                    <h1 class="text-light"><a href="@Url.Action("index", "Home")"><img src="@Url.Content("~/"+@logoimage)" alt="@Firm_Name" style="width: 115px; " /></a></h1>

                                </div>
                                <h1 class="h4 text-uppercase mb-3 welcomback">Welcome Back</h1>
                            </div>

                            @*Sign in-form*@

                            @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form", @id = "UpdateForm" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("latloc")
                                @Html.Hidden("longloc")
                                @Html.Hidden("hdaddress")
                                <div id="signinform">
                                    <div class="mb-3">
                                        <label class="form-label form-label">Email Address / Mobile No</label>
                                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", @placeholder = "", @required = "" })

                                    </div>
                                    <div class="mb-4">
                                        <div class="row">
                                            <div class="col">
                                                <label class="form-label form-label">Password</label>
                                            </div>
                                            <div class="col-auto">
                                                <a class="form-text small text-muted" id="forgotopenform" href="javascript:void(0);">Forgot your password?</a>
                                            </div>
                                        </div>
                                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", @placeholder = "", @required = "" })

                                    </div>
                                    <div class="mb-4 form-check" style="padding-left:0px;">
                                        @Html.CheckBoxFor(m => m.RememberMe)
                                        <label title="" for="RememberMe" class="form-check-label">Remember this device</label>
                                    </div>
                                    <div class="d-grid mb-5 signinclass">
                                        <button type="submit" class="text-uppercase btn btn-primary fullbodydycolorbg">Sign in</button>
                                    </div>
                                    <div class="formsubmiterror">
                                        <span id="login-error" class="locationafterbefore"></span>
                                        <span id="login-error1"></span>
                                        <span id="login-error2" class="locationafterbefore" style="display:none"></span>
                                    </div>

                                    <div class="ikon">
                                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                                        <a href="#"><i class="fab fa-twitter"></i></a>
                                        <a href="#"><i class="fab fa-google-plus"></i></a>
                                    </div>

                                    <p class="text-sm text-muted text-center singup-pclass">Don't have an account yet? <a href="javascript:void(0);" class="button-sinupsign" id="singin">Register</a>.</p>

                                </div>
                            }

                            @*Sign up Form*@

                            @using (Html.BeginForm("Insert_retailer", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form", @id = "frmsignup" }))
                            {
                                @Html.AntiForgeryToken()

                                @Html.Hidden("Email_Id")
                                @Html.Hidden("Mobile_Id")

                                <div class="tab-1 resp-tab-content" id="signupform" style="margin-top: -30px;">
                                    <div class="login-top sign-top">

                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="for-border-effect" style="position:relative;">
                                                    @Html.ValidationMessageFor(m => m.Mobile, "", new { @class = "text-danger" })
                                                    @Html.TextBoxFor(m => m.Mobile, new { @class = "form-control phone", onkeypress = "return isNumber(event)", maxlength = "10", @placeholder = "Enter Mobile No", @required = "", @field = "mobile" })
                                                    <small style="color: red;" id="mobile_err"></small>
                                                    <div class="spinner-border hidden" id="Mobileno_spinner" style="font-size: 8px;position: absolute;right: 10px;top: -26px;height: 20px;width: 20px;">
                                                    </div>
                                                    <img class="hidden" id="success_mobile_img" src="~/images/check_img_input.jpg" style="width:25px; position:absolute; right:7px; top:5px; background-color:none;" />
                                                    <div class="otp_m">
                                                        <div class="form_otp" id="otp_continer_inputs">
                                                            <div class="otp_block">
                                                                <p class="opt_pra_1"> OTP sent successfully to <br />entered mobile number</p>
                                                            </div>
                                                            <div class="otp_set">
                                                                <input id="codeBox1" type="number" maxlength="1" onkeyup="onKeyUpEvent(1, event)" onfocus="onFocusEvent(1)" />
                                                                <input id="codeBox2" type="number" maxlength="1" onkeyup="onKeyUpEvent(2, event)" onfocus="onFocusEvent(2)" />
                                                                <input id="codeBox3" type="number" maxlength="1" onkeyup="onKeyUpEvent(3, event)" onfocus="onFocusEvent(3)" />
                                                                <input id="codeBox4" type="number" maxlength="1" onkeyup="onKeyUpEvent(4, event)" onfocus="onFocusEvent(4)" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="focus-border"><i></i></div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
