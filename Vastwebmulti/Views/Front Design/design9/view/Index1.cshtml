@model Vastwebmulti.Models.RegisterViewModel
@using Vastwebmulti.Models;
@{
    Layout = null;
}
@{
    VastwebmultiEntities db = new VastwebmultiEntities();
    var ccc = db.tblContects.ToList();
    var companyname = ccc.Count == 0 ? "" : ccc.SingleOrDefault().CompnayName;
    var loginimage = db.tblLoginContents.ToList();
    if (loginimage.Count > 0)
    {
        ViewBag.loginimage = loginimage.FirstOrDefault().Image;
    }
    else
    {
        ViewBag.loginimage = "Login_Images/login22.png";
    }

    var image1 = "";
    var fullpath = "";
    var size = "";
    var repeat = "";
    var height = "";
    var backgroundImage = "";
    var image = db.tblWhiteLabelLoginBackImages.Where(p => p.Role == "ADMIN").ToList();
    if (image.Count > 0)
    {

        if (image.Where(a => a.UsedFor == "Repeat" && a.StatusCheck == "Y").SingleOrDefault() != null)
        {

            image1 = image.SingleOrDefault(a => a.UsedFor == "Repeat").otherimage;
            var ddd = image1.Replace(@"\", "/");
            fullpath = "../.." + ddd;

        }
        else if (image.Where(a => a.UsedFor == "Single" && a.StatusCheck == "Y").SingleOrDefault() != null)
        {
            image1 = image.SingleOrDefault(a => a.UsedFor == "Single").otherimage;
            var ddd = image1.Replace(@"\", "/");
            fullpath = "../.." + ddd;

            size = "cover";
            repeat = "no-repeat";
            height = "100vh";
        }
        else
        {
            backgroundImage = "linear-gradient(to right , var(--main-bg-lcolor), var(--main-bg-rcolor)) !important";
        }
    }
    else
    {
        image1 = "img32.png";
        fullpath = "../FooterImages/" + image1;
        backgroundImage = "linear-gradient(to right , var(--main-bg-lcolor), var(--main-bg-rcolor)) !important";
    }
    var admindetail = db.Admin_details.ToList();
    var mailid = admindetail.SingleOrDefault().email;
    var mobile = admindetail.SingleOrDefault().mobile;
    var background = fullpath;
    var Firm_Name = admindetail.SingleOrDefault().Companyname;


    var col = db.changecolors.ToList();
    var color = "";
    if (col.Count > 0)
    {
        color = col.SingleOrDefault(p => p.Role == "ADMIN").adminandouterheadercolor;
    }
    else
    {
        color = "Gray";
    }

}

