<body class="body Login_body" style="background: url(@background);background-size: @size; background-repeat:@repeat; height:@height; background-image : @backgroundImage;display: flex;align-items: center;justify-content: center;">
    @*<h1>Login with @companyname</h1>*@
    <div class="main custome-loginpage" style="width: 100%;float: left;    margin-top: 5%;">
        <div id="horizontalTab">

            @*<p style="color:white;">@TempData["email"]</p>*@

            <div class="container-fluid">
                <div class="container">
                    <div class="row gg" style="padding-top:0 !important;">

                        <div class="col-md-6 border-md gg-item">

                            @if (ViewBag.Loginsilder != null)
                            {
                                try
                                {
                                    <div id="carousel" class="owl-carousel">
                                        @foreach (var item in ViewBag.Loginsilder)
                                        {
                                            if (item.Status == "Y")
                                            {

                                                <div class="item">
                                                    <img src="@Url.Content("~/" + item.ImagePath)" />
                                                </div>

                                            }
                                            else
                                            {
                                                <div class="item">
                                                    <img src="~/images/Default_Login.jpg" />
                                                </div>
                                            }
                                        }
                                    </div>
                                }

                                catch
                                {

                                }

                            }
                            else if (ViewBag.Logo != null)
                            {
                                <div class="item">


                                    <img src="@Url.Content("~/" + ViewBag.Logo)" style="position: absolute;width: 80%;top: 50%;left: 50%;transform: translate(-50%,-50%);" />
                                </div>
                            }
                            else
                            {
                                <div class="item">
                                    <img src="~/Default_Img_Logo/Default_Login_Logo.svg" style="position: absolute;width: 80%;top: 50%;left: 50%;transform: translate(-50%,-50%);" />
                                </div>
                            }
                        </div>

                        <div class="col-md-6 border-md gg-item">
                            <div class="span5">

                                <div class="resp-tabs-list">
                                    <button class="resp-tab-item " id="singin" value="singin" onclick="show(this.id)">Sign In</button>
                                    <button class="resp-tab-item " id="singup" value="singup" onclick="show(this.id)">Sign Up</button>
                                </div>

                                <div class="resp-tabs-container">
                                    @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("latloc")
                                        @Html.Hidden("longloc")
                                        <div class="tab-1 resp-tab-content" id="signinform">
                                            <div class="login-iamge fullbodydycolorbg">
                                                <img src="~/AdminDesign/images/password.svg" />
                                            </div>
                                            <div class="login-top">

                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="for-border-effect">
                                                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                                                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control email", @placeholder = "Enter Registered Email Id / Mobile No", @required = "" })
                                                            <div class="focus-border"><i></i></div>
                                                        </div>
                                                    </div>
                                                </div>


                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="for-border-effect">
                                                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                                                            @Html.PasswordFor(m => m.Password, new { @class = "form-control password", @placeholder = "Enter Password", @required = "" })
                                                            <div class="focus-border"><i></i></div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="login-bottom">
                                                    <ul>
                                                        <li>
                                                            <label>@Html.CheckBoxFor(m => m.RememberMe)&nbsp;Remember Me&nbsp;?</label>
                                                        </li>
                                                        <li>
                                                            <a href="#" onclick="show(this.id)" id="forgetpass">Forgot password&nbsp;?</a>
                                                        </li>
                                                    </ul>
                                                </div>

                                                <input id="login" type="submit" value="LOGIN" class="fullbodydycolorbg">
                                                <span id="login-error"></span>
                                                <span id="login-error1"></span>
                                            </div>
                                        </div>


                                    }

                                    @using (Html.BeginForm("Insert_retailer", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                                    {
                                        @Html.AntiForgeryToken()

                                        <div class="tab-1 resp-tab-content" id="signupform">
                                            <div class="login-top sign-top">

                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="for-border-effect">
                                                            @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                                                            @Html.TextBoxFor(m => m.Name, new { @class = "form-control name", @placeholder = "Enter Customer Name", @required = "" })
                                                            <div class="focus-border"><i></i></div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="for-border-effect">
                                                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                                                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control email", @placeholder = "Enter Email-ID", @required = "" })
                                                            <div class="focus-border"><i></i></div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="for-border-effect">
                                                            @Html.ValidationMessageFor(m => m.Mobile, "", new { @class = "text-danger" })
                                                            @Html.TextBoxFor(m => m.Mobile, new { @class = "form-control phone", onkeypress = "return isNumber(event)", maxlength = "10", @placeholder = "Enter Mobile No", @required = "" })
                                                            <div class="focus-border"><i></i></div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="for-border-effect">
                                                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                                                            @Html.TextBoxFor(m => m.Password, new { @class = "form-control phone", maxlength = "10", @placeholder = "Enter Password", @required = "" })
                                                            <div class="focus-border"><i></i></div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="for-border-effect">
                                                            @Html.ValidationMessageFor(m => m.Pin, "", new { @class = "text-danger " })
                                                            @Html.TextBoxFor(m => m.Pin, new { @class = "form-control phone", maxlength = "4", minlength = "4", @placeholder = "Enter Pin", @required = "", onkeypress = "return isNumber(event)" })
                                                            <div class="focus-border"><i></i></div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="for-border-effect custom-district">
                                                            @Html.ValidationMessageFor(m => m.state, "", new { @class = "text-danger" })
                                                            @Html.DropDownListFor(model => model.state, (IEnumerable<SelectListItem>)ViewBag.Sate, "Select State", new { @class = "form-control", @onchange = "FillDistict()", @required = "" })
                                                            <div class="focus-border"><i></i></div>
                                                        </div>

                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="for-border-effect custom-district">
                                                            @Html.ValidationMessageFor(m => m.distict, "", new { @class = "text-danger" })
                                                            @Html.DropDownListFor(model => model.distict, new SelectList("Value", "Text"), "Select District", new { @class = "form-control", @required = "" })
                                                            <div class="focus-border"><i></i></div>
                                                        </div>


                                                    </div>
                                                </div>


                                                <div class="login-bottom">
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <ul>
                                                                <li>
                                                                    <label>@Html.CheckBoxFor(m => m.RememberMe)&nbsp;Remember Me&nbsp;?</label>
                                                                </li>

                                                            </ul>
                                                        </div>
                                                        <div class="col-md-6" style="margin-top:5px;">
                                                            <input type="checkbox" id="referrral" onclick="myFunction()" style="float:left;"><span id="referrral1" style="float: left;font-size: 15px;margin-top: -5px;margin-left:3px;color:#999;">Have a referral code</span>
                                                            <div class="for-border-effect" style="position: absolute;top: -11px;right: 14px;width: 78%;">
                                                                @Html.TextBoxFor(m => m.referralcode, new { @class = "form-control", @placeholder = "Referral Code", @style = "height:32px; display:none;width:100%;margin-top:0px;margin-bottom:0px;", @maxlength = "10" })
                                                                <div class="focus-border"><i></i></div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>


                                                <input type="submit" value="Sign Up Now" class="fullbodydycolorbg">
                                            </div>
                                        </div>
                                    }


                                    <div class="tab-1 resp-tab-content" id="forget" style="display:none;">
                                        <h2 style="font-size: 22px;text-align: center;margin-bottom: 10px;margin-top:15px;">Registered Email Id</h2>
                                        @using (Html.BeginForm("ForgotPasswordAdmin", "Account", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <div class="login-top sign-top">
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                                                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control email", @placeholder = "Enter Email ID", required = "" })
                                                    </div>
                                                </div>

                                                <div class="login-bottom">

                                                    <div class="clear"></div>
                                                </div>
                                                <input class="fullbodydycolorbg" type="submit" value="Forgot" style="margin-top:30px;">
                                            </div>
                                        }
                                    </div>
                                </div>

                            </div>
                        </div>

                    </div><!--.row-->
                </div><!--.container-->
            </div>

        </div><!--#horizontalTab-->



        <div class="footer">
            <center> <p> &copy; 2019 - @DateTime.Now.Year All Rights Reserved | @Firm_Name </p></center>
        </div>

    </div><!--.main-->
    @{
        <input type="button" value="sleep" id="btnsleep" data-toggle="modal" data-target="#sleep-modal" style="display:none;">
        <div class="modal fade" id="sleep-modal" data-keyboard="false" data-backdrop="static">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-body">
                        <img src="@Url.Content("~/Deskrop Sleep Mode.png")" id="mImage" />

                    </div>
                    <div>
                        <span style="font-size:15px; margin-left:15px;">Mail-id :-<b style="color:red;"> @mailid</b> </span>
                        <br />
                        <span style="font-size:15px; margin-left:15px;">Mobile No :-<b style="color:red;"> @mobile</b></span>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    </div>

                </div>
            </div>
        </div>
    }

    @*<script src="~/AdminDesign/plugins/bootstrap-select/js/bootstrap-select.js"></script>*@
    <script src="~/NewLoginDesign/js/jquery-2.1.4.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    @*<script src="~/Scripts/jquery.validate.unobtrusive.js"></script>*@
    <script src="~/NewLoginDesign/js/easyResponsiveTabs.js"></script>
    <script src="~/Swalalert/sweetalert-dev.js"></script>
    <link href="~/Swalalert/sweetalert.css" rel="stylesheet" />
    <script type="text/javascript">
        $(function () {
            $('#horizontalTab').easyResponsiveTabs({
                type: 'default',
                width: 'auto',
                fit: true
            });
        });
    </script>
    <script>
        function show(clicked_id) {
            if (clicked_id == "singin") {
                $('#fristimage').show();
                $('#thirdimage').hide();
                $('#secondimage').hide();
                $('#signinform').show();
                $('#signupform').hide();
                $('#forget').hide();
            }
            else if (clicked_id == "singup") {
                $('#fristimage').hide();
                $('#thirdimage').hide();
                $('#secondimage').show();
                $('#signinform').hide();
                $('#signupform').show();
                $('#forget').hide();
            }
            else {
                $('#fristimage').hide();
                $('#thirdimage').show();
                $('#secondimage').hide();
                $('#signinform').hide();
                $('#signupform').hide();
                $('#forget').show();
            }
        }

    </script>
    <script>
        $('button').click(function () {
            if (this.id == 'viewmore') {
                $('#allcard').show();
                $('#silderid').hide();
                $('#viewless').show();
                $('#viewmore').hide();
            }
            else {
                $('#allcard').hide();
                $('#silderid').show();
                $('#viewless').hide();
                $('#viewmore').show();
            }
        })
    </script>
