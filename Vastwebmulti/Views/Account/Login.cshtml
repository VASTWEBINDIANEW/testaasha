<script>
    $(function () {
          var message = '@ViewBag.messagechkk'
       if (message != null && message != "") {
           //swal("Message !", message, "success");
            $('#login-error').text(message)
        }
        var status = '@TempData["defaultstatus"]';
        if (status != null && status != "") {
            //swal("Oops!", status, "error");
            $('#login-error').text(status)
        }

        var reg = '@ViewData["success"]';
        if (reg != null && reg != "") {
            var vv = reg.replace(".", "\n");
            //swal("You got registered !!", vv, "success");
            $('#login-error1').text(reg)
        }
        var slaberror = '@ViewData["slaberror"]';
        if (slaberror != null && slaberror != "") {
            //swal("Oops!", slaberror, "error");
             $('#login-error').text(slaberror)
        }
        var email = '@ViewData["email"]'
        if (email != null && email != "") {
            //swal({
            //    html: true,
            //    title: 'Oops!',
            //    text: email,
            //    type: 'error'
            //});
            $('#login-error').text(email)
         }
        var mobilbe = '@ViewData["mobilecon"]'
        if (mobile != null && mobile != "") {
            //swal("Oops!", mobile, "error");
            $('#login-error').text(mobile)
        }
        var message = '@ViewData["wrongpass"]'
        if (message != "") {
            if (message == "Failure") {
                //swal("Oops...", "User ID Or Password Wrong.", "error");
                $('#login-error').text('User ID Or Password Wrong')
            }
        }
        var userMsg = '@ViewData["userblock"]'
        if (userMsg != "") {
            //swal("Oops...", userMsg, "error");
            $('#login-error').text(userMsg)
        }
        var existuser = '@ViewData["existuser"]'
        if (existuser != "" && existuser != null) {
            //swal("Oops...", existuser, "error");
            $('#login-error').text(existuser)
        }

        var ch2 = '@ViewData["confrim"]';
        if (ch2 != "" && ch2 != null) {
            if (ch2 == "Confrimed") {

                 $('#login-error').text('Your Email verification is pending. Please verify the Email first')

            }
        }
        var block = '@ViewData["msg"]';
        if (block == "websiteblock") {
            $('#btnsleep').click();
            $("#sleep-modal").modal('show');
        }
        $(".sweet-alert").css('background', '@PageData["globalOuter"]');
    });
</script>
<script>
    function isNumber(evt) {
        evt = (evt) ? evt : window.event;
        var charCode = (evt.which) ? evt.which : evt.keyCode;
        if (charCode > 31 && (charCode < 48 || charCode > 57)) {
            return false;
        }
        return true;
    }
</script>
<!--fill district javascript-->
<script>
    function FillDistict() {
        var State_id = $('#state').val();
        var dist = $('#distict').val();
        if (dist == "") {
              $("#divdistributor").css("display", "none");
        }
    $.ajax({
       // url: '/Home/FillCity',
        url: '@Url.Action("FillDistict", "Home")',
        type: "GET",
        dataType: "JSON",

        data: { State: State_id },
        success: function (data) {
            var markup = "<option value=''> -- Select District --</option>";
            for (var x = 0; x < data.length; x++) {
                markup += "<option value=" + data[x].Value + ">" + data[x].Text + "</option>";
                //alert(markup)
            }
            $("#distict").html(markup).show();
        },
        error: function (reponse) {
            alert("error : " + reponse);
        }
    });
  }
</script>
<!--fill dealer according to district id-->
<script>
    function FillDealer() {
        var district_id = $('#distict').val();

        $.ajax({
             url: '@Url.Action("FillDealerList", "Home")',
            type: "GET",
            dataType: "JSON",

            data: { District: district_id },
            success: function (show) {
                $("#Distributorid").html("");
                var procemessage = "<option value=''>Select your Nearest & Known Distributor Point</option>";
                $("#Distributorid").html(procemessage).show();
                $("#divdistributor").css("display", "block");
                for (var x = 0; x < show.length; x++) {

                    $("#Distributorid").append($('<option></option>').val(show[x].Value).html(show[x].Text));
                }
                },
            error: function (reponse) {
                alert("error : " + reponse);
            }
        });
    }
</script>
