@using Vastwebmulti.Models;
@{
    Layout = null;
    if (!HttpContext.Current.Request.IsLocal)
    {
        <!-- To Disable Inspect Element -->
        <script src="~/Scripts/Disable_Inspect_Element/Disable_Inspect.js"></script>
    }
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.DomainName</title>
    <link href="~/CSS/bootstrap.css" rel="stylesheet" />
</head>
<body style="background: url(../images/orig.gif); background-repeat:no-repeat;background-size:cover;">
    <div class="container-fluid">


        <div>
            <center>
                <img src="~/outerRegisterDesign/images/000.png" class="img-responsive" style="margin-top:11px;" />
                @*<img src="~/3347259_orig.png" class="img-responsive" />*@
            </center>
        </div>
        <div class="row" style="margin-bottom:50px; margin-top:100px;">
            <div class="col-md-3">

            </div>
            <div class="col-md-6">
                <p style="color:white; font-size:17px;  margin-top:-32px; text-align:justify; font-family:cursive">
                    " Your creativity and courage have eventually led you to open your own business, and I’m so proud of you. Vast Web India Private Limited have every reason to believe that your hard work and perseverance will lead to the success of this business. <span style="color:#ff5b46; font-weight:700;">Congratulations & good luck</span> for your startup. "
                </p>

            </div>
            <div class="col-md-3">

            </div>
            <center><a style="width: 100%;float: left;outline: none;" href="@Url.Action("Registration","Home")"><img src="~/outerRegisterDesign/images/Get Start.png" class="img-responsive" /></a></center>
        </div>
    </div>
</body>
</html>
