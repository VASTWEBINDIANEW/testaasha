<script>
    $(document).ready(function () {
        $("#CaptchaInput").val("").prop("disabled", false);
        // 🔒 Signup fields initially disable
        //$("#signupFields input, #signupFields select, #SignUp").prop("disabled", true);

        // 🟢 Captcha Verify Button Click
        $("#verifyCaptchaBtn").click(function () {
            var captchaInput = $("#CaptchaInput");

            if (captchaInput.length === 0) {
                console.error("❌ Captcha input field not found!");
                return;
            }

            var input = captchaInput.val().trim();
            if (input === "") {
                $("#captcha_msg").text("Please enter captcha first.")
                    .removeClass("text-success")
                    .addClass("text-danger");
                return;
            }

            // Spinner show + success image hide
            $("#captcha_spinner").removeClass("d-none");
            $("#captcha_success_img").addClass("d-none");
            $("#captcha_msg").text("");

            $.ajax({
                url: '@Url.Action("VerifyCaptcha", "Home")', // ✅ Correct controller & action
                type: 'POST',
                data: { inputCaptcha: input }, // ✅ Backend parameter match
                success: function (response) {
                    $("#captcha_spinner").addClass("d-none");

                    if (response.success) {
                        $("#captcha_msg").removeClass("text-danger")
                            .addClass("text-success")
                            .text(response.message);

                        $("#captcha_success_img").removeClass("d-none"); // ✅ Tick image show

                        $("#Mobile").prop("disabled", false);

                        // 🔓 Enable Signup Fields
                        //$("#signupFields input, #signupFields select, #SignUp").prop("disabled", false);

                        // ❌ Disable Captcha fields once verified
                        //$("#CaptchaInput, #verifyCaptchaBtn").prop("disabled", true);
                    } else {
                        $("#captcha_msg").removeClass("text-success")
                            .addClass("text-danger")
                            .text(response.message);

                        $("#captcha_success_img").addClass("d-none");
                    }
                },
                error: function () {
                    $("#captcha_spinner").addClass("d-none");
                    $("#captcha_msg").removeClass("text-success")
                        .addClass("text-danger")
                        .text("Error verifying captcha.");
                }
            });
        });

        // 🔄 Captcha Refresh
        $("#refreshCaptcha").click(function () {
    
            $.get('@Url.Action("RefreshCaptcha", "Home")', function (data) {
                $("#captcha-text").text(data.Captcha); // New Captcha show
                $("#CaptchaInput").val("").prop("disabled", false);
                $("#verifyCaptchaBtn").prop("disabled", false);
                $("#captcha_msg").text("");
                $("#captcha_success_img").addClass("d-none");
            });
        });

    });


    </script>

