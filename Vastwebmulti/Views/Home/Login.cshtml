    async function reverseGeocode(latitude, longitude) {
        //let apikey = "60baa3a9b6154ef3a3ab635c8bd06767";
        try {
            var url = '@Url.Action("fetchlatlong", "Home")';
            url = url + '?lat=' + latitude + '&lon=' + longitude + '';
            const chk = await fetch(url).then((response) => response.json());
            let apikey = chk.key;
            if (chk.sts == true) {
                $('#hdaddress').val(chk.resp);
            } else {
                const resp = await fetch('https://api.opencagedata.com/geocode/v1/json'
                    + '?'
                    + 'key=' + apikey
                    + '&q=' + encodeURIComponent(latitude + ',' + longitude)
                    + '&pretty=1'
                    + '&no_annotations=1')
                    .then((response) => response.json());

                if (resp.status.code == 200) {
                    $('#hdaddress').val(JSON.stringify(resp.results[0].components));
                }
                else {
                    $('#hdaddress').val("Location Not Fetch");
                }
            }
        }
        catch {
            $('#hdaddress').val("Location Not Fetch");
        }
    }

    function success(data) {
        let latitude = data.coords.latitude;
        let longitude = data.coords.longitude;
        $('#latloc').val(latitude);
        $('#longloc').val(longitude);

        reverseGeocode(latitude, longitude);
    }

    if (navigator.geolocation) {
        window.navigator.geolocation
            .getCurrentPosition(success, showError);
    }

    function showError(error) {
        $('#lblerrormsg').text('')
        switch (error.code) {
            case error.PERMISSION_DENIED:
                // alert("User denied the request for Geolocation.")
                $('#login-error2').html("<i class='material-icons'>add_location</i> User denied the request for Geolocation.");
                break;
            case error.POSITION_UNAVAILABLE:
                //  alert("Location information is unavailable.")
                $('#login-error2').html("<i class='material-icons'>add_location</i> Location information is unavailable.")
                break;
            case error.TIMEOUT:
                // alert("The request to get user location timed out.")
                $('#login-error2').html("<i class='material-icons'>add_location</i> The request to get user location timed out.")
                break;
            case error.UNKNOWN_ERROR:
                $('#login-error2').text("An unknown error occurred.")
                // alert("An unknown error occurred.")
                break;
        }
    }
