                        $('#Email_spinner').hide();
                    })


        })

    })
    function getCodeBoxElement(index) {
        return document.getElementById('codeBox' + index);
    }

    function isNumber(evt) {
        var iKeyCode = (evt.which) ? evt.which : evt.keyCode
        if (iKeyCode != 46 && iKeyCode > 31 && (iKeyCode < 48 || iKeyCode > 57))
            return false;
        return true;
    }

    function onKeyUpEvent(index, event) {
        $('#mobile_err').text('');
        const eventCode = event.which || event.keyCode;
        if (getCodeBoxElement(index).value.length === 1) {
            if (index !== 4) {
                getCodeBoxElement(index + 1).focus();
            } else {
                getCodeBoxElement(index).blur();
                // Submit code
                $('#Mobileno_spinner').show();
                var otp = $('#codeBox1').val() + $('#codeBox2').val() + $('#codeBox3').val() + $('#codeBox4').val();
                fetch('@Url.Action("OtpVerify")?type=mobile&clientId=' + mobile_clientId + '&otp=' + otp)
                    .then(res => res.json())
                    .then(data => {
                        $('#Mobileno_spinner').hide();
                        if (data.status) {
                            $('#otp_continer_inputs').hide();
                            $('input[name="Mobile"]').show();
                            document.querySelector('input[name="Mobile"]').setAttribute('disabled', 'disabled');
                            mobile_clientId = null;
                            $('#success_mobile_img').show();
                            document.querySelector('input[type="email"]').removeAttribute('disabled');
                            $('#btnsendOTP_Email').show();
                            mobile_verify = true;

                            fetch('@Url.Action("fetchEmail_Mobile_sts_Data")')
                                .then(res => res.json())
                                .then(data1 => {
                                    if (data1.type == 'OFF') {
                                        email_verify = true;
                                        $('#btnsendOTP_Email').hide()
                                    }
                                    else {
                                        $('#btnsendOTP_Email').show()
                                    }
                                    if (email_verify && mobile_verify) {
                                        block_inputs();
                                        document.getElementById('SignUp').removeAttribute('disabled');
                                    }

                                    $('#Mobile_Id').val(data.id);
                                })
                        }
                        else {
                            $('#mobile_err').text(data.message);
                        }
                    })
                    .catch(err => {
                        mobile_clientId = null;
                    })
            }
        }
        if (eventCode === 8 && index !== 1) {
            getCodeBoxElement(index - 1).focus();
        }
    }

    function onKeyUpEvent_Email(index, event) {
        $('#email_err').text('');
        const eventCode = event.which || event.keyCode;
        if (getCodeBoxElement(index).value.length === 1) {
            if (index !== 8) {
                getCodeBoxElement(index + 1).focus();
            } else {
                getCodeBoxElement(index).blur();
                // Submit code
                $('#Email_spinner').show();
                var otp = $('#codeBox5').val() + $('#codeBox6').val() + $('#codeBox7').val() + $('#codeBox8').val();
                fetch('@Url.Action("OtpVerify")?type=email&clientId=' + email_clientId + '&otp=' + otp)
                    .then(res => res.json())
                    .then(data => {
                        $('#Email_spinner').hide();
                        if (data.status) {
                            $('#otp_continer_inputs_email').hide();
                            $('input[type="email"]').show();
                            document.querySelector('input[type="email"]').setAttribute('disabled', 'disabled');
                            email_clientId = null;
                            $('#success_email_img').show();
                            email_verify = true;
                            if (email_verify && mobile_verify) {
                                block_inputs(true);
                                document.getElementById('SignUp').removeAttribute('disabled');
                            }
                            $('#Email_Id').val(data.id);
                        }
                        else {
                            $('#email_err').text(data.message);
                        }
                    })
                    .catch(err => {
                        mobile_clientId = null;
                    })
            }
        }
        if (eventCode === 8 && index !== 1) {
            getCodeBoxElement(index - 1).focus();
        }
    }

    function onFocusEvent(index) {
        for (item = 1; item < index; item++) {
            const currentElement = getCodeBoxElement(item);
            if (!currentElement.value) {
                currentElement.focus();
                break;
            }
        }
    }
</script>



