        var formData = new FormData();
        formData.append('video_filename', "mpaaa.mp4");
        formData.append('video_blob', blob);

        makeXMLHttpRequest('@Url.Action("UploadVideoforKYC", "Home")', formData);

        setTimeout(() => {
            document.body.removeChild(a);
            window.URL.revokeObjectURL(url);
        }, 100);
        });

        function makeXMLHttpRequest(url, data, callback) {
            var request = new XMLHttpRequest();
            request.onreadystatechange = function () {
                if (request.readyState == 4 && request.status == 200) {
                    alert("Successfully Updated")
                  //  loaderkycLoader.style.display = "none";
                  //  var urlss = '@Url.Action("Dashboard", "Home")';

                    var urls = '@Url.Action("Dashboard", "Home")';
                    location.href = urls;
                }
            };
            request.open('POST', url);
            request.send(data);
        }


        function handleDataAvailable(event) {
            console.log('handleDataAvailable', event);
            if (event.data && event.data.size > 0) {
            recordedBlobs.push(event.data);
        }
        }
        var myVar;
        function startRecording() {
            recordedBlobs = [];
            let options = { mimeType: 'video/webm;codecs=vp9,opus' };
        try {
            mediaRecorder = new MediaRecorder(stream, {
                    audioBitsPerSecond: 128 * 1000, // 128 kbit/s
                    videoBitsPerSecond: 2 * 1000 * 1000, // 2 Mbit/s
                });/*(window.stream, options);*/

        } catch (e) {
            console.error('Exception while creating MediaRecorder:', e);
            errorMsgElement.innerHTML = 'Exception while creating MediaRecorder: ${JSON.stringify(e)Urlrl';
            return;
            errorMsgElement.style.display = "flex";
        }

        console.log('Created MediaRecorder', mediaRecorder, 'with options', options);
        recordButton.textContent = 'Stop Recording';
        playButton.disabled = true;
        downloadButton.disabled = true;
        mediaRecorder.onstop = (event) => {
            console.log('Recorder stopped: ', event);
            console.log('Recorded Blobs: ', recordedBlobs);
        };
        mediaRecorder.ondataavailable = handleDataAvailable;
        mediaRecorder.start();

        console.log('MediaRecorder started', mediaRecorder);
            (function count(cc) {
            document.getElementById("cco").innerHTML = cc;
            if (cc > 0)
                setTimeout(function () { count(--cc); }, 1000);
        })(38);

        //  setTimeout($('#record').click(), 5000);



        }



        function stopRecording() {
            mediaRecorder.stop();
        }



        function handleSuccess(stream) {
            recordButton.disabled = false;
            document.getElementById("record").style.display = "block";
            console.log('getUserMedia() got stream:', stream);
            window.stream = stream;

            const gumVideo = document.querySelector('video#gum');
            gumVideo.srcObject = stream;
        }

        async function init(constraints) {
            try {
                const stream = await navigator.mediaDevices.getUserMedia(constraints);
                handleSuccess(stream);
            } catch (e) {
                console.error('navigator.getUserMedia error:', e);
                errorMsgElement.innerHTML = "Your Browser Not Support WebCam <br /> please open laptop or mobile."; //'navigator.getUserMedia error:${e.toString()}';
