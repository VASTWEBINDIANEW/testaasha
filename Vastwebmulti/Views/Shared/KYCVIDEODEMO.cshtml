                const recordagainButton = document.querySelector('button#recoardagain');
                const cancelrecordButton = document.querySelector('button#cancelrecord');
                const gumVideoplay = document.querySelector('video#gum');
                const loaderkycLoader = document.querySelector('#loaderkyc');
                const videoStarttime = document.querySelector('.videostart-time');



                recordButton.addEventListener('click', () => {

            if (recordButton.textContent === 'Start Record') {
                startRecording();
                document.getElementById("record").style.display = "none";

                setTimeout(function () {

                    document.getElementById("record").click();


                }, 38000);

