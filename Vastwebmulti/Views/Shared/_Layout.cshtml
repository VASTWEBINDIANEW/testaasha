@{
    VastwebmultiEntities db = new VastwebmultiEntities();
    var col = "";

    //var color = db.changecolors.Where(p => p.UserId == whitelabelid).ToList();
    List<Vastwebmulti.Areas.WHITELABEL.Models.JsonFile.ColorSetting> people = new List<Vastwebmulti.Areas.WHITELABEL.Models.JsonFile.ColorSetting>();
    JSONReadWrite readWrite = new JSONReadWrite();
    people = Newtonsoft.Json.JsonConvert.DeserializeObject<List<Vastwebmulti.Areas.WHITELABEL.Models.JsonFile.ColorSetting>>(readWrite.Read("ColorSetting.json", "~/Areas/WHITELABEL/Models/JsonFile/"));

    var color = people.Where(p => p.UserId == whitelabelid).ToList();
    if (color.Count > 0)
    {
        //if (color.SingleOrDefault().Role == "WHITELABEL")
        //{
        col = color.SingleOrDefault().multipaloutercolor;
        //}
    }
    else
    {
        col = "";
    }
    var image1 = "";
    var logoRec = db.tblHeaderLogoes.AsNoTracking().FirstOrDefault(p => p.UserId == whitelabelid);
    if (logoRec != null) { image1 = logoRec.LogoImage; }
    var vv = db.tblMenus.AsNoTracking().Where(tbl => tbl.Status == "Y" && tbl.UserId == whitelabelid).Select(tbl => new { tbl.MenuName });
    ViewBag.menuname = vv;
    // FirstOrDefault instead of ToList() + SingleOrDefault() - avoids loading full table
    var admindetail = db.Admin_details.AsNoTracking().FirstOrDefault();
    var mailid = admindetail != null ? (admindetail.email ?? "") : "";
    var mobile = admindetail != null ? (admindetail.mobile ?? "") : "";
    string RDate = admindetail != null ? admindetail.Date.ToString() : DateTime.Now.ToString();

    // Single query with FirstOrDefault; fields accessed from cached object
    var wlRec = db.WhiteLabel_userList.AsNoTracking().FirstOrDefault(p => p.WhiteLabelID == whitelabelid);
    var company_Name = wlRec != null ? (wlRec.websitename ?? "") : "";
    var phone = wlRec != null ? (wlRec.Support_Mobile ?? "") : "";
    var WMobile = wlRec != null ? (wlRec.Mobile ?? "") : "";
    var address = wlRec != null ? (wlRec.Address ?? "") : "";
    var email = wlRec != null ? (wlRec.Support_Email ?? "") : "";
    var Wemail = wlRec != null ? (wlRec.EmailId ?? "") : "";




    //********************** Start Whitelabel Badges Media **************************
    var allBadges = db.WhiteLabel_Badges.AsNoTracking().Where(p => p.Userid == whitelabelid).ToList();
    var Appfutur = allBadges.FirstOrDefault(p => p.BadgeType == "Appfutura")?.Url_Link ?? "";
    var Applanche = allBadges.FirstOrDefault(p => p.BadgeType == "Applancher")?.Url_Link ?? "";
    var Badus = allBadges.FirstOrDefault(p => p.BadgeType == "Badush")?.Url_Link ?? "";
    var Extrac = allBadges.FirstOrDefault(p => p.BadgeType == "Extract")?.Url_Link ?? "";
    var Goodfirm = allBadges.FirstOrDefault(p => p.BadgeType == "Good-firms")?.Url_Link ?? "";
    var Mobileap = allBadges.FirstOrDefault(p => p.BadgeType == "Mobile-app")?.Url_Link ?? "";
    var Trustpilo = allBadges.FirstOrDefault(p => p.BadgeType == "Trustpilot")?.Url_Link ?? "";
    //********************** End Whitelabel Badges Media **************************

}

