    @{
        var favimage = "";
        VastwebmultiEntities db2 = new VastwebmultiEntities();
        string currenturl = HttpContext.Current.Request.Url.Authority;
        currenturl = currenturl.Replace("www.", "").Replace("https://", "").Replace("http://", "");
        currenturl = currenturl.ToUpper();
        var whitelabelid = "";
        try
        {
            if (currenturl.Contains("LOCALHOST"))
            {
                whitelabelid = db2.WhiteLabel_userList.AsNoTracking().Where(aa => aa.localhost.Replace("www.", "").Replace("https://", "").Replace("http://", "").ToLower() == currenturl.ToLower()).SingleOrDefault().WhiteLabelID;
            }
            else
            {
                whitelabelid = db2.WhiteLabel_userList.AsNoTracking().Where(aa => aa.websitename.Replace("www.", "").Replace("https://", "").Replace("http://", "").ToLower() == currenturl.ToLower()).SingleOrDefault().WhiteLabelID;
            }
        }
        catch { }
        // Single query instead of ToList() + SingleOrDefault()
        var faviconRec2 = db2.tblfavicons.AsNoTracking().FirstOrDefault(p => p.UserId == whitelabelid);
        if (faviconRec2 != null)
        {
            favimage = faviconRec2.faviconimage;
        }

        var imageRec = db2.tblfooterImages.AsNoTracking().FirstOrDefault(p => p.UserId == whitelabelid);
        ViewBag.image = imageRec != null ? imageRec.ImageUrl : "img42.png";

        ViewBag.Sate = db2.State_Desc.AsNoTracking().Select(a => new SelectListItem { Text = a.State_name, Value = a.State_id.ToString() }).ToList();

        var cardMenu2 = db2.tblMenus.AsNoTracking().FirstOrDefault(a => a.MenuName == "CARDS");
        var travelMenu2 = db2.tblMenus.AsNoTracking().FirstOrDefault(a => a.MenuName == "TRAVEL");
        var Card = cardMenu2 != null ? cardMenu2.Status : "N";
        var Travel = travelMenu2 != null ? travelMenu2.Status : "N";
        var NotShow = (Card == "Y" || Travel == "Y");
    }
    <link rel="icon" href="@Url.Content("~/" + @favimage)" type="image/x-icon" />
