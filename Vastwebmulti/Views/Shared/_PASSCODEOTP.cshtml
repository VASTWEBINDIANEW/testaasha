    {
        OTPTYPE = "Day ";
    }
    if (OTPTYPE == "WEAKS")
    {
        OTPTYPE = "Weekly ";
    }
    if (OTPTYPE == "MONTHS")
    {
        OTPTYPE = "MONTHLY ";
    }
}
