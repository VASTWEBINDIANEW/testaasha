        }

    .prompt {
        margin-bottom: 20px;
        font-size: 20px;
        color: white;
    }

    .subm:hover {
        background: none;
    }

    .subms:hover {
        background: red !important;
    }

    .mg {
        width: 96px;
        height: 91px;
        padding: 22px;
        border-radius: 50px;
        background-image: linear-gradient(to right, var(--main-bg-lcolor), var(--main-bg-rcolor)) !important;
    }

    .subm:active {
        background: none;
        border: none !important;
        box-shadow: none;
    }

    .submit-button-one input:hover {
        background: #fff !important;
        color: green !important;
    }

    .linktype input {
        border: none;
    }

        .linktype input:hover {
            background: #fff !important;
            color: red !important;
            border: none !important;
        }

        .linktype input:active {
            background: none !important;
        }

    .back:focus {
        background: none !important;
    }

    .loadingio-spinner-gear-94vo528ab8 {
        width: 77%;
        height: 35px;
        overflow: hidden;
        border: 3px solid var(--main-bg-lcolor);
        text-align: center;
        position: relative;
        margin: auto;
    }

    .loader {
        color: grey;
        font-family: sans-serif;
        height: 35px;
        overflow-x: hidden;
        position: absolute;
        text-align: center;
        width: 100%;
    }

        .loader:before {
            animation: left-to-right 3s alternate infinite linear;
            background-image: linear-gradient(to right, var(--main-bg-lcolor), var(--main-bg-rcolor));
            content: "";
            height: 100%;
            left: 0;
            overflow: hidden;
            position: absolute;
            right: 0;
            top: 0;
        }

    @@keyframes left-to-right {
        0% {
            transform: translateX(-100%);
        }

        100% {
            transform: translateX(100%);
        }
    }

    .dark {
        font-family: 'Open Sans Condensed', sans-serif;
    }
</style>
@{
